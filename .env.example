HTTP_ADDR=:8080
REQUEST_TIMEOUT_SECONDS=10

MAX_BASE_URL=https://platform-api.max.ru
MAX_TOKEN=<MAX_BOT_TOKEN>
WEBHOOK_SECRET=CHANGE_ME_SECRET_2026
WEBHOOK_SECRET_HEADER=X-Max-Bot-Api-Secret

ONEC_BASE_URL=http://mock-onec:1080
ONEC_TOKEN=MOCK_ONEC_TOKEN

INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_TOKEN

# PostgreSQL
POSTGRES_PASSWORD=maxbot_password
DATABASE_URL=postgres://maxbot:maxbot_password@postgres:5432/maxbot?sslmode=disable

# Long polling (used by go run ./cmd/bot-polling)
POLLING_LIMIT=100
POLLING_TIMEOUT_SECONDS=30
POLLING_RETRY_SECONDS=5
POLLING_TYPES=message_created,message_callback,bot_started
