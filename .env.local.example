HTTP_ADDR=:8080
REQUEST_TIMEOUT_SECONDS=10

MAX_BASE_URL=https://platform-api.max.ru
MAX_TOKEN=CHANGE_ME_MAX_TOKEN
WEBHOOK_SECRET=CHANGE_ME_SECRET_2026
WEBHOOK_SECRET_HEADER=X-Max-Bot-Api-Secret

# Long polling для локального запуска без публичного webhook
MAX_POLLING_ENABLED=true
MAX_POLLING_LIMIT=100
MAX_POLLING_TIMEOUT_SECONDS=30
MAX_POLLING_TYPES=message_created,message_callback

# Укажите URL HTTP-сервиса 1С, доступный с этого ПК.
ONEC_BASE_URL=http://localhost:8081/hs/max
ONEC_TOKEN=CHANGE_ME_ONEC_TOKEN

INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_TOKEN

# Оставьте пустым для in-memory режима без PostgreSQL.
DATABASE_URL=
