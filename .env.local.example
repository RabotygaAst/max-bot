HTTP_ADDR=:8080
REQUEST_TIMEOUT_SECONDS=10

MAX_BASE_URL=http://localhost:1080
MAX_TOKEN=LOCAL_DEV_TOKEN
WEBHOOK_SECRET=CHANGE_ME_SECRET_2026
WEBHOOK_SECRET_HEADER=X-Max-Bot-Api-Secret

ONEC_BASE_URL=http://localhost:1080
ONEC_TOKEN=MOCK_ONEC_TOKEN

INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_TOKEN

# Leave empty for in-memory storage.
# For a local Windows PostgreSQL created by scripts/setup-postgres-local.ps1 use:
# DATABASE_URL=postgres://maxbot:maxbot_local_2026@localhost:5432/maxbot?sslmode=disable
DATABASE_URL=

POLLING_LIMIT=100
POLLING_TIMEOUT_SECONDS=30
POLLING_RETRY_SECONDS=5
POLLING_TYPES=message_created,message_callback,bot_started
