Процедура УдалитьЗаписиПоКлючамПомещений(НаборОбъемНачислений) Экспорт
	
	НаборОбъемНачислений.Прочитать();		
	СтрокиУдалить 							= Новый Массив;
	МассивКлючейПомещений 					= НаборОбъемНачислений.ДополнительныеСвойства["МассивКлючейПомещений"];
	Для Каждого СтрокаНабора ИЗ НаборОбъемНачислений Цикл
		Если МассивКлючейПомещений.Найти(СтрокаНабора.КлючПомещения) = Неопределено Тогда
			Продолжить;
		КонецЕсли;			
		СтрокиУдалить.Добавить(СтрокаНабора);
	КонецЦикла;
	
	Для Сч = 0 По СтрокиУдалить.ВГраница() Цикл
		НаборОбъемНачислений.Удалить(СтрокиУдалить[Сч]);
	КонецЦикла;
	
КонецПроцедуры

Процедура РассчитатьСуммы(СтрокНабора, ДопЧисло = 1) Экспорт
	
	ПовыщающийКоэффициент 							= Макс(1,СтрокНабора.ПовыщающийКоэффициент);	
	СтрокНабора.Сумма 								= Окр(СтрокНабора.ОбъемУслуги * СтрокНабора.ЗначениеТарифа,2)  * ДопЧисло * ПовыщающийКоэффициент + Окр(СтрокНабора.ОбъемУслугиПотери * СтрокНабора.ЗначениеТарифа,2);
	Если ПовыщающийКоэффициент > 1 Тогда
		СтрокНабора.СуммаПоПовышенномуКоэффициенту 	= Окр(СтрокНабора.ОбъемУслуги * СтрокНабора.ЗначениеТарифа,2) * (ПовыщающийКоэффициент - 1);
	КонецЕсли;
	
	Если СтрокНабора.ПроцентСниженияСтоимости > 0 Тогда
		СуммаСниженияСтоимости 				= СтрокНабора.Сумма * СтрокНабора.ПроцентСниженияСтоимости / 100;
		СтрокНабора.СуммаСниженияСтоимости  = СуммаСниженияСтоимости;
		СтрокНабора.Сумма 					= СтрокНабора.Сумма - СтрокНабора.СуммаСниженияСтоимости;
	КонецЕсли;
	
КонецПроцедуры

Процедура РассчитатьСуммуПоПотребленномуОбъему(СтрокНабора, ДопЧисло = 1)  Экспорт
	
	ПовыщающийКоэффициент 							= Макс(1,СтрокНабора.ПовыщающийКоэффициент);	
	СтрокНабора.Сумма 								= Окр(СтрокНабора.ОбъемУслугиПотребленный * СтрокНабора.ЗначениеТарифа,2) * ДопЧисло * ПовыщающийКоэффициент + + Окр(СтрокНабора.ОбъемУслугиПотребленныйПотери * СтрокНабора.ЗначениеТарифа,2);
	Если ПовыщающийКоэффициент > 1 Тогда
		СтрокНабора.СуммаПоПовышенномуКоэффициенту 	= Окр(СтрокНабора.ОбъемУслугиПотребленный * СтрокНабора.ЗначениеТарифа,2) * (ПовыщающийКоэффициент - 1);
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьНеЗначащиеЗаписи(Набор) Экспорт
	
	Регистратор = Набор.Отбор.Регистратор.Значение;
	ЭтоНачисление = ТипЗнч(Регистратор) = Тип("ДокументСсылка.энргНачисление");
	
	ДиапазонПоУмолчанию = Справочники.энргДиапазоныДифференцированныхТарифов.ДиапазонПоУмолчанию();
	//Справочники.энргДиапазоныДифференцированныхТарифов.НайтиПоНаименованию("Диапазон 1", Истина);
	
	ЭтоИндивидульныйРасчет = Набор.ДополнительныеСвойства.Свойство("ДанныеНабораДоЗаписи");
	
	ДобавитьВНачисленныйСредний = СоздатьНаборЗаписей();	
	
	Если НЕ ЭтоИндивидульныйРасчет Тогда 
		УдаленныеЗаписи = РегистрыСведений.энргТочкиУчетаСНулевымРасходом.СоздатьТаблицуЗначений();
	КонецЕсли;
	
	СтрокиУдалить 					= Новый Массив;

	ПоПриборам = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление.энргСпособНачислений.ПоПриборам");
	НачислениеПоСреднему = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление.энргСпособНачислений.НачислениеПоСреднему");
	СреднееПоНормативу = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление.энргСпособНачислений.СреднееПоНормативу");
	ПоФормуламРасчета = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление.энргСпособНачислений.ПоФормуламРасчета");
	ФиксированныйОбъем = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление.энргСпособНачислений.ФиксированныйОбъем");
	
	ДатаСменыПостановленияДобавлениеДиапазонов = Справочники.энргДиапазоныДифференцированныхТарифов.ДатаСменыПостановленияДобавлениеДиапазонов();
	
	Для Сч = 0 По Набор.Количество() -1 Цикл		
		
		СтрокаНабора = Набор[Сч];
		
		Если ЭтоНачисление и СтрокаНабора.ПериодНачисления >= ДатаСменыПостановленияДобавлениеДиапазонов Тогда
			СтрокаНабора.ДиапазонДифференцированногоТарифа = ДиапазонПоУмолчанию;
		КонецЕсли;
		
		Если СтрокаНабора.УслугаОграничена Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаНабора.ДоговорЗаключенДоТП Тогда
			СтрокиУдалить.Добавить(СтрокаНабора);
			Продолжить;
		КонецЕсли;
		
		Если СтрокаНабора.Поставщик = СтрокаНабора.ФизЛицо Тогда
			СтрокиУдалить.Добавить(СтрокаНабора);
			Продолжить;
		КонецЕсли;
				
		Если СтрокаНабора.Техническая Тогда
			СтрокаНабора.ОбъемУслугиТехнический = СтрокаНабора.ОбъемУслуги;
			СтрокаНабора.ОбъемУслуги 			= 0;
		КонецЕсли;   		
		
		Если СтрокаНабора.СпособНачисления = ПоПриборам
			И СтрокаНабора.СниматьНачисленныйСредний И Не СтрокаНабора.УслугаПолностьюОприборена Тогда
			
			СтрокиУдалить.Добавить(СтрокаНабора);
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ДобавитьВНачисленныйСредний.Добавить(), СтрокаНабора);
		
		Если СтрокаНабора.СпособНачисления = ПоПриборам
			И СтрокаНабора.СниматьНачисленныйСредний Тогда
			СтрокиУдалить.Добавить(СтрокаНабора);			
		ИначеЕсли СтрокаНабора.СпособНачисления = ПоПриборам
			И СтрокаНабора.СниматьНачисленныйСреднийЗависимыхТочек Тогда
			СтрокиУдалить.Добавить(СтрокаНабора);			
		ИначеЕсли СтрокаНабора.СпособНачисления = ПоПриборам Тогда
			Продолжить;
		ИначеЕсли СтрокаНабора.СпособНачисления = НачислениеПоСреднему Тогда
			Продолжить;
		ИначеЕсли СтрокаНабора.СпособНачисления = СреднееПоНормативу Тогда
			Продолжить;	
		ИначеЕсли СтрокаНабора.СпособНачисления = ПоФормуламРасчета Тогда
			Продолжить;	
		ИначеЕсли СтрокаНабора.СпособНачисления = ФиксированныйОбъем Тогда
			Продолжить;
		ИначеЕсли  
			СтрокаНабора.ОбъемУслуги = 0 И СтрокаНабора.ОбъемУслугиПотребленный = 0 
			И СтрокаНабора.Сумма = 0 и СтрокаНабора.СуммаПоПовышенномуКоэффициенту = 0 Тогда
			СтрокиУдалить.Добавить(СтрокаНабора);
		КонецЕсли;		
	КонецЦикла;
	
	Для Сч = 0 По СтрокиУдалить.ВГраница() Цикл
		
		СтрокаКУдалению = СтрокиУдалить[Сч];		
		Если НЕ ЭтоИндивидульныйРасчет И НЕ СтрокаКУдалению.ДоговорЗаключенДоТП Тогда
			НоваяСтрока = УдаленныеЗаписи.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаКУдалению);
		КонецЕсли; 	
		
		Набор.Удалить(СтрокиУдалить[Сч]);
		
	КонецЦикла;	
	
	Набор.ДополнительныеСвойства.Вставить("ОтложенныеНачисленияПоПриборам", ДобавитьВНачисленныйСредний);
	
	Если НЕ ЭтоИндивидульныйРасчет Тогда 
		Набор.ДополнительныеСвойства.Вставить("УдаленныеЗаписи", УдаленныеЗаписи);
	КонецЕсли;  	
	
КонецПроцедуры

Функция РезультатНачисленныйСреднийОбъем(тзНабор) Экспорт 
	
	Запрос  = Новый Запрос(ТекстЗапросаДанныеНачисленныйСреднийОбъем());
	Запрос.УстановитьПараметр("НаборОтложенные", тзНабор);
	МВТ = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция ОтложенныеНачисленияПоПриборамДляСписания(тзНабор) Экспорт
	Запрос  = Новый Запрос(ТекстЗапросаДанныеНачисленныйСреднийОбъемДляСписания());
	Запрос.УстановитьПараметр("НаборОтложенные", тзНабор);
	Возврат Запрос.Выполнить();

КонецФункции

