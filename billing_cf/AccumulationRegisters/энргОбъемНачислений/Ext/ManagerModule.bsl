#Область СлужебныйПрограммныйИнтерфейс

#Область ПередачаДанныхВБухгалетерию

Процедура НаборЗаписейДляПередачиДанныхПоФактическойСезонности(Схема,Параметры) Экспорт
	
	Если Схема = Неопределено Тогда
		Схема  	= Новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе	
		Пакет  = Схема.ПакетЗапросов.Добавить();
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаОбъемыДляПередачиДанныхВБухгалтериюПоФактическомуОбъему());
	  	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаНаборЗаписейЗаПериод()
	
	Текст =
	"ВЫБРАТЬ
	|	ОбъемНачислений.*
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений КАК ОбъемНачислений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.энргОбъемНачислений.Обороты(, , Запись, ) КАК ОбъемНачисленийОбороты
	|		ПО ОбъемНачислений.Период = ОбъемНачисленийОбороты.Период
	|			И ОбъемНачислений.Регистратор = ОбъемНачисленийОбороты.Регистратор
	|			И ОбъемНачислений.НомерСтроки = ОбъемНачисленийОбороты.НомерСтроки";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаЗаполнитьСхемуНаборомЗаписей()
	
	Текст =
	"ВЫБРАТЬ
	|	ОбъемНачислений.*
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений КАК ОбъемНачислений";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаЗаполнитьСхемуНаборомЗаписейБезСторно()
	
	Текст =
	"ВЫБРАТЬ
	|	ОбъемНачисленийПолный.*
	|ИЗ
	|	ОбъемНачисленийПолный КАК ОбъемНачисленийПолный
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОбъемНачисленийПолный КАК ОбъемНачисленийПолныйПрав
	|		ПО ОбъемНачисленийПолный.НомерСтроки = ОбъемНачисленийПолныйПрав.НомерСторнируемойСтроки
	|ГДЕ
	|	ОбъемНачисленийПолныйПрав.НомерСтроки ЕСТЬ NULL
	|	И НЕ ОбъемНачисленийПолный.ЭтоСторно";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаНаборЗаписейПоПомещениюДоЗаписи()
	
	Текст  =
	"ВЫБРАТЬ
	|	Набор.*
	|ПОМЕСТИТЬ ВТ_СтрокиПомещения
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений КАК Набор
	|ГДЕ
	|	Набор.Регистратор = &Регистратор
	|	И Набор.Организация = &Организация
	|	И Набор.Район = &Район
	|	И НЕ Набор.Распределение
	|	И Набор.Строение = &Строение
	|	И Набор.Помещение В(&Помещение)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_СтрокиПомещения.*
	|ИЗ
	|	ВТ_СтрокиПомещения КАК ВТ_СтрокиПомещения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтрокиПомещения КАК ВТ_СтрокиПомещенияПрав
	|		ПО ВТ_СтрокиПомещения.НомерСтроки = ВТ_СтрокиПомещенияПрав.НомерСторнируемойСтроки
	|ГДЕ
	|	ВТ_СтрокиПомещенияПрав.Организация ЕСТЬ NULL
	|	И НЕ ВТ_СтрокиПомещения.ЭтоСторно";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаОбъемыДляПередачиДанныхВБухгалтериюПоФактическомуОбъему()
	
	Текст  =
	"ВЫБРАТЬ
	|	энргОбъемНачислений.Период КАК Период,
	|	энргОбъемНачислений.Организация КАК Организация,
	|	энргОбъемНачислений.Район КАК Район,
	|	энргОбъемНачислений.Абонент КАК Абонент,
	|	энргОбъемНачислений.ПериодНачисления КАК ПериодНачисления,
	|	энргОбъемНачислений.Услуга КАК Услуга,
	|	энргОбъемНачислений.ЗначениеТарифа КАК ЗначениеТарифа,
	|	энргОбъемНачислений.ТарифнаяГруппа КАК ТарифнаяГруппа,
	|	ВЫБОР
	|		КОГДА НЕ энргОбъемНачислений.БылУстановленныйПриборВЭтомГоду
	|			ТОГДА энргОбъемНачислений.ОбъемУслуги
	|		ИНАЧЕ энргОбъемНачислений.ОбъемУслугиПотребленный
	|	КОНЕЦ КАК ОбъемУслуги,
	|	ВЫБОР
	|		КОГДА НЕ энргОбъемНачислений.БылУстановленныйПриборВЭтомГоду
	|			ТОГДА энргОбъемНачислений.ОбъемУслуги
	|		ИНАЧЕ энргОбъемНачислений.ОбъемУслугиПотребленный
	|	КОНЕЦ * энргОбъемНачислений.ЗначениеТарифа КАК Сумма
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
	|ГДЕ
	|	НЕ энргОбъемНачислений.СпособНачисления = ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.КорректировкаСезонныхУслуг)";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаДанныеНачисленныйСреднийОбъем()
	Текст = 
	"ВЫБРАТЬ
	|	Набор.Период КАК Период,
	|	Набор.Район КАК Район,
	|	Набор.Организация КАК Организация,
	|	ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.энргСпособНачислений.ПоФормуламРасчета) КАК СпособНачисления,
	|	ВЫБОР
	|		КОГДА Набор.ВладелецЗависимойТочкиУчета = ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка)
	|			ТОГДА Набор.Абонент
	|		ИНАЧЕ Набор.ВладелецЗависимойТочкиУчета
	|	КОНЕЦ КАК Абонент,
	|	Набор.Услуга КАК Услуга,
	|	Набор.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	Набор.ЗависимаяТочкаУчета КАК ТочкаУчета,
	|	ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПУстаяСсылка) КАК ПриборУчета,
	|	ЗНАЧЕНИЕ(СПравочник.энргШкалыПриборовУчета.ПустаяСсылка) КАК Шкала,
	|	ЗНАЧЕНИЕ(СПравочник.энргТарифныеЗоны.БезРазбивки) КАК ТарифнаяЗона,
	|	Набор.ЗначениеТарифа КАК ЗначениеТарифа,
	|	Набор.ТарифнаяГруппа КАК ТарифнаяГруппа,
	|	-ВЫБОР
	|		КОГДА Набор.Техническая
	|			ТОГДА Набор.ОбъемУслугиТехнический
	|		ИНАЧЕ Набор.ОбъемУслуги
	|	КОНЕЦ * Набор.КоэффициентФормула КАК ОбъемУслуги,
	|	-Набор.ОбъемУслугиПотребленный * Набор.КоэффициентФормула КАК ОбъемУслугиПотребленный,
	|	-Набор.ОбъемУслугиПотери * Набор.КоэффициентФормула КАК ОбъемУслугиПотери,
	|	-Набор.ОбъемУслугиПотребленныйПотери * Набор.КоэффициентФормула КАК ОбъемУслугиПотребленныйПотери,
	|	-Набор.Сумма * Набор.КоэффициентФормула КАК Сумма,
	|	Набор.Поставщик КАК Поставщик,
	|	Набор.Строение КАК Строение,
	|	Набор.Помещение КАК Помещение,
	|	Набор.ЧастныйСектор КАК ЧастныйСектор,
	|	Набор.ПериодНачисления КАК ПериодНачисления,
	|	Набор.СниматьНачисленныйСреднийПоФормулам КАК СниматьНачисленныйСреднийПоФормулам,
	|	Набор.СниматьНачисленныйСредний КАК СниматьНачисленныйСредний,
	|	Набор.СниматьНачисленныйСреднийЗависимыхТочек КАК СниматьНачисленныйСреднийЗависимыхТочек,
	|	Набор.КоэффициентФормула КАК КоэффициентФормула,
	|	ЛОЖЬ КАК ИзменятьВзаиморасчеты,
	|	Набор.СверхНорматива КАК СверхНорматива,
	|	Набор.ВидБлагоустройства КАК ВидБлагоустройства,
	|	Набор.ДиапазонДифференцированногоТарифа КАК ДиапазонДифференцированногоТарифа,
	|	Набор.НормаПотребления КАК НормаПотребления
	|ПОМЕСТИТЬ Промежуточная_СниматьНачисленныйСреднийПоФормулам
	|ИЗ
	|	&НаборОтложенные КАК Набор
	|ГДЕ
	|	(НЕ Набор.Сумма = 0
	|			ИЛИ НЕ Набор.ОбъемУслуги = 0
	|			ИЛИ НЕ Набор.ОбъемУслугиПотребленный = 0)
	|	И Набор.СниматьНачисленныйСреднийПоФормулам
	|	И Набор.СпособНачисления = ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.ПоПриборам)
	|	И НЕ Набор.ЗависимаяТочкаУчета = ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Набор.СоставнаяУслуга КАК СоставнаяУслуга,
	|	Набор.ЗависимаяТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ВТдляВсехСоставныхУслуг
	|ИЗ
	|	&НаборОтложенные КАК Набор
	|ГДЕ
	|	НЕ Набор.СоставнаяУслуга = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТдляВсехСоставныхУслуг.СоставнаяУслуга КАК СоставнаяУслуга,
	|	ВТдляВсехСоставныхУслуг.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ВТдляСоставныхУслуг
	|ИЗ
	|	ВТдляВсехСоставныхУслуг КАК ВТдляВсехСоставныхУслуг
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Промежуточная_СниматьНачисленныйСреднийПоФормулам КАК СниматьНачисленныйСреднийПоФормулам1
	|		ПО ВТдляВсехСоставныхУслуг.ТочкаУчета = СниматьНачисленныйСреднийПоФормулам1.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Набор.СоставнаяУслуга КАК СоставнаяУслуга,
	|	Набор.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ СгруппированныеТУ
	|ИЗ
	|	ВТдляСоставныхУслуг КАК Набор
	|
	|СГРУППИРОВАТЬ ПО
	|	Набор.СоставнаяУслуга,
	|	Набор.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТдляСоставныхУслуг.ТочкаУчета КАК ТочкаУчета,
	|	энргВидыУслугСоставляющиеУслуг.Услуга КАК Услуга
	|ПОМЕСТИТЬ ТУ_Услуги
	|ИЗ
	|	ВТдляСоставныхУслуг КАК ВТдляСоставныхУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|		ПО ВТдляСоставныхУслуг.СоставнаяУслуга = энргВидыУслугСоставляющиеУслуг.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТдляСоставныхУслуг.ТочкаУчета,
	|	энргВидыУслугСоставляющиеУслуг.Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Набор.Строение КАК Строение,
	|	Набор.Помещение КАК Помещение,
	|	Набор.ВидБлагоустройства КАК ВидБлагоустройства,
	|	Набор.НормаПотребления КАК НормаПотребления,
	|	Набор.ТарифнаяГруппа КАК ТарифнаяГруппа,
	|	Набор.ЗначениеТарифа КАК ЗначениеТарифа,
	|	Набор.ТочкаУчета КАК ТочкаУчета,
	|	Набор.Услуга КАК Услуга,
	|	ЗНАЧЕНИЕ(СПравочник.энргШкалыПриборовУчета.ПустаяСсылка) КАК Шкала,
	|	Набор.ТарифнаяЗона КАК ТарифнаяЗона
	|ПОМЕСТИТЬ ВТдляВсехТУ
	|ИЗ
	|	&НаборОтложенные КАК Набор
	|ГДЕ
	|	Набор.ЗависимаяТочкаУчета = ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТдляВсехТУ.Строение КАК Строение,
	|	ВТдляВсехТУ.Помещение КАК Помещение,
	|	МАКСИМУМ(ВТдляВсехТУ.ТарифнаяГруппа) КАК ТарифнаяГруппа,
	|	МАКСИМУМ(ВТдляВсехТУ.ЗначениеТарифа) КАК ЗначениеТарифа,
	|	МАКСИМУМ(ВТдляВсехТУ.ВидБлагоустройства) КАК ВидБлагоустройства,
	|	МАКСИМУМ(ВТдляВсехТУ.НормаПотребления) КАК НормаПотребления,
	|	ВТдляВсехТУ.ТочкаУчета КАК ТочкаУчета,
	|	ВТдляВсехТУ.Услуга КАК Услуга,
	|	ВТдляВсехТУ.Шкала КАК Шкала,
	|	ВТдляВсехТУ.ТарифнаяЗона КАК ТарифнаяЗона
	|ПОМЕСТИТЬ ВТдляВсехТУСгруппированная
	|ИЗ
	|	ВТдляВсехТУ КАК ВТдляВсехТУ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТдляВсехТУ.Строение,
	|	ВТдляВсехТУ.Помещение,
	|	ВТдляВсехТУ.ТочкаУчета,
	|	ВТдляВсехТУ.Услуга,
	|	ВТдляВсехТУ.Шкала,
	|	ВТдляВсехТУ.ТарифнаяЗона
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.Период КАК Период,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.Район КАК Район,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.Организация КАК Организация,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.СпособНачисления КАК СпособНачисления,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.Абонент КАК Абонент,
	|	ЕСТЬNULL(СгруппированныеТУ.Услуга, Промежуточная_СниматьНачисленныйСреднийПоФормулам.Услуга) КАК Услуга,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.ТочкаУчета КАК ТочкаУчета,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.ПриборУчета КАК ПриборУчета,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.Шкала КАК Шкала,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ЕСТЬNULL(ВТдляВсехТУСгруппированная.ЗначениеТарифа, Промежуточная_СниматьНачисленныйСреднийПоФормулам.ЗначениеТарифа) КАК ЗначениеТарифа,
	|	ЕСТЬNULL(ВТдляВсехТУСгруппированная.ТарифнаяГруппа, Промежуточная_СниматьНачисленныйСреднийПоФормулам.ТарифнаяГруппа) КАК ТарифнаяГруппа,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.ОбъемУслуги КАК ОбъемУслуги,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.ОбъемУслугиПотребленный КАК ОбъемУслугиПотребленный,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.ОбъемУслугиПотери КАК ОбъемУслугиПотери,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.ОбъемУслугиПотребленныйПотери КАК ОбъемУслугиПотребленныйПотери,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.Сумма КАК Сумма,
	|	Промежуточная_СниматьНачисленныйСреднийПоФормулам.Поставщик КАК Поставщик,
	|	ЕСТЬNULL(ВТдляВсехТУСгруппированная.Строение, Промежуточная_СниматьНачисленныйСреднийПоФормулам.Строение) КАК Строение,
	|	ЕСТЬNULL(ВТдляВсехТУСгруппированная.Помещение, Промежуточная_СниматьНачисленныйСреднийПоФормулам.Помещение) КАК Помещение,
