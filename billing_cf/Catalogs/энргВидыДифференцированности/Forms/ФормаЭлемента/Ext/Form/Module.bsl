
#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Элементы.СтраницаФормулыРасчета.Видимость = Объект.ИспользоватьФормулуРасчета;
	
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовФормы

&НаКлиенте
Процедура ИспользоватьФормулуРасчетаПриИзменении(Элемент)
	Элементы.СтраницаФормулыРасчета.Видимость = Объект.ИспользоватьФормулуРасчета;
КонецПроцедуры 

#КонецОбласти

#Область СобытияТабличнойЧастиУслуги

&НаКлиенте
Процедура УслугиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	ТекДанные 								= Элементы.Услуги.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Копирование Тогда
		СтрокиФормулы						= Объект.ФормулыРасчетаУслуг.НайтиСтроки(Новый Структура("IDСтроки", ТекДанные.IDСтроки));
		ТекДанные.IDСтроки 					= Новый УникальныйИдентификатор;
		Для Каждого СтрокаФормулы Из СтрокиФормулы Цикл
			НоваяСтрока  					= Объект.ФормулыРасчетаУслуг.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаФормулы);
			НоваяСтрока.IDСтроки 			= ТекДанные.IDСтроки;
		КонецЦикла;
		
		// энргРаботаСВидомДифференцированности {
		энргРаботаСФормуламиРасчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ФормулыРасчетаУслуг,ТекДанные); 
		// энргРаботаСВидомДифференцированности }
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура УслугиПриАктивизацииСтроки(Элемент)
	ТекДанные 								= Элементы.Услуги.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// энргРаботаСВидомДифференцированности {
	энргРаботаСФормуламиРасчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ФормулыРасчетаУслуг,ТекДанные); 
	// энргРаботаСВидомДифференцированности }

КонецПроцедуры

&НаКлиенте
Процедура УслугиУслугаПриИзменении(Элемент)
	
	ТекДанные  					= Элементы.Услуги.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СоставУслуги 				= энргРаботаСПоставщикамиСервер.ПолучитьСоставУслуги(ТекДанные.Услуга);
	СтрокиФормулы				= Объект.ФормулыРасчетаУслуг.НайтиСтроки(Новый Структура("IDСтроки",ТекДанные.IDСтроки));
	УслугиДобавить 				= ОбщегоНазначенияКлиентСервер.СкопироватьМассив(СоставУслуги);
	СтрокиУдалить  				= Новый Массив;
	Для Каждого СтрокаФормулы Из СтрокиФормулы Цикл
		ИндексУдалить 			= УслугиДобавить.Найти(СтрокаФормулы.Услуга);
		Если СоставУслуги.Найти(СтрокаФормулы.Услуга) = Неопределено Тогда
			СтрокиУдалить.Добавить(СтрокаФормулы);			
		КонецЕсли;
		Если Не ИндексУдалить = Неопределено Тогда
			УслугиДобавить.Удалить(ИндексУдалить);
		КонецЕсли;		
	КонецЦикла;
	
	Для Каждого СтрокаУдалить Из СтрокиУдалить Цикл
		 Объект.ФормулыРасчетаУслуг.Удалить(СтрокаУдалить);
	 КонецЦикла; 
	 
	 Для Каждого УслугаДобавить Из УслугиДобавить Цикл
		СтрокаУслуги 			= Объект.ФормулыРасчетаУслуг.Добавить();
		СтрокаУслуги.Услуга 	= УслугаДобавить;
		СтрокаУслуги.IDСтроки 	= ТекДанные.IDСтроки;
	КонецЦикла; 
	
КонецПроцедуры

#КонецОбласти

#Область СобытияТабличнойЧастиФормулыРасчетаУслуг

&НаКлиенте
Процедура ФормулыРасчетаУслугФормулаРасчетаПредставлениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
		
	ТекущиеДанныеТочкиУчета 	= Элементы.Услуги.ТекущиеДанные;
	ТекущиеДанные 				= Элементы.ФормулыРасчетаУслуг.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено ИЛИ  ТекущиеДанныеТочкиУчета = Неопределено Тогда
		Возврат;
	КонецЕсли;
	     	
	ТарифныеЗоны 				= Новый Массив;
	
	Для Каждого СтрокаТарифнойЗоны Из Объект.ТарифныеЗоны Цикл
		ТарифныеЗоны.Добавить(СтрокаТарифнойЗоны.ТарифнаяЗона);
	КонецЦикла;	
	
	Оповещение 					= Новый ОписаниеОповещения("НастройкаФормулыРасчетаЗавершение",ЭтаФорма,Новый Структура("КлючСтроки", Элементы.ФормулыРасчетаУслуг.ТекущаяСтрока));
	ПараметрыФормы 				= Новый Структура;
	ПараметрыФормы.Вставить("Услуга", 			ТекущиеДанные.Услуга);
	ПараметрыФормы.Вставить("ТарифныеЗоны", 	ТарифныеЗоны);
	
	ОткрытьФорму("ОбщаяФорма.энргНастройкаФормулРасчета",ПараметрыФормы,,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаФормулыРасчетаЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт 
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТипЗнч(РезультатЗакрытия) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не РезультатЗакрытия.Свойство("ПредставлениеФормулы") ИЛИ Не РезультатЗакрытия.Свойство("ФормулаРасчета") Тогда
		Возврат;
	КонецЕсли;
	
	КлючСтроки  								= ДополнительныеПараметры.КлючСтроки;
	ТекущиеДанные  								= Объект.ФормулыРасчетаУслуг.НайтиПоИдентификатору(КлючСтроки);
	ТекущиеДанные.ФормулаРасчетаПредставление 	= РезультатЗакрытия.ПредставлениеФормулы;
	ТекущиеДанные.ФормулаРасчета 				= РезультатЗакрытия.ФормулаРасчета;
	
КонецПроцедуры


#КонецОбласти

