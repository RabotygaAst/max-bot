Функция ЗначенияСвойствОбъекта(ДоговорСсылка, ПолучаемыеСвойства) Экспорт 
	
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДоговорСсылка, ПолучаемыеСвойства); 
	
КонецФункции

Функция НайтиДействующийДоговорПоПараметрам(Организация, Район, Контрагент, ДатаОкончанияДействия) Экспорт 
	
	Запрос 			= Новый Запрос;
	Запрос.Текст 	= 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДоговорыКонтрагентов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.энргДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	НЕ ДоговорыКонтрагентов.ПометкаУдаления
	|	И (ДоговорыКонтрагентов.ДатаОкончанияДействия >= &ДатаОкончанияДействия
	|			ИЛИ ДоговорыКонтрагентов.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))
	|	И ДоговорыКонтрагентов.ДатаНачалаДействия <= &ДатаОкончанияДействия
	|	И (ДоговорыКонтрагентов.Статус <> ЗНАЧЕНИЕ(Перечисление.бестСтатусыДоговоровКонтрагентов.Закрыт)
	|			ИЛИ ДоговорыКонтрагентов.ДатаОкончанияДействия <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))
	|	И ДоговорыКонтрагентов.Организация = &Организация
	|	И ДоговорыКонтрагентов.Район = &Район
	|	И ДоговорыКонтрагентов.Контрагент = &Контрагент";
	
	Запрос.УстановитьПараметр("ДатаОкончанияДействия",	ДатаОкончанияДействия);
	Запрос.УстановитьПараметр("Контрагент",	 			Контрагент);
	Запрос.УстановитьПараметр("Организация", 			Организация);
	Запрос.УстановитьПараметр("Район",		 			Район);
		
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда		
		Возврат ПустаяСсылка();
	КонецЕсли;	
	
	Выборка 		= РезультатЗапроса.Выбрать();	
	Выборка.Следующий(); 	
	Возврат Выборка.Ссылка; 	
	
КонецФункции

Процедура ЗаполнитьОбъектПоОписанию(ДоговорСсылка, ОписаниеОбъекта, НомерДоговора, ЭтоНоваяСсылка) Экспорт
	ДоговорОбъект = ИнициализироватьОбъект(ДоговорСсылка, ЭтоНоваяСсылка);
	
	ЕстьИзменения = Ложь;
	ЗаполнитьИзмененияОбъекта(ДоговорОбъект, ОписаниеОбъекта, НомерДоговора, ЭтоНоваяСсылка); 	
	ПопытатьсяЗаписатьИзменения(ДоговорОбъект, ЕстьИзменения);	 	
КонецПроцедуры

Функция СсылкаПоКлючевымПараметрам(Организация, Район, Контрагент) Экспорт 			
	Запрос  		= Новый Запрос;	
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.УстановитьПараметр("Контрагент",		Контрагент);	
		
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргДоговорыКонтрагентов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|ГДЕ
	|	энргДоговорыКонтрагентов.Организация = &Организация
	|	И энргДоговорыКонтрагентов.Район = &Район
	|	И энргДоговорыКонтрагентов.Контрагент = &Контрагент";
	РезультатЗапроса			= Запрос.Выполнить();
	Выборка 					= РезультатЗапроса.Выбрать(); 
	Если Выборка.Следующий() тогда
		Возврат Выборка.ссылка; 
	КонецЕсли;
	
	Возврат Справочники.энргДоговорыКонтрагентов.ПустаяСсылка();	
КонецФункции

