Функция МассивСсылокПолнотекстовогоПоиска(СтрокаПоиска) Экспорт 
	перем РезультатЗапроса;
		
	мСтрокиПоиска 		= СтрРазделить(СтрокаПоиска," ",Ложь);
	Схема 				= Новый СхемаЗапроса();
	Схема.УстановитьТекстЗапроса(ТекстЗапросаПолнотекстовыйПоиск());
	Пакет 				= Схема.ПакетЗапросов[0];
	Оператор 			= Пакет.Операторы[0];
	Отбор	 			= Оператор.Отбор;
	ОтборЭталон 		= Отбор[0];
	Для Индекс = 1 По мСтрокиПоиска.ВГраница() Цикл
		Отбор.Добавить(СтрЗаменить(ОтборЭталон, "&СтрокаПоиска1","&СтрокаПоиска" + (Индекс+1)));
	КонецЦикла;
	
	Запрос  			= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Для Индекс = 0 По мСтрокиПоиска.ВГраница() Цикл
		Запрос.УстановитьПараметр("СтрокаПоиска" + (Индекс+1), мСтрокиПоиска[Индекс]);
	КонецЦикла;
	
	РезультатЗапроса 	= Запрос.Выполнить();
			
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

#КонецОбласти

 #Область СлужебныеПроцедурыИФункции

Функция ИнициализироватьОбъект(ДоговорСсылка, ЭтоНоваяСсылка)
	Если ЭтоНоваяСсылка Тогда
		ДоговорОбъект 	= СоздатьЭлемент();
		ДоговорОбъект.УстановитьСсылкуНового(ДоговорСсылка);
	Иначе
		ДоговорОбъект 	= ДоговорСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	Возврат ДоговорОбъект;
КонецФункции

Процедура ЗаполнитьИзмененияОбъекта(ДоговорОбъект, ОписаниеОбъекта, НомерДоговора, ЭтоНоваяСсылка)
	Если НЕ ДоговорОбъект.Организация = ОписаниеОбъекта.Организация Тогда 
		ДоговорОбъект.Организация 						= ОписаниеОбъекта.Организация;
		ЕстьИзменения									= Истина;
	КонецЕсли;
	
	Если НЕ ДоговорОбъект.Район = ОписаниеОбъекта.Район Тогда 
		ДоговорОбъект.Район 							= ОписаниеОбъекта.Район;
		ЕстьИзменения									= Истина;
	КонецЕсли;
	
	Если НЕ ДоговорОбъект.СпособЗаключенияДоговора = ОписаниеОбъекта.СпособЗаключенияДоговора Тогда 
		ДоговорОбъект.СпособЗаключенияДоговора 			= ОписаниеОбъекта.СпособЗаключенияДоговора;
		ЕстьИзменения									= Истина;
	КонецЕсли;
	
	Если НЕ ДоговорОбъект.Публичный = ОписаниеОбъекта.Публичный Тогда 
		ДоговорОбъект.Публичный 						= ОписаниеОбъекта.Публичный;
		ЕстьИзменения									= Истина;
	КонецЕсли;
	
	Если НЕ ДоговорОбъект.НачислениеПени = ОписаниеОбъекта.НачислениеПени Тогда 
		ДоговорОбъект.НачислениеПени 					= ОписаниеОбъекта.НачислениеПени;
		ЕстьИзменения									= Истина;
	КонецЕсли; 	
	
		
	Если ЭтоНоваяСсылка Тогда  
		ДоговорОбъект.Номер 							= НомерДоговора;
	КонецЕсли;
КонецПроцедуры

Процедура ПопытатьсяЗаписатьИзменения(ДоговорОбъект, ЕстьИзменения)
	Если Не ЕстьИзменения Тогда
		Возврат;
	КонецЕсли;
		
	Попытка
		ДоговорОбъект.Записать();		
	Исключение
		
	КонецПопытки;
КонецПроцедуры

#Область ТекстыЗапросов

Функция ТекстЗапросаПолнотекстовыйПоиск()
	Текст  = 
	"ВЫБРАТЬ
	|	энргДоговорыКонтрагентов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
	|		ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагенты.Ссылка
	|ГДЕ
	|	(энргДоговорыКонтрагентов.Номер ПОДОБНО ""%"" + &СтрокаПоиска1 + ""%""
	|			ИЛИ энргДоговорыКонтрагентов.Наименование ПОДОБНО ""%"" + &СтрокаПоиска1 + ""%""
	|			ИЛИ ЕСТЬNULL(энргКонтрагенты.Наименование, """") ПОДОБНО ""%"" + &СтрокаПоиска1 + ""%""
	|			ИЛИ ЕСТЬNULL(энргКонтрагенты.ИНН, """") ПОДОБНО ""%"" + &СтрокаПоиска1 + ""%"")";
	
	Возврат Текст;
	
КонецФункции

