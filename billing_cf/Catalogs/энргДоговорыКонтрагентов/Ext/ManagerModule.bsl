#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)
	Перем СтрокаПоиска, Организация, Район, ТипДоговора, ВидДоговора, ГруппаФинансирования;
	
	Если Не Параметры.Свойство("СтрокаПоиска", СтрокаПоиска) Тогда 
		Возврат;
	КонецЕсли;
	
	Параметры.Свойство("Организация", 		 	Организация);
	Параметры.Свойство("Район", 				Район);
	Параметры.Свойство("ТипДоговора", 		 	ТипДоговора);
	Параметры.Свойство("ВидДоговора", 		 	ВидДоговора);
	Параметры.Свойство("ГруппаФинансирования", 	ГруппаФинансирования);

	Если ЗначениеЗаполнено(Организация) ИЛИ ЗначениеЗаполнено(Район) ИЛИ ЗначениеЗаполнено(ТипДоговора) 
			ИЛИ ЗначениеЗаполнено(ВидДоговора) ИЛИ ЗначениеЗаполнено(ГруппаФинансирования) Тогда
			
		СтандартнаяОбработка = Ложь;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	энргДоговорыКонтрагентов.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
			|ГДЕ
			|	НЕ энргДоговорыКонтрагентов.ПометкаУдаления
			|	И энргДоговорыКонтрагентов.Организация = &Организация
			|	И (энргДоговорыКонтрагентов.Наименование ПОДОБНО &Наименование
			|			ИЛИ энргДоговорыКонтрагентов.Номер ПОДОБНО &Наименование)
			|	И энргДоговорыКонтрагентов.Район = &Район
			|	И энргДоговорыКонтрагентов.ТипДоговора = &ТипДоговора
			|	И энргДоговорыКонтрагентов.ВидДоговора = &ВидДоговора
			|	И энргДоговорыКонтрагентов.ГруппаФинансирования = &ГруппаФинансирования";
		
		Запрос.УстановитьПараметр("Наименование", Параметры.СтрокаПоиска + "%");
		
		Если ЗначениеЗаполнено(Организация) Тогда
			Запрос.УстановитьПараметр("Организация", Организация);
		Иначе
		    Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргДоговорыКонтрагентов.Организация = &Организация", "");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Район) Тогда
			Запрос.УстановитьПараметр("Район", Район);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргДоговорыКонтрагентов.Район = &Район", "");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТипДоговора) Тогда
			Запрос.УстановитьПараметр("ТипДоговора", ТипДоговора);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргДоговорыКонтрагентов.ТипДоговора = &ТипДоговора", "");
		КонецЕсли;

		Если ЗначениеЗаполнено(ВидДоговора) Тогда
			Запрос.УстановитьПараметр("ВидДоговора", ВидДоговора);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргДоговорыКонтрагентов.ВидДоговора = &ВидДоговора", "");
		КонецЕсли;

		Если ЗначениеЗаполнено(ГруппаФинансирования) Тогда
			Запрос.УстановитьПараметр("ГруппаФинансирования", ГруппаФинансирования);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргДоговорыКонтрагентов.ГруппаФинансирования = &ГруппаФинансирования", "");
		КонецЕсли;
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ДанныеВыбора = Новый СписокЗначений;
		ДанныеВыбора.ЗагрузитьЗначения(РезультатЗапроса.Выгрузить().ВыгрузитьКолонку(0));

	КонецЕсли;
КонецПроцедуры

#КонецОбласти 

