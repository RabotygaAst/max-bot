#Область ОбработчикиСобытий

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Перем Период, Район,Организация,КлючПомещения,ТочкаУчета,ТипыСредствИзмерений;
	
	Если Параметры.Свойство("Период") Тогда
		Период 				= Параметры.Период;
	КонецЕсли;
	
	Если Параметры.Свойство("Район") Тогда
		Район 				= Параметры.Район;
	КонецЕсли;
	
	Если Параметры.Свойство("Организация") Тогда
		Организация 		= Параметры.Организация;
	КонецЕсли;
	
	Если Параметры.Свойство("КлючПомещения") Тогда
		КлючПомещения 		= Параметры.КлючПомещения;
	КонецЕсли;
	
	Если Параметры.Свойство("ТочкаУчета") Тогда
		ТочкаУчета 			= Параметры.ТочкаУчета;
	КонецЕсли;
	
	Если Параметры.Свойство("ТипыСредствИзмерений") Тогда
		ТипыСредствИзмерений= Параметры.ТипыСредствИзмерений;
	КонецЕсли; 
	
	Если НЕ Район = Неопределено 
		И НЕ Организация = Неопределено
		И НЕ КлючПомещения = Неопределено
		И НЕ КлючПомещения = Неопределено
		И НЕ ТочкаУчета = Неопределено Тогда
		
		мПриборыУчета		= энргСостояниеПриборовУчета.ДействующиеПриборыУчетаПомещения(Период,Организация, Район, КлючПомещения, ТочкаУчета).Выгрузить().ВыгрузитьКолонку("ПриборУчета");
		 					
		ПриборыСписок		= Новый СписокЗначений;
		ПриборыСписок.ЗагрузитьЗначения(мПриборыУчета);
		
		// накладываем отбор на точки динамический список
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список,"Ссылка",ПриборыСписок,ВидСравненияКомпоновкиДанных.ВСписке,,Истина,РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный);
	КонецЕсли;
	
	Если НЕ ТипыСредствИзмерений = Неопределено Тогда 
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "Ссылка.ТипПрибораУчета.МаркаПУ.ТипСИ", ТипыСредствИзмерений, ВидСравненияКомпоновкиДанных.ВСписке,,Истина,РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
