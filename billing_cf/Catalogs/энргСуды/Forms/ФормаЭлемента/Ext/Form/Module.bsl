#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Перем ОбъектСуд;
	ОбъектСуд  = РеквизитФормыВЗначение("Объект");
	СтрокиКонт = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ОбъектСуд, Справочники.ВидыКонтактнойИнформации.АдресОбъекта,, Ложь);
	
	Если ЗначениеЗаполнено(СтрокиКонт) Тогда
		АдресОбъекта 		 = СтрокиКонт[0].Представление;
		АдресОбъектаЗначение = СтрокиКонт[0].Значение;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ТекущийОбъект, АдресОбъектаЗначение, Справочники.ВидыКонтактнойИнформации.АдресОбъекта);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура АдресПриИзменении(Элемент)
		АдресОбъектаЗначение = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(АдресОбъекта, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресДома"));
КонецПроцедуры

&НаКлиенте
Процедура АдресНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
		СтандартнаяОбработка = Ложь;
	МодульУправлениеКонтактнойИнформациейКлиент 		= ОбщегоНазначенияКлиент.ОбщийМодуль("УправлениеКонтактнойИнформациейКлиент");
	
	ПараметрыФормыКонтактнойИнформации 					= МодульУправлениеКонтактнойИнформациейКлиент.ПараметрыФормыКонтактнойИнформации(ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресДома"),""); 
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяРеквизита", Элемент.Имя);
		
	ДанныеСтроки 										= Новый Структура("Представление,ЗначенияПолей",АдресОбъекта,АдресОбъектаЗначение);
	
	ПараметрыФормыКонтактнойИнформации.Значение 		= ДанныеСтроки.ЗначенияПолей;
	ПараметрыФормыКонтактнойИнформации.Представление 	= ДанныеСтроки.Представление;
	
	Оповещение 											= Новый ОписаниеОповещения("АдресОбъектаНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура);
	Оповещение.ДополнительныеПараметры.Вставить("ДанныеЗаполнения",  ДанныеСтроки);
	Оповещение.ДополнительныеПараметры.Вставить("ЭтоТабличнаяЧасть", Ложь);
	Оповещение.ДополнительныеПараметры.Вставить("Элемент",           Элемент);
	Оповещение.ДополнительныеПараметры.Вставить("ДанныеСтроки",      ДанныеСтроки);		
	Оповещение.ДополнительныеПараметры.Вставить("Результат",         Результат);
	Оповещение.ДополнительныеПараметры.Вставить("Форма",             ЭтаФорма);
	Оповещение.ДополнительныеПараметры.Вставить("Строительный",      Ложь);
	
	МодульУправлениеКонтактнойИнформациейКлиент.ОткрытьФормуКонтактнойИнформации(ПараметрыФормыКонтактнойИнформации,,Оповещение);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура АдресОбъектаНачалоВыбораЗавершение(Знач РезультатЗакрытия, Знач ДополнительныеПараметры) Экспорт 
	
	Если ТипЗнч(РезультатЗакрытия) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	

		АдресОбъекта 								= РезультатЗакрытия.Представление;
		АдресОбъектаЗначение 						= РезультатЗакрытия.Значение;
		
		КонтактнаяИнформация						= ПолучитьПрочитанныйJSON(РезультатЗакрытия.Значение);
			
		Если КонтактнаяИнформация.Свойство("oktmo") Тогда 
			ОКТМО									= КонтактнаяИнформация.oktmo;
		КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьПрочитанныйJSON(ТекЗначение)
	ЧтениеJSON 									= Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекЗначение);
	КонтактнаяИнформация 						= ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();	
	
	Возврат КонтактнаяИнформация;
КонецФункции

#КонецОбласти
