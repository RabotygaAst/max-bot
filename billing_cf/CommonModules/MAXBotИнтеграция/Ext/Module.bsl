Функция ПреобразоватьПериодMAX(Период)
	Если ТипЗнч(Период) = Тип("Дата") Тогда Возврат НачалоМесяца(Период); КонецЕсли;
	ПериодСтрокой = Строка(Период);
	Если ПустаяСтрока(ПериодСтрокой) Тогда Возврат НачалоМесяца(ТекущаяДата()); КонецЕсли;
	Год = Число(Лев(ПериодСтрокой, 4));
	Месяц = ?(СтрДлина(ПериодСтрокой) >= 7, Число(Сред(ПериодСтрокой, 6, 2)), Месяц(ТекущаяДата()));
	Возврат Дата(Год, Месяц, 1);
КонецФункции

Функция ПреобразоватьДатуMAX(ДатаСтрокой)
	Если ТипЗнч(ДатаСтрокой) = Тип("Дата") Тогда Возврат ДатаСтрокой; КонецЕсли;
	ДатаСтрокой = Строка(ДатаСтрокой);
	Если ПустаяСтрока(ДатаСтрокой) Тогда Возврат Дата(1, 1, 1); КонецЕсли;
	Попытка
		Возврат Дата(Число(Лев(ДатаСтрокой, 4)), Число(Сред(ДатаСтрокой, 6, 2)), Число(Сред(ДатаСтрокой, 9, 2)));
	Исключение
		Возврат Дата(1, 1, 1);
	КонецПопытки;
КонецФункции

