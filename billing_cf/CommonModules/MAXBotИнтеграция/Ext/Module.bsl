Функция GetBalance(MAXUserID, AccountID) Экспорт
	Если Не ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Тогда
		Возврат Новый Структура("success,code,message,data", Ложь, "FORBIDDEN", "Нет доступа к лицевому счету", Новый Структура);
	КонецЕсли;
	Возврат Новый Структура("success,code,message,data", Истина, "OK", "Баланс", ПолучитьБалансJSON(AccountID));
КонецФункции

Функция ПолучитьПоследниеНачисленияТарифыУслуги(ЛицевойСчет, Период = Неопределено) Экспорт
	Если Период = Неопределено Тогда
		Период = НачалоМесяца(ТекущаяДата());
	КонецЕсли;
	Данные = Новый Структура("Долг,Переплата,Период,Начислено,Оплачено,Услуги,Тарифы,Начисления,debt,overpay,currency,actual_at", 0, 0, Формат(Период, "ДФ=yyyy-MM"), 0, 0, Новый Массив, Новый Массив, Новый Массив, 0, 0, "руб.", Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd"));
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОбъемНачислений.Услуга КАК Услуга,
	|	ОбъемНачислений.Измеритель КАК Измеритель,
	|	ОбъемНачислений.ТочкаУчета КАК ТочкаУчета,
	|	ОбъемНачислений.ПриборУчета КАК ПриборУчета,
	|	ОбъемНачислений.Шкала КАК Шкала,
	|	ОбъемНачислений.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ОбъемНачислений.ЗначениеТарифа КАК ЗначениеТарифа,
	|	ОбъемНачислений.ПериодНачисления КАК ПериодНачисления,
	|	МАКСИМУМ(ОбъемНачислений.Период) КАК Период,
	|	СУММА(ОбъемНачислений.ОбъемУслуги) КАК Объем,
	|	СУММА(ОбъемНачислений.Сумма) КАК Сумма
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений КАК ОбъемНачислений
	|ГДЕ
	|	ОбъемНачислений.Абонент = &ЛицевойСчет
	|	И ОбъемНачислений.ПериодНачисления = &Период
	|
	|СГРУППИРОВАТЬ ПО
	|	ОбъемНачислений.Услуга,
	|	ОбъемНачислений.Измеритель,
	|	ОбъемНачислений.ТочкаУчета,
	|	ОбъемНачислений.ПриборУчета,
	|	ОбъемНачислений.Шкала,
	|	ОбъемНачислений.ТарифнаяЗона,
	|	ОбъемНачислений.ЗначениеТарифа,
	|	ОбъемНачислений.ПериодНачисления";
	Запрос.УстановитьПараметр("ЛицевойСчет", ЛицевойСчет);
	Запрос.УстановитьПараметр("Период", Период);
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
	Исключение
		Возврат Данные;
	КонецПопытки;
	Пока Выборка.Следующий() Цикл
		Услуга = Новый Структура;
		Услуга.Вставить("service_id", UIDСтрокой(Выборка.Услуга));
		Услуга.Вставить("service_name", ПредставлениеБезMock(Выборка.Услуга));
		Услуга.Вставить("resource", ПредставлениеБезMock(Выборка.Измеритель));
		Услуга.Вставить("tariff_id", UIDСтрокой(Выборка.ЗначениеТарифа));
		Услуга.Вставить("tariff_name", ПредставлениеБезMock(Выборка.ЗначениеТарифа));
		Услуга.Вставить("unit", ПредставлениеБезMock(Выборка.Измеритель));
		Услуга.Вставить("volume", Выборка.Объем);
		Услуга.Вставить("amount", Выборка.Сумма);
		Услуга.Вставить("period", Формат(Выборка.ПериодНачисления, "ДФ=yyyy-MM-dd"));
		Услуга.Вставить("meter_ref", Выборка.ПриборУчета);
		Услуга.Вставить("point_ref", Выборка.ТочкаУчета);
		Данные.Услуги.Добавить(Услуга);
		Данные.Начислено = Данные.Начислено + Выборка.Сумма;
	КонецЦикла;
	Возврат Данные;
КонецФункции

Функция ПолучитьПриборыУчетаJSON(AccountID, MAXUserID = Неопределено) Экспорт
	ЛС = ПолучитьЛицевойСчетПоAccountID(AccountID);
	Возврат ПолучитьПриборыУчета(ЛС);
КонецФункции

Функция ПолучитьПриборыУчета(ЛицевойСчет) Экспорт
	Возврат ПолучитьТочкиПередачиПоказаний(ЛицевойСчет);
КонецФункции

Функция ПолучитьТочкиПередачиПоказаний(ЛицевойСчет, Период = Неопределено) Экспорт
	Массив = Новый Массив;
	Начисления = ПолучитьПоследниеНачисленияТарифыУслуги(ЛицевойСчет, Период);
	Для Каждого СтрокаУслуги Из Начисления.Услуги Цикл
		Данные = Новый Структура;
		Прибор = СтрокаУслуги.meter_ref;
		ЕстьПрибор = ЗначениеЗаполнено(Прибор);
		Данные.Вставить("meter_id", ?(ЕстьПрибор, UIDСтрокой(Прибор), ""));
		Данные.Вставить("display_name", СформироватьDisplayName(СтрокаУслуги));
		Данные.Вставить("resource", СтрокаУслуги.resource);
		Данные.Вставить("service_id", СтрокаУслуги.service_id);
		Данные.Вставить("service_name", СтрокаУслуги.service_name);
		Данные.Вставить("tariff_id", СтрокаУслуги.tariff_id);
		Данные.Вставить("tariff_name", СтрокаУслуги.tariff_name);
		Данные.Вставить("unit", СтрокаУслуги.unit);
		Данные.Вставить("serial_number", ?(ЕстьПрибор, Строка(Прибор.Код), ""));
		Последнее = ПолучитьПоследнееПоказаниеПрибора(Прибор);
		Данные.Вставить("last_value", Последнее.Показание);
		Данные.Вставить("last_reading_date", Последнее.Дата);
		Данные.Вставить("verification_to", "");
		Данные.Вставить("can_submit", ЕстьПрибор);
		Данные.Вставить("reason", ?(ЕстьПрибор, "", "Не найден прибор учета для передачи показаний"));
		Массив.Добавить(Данные);
	КонецЦикла;
	Возврат Массив;
КонецФункции

Функция СоздатьПоказаниеПрибора(AccountID, MeterID, Период, Значение, Источник, MAXUserID, MessageID, OperationID) Экспорт
	Если ОперацияУжеВыполнена(OperationID) Тогда
		Возврат ПолучитьРезультатОперацииJSON(OperationID);
	КонецЕсли;
	Если Не ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Тогда
		ВызватьИсключение "FORBIDDEN";
	КонецЕсли;

	ЛицевойСчет = ПолучитьЛицевойСчетПоAccountID(AccountID);
	ТочкаПоказаний = НайтиТочкуПередачиПоказанийДляЗаписи(ЛицевойСчет, MeterID, Период);
	Если ТочкаПоказаний = Неопределено Тогда
		Если ЗначениеЗаполнено(ПолучитьПриборУчетаПоMeterID(MeterID)) Тогда
			Возврат Новый Структура("success,code,message,data", Ложь, "ACCESS_DENIED", "Прибор учета не принадлежит лицевому счету", Новый Структура);
		КонецЕсли;
		Возврат Новый Структура("success,code,message,data", Ложь, "METER_NOT_FOUND", "Точка передачи показаний не найдена", Новый Структура);
	КонецЕсли;

	Если Не ТочкаПоказаний.МожноПередавать Тогда
		Возврат Новый Структура("success,code,message,data", Ложь, "READING_NOT_ALLOWED", ТочкаПоказаний.ПричинаЗапрета, Новый Структура);
	КонецЕсли;

	ИсточникПоказаний = ПолучитьИсточникПоказанийMAX();
	Если Не ЗначениеЗаполнено(ИсточникПоказаний) Тогда
		Возврат Новый Структура("success,code,message,data", Ложь, "CONFIG_REQUIRED", "Не настроен источник показаний MAX", Новый Структура);
	КонецЕсли;

	Док = Документы.энргРегистрацияПоказанийАбонента.СоздатьДокумент();
	Док.Дата = ТекущаяДата();
	Док.Абонент = ТочкаПоказаний.Абонент;
	Док.КлючПомещения = ТочкаПоказаний.КлючПомещения;
	Док.Организация = ТочкаПоказаний.Организация;
	Док.Район = ТочкаПоказаний.Район;
	Док.ПериодНачисления = ПреобразоватьПериодMAX(Период);
	Док.ИсточникПоказаний = ИсточникПоказаний;
	Док.Примечание = "MAX; operation_id=" + OperationID + "; message_id=" + MessageID;

	IDТочки = Новый УникальныйИдентификатор();
	СтрокаТочки = Док.ТочкиУчета.Добавить();
	СтрокаТочки.IDСтроки = IDТочки;
	СтрокаТочки.ТочкаУчета = ТочкаПоказаний.ТочкаУчета;
	СтрокаТочки.Услуга = ТочкаПоказаний.Услуга;
	СтрокаТочки.ПриборУчета = ТочкаПоказаний.ПриборУчета;

	IDШкалы = Новый УникальныйИдентификатор();
	СтрокаШкалы = Док.ШкалыПриборовУчета.Добавить();
	СтрокаШкалы.IDСтроки = IDШкалы;
	СтрокаШкалы.IDСтрокиТочкиУчета = IDТочки;
	СтрокаШкалы.Шкала = ТочкаПоказаний.Шкала;
	УстановитьРеквизитЕслиЕсть(СтрокаШкалы, "ВидДифференцированности", ТочкаПоказаний.ВидДифференцированности);

	ПредыдущиеПоказания = ТочкаПоказаний.ПредыдущиеПоказания;
	Если ТочкаПоказаний.РегистрируетОбъем Тогда
		Разница = Значение;
		ТекущиеПоказания = ПредыдущиеПоказания + Значение;
	Иначе
		ТекущиеПоказания = Значение;
		Разница = Значение - ПредыдущиеПоказания;
	КонецЕсли;

	СтрокаПоказаний = Док.ПоказанияПриборовУчета.Добавить();
	СтрокаПоказаний.IDСтроки = IDШкалы;
	СтрокаПоказаний.ПредыдущиеПоказания = ПредыдущиеПоказания;
	СтрокаПоказаний.ТекущиеПоказания = ТекущиеПоказания;
	СтрокаПоказаний.Разница = Разница;
	СтрокаПоказаний.ПоказанияПредоставлены = Истина;
	УстановитьРеквизитЕслиЕсть(СтрокаПоказаний, "ДатаПоследнихПоказаний", ТочкаПоказаний.ДатаПоследнихПоказаний);
	УстановитьРеквизитЕслиЕсть(СтрокаПоказаний, "ТарифнаяЗона", ТочкаПоказаний.ТарифнаяЗона);
	УстановитьРеквизитЕслиЕсть(СтрокаПоказаний, "СостояниеПоказаний", ПолучитьСостояниеПоказанийMAX());
	УстановитьРеквизитЕслиЕсть(СтрокаПоказаний, "СтатусИзмененПользователем", Истина);
	УстановитьРеквизитЕслиЕсть(СтрокаПоказаний, "Переворот", Ложь);
	УстановитьРеквизитЕслиЕсть(СтрокаПоказаний, "ПереворотИзмененПользователем", Ложь);

	Док.Записать(РежимЗаписиДокумента.Запись);

	Данные = Новый Структура;
	Данные.Вставить("document_number", Док.Номер);
	Данные.Вставить("document_date", Формат(Док.Дата, "ДФ=yyyy-MM-dd"));
	Данные.Вставить("document_ref", Строка(Док.Ссылка.УникальныйИдентификатор()));
	Данные.Вставить("posted", Ложь);
	Данные.Вставить("meter_id", MeterID);
	Данные.Вставить("value", Значение);
	Данные.Вставить("status", "saved_unposted");

	Результат = Новый Структура("success,code,message,data", Истина, "OK", "Показание зарегистрировано", Данные);
	ЗапомнитьРезультатОперации(OperationID, "reading", Результат);
	Возврат Результат;
КонецФункции

Функция НайтиТочкуПередачиПоказанийДляЗаписи(ЛицевойСчет, MeterID, Период = Неопределено) Экспорт
	Если Не ЗначениеЗаполнено(ЛицевойСчет) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если Период = Неопределено Тогда
		Период = НачалоМесяца(ТекущаяДата());
	Иначе
		Период = ПреобразоватьПериодMAX(Период);
	КонецЕсли;
	ПриборУчета = ПолучитьПриборУчетаПоMeterID(MeterID);
	Если Не ЗначениеЗаполнено(ПриборУчета) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОбъемНачислений.Абонент КАК Абонент,
	|	ОбъемНачислений.Организация КАК Организация,
	|	ОбъемНачислений.Район КАК Район,
	|	ОбъемНачислений.КлючПомещения КАК КлючПомещения,
	|	ОбъемНачислений.ТочкаУчета КАК ТочкаУчета,
	|	ОбъемНачислений.Услуга КАК Услуга,
	|	ОбъемНачислений.ПриборУчета КАК ПриборУчета,
	|	ОбъемНачислений.Шкала КАК Шкала,
	|	ОбъемНачислений.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ОбъемНачислений.ВидДифференцированности КАК ВидДифференцированности,
	|	ОбъемНачислений.ПриборУчета.РегистрируетОбъем КАК РегистрируетОбъем
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений КАК ОбъемНачислений
	|ГДЕ
	|	ОбъемНачислений.Абонент = &ЛицевойСчет
	|	И ОбъемНачислений.ПериодНачисления = &Период
	|	И ОбъемНачислений.ПриборУчета = &ПриборУчета
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОбъемНачислений.Период УБЫВ";
	Запрос.УстановитьПараметр("ЛицевойСчет", ЛицевойСчет);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("ПриборУчета", ПриборУчета);

	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;

	Если Не Выборка.Следующий() Тогда
		Возврат Неопределено;
	КонецЕсли;

	Последнее = ПолучитьПоследнееПоказаниеПрибора(Выборка.ПриборУчета);
	Результат = Новый Структура;
	Результат.Вставить("Абонент", Выборка.Абонент);
	Результат.Вставить("КлючПомещения", Выборка.КлючПомещения);
	Результат.Вставить("Организация", Выборка.Организация);
	Результат.Вставить("Район", Выборка.Район);
	Результат.Вставить("ТочкаУчета", Выборка.ТочкаУчета);
	Результат.Вставить("Услуга", Выборка.Услуга);
	Результат.Вставить("ПриборУчета", Выборка.ПриборУчета);
	Результат.Вставить("Шкала", Выборка.Шкала);
	Результат.Вставить("ТарифнаяЗона", Выборка.ТарифнаяЗона);
	Результат.Вставить("ВидДифференцированности", Выборка.ВидДифференцированности);
	Результат.Вставить("ПредыдущиеПоказания", Последнее.Показание);
	Результат.Вставить("ДатаПоследнихПоказаний", ПреобразоватьДатуMAX(Последнее.Дата));
	Результат.Вставить("РегистрируетОбъем", Выборка.РегистрируетОбъем);
	Результат.Вставить("МожноПередавать", ЗначениеЗаполнено(Выборка.ПриборУчета));
	Результат.Вставить("ПричинаЗапрета", ?(ЗначениеЗаполнено(Выборка.ПриборУчета), "", "Не найден прибор учета для передачи показаний"));
	Возврат Результат;
КонецФункции

