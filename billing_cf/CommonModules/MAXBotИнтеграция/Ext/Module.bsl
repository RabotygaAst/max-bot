Функция ПолучитьПоследнееПоказаниеПрибора(Прибор)
	Результат = Новый Структура("Показание,Дата", 0, "");
	Если Не ЗначениеЗаполнено(Прибор) Тогда
		Возврат Результат;
	КонецЕсли;
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1 Показания.Показание КАК Показание, Показания.Период КАК Период ИЗ РегистрСведений.энргПоказанияПриборовУчета КАК Показания ГДЕ Показания.ПриборУчета = &Прибор УПОРЯДОЧИТЬ ПО Показания.Период УБЫВ");
	Запрос.УстановитьПараметр("Прибор", Прибор);
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
	Исключение
		Возврат Результат;
	КонецПопытки;
	Если Выборка.Следующий() Тогда
		Результат.Показание = Выборка.Показание; Результат.Дата = Формат(Выборка.Период, "ДФ=yyyy-MM-dd");
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ОпределитьРесурсПрибора(Прибор)
	Имя = ВРег(Строка(Прибор));
	Если СтрНайти(Имя, "ГВС") > 0 Тогда Возврат "ГВС"; КонецЕсли;
	Если СтрНайти(Имя, "ОТОП") > 0 Тогда Возврат "Отопление"; КонецЕсли;
	Если СтрНайти(Имя, "ЭЛЕКТ") > 0 Тогда Возврат "Электроэнергия"; КонецЕсли;
	Если СтрНайти(Имя, "ГАЗ") > 0 Тогда Возврат "Газ"; КонецЕсли;
	Возврат "ХВС";
КонецФункции

Функция СгенерироватьКодПодтверждения()
	Возврат Формат(1000 + (Секунда(ТекущаяДата()) * 137) % 9000, "ЧГ=0");
КонецФункции

Функция ХешСтроки(ИсходнаяСтрока) Экспорт

	Хеширование = Новый ХешированиеДанных(ХешФункция.SHA256);
	Хеширование.Добавить(ИсходнаяСтрока);

	Возврат НРег(ПолучитьHexСтрокуИзДвоичныхДанных(Хеширование.ХешСумма));

КонецФункции

Функция ПроверитьКодПривязки(MAXUserID, ЛицевойСчет, Код)
	Если MAXBotРазрешитьТестовыйКод() И Код = "1234" Тогда
		Возврат Истина;
	КонецЕсли;
	// TODO: проверить хеш, срок действия и счетчик попыток из MAXBotИсторияДанныхПользователей.
	Возврат Не ПустаяСтрока(Код);
КонецФункции

Функция ОшибкаНеРеализовано(Сообщение)
	Возврат Новый Структура("success,code,message,data", Ложь, "NOT_IMPLEMENTED", Сообщение, Новый Структура);
