				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаПриборовУчета.ПриборУчета",	"ТаблицаПриборовУчета.ПриборУчетаВывод");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");
			ИначеЕсли СтруктураИсточника.ЭтоЗаменаПУ Тогда
