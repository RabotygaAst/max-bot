			// выгрузка услуг по договорам
			Если СтруктураИсточника.ЭтоОткрытиеЛС Или СтруктураИсточника.ЭтоЗакрытиеЛС Тогда
				Запрос.Текст = 
				"ВЫБРАТЬ
				|	бестВыгруженныеУслугиДоговоровГИСЖКХ.Период КАК Период
