				|ГДЕ
				|	бестВыгруженныеЖДГИСЖКХ.Абонент = &Абонент
				|	И бестВыгруженныеЖДГИСЖКХ.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)
				|	И бестВыгруженныеЖДГИСЖКХ.Организация = &Организация
				|	И бестВыгруженныеЖДГИСЖКХ.Район = &Район";
				
				РезультатЗапроса = Запрос.Выполнить().Выбрать();
				Если РезультатЗапроса.Следующий() Тогда
					// очищаем все старые записи этого ЖД
					Набор = РегистрыСведений.бестВыгруженныеЖДГИСЖКХ.СоздатьНаборЗаписей();  			
					Набор.Отбор.Период.Установить(РезультатЗапроса.Период);
					Набор.Отбор.Организация.Установить(Источник.Организация);
					Набор.Отбор.Район.Установить(Источник.Район);
					Набор.Отбор.Абонент.Установить(Абонент);
					//Набор.Очистить();
					Набор.Записать();
				КонецЕсли;
				
				
				НоваяЗапись = РегистрыСведений.бестВыгруженныеЖДГИСЖКХ.СоздатьМенеджерЗаписи();  			
				НоваяЗапись.Период			= Период;
				НоваяЗапись.Организация		= Источник.Организация;
				НоваяЗапись.Район			= Источник.Район;
				НоваяЗапись.Абонент			= Абонент;
				НоваяЗапись.ФИАС			= ВыборкаИдентификаторов.ИдентификаторДомаФИАС;
				
				НоваяЗапись.АдресОЖФ		= АдресОЖФ;
				НоваяЗапись.ОКТМО			= ВыборкаИдентификаторов.ОКТМО;
				НоваяЗапись.Статус			= Перечисления.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись;
				НоваяЗапись.Записать();
				
			КонецЕсли;
		КонецЕсли;
		#КонецОбласти
		
		#Область ВыгрузкаПУ
		Если СтруктураИсточника.ЭтоОткрытиеЛС Или СтруктураИсточника.ЭтоПодключениеУслуги Или СтруктураИсточника.ЭтоВводПУ 
			Или СтруктураИсточника.ЭтоЗаменаПУ Или СтруктураИсточника.ЭтоВводНачальныхОстатков Тогда
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	бестВыгруженныеПУВГИСЖКХ.Период КАК Период
			|ИЗ
			|	РегистрСведений.бестВыгруженныеПУВГИСЖКХ КАК бестВыгруженныеПУВГИСЖКХ
			|ГДЕ
			|	бестВыгруженныеПУВГИСЖКХ.АбонентМКД = &Абонент
			|	И бестВыгруженныеПУВГИСЖКХ.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)
			|	И бестВыгруженныеПУВГИСЖКХ.Организация = &Организация
			|	И бестВыгруженныеПУВГИСЖКХ.Район = &Район
			|	И бестВыгруженныеПУВГИСЖКХ.ВидПУ В (ЗНАЧЕНИЕ(Перечисление.бестВидыПриборовУчетаГИСЖКХ.ОбщийКвартирный), ЗНАЧЕНИЕ(Перечисление.бестВидыПриборовУчетаГИСЖКХ.Индивидуальный))";
			
			РезультатЗапроса = Запрос.Выполнить().Выбрать();
			Если РезультатЗапроса.Следующий() Тогда
				// очищаем все старые записи этого Абонента
				Набор = РегистрыСведений.бестВыгруженныеПУВГИСЖКХ.СоздатьНаборЗаписей();  			
				Набор.Отбор.Период.Установить(РезультатЗапроса.Период);
				Набор.Отбор.Организация.Установить(Источник.Организация);
				Набор.Отбор.Район.Установить(Источник.Район);
				Набор.Отбор.АбонентМКД.Установить(Абонент);
				//Набор.Очистить();
				Набор.Записать();
			КонецЕсли;
			
			ТекстЗапроса = "";
			Если СтруктураИсточника.ЭтоВводНачальныхОстатков Тогда
				ТекстЗапроса = 
				"ВЫБРАТЬ
				|	энргВводНачальныхОстатковАбоненты.IDСтроки КАК IDСтроки
				|ПОМЕСТИТЬ ВТ_IDСтроки
				|ИЗ
				|	Документ.энргВводНачальныхОстатков.Абоненты КАК энргВводНачальныхОстатковАбоненты
				|ГДЕ
				|	энргВводНачальныхОстатковАбоненты.Абонент = &Абонент
				|	И энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка;";
			КонецЕсли;
			Запрос.Текст = ТекстЗапроса + " " +  
			"ВЫБРАТЬ
			|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
			|	ВложенныйЗапрос.Шкала КАК Шкала,
			|	ТаблицаПоказанийПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
			|	ТаблицаПоказанийПриборовУчета.ТекущиеПоказания КАК Показание,
			|	ЕСТЬNULL(энргВидыУслугСоставляющиеУслуг.Услуга, ВложенныйЗапрос.Услуга) КАК Услуга,
			|	ВЫБОР
			|		КОГДА энргВидыУслугСоставляющиеУслуг.Услуга ЕСТЬ NULL
			|			ТОГДА ВложенныйЗапрос.Услуга.бестКоммунальныйРесурсЖКХ
			|		ИНАЧЕ энргВидыУслугСоставляющиеУслуг.Услуга.бестКоммунальныйРесурсЖКХ
			|	КОНЕЦ КАК КоммунальныйРесурс,
			|	энргИдентификаторыПУГИСЖКХ.НомерПрибораГИСЖКХ КАК НомерПрибораГИСЖКХ,
			|	ВложенныйЗапрос.ВидПУ КАК ВидПУ
			|ИЗ
			|	(ВЫБРАТЬ
			|		ТаблицаПриборовУчета.Ссылка КАК Ссылка,
			|		ТаблицаПриборовУчета.ПриборУчета КАК ПриборУчета,
			|		ТаблицаШкал.Шкала КАК Шкала,
			|		ТаблицаШкал.IDСтроки КАК IDСтроки,
			|		ТаблицаПриборовУчета.Услуга КАК Услуга,
			|		ВЫБОР
			|			КОГДА ВЫРАЗИТЬ(&Абонент КАК Справочник.энргАбоненты).Домовладение
			|				ТОГДА ЗНАЧЕНИЕ(Перечисление.бестВидыПриборовУчетаГИСЖКХ.Индивидуальный)
			|			ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.бестВидыПриборовУчетаГИСЖКХ.ОбщийКвартирный)
			|		КОНЕЦ КАК ВидПУ
			|	ИЗ
			|		Документ.энргОперацияСЛицевымСчетом.ТочкиУчета КАК ТаблицаПриборовУчета
			|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом.ШкалыПриборовУчета КАК ТаблицаШкал
			|			ПО ТаблицаПриборовУчета.Ссылка = ТаблицаШкал.Ссылка
			|				И ТаблицаПриборовУчета.IDСтроки = ТаблицаШкал.IDСтрокиТочкиУчета
			|				И (ТаблицаПриборовУчета.Ссылка = &Ссылка)
			|				И (ТаблицаШкал.Ссылка = &Ссылка)
			|				И (НЕ ТаблицаПриборовУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
			|				И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)
			|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом КАК ТаблицаДокумента
			|			ПО ТаблицаПриборовУчета.Ссылка = ТаблицаДокумента.Ссылка
			|				И (ТаблицаПриборовУчета.Ссылка = &Ссылка)
			|				И (ТаблицаДокумента.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом.ПоказанияПриборовУчета КАК ТаблицаПоказанийПриборовУчета
			|		ПО ВложенныйЗапрос.Ссылка = ТаблицаПоказанийПриборовУчета.Ссылка
			|			И ВложенныйЗапрос.IDСтроки = ТаблицаПоказанийПриборовУчета.IDСтроки
			|			И (ТаблицаПоказанийПриборовУчета.Ссылка = &Ссылка)
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
			|		ПО ВложенныйЗапрос.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
			|			И (ВложенныйЗапрос.Услуга.СоставнаяУслуга)
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыПУГИСЖКХ КАК энргИдентификаторыПУГИСЖКХ
			|		ПО ВложенныйЗапрос.ПриборУчета = энргИдентификаторыПУГИСЖКХ.ПриборУчета
			|
			|УПОРЯДОЧИТЬ ПО
			|	Шкала,
			|	ТарифнаяЗона
			|ИТОГИ ПО
			|	ПриборУчета";
			Если СтруктураИсточника.ЭтоПодключениеУслуги Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргОперацияСЛицевымСчетом", "энргОперацияСУслугами");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");
			ИначеЕсли СтруктураИсточника.ЭтоВводПУ Или СтруктураИсточника.ЭтоЗаменаПУ Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргОперацияСЛицевымСчетом", "энргОперацияСПриборомУчета");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");
			ИначеЕсли СтруктураИсточника.ЭтоОткрытиеЛС Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");	
			ИначеЕсли СтруктураИсточника.ЭтоВводНачальныхОстатков Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргОперацияСЛицевымСчетом", "энргВводНачальныхОстатков");
			КонецЕсли;
			
			ВыборкаПУ = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПУ.Следующий() Цикл
				ВыборкаУслуг = ВыборкаПУ.Выбрать();
				Пока ВыборкаУслуг.Следующий() Цикл
					НоваяЗапись = РегистрыСведений.бестВыгруженныеПУВГИСЖКХ.СоздатьМенеджерЗаписи();  			
					НоваяЗапись.Период							= Период;
					НоваяЗапись.Организация						= Источник.Организация;
					НоваяЗапись.Район							= Источник.Район;
					НоваяЗапись.АбонентМКД						= Абонент;
					НоваяЗапись.ПриборУчета						= ВыборкаУслуг.ПриборУчета;
					НоваяЗапись.КоммунальныйРесурс				= ВыборкаУслуг.КоммунальныйРесурс;
					НоваяЗапись.ВидПУ							= ВыборкаУслуг.ВидПУ;
					//ваяЗапись.НомерПУВГИСЖКХ					= ВыборкаУслуг.НомерПУВГИСЖКХ;
					
					НоваяЗапись.АдресОЖФ						= АдресМКД;
					НоваяЗапись.Показание						= ВыборкаУслуг.Показание;
					НоваяЗапись.Статус							= Перечисления.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись;
					НоваяЗапись.Записать();
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
		#КонецОбласти  
		
		#Область ЗакрытыеЛС
		Если СтруктураИсточника.ЭтоЗакрытиеЛС Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	бестВыгруженныеЗакрытыеЛСГИСЖКХ.Период КАК Период
			|ИЗ
			|	РегистрСведений.бестВыгруженныеЗакрытыеЛСГИСЖКХ КАК бестВыгруженныеЗакрытыеЛСГИСЖКХ
			|ГДЕ
			|	бестВыгруженныеЗакрытыеЛСГИСЖКХ.Абонент = &Абонент
			|	И бестВыгруженныеЗакрытыеЛСГИСЖКХ.Статус = Значение(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)";
			
			Запрос.УстановитьПараметр("Абонент", Абонент);
			
			РезультатЗапроса = Запрос.Выполнить().Выбрать();
			Если РезультатЗапроса.Следующий() Тогда
				// очищаем все старые записи этого ЖД
				Набор = РегистрыСведений.бестВыгруженныеЗакрытыеЛСГИСЖКХ.СоздатьНаборЗаписей();  			
				Набор.Отбор.Период.Установить(РезультатЗапроса.Период);
				Набор.Отбор.Организация.Установить(Источник.Организация);
				Набор.Отбор.Район.Установить(Источник.Район);
				Набор.Отбор.Абонент.Установить(Абонент);
				//Набор.Очистить();
				Набор.Записать();
			КонецЕсли;
			
			
			НоваяЗапись = РегистрыСведений.бестВыгруженныеЗакрытыеЛСГИСЖКХ.СоздатьМенеджерЗаписи();  			
			НоваяЗапись.Период			= Период;
			НоваяЗапись.Организация		= Источник.Организация;
			НоваяЗапись.Район			= Источник.Район;
			НоваяЗапись.Абонент			= Абонент;
			
			НоваяЗапись.АдресОЖФ		= АдресОЖФ;
			НоваяЗапись.ДатаЗакрытия	= Источник.Дата;
			НоваяЗапись.ПричинаЗакрытия	= Источник.бестПричинаЗакрытияЛС;
			НоваяЗапись.Примечание		= Источник.Примечание;
			НоваяЗапись.Статус			= Перечисления.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись;
			НоваяЗапись.Записать();		
		КонецЕсли;
		#КонецОбласти
		
		#Область ВыгрузкаПоказанийПУ
		Если СтруктураИсточника.ЭтоРегистрацияПоказанийАбонента Или СтруктураИсточника.ЭтоКвитанция Или СтруктураИсточника.ЭтоРегистрацияПоказанийМКД
			Или СтруктураИсточника.ЭтоЗакрытиеМКД Или СтруктураИсточника.ЭтоОтключениеУслуги Или СтруктураИсточника.ЭтоЗакрытиеЛС
			Или СтруктураИсточника.ЭтоВыводПУ Или СтруктураИсточника.ЭтоЗаменаПУ Или СтруктураИсточника.ЭтоОбходнойЛист Или СтруктураИсточника.ЭтоВводНачальныхОстатков Тогда		
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	бестВыгруженныеПоказанияПУВГИСЖКХ.Период КАК Период,
			|	бестВыгруженныеПоказанияПУВГИСЖКХ.ПриборУчета КАК ПриборУчета
			|ИЗ
			|	РегистрСведений.бестВыгруженныеПоказанияПУВГИСЖКХ КАК бестВыгруженныеПоказанияПУВГИСЖКХ
			|ГДЕ
			|	бестВыгруженныеПоказанияПУВГИСЖКХ.ПриборУчета в (&Приборы)
			|	И бестВыгруженныеПоказанияПУВГИСЖКХ.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)
			|	И бестВыгруженныеПоказанияПУВГИСЖКХ.Организация = &Организация
			|	И бестВыгруженныеПоказанияПУВГИСЖКХ.Район = &Район";
			Запрос.УстановитьПараметр("Приборы",		Источник.ТочкиУчета.ВыгрузитьКолонку("ПриборУчета"));
			Запрос.УстановитьПараметр("Район",			Источник.Район);
			Запрос.УстановитьПараметр("Организация",	Источник.Организация);
			
			РезультатЗапроса = Запрос.Выполнить().Выбрать();
			Если РезультатЗапроса.Следующий() Тогда
				// очищаем все старые записи этого ПУ
				Набор = РегистрыСведений.бестВыгруженныеПоказанияПУВГИСЖКХ.СоздатьНаборЗаписей();  			
				Набор.Отбор.Период.Установить(РезультатЗапроса.Период);
				Набор.Отбор.Организация.Установить(Источник.Организация);
				Набор.Отбор.Район.Установить(Источник.Район);
				Набор.Отбор.ПриборУчета.Установить(РезультатЗапроса.ПриборУчета);
				//Набор.Очистить();
