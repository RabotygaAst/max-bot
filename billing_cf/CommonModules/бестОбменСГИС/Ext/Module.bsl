			|	ПриборУчета";
			
			Если СтруктураИсточника.ЭтоКвитанция Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргРегистрацияПоказанийАбонента", "энргПриходныйКассовыйОрдер");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");
