				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаПриборовУчета.ПриборУчета",	"ТаблицаПриборовУчета.ПриборУчетаВывод");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаПриборовУчета.IDСтроки",		"ТаблицаПриборовУчета.IDСтрокиВывод");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиВыводАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");
			ИначеЕсли СтруктураИсточника.ЭтоВводНачальныхОстатков Тогда
