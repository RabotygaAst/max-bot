			|			И (ВложенныйЗапрос.Услуга.СоставнаяУслуга)
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыПУГИСЖКХ КАК энргИдентификаторыПУГИСЖКХ
			|		ПО ВложенныйЗапрос.ПриборУчета = энргИдентификаторыПУГИСЖКХ.ПриборУчета
			|
			|УПОРЯДОЧИТЬ ПО
			|	Шкала,
			|	ТарифнаяЗона
			|ИТОГИ ПО
			|	ПриборУчета";
			Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
			ВыборкаПУ = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПУ.Следующий() Цикл
				ВыборкаУслуг = ВыборкаПУ.Выбрать();
				Пока ВыборкаУслуг.Следующий() Цикл
					НоваяЗапись = РегистрыСведений.бестВыгруженныеПУВГИСЖКХ.СоздатьМенеджерЗаписи();  			
					НоваяЗапись.Период							= Период;
					НоваяЗапись.Организация						= Источник.Организация;
					НоваяЗапись.Район							= Источник.Район;
					НоваяЗапись.АбонентМКД						= МКД;
					НоваяЗапись.ПриборУчета						= ВыборкаУслуг.ПриборУчета;
					НоваяЗапись.КоммунальныйРесурс				= ВыборкаУслуг.КоммунальныйРесурс;
					НоваяЗапись.ВидПУ							= Перечисления.бестВидыПриборовУчетаГИСЖКХ.Коллективный;
					//ваяЗапись.НомерПУВГИСЖКХ					= ВыборкаУслуг.НомерПУВГИСЖКХ;
					
					НоваяЗапись.АдресОЖФ						= АдресОЖФ;
					НоваяЗапись.Показание						= ВыборкаУслуг.Показание;
					НоваяЗапись.Статус							= Перечисления.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись;
					НоваяЗапись.Записать();
				КонецЦикла;
			КонецЦикла;
			
		КонецЕсли;
		#КонецОбласти 
		
		#Область ВыгрузкаЛС
		Если СтруктураИсточника.ЭтоОплата Тогда
			
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	бестВыгруженныеЛСГИСЖКХ.Период КАК Период
			|ИЗ
			|	РегистрСведений.бестВыгруженныеЛСГИСЖКХ КАК бестВыгруженныеЛСГИСЖКХ
			|ГДЕ
			|	бестВыгруженныеЛСГИСЖКХ.Абонент = &Абонент
			|	И бестВыгруженныеЛСГИСЖКХ.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)
			|	И бестВыгруженныеЛСГИСЖКХ.Организация = &Организация
			|	И бестВыгруженныеЛСГИСЖКХ.Район = &Район";
			
			РезультатЗапроса = Запрос.Выполнить().Выбрать();
			Пока РезультатЗапроса.Следующий() Цикл
				// очищаем все старые записи этого ЛС
				Набор = РегистрыСведений.бестВыгруженныеЛСГИСЖКХ.СоздатьНаборЗаписей();  			
				Набор.Отбор.Период.Установить(РезультатЗапроса.Период);
				Набор.Отбор.Организация.Установить(Источник.Организация);
				Набор.Отбор.Район.Установить(Источник.Район);
				Набор.Отбор.Абонент.Установить(Абонент);
				Набор.Записать();
			КонецЦикла;
			
			
			НоваяЗапись = РегистрыСведений.бестВыгруженныеЛСГИСЖКХ.СоздатьМенеджерЗаписи();  			
			НоваяЗапись.Период					= Период;
			НоваяЗапись.Организация				= Источник.Организация;
			НоваяЗапись.Район					= Источник.Район;
			НоваяЗапись.Абонент					= Абонент;
			
			НоваяЗапись.ИдентификаторЖКУГИСЖКХ	= ВыборкаИдентификаторов.ИдентификаторЖКУГИСЖКХ;
			НоваяЗапись.ВидПомещения			= Перечисления.бестВидыПомещенийГИСЖКХ.ЖилоеПомещение;
			НоваяЗапись.ФИАС					= ВыборкаИдентификаторов.ИдентификаторДомаФИАС;			
			НоваяЗапись.НомерПомещения			= НомерПомещения;
			НоваяЗапись.АдресОЖФ				= АдресОЖФ;
			НоваяЗапись.Статус					= Перечисления.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись;				
			
			НоваяЗапись.Записать();
		КонецЕсли;		
		#КонецОбласти	
		
		#Область Оплата
		
	Иначе
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Источник",		Источник.Ссылка);
		Запрос.УстановитьПараметр("Организация",	Источник.Организация);
		Запрос.УстановитьПараметр("Район",			Источник.Район);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргПлатежноеПоручениеВходящиеОплата.Абонент КАК Абонент,
		|	энргПлатежноеПоручениеВходящиеОплата.Услуга КАК Услуга,
		|	СУММА(энргПлатежноеПоручениеВходящиеОплата.СуммаОплаты) КАК СуммаПлатежа,
		|	энргПлатежноеПоручениеВходящиеОплата.НазначениеПлатежа КАК НазначениеПлатежа,
		|	энргПлатежноеПоручениеВходящиеОплата.ДатаПлатежногоДокумента КАК ДатаПлатежногоДокумента,
		|	энргПлатежноеПоручениеВходящиеОплата.НомерПлатежногоДокумента КАК НомерПлатежногоДокумента,
		|	&Организация КАК Организация,
		|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
		|	энргПлатежноеПоручениеВходящиеОплата.Абонент.Район КАК Район
		|ИЗ
		|	Документ.энргПлатежноеПоручениеВходящие.Оплата КАК энргПлатежноеПоручениеВходящиеОплата
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
		|		ПО энргПлатежноеПоручениеВходящиеОплата.Абонент = энргИдентификаторыАбонентаГИСЖКХ.Абонент
		|ГДЕ
		|	энргПлатежноеПоручениеВходящиеОплата.Ссылка = &Источник
		|
		|СГРУППИРОВАТЬ ПО
		|	энргПлатежноеПоручениеВходящиеОплата.Абонент,
		|	энргПлатежноеПоручениеВходящиеОплата.Услуга,
		|	энргПлатежноеПоручениеВходящиеОплата.НомерПлатежногоДокумента,
		|	энргПлатежноеПоручениеВходящиеОплата.ДатаПлатежногоДокумента,
		|	энргПлатежноеПоручениеВходящиеОплата.НазначениеПлатежа,
		|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ";
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			// очищаем все старые записи этого ЛС
			Набор = РегистрыСведений.бестИсторияОплатыГИСЖКХ.СоздатьНаборЗаписей();  			
			Набор.Отбор.Организация.Установить(Источник.Организация);
			Набор.Отбор.Район.Установить(Выборка.Район);
			Набор.Отбор.Абонент.Установить(Выборка.Абонент);
			Набор.Отбор.ДатаПлатежногоДокумента.Установить(Выборка.ДатаПлатежногоДокумента);
			Набор.Отбор.НомерПлатежногоДокумента.Установить(Выборка.НомерПлатежногоДокумента);
			
			НоваяЗапись = Набор.Добавить();  			
			НоваяЗапись.Организация				= Источник.Организация;
			ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
			НоваяЗапись.Статус					= Перечисления.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись;				
			
			Набор.Записать();					
		КонецЦикла;
		
	КонецЕсли;	
	#КонецОбласти	
	
КонецПроцедуры

#КонецОбласти




#КонецОбласти
