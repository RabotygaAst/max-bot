				Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргРегистрацияПоказанийАбонента", "энргОперацияСУслугами");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");
			ИначеЕсли СтруктураИсточника.ЭтоЗакрытиеЛС Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргРегистрацияПоказанийАбонента", "энргОперацияСЛицевымСчетом");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");
			ИначеЕсли СтруктураИсточника.ЭтоЗакрытиеМКД Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргРегистрацияПоказанийАбонента", "энргОткрытиеМКД");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");
