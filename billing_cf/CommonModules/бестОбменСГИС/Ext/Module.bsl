				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И (ТаблицаПоказанийПриборовУчета.СостояниеПоказаний = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты))", "");
			ИначеЕсли СтруктураИсточника.ЭтоРегистрацияПоказанийАбонента Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТаблицаПриборовУчета.IDСтрокиАбонента В (ВЫБРАТЬ ВТ.IDСтроки ИЗ ВТ_IDСтроки КАК ВТ)", "");
			КонецЕсли;
			
			Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
