#Область СлужебныеПроцедурыИФункции

#Область ОбработчикиСобытий

Процедура бестЗарегистрироватьКОбменуСГИСПриПроведенииОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
 	Если Не энргОбщегоНазначения.ЗначениеФункциональнойОпции("бестВключитьОбменСГИС") Тогда	
 
		Возврат;
	КонецЕсли;
	
	ЭтоОткрытиеЛС					= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОперацияСЛицевымСчетом") И Источник.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС;
	ЭтоЗакрытиеЛС					= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОперацияСЛицевымСчетом") И Источник.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСЛС_ЗакрытиеЛС;
	ЭтоПодключениеУслуги			= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОперацияСУслугами") И Источник.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги;
	ЭтоОтключениеУслуги				= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОперацияСУслугами") И Источник.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги;
	ЭтоРегистрацияПоказанийМКД		= (ТипЗнч(Источник) = Тип("ДокументОбъект.энргРегистрацияПоказанийМКД"));// или ТипЗнч(Источник) = Тип("ДокументОбъект.энргОбходнойЛистМКД"));
 	ЭтоРегистрацияПоказанийАбонента	= (ТипЗнч(Источник) = Тип("ДокументОбъект.энргРегистрацияПоказанийАбонента"));// или ТипЗнч(Источник) = Тип("ДокументОбъект.энргОбходнойЛист"));//((ТипЗнч(Источник) = Тип("ДокументОбъект.энргРегистрацияПоказанийАбонента"))  
 	ЭтоОбходнойЛист					= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОбходнойЛист");
	ЭтоКвитанция					= ТипЗнч(Источник) = Тип("ДокументОбъект.энргПриходныйКассовыйОрдер");
	ЭтоОткрытиеМКД					= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОткрытиеМКД") И Источник.ВидОперации = Перечисления.энргВидыОпераций.энргОткрытиеМКД_Открытие;
	ЭтоЗакрытиеМКД					= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОткрытиеМКД") И Источник.ВидОперации = Перечисления.энргВидыОпераций.энргОткрытиеМКД_Закрытие;
	ЭтоВводПУ						= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОперацияСПриборомУчета") И Источник.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВводПУ;
	ЭтоВыводПУ						= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОперацияСПриборомУчета") И Источник.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВыводПУ;
	ЭтоЗаменаПУ						= ТипЗнч(Источник) = Тип("ДокументОбъект.энргОперацияСПриборомУчета") И Источник.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ;
	ЭтоВводНачальныхОстатков		= ТипЗнч(Источник) = Тип("ДокументОбъект.энргВводНачальныхОстатков");
	ЭтоОплата						= ТипЗнч(Источник) = Тип("ДокументОбъект.энргПлатежноеПоручениеВходящие");
	
	СтруктураИсточника = Новый Структура;
	СтруктураИсточника.Вставить("ЭтоОткрытиеЛС",							ЭтоОткрытиеЛС);
	СтруктураИсточника.Вставить("ЭтоЗакрытиеЛС",							ЭтоЗакрытиеЛС);
	СтруктураИсточника.Вставить("ЭтоПодключениеУслуги",						ЭтоПодключениеУслуги);
	СтруктураИсточника.Вставить("ЭтоОтключениеУслуги",						ЭтоОтключениеУслуги);
	СтруктураИсточника.Вставить("ЭтоРегистрацияПоказанийМКД",				ЭтоРегистрацияПоказанийМКД);
	СтруктураИсточника.Вставить("ЭтоРегистрацияПоказанийАбонента",			ЭтоРегистрацияПоказанийАбонента);
 	СтруктураИсточника.Вставить("ЭтоКвитанция",								ЭтоКвитанция);
	СтруктураИсточника.Вставить("ЭтоОткрытиеМКД",							ЭтоОткрытиеМКД);
	СтруктураИсточника.Вставить("ЭтоЗакрытиеМКД",							ЭтоЗакрытиеМКД);
	СтруктураИсточника.Вставить("ЭтоВводПУ",								ЭтоВводПУ);
	СтруктураИсточника.Вставить("ЭтоВыводПУ",								ЭтоВыводПУ);
	СтруктураИсточника.Вставить("ЭтоЗаменаПУ",								ЭтоЗаменаПУ);
	СтруктураИсточника.Вставить("ЭтоВводНачальныхОстатков",					ЭтоВводНачальныхОстатков);
	СтруктураИсточника.Вставить("ЭтоОплата",								ЭтоОплата);
	СтруктураИсточника.Вставить("ЭтоОбходнойЛист",								ЭтоОбходнойЛист);
	
	Если ЭтоВводНачальныхОстатков Тогда
		Для Каждого ТекАбонент Из Источник.Абоненты Цикл
			ВыполнитьРегистрацию(СтруктураИсточника, Источник, ТекАбонент.Абонент);	
		КонецЦикла;
	ИначеЕсли ЭтоОткрытиеМКД Или ЭтоЗакрытиеМКД Тогда
		ВыполнитьРегистрацию(СтруктураИсточника, Источник, Неопределено);
	ИначеЕсли ЭтоРегистрацияПоказанийМКД Тогда
		ВыполнитьРегистрацию(СтруктураИсточника, Источник, Неопределено);
 	ИначеЕсли ЭтоОбходнойЛист Тогда
 
		ВыполнитьРегистрацию(СтруктураИсточника, Источник, Неопределено);
	ИначеЕсли ЭтоОплата Тогда
		ВыполнитьРегистрацию(СтруктураИсточника, Источник, Неопределено);	
	Иначе
		ВыполнитьРегистрацию(СтруктураИсточника, Источник, Источник.Абонент);
	КонецЕсли;
	
	
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

Процедура  ВыполнитьРегистрацию(СтруктураИсточника, Источник, Абонент)
	#Область ОбщиеПараметры	
	Если Не СтруктураИсточника.ЭтоОплата Тогда	
		МКД					= Справочники.энргСтроения.ПустаяСсылка();
		Если Источник.ДополнительныеСвойства.Свойство("ДанныеСтроения") Тогда
 			Если Не Источник.ДополнительныеСвойства.ДанныеСтроения.ЧастныйСектор Тогда
 				МКД		= Источник.ДополнительныеСвойства.ДанныеСтроения.Строение; 
			КонецЕсли;		
		КонецЕсли;
		
		ПараметрыОтбора		= Новый Структура;
		Если СтруктураИсточника.ЭтоРегистрацияПоказанийМКД Или СтруктураИсточника.ЭтоОткрытиеМКД Или СтруктураИсточника.ЭтоЗакрытиеМКД Тогда
			ПараметрыОтбора.Вставить("Вид", Справочники.ВидыКонтактнойИнформации.АдресДома);
			НайденныеСтроки = МКД.КонтактнаяИнформация.НайтиСтроки(ПараметрыОтбора);
		Иначе
 			Если Источник.ДополнительныеСвойства.Свойство("ДанныеСтроения") Тогда
				Если Источник.ДополнительныеСвойства.ДанныеСтроения.ЧастныйСектор Тогда
 
					ПараметрыОтбора.Вставить("Вид", Справочники.ВидыКонтактнойИнформации.АдресПомещения);
					НайденныеСтроки		= Источник.ДополнительныеСвойства.ДанныеСтроения.Помещение.КонтактнаяИнформация.НайтиСтроки(ПараметрыОтбора); 
				Иначе
					ПараметрыОтбора.Вставить("Вид", Справочники.ВидыКонтактнойИнформации.АдресДома);
					НайденныеСтроки		= Источник.ДополнительныеСвойства.ДанныеСтроения.Строение.КонтактнаяИнформация.НайтиСтроки(ПараметрыОтбора);
				КонецЕсли;
			Иначе
				ПараметрыОтбора.Вставить("Вид", Справочники.ВидыКонтактнойИнформации.АдресОбъекта);
				НайденныеСтроки = Абонент.КонтактнаяИнформация.НайтиСтроки(ПараметрыОтбора);
			КонецЕсли;
			
		КонецЕсли;
		
		Если (СтруктураИсточника.ЭтоОткрытиеЛС Или СтруктураИсточника.ЭтоВводНачальныхОстатков) И ЗначениеЗаполнено(МКД) Тогда
			ПараметрыОтбора.Вставить("Вид", Справочники.ВидыКонтактнойИнформации.АдресДома);
			НайденныеСтрокиМКД = МКД.КонтактнаяИнформация.НайтиСтроки(ПараметрыОтбора);
			АдресМКД		= ?(НайденныеСтрокиМКД.Количество() > 0, НайденныеСтрокиМКД[0].Представление, "");
		Иначе
			АдресМКД		= "";
		КонецЕсли;
		
		АдресОЖФ		= ?(НайденныеСтроки.Количество() > 0, НайденныеСтроки[0].Представление, "");
		Значение		= ?(НайденныеСтроки.Количество() > 0, НайденныеСтроки[0].Значение, "");
		ЗначенияПолей	= ?(НайденныеСтроки.Количество() > 0, НайденныеСтроки[0].ЗначенияПолей, "");
		Период			= Источник.Дата;
		
		Если Значение = "" И СтрНачинаетсяС(СокрЛ(ЗначенияПолей), "{") Тогда 
			Значение = ЗначенияПолей;
		КонецЕсли;
		
		НомерПомещения = "";
		Если СтрНачинаетсяС(СокрЛ(Значение), "{") Тогда 
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(Значение);
			КонтактнаяИнформация = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();
			
			Если КонтактнаяИнформация.Свойство("Apartments") И КонтактнаяИнформация.Apartments <> Неопределено
				И КонтактнаяИнформация.Apartments.Количество() > 0 Тогда
				
				НомерПомещения = КонтактнаяИнформация.Apartments[0].Number; 
			КонецЕсли;
		КонецЕсли;
		
		Запрос = Новый Запрос;
 		Запрос.Текст = 
  		"ВЫБРАТЬ
		|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
		|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ,
		|	энргИдентификаторыМКДГИСЖКХ.ИдентификаторДомаФИАС КАК ИдентификаторДомаФИАС,
		|	ВЫБОР
		|		КОГДА &МКД = ЗНАЧЕНИЕ(справочник.энргСтроения.пустаяссылка)
 
		|			ТОГДА энргИдентификаторыАбонентаГИСЖКХ.ОКТМО
		|		ИНАЧЕ энргИдентификаторыМКДГИСЖКХ.ОКТМО
		|	КОНЕЦ КАК ОКТМО,
		|	ВЫБОР
		|		КОГДА &МКД = ЗНАЧЕНИЕ(справочник.энргСтроения.пустаяссылка)
 		|			ТОГДА ""ЖД""
		|		КОГДА энргСтроения.ТипСтроения = ЗНАЧЕНИЕ(Перечисление.энргТипыСтроений.МКД)
 		|			ТОГДА ""МКД""
		|		КОГДА энргСтроения.ТипСтроения = ЗНАЧЕНИЕ(Перечисление.энргТипыСтроений.ЖД)
		|			ТОГДА ""ЖД""
		|		КОГДА энргСтроения.ТипСтроения = ЗНАЧЕНИЕ(Перечисление.энргТипыСтроений.ЖД_БлокЗастройки)
		|			ТОГДА ""ЖД блок. застройки""
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК ТипДома,
		|	ВЫБОР
		|		КОГДА энргТипСхемыГВССрезПоследних.ТипСхемы ЕСТЬ NULL
		|				ИЛИ энргТипСхемыГВССрезПоследних.ТипСхемы = ЗНАЧЕНИЕ(Перечисление.энргТипыСхемТеплоснабжения.ОткрытаяСхема)
		|			ТОГДА ""Открытая""
		|		ИНАЧЕ ""Закрытая""
		|	КОНЕЦ КАК ТипСхемы,
		|	ВЫБОР
		|		КОГДА &МКД = ЗНАЧЕНИЕ(справочник.энргСтроения.пустаяссылка)
		|			ТОГДА энргИдентификаторыАбонентаГИСЖКХ.УникальныйНомерДома
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК УникальныйНомерДома,
		|	ВЫБОР
		|		КОГДА &МКД = ЗНАЧЕНИЕ(справочник.энргСтроения.пустаяссылка)
		|			ТОГДА """"
		|		ИНАЧЕ энргИдентификаторыАбонентаГИСЖКХ.УникальныйНомерПомещения
		|	КОНЕЦ КАК УникальныйНомерПомещения
		|ИЗ
		|	Справочник.энргАбоненты КАК энргАбоненты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
		|		ПО энргАбоненты.Ссылка = энргИдентификаторыАбонентаГИСЖКХ.Абонент
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыМКДГИСЖКХ КАК энргИдентификаторыМКДГИСЖКХ
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргТипСхемыГВС.СрезПоследних(
		|					&Дата,
		|					Район = &РАйон
		|						И Организация = &Организация
		|						И МКД = &МКД) КАК энргТипСхемыГВССрезПоследних
		|			ПО энргИдентификаторыМКДГИСЖКХ.МКД = энргТипСхемыГВССрезПоследних.МКД
		|		ПО энргАбоненты.КлючПомещения.Строение = энргИдентификаторыМКДГИСЖКХ.МКД
		|ГДЕ
		|	энргАбоненты.Ссылка = &Абонент";
		
		Запрос.УстановитьПараметр("Абонент",		Абонент);
		Запрос.УстановитьПараметр("МКД",			МКД);
		Запрос.УстановитьПараметр("Район",			Источник.Район);
		Запрос.УстановитьПараметр("Организация",	Источник.Организация);
		Запрос.УстановитьПараметр("Дата",			Источник.Дата);
		Запрос.УстановитьПараметр("Ссылка",			Источник.Ссылка);
		
		ВыборкаИдентификаторов = Запрос.Выполнить().Выбрать();
		ВыборкаИдентификаторов.Следующий();
		
		#КонецОбласти
		
		#Область ВыгрузкаДоговоров
		Если СтруктураИсточника.ЭтоОткрытиеЛС Или СтруктураИсточника.ЭтоЗакрытиеЛС Или СтруктураИсточника.ЭтоПодключениеУслуги
			Или СтруктураИсточника.ЭтоОтключениеУслуги Или СтруктураИсточника.ЭтоВводНачальныхОстатков Тогда
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	бестВыгруженныеДоговорыГИСЖКХ.Период КАК Период
			|ИЗ
			|	РегистрСведений.бестВыгруженныеДоговорыГИСЖКХ КАК бестВыгруженныеДоговорыГИСЖКХ
			|ГДЕ
			|	бестВыгруженныеДоговорыГИСЖКХ.Абонент = &Абонент
			|	И бестВыгруженныеДоговорыГИСЖКХ.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)
			|	И бестВыгруженныеДоговорыГИСЖКХ.Организация = &Организация
			|	И бестВыгруженныеДоговорыГИСЖКХ.Район = &Район";
			
			РезультатЗапроса = Запрос.Выполнить().Выбрать();
			Если РезультатЗапроса.Следующий() Тогда
				// очищаем все старые записи этого Договора
				Набор = РегистрыСведений.бестВыгруженныеДоговорыГИСЖКХ.СоздатьНаборЗаписей();  			
				Набор.Отбор.Период.Установить(РезультатЗапроса.Период);
				Набор.Отбор.Организация.Установить(Источник.Организация);
				Набор.Отбор.Район.Установить(Источник.Район);
				Набор.Отбор.Абонент.Установить(Абонент);
				//	Набор.Очистить();
				Набор.Записать();
			КонецЕсли;
			
			НоваяЗапись = РегистрыСведений.бестВыгруженныеДоговорыГИСЖКХ.СоздатьМенеджерЗаписи();  			
			НоваяЗапись.Период		= Период;
			НоваяЗапись.Организация	= Источник.Организация;
			НоваяЗапись.Район		= Источник.Район;
