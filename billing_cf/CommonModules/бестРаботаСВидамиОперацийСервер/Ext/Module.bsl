#Область ПрограммныйИнтерфейс

// Процедура - Заполнить список возможных операций форма списка 
// Заполнение списка выбора операций при создании документа
//
// Параметры:
//  ИмяДокумента	 - Строка
//  СписокОпераций	 - СписокЗначений 
//
Процедура ЗаполнитьСписокВозможныхОперацийФормаСписка(ИмяДокумента,СписокОпераций) Экспорт  
	
	Если ИмяДокумента = "бестЗаключениеДоговоровСЮридическимиЛицами" Тогда
		Если Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("бестИспользоватьДанныеДляРасчетаТепловойЭнергииТеплоносителяИХВСЮЛ") Тогда
			СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ОткрытиеДоговора,							"Регистрация характеристик договора");
		КонецЕсли;
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗакрытиеДоговора,								"Закрытие договора");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ПерезаключениеДоговора,						"Перезаключение договора");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСДоговором_РегистрацияОбъекта,							"Регистрация объекта");
		Если энргОбщегоНазначения.ЗначениеКонстанты("бестИспользоватьДоговорнойБлок") Тогда
			СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение,						"Заявка на заключение");
		КонецЕсли;
		//СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСДоговором_АктБездоговорногоПотребления,					"Акт бездоговорного потребления");
		//СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗаменаДоговораУОбъекта,						"Замена договора у объекта");
		
		
	ИначеЕсли ИмяДокумента = "бестОперацияСПриборомУчетаНП" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВводПУ,									"Акт ввода прибора учета");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВыводПУ,									"Акт вывода прибора учета");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ЗаменаПУ,									"Акт замены прибора учета");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ЗаменаВспомогательногоПУ,					"Акт замены вспомогательного прибора учета");

		
	ИначеЕсли ИмяДокумента = "бестОперацияСУслугамиНП" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСУслугами_ПодключениеУслуги,								"Подключение услуги");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСУслугами_ОтключениеУслуги,								"Отключение услуги");	
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСУслугами_ОграничениеУслуги,								"Ограничение услуги");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСУслугами_ВозобновлениеУслуги,							"Возобновление услуги");
		
	ИначеЕсли ИмяДокумента = "бестОперацияСОбъектамиНП" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСОбъектами_ПодключениеОбъекта,							"Подключение объекта");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСОбъектами_ОтключениеОбъекта,								"Отключение объекта");		
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ОперацияСОбъектами_ЗаменаДоговораУОбъекта,						"Замена договора у объекта");
		
	ИначеЕсли ИмяДокумента = "бестРегистрацияПоказанийНП" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.бестРегистрацияПоказанийНП_РегистрацияПоказаний,					"Регистрация показаний");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.бестРегистрацияПоказанийНП_РегистрацияКонтрольногоСъема,			"Регистрация контрольного съёма");		
		
	ИначеЕсли ИмяДокумента = "бестПерерасчетНП" тогда
		//СписокОпераций.добавить(Перечисления.бестВидыОпераций.Перерасчет_СвязанныйПерерасчет,									"Связанный перерасчет");
		//СписокОпераций.добавить(Перечисления.бестВидыОпераций.Перерасчет_ИзменениеПараметраРассчета,							"Изменение параметра рассчета");
		//СписокОпераций.добавить(Перечисления.бестВидыОпераций.Перерасчет_КорректировкаПоказаний,								"Корректировка показаний");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.Перерасчет_РучнойПерерасчет,										"Ручной перерасчет");
		
		
	ИначеЕсли ИмяДокумента = "бестОбращения" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.бестОбращения_ОбращениеФизическогоЛица,							"Обращение физического лица");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.бестОбращения_ОбращениеЮридическогоЛица,							"Обращение юридического лица");		
		
	ИначеЕсли ИмяДокумента = "бестРегистрацияПоказанийНПОбщий" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.бестРегистрацияПоказанийНП_РегистрацияПоказаний,					"Регистрация показаний");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.бестРегистрацияПоказанийНП_РегистрацияКонтрольногоСъема,			"Регистрация контрольного съёма");		
		
	ИначеЕсли ИмяДокумента = "бестИзменитьДанныеДляДополнительногоРасчета" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ИзменитьДанныеДляДополнительногоРасчета_ПревышениеПДК,					"Превышение ПДК");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ИзменитьДанныеДляДополнительногоРасчета_НегативноеВоздействие,			"Негативное воздействие");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ИзменитьДанныеДляДополнительногоРасчета_ПрочиеДополнительныеНачисления,	"Прочие дополнительные начисления");

	ИначеЕсли ИмяДокумента = "бестИзменитьНомерПломбыПрибораУчета" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ИзменитьНомерПломбыПрибораУчета_Опломбировка,							"Опломбировка");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ИзменитьНомерПломбыПрибораУчета_Распломбировка,						"Распломбировка");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ИзменитьНомерПломбыПрибораУчета_ЗаменаПломбы,							"Замена пломбы");
		
	ИначеЕсли ИмяДокумента = "бестРегистрацияБездоговорногоБезучетногоПотребления" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.РегистрацияБездоговорногоБезучетногоПотребления_БездоговорноеПотребление,	"Бездоговорное потребление");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.РегистрацияБездоговорногоБезучетногоПотребления_БезучетноеПотребление,	"Безучетное потребление");
		
	ИначеЕсли ИмяДокумента = "бестАктированиеНедопускаДопускаЮЛ" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.АктированиеНедопускаЮЛ_АктированиеДопуска,		"Актирование допуска");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.АктированиеНедопускаЮЛ_АктированиеНедопуска,		"Актирование недопуска");
		
	ИначеЕсли ИмяДокумента = "бестПочасоваяВедомость" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ПочасоваяВедомость_ПлановоеПотребление,			"Плановое потребление");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ПочасоваяВедомость_ФактическоеПотребление,		"Фактическое потребление");
		
	ИначеЕсли ИмяДокумента = "бестИзмененитьРазрядностьОбъемовУслуг" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ИзмененитьРазрядностьОбъемовУслуг_ОбщаяНастройка,				"Общая настройка");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ИзмененитьРазрядностьОбъемовУслуг_ИндивидуальнаяНастройка,	"Индивидуальная настройка");
		
	ИначеЕсли ИмяДокумента = "бестКорректировкаЗадолженности" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.КорректировкаЗадолженности_ВозвратПлатежа,				"Возврат платежа");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.КорректировкаЗадолженности_ПереносПлатежа,				"Перенос платежа");
		
	ИначеЕсли ИмяДокумента = "бестПлатежныйДокумент" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ПлатежныйДокумент_СчетНаОстаток,				"Счет на остаток");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ПлатежныйДокумент_Корректировка,				"Корректировка");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ПлатежныйДокумент_Исправление,				"Исправление");
		
	ИначеЕсли ИмяДокумента = "бестПерерасчетЭЭ" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ПерерасчетЭЭ_КорректировкаИсправление,		"Корректировка/исправление");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ПерерасчетЭЭ_СвязанныйПерерасчет,				"Связанный перерасчет");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ПерерасчетЭЭ_РучнойПерерасчет,				"Ручной перерасчет");
		
	ИначеЕсли ИмяДокумента = "бестЗаписиКнигПродажПокупок" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ЗаписиКнигПродажПокупок_КнигаПродаж,		"Книга продаж");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.ЗаписиКнигПродажПокупок_КнигаПокупок,		"Книга покупок");
		
	ИначеЕсли ИмяДокумента = "бестСписаниеВосстановлениеЗадолженности" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.СписаниеВосстановлениеЗадолженности_СписаниеЗадолженности,			"Списание задолженности");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.СписаниеВосстановлениеЗадолженности_ВосстановлениеЗадолженности,		"Восстановление задолженности");
		
	ИначеЕсли ИмяДокумента = "бестРегистрацияБанкротства" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.РегистрацияБанкротства_ПризнаниеБанкротом,			"Признание банкротом");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.РегистрацияБанкротства_ОтменаБанкротства,				"Отмена банкротства");

	ИначеЕсли ИмяДокумента = "бестРеструктуризацияЗадолженности" тогда
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.РеструктуризацияЗадолженности_РегистрацияРеструктуризации,			"Регистрация реструктуризации");
		СписокОпераций.добавить(Перечисления.бестВидыОпераций.РеструктуризацияЗадолженности_ОтменаРеструктуризации,					"Отмена реструктуризации");
		
	Иначе
		МенеджерОбъектов 		= ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени("Документ." + ИмяДокумента);
		врСписокОпераций 		= МенеджерОбъектов.ЗаполнитьСписокВозможныхОперацийФормаСписка();
		Для Каждого ЗначениеСписка Из врСписокОпераций Цикл
			СписокОпераций.Добавить(ЗначениеСписка.Значение, ЗначениеСписка.Представление);
		КонецЦикла;
		
	КонецЕсли;
	
	ЗаполнитьСписокВозможныхОперацийФормаСписка_Переопределяемый(ИмяДокумента, СписокОпераций);
	
КонецПроцедуры

Процедура ЗаполнитьСписокВозможныхОперацийФормаСписка_Переопределяемый(ИмяДокумента, СписокОпераций)
	
КонецПроцедуры

// Функция - Префикс формы
// Определение префикса формы по выбранному виду операции
//
// Параметры:
//  ИмяДокумента		 - Строка
//  ВыбранноеЗначение	 - ПеречислениеСсылка.бестВидыОпераций 
// 
// Возвращаемое значение:
//   Строка - Префикс формы 
//
Функция ПрефиксФормы(ИмяДокумента,ВыбранноеЗначение) Экспорт  
	Соотвествие  		= Новый Соответствие;
	Если ИмяДокумента = "бестЗаключениеДоговоровСЮридическимиЛицами" Тогда
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ОткрытиеДоговора,								"ОткрытиеДоговора");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗакрытиеДоговора,								"ЗакрытиеПерезаключениеДоговора");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ПерезаключениеДоговора,						"ЗакрытиеПерезаключениеДоговора");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение,							"РегистрацияОбъекта");
		//Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСДоговором_АктБездоговорногоПотребления,					"АктБездоговорногоПотребления");
		//Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗаменаДоговораУОбъекта,						"ПерезаключениеДоговора");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСДоговором_РегистрацияОбъекта,							"РегистрацияОбъекта");
		
	ИначеЕсли ИмяДокумента = "бестОперацияСУслугамиНП" Тогда
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСУслугами_ПодключениеУслуги,								"ПодключениеУслуги");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСУслугами_ОтключениеУслуги,								"ОтключениеУслуги");	
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСУслугами_ОграничениеУслуги,								"ОграничениеУслуги");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСУслугами_ВозобновлениеУслуги,							"ВозобновлениеУслуги");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСУслугами_ПодключениеУслугиПослеТП,						"ПодключениеУслугиПослеТП");
		
	ИначеЕсли ИмяДокумента = "бестОперацияСПриборомУчетаНП" тогда
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВводПУ,									"ВводПУ");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВыводПУ,									"ВыводПУ");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ЗаменаПУ,									"ЗаменаПУ");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ЗаменаВспомогательногоПУ,					"ЗаменаПУ");
		
	ИначеЕсли ИмяДокумента = "бестОперацияСОбъектамиНП" тогда
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСОбъектами_ПодключениеОбъекта,							"ПодключениеОбъекта");
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСОбъектами_ОтключениеОбъекта,							"ОтключениеОбъекта");		
		Соотвествие.Вставить(Перечисления.бестВидыОпераций.ОперацияСОбъектами_ЗаменаДоговораУОбъекта,						"ЗаменаДоговораУОбъекта");
		
