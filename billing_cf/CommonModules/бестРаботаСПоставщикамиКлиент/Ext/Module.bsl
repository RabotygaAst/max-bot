#Область ПрограммныйИнтерфейс

// Процедура - При изменении услуги
//
// Параметры:
//  Форма			 - ФормаКлиентскогоПриложения 
//  ТекДанные		 - ДанныеФормыЭлементКоллекции
//  ОписаниеУслуги	 - Структура - ЭтоСоставнаяУслуга, Услуги (Массив из элементов с типом СправочникСсылка.энргВидыУслуг) 
//
Процедура ПриИзмененииУслуги(Форма,ТекДанные,ОписаниеУслуги) Экспорт 
	
	Если ОписаниеУслуги.ЭтоСоставнаяУслуга и не ЗначениеЗаполнено(ТекДанные.IDСтроки) тогда
	//Если  не ЗначениеЗаполнено(ТекДанные.IDСтроки) тогда

		ТекДанные.IDСтроки 					= Новый УникальныйИдентификатор;
	КонецЕсли;
		
	ПоставщикПоУмолчанию 					= Форма.ПараметрыПоставщиков.ПоставщикПоУмолчанию;
	ТекДанные.ЭтоСоставнаяУслуга 			= ОписаниеУслуги.ЭтоСоставнаяУслуга; 	
	
	// ищем строки 
	СтрокиСоотвествия 						= Форма.Объект.ПоставщикиСоставныхУслуг.НайтиСтроки(Новый Структура("IDСтроки",ТекДанные.IDСтроки));	
	для Каждого СтрокаСоотвествия из СтрокиСоотвествия цикл
		Форма.Объект.ПоставщикиСоставныхУслуг.Удалить(СтрокаСоотвествия);
	КонецЦикла;
	
	Если ОписаниеУслуги.ЭтоСоставнаяУслуга тогда
		ПредставлениеПоставщика  			= "";
		для Каждого Строка из ОписаниеУслуги.Услуги цикл
			СтрокаТЧ  						= Форма.Объект.ПоставщикиСоставныхУслуг.Добавить();
			СтрокаТЧ.IDСтроки 				= ТекДанные.IDСтроки;
			СтрокаТЧ.ЧастьСоставнойУслуги 	= Строка;
			СтрокаТЧ.Поставщик 				= ПоставщикПоУмолчанию;
			ПредставлениеПоставщика 		= ПредставлениеПоставщика + ?(ЗначениеЗаполнено(ПредставлениеПоставщика),"/","") +  ПоставщикПоУмолчанию;
		КонецЦикла;
		
		ДанныеСоставныхУслуг	= Форма.ПараметрыПоставщиков.ДанныеСоставныхУслуг;
		IDСтрока				= СтрЗаменить(ТекДанные.IDСтроки,Символы.НПП,"");
		ИмяПоля					= "Поставщик";
		Если ДанныеСоставныхУслуг.Получить(IDСтрока) = Неопределено тогда
			ДанныеСоставныхУслуг.Вставить(IDСтрока,Новый Структура(ИмяПоля,ПредставлениеПоставщика));
		ИначеЕсли ДанныеСоставныхУслуг[IDСтрока][ИмяПоля] = Неопределено тогда
			ДанныеСоставныхУслуг[IDСтрока].вставить(ИмяПоля,ПредставлениеПоставщика);
		иначе
			ДанныеСоставныхУслуг[IDСтрока][ИмяПоля] 	= ПредставлениеПоставщика; 
		КонецЕсли;
	иначе
		ТекДанные.Поставщик 				= ПоставщикПоУмолчанию; 
	КонецЕсли;
КонецПроцедуры

// Процедура - При изменении услуги после
//
// Параметры:
//  Форма			 - ФормаКлиентскогоПриложения 
//  ТекДанные		 - ДанныеФормыЭлементКоллекции 
//  ОписаниеУслуги	 - Структура - ЭтоСоставнаяУслуга, Услуги (Массив из элементов с типом СправочникСсылка.энргВидыУслуг) 
//
Процедура ПриИзмененииУслугиПосле(Форма,ТекДанные,ОписаниеУслуги) Экспорт 
	
	Если ОписаниеУслуги.ЭтоСоставнаяУслуга и не ЗначениеЗаполнено(ТекДанные.IDСтроки) тогда
	//Если  не ЗначениеЗаполнено(ТекДанные.IDСтроки) тогда

		ТекДанные.IDСтроки 					= Новый УникальныйИдентификатор;
	КонецЕсли;
		
	ПоставщикПоУмолчанию 					= Форма.ПараметрыПоставщиков.ПоставщикПоУмолчанию;
	ТекДанные.ЭтоСоставнаяУслуга 			= ОписаниеУслуги.ЭтоСоставнаяУслуга; 	
	
	// ищем строки 
	СтрокиСоотвествия 						= Форма.Объект.ПоставщикиСоставныхУслуг.НайтиСтроки(Новый Структура("IDСтроки",ТекДанные.IDСтроки));	
	для Каждого СтрокаСоотвествия из СтрокиСоотвествия цикл
		Форма.Объект.ПоставщикиСоставныхУслуг.Удалить(СтрокаСоотвествия);
	КонецЦикла;
	
	Если ОписаниеУслуги.ЭтоСоставнаяУслуга тогда
		ПредставлениеПоставщика  			= "";
		для Каждого Строка из ОписаниеУслуги.Услуги цикл
			СтрокаТЧ  						= Форма.Объект.ПоставщикиСоставныхУслуг.Добавить();
			СтрокаТЧ.IDСтроки 				= ТекДанные.IDСтроки;
			СтрокаТЧ.ЧастьСоставнойУслуги 	= Строка;
			СтрокаТЧ.Поставщик 				= ПоставщикПоУмолчанию;
			СтрокаТЧ.ПоставщикПосле         = ПоставщикПоУмолчанию;
			ПредставлениеПоставщика 		= ПредставлениеПоставщика + ?(ЗначениеЗаполнено(ПредставлениеПоставщика),"/","") +  ПоставщикПоУмолчанию;
		КонецЦикла;
		
		ДанныеСоставныхУслуг	= Форма.ПараметрыПоставщиков.ДанныеСоставныхУслуг;
		IDСтрока				= ТекДанные.IDСтроки;
		ИмяПоля					= "ПоставщикПосле";
		Если ДанныеСоставныхУслуг.Получить(IDСтрока) = Неопределено тогда
			ДанныеСоставныхУслуг.Вставить(IDСтрока,Новый Структура(ИмяПоля,ПредставлениеПоставщика));
		ИначеЕсли ДанныеСоставныхУслуг[IDСтрока][ИмяПоля] = Неопределено тогда
			ДанныеСоставныхУслуг[IDСтрока].вставить(ИмяПоля,ПредставлениеПоставщика);
		иначе
			ДанныеСоставныхУслуг[IDСтрока][ИмяПоля] 	= ПредставлениеПоставщика; 
		КонецЕсли;
	иначе
		ТекДанные.Поставщик 				= ПоставщикПоУмолчанию; 
		ТекДанные.ПоставщикПосле 			= ПоставщикПоУмолчанию; 

	КонецЕсли;
КонецПроцедуры

#КонецОбласти
