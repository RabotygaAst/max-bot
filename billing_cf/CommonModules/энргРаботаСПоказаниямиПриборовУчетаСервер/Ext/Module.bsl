Функция ПроверитьПоказанияПоВсемЗонамСуток(Объект) Экспорт 
	Ответ 							= Новый Структура("Успешно, ТекстОшибки", Истина, "");
	Массив							= Новый Массив;
	ИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	ИспользоватьШкалыПриборовУчета 	= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	
	Если НЕ ИспользоватьТарифныеЗоны и НЕ ИспользоватьШкалыПриборовУчета Тогда 
		Возврат Ответ;	
	КонецЕсли;
	
	
	Для Каждого ТекСтрока Из Объект.ТочкиУчета Цикл 
		ИтоговаяСтрока 	= "";
		МассивШкал 		= Объект.ШкалыПриборовУчета.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекСтрока.IDСтроки));
		ОшибкиВШкалах 	= Новый Массив;
		Для Каждого ТекШкала Из МассивШкал Цикл
			МассивПоказаний 			= Объект.ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки", ТекШкала.IDСтроки));
			ПоказанияНеУказаны 			= Новый Массив;
			ВсегоСтрок 					= МассивПоказаний.Количество();
			КолвоУказанныхПоказаний		= 0;
			Для Каждого ТекСтрокаПоказаний Из МассивПоказаний Цикл
				Если ТекСтрокаПоказаний.ПоказанияПредоставлены Тогда
					КолвоУказанныхПоказаний = КолвоУказанныхПоказаний + 1;
				Иначе 
					ПоказанияНеУказаны.Добавить(ТекСтрокаПоказаний.ТарифнаяЗона);
				КонецЕсли;				
			КонецЦикла;
			
			Если КолвоУказанныхПоказаний > 0 И ВсегоСтрок <> КолвоУказанныхПоказаний Тогда	
				Если ИспользоватьШкалыПриборовУчета Тогда
					ИтоговаяСтрока = ИтоговаяСтрока + " в шкале: " + ТекШкала.Шкала;
				КонецЕсли;
				
				Если ИспользоватьТарифныеЗоны Тогда
					ИтоговаяСтрока = ИтоговаяСтрока + " не указаны показания по тарифным зонам: " + СтрСоединить(ПоказанияНеУказаны, ",");
				Иначе 
					ИтоговаяСтрока = ИтоговаяСтрока + " не указаны показания";
				КонецЕсли;
				
				ОшибкиВШкалах.Добавить(ИтоговаяСтрока);               				
			КонецЕсли;	
			
		КонецЦикла;
		
		Если ОшибкиВШкалах.Количество() > 0 Тогда	
			Массив.Добавить("У прибора учета: " + ТекСтрока.ПриборУчета + СтрСоединить(ОшибкиВШкалах, ","));
		КонецЕсли;		
		
	КонецЦикла; 
	
	Если Массив.Количество() > 0 Тогда
		Ответ.Успешно 		= Ложь;	
		Ответ.ТекстОшибки 	= СтрСоединить(Массив, ". ");	
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

Функция ЕстьПринятыеПоказанияДатойПозже(МассивПУ, ПараметрыПроверки) Экспорт 
	
	ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(МассивПУ, Справочники.энргПриборыУчетаАбонента.ПустаяСсылка());
	Если НЕ ЗначениеЗаполнено(МассивПУ) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргПоказанияПриборовУчета.ПриборУчета КАК ПриборУчета
	|ИЗ
	|	РегистрСведений.энргПоказанияПриборовУчета КАК энргПоказанияПриборовУчета
	|ГДЕ
	|	энргПоказанияПриборовУчета.Организация = &Организация
	|	И энргПоказанияПриборовУчета.Район = &Район
	|	И энргПоказанияПриборовУчета.КлючПомещения = &КлючПомещения
	|	И энргПоказанияПриборовУчета.ПриборУчета В(&МассивПУ)
	|	И энргПоказанияПриборовУчета.Период >= &Дата
	|	И энргПоказанияПриборовУчета.СостояниеПоказаний = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|	И НЕ энргПоказанияПриборовУчета.Регистратор = &ТекРегистратор";
	
	Запрос.УстановитьПараметр("Организация"		, ПараметрыПроверки.Организация);
	Запрос.УстановитьПараметр("Район"			, ПараметрыПроверки.Район);
	Запрос.УстановитьПараметр("КлючПомещения"	, ПараметрыПроверки.КлючПомещения); 
	Запрос.УстановитьПараметр("Дата"			, ПараметрыПроверки.Дата); 
	Запрос.УстановитьПараметр("ТекРегистратор"	, ПараметрыПроверки.Ссылка);
	Запрос.УстановитьПараметр("МассивПУ"		, МассивПУ);  
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();  
	
КонецФункции

#КонецОбласти 

#Область СервисПроверкиПоказанийПриборовУчета

Функция ПриборыДляОтклоненияПоказаний(Период, Организация, ТаблицаПриборов, ВспомогательныеПараметры) Экспорт
	ТекстСНеДопуском = РегистрыСведений.энргСостояниеДопускаВПомещение.ТекстЗапросаПриборыБезДопускаПодрядБольшеОпределенногоЧисла("ТаблицаДанных");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаДанных.Район КАК Район,
		|	ТаблицаДанных.КлючПомещения КАК КлючПомещения,
		|	ТаблицаДанных.ТочкаУчета КАК ТочкаУчета,
		|	ТаблицаДанных.ПриборУчета КАК ПриборУчета,
		|	ТаблицаДанных.НомерСтроки КАК НомерСтроки,
		|	ТаблицаДанных.IDСтроки КАК IDСтроки
		|ПОМЕСТИТЬ ТаблицаДанныхНачало
		|ИЗ
		|	&ТаблицаДанных КАК ТаблицаДанных
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ 
		|	&Организация КАК Организация,
		|	ТаблицаДанныхНачало.Район КАК Район,
		|	ТаблицаДанныхНачало.КлючПомещения КАК КлючПомещения,
		|	ТаблицаДанныхНачало.ТочкаУчета КАК ТочкаУчета,
		|	ТаблицаДанныхНачало.ПриборУчета КАК ПриборУчета,
		|	энргКлючиПомещений.Строение КАК Строение,
		|	энргКлючиПомещений.Помещение КАК Помещение,
		|	энргКлючиПомещений.ЧастныйСектор КАК ЧастныйСектор,
		|	ТаблицаДанныхНачало.НомерСтроки КАК НомерСтроки,
		|	ТаблицаДанныхНачало.IDСтроки КАК IDСтроки
		|ПОМЕСТИТЬ ТаблицаДанных
		|ИЗ
		|	ТаблицаДанныхНачало КАК ТаблицаДанныхНачало
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
		|		ПО ТаблицаДанныхНачало.КлючПомещения = энргКлючиПомещений.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргАбонентыПомещенийСрезПоследних.Абонент КАК Абонент,
		|	энргАбонентыПомещенийСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргАбонентыПомещенийСрезПоследних.Район КАК Район
		|ПОМЕСТИТЬ ТаблицаАбоненты
		|ИЗ
		|	РегистрСведений.энргАбонентыПомещений.СрезПоследних(
		|			,
		|			Организация = &Организация
		|				И (КлючПомещения, Район) В
		|					(ВЫБРАТЬ
		|						ТаблицаДанных.КлючПомещения,
		|						ТаблицаДанных.Район
		|					ИЗ
		|						ТаблицаДанных КАК ТаблицаДанных)) КАК энргАбонентыПомещенийСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаДанных.Район КАК Район,
		|	ТаблицаДанных.КлючПомещения КАК КлючПомещения,
		|	ТаблицаДанных.ТочкаУчета КАК ТочкаУчета,
		|	ТаблицаДанных.ПриборУчета КАК ПриборУчета,
		|	ТаблицаДанных.Строение КАК Строение,
		|	ТаблицаДанных.Помещение КАК Помещение,
		|	ТаблицаДанных.ЧастныйСектор КАК ЧастныйСектор,
		|	ТаблицаДанных.НомерСтроки КАК НомерСтроки,
		|	ТаблицаДанных.IDСтроки КАК IDСтроки,
		|	ЕСТЬNULL(ТаблицаАбоненты.Абонент, ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка)) КАК Абонент
		|ПОМЕСТИТЬ ТаблицаДанныхСАбонентом
		|ИЗ
		|	ТаблицаДанных КАК ТаблицаДанных
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаАбоненты КАК ТаблицаАбоненты
		|		ПО ТаблицаДанных.КлючПомещения = ТаблицаАбоненты.КлючПомещения
		|			И (ТаблицаАбоненты.Район = ТаблицаДанных.Район)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос1.Организация КАК Организация,
		|	ВложенныйЗапрос1.Район КАК Район,
		|	ВложенныйЗапрос1.ЧастныйСектор КАК ЧастныйСектор,
		|	ВложенныйЗапрос1.Строение КАК Строение,
		|	ВложенныйЗапрос1.Помещение КАК Помещение,
		|	ВложенныйЗапрос1.Абонент КАК Абонент,
		|	энргРегистрацияВременногоОтсутствия.ПериодС КАК ПериодС,
		|	энргРегистрацияВременногоОтсутствия.ПериодПо КАК ПериодПо,
		|	ВложенныйЗапрос1.ГраницаПериода КАК ГраницаПериода
		|ПОМЕСТИТЬ ПолноеОтсутствиеАбонентаВРасчетномПериоде
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВложенныйЗапрос.Район КАК Район,
		|		ВложенныйЗапрос.ЧастныйСектор КАК ЧастныйСектор,
		|		ВложенныйЗапрос.Строение КАК Строение,
		|		ВложенныйЗапрос.Помещение КАК Помещение,
		|		ВложенныйЗапрос.Организация КАК Организация,
		|		ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
		|		ВложенныйЗапрос.ГраницаПериода КАК ГраницаПериода,
		|		ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
		|		ВложенныйЗапрос.Абонент КАК Абонент,
		|		ВложенныйЗапрос.Дата КАК Дата,
		|		МАКСИМУМ(энргРегистрацияВременногоОтсутствия.Ссылка) КАК Ссылка
		|	ИЗ
		|		(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|			ТаблицаДанных.Район КАК Район,
		|			ТаблицаДанных.ЧастныйСектор КАК ЧастныйСектор,
		|			ТаблицаДанных.Строение КАК Строение,
		|			ТаблицаДанных.Помещение КАК Помещение,
		|			&Организация КАК Организация,
		|			&ПериодНачисления КАК ПериодНачисления,
		|			&ГраницаПериода КАК ГраницаПериода,
		|			ТаблицаДанных.КлючПомещения КАК КлючПомещения,
		|			ТаблицаДанных.Абонент КАК Абонент,
		|			МАКСИМУМ(энргРегистрацияВременногоОтсутствия.Дата) КАК Дата
		|		ИЗ
		|			ТаблицаДанныхСАбонентом КАК ТаблицаДанных
		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргРегистрацияВременногоОтсутствия КАК энргРегистрацияВременногоОтсутствия
		|				ПО ТаблицаДанных.Район = энргРегистрацияВременногоОтсутствия.Район
		|					И ТаблицаДанных.КлючПомещения = энргРегистрацияВременногоОтсутствия.КлючПомещения
		|					И ТаблицаДанных.Абонент = энргРегистрацияВременногоОтсутствия.Абонент
		|					И (энргРегистрацияВременногоОтсутствия.Проведен)
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ТаблицаДанных.Район,
		|			ТаблицаДанных.ЧастныйСектор,
		|			ТаблицаДанных.Строение,
		|			ТаблицаДанных.КлючПомещения,
		|			ТаблицаДанных.Помещение,
		|			ТаблицаДанных.Абонент) КАК ВложенныйЗапрос
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргРегистрацияВременногоОтсутствия КАК энргРегистрацияВременногоОтсутствия
		|			ПО ВложенныйЗапрос.Район = энргРегистрацияВременногоОтсутствия.Район
		|				И ВложенныйЗапрос.КлючПомещения = энргРегистрацияВременногоОтсутствия.КлючПомещения
		|				И ВложенныйЗапрос.Абонент = энргРегистрацияВременногоОтсутствия.Абонент
		|				И (энргРегистрацияВременногоОтсутствия.Проведен)
		|				И ВложенныйЗапрос.Дата = энргРегистрацияВременногоОтсутствия.Дата
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВложенныйЗапрос.Дата,
		|		ВложенныйЗапрос.ЧастныйСектор,
		|		ВложенныйЗапрос.Организация,
		|		ВложенныйЗапрос.ПериодНачисления,
		|		ВложенныйЗапрос.ГраницаПериода,
		|		ВложенныйЗапрос.Строение,
		|		ВложенныйЗапрос.Помещение,
		|		ВложенныйЗапрос.КлючПомещения,
		|		ВложенныйЗапрос.Абонент,
		|		ВложенныйЗапрос.Район) КАК ВложенныйЗапрос1
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргРегистрацияВременногоОтсутствия КАК энргРегистрацияВременногоОтсутствия
		|		ПО ВложенныйЗапрос1.Ссылка = энргРегистрацияВременногоОтсутствия.Ссылка
		|			И (ВложенныйЗапрос1.ГраницаПериода <= КОНЕЦПЕРИОДА(энргРегистрацияВременногоОтсутствия.ПериодПо, ДЕНЬ))
		|;
		| " + ТекстСНеДопуском + "
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	энргПриборыУчетаСИстекшимСрокомПоверкиСрезПоследних.ПриборУчета КАК ПриборУчета,
		|	ЗНАЧЕНИЕ(Перечисление.энргПричиныОтклоненияПоказаний.УПрибораУчетаИстекМПИ) КАК ПричинаОтклонения,
		|	ТаблицаДанных.НомерСтроки КАК НомерСтроки,
		|	ТаблицаДанных.IDСтроки КАК IDСтроки,
		|	1 КАК Приоритет
		|ПОМЕСТИТЬ ПриборыДляОтклоненияПоказаний
		|ИЗ
		|	ТаблицаДанных КАК ТаблицаДанных
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргПриборыУчетаСИстекшимСрокомПоверки.СрезПоследних(
		|				&Период,
		|				Организация = &Организация
		|					И (Район, КлючПомещения, ПриборУчета) В
		|						(ВЫБРАТЬ
		|							ТаблицаДанных.Район КАК Район,
		|							ТаблицаДанных.КлючПомещения КАК КлючПомещения,
		|							ТаблицаДанных.ПриборУчета КАК ПриборУчета
		|						ИЗ
		|							ТаблицаДанных КАК ТаблицаДанных)) КАК энргПриборыУчетаСИстекшимСрокомПоверкиСрезПоследних
		|		ПО (энргПриборыУчетаСИстекшимСрокомПоверкиСрезПоследних.Организация = &Организация)
		|			И ТаблицаДанных.Район = энргПриборыУчетаСИстекшимСрокомПоверкиСрезПоследних.Район
		|			И ТаблицаДанных.КлючПомещения = энргПриборыУчетаСИстекшимСрокомПоверкиСрезПоследних.КлючПомещения
		|			И ТаблицаДанных.ПриборУчета = энргПриборыУчетаСИстекшимСрокомПоверкиСрезПоследних.ПриборУчета
		|ГДЕ
		|	энргПриборыУчетаСИстекшимСрокомПоверкиСрезПоследних.ПоверкаВыполнена = ЛОЖЬ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТаблицаДанных.ПриборУчета,
		|	ЗНАЧЕНИЕ(Перечисление.энргПричиныОтклоненияПоказаний.ОРП),
		|	ТаблицаДанных.НомерСтроки,
		|	ТаблицаДанных.IDСтроки,
		|	2
		|ИЗ
		|	ТаблицаДанных КАК ТаблицаДанных
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
		|				&Период,
		|				Организация = &Организация
		|					И (Район, КлючПомещения, ТочкаУчета) В
		|						(ВЫБРАТЬ
		|							ТаблицаДанных.Район КАК Район,
		|							ТаблицаДанных.КлючПомещения КАК КлючПомещения,
		|							ТаблицаДанных.ТочкаУчета КАК ТочкаУчета
		|						ИЗ
		|							ТаблицаДанных КАК ТаблицаДанных)) КАК энргАктивностьТочекУчетаСрезПоследних
		|		ПО (энргАктивностьТочекУчетаСрезПоследних.Организация = &Организация)
		|			И ТаблицаДанных.Район = энргАктивностьТочекУчетаСрезПоследних.Район
		|			И ТаблицаДанных.КлючПомещения = энргАктивностьТочекУчетаСрезПоследних.КлючПомещения
		|			И ТаблицаДанных.ТочкаУчета = энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета
		|ГДЕ
		|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.ОРП)
		|	И (&ПроверятьОРП)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТаблицаДанных.ПриборУчета,
		|	ЗНАЧЕНИЕ(Перечисление.энргПричиныОтклоненияПоказаний.АбонентОтсутствует),
		|	ТаблицаДанных.НомерСтроки,
		|	ТаблицаДанных.IDСтроки,
		|	3
		|ИЗ
		|	ПолноеОтсутствиеАбонентаВРасчетномПериоде КАК ПолноеОтсутствиеАбонентаВРасчетномПериоде
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаДанныхСАбонентом КАК ТаблицаДанных
		|		ПО ПолноеОтсутствиеАбонентаВРасчетномПериоде.Район = ТаблицаДанных.Район
		|			И ПолноеОтсутствиеАбонентаВРасчетномПериоде.ЧастныйСектор = ТаблицаДанных.ЧастныйСектор
		|			И ПолноеОтсутствиеАбонентаВРасчетномПериоде.Строение = ТаблицаДанных.Строение
		|			И ПолноеОтсутствиеАбонентаВРасчетномПериоде.Помещение = ТаблицаДанных.Помещение
		|			И ПолноеОтсутствиеАбонентаВРасчетномПериоде.Абонент = ТаблицаДанных.Абонент
		|ГДЕ
		|	ПолноеОтсутствиеАбонентаВРасчетномПериоде.ГраницаПериода >= ПолноеОтсутствиеАбонентаВРасчетномПериоде.ПериодС
		|	И ПолноеОтсутствиеАбонентаВРасчетномПериоде.ГраницаПериода <= ПолноеОтсутствиеАбонентаВРасчетномПериоде.ПериодПо
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТаблицаДанных.ПриборУчета,
		|	ЗНАЧЕНИЕ(Перечисление.энргПричиныОтклоненияПоказаний.ЗапретПриемаВПУ),
		|	ТаблицаДанных.НомерСтроки,
		|	ТаблицаДанных.IDСтроки,
		|	4
		|ИЗ
		|	ТаблицаДанных КАК ТаблицаДанных
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
		|		ПО ТаблицаДанных.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
		|			И (НЕ энргПриборыУчетаАбонента.СистемаУчетаЭлектроэнергии = ЗНАЧЕНИЕ(Справочник.энргСистемыУчетаЭлектроэнергии.ПустаяСсылка))
		|			И (&ПроверятьЗапретПриемаВПУ)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПриборыСНЕДопуском.ПриборУчета,
		|	ЗНАЧЕНИЕ(Перечисление.энргПричиныОтклоненияПоказаний.АктНедопуска),
		|	ТаблицаДанных.НомерСтроки,
		|	ТаблицаДанных.IDСтроки,
		|	5
		|ИЗ
		|	ТаблицаДанных КАК ТаблицаДанных
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПриборыСНЕДопуском КАК ПриборыСНЕДопуском
		|		ПО (ТаблицаДанных.Организация = ПриборыСНЕДопуском.Организация)
		|			И ТаблицаДанных.Район = ПриборыСНЕДопуском.Район
		|			И ТаблицаДанных.КлючПомещения = ПриборыСНЕДопуском.КлючПомещения
		|			И ТаблицаДанных.ПриборУчета = ПриборыСНЕДопуском.ПриборУчета
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТаблицаДанных.ПриборУчета,
		|	ЗНАЧЕНИЕ(Перечисление.энргПричиныОтклоненияПоказаний.ПоказанияПредоставленыНеВСрок),
		|	ТаблицаДанных.НомерСтроки,
		|	ТаблицаДанных.IDСтроки,
		|	6
		|ИЗ
		|	ТаблицаДанных КАК ТаблицаДанных
		|ГДЕ
		|	&ПоказанияНеВСрок
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПриборыДляОтклоненияПоказаний.ПриборУчета КАК ПриборУчета,
		|	ПриборыДляОтклоненияПоказаний.ПричинаОтклонения КАК ПричинаОтклонения,
		|	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Отклонены) КАК СостояниеПоказаний,
		|	ПриборыДляОтклоненияПоказаний.НомерСтроки КАК НомерСтроки,
		|	ПриборыДляОтклоненияПоказаний.IDСтроки КАК IDСтроки
		|ИЗ
		|	(ВЫБРАТЬ
		|		ПриборыДляОтклоненияПоказаний.ПриборУчета КАК ПриборУчета,
		|		ПриборыДляОтклоненияПоказаний.НомерСтроки КАК НомерСтроки,
		|		ПриборыДляОтклоненияПоказаний.IDСтроки КАК IDСтроки,
		|		МИНИМУМ(ПриборыДляОтклоненияПоказаний.Приоритет) КАК Приоритет
		|	ИЗ
		|		ПриборыДляОтклоненияПоказаний КАК ПриборыДляОтклоненияПоказаний
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ПриборыДляОтклоненияПоказаний.ПриборУчета,
		|		ПриборыДляОтклоненияПоказаний.НомерСтроки,
		|		ПриборыДляОтклоненияПоказаний.IDСтроки) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПриборыДляОтклоненияПоказаний КАК ПриборыДляОтклоненияПоказаний
		|		ПО ВложенныйЗапрос.Приоритет = ПриборыДляОтклоненияПоказаний.Приоритет
		|			И ВложенныйЗапрос.ПриборУчета = ПриборыДляОтклоненияПоказаний.ПриборУчета
		|			И ВложенныйЗапрос.НомерСтроки = ПриборыДляОтклоненияПоказаний.НомерСтроки
		|			И ВложенныйЗапрос.IDСтроки = ПриборыДляОтклоненияПоказаний.IDСтроки";
	
	ЭтоЗагрузкаПоказанийИзВнешнийИсточников = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ВспомогательныеПараметры, 
		"ЭтоЗагрузкаПоказанийИзВнешнийИсточников", 
		Ложь);
	ПроверятьЗапретПриемаВПУ = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ВспомогательныеПараметры,
		"ПроверятьЗапретПриемаВПУ",
		Истина);
	ПроверятьОРП = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ВспомогательныеПараметры,
		"ПроверятьОРП",
		Истина);
		
	Если НЕ ЭтоЗагрузкаПоказанийИзВнешнийИсточников Тогда 
		ТаблицаПриборов.Колонки.Добавить("НомерСтроки"	, ОбщегоНазначения.ОписаниеТипаЧисло(10));
		ТаблицаПриборов.Колонки.Добавить("IDСтроки"		, ОбщегоНазначения.ОписаниеТипаСтрока(36));
	КонецЕсли; 	
	
	Запрос.УстановитьПараметр("Период"					, Период);
	Запрос.УстановитьПараметр("Организация"				, Организация);
	Запрос.УстановитьПараметр("ТаблицаДанных"			, ТаблицаПриборов);
	Запрос.УстановитьПараметр("ПоказанияНеВСрок"		, НЕ ВспомогательныеПараметры.ПоказанияВСрок);	
	Запрос.УстановитьПараметр("ПериодНачисления"		, ВспомогательныеПараметры.ПериодНачисления);	
	Запрос.УстановитьПараметр("ГраницаПериода"			, Период.Значение);
	Запрос.УстановитьПараметр("ПроверятьЗапретПриемаВПУ", ПроверятьЗапретПриемаВПУ);
	Запрос.УстановитьПараметр("ПроверятьОРП"			, ПроверятьОРП);
	Запрос.УстановитьПараметр("КолвоНедопусковПодряд"	, энргРаботаСКонстантами.ЗначениеКонстантыКоличествоНедопусковДляОтклоненияПоказаний());
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса;
	
КонецФункции

Процедура ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний(ФормаОбъекта, РезультатЗапроса, ОчищатьТаблицуПриборов = Истина) Экспорт
	
	Если НЕ ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ФормаОбъекта, "ПриборыДляОтклоненияПоказаний") Тогда 
		Возврат;
	КонецЕсли;
	
	ПриборыДляОтклоненияПоказаний = ФормаОбъекта.ПриборыДляОтклоненияПоказаний;
	Если ОчищатьТаблицуПриборов Тогда 
		ПриборыДляОтклоненияПоказаний.Очистить();
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();	
	Пока Выборка.Следующий() Цикл
		НСтрока = ПриборыДляОтклоненияПоказаний.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, Выборка);
	КонецЦикла;
	
КонецПроцедуры


Функция ПоказанияПредоставляютсяВСрок(ПериодНачисления, ПериодРегистрации, Организация, Район) Экспорт
	ПериодРегистрации		= ?(ПериодРегистрации = Дата(1, 1, 1), ТекущаяДата(), ПериодРегистрации);
	
	СтруктураСреза  		= РегистрыСведений.энргПериодыПриемаПоказаний.ПолучитьПоследнее(ПериодРегистрации, Новый Структура("Организация", Организация));
	ПоказанияС				= ?(Не ЗначениеЗаполнено(СтруктураСреза.ДатаС), 1, СтруктураСреза.ДатаС);
	ПоказанияПО 			= ?(Не ЗначениеЗаполнено(СтруктураСреза.ДатаПо), 31, СтруктураСреза.ДатаПо);
	
	ГраницыПериода  		= Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация, Район, ПериодНачисления);	
	НачалоПериодаРасчета	= ГраницыПериода.НачалоОП;
	
	ВСрок 					= ПериодРегистрации >= НачалоПериодаРасчета И День(ПериодРегистрации) >= ПоказанияС И День(ПериодРегистрации) <= ПоказанияПО;
	Возврат ВСрок;
КонецФункции


Функция НоваяТаблицаПриборовДляПроверки() Экспорт 
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Район"			, Новый ОписаниеТипов("СправочникСсылка.энргЗоныОтвественности"));
	Результат.Колонки.Добавить("КлючПомещения"	, Новый ОписаниеТипов("СправочникСсылка.энргКлючиПомещений"));
	Результат.Колонки.Добавить("ТочкаУчета"		, Новый ОписаниеТипов("СправочникСсылка.энргТочкиУчета"));
	Результат.Колонки.Добавить("ПриборУчета"	, Новый ОписаниеТипов("СправочникСсылка.энргПриборыУчетаАбонента"));
	
	Возврат Результат;
	
КонецФункции 

Функция НовыеВспомогательныеПараметрыПроверкиОтклоненияПоказаний() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ПоказанияВСрок"			, Ложь);
	Результат.Вставить("ПериодНачисления"		, Дата(1,1,1));
	Результат.Вставить("ЭтоЗагрузкаПоказанийИзВнешнийИсточников", Ложь);
	Результат.Вставить("ПроверятьЗапретПриемаВПУ", Истина);
	Результат.Вставить("ПроверятьОРП", Истина);
	
	Возврат Результат;
	
КонецФункции

Функция ПараметрыОтветаОпределитьСостояниеПоказанийПоСтроке() Экспорт 
	
	Результат = Новый Структура;
	Результат.Вставить("СостояниеИзменено"		, Ложь);
	Результат.Вставить("СостояниеПоказаний"		, Перечисления.энргСостояниеПоказаний.ПустаяСсылка());
	Результат.Вставить("ПричинаОтклонения"		, Перечисления.энргПричиныОтклоненияПоказаний.ПустаяСсылка());
	Результат.Вставить("ПоказанияПредоставлены"	, Ложь);
	Результат.Вставить("Разница"				, 0);
	Результат.Вставить("Сумма"					, 0);
	
	Возврат Результат;
	
КонецФункции

Функция ПричиныОтклоненияИсключая() Экспорт 
	
	Результат = Новый Массив;
	Результат.Добавить(Перечисления.энргПричиныОтклоненияПоказаний.ЗапретПриемаВПУ);
	Результат.Добавить(Перечисления.энргПричиныОтклоненияПоказаний.АктНедопуска);
	Результат.Добавить(Перечисления.энргПричиныОтклоненияПоказаний.ПоказанияПредоставленыНеВСрок);
	Результат.Добавить(Перечисления.энргПричиныОтклоненияПоказаний.АбонентОтсутствует);
	Результат.Добавить(Перечисления.энргПричиныОтклоненияПоказаний.ОРП);
	
	Возврат Результат;
	
КонецФункции

Функция РезультатДанныеЗаполненияТаблицыПоказанийСУчетомОтклонения(Организация, Район, тзТаблицаПоказаний, МоментВремени, тзПриборыДляОтклоненияПоказаний, КонтрольныйСъем = Ложь) Экспорт 
		
	мРайоны 						= ОбщегоНазначенияКлиентСервер.СвернутьМассив(тзТаблицаПоказаний.ВыгрузитьКолонку("Район"));
	мКлючиПомещений 				= ОбщегоНазначенияКлиентСервер.СвернутьМассив(тзТаблицаПоказаний.ВыгрузитьКолонку("КлючПомещения"));
	
	МВТ  							= Новый МенеджерВременныхТаблиц;
	
	Параметры  						= Новый Структура; 	
	ПараметрыВТ						= Новый Массив;
	Если ЗначениеЗаполнено(Организация) Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", 	Новый Структура("Организация","Организация")));
	КонецЕсли;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", 	Новый Структура("ПериодНачисления","ПериодНачисления")));
	
	Если мРайоны.Количество() = 1 Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", 	Новый Структура("Район","мРайоны")));
	ИначеЕсли мРайоны.Количество() > 1 Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраВСписке", 	Новый Структура("Район","мРайоны")));
	КонецЕсли; 
	
	Если мКлючиПомещений.Количество() = 1 Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", 	Новый Структура("КлючПомещения","мКлючПомещений")));
	Иначе
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраВСписке", 	Новый Структура("КлючПомещения","мКлючПомещений")));
	КонецЕсли;
		
	Параметры.Вставить("ПараметрыВТ", 			ПараметрыВТ);
	
	Если ЗначениеЗаполнено(МоментВремени) Тогда
		Параметры.Вставить("Период", 			Новый Структура("ИмяПараметра","Период"));
	КонецЕсли;	
	
	Параметры.Вставить("ВыбиратьРазрешенные", 	Ложь);
	Схема  							= Неопределено;
	РегистрыСведений.энргМаксимальныеПоказателиПотребления.МаксимальныеПоказателиПотребления(Схема,Параметры,"МаксимальныеПоказателиПотребления");
	РегистрыСведений.энргКоэффциентыПриборовУчета.КоэффциентыПриборовУчета(Схема,Параметры,"КоэффциентыПриборовУчета");
	РегистрыСведений.энргСреднийОбъемПотребленияАбонентов.СреднийОбъемПотребленияАбонентов(Схема,Параметры,"СреднийОбъемПотребленияАбонентов");
	РегистрыСведений.энргМаксимальныеПоказания.МаксимальныеПоказанияСрез(Схема,Параметры,"МаксимальныеПоказанияСрез");
	энргРаботаСТочкамиУчетаСервер.ЗначенияТарифовУслугАбонентовВоВременную(МВТ, Схема, Параметры, Организация, МоментВремени, мРайоны, мКлючиПомещений);
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ТекущиеДанныеДокумента.НомерСтроки КАК НомерСтроки,
	|	ТекущиеДанныеДокумента.Организация КАК Организация,
	|	ТекущиеДанныеДокумента.Район КАК Район,
	|	ТекущиеДанныеДокумента.КлючПомещения КАК КлючПомещения,
	|	ТекущиеДанныеДокумента.ВидДифференцированности КАК ВидДифференцированности,
	|	ТекущиеДанныеДокумента.ПриборУчета КАК ПриборУчета,
	|	ТекущиеДанныеДокумента.Шкала КАК Шкала,
	|	ТекущиеДанныеДокумента.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТекущиеДанныеДокумента.ТочкаУчета КАК ТочкаУчета,
	|	ТекущиеДанныеДокумента.Услуга КАК Услуга,
	|	ТекущиеДанныеДокумента.ПредыдущиеПоказания КАК ПредыдущиеПоказания,
	|	ТекущиеДанныеДокумента.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ТекущиеДанныеДокумента.Переворот КАК Переворот,
	|	ТекущиеДанныеДокумента.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ТекущиеДанныеДокумента.СостояниеПоказаний КАК СостояниеПоказаний,
	|	ТекущиеДанныеДокумента.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем
	|ПОМЕСТИТЬ ТекущиеДанные
	|ИЗ
	|	&ТекущиеДанные КАК ТекущиеДанныеДокумента"); 
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ТаблицаПриборыДляОтклоненияПоказаний.ПриборУчета КАК ПриборУчета,
	|	ТаблицаПриборыДляОтклоненияПоказаний.СостояниеПоказаний КАК СостояниеПоказаний,
	|	ТаблицаПриборыДляОтклоненияПоказаний.ПричинаОтклонения КАК ПричинаОтклонения
	|ПОМЕСТИТЬ ПриборыДляОтклоненияПоказаний
	|ИЗ
	|	&ПриборыДляОтклоненияПоказаний КАК ТаблицаПриборыДляОтклоненияПоказаний"); 
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ТекущиеДанные.Организация КАК Организация,
