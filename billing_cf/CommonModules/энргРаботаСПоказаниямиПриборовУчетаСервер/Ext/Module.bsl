#Область ОбработчикиСобытий

// Процедура - Обновить показания приборов учета
//
// Параметры:
//  Район	 - СправочникСсылкаРайоны	 	-.
												// Используется для отбора в среднем объеме потребления.
//  Дом		 - 	 - 
//  Абонент	 - 	 - 
//  Дата	 - 	 - 
Функция РезультатДанныеЗаполненияТаблицыПоказаний(Организация, Район, тзТаблицаПоказаний, МоментВремени, КонтрольныйСъем = Ложь) Экспорт 
		
	мРайоны 						= ОбщегоНазначенияКлиентСервер.СвернутьМассив(тзТаблицаПоказаний.ВыгрузитьКолонку("Район"));
	мКлючиПомещений 				= ОбщегоНазначенияКлиентСервер.СвернутьМассив(тзТаблицаПоказаний.ВыгрузитьКолонку("КлючПомещения"));
	
	МВТ  							= Новый МенеджерВременныхТаблиц;
	
	Параметры  						= Новый Структура; 	
	ПараметрыВТ						= Новый Массив;
	Если ЗначениеЗаполнено(Организация) Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", 	Новый Структура("Организация","Организация")));
	КонецЕсли;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", 	Новый Структура("ПериодНачисления","ПериодНачисления")));
	
	Если мРайоны.Количество() = 1 Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", 	Новый Структура("Район","мРайоны")));
	ИначеЕсли мРайоны.Количество() > 1 Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраВСписке", 	Новый Структура("Район","мРайоны")));
	КонецЕсли; 
	
	Если мКлючиПомещений.Количество() = 1 Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", 	Новый Структура("КлючПомещения","мКлючПомещений")));
	Иначе
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраВСписке", 	Новый Структура("КлючПомещения","мКлючПомещений")));
	КонецЕсли;
		
	Параметры.Вставить("ПараметрыВТ", 			ПараметрыВТ);
	
	Если ЗначениеЗаполнено(МоментВремени) Тогда
		Параметры.Вставить("Период", 			Новый Структура("ИмяПараметра","Период"));
	КонецЕсли;	
	
	Параметры.Вставить("ВыбиратьРазрешенные", 	Ложь);
	Схема  							= Неопределено;
	РегистрыСведений.энргМаксимальныеПоказателиПотребления.МаксимальныеПоказателиПотребления(Схема,Параметры,"МаксимальныеПоказателиПотребления");
	РегистрыСведений.энргКоэффциентыПриборовУчета.КоэффциентыПриборовУчета(Схема,Параметры,"КоэффциентыПриборовУчета");
	РегистрыСведений.энргСреднийОбъемПотребленияАбонентов.СреднийОбъемПотребленияАбонентов(Схема,Параметры,"СреднийОбъемПотребленияАбонентов");
	РегистрыСведений.энргМаксимальныеПоказания.МаксимальныеПоказанияСрез(Схема,Параметры,"МаксимальныеПоказанияСрез");
	энргРаботаСТочкамиУчетаСервер.ЗначенияТарифовУслугАбонентовВоВременную(МВТ, Схема, Параметры, Организация, МоментВремени, мРайоны, мКлючиПомещений);
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ТекущиеДанныеДокумента.НомерСтроки КАК НомерСтроки,
	|	ТекущиеДанныеДокумента.Организация КАК Организация,
	|	ТекущиеДанныеДокумента.Район КАК Район,
	|	ТекущиеДанныеДокумента.КлючПомещения КАК КлючПомещения,
	|	ТекущиеДанныеДокумента.ВидДифференцированности КАК ВидДифференцированности,
	|	ТекущиеДанныеДокумента.ПриборУчета КАК ПриборУчета,
	|	ТекущиеДанныеДокумента.Шкала КАК Шкала,
	|	ТекущиеДанныеДокумента.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТекущиеДанныеДокумента.ТочкаУчета КАК ТочкаУчета,
	|	ТекущиеДанныеДокумента.Услуга КАК Услуга,
	|	ТекущиеДанныеДокумента.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ТекущиеДанныеДокумента.Переворот КАК Переворот,
	|	ТекущиеДанныеДокумента.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ТекущиеДанныеДокумента.СостояниеПоказаний КАК СостояниеПоказаний,
	|	ТекущиеДанныеДокумента.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем
	|ПОМЕСТИТЬ ТекущиеДанные
	|ИЗ
	|	&ТекущиеДанные КАК ТекущиеДанныеДокумента"); 	
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ТекущиеДанные.Организация КАК Организация,
	|	ТекущиеДанные.Район КАК Район,
	|	ТекущиеДанные.НомерСтроки КАК НомерСтроки,
	|	ТекущиеДанные.КлючПомещения КАК КлючПомещения,
	|	ТекущиеДанные.ТочкаУчета КАК ТочкаУчета,
	|	ТекущиеДанные.Услуга КАК Услуга,
	|	ТекущиеДанные.ПриборУчета КАК ПриборУчета,
	|	ТекущиеДанные.Шкала КАК Шкала,
	|	ТекущиеДанные.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТекущиеДанные.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ТекущиеДанные.Переворот КАК ТекущийПереворот,
	|	ТекущиеДанные.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ТекущиеДанные.СостояниеПоказаний КАК ТекущиеСостояниеПоказаний,
	|	ТекущиеДанные.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем,
	|	ЕСТЬNULL(КоэффциентыПриборовУчета.Коэффициент, 1) КАК Коэффициент,
	|	ЕСТЬNULL(энргПриборыУчетаАбонента.МаксимальноВозможныеПоказания, 0) КАК МаксимальноВозможные,
	|	ЕСТЬNULL(энргПриборыУчетаАбонента.РегистрируетОбъем, ЛОЖЬ) КАК РегистрируетОбъем,
	|	ЕСТЬNULL(МаксимальныеПоказателиПотребления.МаксимальноеПотребления, 0) КАК МаксимальныйОбъемПотребления,
	|	ЕСТЬNULL(МаксимальныеПоказателиПотребления.ПовышающийКоэффициент, 1) КАК ПовышающийКоэффициентМаксимальноеПотребления,
	|	ЕСТЬNULL(ТаблицаЗначенийТарифовТочекУчета.ЗначениеТарифа, 0) КАК ЗначениеТарифа,
	|	ЕСТЬNULL(ТаблицаЗначенийТарифовТочекУчета.ПредставлениеЗначениеТарифа, """") КАК ПредставлениеЗначениеТарифа
	|ПОМЕСТИТЬ ДанныеДокументаСПоказаниями
	|ИЗ
	|	ТекущиеДанные КАК ТекущиеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ КоэффциентыПриборовУчета КАК КоэффциентыПриборовУчета
	|		ПО ТекущиеДанные.КлючПомещения = КоэффциентыПриборовУчета.КлючПомещения И ТекущиеДанные.КлючПомещения = КоэффциентыПриборовУчета.КлючПомещения
	|			И ТекущиеДанные.ПриборУчета = КоэффциентыПриборовУчета.ПриборУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ТекущиеДанные.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ МаксимальныеПоказателиПотребления КАК МаксимальныеПоказателиПотребления
	|		ПО ТекущиеДанные.Услуга = МаксимальныеПоказателиПотребления.Услуга
	|			И ТекущиеДанные.ТарифнаяЗона = МаксимальныеПоказателиПотребления.ТарифнаяЗона
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаЗначенийТарифовТочекУчета КАК ТаблицаЗначенийТарифовТочекУчета
	|		ПО ТекущиеДанные.КлючПомещения = ТаблицаЗначенийТарифовТочекУчета.КлючПомещения
	|			И ТекущиеДанные.ТочкаУчета = ТаблицаЗначенийТарифовТочекУчета.ТочкаУчета
	|			И ТекущиеДанные.ТарифнаяЗона = ТаблицаЗначенийТарифовТочекУчета.ТарифнаяЗона");
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(	
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ВложенныйЗапрос.ПоследниеПоказания КАК ПоследниеПоказания,
	|	ВложенныйЗапрос.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ВложенныйЗапрос.СреднийОбъемПотребления КАК СреднийОбъемПотребления,
	|	ВложенныйЗапрос.ДатаПоследнихПоказаний КАК ДатаПоследнихПоказаний,
	|	(ВложенныйЗапрос.ТекущиеПоказания - ВложенныйЗапрос.ПоследниеПоказания) * ВложенныйЗапрос.Коэффициент КАК Расход,
	|	ВЫБОР
	|		КОГДА ВложенныйЗапрос.ТекущиеПоказания < ВложенныйЗапрос.ПоследниеПоказания
	|			ТОГДА (ВложенныйЗапрос.ПоследниеПоказания - ВложенныйЗапрос.ТекущиеПоказания) * ВложенныйЗапрос.Коэффициент
	|		ИНАЧЕ (ВложенныйЗапрос.ТекущиеПоказания - ВложенныйЗапрос.ПоследниеПоказания) * ВложенныйЗапрос.Коэффициент
	|	КОНЕЦ КАК РасходПоМодулю,
	|	(ВложенныйЗапрос.МаксимальноВозможные - ВложенныйЗапрос.ПоследниеПоказания + ВложенныйЗапрос.ТекущиеПоказания) * ВложенныйЗапрос.Коэффициент КАК РасходСПереворотом,
	|	ВЫБОР
	|		КОГДА ВложенныйЗапрос.СреднийОбъемПотребления > ВложенныйЗапрос.МаксимальныйОбъемПотребления
	|				И ВложенныйЗапрос.СреднийОбъемПотребления > 0
	|			ТОГДА ВложенныйЗапрос.СреднийОбъемПотребления
	|		ИНАЧЕ ВложенныйЗапрос.МаксимальныйОбъемПотребления
	|	КОНЕЦ * ВложенныйЗапрос.ПовышающийКоэффициентМаксимальноеПотребления * ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(ВложенныйЗапрос.ДатаПоследнихПоказаний, &ПериодНачисления, МЕСЯЦ) = 0
	|			ТОГДА 1
	|		ИНАЧЕ РАЗНОСТЬДАТ(ВложенныйЗапрос.ДатаПоследнихПоказаний, &ПериодНачисления, МЕСЯЦ)
	|	КОНЕЦ КАК МаксимальныйРасходЗаПериод,
	|	ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(ВложенныйЗапрос.ДатаПоследнихПоказаний, &ПериодНачисления, МЕСЯЦ) = 0
	|			ТОГДА 1
	|		ИНАЧЕ РАЗНОСТЬДАТ(ВложенныйЗапрос.ДатаПоследнихПоказаний, &ПериодНачисления, МЕСЯЦ)
	|	КОНЕЦ КАК РазностьМесяцев,
	|	ВложенныйЗапрос.Коэффициент КАК КоэффициентПУ,
	|	ВложенныйЗапрос.ТекущийПереворот КАК ТекущийПереворот,
	|	ВложенныйЗапрос.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ВложенныйЗапрос.ТекущиеСостояниеПоказаний КАК ТекущиеСостояниеПоказаний,
	|	ВложенныйЗапрос.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем,
	|	ВложенныйЗапрос.МаксимальноВозможные КАК МаксимальноВозможныеПоказания,
	|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	ВложенныйЗапрос.ЗначениеТарифа КАК ЗначениеТарифа,
	|	ВложенныйЗапрос.ПредставлениеЗначениеТарифа КАК ПредставлениеЗначениеТарифа
	|ПОМЕСТИТЬ ДанныеДляАнализа
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеДокументаСПоказаниями.Организация КАК Организация,
	|		ДанныеДокументаСПоказаниями.Район КАК Район,
	|		ДанныеДокументаСПоказаниями.КлючПомещения КАК КлючПомещения,
	|		ДанныеДокументаСПоказаниями.ТочкаУчета КАК ТочкаУчета,
	|		ДанныеДокументаСПоказаниями.Шкала КАК Шкала,
	|		ДанныеДокументаСПоказаниями.НомерСтроки КАК НомерСтроки,
	|		ДанныеДокументаСПоказаниями.ТарифнаяЗона КАК ТарифнаяЗона,
	|		ДанныеДокументаСПоказаниями.Коэффициент КАК Коэффициент,
	|		ДанныеДокументаСПоказаниями.ТекущийПереворот КАК ТекущийПереворот,
	|		ДанныеДокументаСПоказаниями.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|		ДанныеДокументаСПоказаниями.ТекущиеПоказания КАК ТекущиеПоказания,
	|		ДанныеДокументаСПоказаниями.ТекущиеСостояниеПоказаний КАК ТекущиеСостояниеПоказаний,
	|		ДанныеДокументаСПоказаниями.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем,
	|		ДанныеДокументаСПоказаниями.МаксимальноВозможные КАК МаксимальноВозможные,
	|		ДанныеДокументаСПоказаниями.МаксимальныйОбъемПотребления КАК МаксимальныйОбъемПотребления,
	|		ДанныеДокументаСПоказаниями.ПовышающийКоэффициентМаксимальноеПотребления КАК ПовышающийКоэффициентМаксимальноеПотребления,
	|		ДанныеДокументаСПоказаниями.РегистрируетОбъем КАК РегистрируетОбъем,
	|		ДанныеДокументаСПоказаниями.ЗначениеТарифа КАК ЗначениеТарифа,
	|		ДанныеДокументаСПоказаниями.ПредставлениеЗначениеТарифа КАК ПредставлениеЗначениеТарифа,
	|		ЕСТЬNULL(СреднийОбъемПотребленияАбонентов.Объем, 0) КАК СреднийОбъемПотребления,
	|		ЕСТЬNULL(МаксимальныеПоказанияСрез.Период, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПоследнихПоказаний,
	|		ЕСТЬNULL(МаксимальныеПоказанияСрез.Показание, 0) КАК ПоследниеПоказания
	|	ИЗ
	|		ДанныеДокументаСПоказаниями КАК ДанныеДокументаСПоказаниями
	|			ЛЕВОЕ СОЕДИНЕНИЕ МаксимальныеПоказанияСрез КАК МаксимальныеПоказанияСрез
	|			ПО ДанныеДокументаСПоказаниями.КлючПомещения = МаксимальныеПоказанияСрез.КлючПомещения
	|				И ДанныеДокументаСПоказаниями.ПриборУчета = МаксимальныеПоказанияСрез.ПриборУчета
	|				И ДанныеДокументаСПоказаниями.Шкала = МаксимальныеПоказанияСрез.Шкала
	|				И ДанныеДокументаСПоказаниями.ТарифнаяЗона = МаксимальныеПоказанияСрез.ТарифнаяЗона
	|			ЛЕВОЕ СОЕДИНЕНИЕ СреднийОбъемПотребленияАбонентов КАК СреднийОбъемПотребленияАбонентов
	|			ПО ДанныеДокументаСПоказаниями.КлючПомещения = СреднийОбъемПотребленияАбонентов.КлючПомещения
	|				И ДанныеДокументаСПоказаниями.ТочкаУчета = СреднийОбъемПотребленияАбонентов.ТочкаУчета
	|				И ДанныеДокументаСПоказаниями.ТарифнаяЗона = СреднийОбъемПотребленияАбонентов.ТарифнаяЗона
	|				И ДанныеДокументаСПоказаниями.Шкала = СреднийОбъемПотребленияАбонентов.Шкала) КАК ВложенныйЗапрос");
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеДляАнализа.Организация КАК Организация,
	|	ДанныеДляАнализа.Район КАК Район,
	|	ДанныеДляАнализа.НомерСтроки КАК НомерСтроки,
	|	ДанныеДляАнализа.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ДанныеДляАнализа.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ВЫБОР
	|		КОГДА ДанныеДляАнализа.ПереворотИзмененПользователем
	|			ТОГДА ДанныеДляАнализа.ТекущийПереворот
	|		КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|			ТОГДА ЛОЖЬ
	|		КОГДА ДанныеДляАнализа.Расход >= 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ДанныеДляАнализа.РасходСПереворотом < ДанныеДляАнализа.МаксимальныйРасходЗаПериод
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ
	|	КОНЕЦ КАК Переворот,
	|	ДанныеДляАнализа.ДатаПоследнихПоказаний КАК ДатаПоследнихПоказаний,
	|	ДанныеДляАнализа.СреднийОбъемПотребления КАК СреднийОбъемПотребления,
	|	ВЫБОР
	|		КОГДА ДанныеДляАнализа.ПереворотИзмененПользователем
	|			ТОГДА ВЫБОР
	|					КОГДА ДанныеДляАнализа.ТекущийПереворот
	|						ТОГДА ДанныеДляАнализа.РасходСПереворотом
	|					ИНАЧЕ ДанныеДляАнализа.Расход
	|				КОНЕЦ
	|		КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|			ТОГДА 0
	|		КОГДА ДанныеДляАнализа.Расход >= 0
	|			ТОГДА ДанныеДляАнализа.Расход
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ДанныеДляАнализа.РасходСПереворотом < ДанныеДляАнализа.МаксимальныйРасходЗаПериод
	|					ТОГДА ДанныеДляАнализа.РасходСПереворотом
	|				ИНАЧЕ -ДанныеДляАнализа.РасходПоМодулю
	|			КОНЕЦ
	|	КОНЕЦ КАК Разница,
	|	ЛОЖЬ КАК ПереворотИзмененПользователем,
	|	ЛОЖЬ КАК СтатусИзмененПользователем,
	|	ДанныеДляАнализа.МаксимальноВозможныеПоказания КАК МаксимальноВозможныеПоказания,
	|	ДанныеДляАнализа.МаксимальныйРасходЗаПериод КАК МаксимальноВозможныйОбъемПотребления,
	|	ВЫБОР
	|		КОГДА ДанныеДляАнализа.ПереворотИзмененПользователем
	|			ТОГДА ДанныеДляАнализа.ТекущиеСостояниеПоказаний
	|		КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|			ТОГДА ВЫБОР
	|					КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|							И ДанныеДляАнализа.ПоследниеПоказания = 0
	|						ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Отклонены)
	|				КОНЕЦ
	|		КОГДА ДанныеДляАнализа.Расход = 0
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|		КОГДА &КонтрольныйСъем
	|				И ВЫБОР
	|					КОГДА ДанныеДляАнализа.Расход >= 0
	|						ТОГДА ДанныеДляАнализа.Расход
	|					ИНАЧЕ ВЫБОР
	|							КОГДА ДанныеДляАнализа.РасходСПереворотом < ДанныеДляАнализа.МаксимальныйРасходЗаПериод
	|								ТОГДА ДанныеДляАнализа.РасходСПереворотом
	|							ИНАЧЕ -ДанныеДляАнализа.РасходПоМодулю
	|						КОНЕЦ
	|				КОНЕЦ >= 0
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|		КОГДА ВЫБОР
	|				КОГДА ДанныеДляАнализа.Расход >= 0
	|					ТОГДА ДанныеДляАнализа.Расход
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ДанныеДляАнализа.РасходСПереворотом < ДанныеДляАнализа.МаксимальныйРасходЗаПериод
	|							ТОГДА ДанныеДляАнализа.РасходСПереворотом
	|						ИНАЧЕ ДанныеДляАнализа.Расход
	|					КОНЕЦ
	|			КОНЕЦ >= 0
	|			ТОГДА ВЫБОР
	|					КОГДА ВЫБОР
	|							КОГДА ДанныеДляАнализа.Расход >= 0
	|								ТОГДА ДанныеДляАнализа.Расход
	|							ИНАЧЕ ВЫБОР
	|									КОГДА ДанныеДляАнализа.РасходСПереворотом < ДанныеДляАнализа.МаксимальныйРасходЗаПериод
	|										ТОГДА ДанныеДляАнализа.РасходСПереворотом
	|									ИНАЧЕ ДанныеДляАнализа.РасходПоМодулю
	|								КОНЕЦ
	|						КОНЕЦ > ДанныеДляАнализа.МаксимальныйРасходЗаПериод
	|						ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Отклонены)
	|					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|				КОНЕЦ
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Отклонены)
	|	КОНЕЦ КАК СостояниеПоказаний,
	|	ДанныеДляАнализа.КоэффициентПУ КАК КоэффициентПУ,
	|	ДанныеДляАнализа.ПоследниеПоказания КАК ПредыдущиеПоказания,
	|	ДанныеДляАнализа.ЗначениеТарифа КАК ЗначениеТарифа,
	|	ДанныеДляАнализа.ПредставлениеЗначениеТарифа КАК ПредставлениеЗначениеТарифа
	|ИЗ
	|	ДанныеДляАнализа КАК ДанныеДляАнализа");  
	
	ДатаОпределенияПериодаНачисления 	= ТекущаяДата();
	Если ТипЗнч(МоментВремени) = Тип("Дата") И ЗначениеЗаполнено(МоментВремени) Тогда
		ДатаОпределенияПериодаНачисления 	= МоментВремени; 
	Иначе
		// 
	КонецЕсли;
	
	ПериодНачисления 					= Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ДатаОпределенияПериодаНачисления, Организация, Район);
	ПараметрыЗапроса 					= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация",			Организация);
	ПараметрыЗапроса.Вставить("ПериодНачисления",		ПериодНачисления);
	ПараметрыЗапроса.Вставить("ТекущиеДанные",			тзТаблицаПоказаний);
	ПараметрыЗапроса.Вставить("КонтрольныйСъем",		КонтрольныйСъем);
	ПараметрыЗапроса.Вставить("Период",					МоментВремени);
	
	Если мРайоны.Количество() = 1 Тогда
		ПараметрыЗапроса.Вставить("мРайоны",			мРайоны[0]);
	Иначе
		ПараметрыЗапроса.Вставить("мРайоны",			мРайоны);
	КонецЕсли;
	
	Если мКлючиПомещений.Количество() = 1 Тогда
		ПараметрыЗапроса.Вставить("мКлючПомещений",		мКлючиПомещений[0]);
	Иначе
		ПараметрыЗапроса.Вставить("мКлючПомещений",		мКлючиПомещений);
	КонецЕсли;
		
	РезультатЗапроса				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса, МВТ);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргРаботаСПоказаниямиПриборовУчетаСервер.РезультатДанныеЗаполненияТаблицыПоказаний";
		ПараметрыМетода 			= Новый Структура("Организация, тзТаблицаПоказаний, МоментВремени, КонтрольныйСъем",Организация, тзТаблицаПоказаний, МоментВремени, КонтрольныйСъем); 
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);		
	КонецЕсли;
	
	Возврат РезультатЗапроса;
		
КонецФункции

Функция ТаблицаПоказаний(Организация, ТочкиУчета, ШкалыПриборов, ТаблицаПоказаний, Район = Неопределено, КлючПомещения = Неопределено, ИдентификаторСтроки = Неопределено, СоответствиеКолонок = Неопределено) Экспорт 
	
	ИсходноеСоотвествиеКолонок  			= Новый Структура;
	ИсходноеСоотвествиеКолонок.Вставить("IDСтроки", 	"IDСтроки");
	ИсходноеСоотвествиеКолонок.Вставить("ПриборУчета", 	"ПриборУчета");
	
	Если НЕ СоответствиеКолонок = Неопределено Тогда
		Для Каждого КлючЗначение Из СоответствиеКолонок Цикл
			ИсходноеСоотвествиеКолонок[КлючЗначение.Ключ] 	= КлючЗначение.Значение;
		КонецЦикла;		
	КонецЕсли;
	
	КоллекцияТочек 							= ТочкиУчета;
	Если ТипЗнч(ТочкиУчета)  = Тип("ТаблицаЗначений") тогда
		ТекущиеДанные 						= ТочкиУчета;
		Индекс 								= 0;
	ИначеЕсли ТипЗнч(ТочкиУчета)  = Тип("ДанныеФормыДерево") и ИдентификаторСтроки = Неопределено тогда
		ТочкиУчетаДерево					= ДанныеФормыВЗначение(ТочкиУчета,Тип("ДеревоЗначений"));
		ТекущиеДанные 						= Новый ТаблицаЗначений;
		КоллекцияТочек 						= ТочкиУчетаДерево.Строки;
		Для Каждого КолонкаДерева Из ТочкиУчетаДерево.Колонки Цикл
			ТекущиеДанные.Колонки.Добавить(КолонкаДерева.Имя,КолонкаДерева.ТипЗначения);
		КонецЦикла;
		
		Индекс 								= 0;	
		Для Каждого СтрокаДерева ИЗ ТочкиУчетаДерево.Строки Цикл
			ЗаполнитьЗначенияСвойств(ТекущиеДанные.Добавить(), СтрокаДерева);
		КонецЦикла;
	ИначеЕсли  ТипЗнч(ТочкиУчета)  = Тип("ДанныеФормыДерево") Тогда
		
		ТочкиУчетаДерево					= ДанныеФормыВЗначение(ТочкиУчета,Тип("ДеревоЗначений"));
		ТекущиеДанные 						= Новый ТаблицаЗначений;
		КоллекцияТочек 						= ТочкиУчетаДерево.Строки;
		
		Для Каждого КолонкаДерева Из ТочкиУчетаДерево.Колонки Цикл
			ТекущиеДанные.Колонки.Добавить(КолонкаДерева.Имя,КолонкаДерева.ТипЗначения);
		КонецЦикла;
		
		Индекс 								= 0;	
		
		ЗаполнитьЗначенияСвойств(ТекущиеДанные.Добавить(), ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки));		
		
	ИначеЕсли НЕ ИдентификаторСтроки = Неопределено Тогда
		ТекущиеДанные  						= ТочкиУчета.Выгрузить();
		ТекущиеДанные.Очистить();
		Строка  							= ТекущиеДанные.Добавить();
		ЗаполнитьЗначенияСвойств(Строка, ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки));
	Иначе	
		ТекущиеДанные  						= ТочкиУчета.Выгрузить();
		Индекс  							= -1;
	КонецЕсли;
	
	СтрокиУдалить  							= ТекущиеДанные.НайтиСтроки(Новый Структура("ПриборУчета", Справочники.энргПриборыУчетаАбонента.ПустаяСсылка()));
	
	Для Каждого СтрокаУдалить Из СтрокиУдалить Цикл
		ТекущиеДанные.Удалить(СтрокаУдалить);
	КонецЦикла;
	
	Если ТипЗнч(ТаблицаПоказаний)  = Тип("ТаблицаЗначений") тогда
		тзТаблицаПоказаний 							= ТаблицаПоказаний;		
	ИначеЕсли  НЕ ИдентификаторСтроки = Неопределено Тогда
		тзТаблицаПоказаний							= ТаблицаПоказаний.Выгрузить();
		тзТаблицаПоказаний.очистить();
		СтрокаТочкиУчета 							= ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
		СтрокиШкал 									= ШкалыПриборов.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", СтрокаТочкиУчета[ИсходноеСоотвествиеКолонок["IDСтроки"]]));
		НомерСтроки 								= 1;
		Для Каждого СтрокаШкалы Из СтрокиШкал Цикл
			СтрокиПоказаний  						= ТаблицаПоказаний.НайтиСтроки(Новый Структура("IDСтроки", СтрокаШкалы.IDСтроки));			
			Для Каждого СтрокаПоказаний Из СтрокиПоказаний Цикл
				СтрокаТаблицаПоказаний 				= тзТаблицаПоказаний.добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицаПоказаний,СтрокаПоказаний);
				СтрокаТаблицаПоказаний.НомерСтроки 	= НомерСтроки;
				НомерСтроки 						= НомерСтроки + 1;
			КонецЦикла;			  
		КонецЦикла;			
	Иначе		
		тзТаблицаПоказаний					= ТаблицаПоказаний.Выгрузить();
	КонецЕсли;
	
	тзТаблицаПоказаний.Колонки.добавить("Организация",						Новый ОписаниеТипов("СправочникСсылка.Организации"));
	тзТаблицаПоказаний.Колонки.добавить("Район",							Новый ОписаниеТипов("СправочникСсылка.энргЗоныОтвественности"));
	тзТаблицаПоказаний.Колонки.добавить("КлючПомещения",					Новый ОписаниеТипов("СправочникСсылка.энргКлючиПомещений"));
	тзТаблицаПоказаний.Колонки.добавить("ТочкаУчета",						Новый ОписаниеТипов("СправочникСсылка.энргТочкиУчета"));
	тзТаблицаПоказаний.Колонки.добавить("Услуга",							Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	тзТаблицаПоказаний.Колонки.добавить("ПриборУчета",						Новый ОписаниеТипов("СправочникСсылка.энргПриборыУчетаАбонента"));
	
	Если тзТаблицаПоказаний.Колонки.Найти("IDСтрокиТочкиУчета") = Неопределено Тогда
		тзТаблицаПоказаний.Колонки.добавить("IDСтрокиТочкиУчета",			Новый ОписаниеТипов("УникальныйИдентификатор"));
	КонецЕсли;
	
	Если тзТаблицаПоказаний.Колонки.Найти("ВидДифференцированности") = Неопределено Тогда
		тзТаблицаПоказаний.Колонки.добавить("ВидДифференцированности",		Новый ОписаниеТипов("СправочникСсылка.энргВидыДифференцированности"));
	КонецЕсли;
	Если тзТаблицаПоказаний.Колонки.Найти("Шкала") = Неопределено Тогда
		тзТаблицаПоказаний.Колонки.добавить("Шкала",						Новый ОписаниеТипов("СправочникСсылка.энргШкалыПриборовУчета"));
	КонецЕсли;
	
	Если тзТаблицаПоказаний.Колонки.Найти("ТекущиеПоказания") =Неопределено Тогда
		тзТаблицаПоказаний.Колонки.добавить("ТекущиеПоказания",				Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,4)));
	КонецЕсли;
	
	Если тзТаблицаПоказаний.Колонки.Найти("Переворот") =Неопределено Тогда
		тзТаблицаПоказаний.Колонки.добавить("Переворот",					Новый ОписаниеТипов("Булево"));
	КонецЕсли;
	
	Если тзТаблицаПоказаний.Колонки.Найти("СтатусИзмененПользователем") =Неопределено Тогда
		тзТаблицаПоказаний.Колонки.добавить("СтатусИзмененПользователем",		Новый ОписаниеТипов("Булево"));
	КонецЕсли;
	
	Если тзТаблицаПоказаний.Колонки.Найти("СостояниеПоказаний") =Неопределено Тогда
		тзТаблицаПоказаний.Колонки.добавить("СостояниеПоказаний",				Новый ОписаниеТипов("ПеречислениеСсылка.энргСостояниеПоказаний"));
	КонецЕсли;
	
	Если тзТаблицаПоказаний.Колонки.Найти("ПереворотИзмененПользователем") =Неопределено Тогда
		тзТаблицаПоказаний.Колонки.добавить("ПереворотИзмененПользователем",	Новый ОписаниеТипов("Булево"));
	КонецЕсли;	
	
	Если ИдентификаторСтроки = Неопределено Тогда
		Для Каждого СтрокаТочкиУчета из КоллекцияТочек цикл
			//яРайон  											= ?(Район = Неопределено, СтрокаТочкиУчета.Район, Район);
			//Если мРайоны.Найти(яРайон) = Неопределено Тогда
			//	мРайоны.Добавить(яРайон);
			//КонецЕсли;
			
			СтрокиШкал 											= ШкалыПриборов.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", СтрокаТочкиУчета[ИсходноеСоотвествиеКолонок["IDСтроки"]]));		
			Для Каждого СтрокаШкалы Из СтрокиШкал Цикл
				СтрокиТарифнойЗоны								= тзТаблицаПоказаний.НайтиСтроки(Новый Структура("IDСтроки",СтрокаШкалы.IDСтроки));
