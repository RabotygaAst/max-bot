		|		ЕСТЬNULL(ВидДифференцированностиВведенныхПриборов.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности,
		|		ДанныеПоПриборам.ЗаводскойНомер КАК ЗаводскойНомер
		|	ИЗ
		|		ДанныеПоПриборам КАК ДанныеПоПриборам
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВидДифференцированностиВведенныхПриборов КАК ВидДифференцированностиВведенныхПриборов
		|			ПО ДанныеПоПриборам.Организация = ВидДифференцированностиВведенныхПриборов.Организация
		|				И ДанныеПоПриборам.Район = ВидДифференцированностиВведенныхПриборов.Район
		|				И ДанныеПоПриборам.МКД = ВидДифференцированностиВведенныхПриборов.МКД
		|				И ДанныеПоПриборам.ПриборУчета = ВидДифференцированностиВведенныхПриборов.ПриборУчета
		|				И ДанныеПоПриборам.Шкала = ВидДифференцированностиВведенныхПриборов.Шкала) КАК Вложенныйзапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
		|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка");
	
	
	ПоляОтбораПоказаний = Новый Структура("ПриборУчета,Шкала,ТарифнаяЗона", "ПриборУчета","Шкала","ТарифнаяЗона");
	ОтборПоказаний = энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица("ДанныеПоПриборамИтог", ПоляОтбораПоказаний);
	ПараметрыВТ.Добавить(ОтборПоказаний);
	РегистрыСведений.энргМаксимальныеПоказанияМКД.МаксимальныеПоказанияСрез(Схема, Параметры, "МаксимальныеПоказанияСрез");
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеПоПриборамИтог.Организация КАК Организация,
	|	ДанныеПоПриборамИтог.Район КАК Район,
	|	ДанныеПоПриборамИтог.МКД КАК МКД,
	|	ДанныеПоПриборамИтог.ТочкаУчета КАК ТочкаУчета,
	|	ДанныеПоПриборамИтог.ПриборУчета КАК ПриборУчета,
	|	ДанныеПоПриборамИтог.ЗаводскойНомер КАК ЗаводскойНомерПриборУчета,
	|	ДанныеПоПриборамИтог.Шкала КАК Шкала,
	|	ДанныеПоПриборамИтог.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ЕСТЬNULL(МаксимальныеПоказанияСрез.Показание, 0) КАК Показание,
	|	ПРЕДСТАВЛЕНИЕ(ДанныеПоПриборамИтог.ТарифнаяЗона) КАК ТарифнаяЗонаИмя,
	|	УслугиДействующихТочекМКД.Услуга КАК Услуга,
	|	ДанныеПоПриборамИтог.ВидДифференцированности КАК ВидДифференцированности
	|ИЗ
	|	ДанныеПоПриборамИтог КАК ДанныеПоПриборамИтог
	|		ЛЕВОЕ СОЕДИНЕНИЕ МаксимальныеПоказанияСрез КАК МаксимальныеПоказанияСрез
	|		ПО ДанныеПоПриборамИтог.Организация = МаксимальныеПоказанияСрез.Организация
	|			И ДанныеПоПриборамИтог.Район = МаксимальныеПоказанияСрез.Район
	|			И ДанныеПоПриборамИтог.МКД = МаксимальныеПоказанияСрез.МКД
	|			И ДанныеПоПриборамИтог.ПриборУчета = МаксимальныеПоказанияСрез.ПриборУчета
	|			И ДанныеПоПриборамИтог.Шкала = МаксимальныеПоказанияСрез.Шкала
	|			И ДанныеПоПриборамИтог.ТарифнаяЗона = МаксимальныеПоказанияСрез.ТарифнаяЗона
	|		ЛЕВОЕ СОЕДИНЕНИЕ УслугиДействующихТочекМКД КАК УслугиДействующихТочекМКД
	|		ПО ДанныеПоПриборамИтог.МКД = УслугиДействующихТочекМКД.МКД
	|			И ДанныеПоПриборамИтог.ТочкаУчета = УслугиДействующихТочекМКД.ТочкаУчета
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПриборУчета,
	|	Шкала");
	
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Период",			Период);
	ПараметрыЗапроса.Вставить("Организация",	ВходныеПараметры.Организация);
	ПараметрыЗапроса.Вставить("Район",			ВходныеПараметры.Район); 	
	ПараметрыЗапроса.Вставить("МКД",			ВходныеПараметры.МКД);			
	
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса); 
