	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МаксимумРазделить";
	
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	
	Если не Параметры.свойство("Район") тогда
		Текст = СтрЗаменить(Текст,"энргМаксимальныеПоказанияРазделитель.Район = &Район","Истина");
	иначе
		Запрос.УстановитьПараметр("Район",Параметры.Район);
	КонецЕсли;
	 	
	Если не Параметры.свойство("МКД") тогда
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.МКД = &МКД","");
	иначе
		Запрос.УстановитьПараметр("МКД",Параметры.МКД);
	КонецЕсли;

	Если не Параметры.свойство("ПриборУчета") тогда
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.ПриборУчета = &ПриборУчета","");
	ИначеЕсли ТипЗнч(Параметры.ПриборУчета) = тип("Массив") тогда
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.ПриборУчета = &ПриборУчета","И энргМаксимальныеПоказания.ПриборУчета в (&ПриборыУчета)");
		Запрос.УстановитьПараметр("ПриборыУчета",Параметры.ПриборУчета)
	иначе	
		Запрос.УстановитьПараметр("ПриборУчета",Параметры.ПриборУчета);
	КонецЕсли;

	Если не Параметры.свойство("МоментВремени") тогда
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.Период <= &МоментВремениПериод","");
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.Регистратор <= &МоментВремениРегистратор","");
	ИначеЕсли Параметры.МоментВремени = Неопределено тогда
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.Период <= &МоментВремениПериод","");
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.Регистратор <= &МоментВремениРегистратор","");
	ИначеЕсли ТипЗнч(Параметры.МоментВремени) = Тип("Дата") тогда 
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.Регистратор <= &МоментВремениРегистратор","");
		Запрос.УстановитьПараметр("МоментВремениПериод",Параметры.МоментВремени); 
		
	ИначеЕсли  ТипЗнч(Параметры.МоментВремени) = Тип("Граница")
		и  Параметры.МоментВремени.ВидГраницы = ВидГраницы.Исключая
		и ТипЗнч(Параметры.МоментВремени.Значение) = Тип("Дата")  тогда	
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.Период <= &МоментВремениПериод","И энргМаксимальныеПоказания.Период < &МоментВремениПериод");
		Текст = СтрЗаменить(Текст,"И энргМаксимальныеПоказания.Регистратор <= &МоментВремениРегистратор","");
		Запрос.УстановитьПараметр("МоментВремениПериод",Параметры.МоментВремени.Значение);
	иначе 		
		Запрос.УстановитьПараметр("МоментВремениПериод",Параметры.МоментВремени.дата);
		Запрос.УстановитьПараметр("МоментВремениРегистратор",Параметры.МоментВремени.ссылка);
	КонецЕсли;
	
	Текст 			= СтрЗаменить(Текст,"ПОМЕСТИТЬ энргМаксимальныеПоказанияСрезПоследних","ПОМЕСТИТЬ " + ИмяТаблицы);	
	Запрос.Текст 	= Текст;
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура МаксимальныеПоказанияСрезПоследнихТеплоисточник(МВТ,ИмяТаблицы,Параметры)  Экспорт 
	
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Текст = 
	"ВЫБРАТЬ
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.Теплоисточник КАК Теплоисточник,
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.Шкала КАК Шкала,
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.Период КАК Период,
	|	МАКСИМУМ(энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.Показание) КАК Показание
	|ПОМЕСТИТЬ энргМаксимальныеПоказанияСрезПоследних
	|ИЗ
	|	РегистрСведений.энргПоказанияПриборовУчетаТеплоисточников.СрезПоследних(
	|			&МоментВремени,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Теплоисточник = &Теплоисточник
	|				И СостояниеПоказаний = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)) КАК энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.Теплоисточник,
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.ПриборУчета,
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.Шкала,
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.ТарифнаяЗона,
	|	энргПоказанияПриборовУчетаТеплоисточниковСрезПоследних.Период";
	
	Запрос.УстановитьПараметр("Организация",	Параметры.Организация);
	Запрос.УстановитьПараметр("Район",			Параметры.Район);
	Запрос.УстановитьПараметр("Теплоисточник",	Параметры.Теплоисточник);
	Запрос.УстановитьПараметр("МоментВремени",	Параметры.МоментВремени);

	Текст 			= СтрЗаменить(Текст,"ПОМЕСТИТЬ энргМаксимальныеПоказанияСрезПоследних","ПОМЕСТИТЬ " + ИмяТаблицы);	
	Запрос.Текст 	= Текст;
	Запрос.Выполнить();
	
КонецПроцедуры

Функция ЗаполнитьДанныеПрибораУчетаПлатежноеПоручение(ТекущиеДанные, ДатаОплаты,ПериодНачисления,Район) Экспорт
		
	Запрос  	= Новый Запрос;	
	Запрос.УстановитьПараметр("Район",Район);
	Запрос.УстановитьПараметр("ПериодНачисления",ПериодНачисления);
	Запрос.УстановитьПараметр("Период",ДатаОплаты);
	Запрос.УстановитьПараметр("ТекущиеДанные",ТекущиеДанные);  
	
	СоотвествиеКолонок  = Новый Структура;
	СоотвествиеКолонок.Вставить("СуммаПолив","Полив");
	СоотвествиеКолонок.Вставить("СуммаСливГВС","СливГВС");
	СоотвествиеКолонок.Вставить("СуммаСливХВС","СливХВС");
	СоотвествиеКолонок.Вставить("СуммаХВС","ХВС");	
	
	Текст ="ВЫБРАТЬ
	|	ТекущиеДанные.ТекущиеПоказания,
	|	ТекущиеДанные.СуммаПолив,
	|	ТекущиеДанные.СуммаСливХВС,
	|	ТекущиеДанные.СуммаСливГВС,
	|	ТекущиеДанные.СуммаХВС,
	|	ТекущиеДанные.ДатаОперации,
	|	ТекущиеДанные.ФИО,
	|	ТекущиеДанные.ЛС,
	|	ТекущиеДанные.НомерПУ
	|ПОМЕСТИТЬ ТекущиеДанные
	|ИЗ
	|	&ТекущиеДанные КАК ТекущиеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(энргАбоненты.Ссылка, ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка)) КАК АбонентСсылка,
	|	ЕСТЬNULL(энргАбоненты.Район, ЗНАЧЕНИЕ(Справочник.энргЗоныОтвественности.ПустаяСсылка)) КАК Район,
	|	ТекущиеДанные.ЛС,
	|	ТекущиеДанные.ТекущиеПоказания,
	|	ТекущиеДанные.СуммаПолив,
	|	ТекущиеДанные.СуммаСливХВС,
	|	ТекущиеДанные.СуммаСливГВС,
	|	ТекущиеДанные.СуммаХВС,
	|	ТекущиеДанные.ДатаОперации,
	|	ТекущиеДанные.ФИО,
	|	ТекущиеДанные.НомерПУ
	|ПОМЕСТИТЬ ПоискАбонента
	|ИЗ
	|	ТекущиеДанные КАК ТекущиеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|		ПО ТекущиеДанные.ЛС = энргАбоненты.ЛицевойСчет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПоискАбонента.АбонентСсылка,
	|	ПоискАбонента.Район,
	|	ПоискАбонента.ЛС,
	|	ПоискАбонента.ТекущиеПоказания,
	|	ПоискАбонента.СуммаПолив,
	|	ПоискАбонента.СуммаСливХВС,
	|	ПоискАбонента.СуммаСливГВС,
	|	ПоискАбонента.СуммаХВС,
	|	ПоискАбонента.ДатаОперации,
	|	ПоискАбонента.ФИО,
	|	ПоискАбонента.НомерПУ
	|ПОМЕСТИТЬ НайденныеАбоненты
	|ИЗ
	|	ПоискАбонента КАК ПоискАбонента
	|ГДЕ
	|	НЕ ПоискАбонента.АбонентСсылка = ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НайденныеАбоненты.АбонентСсылка,
	|	НайденныеАбоненты.ДатаОперации,
	|	НайденныеАбоненты.Район,
	|	МАКСИМУМ(ЕСТЬNULL(энргСостояниеЛС.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК ПериодОткрытияЛС
	|ПОМЕСТИТЬ МаксПериодСостояниеЛС
	|ИЗ
	|	НайденныеАбоненты КАК НайденныеАбоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСостояниеЛС КАК энргСостояниеЛС
	|		ПО НайденныеАбоненты.АбонентСсылка = энргСостояниеЛС.Абонент
	|			И НайденныеАбоненты.Район = энргСостояниеЛС.Район
	|			И НайденныеАбоненты.ДатаОперации >= энргСостояниеЛС.Период
	|
	|СГРУППИРОВАТЬ ПО
	|	НайденныеАбоненты.АбонентСсылка,
	|	НайденныеАбоненты.Район,
	|	НайденныеАбоненты.ДатаОперации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МаксПериодСостояниеЛС.АбонентСсылка,
	|	МаксПериодСостояниеЛС.Район,
	|	МаксПериодСостояниеЛС.ДатаОперации,
	|	МаксПериодСостояниеЛС.ПериодОткрытияЛС,
	|	МАКСИМУМ(ЕСТЬNULL(энргСостояниеЛС.Регистратор, НЕОПРЕДЕЛЕНО)) КАК РегистраторСосоятонияЛС
	|ПОМЕСТИТЬ МаксРегСостоянияЛс
	|ИЗ
	|	МаксПериодСостояниеЛС КАК МаксПериодСостояниеЛС
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргСостояниеЛС КАК энргСостояниеЛС
	|		ПО МаксПериодСостояниеЛС.АбонентСсылка = энргСостояниеЛС.Абонент
	|			И МаксПериодСостояниеЛС.Район = энргСостояниеЛС.Район
	|			И МаксПериодСостояниеЛС.ПериодОткрытияЛС = энргСостояниеЛС.Период
	|
	|СГРУППИРОВАТЬ ПО
	|	МаксПериодСостояниеЛС.АбонентСсылка,
	|	МаксПериодСостояниеЛС.Район,
	|	МаксПериодСостояниеЛС.ДатаОперации,
	|	МаксПериодСостояниеЛС.ПериодОткрытияЛС
