	Параметры  												= Новый Структура("Организация,Район,МоментВремени",Организация, Район,МоментВремени);
	Если МКД <> Неопределено тогда
		 Параметры.Вставить("МКД",МКД);
	КонецЕсли;   	
	
	МаксимальныеПоказанияСрезПоследнихМКД(МВТ,"энргМаксимальныеПоказанияСрезПоследних",Параметры);
	     	
	Запрос  													= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 								= МВТ;
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("МоментВремени",			МоментВремени);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("ПериодНачисления",		ПериодНачисления);
	Запрос.УстановитьПараметр("ТекущиеДанные",			тзТаблицаПоказаний);
	Запрос.УстановитьПараметр("МКД",					МКД);
	Запрос.УстановитьПараметр("КонтрольныйСъем",		КонтрольныйСъем);
	Запрос.УстановитьПараметр("Коэффициент",			1);
	Текст 														=
	"ВЫБРАТЬ
	|	ТекущиеДанныеДокумента.НомерСтроки КАК НомерСтроки,
	|	ТекущиеДанныеДокумента.МКД КАК МКД,
	|	ТекущиеДанныеДокумента.ВидДифференцированности КАК ВидДифференцированности,
	|	ТекущиеДанныеДокумента.ПриборУчета КАК ПриборУчета,
	|	ТекущиеДанныеДокумента.Шкала КАК Шкала,
	|	ТекущиеДанныеДокумента.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТекущиеДанныеДокумента.ТочкаУчета КАК ТочкаУчета,
	|	ТекущиеДанныеДокумента.Услуга КАК Услуга,
	|	ТекущиеДанныеДокумента.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ТекущиеДанныеДокумента.Переворот КАК Переворот,
	|	ТекущиеДанныеДокумента.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ТекущиеДанныеДокумента.СостояниеПоказаний КАК СостояниеПоказаний,
	|	ТекущиеДанныеДокумента.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем
	|ПОМЕСТИТЬ ТекущиеДанные
	|ИЗ
	|	&ТекущиеДанные КАК ТекущиеДанныеДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргКоэффциентыПриборовУчетаСрезПоследних.КлючПомещения КАК МКД,
	|	энргКоэффциентыПриборовУчетаСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргКоэффциентыПриборовУчетаСрезПоследних.Коэффициент КАК Коэффициент
	|ПОМЕСТИТЬ КоэффциентыПриборовУчета
	|ИЗ
	|	РегистрСведений.энргКоэффциентыПриборовУчета.СрезПоследних(
	|			&МоментВремени,
	|			Район = &Район
	|				И КлючПомещения В
	|					(ВЫБРАТЬ
	|						ТекущиеДанные.МКД
	|					ИЗ
	|						ТекущиеДанные КАК ТекущиеДанные)) КАК энргКоэффциентыПриборовУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТекущиеДанные.НомерСтроки КАК НомерСтроки,
	|	ТекущиеДанные.МКД КАК МКД,
	|	ТекущиеДанные.ТочкаУчета КАК ТочкаУчета,
	|	ТекущиеДанные.Услуга КАК Услуга,
	|	ТекущиеДанные.ПриборУчета КАК ПриборУчета,
	|	ТекущиеДанные.Шкала КАК Шкала,
	|	ТекущиеДанные.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТекущиеДанные.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ТекущиеДанные.Переворот КАК ТекущийПереворот,
	|	ТекущиеДанные.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ТекущиеДанные.СостояниеПоказаний КАК ТекущиеСостояниеПоказаний,
	|	ТекущиеДанные.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем,
	|	ЕСТЬNULL(КоэффциентыПриборовУчета.Коэффициент, 0) КАК Коэффициент,
	|	ЕСТЬNULL(энргПриборыУчетаАбонента.МаксимальноВозможныеПоказания, 0) КАК МаксимальноВозможные
	|ПОМЕСТИТЬ ДанныеДокументаСПоказаниями
	|ИЗ
	|	ТекущиеДанные КАК ТекущиеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ КоэффциентыПриборовУчета КАК КоэффциентыПриборовУчета
	|		ПО ТекущиеДанные.МКД = КоэффциентыПриборовУчета.МКД
	|			И ТекущиеДанные.ПриборУчета = КоэффциентыПриборовУчета.ПриборУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ТекущиеДанные.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&МКД КАК МКД,
	|	СреднийОбъемПотребленияАбонентов.ТочкаУчета КАК ТочкаУчета,
	|	СреднийОбъемПотребленияАбонентов.ТарифнаяЗона КАК ТарифнаяЗона,
	|	СреднийОбъемПотребленияАбонентов.Шкала КАК Шкала,
	|	СреднийОбъемПотребленияАбонентов.Объем КАК Объем
	|ПОМЕСТИТЬ СреднийОбъемПотребления
	|ИЗ
	|	РегистрСведений.энргСреднийОбъемПотребленияМКД КАК СреднийОбъемПотребленияАбонентов
	|ГДЕ
	|	СреднийОбъемПотребленияАбонентов.ПериодНачисления = &ПериодНачисления
	|	И СреднийОбъемПотребленияАбонентов.Район = &Район
	|	И СреднийОбъемПотребленияАбонентов.МКД = &МКД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокументаСПоказаниями.НомерСтроки КАК НомерСтроки,
	|	ДанныеДокументаСПоказаниями.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0) КАК ПоследниеПоказания,
	|	ДанныеДокументаСПоказаниями.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ЕСТЬNULL(СреднийОбъемПотребления.Объем, 0) КАК СреднийОбъемПотребления,
	|	ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Период, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПоследнихПоказаний,
	|	(ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0) - ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0)) * ДанныеДокументаСПоказаниями.Коэффициент КАК Расход,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0) < ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0)
	|			ТОГДА (ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0) - ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0)) * ДанныеДокументаСПоказаниями.Коэффициент
	|		ИНАЧЕ (ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0) - ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0)) * ДанныеДокументаСПоказаниями.Коэффициент
	|	КОНЕЦ КАК РасходПоМодулю,
	|	(ДанныеДокументаСПоказаниями.МаксимальноВозможные - ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0) + ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0)) * ДанныеДокументаСПоказаниями.Коэффициент КАК РасходСПереворотом,
	|	ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Период, ДАТАВРЕМЯ(1, 1, 1)), &ПериодНачисления, МЕСЯЦ) = 0
	|			ТОГДА 1
	|		ИНАЧЕ РАЗНОСТЬДАТ(ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Период, ДАТАВРЕМЯ(1, 1, 1)), &ПериодНачисления, МЕСЯЦ)
	|	КОНЕЦ КАК РазностьМесяцев,
	|	ДанныеДокументаСПоказаниями.Коэффициент КАК КоэффициентПУ,
	|	ДанныеДокументаСПоказаниями.ТекущийПереворот КАК ТекущийПереворот,
	|	ДанныеДокументаСПоказаниями.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ДанныеДокументаСПоказаниями.ТекущиеСостояниеПоказаний КАК ТекущиеСостояниеПоказаний,
	|	ДанныеДокументаСПоказаниями.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем,
	|	ДанныеДокументаСПоказаниями.МаксимальноВозможные КАК МаксимальноВозможныеПоказания
	|ПОМЕСТИТЬ ДанныеДляАнализа
	|ИЗ
	|	ДанныеДокументаСПоказаниями КАК ДанныеДокументаСПоказаниями
	|		ЛЕВОЕ СОЕДИНЕНИЕ энргМаксимальныеПоказанияСрезПоследних КАК энргМаксимальныеПоказанияСрезПоследних
	|		ПО ДанныеДокументаСПоказаниями.МКД = энргМаксимальныеПоказанияСрезПоследних.МКД
	|			И ДанныеДокументаСПоказаниями.ПриборУчета = энргМаксимальныеПоказанияСрезПоследних.ПриборУчета
	|			И ДанныеДокументаСПоказаниями.Шкала = энргМаксимальныеПоказанияСрезПоследних.Шкала
	|			И ДанныеДокументаСПоказаниями.ТарифнаяЗона = энргМаксимальныеПоказанияСрезПоследних.ТарифнаяЗона
	|		ЛЕВОЕ СОЕДИНЕНИЕ СреднийОбъемПотребления КАК СреднийОбъемПотребления
	|		ПО ДанныеДокументаСПоказаниями.МКД = СреднийОбъемПотребления.МКД
	|			И ДанныеДокументаСПоказаниями.ТочкаУчета = СреднийОбъемПотребления.ТочкаУчета
	|			И ДанныеДокументаСПоказаниями.ТарифнаяЗона = СреднийОбъемПотребления.ТарифнаяЗона
	|			И ДанныеДокументаСПоказаниями.Шкала = СреднийОбъемПотребления.Шкала
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДляАнализа.НомерСтроки КАК НомерСтроки,
	|	ДанныеДляАнализа.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ДанныеДляАнализа.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ВЫБОР
	|		КОГДА ДанныеДляАнализа.ПереворотИзмененПользователем
	|			ТОГДА ДанныеДляАнализа.ТекущийПереворот
	|		КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|			ТОГДА ЛОЖЬ
	|		КОГДА ДанныеДляАнализа.Расход >= 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК Переворот,
	|	ДанныеДляАнализа.ДатаПоследнихПоказаний КАК ДатаПоследнихПоказаний,
	|	ДанныеДляАнализа.СреднийОбъемПотребления КАК СреднийОбъемПотребления,
	|	ВЫБОР
	|		КОГДА ДанныеДляАнализа.ПереворотИзмененПользователем
	|			ТОГДА ВЫБОР
	|					КОГДА ДанныеДляАнализа.ТекущийПереворот
	|						ТОГДА ДанныеДляАнализа.РасходСПереворотом
	|					ИНАЧЕ ДанныеДляАнализа.Расход
	|				КОНЕЦ
	|		КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|			ТОГДА 0
	|		КОГДА ДанныеДляАнализа.Расход >= 0
	|			ТОГДА ДанныеДляАнализа.Расход
	|		ИНАЧЕ ДанныеДляАнализа.РасходСПереворотом
	|	КОНЕЦ КАК Разница,
	|	ЛОЖЬ КАК ПереворотИзмененПользователем,
	|	ЛОЖЬ КАК СтатусИзмененПользователем,
	|	ДанныеДляАнализа.МаксимальноВозможныеПоказания КАК МаксимальноВозможныеПоказания,
	|	ВЫБОР
	|		КОГДА ДанныеДляАнализа.ПереворотИзмененПользователем
	|			ТОГДА ДанныеДляАнализа.ТекущиеСостояниеПоказаний
	|		КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Отклонены)
	|		КОГДА ДанныеДляАнализа.Расход = 0
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|		КОГДА &КонтрольныйСъем
	|				И ВЫБОР
	|					КОГДА ДанныеДляАнализа.Расход >= 0
	|						ТОГДА ДанныеДляАнализа.Расход
	|					ИНАЧЕ ДанныеДляАнализа.РасходСПереворотом
	|				КОНЕЦ >= 0
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|		КОГДА ДанныеДляАнализа.Расход >= 0
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Отклонены)
	|	КОНЕЦ КАК СостояниеПоказаний,
	|	ДанныеДляАнализа.КоэффициентПУ КАК КоэффициентПУ,
	|	ДанныеДляАнализа.ПоследниеПоказания КАК ПредыдущиеПоказания
	|ИЗ
	|	ДанныеДляАнализа КАК ДанныеДляАнализа";  
	
	Если Не энргОбщегоНазначения.ЗначениеКонстанты("энргИспользоватьТарифныеЗоны") Тогда
		Текст = СтрЗаменить(Текст, "И ДанныеДокументаСПоказаниями.ТарифнаяЗона = энргМаксимальныеПоказанияСрезПоследних.ТарифнаяЗона", "");
		Текст = СтрЗаменить(Текст, "И ДанныеДокументаСПоказаниями.ТарифнаяЗона = СреднийОбъемПотребления.ТарифнаяЗона", "");
	КонецЕсли;
	
	Запрос.Текст 					= Текст;	
	Результат  						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	
	Пока выборка.Следующий() цикл		 
		IDСтроки  					= тзТаблицаПоказаний[Выборка.НомерСтроки -1].IDСтроки;
		ТарифнаяЗона				= тзТаблицаПоказаний[Выборка.НомерСтроки -1].ТарифнаяЗона;
		СтрокаПоказаний 			= ТаблицаПоказаний.НайтиСтроки(Новый Структура("IDСтроки, ТарифнаяЗона", IDСтроки, ТарифнаяЗона))[0];
		ЗаполнитьЗначенияСвойств(СтрокаПоказаний,Выборка);
	КонецЦикла; 
	
КонецПроцедуры

Процедура ОбновитьПоказанияПриборовУчетаТеплоисточников(ТочкиУчета,ШкалыПриборов,ТаблицаПоказаний,МоментВремени,Организация,Район,Теплоисточник,КонтрольныйСъем = ложь, приборучета=Неопределено) Экспорт 
			
	// заполняем табличную часть приборы
	Если ТипЗнч(МоментВремени) = тип("Граница") тогда
		ПериодНачисления 					= Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(МоментВремени.Значение, Организация,Район);
	иначе
		ПериодНачисления 					= Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(МоментВремени, Организация,Район);
	КонецЕсли;
	
	Если ТипЗнч(ТочкиУчета)  = Тип("ТаблицаЗначений") тогда
		ТекущиеДанные 						= ТочкиУчета;
		Индекс 								= 0; 
	иначе                  		
		ТекущиеДанные  						= ТочкиУчета.Выгрузить();
		Индекс  							= -1;
	КонецЕсли;
	              	
	Если ТипЗнч(ТаблицаПоказаний)  = Тип("ТаблицаЗначений") тогда
		тзТаблицаПоказаний 					= ТаблицаПоказаний;		
	иначе                  		
		тзТаблицаПоказаний					= ТаблицаПоказаний.Выгрузить();
	КонецЕсли;
	
	
	тзТаблицаПоказаний.Колонки.добавить("ТочкаУчета",				Новый ОписаниеТипов("СправочникСсылка.энргТочкиУчета"));
	тзТаблицаПоказаний.Колонки.добавить("Услуга",					Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	тзТаблицаПоказаний.Колонки.добавить("ПриборУчета",				Новый ОписаниеТипов("СправочникСсылка.энргПриборыУчетаАбонента"));
	тзТаблицаПоказаний.Колонки.добавить("IDСтрокиТочкиУчета",		Новый ОписаниеТипов("УникальныйИдентификатор"));
	тзТаблицаПоказаний.Колонки.добавить("ВидДифференцированности",	Новый ОписаниеТипов("СправочникСсылка.энргВидыДифференцированности"));
	тзТаблицаПоказаний.Колонки.добавить("Шкала",					Новый ОписаниеТипов("СправочникСсылка.энргШкалыПриборовУчета"));
	
	ИсходноеСоотвествиеКолонок  							= Новый Структура;
	ИсходноеСоотвествиеКолонок.Вставить("IDСтроки", 	"IDСтроки");
	ИсходноеСоотвествиеКолонок.Вставить("ПриборУчета", "ПриборУчета");
	
	Для Каждого СтрокаТочкиУчета из ТочкиУчета цикл
		СтрокиШкал 											= ШкалыПриборов.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", СтрокаТочкиУчета[ИсходноеСоотвествиеКолонок["IDСтроки"]]));		
		Для Каждого СтрокаШкалы Из СтрокиШкал Цикл
			СтрокиТарифнойЗоны								= тзТаблицаПоказаний.НайтиСтроки(Новый Структура("IDСтроки",СтрокаШкалы.IDСтроки));
			Для Каждого СтрокаТарифнойЗоны из СтрокиТарифнойЗоны цикл
				СтрокаТарифнойЗоны.ТочкаУчета 				= СтрокаТочкиУчета.ТочкаУчета;
				СтрокаТарифнойЗоны.Услуга 					= СтрокаТочкиУчета.Услуга;
				СтрокаТарифнойЗоны.ПриборУчета 				= СтрокаТочкиУчета[ИсходноеСоотвествиеКолонок["ПриборУчета"]];
				СтрокаТарифнойЗоны.IDСтрокиТочкиУчета 		= СтрокаТочкиУчета[ИсходноеСоотвествиеКолонок["IDСтроки"]];
				СтрокаТарифнойЗоны.IDСтроки 				= СтрокаШкалы.IDСтроки;
				СтрокаТарифнойЗоны.ВидДифференцированности 	= СтрокаШкалы.ВидДифференцированности;
				СтрокаТарифнойЗоны.Шкала 					= СтрокаШкалы.Шкала;
			КонецЦикла;
		КонецЦикла; 		
	КонецЦикла;			
	
	МВТ  													= Новый МенеджерВременныхТаблиц;	
	Параметры  												= Новый Структура("Организация,Район,МоментВремени",Организация, Район,МоментВремени);
	Если Теплоисточник <> Неопределено тогда
		 Параметры.Вставить("Теплоисточник",Теплоисточник);
	КонецЕсли;   	
	
	МаксимальныеПоказанияСрезПоследнихТеплоисточник(МВТ,"энргМаксимальныеПоказанияСрезПоследних",Параметры);
	     	
	Запрос  								= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 			= МВТ;
	Запрос.УстановитьПараметр("МоментВремени",			МоментВремени);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("ПериодНачисления",		ПериодНачисления);
	Запрос.УстановитьПараметр("ТекущиеДанные",			тзТаблицаПоказаний);
	Запрос.УстановитьПараметр("Теплоисточник",			Теплоисточник);
	Запрос.УстановитьПараметр("КонтрольныйСъем",		КонтрольныйСъем);
	Запрос.УстановитьПараметр("Коэффициент",			1);
	
	Текст 								=
	"ВЫБРАТЬ
	|	ТекущиеДанныеДокумента.НомерСтроки КАК НомерСтроки,
	|	ТекущиеДанныеДокумента.Теплоисточник КАК Теплоисточник,
	|	ТекущиеДанныеДокумента.ВидДифференцированности КАК ВидДифференцированности,
	|	ТекущиеДанныеДокумента.ПриборУчета КАК ПриборУчета,
	|	ТекущиеДанныеДокумента.Шкала КАК Шкала,
	|	ТекущиеДанныеДокумента.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТекущиеДанныеДокумента.ТочкаУчета КАК ТочкаУчета,
	|	ТекущиеДанныеДокумента.Услуга КАК Услуга,
	|	ТекущиеДанныеДокумента.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ТекущиеДанныеДокумента.Переворот КАК Переворот,
	|	ТекущиеДанныеДокумента.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ТекущиеДанныеДокумента.СостояниеПоказаний КАК СостояниеПоказаний,
	|	ТекущиеДанныеДокумента.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем
	|ПОМЕСТИТЬ ТекущиеДанные
	|ИЗ
	|	&ТекущиеДанные КАК ТекущиеДанныеДокумента
	|ГДЕ
	|	НЕ ТекущиеДанныеДокумента.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргКоэффциентыПриборовУчетаСрезПоследних.КлючПомещения КАК Теплоисточник,
	|	энргКоэффциентыПриборовУчетаСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргКоэффциентыПриборовУчетаСрезПоследних.Коэффициент КАК Коэффициент
	|ПОМЕСТИТЬ КоэффциентыПриборовУчета
	|ИЗ
	|	РегистрСведений.энргКоэффциентыПриборовУчета.СрезПоследних(
	|			&МоментВремени,
	|			Организация = &Организация
	|				И Район = &Район
	|				И КлючПомещения = &Теплоисточник) КАК энргКоэффциентыПриборовУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТекущиеДанные.НомерСтроки КАК НомерСтроки,
	|	ТекущиеДанные.Теплоисточник КАК Теплоисточник,
	|	ТекущиеДанные.ТочкаУчета КАК ТочкаУчета,
	|	ТекущиеДанные.Услуга КАК Услуга,
	|	ТекущиеДанные.ПриборУчета КАК ПриборУчета,
	|	ТекущиеДанные.Шкала КАК Шкала,
	|	ТекущиеДанные.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТекущиеДанные.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ТекущиеДанные.Переворот КАК ТекущийПереворот,
	|	ТекущиеДанные.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ТекущиеДанные.СостояниеПоказаний КАК ТекущиеСостояниеПоказаний,
	|	ТекущиеДанные.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем,
	|	ЕСТЬNULL(КоэффциентыПриборовУчета.Коэффициент, 0) КАК Коэффициент,
	|	ЕСТЬNULL(энргПриборыУчетаАбонента.МаксимальноВозможныеПоказания, 0) КАК МаксимальноВозможные
	|ПОМЕСТИТЬ ДанныеДокументаСПоказаниями
	|ИЗ
	|	ТекущиеДанные КАК ТекущиеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ КоэффциентыПриборовУчета КАК КоэффциентыПриборовУчета
	|		ПО ТекущиеДанные.ПриборУчета = КоэффциентыПриборовУчета.ПриборУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ТекущиеДанные.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокументаСПоказаниями.НомерСтроки КАК НомерСтроки,
	|	ДанныеДокументаСПоказаниями.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0) КАК ПоследниеПоказания,
	|	ДанныеДокументаСПоказаниями.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Период, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПоследнихПоказаний,
	|	(ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0) - ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0)) * ДанныеДокументаСПоказаниями.Коэффициент КАК Расход,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0) < ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0)
	|			ТОГДА (ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0) - ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0)) * ДанныеДокументаСПоказаниями.Коэффициент
	|		ИНАЧЕ (ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0) - ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0)) * ДанныеДокументаСПоказаниями.Коэффициент
	|	КОНЕЦ КАК РасходПоМодулю,
	|	(ДанныеДокументаСПоказаниями.МаксимальноВозможные - ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Показание, 0) + ЕСТЬNULL(ДанныеДокументаСПоказаниями.ТекущиеПоказания, 0)) * ДанныеДокументаСПоказаниями.Коэффициент КАК РасходСПереворотом,
	|	ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Период, ДАТАВРЕМЯ(1, 1, 1)), &ПериодНачисления, МЕСЯЦ) = 0
	|			ТОГДА 1
	|		ИНАЧЕ РАЗНОСТЬДАТ(ЕСТЬNULL(энргМаксимальныеПоказанияСрезПоследних.Период, ДАТАВРЕМЯ(1, 1, 1)), &ПериодНачисления, МЕСЯЦ)
	|	КОНЕЦ КАК РазностьМесяцев,
	|	ДанныеДокументаСПоказаниями.Коэффициент КАК КоэффициентПУ,
	|	ДанныеДокументаСПоказаниями.ТекущийПереворот КАК ТекущийПереворот,
	|	ДанныеДокументаСПоказаниями.СтатусИзмененПользователем КАК СтатусИзмененПользователем,
	|	ДанныеДокументаСПоказаниями.ТекущиеСостояниеПоказаний КАК ТекущиеСостояниеПоказаний,
	|	ДанныеДокументаСПоказаниями.ПереворотИзмененПользователем КАК ПереворотИзмененПользователем,
	|	ДанныеДокументаСПоказаниями.МаксимальноВозможные КАК МаксимальноВозможныеПоказания
	|ПОМЕСТИТЬ ДанныеДляАнализа
	|ИЗ
	|	ДанныеДокументаСПоказаниями КАК ДанныеДокументаСПоказаниями
	|		ЛЕВОЕ СОЕДИНЕНИЕ энргМаксимальныеПоказанияСрезПоследних КАК энргМаксимальныеПоказанияСрезПоследних
	|		ПО ДанныеДокументаСПоказаниями.Теплоисточник = энргМаксимальныеПоказанияСрезПоследних.Теплоисточник
	|			И ДанныеДокументаСПоказаниями.ПриборУчета = энргМаксимальныеПоказанияСрезПоследних.ПриборУчета
	|			И ДанныеДокументаСПоказаниями.Шкала = энргМаксимальныеПоказанияСрезПоследних.Шкала
	|			И ДанныеДокументаСПоказаниями.ТарифнаяЗона = энргМаксимальныеПоказанияСрезПоследних.ТарифнаяЗона
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДляАнализа.НомерСтроки КАК НомерСтроки,
	|	ДанныеДляАнализа.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ДанныеДляАнализа.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ВЫБОР
	|		КОГДА ДанныеДляАнализа.ПереворотИзмененПользователем
	|			ТОГДА ДанныеДляАнализа.ТекущийПереворот
	|		КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|			ТОГДА ЛОЖЬ
	|		КОГДА ДанныеДляАнализа.Расход >= 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Переворот,
	|	ДанныеДляАнализа.ДатаПоследнихПоказаний КАК ДатаПоследнихПоказаний,
	|	ВЫБОР
	|		КОГДА ДанныеДляАнализа.ПереворотИзмененПользователем
	|			ТОГДА ВЫБОР
	|					КОГДА ДанныеДляАнализа.ТекущийПереворот
	|						ТОГДА ДанныеДляАнализа.РасходСПереворотом
	|					ИНАЧЕ ДанныеДляАнализа.Расход
	|				КОНЕЦ
	|		КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|			ТОГДА 0
	|		КОГДА ДанныеДляАнализа.Расход >= 0
	|			ТОГДА ДанныеДляАнализа.Расход
	|		ИНАЧЕ ДанныеДляАнализа.РасходСПереворотом
	|	КОНЕЦ КАК Разница,
	|	ЛОЖЬ КАК ПереворотИзмененПользователем,
	|	ЛОЖЬ КАК СтатусИзмененПользователем,
	|	ДанныеДляАнализа.МаксимальноВозможныеПоказания КАК МаксимальноВозможныеПоказания,
	|	ВЫБОР
	|		КОГДА ДанныеДляАнализа.ПереворотИзмененПользователем
	|			ТОГДА ДанныеДляАнализа.ТекущиеСостояниеПоказаний
	|		КОГДА ДанныеДляАнализа.ТекущиеПоказания = 0
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Отклонены)
	|		КОГДА ДанныеДляАнализа.Расход = 0
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|		КОГДА ВЫБОР
	|				КОГДА ДанныеДляАнализа.Расход >= 0
	|					ТОГДА ДанныеДляАнализа.Расход
	|				ИНАЧЕ ДанныеДляАнализа.РасходСПереворотом
	|			КОНЕЦ >= 0
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Отклонены)
	|	КОНЕЦ КАК СостояниеПоказаний,
	|	ДанныеДляАнализа.КоэффициентПУ КАК КоэффициентПУ,
	|	ДанныеДляАнализа.ПоследниеПоказания КАК ПредыдущиеПоказания
	|ИЗ
	|	ДанныеДляАнализа КАК ДанныеДляАнализа";  
	
	Если Теплоисточник <> Неопределено тогда
		Текст 						= СтрЗаменить(Текст,"ТекущиеДанныеДокумента.Теплоисточник","&Теплоисточник");
		Запрос.УстановитьПараметр("Теплоисточник",Теплоисточник);
	иначе
		Текст 						= СтрЗаменить(Текст,"И СреднийОбъемПотребленияАбонентов.Теплоисточник = &Теплоисточник","");
	КонецЕсли;
	
	Запрос.Текст 					= Текст;	
	Результат  						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	
	Пока выборка.Следующий() цикл		 
		IDСтроки  					= тзТаблицаПоказаний[Выборка.НомерСтроки -1].IDСтроки;
		ТарифнаяЗона				= тзТаблицаПоказаний[Выборка.НомерСтроки -1].ТарифнаяЗона;
		СтрокаПоказаний 			= ТаблицаПоказаний.НайтиСтроки(Новый Структура("IDСтроки, ТарифнаяЗона", IDСтроки, ТарифнаяЗона))[0];
		ЗаполнитьЗначенияСвойств(СтрокаПоказаний,Выборка);
	КонецЦикла;  
	
КонецПроцедуры

Процедура МаксимальныеПоказанияСрезПоследнихМКД(МВТ,ИмяТаблицы,Параметры)  Экспорт 
	
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Текст = "ВЫБРАТЬ
	|	энргМаксимальныеПоказания.МКД,
	|	энргМаксимальныеПоказания.ПриборУчета,
	|	энргМаксимальныеПоказания.Шкала,
	|	энргМаксимальныеПоказания.ТарифнаяЗона,
	|	энргМаксимальныеПоказания.Период,
	|	энргМаксимальныеПоказания.Регистратор,
	|	энргМаксимальныеПоказания.Разделитель,
	|	энргМаксимальныеПоказания.Показание
	|ПОМЕСТИТЬ Набор
	|ИЗ
	|	РегистрСведений.энргМаксимальныеПоказанияМКД КАК энргМаксимальныеПоказания
	|ГДЕ
	|	энргМаксимальныеПоказания.Организация = &Организация
	|	И энргМаксимальныеПоказания.Район = &Район
	|	И энргМаксимальныеПоказания.МКД = &МКД
	|	И энргМаксимальныеПоказания.ПриборУчета = &ПриборУчета
	|	И энргМаксимальныеПоказания.Период <= &МоментВремениПериод
	|	И энргМаксимальныеПоказания.Регистратор <= &МоментВремениРегистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Набор.МКД,
