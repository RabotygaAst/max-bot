КонецПроцедуры

#КонецОбласти

Функция СвязанныеДокументыСЗагрузкойПоказанийИзВнешнихИсточников(ДокументОснование) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргОбходнойЛист.Ссылка КАК Ссылка,
		|	энргОбходнойЛист.Район КАК Район,
		|	НАЧАЛОПЕРИОДА(энргОбходнойЛист.Дата, ДЕНЬ) КАК Дата
		|ИЗ
		|	Документ.энргОбходнойЛист КАК энргОбходнойЛист
		|ГДЕ
		|	энргОбходнойЛист.ДокументОснование = &ДокументОснование
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата,
		|	Район";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить(); 
	
	Возврат РезультатЗапроса;
	
КонецФункции

Функция СоответствиеПоРайонуСвязанныхДокументовСЗагрузкойПоказанийИзВнешнихИсточников(ДокументОснование) Экспорт
	Результат = Новый Соответствие;
	
	РезультатЗапроса = СвязанныеДокументыСЗагрузкойПоказанийИзВнешнихИсточников(ДокументОснование); 	
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Район, Выборка.Ссылка.ПолучитьОбъект());
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция СоответствиеПоРайонуДатеСвязанныхДокументовСЗагрузкойПоказанийИзВнешнихИсточников(ДокументОснование) Экспорт
	Результат = Новый Соответствие;
	
	РезультатЗапроса = СвязанныеДокументыСЗагрузкойПоказанийИзВнешнихИсточников(ДокументОснование); 	
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Результат[Выборка.Дата] = Неопределено Тогда			
			СоотвествиРайон	= Новый Соответствие;
			СоотвествиРайон.Вставить(Выборка.Район, Выборка.Ссылка.ПолучитьОбъект()); 
			
			Результат.Вставить(Выборка.Дата, СоотвествиРайон);			
		Иначе			
			Результат[Выборка.Дата].Вставить(Выборка.Район, Выборка.Ссылка.ПолучитьОбъект());			
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

#Область ПолучениеАктуальныйПриборовИИхПоказаний

Функция РезультатЗапросаАктуальныхПриборовИИхПоказаний(Период, ВходныеПараметры) Экспорт 
	
	Схема 			= Неопределено;  	
	ПараметрыВТ 	= Новый Массив;
	
	СоответствиеРавно = Новый Структура("Организация, Район, КлючПомещения, АбонентВладелец", "Организация", "Район", "КлючПомещения", "КлючПомещения");	
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(СоответствиеРавно));
				
	Параметры = Новый Структура;	
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);
	Параметры.Вставить("Период",  Новый Структура("ИмяПараметра,ТипПараметра", "Период", "ГраницаИсключая"));
	Параметры.Вставить("ВключаяОРП", Истина);
	
	РегистрыСведений.энргСостояниеПриборовУчетаАбонента.ДействующиеПриборыУчетаПомещения(Схема, Параметры, "ДействующиеПриборыУчетаПомещения");
	РегистрыСведений.энргВидыДифференцированностиПриборовУчета.ВидДифференцированностиВведенныхПриборов(Схема, Параметры, "ВидДифференцированностиВведенныхПриборов");	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	ВложенныйЗапрос.Организация КАК Организация,
		|	ВложенныйЗапрос.Район КАК Район,
		|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
		|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
		|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
		|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
		|	ЕСТЬNULL(энргВидыКанальностиШкалы.Шкала, ЗНАЧЕНИЕ(Справочник.энргШкалыПриборовУчета.ПустаяСсылка)) КАК Шкала,
		|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
		|	ВложенныйЗапрос.ЗаводскойНомер КАК ЗаводскойНомер
		|ПОМЕСТИТЬ ДанныеПоПриборам
		|ИЗ
		|	(ВЫБРАТЬ
		|		ДействующиеПриборыУчетаПомещения.Организация КАК Организация,
		|		ДействующиеПриборыУчетаПомещения.Район КАК Район,
		|		ДействующиеПриборыУчетаПомещения.КлючПомещения КАК КлючПомещения,
		|		ДействующиеПриборыУчетаПомещения.ТочкаУчета КАК ТочкаУчета,
		|		ДействующиеПриборыУчетаПомещения.ПриборУчета КАК ПриборУчета,
		|		ЕСТЬNULL(энргПриборыУчетаАбонента.ВидКанальности, ЗНАЧЕНИЕ(Справочник.энргВидыКанальности.ПустаяСсылка)) КАК ВидКанальности,
		|		энргПриборыУчетаАбонента.РегистрируетОбъем КАК РегистрируетОбъем,
		|		энргПриборыУчетаАбонента.Код КАК ЗаводскойНомер
		|	ИЗ
		|		ДействующиеПриборыУчетаПомещения КАК ДействующиеПриборыУчетаПомещения
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
		|			ПО ДействующиеПриборыУчетаПомещения.ПриборУчета = энргПриборыУчетаАбонента.Ссылка) КАК ВложенныйЗапрос
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
		|		ПО ВложенныйЗапрос.ВидКанальности = энргВидыКанальностиШкалы.Ссылка");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	Вложенныйзапрос.Организация КАК Организация,
		|	Вложенныйзапрос.Район КАК Район,
		|	Вложенныйзапрос.КлючПомещения КАК КлючПомещения,
		|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
		|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
		|	Вложенныйзапрос.Шкала КАК Шкала,
		|	Вложенныйзапрос.ЗаводскойНомер КАК ЗаводскойНомер,
		|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона
		|ПОМЕСТИТЬ ДанныеПоПриборамИтог
		|ИЗ
		|	(ВЫБРАТЬ
		|		ДанныеПоПриборам.Организация КАК Организация,
		|		ДанныеПоПриборам.Район КАК Район,
		|		ДанныеПоПриборам.КлючПомещения КАК КлючПомещения,
		|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
		|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
		|		ДанныеПоПриборам.Шкала КАК Шкала,
		|		ЕСТЬNULL(ВидДифференцированностиВведенныхПриборов.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности,
		|		ДанныеПоПриборам.ЗаводскойНомер КАК ЗаводскойНомер
		|	ИЗ
		|		ДанныеПоПриборам КАК ДанныеПоПриборам
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВидДифференцированностиВведенныхПриборов КАК ВидДифференцированностиВведенныхПриборов
		|			ПО ДанныеПоПриборам.Организация = ВидДифференцированностиВведенныхПриборов.Организация
		|				И ДанныеПоПриборам.Район = ВидДифференцированностиВведенныхПриборов.Район
		|				И ДанныеПоПриборам.КлючПомещения = ВидДифференцированностиВведенныхПриборов.КлючПомещения
		|				И ДанныеПоПриборам.ПриборУчета = ВидДифференцированностиВведенныхПриборов.ПриборУчета
		|				И ДанныеПоПриборам.Шкала = ВидДифференцированностиВведенныхПриборов.Шкала) КАК Вложенныйзапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
		|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка");
	
	
	ПоляОтбораПоказаний = Новый Структура("ПриборУчета,Шкала,ТарифнаяЗона", "ПриборУчета","Шкала","ТарифнаяЗона");
	ОтборПоказаний = энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица("ДанныеПоПриборамИтог", ПоляОтбораПоказаний);
	ПараметрыВТ.Добавить(ОтборПоказаний);
	РегистрыСведений.энргМаксимальныеПоказания.МаксимальныеПоказанияСрез(Схема, Параметры, "МаксимальныеПоказанияСрез");
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеПоПриборамИтог.Организация КАК Организация,
	|	ДанныеПоПриборамИтог.Район КАК Район,
	|	ДанныеПоПриборамИтог.КлючПомещения КАК КлючПомещения,
	|	ДанныеПоПриборамИтог.ТочкаУчета КАК ТочкаУчета,
	|	ДанныеПоПриборамИтог.ПриборУчета КАК ПриборУчета,
	|	ДанныеПоПриборамИтог.ЗаводскойНомер КАК ЗаводскойНомерПриборУчета,
	|	ДанныеПоПриборамИтог.Шкала КАК Шкала,
	|	ДанныеПоПриборамИтог.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ЕСТЬNULL(МаксимальныеПоказанияСрез.Показание, 0) КАК Показание,
	|	ПРЕДСТАВЛЕНИЕ(ДанныеПоПриборамИтог.ТарифнаяЗона) КАК ТарифнаяЗонаИмя
	|ИЗ
	|	ДанныеПоПриборамИтог КАК ДанныеПоПриборамИтог
	|		ЛЕВОЕ СОЕДИНЕНИЕ МаксимальныеПоказанияСрез КАК МаксимальныеПоказанияСрез
	|		ПО ДанныеПоПриборамИтог.Организация = МаксимальныеПоказанияСрез.Организация
	|			И ДанныеПоПриборамИтог.Район = МаксимальныеПоказанияСрез.Район
	|			И ДанныеПоПриборамИтог.КлючПомещения = МаксимальныеПоказанияСрез.КлючПомещения
	|			И ДанныеПоПриборамИтог.ПриборУчета = МаксимальныеПоказанияСрез.ПриборУчета
	|			И ДанныеПоПриборамИтог.Шкала = МаксимальныеПоказанияСрез.Шкала
	|			И ДанныеПоПриборамИтог.ТарифнаяЗона = МаксимальныеПоказанияСрез.ТарифнаяЗона
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПриборУчета,
	|	Шкала");
	
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Период",			Период);
	ПараметрыЗапроса.Вставить("Организация",	ВходныеПараметры.Организация);
	ПараметрыЗапроса.Вставить("Район",			ВходныеПараметры.Район); 	
	ПараметрыЗапроса.Вставить("КлючПомещения",	ВходныеПараметры.КлючПомещения);			
	
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса); 
	Возврат РезультатЗапроса;
	
КонецФункции

Функция РезультатЗапросаАктуальныхПриборовМКДИхПоказаний(Период, ВходныеПараметры) Экспорт 
	
	Схема 			= Неопределено;  	
	ПараметрыВТ 	= Новый Массив;
	
	СоответствиеРавно = Новый Структура("Организация, Район, МКД, АбонентВладелец", "Организация", "Район", "МКД", "МКД");	
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(СоответствиеРавно));
				
	Параметры = Новый Структура;	
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);
	Параметры.Вставить("Период",  Новый Структура("ИмяПараметра,ТипПараметра", "Период", "ГраницаИсключая"));
	Параметры.Вставить("ВключаяОРП", Истина);
	
	РегистрыСведений.энргСостояниеПриборовМКД.АктивныеПриборыУчетаМКД(Схема, Параметры, "ДействующиеПриборыУчетаМКД");
	РегистрыСведений.энргУслугиТочекУчетаМКД.УслугиДействующихТочек(Схема, Параметры, "УслугиДействующихТочекМКД"); 	
	РегистрыСведений.энргВидыДифференцированностиПриборовУчетаМКД.ВидДифференцированностиВведенныхПриборов(Схема, Параметры, "ВидДифференцированностиВведенныхПриборов");


	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	ВложенныйЗапрос.Организация КАК Организация,
		|	ВложенныйЗапрос.Район КАК Район,
		|	ВложенныйЗапрос.МКД КАК МКД,
		|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
		|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
		|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
		|	ЕСТЬNULL(энргВидыКанальностиШкалы.Шкала, ЗНАЧЕНИЕ(Справочник.энргШкалыПриборовУчета.ПустаяСсылка)) КАК Шкала,
		|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
		|	ВложенныйЗапрос.ЗаводскойНомер КАК ЗаводскойНомер
