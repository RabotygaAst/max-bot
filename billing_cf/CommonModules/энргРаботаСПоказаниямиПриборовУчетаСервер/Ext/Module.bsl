#Область ВосстановлениеПоследовательности

Процедура ВосстановитьПоказанияМногопоточно(Отборы, ДополнительныеПараметры) Экспорт 
	
	КоличествоПотоков = ДополнительныеПараметры.КоличествоПотоков;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргПоказанияПУПоследовательность.Строение КАК Строение,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ энргПоказанияПУПоследовательность.ПриборУчета) КАК ПриборУчета
		|ПОМЕСТИТЬ СбитыеВПоследоватеьности
		|ИЗ
		|	РегистрСведений.энргПоказанияПУПоследовательность КАК энргПоказанияПУПоследовательность
		|ГДЕ
		|	энргПоказанияПУПоследовательность.Организация = &Организация
		|	И энргПоказанияПУПоследовательность.ПериодНачисления = &ПериодНачисления
		|	И энргПоказанияПУПоследовательность.Район = &Район
		|	И НЕ энргПоказанияПУПоследовательность.СостояниеПроведения = &СостояниеПроведения
		|
		|СГРУППИРОВАТЬ ПО
		|	энргПоказанияПУПоследовательность.Строение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СбитыеВПоследоватеьности.Строение КАК Строение
		|ИЗ
		|	СбитыеВПоследоватеьности КАК СбитыеВПоследоватеьности
		|
		|УПОРЯДОЧИТЬ ПО
		|	СбитыеВПоследоватеьности.ПриборУчета УБЫВ";
	
	Запрос.УстановитьПараметр("Организация", Отборы.Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", Отборы.ПериодНачисления);
	Запрос.УстановитьПараметр("Район", Отборы.Район);
	Запрос.УстановитьПараметр("СостояниеПроведения", ПредопределенноеЗначение("Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности"));
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	ОбщееКоличество = Выборка.Количество();		
	Если ОбщееКоличество <= КоличествоПотоков Тогда 
		Порция = ОбщееКоличество;
	Иначе 
		Порция = Цел(ОбщееКоличество / КоличествоПотоков);
		Если (ОбщееКоличество % КоличествоПотоков) > 0 Тогда			
			Порция = Порция + 1;
		КонецЕсли;
	КонецЕсли;	
	
	Итерация = 0; 
	ПодготовленныеПотоки = Новый Массив;
	Для Сч = 1 По КоличествоПотоков Цикл
		
		ПодготовленныеПотоки.Добавить(Новый Массив);		
		
	КонецЦикла;
	
	Пока Выборка.Следующий() Цикл
		
		Если Итерация >  КоличествоПотоков - 1 Тогда
			Итерация = 0;
		КонецЕсли;
		
		ПодготовленныеПотоки[Итерация].Добавить(Выборка.Строение);
		
		Итерация = Итерация + 1;
	КонецЦикла;
	
	ДлительныеОперацииСписок = Новый Массив;
	Для Каждого Поток из ПодготовленныеПотоки Цикл 
		ДлительнаяОперация = ЗапуститьФоновоеЗаданиеСервер(Отборы, Поток);
		ДлительныеОперацииСписок.Добавить(ДлительнаяОперация);
	КонецЦикла;
	           	
	ОжидатьЗавершениеВсехПотоков(ДлительныеОперацииСписок);
	
КонецПроцедуры

Функция ЗапуститьФоновоеЗаданиеСервер(Отборы, Идентификаторы)

	Инструмент = Новый Структура("Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение,Строения");
	Инструмент.Организация  	= Отборы.Организация;
	Инструмент.ПериодНачисления	= Отборы.ПериодНачисления;
	Инструмент.Район			= Отборы.Район;
	Инструмент.Строения			= Идентификаторы;	
	
	Шаблон = "ru = '%1'";
	НаимДок = "";
	ИмяФункции = "энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоказанияПУМногопоточно";
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр(СтрШаблон(Шаблон, НаимДок));
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения, 
		ИмяФункции,
		Инструмент);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

Процедура ОжидатьЗавершениеВсехПотоков(ДлительныеОперацииСписок)
	
	ЗавершенныеЗадания = Новый Массив;
	Пока Истина Цикл
		
		Если ЗавершенныеЗадания.Количество() = ДлительныеОперацииСписок.Количество() Тогда 
			Прервать;
		КонецЕсли;
		
		
		Для Каждого ДлительнаяОперация из ДлительныеОперацииСписок Цикл 
			
			Если НЕ ЗавершенныеЗадания.Найти(ДлительнаяОперация) = Неопределено Тогда 
				Продолжить;
			КонецЕсли;
			
			
			Выполнено = Ложь;
			Попытка
				
				Выполнено = ДлительныеОперации.ЗаданиеВыполнено(ДлительнаяОперация.ИдентификаторЗадания);	
				
			Исключение
				// Завершенные аварийно задания помещаем как выполненные
				Выполнено = Истина;
			КонецПопытки;
			
			Если Выполнено Тогда 
				ЗавершенныеЗадания.Добавить(ДлительнаяОперация);
			КонецЕсли; 			
			
		КонецЦикла;
		
		ОбменДаннымиСервер.Пауза(5);
		
	КонецЦикла; 	
	
КонецПроцедуры
	
#КонецОбласти