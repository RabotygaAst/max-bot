			КонецЕсли;
			
			ПоляТаблицы 			= ПоляТаблицы + ?(НЕ ПустаяСтрока(ПоляТаблицы),Символы.ПС + "И ","") + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,КлючЗначениеИмяТаблицы.Ключ,КлючЗначение.Ключ,КлючЗначение.Значение);			
		КонецЦикла;
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
		
		ОтборСхемыЗапроса.Добавить(ПоляТаблицы);
		
	ИначеЕсли ПараметрОтбор.ТипПараметра = "ТипПараметраНеВСписке" Тогда
		ПоляТаблицы 				= "";
		ШаблонПоля 					= "НЕ %1.%2 В (&%3)";           
		
		Для Каждого КлючЗначение Из ПараметрОтбор.СоотвествиеПолей Цикл				
			ЕстьПолеОтбора 			= Ложь;
			Для Каждого КлючЗначениеИмяТаблицы Из стДоступныеПоляОтбора Цикл
				Если НЕ КлючЗначениеИмяТаблицы.Значение.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
