#КонецОбласти

Процедура ДобавитьПолеУпорядочивания(ПорядокСхемы, ДоступныеПоля, ИмяПоля) Экспорт 
	НайденноеПоле = ДоступныеПоля.Найти(ИмяПоля);
	Если НайденноеПоле = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ПорядокСхемы.Добавить(НайденноеПоле);	
КонецПроцедуры

#КонецОбласти

