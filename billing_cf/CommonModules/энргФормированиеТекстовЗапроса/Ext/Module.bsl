
#Область СлужебныйПрограммныйИнтерфейс

#Область УстановкаОтборов

Процедура УстановитьПараметрыВременнойТаблицыРегистраСведений(Параметр, ПараметрыВТ, ДоступныеПараметры) Экспорт	
	
	Если ТипЗнч(ПараметрыВТ) = Тип("Структура") Тогда
		УстановитьПараметрВременнойТаблицы(Параметр, ПараметрыВТ, ДоступныеПараметры);
	Иначе
		Для Сч = 0 По ПараметрыВТ.ВГраница() Цикл
			УстановитьПараметрВременнойТаблицы(Параметр, ПараметрыВТ[Сч], ДоступныеПараметры);
		КонецЦикла;
	КонецЕсли;	
	 	
КонецПроцедуры

Процедура УстановитьПараметрыТаблицыПодмены(Запрос, ТаблицыПодмены) Экспорт 
	
	Для Каждого КлючЗначение Из ТаблицыПодмены Цикл
		Запрос.УстановитьПараметр(КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;	
	
КонецПроцедуры 

Процедура УстановитьОтборТаблицы(ОтборСхемыЗапроса, ИмяТаблицы, Параметры, ДоступныеПоляОтбора, ИсточникиПолей = "", ОператорыВыбора = Неопределено) Экспорт 
	Если НЕ ДоступныеПоляОтбора = Неопределено И ТипЗнч(ДоступныеПоляОтбора) = Тип("Строка") Тогда
		врДоступныеПоляОтбора 						= Новый Структура(ИмяТаблицы, ДоступныеПоляОтбора);
	Иначе
		врДоступныеПоляОтбора 						= ДоступныеПоляОтбора;
	КонецЕсли;
	
	стДоступныеПоляОтбора 							= Новый Структура;
	Для Каждого КлючЗначение Из врДоступныеПоляОтбора Цикл
		врмДоступныеПоляОтбора 						= СтрРазделить(СтрЗаменить(ВРег(КлючЗначение.Значение)," ",""),",");
		стДоступныеПоляОтбора.Вставить(КлючЗначение.Ключ, врмДоступныеПоляОтбора);
	КонецЦикла;
		
	Для Сч = 0 По Параметры.ВГраница() Цикл
		ПараметрОтбор = Параметры[Сч];	
		Если ПараметрОтбор.ТипПараметра = "ТипПараметраГруппаИли" Тогда
			Для Индекс = 0 По ПараметрОтбор.Значение.ВГраница() Цикл
				УстановитьОтборОператора(ОператорыВыбора[Индекс].Отбор,ПараметрОтбор.Значение[Индекс],стДоступныеПоляОтбора);
				Если НЕ Индекс = ПараметрОтбор.Значение.ВГраница() Тогда
					НовыйОператор 					= ОператорыВыбора.Добавить(ОператорыВыбора[Индекс]);
					НовыйОператор.ТипОбъединения 	= ТипОбъединенияСхемыЗапроса.Объединить;
					НовыйОператор.Отбор.Удалить(НовыйОператор.Отбор.Количество()-1);
				КонецЕсли;
			КонецЦикла;
			
		Иначе 
			УстановитьОтборОператора(ОтборСхемыЗапроса, ПараметрОтбор, стДоступныеПоляОтбора);	
		КонецЕсли;
	КонецЦикла;

