Процедура УстановитьИсточникЗапроса(Источник1, Источник2, ТипСоединения, МассивУсловий) Экспорт 
	
	ШаблонПоля	= "%1.%2 = %3.%4";           
	
	Для Каждого ПараметрУсловия Из МассивУсловий Цикл
		Если ПараметрУсловия.ТипУсловия = "ТипУсловияРавно" Тогда
			
			Для Каждого КлючЗначение Из ПараметрУсловия.СоотвествиеУсловий Цикл	
				
				ТекстУсловия	= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля, Источник1.Источник.Псевдоним, КлючЗначение.Ключ, Источник2.Источник.Псевдоним, КлючЗначение.Значение);	
				Источник1.Соединения.Добавить(Источник2, ТекстУсловия);
				
			КонецЦикла;
			
			НачальнаяПозиция	=  Источник1.Соединения.Количество() - ПараметрУсловия.СоотвествиеУсловий.Количество();
			
			Для Сч = НачальнаяПозиция По Источник1.Соединения.Количество()-1 Цикл
				Источник1.Соединения[Сч].ТипСоединения = ТипСоединения;
			КонецЦикла;
			
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область УстановкаПерехватов

Процедура УстановитьПерехватОбращенияКТаблицам(СхемаЗапроса,ТаблицыПодмены, ПараметрыЗапроса) Экспорт 
	
	Если СхемаЗапроса = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИменаТаблицПодмены  		= ТаблицыПерехватаВДоступныеТаблицы(СхемаЗапроса, ТаблицыПодмены, ПараметрыЗапроса);	
	Для Каждого Пакет Из СхемаЗапроса.ПакетЗапросов Цикл
		СоотвествиеЗамен 		= Новый Соответствие;
		Для Каждого Оператор Из Пакет.Операторы Цикл
			Для Каждого Источник Из Оператор.Источники Цикл
				УстановитьПерехватОбращенияКТаблицамРекурсия(Источник,СоотвествиеЗамен,ИменаТаблицПодмены);
			КонецЦикла;			
		КонецЦикла;
		Если СоотвествиеЗамен.Количество() > 0 Тогда
			ТекстЗапроса 		= Пакет.ПолучитьТекстЗапроса();
			Для Каждого КлючЗначение Из СоотвествиеЗамен Цикл
				ТекстЗапроса 	= СтрЗаменить(ТекстЗапроса,КлючЗначение.Ключ,КлючЗначение.Значение);
			КонецЦикла;
			Пакет.УстановитьТекстЗапроса(ТекстЗапроса);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ДобавитьДополнительныеПоляИзИсточника(Пакет, ИмяТаблицы, ПсевдонимТаблицы, УсловияСоединения, ВыбираемыеПоля) Экспорт 
	
	Схема  							= Новый СхемаЗапроса;
	Результат 						= Схема.ПакетЗапросов[0];
	Результат.УстановитьТекстЗапроса(Пакет.ПолучитьТекстЗапроса());
	
	Результат.Операторы[0].Источники.Добавить(ИмяТаблицы,ПсевдонимТаблицы);
	Если Результат.Операторы[0].Источники[0].Соединения.Добавить(ИмяТаблицы,СтрСоединить(УсловияСоединения,Символы.ПС + " И ")) Тогда			 
		Соединение					= Результат.Операторы[0].Источники[0].Соединения[Результат.Операторы[0].Источники[0].Соединения.Количество() -1];
		Соединение.ТипСоединения 	= ТипСоединенияСхемыЗапроса.ЛевоеВнешнее;
	КонецЕсли;
	
	Для Каждого КлючЗначение Из ВыбираемыеПоля Цикл
		Результат.Операторы[0].ВыбираемыеПоля.Добавить(КлючЗначение.Значение);
		Колонка 					= Результат.Колонки[Пакет.Колонки.Количество()-1];
		Колонка.Псевдоним 			= КлючЗначение.Ключ;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

