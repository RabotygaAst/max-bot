			иначе 
				ПоляСПо					= КлючЗначение.Значение;
				ПоляТаблицы 			= ПоляТаблицы + ?(НЕ ПустаяСтрока(ПоляТаблицы),Символы.ПС + "И ","") + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,КлючЗначениеИмяТаблицы.Ключ,КлючЗначение.Ключ,ПоляСПо.ГраницаС, ПоляСПо.ГраницаПо);			
