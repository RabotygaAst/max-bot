			Возврат;
		КонецЕсли;
		
		ОтборСхемыЗапроса.Добавить(ПоляТаблицы); 
		 	
	КонецЕсли;

КонецПроцедуры

Процедура ДобавитьУсловие(ПоляТаблицы, ШаблонПоля, стДоступныеПоляОтбора, ПараметрОтбор)
	
	Для Каждого КлючЗначение Из ПараметрОтбор.СоотвествиеПолей Цикл				
		
		ЕстьПолеОтбора = Ложь;
		
		Для Каждого КлючЗначениеИмяТаблицы Из стДоступныеПоляОтбора Цикл
			Если НЕ КлючЗначениеИмяТаблицы.Значение.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
				ЕстьПолеОтбора = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;				
		
		Если НЕ ЕстьПолеОтбора Тогда
			Продолжить;
		КонецЕсли;
		
		ПоляТаблицы = ПоляТаблицы + 
		?(НЕ ПустаяСтрока(ПоляТаблицы), Символы.ПС + "И ", "") + 
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонПоля, 
			КлючЗначениеИмяТаблицы.Ключ, 
			КлючЗначение.Ключ, 
			КлючЗначение.Значение);	
		
	КонецЦикла;
	
КонецПроцедуры


#КонецОбласти

#Область УстановкаПерехватов

Процедура УстановитьПерехватОбращенияКТаблицамРекурсия(Источник,СоотвествиеЗамен,ИменаТаблицПодмены)
	
	Если ТипЗнч(Источник.Источник) = Тип("ТаблицаСхемыЗапроса") Тогда
		Если НЕ ИменаТаблицПодмены[Источник.Источник.ИмяТаблицы] = Неопределено Тогда 			
			СоотвествиеЗамен.Вставить(Источник.Источник.ИмяТаблицы + " КАК " + Источник.Источник.Псевдоним, ИменаТаблицПодмены[Источник.Источник.ИмяТаблицы] + " КАК " + Источник.Источник.Псевдоним);
		КонецЕсли;		
	ИначеЕсли ТипЗнч(Источник.Источник) = Тип("ВложенныйЗапросСхемыЗапроса") Тогда
		Для Каждого яОператор Из Источник.Источник.Запрос.Операторы Цикл
			Для Каждого яИсточник Из яОператор.Источники Цикл
				УстановитьПерехватОбращенияКТаблицамРекурсия(яИсточник,СоотвествиеЗамен,ИменаТаблицПодмены);
			КонецЦикла;			
		КонецЦикла;
	ИначеЕсли ТипЗнч(Источник.Источник) = Тип("ОписаниеВременнойТаблицыСхемыЗапроса") Тогда
		Ат = 0;
	Иначе
		ВызватьИсключение "Ой, что то пошло не так";
	КонецЕсли;
		
	
КонецПроцедуры

Процедура УстановитьПараметрВременнойТаблицы(Параметр, ПараметрыВТ, ДоступныеПараметры)
	
	мДоступныеПараметры 			= СтрРазделить(СтрЗаменить(ВРег(ДоступныеПараметры)," ",""),",",);
	Если ПараметрыВТ.ТипПараметра = "ТипПараметраВременнаяТаблица" Тогда
		Шаблон 						= "(%1) В (ВЫБРАТЬ %2 ИЗ %3 КАК %3)";
		ПоляТаблицы 				= "";
		ПоляВременнойТаблицы 		= "";		
		ШаблонПоля 					= "%1";
		ШаблонПоляВыбора			= "%1.%2";
		ТаблицаИсточник 			= ПараметрыВТ.ТаблицаИсточник;
		Для Каждого КлючЗначение Из ПараметрыВТ.СоотвествиеПолей Цикл				
			Если ПустаяСтрока(ДоступныеПараметры) ИЛИ мДоступныеПараметры.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ПоляТаблицы 			= ПоляТаблицы + ?(НЕ ПустаяСтрока(ПоляТаблицы),",","") +  СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,КлючЗначение.Ключ);
			ПоляВременнойТаблицы	= ПоляВременнойТаблицы + ?(НЕ ПустаяСтрока(ПоляВременнойТаблицы),",","") + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоляВыбора,ТаблицаИсточник,КлючЗначение.Значение)
		КонецЦикла;
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
		
		стрВыражение 				= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон,ПоляТаблицы,ПоляВременнойТаблицы,ТаблицаИсточник);
		
		Если Не ПустаяСтрока("" + Параметр.Выражение) Тогда
			Параметр.Выражение		= Новый ВыражениеСхемыЗапроса("" + Параметр.Выражение + Символы.ПС + "И " + стрВыражение);
		Иначе
			Параметр.Выражение		= Новый ВыражениеСхемыЗапроса(стрВыражение);
		КонецЕсли;
		
		
	ИначеЕсли ПараметрыВТ.ТипПараметра = "ТипПараметраРавно" Тогда
		ПоляТаблицы 				= "";
		ШаблонПоля 					= "%1 = &%2";
		Для Каждого КлючЗначение Из ПараметрыВТ.СоотвествиеПолей Цикл				
			Если ПустаяСтрока(ДоступныеПараметры) ИЛИ мДоступныеПараметры.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
				Продолжить;
			КонецЕсли;			
			мПараметрыИЛИ 			= СтрРазделить(КлючЗначение.Значение, ",");
			ПолеТаблицы 			= ?(мПараметрыИЛИ.Количество() = 1,"","(");
			Для ИндексПараметраИли = 0 По мПараметрыИЛИ.ВГраница() Цикл
				Если НЕ ИндексПараметраИли = 0 Тогда
					ПолеТаблицы 	= ПолеТаблицы + Символы.ПС + "ИЛИ ";
				КонецЕсли;
				ПолеТаблицы 		= ПолеТаблицы + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,КлючЗначение.Ключ,мПараметрыИЛИ[ИндексПараметраИли]);
			КонецЦикла;
			
			Если НЕ мПараметрыИЛИ.Количество() = 1 Тогда
				ПолеТаблицы 		= ПолеТаблицы + ")";
			КонецЕсли;
			
			ПоляТаблицы 			= ПоляТаблицы + ?(НЕ ПустаяСтрока(ПоляТаблицы),Символы.ПС + "И ","") + ПолеТаблицы;
		КонецЦикла;	
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
		
		Если Не ПустаяСтрока("" + Параметр.Выражение) Тогда
			Параметр.Выражение		= Новый ВыражениеСхемыЗапроса("" + Параметр.Выражение + Символы.ПС + "И " + ПоляТаблицы);
		Иначе
			Параметр.Выражение		= Новый ВыражениеСхемыЗапроса(ПоляТаблицы);
		КонецЕсли;
		
	ИначеЕсли ПараметрыВТ.ТипПараметра = "ТипПараметраМеньше" Тогда
		ПоляТаблицы 				= "";
		ШаблонПоля 					= "%1 < &%2";
		Для Каждого КлючЗначение Из ПараметрыВТ.СоотвествиеПолей Цикл				
			Если ПустаяСтрока(ДоступныеПараметры) ИЛИ мДоступныеПараметры.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
				Продолжить;
			КонецЕсли;			
			мПараметрыИЛИ 			= СтрРазделить(КлючЗначение.Значение, ",");
			ПолеТаблицы 			= ?(мПараметрыИЛИ.Количество() = 1,"","(");
			Для ИндексПараметраИли = 0 По мПараметрыИЛИ.ВГраница() Цикл
				Если НЕ ИндексПараметраИли = 0 Тогда
					ПолеТаблицы 	= ПолеТаблицы + Символы.ПС + "ИЛИ ";
				КонецЕсли;
				ПолеТаблицы 		= ПолеТаблицы + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,КлючЗначение.Ключ,мПараметрыИЛИ[ИндексПараметраИли]);
			КонецЦикла;
			
			Если НЕ мПараметрыИЛИ.Количество() = 1 Тогда
				ПолеТаблицы 		= ПолеТаблицы + ")";
			КонецЕсли;
			
			ПоляТаблицы 			= ПоляТаблицы + ?(НЕ ПустаяСтрока(ПоляТаблицы),Символы.ПС + "И ","") + ПолеТаблицы;
		КонецЦикла;	
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
		
		Если Не ПустаяСтрока("" + Параметр.Выражение) Тогда
			Параметр.Выражение		= Новый ВыражениеСхемыЗапроса("" + Параметр.Выражение + Символы.ПС + "И " + ПоляТаблицы);
		Иначе
			Параметр.Выражение		= Новый ВыражениеСхемыЗапроса(ПоляТаблицы);
		КонецЕсли;
		
	ИначеЕсли ПараметрыВТ.ТипПараметра = "ТипПараметраВСписке" Тогда
		ПоляТаблицы 				= "";
		ШаблонПоля 					= "%1 В (&%2)";
		Для Каждого КлючЗначение Из ПараметрыВТ.СоотвествиеПолей Цикл				
			Если ПустаяСтрока(ДоступныеПараметры) ИЛИ мДоступныеПараметры.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
				Продолжить;
			КонецЕсли;			
			ПоляТаблицы 			= ПоляТаблицы + ?(НЕ ПустаяСтрока(ПоляТаблицы),Символы.ПС + "И ","") +  СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,КлючЗначение.Ключ, КлючЗначение.Значение);
		КонецЦикла;	
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
				
		Если Не ПустаяСтрока("" + Параметр.Выражение) Тогда
			Параметр.Выражение		= Новый ВыражениеСхемыЗапроса("" + Параметр.Выражение + Символы.ПС + "И " + ПоляТаблицы);
		Иначе
			Параметр.Выражение		= Новый ВыражениеСхемыЗапроса(ПоляТаблицы);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ТаблицыПерехватаВДоступныеТаблицы(СхемаЗапроса, ТаблицыПодмены, ПараметрыЗапроса) 
	ИсходноеКоличествоПакетов 				= Неопределено;
	Индекс 									= 0;
	ТаблицыПерехвата 						= Новый Соответствие;
	ШаблонТекстаЗапроса  					= 
	"ВЫБРАТЬ 
	|	%1
	|ПОМЕСТИТЬ %2
	|ИЗ
	|	&%2 КАК %2";
	ШаблонВыбораПоля 						=  "%1.%2 КАК %2";
	Для Каждого КлючЗначение Из ТаблицыПодмены Цикл
		ТаблицаПерехвата 					= Новый ТаблицаЗначений;
		мМетаданные 						= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(КлючЗначение.Ключ,".");
		Если мМетаданные[0] = "Документ" Тогда
			КоллекцияМетаданных 			= Метаданные.Документы;
		ИначеЕсли мМетаданные[1] = "Справочник" Тогда
			КоллекцияМетаданных 			= Метаданные.Справочники;
		КонецЕсли;
		мМассивПолей 						= Новый Массив;
		яМетаданныеТаблицы  				= КоллекцияМетаданных[мМетаданные[1]];
		ПсевдонимТаблицы 					= "Таблица" + мМетаданные[1];
				
		ДобавитьПоляТаблицыВМассив(мМассивПолей, ПсевдонимТаблицы, ТаблицаПерехвата, ШаблонВыбораПоля, яМетаданныеТаблицы);
	
		ТекстЗапроса  						= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонТекстаЗапроса,СтрСоединить(мМассивПолей,"," + Символы.ПС),ПсевдонимТаблицы);
		Если СхемаЗапроса = Неопределено Тогда
			СхемаЗапроса  					= Новый СхемаЗапроса;
			Пакет 							= СхемаЗапроса.ПакетЗапросов[0];
			ИсходноеКоличествоПакетов 		= 0;
		Иначе
			Если ИсходноеКоличествоПакетов = Неопределено Тогда
				ИсходноеКоличествоПакетов 	= СхемаЗапроса.ПакетЗапросов.Количество();
			КонецЕсли;			
			Пакет 							= СхемаЗапроса.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
		КонецЕсли;  	 
		Индекс 								= Индекс + 1;
		Пакет.УстановитьТекстЗапроса(ТекстЗапроса);
		ЗаполнитьТаблицуПерехавата(КлючЗначение.Значение, ТаблицаПерехвата);		
		ТаблицыПерехвата.Вставить(КлючЗначение.Ключ, ПсевдонимТаблицы);
		ПараметрыЗапроса.Вставить(ПсевдонимТаблицы, ТаблицаПерехвата);	
		СхемаЗапроса.ПакетЗапросов.Сдвинуть(Пакет,0-ИсходноеКоличествоПакетов);
		
		Для Каждого ТабЧасть Из яМетаданныеТаблицы.ТабличныеЧасти Цикл			
			ТаблицаПерехватаТабЧасти		= Новый ТаблицаЗначений;
			мМассивПолейТабЧасти			= Новый Массив;
			ПсевдонимТаблицыТабЧасти		= ПсевдонимТаблицы + ТабЧасть.Имя;
			ДобавитьПоляТаблицыВМассив(мМассивПолейТабЧасти, ПсевдонимТаблицыТабЧасти, ТаблицаПерехватаТабЧасти, ШаблонВыбораПоля, ТабЧасть, яМетаданныеТаблицы);
			ТекстЗапросаТабЧасти			= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонТекстаЗапроса,СтрСоединить(мМассивПолейТабЧасти,"," + Символы.ПС),ПсевдонимТаблицыТабЧасти);
			Пакет 							= СхемаЗапроса.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
			Пакет.УстановитьТекстЗапроса(ТекстЗапросаТабЧасти);
			Для Сч = 0 По КлючЗначение.Значение.ВГраница() Цикл
				Если НЕ КлючЗначение.Значение[Сч].Свойство(ТабЧасть.Имя) Тогда
					Продолжить;
				КонецЕсли; 				
				ЗаполнитьТаблицуПерехавата(КлючЗначение.Значение[Сч][ТабЧасть.Имя], ТаблицаПерехватаТабЧасти);
			КонецЦикла;		
			ТаблицыПерехвата.Вставить(КлючЗначение.Ключ + "." + ТабЧасть.Имя, ПсевдонимТаблицыТабЧасти);
			ПараметрыЗапроса.Вставить(ПсевдонимТаблицыТабЧасти, ТаблицаПерехватаТабЧасти);	
			СхемаЗапроса.ПакетЗапросов.Сдвинуть(Пакет,0-ИсходноеКоличествоПакетов);		
		КонецЦикла;		
	КонецЦикла;
	
	Возврат ТаблицыПерехвата;
	
КонецФункции

Процедура ДобавитьПоляТаблицыВМассив(мМассивПолей, ПсевдонимТаблицы, ТаблицаПерехвата, ШаблонВыбораПоля, яМетаданныеТаблицы, яМетаданныеРодитель  = Неопределено)

	Для Каждого РеквизитШапки Из яМетаданныеТаблицы.СтандартныеРеквизиты Цикл			
		ТаблицаПерехвата.Колонки.Добавить(РеквизитШапки.Имя,РеквизитШапки.Тип);
		мМассивПолей.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонВыбораПоля,ПсевдонимТаблицы,РеквизитШапки.Имя));
	КонецЦикла;
	
	Для Каждого РеквизитШапки Из яМетаданныеТаблицы.Реквизиты Цикл
		ТаблицаПерехвата.Колонки.Добавить(РеквизитШапки.Имя,РеквизитШапки.Тип);			
		мМассивПолей.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонВыбораПоля,ПсевдонимТаблицы,РеквизитШапки.Имя));
	КонецЦикла;

	Если НЕ яМетаданныеРодитель = Неопределено Тогда
		ТаблицаПерехвата.Колонки.Добавить(яМетаданныеРодитель.СтандартныеРеквизиты.Ссылка.Имя,яМетаданныеРодитель.СтандартныеРеквизиты.Ссылка.Тип);			
		мМассивПолей.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонВыбораПоля,ПсевдонимТаблицы,яМетаданныеРодитель.СтандартныеРеквизиты.Ссылка.Имя));
	КонецЕсли;  	
	
КонецПроцедуры

Процедура ЗаполнитьТаблицуПерехавата(Источник, Приемник)
	
	Если ТипЗнч(Источник) = Тип("Массив") Тогда
		Для Сч = 0 По Источник.ВГраница() Цикл
			ЗаполнитьЗначенияСвойств(Приемник.Добавить(),  Источник[Сч]);
		КонецЦикла;		
	ИначеЕсли ТипЗнч(Источник) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(Приемник.Добавить(),  Источник[Сч]);
	Иначе
		ВызватьИсключение "ЗаполнитьТаблицуПерехавата Не известный тип источника";
	КонецЕсли;
	
	
КонецПроцедуры

#КонецОбласти

Функция КлючиТаблицДвижений(Схема) Экспорт 
	
	КлючиТаблицДвижений  				= Новый Структура;
	Для Сч = 0 По Схема.ПакетЗапросов.Количество() - 1  Цикл
		Пакет 							= Схема.ПакетЗапросов[Сч];		
		Если Не ПустаяСтрока(Пакет.ТаблицаДляПомещения) И СтрНачинаетсяС(Пакет.ТаблицаДляПомещения, "Набор") Тогда			
			КлючиТаблицДвижений.Вставить(Прав(Пакет.ТаблицаДляПомещения,СтрДлина(Пакет.ТаблицаДляПомещения) - СтрДлина("Набор")),Сч);			
			Пакет.ТаблицаДляПомещения 	= "";
		КонецЕсли;		
	КонецЦикла;
	
	Возврат КлючиТаблицДвижений;
	
КонецФункции

#КонецОбласти







