#Область УстановкаОтборов

Процедура УстановитьОтборОператора(ОтборСхемыЗапроса, ПараметрОтбор, стДоступныеПоляОтбора)
	
	Если ПараметрОтбор.ТипПараметра = "ТипПараметраВременнаяТаблица" Тогда
		Шаблон 						= "(%1) В (ВЫБРАТЬ %2 ИЗ %3 КАК %3)";
		ПоляТаблицы 				= "";
		ПоляВременнойТаблицы 		= "";
		ИмяТаблицы 					= ИмяТаблицы;
		ШаблонПоля 					= "%1.%2";
		ТаблицаИсточник 			= ПараметрОтбор.ТаблицаИсточник;
		Для Каждого КлючЗначение Из ПараметрОтбор.СоотвествиеПолей Цикл				
			ЕстьПолеОтбора 			= Ложь;
			Для Каждого КлючЗначениеИмяТаблицы Из стДоступныеПоляОтбора Цикл
				Если НЕ КлючЗначениеИмяТаблицы.Значение.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
					ЕстьПолеОтбора 	= Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;				
			
			Если НЕ ЕстьПолеОтбора Тогда
				Продолжить;
			КонецЕсли;
			
			ПоляТаблицы 			= ПоляТаблицы + ?(НЕ ПустаяСтрока(ПоляТаблицы),",","") +  СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,КлючЗначениеИмяТаблицы.Ключ,КлючЗначение.Ключ);
			ПоляВременнойТаблицы	= ПоляВременнойТаблицы + ?(НЕ ПустаяСтрока(ПоляВременнойТаблицы),",","") + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,ТаблицаИсточник,КлючЗначение.Значение)
		КонецЦикла;
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
		
		ОтборСхемыЗапроса.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон,ПоляТаблицы,ПоляВременнойТаблицы,ТаблицаИсточник));
		
	ИначеЕсли ПараметрОтбор.ТипПараметра = "ТипПараметраРавно" Тогда
		ПоляТаблицы 				= "";
		ШаблонПоля 					= "%1.%2 =&%3";           
		
		Для Каждого КлючЗначение Из ПараметрОтбор.СоотвествиеПолей Цикл				
			ЕстьПолеОтбора 			= Ложь;
			Для Каждого КлючЗначениеИмяТаблицы Из стДоступныеПоляОтбора Цикл
				Если НЕ КлючЗначениеИмяТаблицы.Значение.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
					ЕстьПолеОтбора 	= Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;				
			
			Если НЕ ЕстьПолеОтбора Тогда
				Продолжить;
			КонецЕсли;
			
			ПоляТаблицы 			= ПоляТаблицы + ?(НЕ ПустаяСтрока(ПоляТаблицы),Символы.ПС + "И ","") + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,КлючЗначениеИмяТаблицы.Ключ,КлючЗначение.Ключ,КлючЗначение.Значение);			
		КонецЦикла;
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
		
		ОтборСхемыЗапроса.Добавить(ПоляТаблицы);
		
	ИначеЕсли ПараметрОтбор.ТипПараметра = "ТипПараметраМеньше" Тогда
		ПоляТаблицы 				= "";
		ШаблонПоля 					= "%1.%2 <&%3";           
		
		Для Каждого КлючЗначение Из ПараметрОтбор.СоотвествиеПолей Цикл				
			ЕстьПолеОтбора 			= Ложь;
