	ИначеЕсли ПараметрОтбор.ТипПараметра = "ТипПараметраБольше" Тогда
		
		ПоляТаблицы = "";
		ШаблонПоля 	= "%1.%2 > %3";           
		
		ДобавитьУсловие(ПоляТаблицы, ШаблонПоля, стДоступныеПоляОтбора, ПараметрОтбор);
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
		
		ОтборСхемыЗапроса.Добавить(ПоляТаблицы);
		
	ИначеЕсли ПараметрОтбор.ТипПараметра = "ТипПараметраБольшеРавно" Тогда
		
		ПоляТаблицы = "";
		ШаблонПоля 	= "%1.%2 >= %3";           
		
		ДобавитьУсловие(ПоляТаблицы, ШаблонПоля, стДоступныеПоляОтбора, ПараметрОтбор);
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
		
		ОтборСхемыЗапроса.Добавить(ПоляТаблицы);	
		
	ИначеЕсли ПараметрОтбор.ТипПараметра = "ТипПараметраПодобно" Тогда
		ПоляТаблицы 				= "";
		ШаблонПоля 					= "%1.Наименование ПОДОБНО ""%2%""";           
		Для Каждого КлючЗначение Из ПараметрОтбор.СоотвествиеПолей Цикл				
			ЕстьПолеОтбора 			= Ложь;
			Для Каждого КлючЗначениеИмяТаблицы Из стДоступныеПоляОтбора Цикл
				Если НЕ КлючЗначениеИмяТаблицы.Значение.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
					ЕстьПолеОтбора 	= Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;				
			
			Если НЕ ЕстьПолеОтбора Тогда
				Продолжить;
			КонецЕсли;			
			
			ПоляТаблицы 			= ПоляТаблицы + ?(НЕ ПустаяСтрока(ПоляТаблицы),Символы.ПС + "И ","") +  СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПоля,КлючЗначениеИмяТаблицы.Ключ,КлючЗначение.Значение);			
		КонецЦикла;
		
		Если ПустаяСтрока(ПоляТаблицы) Тогда
			Возврат;
		КонецЕсли;
		
		ОтборСхемыЗапроса.Добавить(ПоляТаблицы);   		 			
		
	ИначеЕсли ПараметрОтбор.ТипПараметра = "ТипПараметраВСписке" Тогда
		ПоляТаблицы 				= "";
		ШаблонПоля 					= "%1.%2 В (&%3)";           
		
		Для Каждого КлючЗначение Из ПараметрОтбор.СоотвествиеПолей Цикл				
			ЕстьПолеОтбора 			= Ложь;
			Для Каждого КлючЗначениеИмяТаблицы Из стДоступныеПоляОтбора Цикл
				Если НЕ КлючЗначениеИмяТаблицы.Значение.Найти(ВРег(КлючЗначение.Ключ)) = Неопределено Тогда
					ЕстьПолеОтбора 	= Истина;
					Прервать;
				КонецЕсли;
