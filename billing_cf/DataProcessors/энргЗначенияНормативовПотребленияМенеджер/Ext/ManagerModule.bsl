#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Получает услуги благоустройства.
//
// Параметры:
//  СвойстваОтбора	-	Структура.
// 
// Возвращаемое значение:
//   Массив из СправочникСсылка.энргВидыБлагоустройств.
//
Функция БлагоустройстваУслуги(СвойстваОтбора) Экспорт 
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		Если слжОбщегоНазначенияМодуль.ВоспроизводитьРезультатМетодов() Тогда; 
			Если НЕ Метаданные.Обработки.Найти("слжЗначенияНормативовПотребленияМенеджер") = Неопределено Тогда
				Возврат Обработки["слжЗначенияНормативовПотребленияМенеджер"].БлагоустройстваУслуги(СвойстваОтбора);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Схема  							= Неопределено;
	
	ПараметрыЗапроса 				= Новый Структура;	
	СоотвествиеПолей 				= Новый Структура;
	
	Если СвойстваОтбора.Свойство("Организация") Тогда
		СоотвествиеПолей.Вставить("Организация", "Организация");
		ПараметрыЗапроса.Вставить("Организация", СвойстваОтбора.Организация);
	КонецЕсли;
	
	Если СвойстваОтбора.Свойство("Район") Тогда
		СоотвествиеПолей.Вставить("Район", "Район");
		ПараметрыЗапроса.Вставить("Район", СвойстваОтбора.Район);
	КонецЕсли;
	
	Если СвойстваОтбора.Свойство("ТипНачисления") Тогда
		СоотвествиеПолей.Вставить("ТипНачисления", "ТипНачисления");
		ПараметрыЗапроса.Вставить("ТипНачисления", СвойстваОтбора.ТипНачисления);
	КонецЕсли;
	
	Если СвойстваОтбора.Свойство("НаправлениеИспользованияТУ") Тогда
		СоотвествиеПолей.Вставить("НаправлениеИспользованияТУ", "НаправлениеИспользованияТУ");
		ПараметрыЗапроса.Вставить("НаправлениеИспользованияТУ", СвойстваОтбора.НаправлениеИспользованияТУ);
	КонецЕсли;
	
	Если СвойстваОтбора.Свойство("КлючНорматива")  Тогда
		СоотвествиеПолей.Вставить("КлючНорматива", "КлючНорматива");
		ПараметрыЗапроса.Вставить("КлючНорматива", СвойстваОтбора.КлючНорматива);
	КонецЕсли;
	
	Если СвойстваОтбора.Свойство("Услуга") Тогда
		СоотвествиеПолей.Вставить("Услуга", "Услуга");
		ПараметрыЗапроса.Вставить("Услуга", СвойстваОтбора.Услуга);
	КонецЕсли;

	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(СоотвествиеПолей));
	ПараметрыСхемы 					= Новый Структура("ПараметрыВТ", ПараметрыВТ);
	Если СвойстваОтбора.Свойство("Период") Тогда
		ПараметрыСхемы.Вставить("Период",энргФормированиеТекстовЗапроса.ПараметрПериодРавно("Период"));
		ПараметрыЗапроса.Вставить("КлючНорматива", СвойстваОтбора.Период);
	КонецЕсли;
	
	РегистрыСведений.энргЗначенияНормативовПотребления.ЗаполнитьСхемуБлагоустройстваУслуги(Схема,ПараметрыСхемы,"");
	  	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	Результат 						= РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ВидБлагоустройства");	
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "слжЗначенияНормативовПотребленияМенеджер.БлагоустройстваУслуги";
		ПараметрыМетода 			= Новый Структура("СвойстваОтбора", СвойстваОтбора);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, Результат, ПараметрыМетода);
	КонецЕсли;
	
	Возврат Результат;  
		
КонецФункции

#КонецОбласти

#КонецЕсли