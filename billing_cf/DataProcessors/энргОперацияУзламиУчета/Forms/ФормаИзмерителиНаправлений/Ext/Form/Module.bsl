
#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗаполнитьВходнымиДанными(); 	
КонецПроцедуры 

#Конецобласти

#Область КомандыФормы

&НаКлиенте
Процедура Завершить(Команда)	
	Закрыть(ПолучитьРезультат());
КонецПроцедуры

&НаСервере
Функция ПолучитьРезультат()
	КлючиДанных 		= ПолучитьКлючиЗаполнения();
	Результат 			= Новый Структура(КлючиДанных.Реквизиты + ", " + КлючиДанных.Таблицы);
	
	ЗаполнитьЗначенияСвойств(Результат, ЭтаФорма, КлючиДанных.Реквизиты);
	ИдентификаторФормы 				= ЭтаФорма.УникальныйИдентификатор;	
	Результат.ЗначенияИзмерителей 	= ПоместитьВоВременноеХранилище(ЗначенияИзмерителей.Выгрузить(), ИдентификаторФормы);
	//Результат.ЗначенияИзмерителей 	= ОбщегоНазначения.ТаблицаЗначенийВМассив(ЗначенияИзмерителей.Выгрузить());
	
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область СобытияРеквизитовШапки

&НаКлиенте
Процедура НаправлениеИспользованияПриИзменении(Элемент)
	ОбновитьТЧЗначенияИзмерителей();
КонецПроцедуры

&НаКлиенте
Процедура НаправлениеИспользованияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка 	= Ложь;
	ПараметрыФормы 			= Новый Структура("Отбор", Новый Структура("Родитель", ПредопределенноеЗначение("Справочник.энргНаправлениеИспользованияТочекУчета.ПустаяСсылка")));
	ОткрытьФорму("Справочник.энргНаправлениеИспользованияТочекУчета.ФормаВыбора", ПараметрыФормы, Элемент);
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьВходнымиДанными()
	ВходныеПараметры = Параметры.ВходныеПараметры;
	
	НаправлениеИспользованияТУ = ВходныеПараметры.НаправлениеИспользованияТУ;
	ЗначенияИзмерителейВходная = ПолучитьИзВременногоХранилища(ВходныеПараметры.ЗначенияИзмерителей);
	ЗначенияИзмерителей.Загрузить(ЗначенияИзмерителейВходная);
	
	//ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.ЗначенияИзмерителей, ЗначенияИзмерителей); 
КонецПроцедуры

&НаСервере
Процедура ОбновитьТЧЗначенияИзмерителей()
	ЗначенияИзмерителей.Очистить();
	МенеджерНаправлений = Справочники.энргНаправлениеИспользованияТочекУчета;
	
	Если НаправлениеИспользованияТУ = МенеджерНаправлений.ОсновноеНаправление или не ЗначениеЗаполнено(НаправлениеИспользованияТУ) Тогда
		Возврат;
	КонецЕсли;	
	
	РезультатЗапроса 	= МенеджерНаправлений.ВернутьПодчиненныеЭлементы(НаправлениеИспользованияТУ);
	Выборка 			= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл		
		НоваяСтрока 							= ЗначенияИзмерителей.Добавить();
		НоваяСтрока.НаправлениеИспользованияТУ 	= Выборка.НаправлениеИспользованияТУ; 		
	КонецЦикла;
	            	
КонецПроцедуры

&НаСервере
Функция ПолучитьКлючиЗаполнения()
	Возврат Обработки.энргОперацияУзламиУчета.ПолучитьКлючиЗаполненияИзмерителиНаправлений();
КонецФункции

#КонецОбласти