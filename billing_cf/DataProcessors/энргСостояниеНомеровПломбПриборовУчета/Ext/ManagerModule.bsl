		ПараметрыЗапроса.Вставить("ПриборУчета", ПриборыУчета);
	ИначеЕсли НЕ ПриборыУчета = Неопределено и ТипЗнч(ПриборыУчета) = Тип("СправочникСсылка.энргПриборыУчетаАбонента") Тогда		
		ЕстьОтборПоПриборам = Истина;
		ПараметрыЗапроса.Вставить("ПриборУчета", ПриборыУчета);
