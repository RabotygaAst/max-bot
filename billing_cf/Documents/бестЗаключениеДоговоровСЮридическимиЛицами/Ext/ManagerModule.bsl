Процедура ДобавитьТекстЗапросабестФормулыРасчетаТочекУчетаНП(Схема, ИмяРегистра)
		
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	РеквизитыДокумента.Дата КАК Период,
	|	РеквизитыДокумента.Организация КАК Организация,
	|	РеквизитыДокумента.Район КАК Район,
	|	ТаблицаТочекУчета.ТочкаУчета КАК ГоловнаяТочкаУчета,
	|	ТаблицаОбъектовРасчета.ОбъектРасчета КАК ОбъектРасчета,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиСубабоненты.Услуга КАК УслугаСубабонента,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиСубабоненты.ОбъектРасчета КАК ОбъектРасчетаСубабонента,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиСубабоненты.ТочкаУчета КАК ТочкаУчетаСубабонента,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиСубабоненты.Услуга КАК Услуга,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиСубабоненты.СторнироватьОбъемИндивидуальногоПотребления КАК СторнироватьОбъемИндивидуальногоПотребления,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиСубабоненты.Абонент КАК АбонентСубабонента,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиСубабоненты.Коэффициент КАК Коэффициент,
	|	НЕ ИдентификаторыТУСоСхемойПоРазнымРайонам.IDСтроки ЕСТЬ NULL КАК ТранзитИзРазныхРО,
	|	ИСТИНА КАК Актуальность
	|ИЗ
	|	РеквизитыДокумента КАК РеквизитыДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаОбъектовРасчета КАК ТаблицаОбъектовРасчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК ТаблицаТочекУчета
	|				ЛЕВОЕ СОЕДИНЕНИЕ ИдентификаторыТУСоСхемойПоРазнымРайонам КАК ИдентификаторыТУСоСхемойПоРазнымРайонам
	|				ПО ТаблицаТочекУчета.IDСтроки = ИдентификаторыТУСоСхемойПоРазнымРайонам.IDСтроки
