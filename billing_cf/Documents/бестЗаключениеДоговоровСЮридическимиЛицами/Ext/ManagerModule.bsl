		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	бестЗаключениеДоговоровСЮридическимиЛицамиСубабоненты.IDСтроки КАК IDСтроки
	|ПОМЕСТИТЬ ИдентификаторыТУСоСхемойПоРазнымРайонам
	|ИЗ
	|	Документ.бестЗаключениеДоговоровСЮридическимиЛицами.Субабоненты КАК бестЗаключениеДоговоровСЮридическимиЛицамиСубабоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестАктивностьТочекУчетаНП КАК бестАктивностьТочекУчетаНП
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РеквизитыДокумента КАК РеквизитыДокумента
