	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	РеквизитыДокумента.Дата КАК Период,
	|	РеквизитыДокумента.Организация КАК Организация,
	|	РеквизитыДокумента.Район КАК Район,
	|	ТаблицаОбъектовРасчета.ОбъектРасчета КАК ОбъектРасчета,
	|	ТаблицаОбъектовРасчета.Собственник КАК Собственник
	|ИЗ
	|	РеквизитыДокумента КАК РеквизитыДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаОбъектовРасчета КАК ТаблицаОбъектовРасчета
	|		ПО РеквизитыДокумента.Ссылка = ТаблицаОбъектовРасчета.Ссылка";		
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросабестДоговорыТочекУчета(Схема, ИмяРегистра)
		
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Период КАК Период,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ОбъектРасчета КАК ОбъектРасчета,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВЫБОР
	|		КОГДА бестЗаключениеДоговоровСЮридическимиЛицамиДоговорыСоставныхУслуг.Ссылка ЕСТЬ NULL
	|			ТОГДА ВложенныйЗапрос.Договор
	|		ИНАЧЕ ЕСТЬNULL(бестЗаключениеДоговоровСЮридическимиЛицамиДоговорыСоставныхУслуг.Договор, Значение(Справочник.энргДоговорыКонтрагентов.ПустаяСсылка))
	|	КОНЕЦ КАК Договор
	|ИЗ
	|	(ВЫБРАТЬ
	|		РеквизитыДокумента.Дата КАК Период,
	|		РеквизитыДокумента.Организация КАК Организация,
	|		РеквизитыДокумента.Район КАК Район,
	|		ВЫБОР
	|			КОГДА энргДоговорыКонтрагентов.ОснованиеДопСоглашения = ЗНАЧЕНИЕ(Справочник.энргДоговорыКонтрагентов.пустаяссылка)
	|				ТОГДА ТаблицаТочекУчета.Договор
	|			ИНАЧЕ энргДоговорыКонтрагентов.ОснованиеДопСоглашения
	|		КОНЕЦ КАК Договор,
	|		ТаблицаТочекУчета.ТочкаУчета КАК ТочкаУчета,
	|		ТаблицаОбъектовРасчета.ОбъектРасчета КАК ОбъектРасчета,
	|		ВЫБОР
	|			КОГДА ТаблицаТочекУчета.Услуга.СоставнаяУслуга
	|				ТОГДА ЕСТЬNULL(энргВидыУслугСоставляющиеУслуг.Услуга, Значение(Справочник.энргВидыУслуг.ПустаяСсылка))
	|			ИНАЧЕ ТаблицаТочекУчета.Услуга
	|		КОНЕЦ КАК Услуга,
	|		ТаблицаТочекУчета.IDСтроки КАК IDСтроки,
	|		РеквизитыДокумента.Ссылка КАК Ссылка
	|	ИЗ
	|		РеквизитыДокумента КАК РеквизитыДокумента
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК ТаблицаТочекУчета
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|				ПО ТаблицаТочекУчета.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
	|					И (ТаблицаТочекУчета.Услуга.СоставнаяУслуга)
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|				ПО ТаблицаТочекУчета.Договор = энргДоговорыКонтрагентов.Ссылка
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаОбъектовРасчета КАК ТаблицаОбъектовРасчета
	|				ПО (ТаблицаОбъектовРасчета.Ссылка = ТаблицаТочекУчета.Ссылка)
	|					И (ТаблицаОбъектовРасчета.IDСтроки = ТаблицаТочекУчета.IDСтрокиВладельца)
	|			ПО РеквизитыДокумента.Ссылка = ТаблицаТочекУчета.Ссылка) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ДоговорыСоставныхУслуг КАК бестЗаключениеДоговоровСЮридическимиЛицамиДоговорыСоставныхУслуг
	|		ПО ВложенныйЗапрос.Услуга = бестЗаключениеДоговоровСЮридическимиЛицамиДоговорыСоставныхУслуг.ЧастьСоставнойУслуги
	|			И ВложенныйЗапрос.IDСтроки = бестЗаключениеДоговоровСЮридическимиЛицамиДоговорыСоставныхУслуг.IDСтроки
	|			И ВложенныйЗапрос.Ссылка = бестЗаключениеДоговоровСЮридическимиЛицамиДоговорыСоставныхУслуг.Ссылка";		
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросабестПрочиеДополнительныеНачисления(Схема, ИмяРегистра)
		
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	РеквизитыДокумента.Дата КАК Период,
	|	РеквизитыДокумента.Организация КАК Организация,
	|	РеквизитыДокумента.Район КАК Район,
	|	ТаблицаТочекУчета.ТочкаУчета КАК ТочкаУчета,
	|	ТаблицаОбъектовРасчета.ОбъектРасчета КАК ОбъектРасчета,
	|	ТаблицаОбъектовРасчета.МКД КАК МКД,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияТУ.ТипДополнительногоНачисления КАК ТипДополнительногоНачисления,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияТУ.Услуга КАК Услуга,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияТУ.ТарифнаяКатегория КАК ТарифнаяКатегория,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияЗначения.Сезонность КАК Сезонность,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияЗначения.Процент КАК Процент
	|ИЗ
	|	РеквизитыДокумента КАК РеквизитыДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаОбъектовРасчета КАК ТаблицаОбъектовРасчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК ТаблицаТочекУчета
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ДополнительныеНачисленияТУ КАК бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияТУ
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ДополнительныеНачисленияЗначения КАК бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияЗначения
	|					ПО бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияТУ.Ссылка = бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияЗначения.Ссылка
	|						И бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияТУ.IDСтроки = бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияЗначения.IDСтроки
	|				ПО ТаблицаТочекУчета.Ссылка = бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияТУ.Ссылка
	|					И ТаблицаТочекУчета.IDСтроки = бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияТУ.IDСтрокиТУ
	|					И ТаблицаТочекУчета.IDСтрокиВладельца = бестЗаключениеДоговоровСЮридическимиЛицамиДополнительныеНачисленияТУ.IDСтрокиВладельца
	|			ПО ТаблицаОбъектовРасчета.Ссылка = ТаблицаТочекУчета.Ссылка
	|				И ТаблицаОбъектовРасчета.IDСтроки = ТаблицаТочекУчета.IDСтрокиВладельца
	|		ПО РеквизитыДокумента.Ссылка = ТаблицаОбъектовРасчета.Ссылка";		
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

