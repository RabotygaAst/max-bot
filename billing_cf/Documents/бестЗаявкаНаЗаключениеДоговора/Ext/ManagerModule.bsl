#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)

	ЕстьЗначенияЗаполнения  	= Параметры.свойство("ЗначенияЗаполнения");
	
	ВидОперацииВыбран  			= Ложь;
	
	Если ЕстьЗначенияЗАполнения тогда
		 ВидОперацииВыбран 		= Параметры.ЗначенияЗаполнения.свойство("видоперации");
	КонецЕсли;
	
	МетаданныеСущности			= Метаданные.Документы.бестЗаявкаНаЗаключениеДоговора;
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка 	= Ложь;
		Основание				= Неопределено;
		
		Если Параметры.свойство("Ключ") тогда
			ВидОперации 		= Параметры.ключ.видоперации;
			ПрефиксФормы  		= бестРаботаСВидамиОперацийСервер.ПрефиксФормы(МетаданныеСущности.Имя,ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		ИначеЕсли  Параметры.свойство("ЗначениеКопирования") тогда
			ВидОперации 		= Параметры.ЗначениеКопирования.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы(МетаданныеСущности.Имя,ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы; 			
		ИначеЕсли  ЕстьЗначенияЗАполнения и ВидОперацииВыбран тогда
			ВидОперации 		= Параметры.ЗначенияЗаполнения.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы(МетаданныеСущности.Имя,ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;			
		ИначеЕсли  Параметры.свойство("Основание", Основание) И ТипЗнч(Основание) = Тип("СправочникСсылка.энргДоговорыКонтрагентов") Тогда
			ВидОперации 		= Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_ЗаключениеДоговора;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы(МетаданныеСущности.Имя,ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		иначе
			ВыбраннаяФорма 		= "ОбщаяФорма.бестФормаВыбораОперации";
			Параметры.вставить("ИмяДокумента",МетаданныеСущности.Имя);
			Параметры.вставить("ВыборОперации",Истина);
		КонецЕсли; 		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли

#Область ПрограммныйИнтерфейс

Функция ЗаполнитьСписокВозможныхОперацийФормаСписка() Экспорт
	
	ЗначениеПеречисления  	= Метаданные.Перечисления.бестВидыОпераций.ЗначенияПеречисления;
	СписокОпераций 			= Новый СписокЗначений;
	СписокОпераций.Добавить(Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_ЗаключениеДоговора, 					ЗначениеПеречисления.ЗаявкаНаЗаключениеДоговора_ЗаключениеДоговора.Синоним);
	СписокОпераций.Добавить(Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_ЗаключениеДополнительногоСоглашения, 	ЗначениеПеречисления.ЗаявкаНаЗаключениеДоговора_ЗаключениеДополнительногоСоглашения.Синоним);
	СписокОпераций.Добавить(Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_РасторжениеДоговора, 					ЗначениеПеречисления.ЗаявкаНаЗаключениеДоговора_РасторжениеДоговора.Синоним);
	
	Возврат СписокОпераций;
	
КонецФункции

Функция ПрефиксФормы() Экспорт
	
	ПрефиксыФорм 			= Новый Соответствие;
	ПрефиксыФорм.Вставить(Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_ЗаключениеДоговора, 						"ЗаключениеДоговора");
	ПрефиксыФорм.Вставить(Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_ЗаключениеДополнительногоСоглашения, 	"ЗаключениеДополнительногоСоглашения");
	ПрефиксыФорм.Вставить(Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_РасторжениеДоговора, 					"РасторжениеДоговора");
	
	Возврат ПрефиксыФорм;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ВидыОпераций() Экспорт
	
	ВидыОпераций = Новый Массив;
	ВидыОпераций.Добавить(Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_ЗаключениеДоговора);
	ВидыОпераций.Добавить(Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_ЗаключениеДополнительногоСоглашения);
	ВидыОпераций.Добавить(Перечисления.бестВидыОпераций.ЗаявкаНаЗаключениеДоговора_РасторжениеДоговора);
	
	Возврат ВидыОпераций;	
КонецФункции

#КонецОбласти