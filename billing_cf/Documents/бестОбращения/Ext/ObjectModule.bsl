	Движения.бестЭтапыОбращений.Записывать 		= Истина;
	Движения.бестЭтапыОбращенийЮрЛиц.Записывать = Истина;
	
	Если ВидОперации = Перечисления.бестВидыОпераций.бестОбращения_ОбращениеФизическогоЛица Тогда
