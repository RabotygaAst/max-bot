#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗаполнитьПлановуюДатуОкончанияЭтапа() Экспорт 
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", 			Дата);
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Этап", 			ЭтапОбращения);
	ЗАпрос.Текст = "ВЫБРАТЬ
	|	бестСрокиЭтаповОбращенийСрезПоследних.Срок КАК Срок
	|ИЗ
	|	РегистрСведений.бестСрокиЭтаповОбращений.СрезПоследних(
	|			&Дата,
	|			Организация = &Организация
	|				И Этап = &Этап) КАК бестСрокиЭтаповОбращенийСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	бестСрокиЭтаповОбращенийСрезПоследних.Срок";
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Срок = 0;
	Если Выборка.Следующий() Тогда
		Срок = Выборка.Срок;
	КонецЕсли;
	
	ПлановаяДатаОкончанияЭтапа	= КонецДня(Дата + 86400*Срок);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СледующийЭтапОбращения(ПредыдущийЭтап)
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ПредыдущийЭтап",ПредыдущийЭтап);
	Запрос.Текст 	="ВЫБРАТЬ
	|	бестЭтапыОбращений.Ссылка КАК Этап
	|ИЗ
	|	(ВЫБРАТЬ
	|		МИНИМУМ(бестЭтапыОбращений.Порядок) КАК Порядок
	|	ИЗ
	|		Справочник.бестЭтапыОбращений КАК бестЭтапыОбращений
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				бестЭтапыОбращений.Порядок КАК Порядок
	|			ИЗ
	|				Справочник.бестЭтапыОбращений КАК бестЭтапыОбращений
	|			ГДЕ
	|				бестЭтапыОбращений.Ссылка = &ПредыдущийЭтап) КАК ВложенныйЗапрос
	|			ПО (ВложенныйЗапрос.Порядок < бестЭтапыОбращений.Порядок)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестЭтапыОбращений КАК бестЭтапыОбращений
	|		ПО ВложенныйЗапрос.Порядок = бестЭтапыОбращений.Порядок";
	результат  = Запрос.Выполнить();
	Если результат.Пустой() тогда
		Возврат Справочники.бестЭтапыОбращений.ПустаяСсылка();
	иначе
		Выборка = результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Этап;
	КонецЕсли; 
КонецФункции 

Процедура ПроведениеОбращенияФизЛица()
	Таблица	= ПолучитьТаблицуПроведенияФизЛиц(Ссылка);
	Пока Таблица.Следующий() Цикл
		Движение 						= Движения.бестЭтапыОбращений.Добавить();
		ЗаполнитьЗначенияСвойств(Движение, Таблица);
	КонецЦикла;	
КонецПроцедуры

Процедура ПроведениеОбращенияЮрЛица()
	Таблица	= ПолучитьТаблицуПроведенияЮрЛиц(Ссылка);
	Пока Таблица.Следующий() Цикл
		Движение 						= Движения.бестЭтапыОбращенийЮрЛиц.Добавить();
		ЗаполнитьЗначенияСвойств(Движение, Таблица);
	КонецЦикла;	
КонецПроцедуры

Функция ПолучитьТаблицуПроведенияФизЛиц(ТекДок)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ТекДок);
	Запрос.Текст = "ВЫБРАТЬ
	               |	бестОбращения.Ссылка КАК Ссылка,
	               |	бестОбращения.Дата КАК Период,
	               |	бестОбращения.Абонент КАК Абонент,
	               |	бестОбращения.Организация КАК Организация,
	               |	ВЫБОР
	               |		КОГДА бестОбращения.Основание = ЗНАЧЕНИЕ(Документ.бестОбращения.ПустаяСсылка)
	               |			ТОГДА бестОбращения.Ссылка
	               |		ИНАЧЕ бестОбращения.Основание
	               |	КОНЕЦ КАК Обращение,
	               |	бестОбращения.ЭтапОбращения КАК Этап,
	               |	бестОбращения.ПлановаяДатаОкончанияЭтапа КАК СрокОкончанияЭтапа
	               |ИЗ
	               |	Документ.бестОбращения КАК бестОбращения
	               |ГДЕ
	               |	бестОбращения.Ссылка = &Ссылка
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	бестОбращения.Ссылка,
	               |	бестОбращения.Дата,
	               |	бестОбращения.Абонент,
	               |	бестОбращения.Организация,
	               |	бестОбращения.ЭтапОбращения,
	               |	бестОбращения.ПлановаяДатаОкончанияЭтапа,
	               |	ВЫБОР
	               |		КОГДА бестОбращения.Основание = ЗНАЧЕНИЕ(Документ.бестОбращения.ПустаяСсылка)
	               |			ТОГДА бестОбращения.Ссылка
	               |		ИНАЧЕ бестОбращения.Основание
	               |	КОНЕЦ";
	Результат = Запрос.Выполнить();
	Выборка	= Результат.Выбрать();
	
	Возврат Выборка;
КонецФункции

Функция ПолучитьТаблицуПроведенияЮрЛиц(ТекДок)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ТекДок);
	Запрос.Текст = "ВЫБРАТЬ
	               |	бестОбращения.Ссылка КАК Ссылка,
	               |	бестОбращения.Дата КАК Период,
	               |	бестОбращения.Организация КАК Организация,
	               |	ВЫБОР
	               |		КОГДА бестОбращения.Основание = ЗНАЧЕНИЕ(Документ.бестОбращения.ПустаяСсылка)
	               |			ТОГДА бестОбращения.Ссылка
	               |		ИНАЧЕ бестОбращения.Основание
	               |	КОНЕЦ КАК Обращение,
	               |	бестОбращения.ЭтапОбращения КАК Этап,
	               |	бестОбращения.ПлановаяДатаОкончанияЭтапа КАК СрокОкончанияЭтапа,
	               |	бестОбращения.Контрагент КАК Контрагент,
	               |	бестОбращения.Договор КАК Договор
	               |ИЗ
	               |	Документ.бестОбращения КАК бестОбращения
				   // ОТЭК, 20.05.2020, 000353559, Комментарий т.к. данные не выбираются во временную таблицу и не используются в запросе.
				   //|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НачальныйЭтап КАК ВТ_НачальныйЭтап
				   //|		ПО бестОбращения.ЭтапОбращения = ВТ_НачальныйЭтап.НачальныйЭтап
	               |ГДЕ
	               |	бестОбращения.Ссылка = &Ссылка
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	бестОбращения.Ссылка,
	               |	бестОбращения.Дата,
	               |	бестОбращения.Организация,
	               |	бестОбращения.ЭтапОбращения,
	               |	бестОбращения.ПлановаяДатаОкончанияЭтапа,
	               |	бестОбращения.Контрагент,
	               |	бестОбращения.Договор,
	               |	ВЫБОР
	               |		КОГДА бестОбращения.Основание = ЗНАЧЕНИЕ(Документ.бестОбращения.ПустаяСсылка)
	               |			ТОГДА бестОбращения.Ссылка
	               |		ИНАЧЕ бестОбращения.Основание
	               |	КОНЕЦ";
	Результат = Запрос.Выполнить();
	Выборка	= Результат.Выбрать();
	
	Возврат Выборка;
КонецФункции

