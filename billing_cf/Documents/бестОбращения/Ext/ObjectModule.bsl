Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	// ОТЭК, 20.05.2020, 000353559.
	Если ВидОперации = ПредопределенноеЗначение("Перечисление.бестВидыОпераций.бестОбращения_ОбращениеФизическогоЛица") Тогда
		ПроверяемыеРеквизиты.Добавить("Абонент");
	ИначеЕсли ВидОперации = ПредопределенноеЗначение("Перечисление.бестВидыОпераций.бестОбращения_ОбращениеЮридическогоЛица") Тогда
		ПроверяемыеРеквизиты.Добавить("Контрагент");
	КонецЕсли;
