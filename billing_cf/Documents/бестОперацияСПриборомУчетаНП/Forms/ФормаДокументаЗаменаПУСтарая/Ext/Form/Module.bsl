			энргРаботаСПериодомДействияКлиент.ОткрытьФормуДокументаУстановкаФормулыРасчета(ДанныеДляФормулы);
		иначе
			ДанныеДляФормулы = Неопределено;
		КонецЕсли; 		
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Функция ПроверитьТочкиУчетаВРСРасчетныеФормулы()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	энргТочкиУчета.Ссылка КАК ТочкаУчета
	|ПОМЕСТИТЬ ВрТ
	|ИЗ
	|	Справочник.энргТочкиУчета КАК энргТочкиУчета
	|ГДЕ
	|	энргТочкиУчета.Ссылка В(&ТочкиУчета)
	|
	|СГРУППИРОВАТЬ ПО
	|	энргТочкиУчета.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВрТ.ТочкаУчета КАК ТочкаУчета,
	|	ЕСТЬNULL(энргФормулыРасчетаТочекУчетаСрезПоследних.РассчитываемаяТочка, ЛОЖЬ) КАК Рассчитываемая
	|ИЗ
	|	ВрТ КАК ВрТ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргФормулыРасчетаТочекУчета.СрезПоследних(&Дата, ) КАК энргФормулыРасчетаТочекУчетаСрезПоследних
	|		ПО ВрТ.ТочкаУчета = энргФормулыРасчетаТочекУчетаСрезПоследних.РассчитываемаяТочка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВрТ.ТочкаУчета,
	|	ЕСТЬNULL(энргФормулыРасчетаТочекУчетаСрезПоследних.ТочкаИсточник, ЛОЖЬ)
	|ИЗ
	|	ВрТ КАК ВрТ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргФормулыРасчетаТочекУчета.СрезПоследних(&Дата, ) КАК энргФормулыРасчетаТочекУчетаСрезПоследних
	|		ПО ВрТ.ТочкаУчета = энргФормулыРасчетаТочекУчетаСрезПоследних.ТочкаИсточник";
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия), Объект.ДатаФактическогоСобытия,Объект.Дата));
	Запрос.УстановитьПараметр("ТочкиУчета", Объект.ТочкиУчета.Выгрузить().ВыгрузитьКолонку("ТочкаУчета"));
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Истина;
	Иначе 
		Возврат ложь;
	КонецЕсли;
КонецФункции

#Область ВыборТипаПУ

&НаКлиенте
Процедура ОткрытьВыборТипаПУ(СтандартнаяОбработка)
	
	ИмяТаблицыТочек 	= "ТочкиУчета" + ПрефиксТочекУчета;	
	ТекущиеДанные 		= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	Соответсвие = новый Соответствие;
	Соответсвие.Вставить("ТипУзлаУчета","ТипУзлаУчета");
	энргОбщегоНазначения.ПолучитьЗначенияРеквизитов(,ТекущиеДанные.УзелУчета,Соответсвие);
	
	ТипУзлаУчета = Соответсвие["ТипУзлаУчета"];
	Если ЗначениеЗаполнено(ТипУзлаУчета) Тогда 
		КолвоСостава = ПолучитьКолвоСоставаУзла(ТипУзлаУчета);
		
		Если КолвоСостава > 0 Тогда 	
			
			СоответсвиеТипа = новый Соответствие;
			СоответсвиеТипа.Вставить("ТипПрибораУчета","");
			энргОбщегоНазначения.ПолучитьЗначенияРеквизитов(,ТекущиеДанные.ПриборУчетаВывод,СоответсвиеТипа);
			
			СоответсвиеРод = новый Соответствие;
			СоответсвиеРод.Вставить("Родитель","");
			энргОбщегоНазначения.ПолучитьЗначенияРеквизитов(,СоответсвиеТипа["ТипПрибораУчета"],СоответсвиеРод);			
			
			СтандартнаяОбработка = Ложь;
			СтруктураОтбора = Новый Структура("Родитель",СоответсвиеРод["Родитель"]);			
			ПараметрыВыбораФормы	= Новый Структура("Отбор", СтруктураОтбора);
			ОписаниеОповещения 		= Новый ОписаниеОповещения("ТипПрибораУчетаОкончаниеВыбора",ЭтаФорма,Новый Структура("ТекДанные", ТекущиеДанные));
			
			Форма 					= ОткрытьФорму("Справочник.энргТипыПриборовУчета.ФормаВыбора",ПараметрыВыбораФормы,,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			Форма.Элементы.Список.Отображение = ОтображениеТаблицы.Список;   			
			
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ТипПрибораУчетаОкончаниеВыбора(Результат,ДополнительныеПараметры) Экспорт  
	
	Если Результат <> Неопределено Тогда 
		ТекДанные					= ДополнительныеПараметры.ТекДанные;
		ТекДанные.ТипПрибораУчета	= Результат;		
	КонецЕсли;
	
КонецПроцедуры

