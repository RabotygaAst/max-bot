
#Область ПрограммныйИнтерфейс

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	СтруктураРеквизитовДокумент = энргОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПараметрКоманды, "Организация, Район, Дата");
	ПараметрыФормы = Новый Структура("ОбъектПечати, 
										|ИмяМакета, 
										|ТаблицаМакета, 
										|Организация, 
										|Район, 
										|Период", 
										ПараметрКоманды,
										"ПФ_MXL_СчетНаПредварительнуюОплатуЭЭ",
										"Документ.бестПлатежныйДокумент",
										СтруктураРеквизитовДокумент.Организация,
										СтруктураРеквизитовДокумент.Район,
										СтруктураРеквизитовДокумент.Дата);
	ОткрытьФорму("ОбщаяФорма.бестФормаПечатныхФорм", 
					ПараметрыФормы, 
					ПараметрыВыполненияКоманды.Источник,
					ПараметрыВыполненияКоманды.Уникальность, 
					ПараметрыВыполненияКоманды.Окно, 
					ПараметрыВыполненияКоманды.НавигационнаяСсылка);
КонецПроцедуры

#КонецОбласти
