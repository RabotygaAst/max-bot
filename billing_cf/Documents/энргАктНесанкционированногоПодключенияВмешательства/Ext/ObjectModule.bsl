Процедура ЗаполнитьАктивнымиУслугами(ТочкаУчета = Неопределено) Экспорт	
	Услуги.Очистить();
	
	АктивныеУслуги 	= ПолучитьАктивныеУслуги(ТочкаУчета);
	ОбработатьРезультатАктивныеУслуги(АктивныеУслуги);

КонецПроцедуры

Процедура ОбработатьРезультатАктивныеУслуги(Результат) Экспорт
	Выборка	 		= Результат.Выбрать();
	текУслуга 		= Неопределено;
	Пока Выборка.Следующий() Цикл
		Если НЕ текУслуга = Выборка.Услуга Тогда
			НоваяСтрока = Услуги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		КонецЕсли;
		
		текУслуга = Выборка.Услуга;
	КонецЦикла;
КонецПроцедуры

