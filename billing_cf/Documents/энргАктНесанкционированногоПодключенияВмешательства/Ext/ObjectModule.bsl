Функция ТекстЗапросаАктивныеУслуги(ТочкаУчета = Неопределено, Схема = Неопределено) Экспорт
	Результат = "";
	
	Если Схема = Неопределено Тогда 
		Схема = новый СхемаЗапроса;	
	КонецЕсли;
	
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", 	"Организация"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район", 			"Район"), 			Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения", 	"КлючПомещения"), 	Неопределено));
	Если ЗначениеЗаполнено(ТочкаУчета) Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета", 	"ТочкаУчета"), 	Неопределено));
	КонецЕсли;	
	
	Параметры 	= Новый Структура;	
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);
	Параметры.Вставить("Период"		, Новый Структура("ИмяПараметра", "Период"));
	
	ИнициализироватьПервоначальныеДанные(Схема, Параметры);
	Результат 	= Схема.ПолучитьТекстЗапроса() + ОбщегоНазначения.РазделительПакетаЗапросов();
	ДополнитьТекстЗапросаПолученияКлючаНорматива(Результат);
	
	Результат 	= Результат + "ВЫБРАТЬ
	|	ВсеПараметрыРасчетаНорматив.ТочкаУчета КАК ТочкаУчета,
	|	ВсеПараметрыРасчетаНорматив.Услуга КАК Услуга,
	|	ВсеПараметрыРасчетаНорматив.Поставщик КАК Поставщик,
	|	ВсеПараметрыРасчетаНорматив.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	ВсеПараметрыРасчетаНорматив.ВидБлагоустройства КАК ВидБлагоустройстваИндивидуальный,
	|	ВсеПараметрыРасчетаНорматив.ГруппаПотребителей КАК ГруппаПотребителей,
	|	ВсеПараметрыРасчетаНорматив.КлючНорматива КАК КлючНорматива,
	|	ЗначенияНормативовПотребления.ЗначениеНорматива КАК НормаПотребления
	|ИЗ
	|	ВсеПараметрыРасчетаНорматив КАК ВсеПараметрыРасчетаНорматив
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияНормативовПотребления КАК ЗначенияНормативовПотребления
	|		ПО ВсеПараметрыРасчетаНорматив.Организация = ЗначенияНормативовПотребления.Организация
	|			И ВсеПараметрыРасчетаНорматив.Район = ЗначенияНормативовПотребления.Район
	|			И ВсеПараметрыРасчетаНорматив.НаправлениеИспользованияТУ = ЗначенияНормативовПотребления.НаправлениеИспользованияТУ
	|			И ВсеПараметрыРасчетаНорматив.КлючНорматива = ЗначенияНормативовПотребления.КлючНорматива
	|			И ВсеПараметрыРасчетаНорматив.Услуга = ЗначенияНормативовПотребления.Услуга";	
	
	Возврат Результат;
КонецФункции

