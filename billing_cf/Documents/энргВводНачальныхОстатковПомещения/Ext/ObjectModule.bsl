	Запрос			= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Запрос.Текст 	= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.Ссылка КАК Ссылка,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.Ссылка.Дата КАК Дата,
	             	  |	энргАбоненты.Район КАК Район,
	             	  |	энргАбоненты.МКД КАК МКД,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.Абонент КАК Абонент,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.ТочкаУчета КАК ТочкаУчета,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.Услуга КАК Услуга,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.Головная КАК Головная,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.ДатаОткрытияЛС КАК ДатаОткрытияЛС,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.ДатаПодключенияПУ КАК ДатаПодключенияПУ,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.ДатаПоверки КАК ДатаПоверки,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.ПриборУчета КАК ПриборУчета,
	             	  |	энргВводНачальныхОстатковДанныеТочекУчета.ВидДифференцированности КАК ВидДифференцированности,
	             	  |	ВЫБОР
	             	  |		КОГДА энргВводНачальныхОстатковДанныеТочекУчета.КоэффициентПУ = 0
	             	  |			ТОГДА 1
	             	  |		ИНАЧЕ энргВводНачальныхОстатковДанныеТочекУчета.КоэффициентПУ
	             	  |	КОНЕЦ КАК КоэффициентПУ,
	             	  |	энргАбоненты.Организация КАК Организация
	             	  |ПОМЕСТИТЬ ДанныеТочекУчета
	             	  |ИЗ
	             	  |	Документ.энргВводНачальныхОстатков.ТочкиУчета КАК энргВводНачальныхОстатковДанныеТочекУчета
	             	  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	             	  |		ПО энргВводНачальныхОстатковДанныеТочекУчета.Абонент = энргАбоненты.Ссылка
	             	  |			И (энргВводНачальныхОстатковДанныеТочекУчета.Ссылка = &Ссылка)";
	Запрос.Выполнить();
	Возврат МВТ;	
КонецФункции

Функция РезультатПоказанияПУ(Док)
	Запрос 			= Новый Запрос;
	Запрос.Текст 	= "ВЫБРАТЬ
	             	  |	энргВводНачальныхОстатковПоказанияПриборовУчета.ДатаПоказаний КАК ДатаПоказаний,
