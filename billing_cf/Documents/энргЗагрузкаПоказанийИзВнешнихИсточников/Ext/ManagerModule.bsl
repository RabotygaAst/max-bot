Функция ИмяСобытияОшибки()
	
	Возврат "Загрузка показаний";
	
КонецФункции

#Область РазборОчередиПоказаний

Процедура ЗаписатьДокументРегистрацииПоказаний(ПараметрыЗаписи, ДокументОбъект)
	
	НаборТочек = ПараметрыЗаписи.МенеджерТочек.СоздатьНаборЗаписей();
	НаборТочек.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	НаборТочек.Отбор.ДокументОснование.Установить(ПараметрыЗаписи.ДокументОснование);
	НаборТочек.Отбор.IDСтроки.Установить(ПараметрыЗаписи.ИдентификаторТочки);
	
	НаборШкал = ПараметрыЗаписи.МенеджерШкал.СоздатьНаборЗаписей();
	НаборШкал.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	НаборШкал.Отбор.ДокументОснование.Установить(ПараметрыЗаписи.ДокументОснование);
	НаборШкал.Отбор.IDСтрокиТочкиУчета.Установить(ПараметрыЗаписи.ИдентификаторТочки);
	
	НаборПоказаний = ПараметрыЗаписи.МенеджерПоказаний.СоздатьНаборЗаписей();
	НаборПоказаний.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	НаборПоказаний.Отбор.ДокументОснование.Установить(ПараметрыЗаписи.ДокументОснование);
	НаборПоказаний.Отбор.IDСтрокиТочкиУчета.Установить(ПараметрыЗаписи.ИдентификаторТочки);	
	
	НачатьТранзакцию();
	Попытка
		
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		НаборТочек.Записать();	
		НаборШкал.Записать();
		НаборПоказаний.Записать();
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию(); 
		
		Инфо = ИнформацияОбОшибке();
		ЗаписьЖурналаРегистрации(
		"Создание показаний при загрузке показаний", 
		УровеньЖурналаРегистрации.Ошибка,,,
		"Идентификатор точки: " + ПараметрыЗаписи.ИдентификаторТочки + " причина: " + ПодробноеПредставлениеОшибки(Инфо));	
		
	КонецПопытки;
	
КонецПроцедуры

Функция ЗапуститьФоновоеЗаданиеСервер(ДокументОснование, Идентификаторы)
	
	Шаблон = "ru = '%1'";
	НаимДок = "Создание регистрации показаний. Основание: " + ДокументОснование;
	ИмяФункции = "энргРаботаСПоказаниямиПриборовУчетаСервер.ЗапуститьФормированиеРегистрацииПоказанийПоИдентификаторам";
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ПараметрыВыполнения.ОжидатьЗавершение = 0; // запускать сразу
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр(СтрШаблон(Шаблон, НаимДок));
	//ПараметрыВыполнения.КлючФоновогоЗадания = УникальныйИдентификатор;
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьПроцедуру(
	ПараметрыВыполнения, 
	ИмяФункции,
	ДокументОснование,
	Идентификаторы);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

