Процедура УстановитьКлючиСтрокЖильцы()
	Для каждого Стр Из Объект.Жильцы Цикл
		Если Не ЗначениеЗаполнено(Стр.IdСтроки) или стр.IDСтроки = "00000000-0000-0000-0000-000000000000" Тогда
			Стр.IdСтроки = Новый УникальныйИдентификатор;
		КонецЕсли;
	КонецЦикла;
	УстановитьВидимостьСтрок();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьСтрок()
	СоставИндексСтроки = Объект.Жильцы.Индекс(Элементы.Жильцы.ТекущиеДанные);
	Если СоставИндексСтроки >= 0 Тогда
		ВыделеннаяСтрока = Объект.Жильцы.Получить(СоставИндексСтроки);
		IdСтроки = ВыделеннаяСтрока.IdСтроки;
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("IdСтроки", IdСтроки);
		Элементы.Льготы.ОтборСтрок = Новый ФиксированнаяСтруктура(СтруктураПоиска);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьКлючиСтрокЛьготы()
	
	ИндексСтрокиЛьгота = Объект.Жильцы.Индекс(Элементы.Жильцы.ТекущиеДанные);
	ВыделеннаяСтрока = Объект.Жильцы.Получить(ИндексСтрокиЛьгота);
	КлючСтроки = ВыделеннаяСтрока.IdСтроки;
	
	Для каждого Стр Из Объект.Льготы Цикл
		Если Не ЗначениеЗаполнено(Стр.IdСтроки) Тогда
			Стр.IdСтроки = КлючСтроки;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Функция ПолучитьМаксимальныйКлючСтроки()
	МаксимальныйКлючСтроки = 1;
	Для каждого Стр Из Объект.Жильцы Цикл
		Попытка
			МаксимальныйКлючСтроки = Макс(МаксимальныйКлючСтроки, Число(Стр.IDСтроки));
		Исключение
			МаксимальныйКлючСтроки = МаксимальныйКлючСтроки;
		КонецПопытки;
	КонецЦикла;
	Возврат МаксимальныйКлючСтроки;
КонецФункции

