&наклиенте
Функция   ПрочитатьиРазобратьХМЛ(ФайлДляЧтения)
	Файл = Новый ДвоичныеДанные(ФайлДляЧтения);
	Адрес = ПоместитьВоВременноеХранилище(Файл, ЭтаФорма.УникальныйИдентификатор);
	СЗ = РазобратьХМЛ(Адрес);
	Возврат СЗ;
КонецФункции

&НаСервере
Функция РазобратьХМЛ(Адрес)
	обработка = Обработки.энргЗагрузкаИзВнешнихИсточников_ОбходнойЛист.Создать();
	СЗ = обработка.РазобратьХМЛ(Адрес);
	возврат СЗ;
КонецФункции

