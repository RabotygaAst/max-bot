&НаКлиенте
Процедура ЗагрузитьИзXML()
	
	Если не ЗначениеЗаполнено(Объект.ФайлДляЧтения) и не ЗначениеЗаполнено(Объект.URLДляЧтения) тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите файл или url для чтения",,"ФайлДляЧтения","ФайлДляЧтения");
		Возврат;
	КонецЕсли;
	Если ЗначениеЗаполнено(объект.ФайлДляЧтения) тогда
		СЗ = ПрочитатьиРазобратьХМЛ(объект.ФайлДляЧтения);
	иначеЕсли ЗначениеЗаполнено(объект.URLДляЧтения) тогда;
		СЗ = ПрочитатьиРазобратьХМЛ(объект.URLДляЧтения);
	КонецЕсли;
	отправитьНаОбработку(СЗ);
КонецПроцедуры

