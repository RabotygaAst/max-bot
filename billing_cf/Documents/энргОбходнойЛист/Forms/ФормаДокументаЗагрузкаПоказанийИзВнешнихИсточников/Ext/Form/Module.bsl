		ПоказатьПредупреждение(,"Заполните Абонента");
		Возврат;
	КонецЕсли;
	
	Если ДанныеПоОтборуЕсть("Абонент", Абонент) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По абоненту: " + СокрЛП(Абонент) + " данные заполнены.");
		Возврат;
	КонецЕсли;
	
	ПолучитьДанныеДляЗаполненияПоАбоненту();	
