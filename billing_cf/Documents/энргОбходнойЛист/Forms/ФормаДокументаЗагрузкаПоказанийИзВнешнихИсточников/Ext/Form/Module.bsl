	обработка = Обработки.энргЗагрузкаИзВнешнихИсточников_ОбходнойЛист.Создать();
	обработка.ЗаполнитьДокумент(СЗ, объект, ТЗ);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоказанияНаСервере(Результат)

	Выборка  									= Результат.выбрать();
	ТекКлючПомещения							= Неопределено;
	ТекТочкаУчета 								= Неопределено;
	ТекШкала 									= Неопределено;
	IDСтрокиТочки 								= Неопределено;
	IDСтрокиШкалы 								= Неопределено;
	Пока Выборка.следующий() Цикл 
		НоваяТочка = Ложь;
		Если Не ТекКлючПомещения = Выборка.КлючПомещения Или НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
			IDСтрокиТочки 						= Новый УникальныйИдентификатор;
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.КлючПомещения 		= Выборка.КлючПомещения;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
			СтрокаТочкиУчета.РегистрируетОбъем 	= Выборка.РегистрируетОбъем;
		КонецЕсли;
		
		Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
		КонецЕсли;

		СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
		СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона; 
		
		ТекКлючПомещения 						= Выборка.КлючПомещения;
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
	    ТекШкала 								= Выборка.Шкала
	КонецЦикла; 
	
	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Район); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Объект.Организация, Объект.Район,ТаблицаПоказанийДляЗаполнения,Объект.Дата,Истина);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета);
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ТочкиУчета");
	
	Объект.ТочкиУчета.Сортировать("Строение,Помещение");
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект,Объект,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета);
	
	ЗаполнитьАбонентов();
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСостояниеЛСАбонента(Организация, Район, Абонент)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСостояниеЛССрезПоследних.Период КАК Период,
		|	энргСостояниеЛССрезПоследних.Состояние КАК Состояние
		|ИЗ
		|	РегистрСведений.энргСостояниеЛС.СрезПоследних(
		|			&ТекДата,
		|			Абонент = &Абонент
		|				И Район = &Район
		|				И Организация = &Организация) КАК энргСостояниеЛССрезПоследних";
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Возврат Новый Структура("Период, Состояние", Выборка.Период, Выборка.Состояние);
	КонецЦикла;

КонецФункции

&НаСервере
Процедура ЗаполнитьАбонентов()
	Ключи 		= новый Массив;
	ДанныеСтрок = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("Абонент", Справочники.энргАбоненты.ПустаяСсылка()));
	Для Каждого ТекСтр из ДанныеСтрок Цикл 
		Ключи.Добавить(ТекСтр.КлючПомещения);
	КонецЦикла;	
	
	//Ключи = Объект.ТочкиУчета.Выгрузить(,"КлючПомещения").ВыгрузитьКолонку("КлючПомещения");
	КлючиАбонентов = АбонентыКлючейПомещений(Ключи);
	Для Каждого СтрТУ Из ДанныеСтрок Цикл
		СтрТУ.Абонент = КлючиАбонентов.Получить(СтрТУ.КлючПомещения);
	КонецЦикла; 
	
КонецПроцедуры

&НаСервере
Функция АбонентыКлючейПомещений(Ключи)
	
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргАбоненты.Ссылка КАК Абонент,
		|	энргАбоненты.КлючПомещения КАК КлючПомещения
		|ИЗ
		|	Справочник.энргАбоненты КАК энргАбоненты
		|ГДЕ
		|	НЕ энргАбоненты.ПометкаУдаления
		|	И энргАбоненты.КлючПомещения В(&КлючПомещения)
		|	И энргАбоненты.Организация = &Организация";
	
	Запрос.УстановитьПараметр("КлючПомещения", Ключи);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Результат.Вставить(ВыборкаДетальныеЗаписи.КлючПомещения,ВыборкаДетальныеЗаписи.Абонент);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ДанныеПоОтборуЕсть(ИмяРеквизита, ЗначениеРеквизита)
	Возврат Объект.ТочкиУчета.НайтиСтроки(Новый Структура(ИмяРеквизита, ЗначениеРеквизита)).Количество() > 0;
КонецФункции

&НаСервере
Функция СформироватьТЗ()
	ТЗ = новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("абонент", новый ОписаниеТипов("СправочникСсылка.энргАбоненты"));
	ТЗ.Колонки.Добавить("ИспользоватьТарифныеЗоны", новый ОписаниеТипов("булево"));
	ТЗ.Колонки.Добавить("ИспользоватьШкалыПриборовУчета", новый ОписаниеТипов("булево"));
	ТЗ.Колонки.Добавить("НеЗагруженныеДанныеНеЗагруженныеПоказания", новый ОписаниеТипов("ДанныеФормыКоллекция"));
	ТЗ.Колонки.Добавить("НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона", новый ОписаниеТипов("ДанныеФормыКоллекция"));
	ТЗ.Колонки.Добавить("ПрефиксТочекУчета", новый ОписаниеТипов("строка"));
	ТЗ.Колонки.Добавить("ТочкаУчетаОтбор", новый ОписаниеТипов("СправочникСсылка.энргТочкиУчета"));
	строкаТЗ = тз.Добавить();
	строкаТЗ.абонент												 = этаформа.Абонент;
	строкаТЗ.ИспользоватьТарифныеЗоны								 = ЭтаФорма.ИспользоватьТарифныеЗоны;
	строкаТЗ.ИспользоватьШкалыПриборовУчета						 = ЭтаФорма.ИспользоватьШкалыПриборовУчета;
	строкаТЗ.НеЗагруженныеДанныеНеЗагруженныеПоказания			 = этаформа.НеЗагруженныеДанныеНеЗагруженныеПоказания;
	строкаТЗ.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона = этаформа.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона;
	строкаТЗ.ПрефиксТочекУчета 									 = ЭтаФорма.ПрефиксТочекУчета;
	строкаТЗ.ТочкаУчетаОтбор										 = ЭтаФорма.ТочкаУчетаОтбор;	

	возврат ТЗ;
КонецФункции

