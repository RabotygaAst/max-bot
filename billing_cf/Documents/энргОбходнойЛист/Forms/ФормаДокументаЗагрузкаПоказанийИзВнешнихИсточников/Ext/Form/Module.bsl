Процедура ИсправитьДанные(Команда)
	ИсправитьДанныеНаСервере();
КонецПроцедуры

&НаСервере
Процедура ИсправитьДанныеНаСервере()
	ТЗ = сформироватьТЗ();
	обработка = Обработки.энргЗагрузкаИзВнешнихИсточников_ОбходнойЛист.Создать();
	ТЗБаза = обработка.ЗаполнитьТочкиУчетаСервер(объект, ТЗ);
	для каждого строка из ЭтаФорма.НеЗагруженныеДанныеНеЗагруженныеПоказания цикл
		Если строка.НомерПрибораУчета<>""  тогда
			// обходим первую таблицу и ищем во второй строки с таким же номером прибора учета
			Отбор = Новый Структура("приборучета", Справочники.энргПриборыУчетаАбонента.НайтиПоКоду(строка.НомерПрибораУчета));
			Если ЗначениеЗаполнено(Отбор.приборучета) тогда
				МассивСтрок = ТЗБаза.НайтиСтроки(Отбор);
			КонецЕсли;
		КонецЕсли;
		
		Если МассивСтрок.количество()>0 или не ЗначениеЗаполнено(Отбор.приборучета) Тогда // ничего не нашли
			продолжить;
		иначе
			для каждого строкамассива из массивстрок цикл
				если ЗначениеЗаполнено(строкамассива.приборучета) тогда
					стротбора = новый структура;
					стротбора.Вставить("НомерПрибораУчета", строка.НомерПрибораУчета);
					нДокТУ = объект.ТочкиУчета.Добавить();
					ЗначИзБазы  = ТЗБаза.найти(строкамассива.ПриборУчета, "ПриборУчета");
					нДокТУ.ПриборУчета = ЗначИзБазы.ПриборУчета;
					нДокТУ.ТочкаУчета = ЗначИзБазы.ТочкаУчета;
					нДокНЕТУ = ЭтаФорма.НеЗагруженныеДанныеНеЗагруженныеПоказания.НайтиСтроки(стротбора);
					IDудаляемойстроки = нДокНЕТУ[0].IDСтроки;
					стротбора = новый структура;
					стротбора.Вставить("IDСтроки", IDудаляемойстроки);
					ПоказанияТУФорма = ЭтаФорма.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона.НайтиСтроки(стротбора);
				КонецЕсли;
				
			ТекущийПриборУчета = Обработка.получитьДанныеПрибораУчета(строкамассива.ПриборУчета);
			Обработка.ЗаполнитьДанныеПриборовУчета(Отбор.приборучета, ПоказанияТУФорма,ТекущийПриборУчета, объект, ТЗ);
			КонецЦикла;

			// удаление строка, которые перенесли в другую ТЧ
			ПУДляУдаления = Новый Массив;
			для каждого строка из ЭтаФорма.НеЗагруженныеДанныеНеЗагруженныеПоказания цикл
				если строка.IDСтроки = IDудаляемойстроки тогда
					  ПУДляУдаления.Добавить(строка);
				КонецЕсли;
			КонецЦикла;
			для счетчик = 0 по ЭтаФорма.НеЗагруженныеДанныеНеЗагруженныеПоказания.НайтиСтроки(стротбора).Количество()-1 цикл
				ЭтаФорма.НеЗагруженныеДанныеНеЗагруженныеПоказания.Удалить(ПУДляУдаления[счетчик]);
			КонецЦикла;

			ПоказанияДляУдаления = Новый Массив;
			для каждого строка из ЭтаФорма.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона цикл
				если строка.IDСтроки = IDудаляемойстроки тогда
					  ПоказанияДляУдаления.Добавить(строка);
				КонецЕсли;
			КонецЦикла;
			для счетчик = 0 по ЭтаФорма.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона.НайтиСтроки(стротбора).Количество()-1 цикл
				ЭтаФорма.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона.Удалить(ПоказанияДляУдаления[счетчик]);
			КонецЦикла;
			
		КонецЕсли;
		
		
	КонецЦикла;

КонецПроцедуры

