#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

Функция МассивПриборов() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ссылка",				Ссылка);
	Запрос.Текст  	= 
	"ВЫБРАТЬ
	|	ШапкаДокумента.ПериодНачисления КАК ПериодНачисления,
	|	ШапкаДокумента.Дата КАК ПериодРегистрации,
	|	энргСтроения.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ВложенныйЗапрос.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ВложенныйЗапрос.ВыводПрибораУчета КАК ВыводПрибораУчета,
	|	ВложенныйЗапрос.ИмяТабЧасти КАК ИмяТабЧасти
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаТочек.Ссылка КАК ссылка,
	|		ТаблицаТочек.ПриборУчета КАК ПриборУчета,
	|		ПоказанияПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	|		ПоказанияПриборовУчета.ТекущиеПоказания КАК ТекущиеПоказания,
	|		ЛОЖЬ КАК ВыводПрибораУчета,
	|		""ПоказанияПриборовУчета"" КАК ИмяТабЧасти,
	|		ТаблицаТочек.МКД КАК МКД
	|	ИЗ
	|		Документ.энргОбходнойЛистМКД.ТочкиУчета КАК ТаблицаТочек
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОбходнойЛистМКД.ПоказанияПриборовУчета  КАК ПоказанияПриборовУчета
	|			ПО ТаблицаТочек.IDСтроки = ПоказанияПриборовУчета.IDСтроки
	|				И ТаблицаТочек.Ссылка = ПоказанияПриборовУчета.Ссылка
	|				И (ПоказанияПриборовУчета.Ссылка = &ссылка)
	|				И (ТаблицаТочек.Ссылка = &ссылка)
	|				И (НЕ ТаблицаТочек.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОбходнойЛистМКД КАК ШапкаДокумента
	|		ПО ВложенныйЗапрос.ссылка = ШапкаДокумента.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргСтроения КАК энргСтроения
	|		ПО ВложенныйЗапрос.МКД = энргСтроения.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Район,
	|	МКД,
	|	ПриборУчета,
	|	ТарифнаяЗона,
	|	ПериодРегистрации,
	|	ТекущиеПоказания";
	
	ДополнительныеСвойства.Вставить("МассивПриборов",Запрос.Выполнить());
	
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеСвойства.свойство("ВосстановлениеПоследовательности") тогда
		Возврат;
	КонецЕсли;	
	
	Ответственный = Пользователи.ТекущийПользователь();
		
	ДополнительныеСвойства.Вставить("ГруппаАбонентов",Истина);
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект); 
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
		
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	Для Каждого СтрПоказания из ПоказанияПриборовУчета Цикл 
		Если не ЗначениеЗаполнено(СтрПоказания.ТекущиеПоказания) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Конечные показания не заполнены");
			Отказ=Истина;
		КонецЕсли;
	КонецЦикла;
	
	энргРаботаСприборамиУчетаСервер.ЗаписатьПоказанияМКДРезультатЗапроса(Новый Структура("Документ", Ссылка), Движения);	
	
КонецПроцедуры 

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли