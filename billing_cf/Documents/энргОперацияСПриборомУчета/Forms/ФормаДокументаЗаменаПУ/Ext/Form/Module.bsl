&НаСервере
Процедура ПриИзмененииДатыСервер()
	
	Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииДатыФактическогоСобытияСервер()
	
	Если ЗначениеЗаполнено(Объект.Организация) и ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия) Тогда 		
		Объект.ПериодНачисленияФактическогоСобытия = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.ДатаФактическогоСобытия, Объект.Организация,Объект.Район);
	ИначеЕсли НЕ ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия) Тогда
		Объект.ПериодНачисленияФактическогоСобытия = '0001-01-01';		
	КонецЕсли;
	ЗаполнитьПриборыУчетаСервер();
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииТочкиУчетаСервер(ИдентификаторСтроки)
	
	ЗаполнитьПриборыУчетаСервер(ИдентификаторСтроки);
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииАбонентаСервер() 
	
	ПолучаемыеСвойства 			= "Организация,Район,КлючПомещения";
	ЗначенияРеквизитов 			= Обработки.энргАбонентыМенеджер.ЗначенияРеквизитовОбъекта(Объект.Абонент, ПолучаемыеСвойства);
	ЗаполнитьЗначенияСвойств(Объект,ЗначенияРеквизитов,ПолучаемыеСвойства);
	
	ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(Объект.КлючПомещения);
	ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);
	
	ЗаполнитьПриборыУчетаСервер();
	
КонецПроцедуры

&НаСервере
Процедура СтроениеПомещениеПриИзмененииСервер() 
	
	ДанныеКлючаПомещения  = Обработки.энргКлючиПомещенийМенеджер.КлючПомещенияПоСтроениюИПомещению(Строение,Помещение);
	
	ЗаполнитьЗначенияСвойств(Объект, ДанныеКлючаПомещения, "КлючПомещения, Район");	
	ЧастныйСектор = ДанныеКлючаПомещения.ЧастныйСектор;
	
	ЗаполнитьПриборыУчетаСервер();
	
КонецПроцедуры  

&НаСервере
Процедура ЗаполнитьДанныеКлючаПомещения(Знач ДанныеПомещенияРезультат)
	
	Перем ДанныеПомещенияВыборка;
	
	Если Не ДанныеПомещенияРезультат.Пустой() Тогда
		ДанныеПомещенияВыборка  = ДанныеПомещенияРезультат.Выбрать();
		ДанныеПомещенияВыборка.Следующий();
		ЗаполнитьЗначенияСвойств(ЭтаФорма,ДанныеПомещенияВыборка,"Строение,Помещение,ЧастныйСектор");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередУдалениемСтрокиТочкиУчета()
	
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;;
	
	ТабЧасть  								= объект.ШкалыПриборовУчета ;
	СтрокиТЧ 								= ТабЧасть.найтиСтроки(Новый Структура("IDСтрокиТочкиУчета",ТекущиеДанные.IDСтроки));
	для Каждого СтрокаТЧ из СтрокиТЧ цикл
		СтрокиПоказаний 					= объект.ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки", СтрокаТЧ.IDСтроки));
		Для Каждого СтрокаПоказаний Из СтрокиПоказаний Цикл
			объект.ПоказанияПриборовУчета.Удалить(СтрокаПоказаний);
		КонецЦикла;				
		ТабЧасть.удалить(СтрокаТЧ);
	КонецЦикла;
	
	ТабЧасть  								= объект.ШкалыПриборовУчета ;
	СтрокиТЧ 								= ТабЧасть.найтиСтроки(Новый Структура("IDСтрокиТочкиУчета",ТекущиеДанные.IDСтрокиВывод));
	для Каждого СтрокаТЧ из СтрокиТЧ цикл
		СтрокиПоказаний 					= объект.ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки", СтрокаТЧ.IDСтроки));
		Для Каждого СтрокаПоказаний Из СтрокиПоказаний Цикл
			объект.ПоказанияПриборовУчета.Удалить(СтрокаПоказаний);
		КонецЦикла;				
		ТабЧасть.удалить(СтрокаТЧ);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьКоэфициент(ТекущиеДанные) 	
	Если ТекущиеДанные.КоэффициентПУ = 0 тогда
		Если ЗначениеЗаполнено(ТекущиеДанные.ЗаводскойНомер) или ЗначениеЗаполнено(ТекущиеДанные.ДатаПоверкиСчетчика) или ЗначениеЗаполнено(ТекущиеДанные.ТипПрибораУчета) Тогда
			ТекущиеДанные.КоэффициентПУ = 1;
		КонецЕсли; 	
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.ВидКанальности) тогда
		Если ЗначениеЗаполнено(ТекущиеДанные.ЗаводскойНомер) или ЗначениеЗаполнено(ТекущиеДанные.ДатаПоверкиСчетчика) или ЗначениеЗаполнено(ТекущиеДанные.ТипПрибораУчета) Тогда
			ТекущиеДанные.ВидКанальности = ПредопределенноеЗначение("Справочник.энргВидыКанальности.Одноканальный");
		КонецЕсли; 	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПриборыУчетаСервер(ИдентификаторСтроки  = Неопределено)
	
	ТочкаУчета 										= Неопределено;
	СтрокаТочкиУчета 								= Неопределено;
	Если НЕ ИдентификаторСтроки = Неопределено Тогда
		СтрокаТочкиУчета 							= Объект.ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
	КонецЕсли;	
	
	ТаблицаТЧ 										= Объект.ПоказанияПриборовУчета.Выгрузить();
	
	Если СтрокаТочкиУчета = Неопределено Тогда 		
		Объект.ТочкиУчета.Очистить();
		Объект.Измерители.Очистить();
		Объект.ШкалыПриборовУчета.Очистить();
		Объект.ПоказанияПриборовУчета.Очистить();
	Иначе
		ТочкаУчета 									= СтрокаТочкиУчета.ТочкаУчета;
		ОтборСтрок									= Новый Структура("IDСтрокиТочкиУчета", СтрокаТочкиУчета.IDСтрокиВывод);
		СтрокиШкалДляУдаления 						= Объект.ШкалыПриборовУчета.НайтиСтроки(ОтборСтрок);
		Для Индекс  = 0 По СтрокиШкалДляУдаления.ВГраница() Цикл
			СтрокаШкалы 							= СтрокиШкалДляУдаления[Индекс];
			СтрокиПоказанияДляУдаления 				= Объект.ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки", СтрокаШкалы.IDСтроки));
			Для ИндекПоказаний = 0 По СтрокиПоказанияДляУдаления.ВГраница() Цикл
				Объект.ПоказанияПриборовУчета.Удалить(СтрокиПоказанияДляУдаления[ИндекПоказаний]);
			КонецЦикла;
			Объект.ШкалыПриборовУчета.Удалить(СтрокаШкалы);
		КонецЦикла;
		
		энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.Измерители, ОтборСтрок); 
	КонецЕсли;
	
	Если энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыФизЛиц() Тогда
		ЗаполнитьПриборыУчетаСВспомогательнымОборудованием(ТочкаУчета, ИдентификаторСтроки)
	Иначе 		
		ЗаполнитьПриборыУчетаБезВспомогательногоОборудования(ТочкаУчета, ИдентификаторСтроки);
	КонецЕсли;
	
	СоотвествиеКолонок = Новый Структура;
	СоотвествиеКолонок.Вставить("IDСтроки"		, "IDСтрокиВывод");
	СоотвествиеКолонок.Вставить("ПриборУчета"	, "ПриборУчетаВывод");
	
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();
	
	ДатаЗаполненияПоказаний = ?(Объект.ДатаФактическогоСобытия = Дата(1,1,1), Объект.Дата, Объект.ДатаФактическогоСобытия);
	
	ТаблицаПоказанийДляЗаполнения 		= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Район,Объект.КлючПомещения,ИдентификаторСтроки,СоотвествиеКолонок); 
	РезультатДанныеЗаполненияПоказаний 	= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказанийСУчетомОтклонения(Объект.Организация,Объект.Район,ТаблицаПоказанийДляЗаполнения,Объект.Дата, ПриборыДляОтклоненияПоказаний.Выгрузить());
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, Объект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
	ЗаполнитьТекстовыеПоля();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПриборыУчетаБезВспомогательногоОборудования(ТочкаУчета, ИдентификаторСтроки)	
	Результат 										= Обработки.энргСостояниеПриборовУчетаМенеджер.ДействующиеПриборыУчетаПомещения(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения, ТочкаУчета, Истина, Новый Структура("ТолькоОткрытыеЛС", Истина)); 
	Выборка  										= Результат.выбрать();
	ТекТочкаУчета 									= Неопределено;
	ТекШкала 										= Неопределено;
	IDСтрокиТочки 									= Неопределено;
	IDСтрокиШкалы 									= Неопределено;
	Пока Выборка.следующий() цикл
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			Если ИдентификаторСтроки = Неопределено Тогда
				СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
				IDСтрокиТочки 						= Новый УникальныйИдентификатор;
				IDСтрокиТочкиВывод					= Новый УникальныйИдентификатор;
				СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
				СтрокаТочкиУчета.IDСтрокиВывод 		= IDСтрокиТочкиВывод;
				СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			иначе 				
				СтрокаТочкиУчета  					= Объект.ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
				IDСтрокиТочки 						= СтрокаТочкиУчета.IDСтрокиВывод;
			КонецЕсли;	
			СтрокаТочкиУчета.Услуга 				= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчетаВывод		= Выборка.ПриборУчета;			
		КонецЕсли;
		
		Если НЕ ТекШкала = Выборка.Шкала Или НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			СтрокаШкалы  							= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 							= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 			= СтрокаТочкиУчета.IDСтрокиВывод;
			СтрокаШкалы.IDСтроки 					= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 						= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности 	= Выборка.ВидДифференцированности;
			СтрокаШкалы.Вывод 						= Истина;
		КонецЕсли;
		
		СтрокаПоказаний 							= Объект.ПоказанияПриборовУчета.Добавить();
		СтрокаПоказаний.IDСтроки 					= IDСтрокиШкалы; 	
		СтрокаПоказаний.ТарифнаяЗона 				= Выборка.ТарифнаяЗона;
		СтрокаПоказаний.Вывод 						= Истина;
		
		ТекТочкаУчета 	= Выборка.ТочкаУчета;
		ТекШкала 		= Выборка.Шкала;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПриборыУчетаСВспомогательнымОборудованием(ТочкаУчета, ИдентификаторСтроки)	
	Результат = Обработки.энргСостояниеПриборовУчетаМенеджер.ДействующиеПриборыУчетаПомещенияСВспомогательнымОборудованием(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения, ТочкаУчета, Истина); 
	РезультатТУ			= Результат[Результат.Количество()-2];
	РезультатИзмерители	= Результат[Результат.Количество()-1].Выгрузить();
	Выборка  			= РезультатТУ.выбрать();
	ТекТочкаУчета 		= Неопределено;
	ТекШкала 			= Неопределено;
	IDСтрокиТочки 		= Неопределено;
	IDСтрокиШкалы 		= Неопределено;
	Пока Выборка.следующий() цикл
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			Если ИдентификаторСтроки = Неопределено Тогда
				СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
				IDСтрокиТочки 						= Новый УникальныйИдентификатор;
				IDСтрокиТочкиВывод					= Новый УникальныйИдентификатор;
				СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
				СтрокаТочкиУчета.IDСтрокиВывод 		= IDСтрокиТочкиВывод;
				СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			КонецЕсли;	
			СтрокаТочкиУчета.Услуга 				= Выборка.Услуга;
			СтрокаТочкиУчета.ТипУзлаУчета 			= Выборка.ТипУзлаУчета;
			СтрокаТочкиУчета.ПриборУчетаВывод		= Выборка.ПриборУчета;
			
			
			СтрокаИзмерителя 								= Объект.Измерители.Добавить();
			СтрокаИзмерителя.IDСтроки 						= Новый УникальныйИдентификатор;
			СтрокаИзмерителя.IDСтрокиТочкиУчета 			= IDСтрокиТочкиВывод;
			СтрокаИзмерителя.ПриборУчета 					= СтрокаТочкиУчета.ПриборУчетаВывод;
			СтрокаИзмерителя.ВспомогательноеОборудование 	= Ложь;
			СтрокаИзмерителя.ТипПрибораУчета       			= Выборка.ТипПрибораУчета;
			СтрокаИзмерителя.РасположениеИзмерителя			= Выборка.РасположениеИзмерителя; 			
			СтрокаИзмерителя.ТипИзмерителя					= Выборка.ТипИзмерителя; 			
			СтрокаИзмерителя.Вывод 							= Истина;
			
			Отбор = Новый Структура("ТочкаУчета", Выборка.ТочкаУчета);
			СтрокиИзмерителей 	= РезультатИзмерители.НайтиСтроки(Отбор);
			Для Каждого стр из СтрокиИзмерителей Цикл
				СтрокаИзмерителя 							= Объект.Измерители.Добавить();
				СтрокаИзмерителя.IDСтроки 					= Новый УникальныйИдентификатор;
				СтрокаИзмерителя.IDСтрокиТочкиУчета 		= IDСтрокиТочкиВывод;
				ЗаполнитьЗначенияСвойств(СтрокаИзмерителя, стр);
			КонецЦикла;
		КонецЕсли;
		
		Если НЕ ТекШкала = Выборка.Шкала Или НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			СтрокаШкалы  							= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 							= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 			= СтрокаТочкиУчета.IDСтрокиВывод;
			СтрокаШкалы.IDСтроки 					= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 						= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности 	= Выборка.ВидДифференцированности;
			СтрокаШкалы.Вывод 						= Истина;
		КонецЕсли;
		
		СтрокаПоказаний 							= Объект.ПоказанияПриборовУчета.Добавить();
		СтрокаПоказаний.IDСтроки 					= IDСтрокиШкалы;
		СтрокаПоказаний.IDСтрокиТочкиУчета 			= IDСтрокиТочкиВывод;
		СтрокаПоказаний.ТарифнаяЗона 				= Выборка.ТарифнаяЗона;
		СтрокаПоказаний.Вывод 						= Истина;
		
		ТекТочкаУчета 	= Выборка.ТочкаУчета;
		ТекШкала 		= Выборка.Шкала;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Функция ЕстьОшибкиЗаполнения(РежимЗаписи)
	
	ЕстьОшибкиЗаполнения = Ложь;
	
	Если НачалоМесяца(Объект.Дата) = НачалоМесяца(Объект.ДатаФактическогоСобытия) Тогда
		ЕстьОшибкиЗаполнения = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Фактическая и текущая дата не могут находиться в одном периоде");
		Объект.ДатаФактическогоСобытия = Дата(1,1,1);
	КонецЕсли;
	
	Возврат ЕстьОшибкиЗаполнения;
	
КонецФункции

&НаКлиенте
Процедура РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные)
	ДопПараметры = Новый Структура("ЭтоВводПУ",Истина);
	энргРаботаСПриборамиУчетаКлиент.РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные.РегистрируетОбъемВывод,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета,ЭтаФорма,ДопПараметры);
КонецПроцедуры

&НаСервере
Процедура УдалитьСтроку(ДополнительныеПараметры)
	Объект[ДополнительныеПараметры.ТЧ].Удалить(ДополнительныеПараметры.НомерСтроки);	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваПриборовУчета(Знач ТекущийОбъект)
	
	Перем мПриборыУчета, ПолучаемыеСвойстваПриборовУчета, СвойстваПриборовУчета;
	
	ПолучаемыеСвойстваПриборовУчета = ПолучаемыеСвойстваПриборовУчета();	
	мПриборыУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.ТочкиУчета.Выгрузить().ВыгрузитьКолонку("ПриборУчета"));
	СвойстваПриборовУчета 			= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектов(мПриборыУчета, ПолучаемыеСвойстваПриборовУчета);
	ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Объект.ТочкиУчета, СвойстваПриборовУчета);
	
КонецПроцедуры

&НаСервере
Функция СоотвествиеРеквизитовСвойствамТочкиУчета()
	Возврат Новый Структура("НаименованиеТочки","Наименование");
КонецФункции

&НаСервере
Функция ПолучаемыеСвойстваПриборовУчета() 
	Возврат энргРаботаСприборамиУчетаСервер.ПолучаемыеСвойстваПриборовУчета();	
КонецФункции

#Область СервисПроверкиПоказанийПриборовУчета

&НаСервере
Процедура ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний()
	
	ТаблицаПриборов = энргРаботаСПоказаниямиПриборовУчетаСервер.НоваяТаблицаПриборовДляПроверки();
	Для Каждого ТекСтрока из Объект.ТочкиУчета Цикл
		НСтрока = ТаблицаПриборов.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, ТекСтрока);
		НСтрока.Район 			= Объект.Район;
		НСтрока.КлючПомещения 	= Объект.КлючПомещения;
	КонецЦикла;
	
	ПериодЗапроса = Новый Граница(Объект.Дата, ВидГраницы.Исключая); 
	ВспомогательныеПараметры = энргРаботаСПоказаниямиПриборовУчетаСервер.НовыеВспомогательныеПараметрыПроверкиОтклоненияПоказаний();
	ВспомогательныеПараметры.ПоказанияВСрок = Истина;
	ВспомогательныеПараметры.ПериодНачисления = Объект.ПериодНачисления;
	
	РезультатЗапроса = энргРаботаСПоказаниямиПриборовУчетаСервер.ПриборыДляОтклоненияПоказаний(ПериодЗапроса, Объект.Организация, ТаблицаПриборов, ВспомогательныеПараметры);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний(ЭтотОбъект, РезультатЗапроса);	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтрокуСПоказаниями(ТекущиеДанныеТочкиУчета, ТекущиеДанные, ДанныеСтроки = Неопределено)
	
	РезультатПроверки = энргРаботаСПоказаниямиПриборовУчетаКлиент.ОпределитьСостояниеПоказанийПоСтроке(ТекущиеДанныеТочкиУчета.ПриборУчета, ЭтотОбъект, ТекущиеДанные);
	Если РезультатПроверки.СостояниеИзменено И Не ТекущиеДанные.ПричинаОтклонения = РезультатПроверки.ПричинаОтклонения Тогда
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, РезультатПроверки);	
		
		Если Не ДанныеСтроки = Неопределено Тогда
			Если ДанныеСтроки.Свойство("СтатусИзмененПользователем") И ДанныеСтроки.СтатусИзмененПользователем Тогда
				ДанныеСтроки.СтатусИзмененПользователем = Ложь;		
			КонецЕсли; 
			Если ДанныеСтроки.Свойство("ПереворотИзмененПользователем") И ДанныеСтроки.ПереворотИзмененПользователем Тогда
				ДанныеСтроки.ПереворотИзмененПользователем = Ложь;		
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	энргРаботаСПоказаниямиПриборовУчетаКлиент.ПересчитатьСтрокуПриборовУчета(ТекущиеДанные, ТекущиеДанныеТочкиУчета.РегистрируетОбъем, Объект.Дата, ДанныеСтроки); 
	
КонецПроцедуры

