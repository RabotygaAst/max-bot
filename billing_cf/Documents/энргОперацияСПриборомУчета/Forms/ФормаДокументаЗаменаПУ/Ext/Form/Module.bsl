&НаКлиенте
Процедура ТочкиУчетаТочкаУчетаПриИзменении(Элемент)
	
	ТекущаяСтрока 						= Элементы["ТочкиУчета"].ТекущаяСтрока;
	
	Если ТекущаяСтрока  = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПриИзмененииТочкиУчетаСервер(ТекущаяСтрока);
	
	ТочкиУчетаПриАктивизацииСтроки(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПередУдалением(Элемент, Отказ)
	
	ТекущиеДанные				= Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицыФормы 				= Новый Массив;
	ТаблицыФормы.Добавить("ШкалыПриборовУчета");
	
	ТаблицыФормыВторогоУровня 	= Новый Массив;
	ТаблицыФормыВторогоУровня.Добавить("ПоказанияПриборовУчета");
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы, "ТочкиУчета", ТаблицыФормыВторогоУровня);
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(ТекущиеДанные.IDСтрокиВывод, Объект, ТаблицыФормы, "ТочкиУчета", ТаблицыФормыВторогоУровня);
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПриАктивизацииСтроки(Элемент)
	
	ИмяТаблицыШкал	 						= "ШкалыПриборовУчета";
	ИмяТаблицыПоказаний						= "ПоказанияПриборовУчета";
	ТекущиеДанные 							= Элементы.ТочкиУчета.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	
	ТаблицаФормыПоказания 					= Элементы.Найти(ИмяТаблицыПоказаний + ПрефиксТочекУчета + "Ввод");	
	Если ТаблицаФормыПоказания = Неопределено Тогда
		ТаблицаФормыПоказания 				= Элементы.Найти(ИмяТаблицыШкал + ПрефиксТочекУчета + "Ввод");
	КонецЕсли;
	
	Если НЕ ТаблицаФормыПоказания = Неопределено Тогда 
		энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаФормыПоказания,"IDСтрокиТочкиУчета",ТекущиеДанные.IDСтроки);		
	КонецЕсли;
	
	ТаблицаФормыПоказания 					= Элементы.Найти(ИмяТаблицыПоказаний + ПрефиксТочекУчета + "Вывод");	
	Если ТаблицаФормыПоказания = Неопределено Тогда
		ТаблицаФормыПоказания 				= Элементы.Найти(ИмяТаблицыШкал + ПрефиксТочекУчета + "Вывод");
	КонецЕсли;
	
	Если НЕ ТаблицаФормыПоказания = Неопределено Тогда 
		энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаФормыПоказания,"IDСтрокиТочкиУчета",ТекущиеДанные.IDСтрокиВывод);		
	КонецЕсли;
	
	ТаблицаПриборыВвод 						= Элементы.Найти("ПриборыУчета" + ПрефиксТочекУчета + "Ввод");
	Если НЕ ТаблицаПриборыВвод = Неопределено Тогда
		энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаПриборыВвод,"IDСтроки",ТекущиеДанные.IDСтроки);
	КонецЕсли;
	
	ТаблицаПриборыВывод 					= Элементы.Найти("ПриборыУчета" + ПрефиксТочекУчета + "Вывод");
	Если НЕ ТаблицаПриборыВывод = Неопределено Тогда
		энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаПриборыВывод,"IDСтроки",ТекущиеДанные.IDСтроки);
	КонецЕсли;
	
	Если ИспользоватьТарифныеЗоны и НЕ ИспользоватьШкалыПриборовУчета Тогда 
		ПриборыУчетаВыводНеШкалЕстьТарифЗоныПриАктивацииСтроки(Элемент);
		ПриборыУчетаНетШкалЕстьТарифныеЗоныВводПриАктивизацииСтроки(Элемент);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда
		ТекущиеДанные 					= Элементы.ТочкиУчета.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		IDСтрокиТочки 					= Новый УникальныйИдентификатор;
		IDСтрокиТочкиВывод				= Новый УникальныйИдентификатор;
		ТекущиеДанные.IDСтроки 			= IDСтрокиТочки;
		ТекущиеДанные.IDСтрокиВывод 	= IDСтрокиТочкиВывод;
	КонецЕсли; 	
	
КонецПроцедуры

