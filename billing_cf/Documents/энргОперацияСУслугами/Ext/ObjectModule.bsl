КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
		
	Если ДополнительныеСвойства.свойство("ВосстановлениеПоследовательности") тогда
		Возврат;
	КонецЕсли;	
	
	Ответственный = Пользователи.ТекущийПользователь(); 		
	энргРаботаСТочкамиУчетаСервер.УстановитьНаправлениеИспользованияТочекУчетаПоУмолчанию(ТочкиУчета);
	ДополнительныеСвойства.Вставить("ПроверятьСостояниеПоследовательностиВПолеВыборки", Ложь);
	
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
	
	Если НЕ ДополнительныеСвойства.Свойство("НеЗаполнятьДанныеПоПотерям") тогда
		энргРаботаСТочкамиУчетаСервер.ОчиститьДанныеПоПотерям(Потери);
		энргРаботаСТочкамиУчетаСервер.ЗаполнитьДанныеПоПотерям(Потери);
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение И ЕстьПринятыеПоказанияДатойПозже() Тогда  
		Отказ = Истина;
		Комментарий = НСтр("ru = 'В системе зарегистрированы показания со статусом ""Приняты"" датой позже текущего документа'");
		ОбщегоНазначения.СообщитьПользователю(Комментарий);
		ВызватьИсключение Комментарий;
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение И ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги И Не ДополнительныеСвойства.Свойство("НеПроверятьТочкиСОРП") Тогда
 
		Если Документы.энргОперацияСУслугами.ЕстьТочкиСОРП(Дата, Организация, Район, КлючПомещения) Тогда
			Отказ = Истина;
			Комментарий = НСтр("ru = 'У Абонента введено ОРП, проведение данного документа невозможно. Создайте документ ВРП'");
			ОбщегоНазначения.СообщитьПользователю(Комментарий);
			ВызватьИсключение Комментарий;
		КонецЕсли;	
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Документы.энргОперацияСУслугами.ИнициализироватьДанныеДокумента(Ссылка, ДополнительныеСвойства);	
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
 	энргПроведениеСервер.ЗаписатьНаборыЗаписей(ЭтотОбъект);	
	Документы.энргОперацияСУслугами.ИнициализироватьТаблицыДляКонтроля(Ссылка, ДополнительныеСвойства);
	энргПроведениеСервер.ВыполнитьКонтрольРезультатовПроведения(ЭтотОбъект, Отказ);  	
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);			
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Дата, Организация, Район);	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЕстьПринятыеПоказанияДатойПозже()
	
	Если ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги
			Или ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления Тогда
		Возврат Ложь;	
	КонецЕсли;
	
	ПараметрыПроверки = Новый Структура("Дата, Организация, Район, КлючПомещения, Ссылка");
	ЗаполнитьЗначенияСвойств(ПараметрыПроверки, ЭтотОбъект); 
	
	ТЗ = ТочкиУчета.Выгрузить(, "ПриборУчета");	
	Возврат энргРаботаСПоказаниямиПриборовУчетаСервер.ЕстьПринятыеПоказанияДатойПозже(ТЗ.ВыгрузитьКолонку("ПриборУчета"), ПараметрыПроверки);
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли