#Область ПрограммныйИнтерфейс

// Вставляет в дополнительные свойсва массив приборов.
//
Процедура МассивПриборов() Экспорт 
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ссылка",				Ссылка);
	Запрос.УстановитьПараметр("ВыводПрибораУчета",	?(ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги, Истина, Ложь));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргОперацияСУслугами.Ссылка КАК Ссылка,
	|	&ВыводПрибораУчета КАК ВыводПрибораУчета,
	|	""ПоказанияПриборовУчета"" КАК ИмяТабЧасти,
	|	0 КАК Разделитель,
	|	ВЫБОР
	|		КОГДА энргОперацияСУслугами.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ОграничениеРежимаПотребления)
	|			ТОГДА ИСТИНА
	|		КОГДА энргОперацияСУслугами.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоОРП,
	|	ВЫБОР
	|		КОГДА энргОперацияСУслугами.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги)
	|				И энргОперацияСУслугами.ДатаФактическогоСобытия <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности)
	|	КОНЕЦ КАК СостояниеПроведения
	|ПОМЕСТИТЬ ШапкаДокумента
	|ИЗ
	|	Документ.энргОперацияСУслугами КАК энргОперацияСУслугами
	|ГДЕ
	|	энргОперацияСУслугами.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаПриборов.ПриборУчета КАК ПриборУчета,
	|	ШапкаДокумента.ВыводПрибораУчета КАК ВыводПрибораУчета,
	|	ШапкаДокумента.ИмяТабЧасти КАК ИмяТабЧасти,
	|	ШапкаДокумента.Разделитель КАК Разделитель,
	|	ШапкаДокумента.СостояниеПроведения КАК СостояниеПроведения
	|ИЗ
	|	ШапкаДокумента КАК ШапкаДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ТочкиУчета КАК ТаблицаПриборов
	|		ПО ШапкаДокумента.Ссылка = ТаблицаПриборов.Ссылка
	|			И (ТаблицаПриборов.Ссылка = &Ссылка)
	|			И (НЕ ТаблицаПриборов.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|			И (ШапкаДокумента.ЭтоОРП = ЛОЖЬ)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаПриборов.ПриборУчета,
	|	ШапкаДокумента.ВыводПрибораУчета,
	|	ШапкаДокумента.ИмяТабЧасти,
	|	ШапкаДокумента.Разделитель,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ТаблицаПоказанияПриборовУчета.СостояниеПоказаний = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|				ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности)
	|			ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности)
	|		КОНЕЦ)
	|ИЗ
	|	ШапкаДокумента КАК ШапкаДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ТочкиУчета КАК ТаблицаПриборов
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ШкалыПриборовУчета КАК ТаблицаШкалыПриборовУчета
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ПоказанияПриборовУчета КАК ТаблицаПоказанияПриборовУчета
	|				ПО (ТаблицаПоказанияПриборовУчета.Ссылка = &Ссылка)
	|					И ТаблицаШкалыПриборовУчета.Ссылка = ТаблицаПоказанияПриборовУчета.Ссылка
	|					И ТаблицаШкалыПриборовУчета.IDСтроки = ТаблицаПоказанияПриборовУчета.IDСтроки
	|			ПО (ТаблицаШкалыПриборовУчета.Ссылка = &Ссылка)
	|				И ТаблицаПриборов.Ссылка = ТаблицаШкалыПриборовУчета.Ссылка
	|				И ТаблицаПриборов.IDСтроки = ТаблицаШкалыПриборовУчета.IDСтрокиТочкиУчета
	|		ПО ШапкаДокумента.Ссылка = ТаблицаПриборов.Ссылка
	|			И (ТаблицаПриборов.Ссылка = &Ссылка)
	|			И (НЕ ТаблицаПриборов.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|			И (ШапкаДокумента.ЭтоОРП)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаПриборов.ПриборУчета,
	|	ШапкаДокумента.ВыводПрибораУчета,
	|	ШапкаДокумента.ИмяТабЧасти,
	|	ШапкаДокумента.Разделитель";
	
	ДополнительныеСвойства.Вставить("МассивПриборов", Запрос.Выполнить());
	
КонецПроцедуры


// Получает абонентов плательщиков.
// 
// Возвращаемое значение:
//   Массив из Структура.
//
Функция ПолучитьАбонентовПлательщиков() Экспорт
	
	МассивПлательщиков = Новый Массив;
	
	Если Не ЗначениеЗаполнено(ДатаФактическогоСобытия) Тогда
		Возврат МассивПлательщиков;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ссылка",		Ссылка);
	Запрос.УстановитьПараметр("ДатаФакта",	ДатаФактическогоСобытия);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргОперацияСУслугами.Ссылка КАК Ссылка,
	|	энргОперацияСУслугами.ВидОперации КАК ВидОперации,
	|	энргОперацияСУслугами.Абонент КАК Абонент
	|ПОМЕСТИТЬ ШапкаДокумента
	|ИЗ
	|	Документ.энргОперацияСУслугами КАК энргОперацияСУслугами
	|ГДЕ
	|	энргОперацияСУслугами.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаПриборов.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ВТ_ТУ
	|ИЗ
	|	Документ.энргОперацияСУслугами.ТочкиУчета КАК ТаблицаПриборов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК ШапкаДокумента
	|		ПО ТаблицаПриборов.Ссылка = ШапкаДокумента.Ссылка
	|			И (ТаблицаПриборов.Ссылка = &Ссылка)
	|			И (ШапкаДокумента.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСтабильныеПериоды.Плательщик КАК Плательщик,
	|	энргАбоненты.КлючПомещения КАК КлючПомещения
	|ИЗ
	|	РегистрСведений.энргСтабильныеПериоды КАК энргСтабильныеПериоды
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ТУ КАК ВТ_ТУ
	|		ПО энргСтабильныеПериоды.ТочкаУчета = ВТ_ТУ.ТочкаУчета
	|			И (энргСтабильныеПериоды.Плательщик <> ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка))
	|			И (энргСтабильныеПериоды.ПериодНачисления >= &ДатаФакта)
	|			И (энргСтабильныеПериоды.Абонент <> энргСтабильныеПериоды.Плательщик)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|		ПО энргСтабильныеПериоды.Плательщик = энргАбоненты.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	энргСтабильныеПериоды.Плательщик,
	|	энргАбоненты.КлючПомещения
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргОперацияСУслугамиПоставщикиСоставныхУслуг.Плательщик,
	|	энргАбоненты.КлючПомещения
	|ИЗ
	|	Документ.энргОперацияСУслугами.ПоставщикиСоставныхУслуг КАК энргОперацияСУслугамиПоставщикиСоставныхУслуг
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК ШапкаДокумента
	|		ПО энргОперацияСУслугамиПоставщикиСоставныхУслуг.Ссылка = ШапкаДокумента.Ссылка
	|			И (энргОперацияСУслугамиПоставщикиСоставныхУслуг.Ссылка = &Ссылка)
	|			И (ШапкаДокумента.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги))
	|			И (энргОперацияСУслугамиПоставщикиСоставныхУслуг.Плательщик <> ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка))
	|			И энргОперацияСУслугамиПоставщикиСоставныхУслуг.Плательщик <> ШапкаДокумента.Абонент
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|		ПО энргОперацияСУслугамиПоставщикиСоставныхУслуг.Плательщик = энргАбоненты.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	энргОперацияСУслугамиПоставщикиСоставныхУслуг.Плательщик,
	|	энргАбоненты.КлючПомещения";
	
	Результат = Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		МассивПлательщиков.Добавить(Новый Структура("Абонент,КлючПомещения", Результат.Плательщик, Результат.КлючПомещения));
	КонецЦикла;
	
	Возврат МассивПлательщиков;
КонецФункции

#КонецОбласти

