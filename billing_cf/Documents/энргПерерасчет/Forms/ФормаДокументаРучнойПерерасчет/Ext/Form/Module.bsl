&НаКлиенте
Процедура ПересчитатьСумму(ТекущиеДанные = Неопределено)
	ДопЧисло 											= 1;
	Если ТекущиеДанные = Неопределено Тогда
		ТекущиеДанные									= Элементы.ДвиженияэнргОбъемНачислений.ТекущиеДанные;
	КонецЕсли;
	ТекущиеДанные.СуммаПоПовышенномуКоэффициенту		= 0;
	ПовыщающийКоэффициент 								= Макс(1,ТекущиеДанные.ПовыщающийКоэффициент);	
	ТекущиеДанные.Сумма 								= Окр(ТекущиеДанные.ОбъемУслуги * ТекущиеДанные.ЗначениеТарифа,2)  * ДопЧисло * ПовыщающийКоэффициент + Окр(ТекущиеДанные.ОбъемУслугиПотери * ТекущиеДанные.ЗначениеТарифа,2);
	Если ПовыщающийКоэффициент > 1 Тогда
		ТекущиеДанные.СуммаПоПовышенномуКоэффициенту 	= Окр(ТекущиеДанные.ОбъемУслуги * ТекущиеДанные.ЗначениеТарифа,2) * (ПовыщающийКоэффициент - 1);
	КонецЕсли;  		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПриборыУчетаСервер(ТекущиеДанные, УслугиТочекУчета, ПоставщикиУслугТочекУчета, АктивныеТУНаДату = Ложь)
		
	Если АктивныеТУНаДату Тогда
		ПараметрыОтбора					= Новый Структура("ВыбратьТУСрезНаДату", Истина); 
		ПараметрыОтбора					= Новый Структура("ВключаяОРП", Истина); 
	Иначе
		ПараметрыОтбора 				= Неопределено;
	КонецЕсли;
		
	Результат 							= Обработки.энргСостояниеТочекУчетаМенеджер.ДействующиеТочкиИИхПриборы(КонецДня(ТекущиеДанные.ПериодНачисления), Объект.Организация, Объект.Район, Объект.КлючПомещения, ТекущиеДанные.ТочкаУчета, ПараметрыОтбора); 
	СоставнаяУслуга 					= Неопределено;
	ЭтоСоставнаяУслуга					= Ложь;
	мТарифныеЗоны 						= Новый Массив;
	
	Если Не Результат.Пустой() Тогда
		Выборка 						= Результат.Выбрать();
		ЕстьСледующий 					= Выборка.Следующий();
		ЗаполнитьЗначенияСвойств(ТекущиеДанные,Выборка,"ПриборУчета, НаправлениеИспользованияТУ");		
		Если ЗначениеЗаполнено(Выборка.Услуга) Тогда			
			Если Выборка.СоставнаяУслуга Тогда
				СоставнаяУслуга 		= Выборка.Услуга;
				ЭтоСоставнаяУслуга		= Истина;
			Иначе
				СоотвествиеТочкаУчета 	= Новый Соответствие;
				мУслуги 				= Новый Массив;
				мУслуги.Добавить(Выборка.Услуга);
				СоотвествиеТочкаУчета.Вставить(ТекущиеДанные.ТочкаУчета, мУслуги); 		
				УслугиТочекУчета.Вставить(ТекущиеДанные.ПериодНачисления, СоотвествиеТочкаУчета);
				ТекущиеДанные.Услуга 	= Выборка.Услуга;
			КонецЕсли;			
		КонецЕсли;
				
		Если ЗначениеЗаполнено(Выборка.Поставщик) и Не ЭтоСоставнаяУслуга Тогда
			КлючЗначение  				= Новый Соответствие;
			КлючЗначение.Вставить(Выборка.Услуга, Выборка.Поставщик);
			СоотвествиеТочкаУчета 		= Новый Соответствие;
			СоотвествиеТочкаУчета.Вставить(ТекущиеДанные.ТочкаУчета, КлючЗначение); 
			ПоставщикиУслугТочекУчета.Вставить(ТекущиеДанные.ПериодНачисления, СоотвествиеТочкаУчета);
			ТекущиеДанные.Поставщик 	= Выборка.Поставщик;
		КонецЕсли;
		
		Пока ЕстьСледующий Цикл
			мТарифныеЗоны.Добавить(Выборка.ТарифнаяЗона);
			ЕстьСледующий 				= Выборка.Следующий();
		КонецЦикла;	
		
		Если мТарифныеЗоны.Количество() = 1 Тогда
			ТекущиеДанные.тарифнаяЗона 	= мТарифныеЗоны[0];
		КонецЕсли; 	
		
	КонецЕсли; 	
	
	Если НЕ СоставнаяУслуга = Неопределено Тогда
		
		ТекущиеДанные.СоставнаяУслуга	= СоставнаяУслуга;
		
		ПараметрыСоставнойУслуги		= Новый Структура;
		Схема 							= Неопределено;
		ПараметрыВТ 					= Новый Массив;
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("Организация", 	"Организация"), 	Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("Район", 			"Район"), 			Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("КлючПомещения", 	"КлючПомещения"), 	Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("ТочкаУчета", 		"ТочкаУчета"), 		Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраВСписке", 	Новый Структура("Услуга",	 		"Услуги"), 			Неопределено));		
		
		ПараметрыСоставнойУслуги.Вставить("Период", 			Новый Структура("ИмяПараметра", "Период"));
	    ПараметрыСоставнойУслуги.Вставить("ПараметрыВТ", 		ПараметрыВТ);
		
		мЧастиУслуг 					= Новый Массив;
		СоставляющиеУслуги 				= СоставнаяУслуга.СоставляющиеУслуг;
		Для Каждого СтрокаТабЧасти Из  СоставляющиеУслуги Цикл
			мЧастиУслуг.Добавить(СтрокаТабЧасти.Услуга);
		КонецЦикла;
		
		РегистрыСведений.энргПоставщикиУслугАбонента.ПоставщикиСоставнойУслуги(Схема,ПараметрыСоставнойУслуги,"");
		ПараметрыЗапроса 				= Новый Структура;
		ПараметрыЗапроса.Вставить("Организация", 	Объект.Организация);
		ПараметрыЗапроса.Вставить("Район", 			Объект.Район);
		ПараметрыЗапроса.Вставить("КлючПомещения", 	Объект.КлючПомещения);
		ПараметрыЗапроса.Вставить("ТочкаУчета", 	ТекущиеДанные.ТочкаУчета);
		ПараметрыЗапроса.Вставить("Услуги", 		мЧастиУслуг);
		ПараметрыЗапроса.Вставить("Период", 		КонецДня(ТекущиеДанные.ПериодНачисления));
						
		Результат 						= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
		Выборка 						= Результат.Выбрать();
		мУслуги 						= Новый Массив;
		КлючЗначение  					= Новый Соответствие;
		Пока Выборка.Следующий() Цикл
			мУслуги.Добавить(Выборка.Услуга);			
			КлючЗначение.Вставить(Выборка.Услуга, Выборка.Поставщик);			
		КонецЦикла; 
		СоотвествиеТочкаУчета 		= Новый Соответствие;
		СоотвествиеТочкаУчета.Вставить(ТекущиеДанные.ТочкаУчета, КлючЗначение);
		ПоставщикиУслугТочекУчета.Вставить(ТекущиеДанные.ПериодНачисления, СоотвествиеТочкаУчета);
		
		СоотвествиеТочкаУчета 	= Новый Соответствие; 
		СоотвествиеТочкаУчета.Вставить(ТекущиеДанные.ТочкаУчета, мУслуги);
		УслугиТочекУчета.Вставить(ТекущиеДанные.ПериодНачисления, СоотвествиеТочкаУчета);		
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.ТарифнаяЗона) Тогда
		ТекущиеДанные.ТарифнаяЗона = ПредопределенноеЗначение("Справочник.энргТарифныеЗоны.БезРазбивки");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Услуга) И ЗначениеЗаполнено(ТекущиеДанные.Поставщик) и ЗначениеЗаполнено(ТекущиеДанные.ТарифнаяЗона) Тогда
		ТарифнаяЗона 					= ?(НЕ ИспользоватьТарифныеЗоны, ПредопределенноеЗначение("Справочник.энргТарифныеЗоны.БезРазбивки"), ТекущиеДанные.ТарифнаяЗона);
		ЗначенияТарифа 						= энргРаботаСПоставщикамиСервер.ЗначенияТарифаПомещения(Объект.Организация, Объект.Район, Объект.КлючПомещения, ТекущиеДанные.Услуга, ТекущиеДанные.Поставщик, ТарифнаяЗона, ТекущиеДанные.ПериодНачисления);
		ТекущиеДанные.ЗначениеТарифа 		= ЗначенияТарифа.Значение;
		ТекущиеДанные.ВидБлагоустройства	= ЗначенияТарифа.ВидБлагоустройства;
		ТекущиеДанные.ЗначениеТарифаРЭК		= ЗначенияТарифа.ЗначениеРЭК;
		ТекущиеДанные.ТарифнаяГруппа		= ЗначенияТарифа.ГруппаПотребителей;
		ТекущиеДанные.Сумма					= ТекущиеДанные.ЗначениеТарифа * ТекущиеДанные.ОбъемУслуги;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьТаблицыОбъемовНачислений()
	Элементы.ОбъемНачисленийРучнойПерерасчет.Видимость = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргПерерасчет_РучнойПерерасчет");
	Элементы.ОбъемНачисленийБлокировочныйАкт.Видимость = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргПерерасчет_БлокировочныйАкт");
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииУслугиПоставщикаТарЗоны(ТекущиеДанные)
	Если Не ЗначениеЗаполнено(ТекущиеДанные.ТарифнаяЗона) Тогда
		ТекущиеДанные.ТарифнаяЗона = ПредопределенноеЗначение("Справочник.энргТарифныеЗоны.БезРазбивки");
	КонецЕсли;
	Если ЗначениеЗаполнено(ТекущиеДанные.Услуга) И ЗначениеЗаполнено(ТекущиеДанные.Поставщик) и (ЗначениеЗаполнено(ТекущиеДанные.ТарифнаяЗона) ИЛИ НЕ ИспользоватьТарифныеЗоны) Тогда
		СтруктураСтроки = Новый Структура("Организация, Район, Абонент, ПериодНачисления, КлючПомещения, ТочкаУчета, Услуга, СоставнаяУслуга, Поставщик, ТарифнаяЗона");
		ЗаполнитьЗначенияСвойств(СтруктураСтроки, ТекущиеДанные);
		ЗаполнитьЗначенияСвойств(СтруктураСтроки, Объект, "Организация,Район,Абонент,ПериодНачисления,КлючПомещения");
		// При ручном перерасчете для получения значения тарифа должен использоваться период начисления строки
		Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргПерерасчет_РучнойПерерасчет") Тогда
			ЗаполнитьЗначенияСвойств(СтруктураСтроки, ТекущиеДанные, "ПериодНачисления");	
		КонецЕсли;
		
		ЗначенияТарифаНорматива = ПриИзмененииУслугиПоставщикаТарЗоныНаСервере(СтруктураСтроки, ИспользоватьТарифныеЗоны);
		ЗаполнитьЗначенияСвойств(ТекущиеДанные,ЗначенияТарифаНорматива);
		
		ПересчитатьСумму(ТекущиеДанные);
		
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПриИзмененииУслугиПоставщикаТарЗоныНаСервере(СтруктураСтроки, ИспользоватьТарифныеЗоны)
	ТарифнаяЗона	= ?(НЕ ИспользоватьТарифныеЗоны,Справочники.энргТарифныеЗоны.БезРазбивки, СтруктураСтроки.ТарифнаяЗона);
	СтруктураТарифа	= энргРаботаСПоставщикамиСервер.ЗначенияТарифаПомещения(СтруктураСтроки.Организация, СтруктураСтроки.Район, СтруктураСтроки.КлючПомещения, СтруктураСтроки.Услуга, СтруктураСтроки.Поставщик, СтруктураСтроки.ТарифнаяЗона, КонецМесяца(СтруктураСтроки.ПериодНачисления));
	
	СтруктураНорматива = Документы.энргПерерасчет.ЗначенияНормативаТУ(СтруктураСтроки, СтруктураТарифа);
	
	СтруктураТарифа.Вставить("НормаПотребления", 	СтруктураНорматива.ЗначениеНорматива);
	СтруктураТарифа.Вставить("КлючНорматива",		СтруктураНорматива.КлючНорматива);
	СтруктураТарифа.Вставить("ЗначениеТарифа", 		СтруктураТарифа.Значение);
	СтруктураТарифа.Вставить("ЗначениеТарифаРЭК",	СтруктураТарифа.ЗначениеРЭК);
	СтруктураТарифа.Вставить("ТарифнаяГруппа",		СтруктураТарифа.ГруппаПотребителей);

	СтруктураТарифа.Удалить("Значение");
	СтруктураТарифа.Удалить("ЗначениеРЭК");
	СтруктураТарифа.Удалить("ГруппаПотребителей");
	
	Возврат СтруктураТарифа;
	
КонецФункции

&НаКлиенте
Процедура ТочкаУчетаПриИзменении(ТекущаяСтрока, ЭтоБокАкт)
	ТочкаУчетаПриИзмененииНаСервере(ТекущаяСтрока, УслугиТочекУчета, ПоставщикиУслугТочекУчета, ЭтоБокАкт);	
КонецПроцедуры

&НаСервере
Процедура ТочкаУчетаПриИзмененииНаСервере(ТекущаяСтрока, УслугиТочекУчета, ПоставщикиУслугТочекУчета, ЭтоБокАкт)
	
	Если ЭтоБокАкт Тогда		
		АктивныеТУНаДату 	= Ложь;
		ТекущиеДанные		= Объект.ДанныеБлокировочногоАкта.НайтиПоИдентификатору(ТекущаяСтрока);		
	Иначе 		
		АктивныеТУНаДату 	= Истина;
		ТекущиеДанные		= Объект.Движения.энргОбъемНачислений.НайтиПоИдентификатору(ТекущаяСтрока);		
	КонецЕсли;	
	
	ЗаполнитьПриборыУчетаСервер(ТекущиеДанные, УслугиТочекУчета, ПоставщикиУслугТочекУчета, АктивныеТУНаДату);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеКлючаПомещения(Знач ДанныеПомещенияРезультат)
	
	Перем ДанныеПомещенияВыборка;
	
	Если Не ДанныеПомещенияРезультат.Пустой() Тогда
		ДанныеПомещенияВыборка  = ДанныеПомещенияРезультат.Выбрать();
		ДанныеПомещенияВыборка.Следующий();
		ЗаполнитьЗначенияСвойств(ЭтаФорма,ДанныеПомещенияВыборка,"Строение,Помещение,ЧастныйСектор");
	КонецЕсли;

КонецПроцедуры

&НаСервере 
Процедура ПроверитьПраваДокументаПерерасчет(Отказ) 
	
	ЕстьПравоЧтение = Документы.энргПерерасчет.ПроверитьПравоДляДокумента(Объект.ВидОперации, "Чтение"); 
	ЕстьПравоИзменение = Документы.энргПерерасчет.ПроверитьПравоДляДокумента(Объект.ВидОперации, "Изменение");
	Если Не ЕстьПравоИзменение И (Не ЕстьПравоЧтение Или ЕстьПравоЧтение И Не ЗначениеЗаполнено(Объект.Ссылка)) Тогда
		Отказ = Истина;
		ВызватьИсключение "Нарушение прав доступа";
	КонецЕсли;
	ЭтотОбъект.ТолькоПросмотр = ЕстьПравоЧтение И Не ЕстьПравоИзменение;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПодменюСоздатьНаОсновании", "Доступность", Не ЭтотОбъект.ТолькоПросмотр);	
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаУдаленияСтроки(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения(ДопПараметры.ИмяПроцедуры,ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Удалить всю строку вместо значения ячейки?",РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросУдаленияСтроки(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	энргОбъемНачислений = Объект.Движения.энргОбъемНачислений;	
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			энргОбъемНачислений.Удалить(ДополнительныеПараметры.НомерСтроки);
		КонецЕсли;		
	КонецЕсли;	
КонецПроцедуры

#КонецОбласти