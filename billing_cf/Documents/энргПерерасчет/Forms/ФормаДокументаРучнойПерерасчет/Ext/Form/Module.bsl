	//	ТарифнаяЗона 					= ?(НЕ ИспользоватьТарифныеЗоны, ПредопределенноеЗначение("Справочник.энргТарифныеЗоны.БезРазбивки"), ТекущиеДанные.ТарифнаяЗона);
	//	ЗначениеТарифа 					= энргРаботаСПоставщикамиСервер.ЗначениеТарифаПомещения(Объект.Организация, Объект.Район, Объект.КлючПомещения, ТекущиеДанные.Услуга, ТекущиеДанные.Поставщик, ТарифнаяЗона);
	//	ТекущиеДанные.ЗначениеТарифа 	= ЗначениеТарифа;
