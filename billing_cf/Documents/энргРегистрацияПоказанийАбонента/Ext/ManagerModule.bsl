Процедура УстановитьПометкуУдаленияПоказанийПоДокументуОснованию(ДокументОснование, ПризнакПометки = Истина) Экспорт 

	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда 
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(1, "Отмена документов показаний");
	
	ПовторнаяОтмена = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргРегистрацияПоказанийАбонента.Ссылка КАК Ссылка,
		|	энргРегистрацияПоказанийАбонента.ДокументОснование КАК ДокументОснование
		|ИЗ
		|	Документ.энргРегистрацияПоказанийАбонента КАК энргРегистрацияПоказанийАбонента
		|ГДЕ
		|	энргРегистрацияПоказанийАбонента.ДокументОснование = &ДокументОснование
		|	И НЕ энргРегистрацияПоказанийАбонента.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Всего = Выборка.Количество();
	Счетчик = 0;
	КоличествоИтераций = Счетчик;
	КолвоСообщений = Цел(Всего / 15);
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ЗначениеЗаполнено(Выборка.ДокументОснование) Тогда 
			Продолжить;
		КонецЕсли;
		
		Если КоличествоИтераций = КолвоСообщений Тогда
			Процент = Цел(Счетчик / Всего * 100);
			ДлительныеОперации.СообщитьПрогресс(Процент, "Отменено документов показаний " + Счетчик + " из " + Всего);
			КоличествоИтераций = 0;
		КонецЕсли; 		
		
		УстановитьПометкуУдаленияПоказаний(Выборка.Ссылка, ПовторнаяОтмена, ПризнакПометки);
		
		Счетчик = Счетчик + 1;
		КоличествоИтераций = КоличествоИтераций + 1;
				
	КонецЦикла;	
	
	Для Каждого ДокументСсылка из ПовторнаяОтмена Цикл 
		УстановитьПометкуУдаленияПоказаний(ДокументСсылка,, ПризнакПометки);
	КонецЦикла; 	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьТекстЗапросаПоказанияПриборовУчета(Схема, Регистры) 
	
	ИмяРегистра 	= "энргПоказанияПриборовУчета";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  		= 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Период КАК Период,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.Шкала КАК Шкала,
	|	ТаблицаПоказанияПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	|	0 КАК Разделитель,
	|	ВЫБОР
	|		КОГДА энргПриборыУчетаАбонента.РегистрируетОбъем
	|			ТОГДА ТаблицаПоказанияПриборовУчета.Разница
	|		ИНАЧЕ ТаблицаПоказанияПриборовУчета.ТекущиеПоказания
	|	КОНЕЦ КАК Показание,
	|	ТаблицаПоказанияПриборовУчета.СостояниеПоказаний КАК СостояниеПоказаний,
	|	ВложенныйЗапрос.ИсточникПоказаний = ЗНАЧЕНИЕ(Справочник.энргИсточникиПоказаний.КонтрольныйСъем) КАК КС,
	|	ВложенныйЗапрос.ИсточникПоказаний КАК ИсточникПоказаний,
	|	ТаблицаПоказанияПриборовУчета.Переворот КАК Переворот,
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.ПериодРегистрации КАК ПериодРегистрации,
	|	ТаблицаПоказанияПриборовУчета.НомерСтроки КАК НомерСтрокиТЧ,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ТаблицаПоказанияПриборовУчета.ПричинаОтклонения КАК ПричинаОтклонения
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.Период КАК Период,
	|		ВложенныйЗапрос.Организация КАК Организация,
	|		ВложенныйЗапрос.Район КАК Район,
	|		ВложенныйЗапрос.ИсточникПоказаний КАК ИсточникПоказаний,
	|		ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		ВложенныйЗапрос.Состояние КАК Состояние,
	|		ВложенныйЗапрос.ПериодРегистрации КАК ПериодРегистрации,
	|		ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|		ВложенныйЗапрос.IDСтрокиТочкиУчета КАК IDСтрокиТочкиУчета,
	|		ВложенныйЗапрос.Регистратор КАК Регистратор,
	|		ТаблицаШкалы.IDСтроки КАК IDСтроки,
	|		ТаблицаШкалы.Шкала КАК Шкала
	|	ИЗ
	|		(ВЫБРАТЬ
	|			Шапка.Дата КАК Период,
	|			Шапка.Организация КАК Организация,
	|			Шапка.Район КАК Район,
	|			Шапка.ИсточникПоказаний КАК ИсточникПоказаний,
	|			Шапка.КлючПомещения КАК КлючПомещения,
	|			ТаблицаТочки.ТочкаУчета КАК ТочкаУчета,
	|			ТаблицаТочки.ПриборУчета КАК ПриборУчета,
	|			ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод) КАК Состояние,
	|			Шапка.Дата КАК ПериодРегистрации,
	|			Шапка.ПериодНачисления КАК ПериодНачисления,
	|			ТаблицаТочки.IDСтроки КАК IDСтрокиТочкиУчета,
	|			Шапка.Ссылка КАК Регистратор
	|		ИЗ
	|			Документ.энргРегистрацияПоказанийАбонента КАК Шапка
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргРегистрацияПоказанийАбонента.ТочкиУчета КАК ТаблицаТочки
	|				ПО Шапка.Ссылка = ТаблицаТочки.Ссылка
	|					И (Шапка.Ссылка В (&мДокументы))
	|					И (ТаблицаТочки.Ссылка В (&мДокументы))
	|					И (НЕ ТаблицаТочки.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргРегистрацияПоказанийАбонента.ШкалыПриборовУчета КАК ТаблицаШкалы
	|			ПО ВложенныйЗапрос.Регистратор = ТаблицаШкалы.Ссылка
	|				И ВложенныйЗапрос.IDСтрокиТочкиУчета = ТаблицаШкалы.IDСтрокиТочкиУчета) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргРегистрацияПоказанийАбонента.ПоказанияПриборовУчета КАК ТаблицаПоказанияПриборовУчета
	|		ПО ВложенныйЗапрос.Регистратор = ТаблицаПоказанияПриборовУчета.Ссылка
	|			И ВложенныйЗапрос.IDСтроки = ТаблицаПоказанияПриборовУчета.IDСтроки
	//|			И (ВЫБОР
	//|				КОГДА ТаблицаПоказанияПриборовУчета.СтатусИзмененПользователем
	//|						ИЛИ ТаблицаПоказанияПриборовУчета.ПереворотИзмененПользователем
	//|					ТОГДА ИСТИНА
	//|				ИНАЧЕ НЕ ТаблицаПоказанияПриборовУчета.ПричинаОтклонения В (&ПричиныОтклоненияИсключая)
	//|			КОНЕЦ)
	|			И (ТаблицаПоказанияПриборовУчета.ПоказанияПредоставлены)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ВложенныйЗапрос.ПриборУчета = энргПриборыУчетаАбонента.Ссылка"; 	
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

Процедура УстановитьЗависимыеРеквизиты(ДокументСсылка, ЗависимыеРеквизиты, ЗависимыеПоляПерезаписи, ПовторнаяЗапись = Неопределено)
	
	Попытка
		
		ДокОбъект = ДокументСсылка.ПолучитьОбъект();
		ЗаполнитьЗначенияСвойств(ДокОбъект, ЗависимыеРеквизиты, ЗависимыеПоляПерезаписи);
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
	Исключение
		
		Если НЕ ПовторнаяЗапись = Неопределено Тогда 
			ПовторнаяЗапись.Добавить(ДокументСсылка);
		КонецЕсли;
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ПровестиДокумент(ДокументСсылка, ПовторнаяЗапись = Неопределено)
	
	Попытка
		
		ДокОбъект = ДокументСсылка.ПолучитьОбъект();
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
	Исключение
		
		Если НЕ ПовторнаяЗапись = Неопределено Тогда 
			ПовторнаяЗапись.Добавить(ДокументСсылка);
		КонецЕсли;
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ОтменитьПроведениеДокумента(ДокументСсылка, ПовторнаяЗапись = Неопределено)
	
	Попытка
		
		ДокОбъект = ДокументСсылка.ПолучитьОбъект();
		ДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		
	Исключение
		
		Если НЕ ПовторнаяЗапись = Неопределено Тогда 
			ПовторнаяЗапись.Добавить(ДокументСсылка);
		КонецЕсли;
		
	КонецПопытки; 	
	
КонецПроцедуры

Процедура УстановитьПометкуУдаленияПоказаний(ДокументСсылка, ПовторнаяЗапись = Неопределено, ПризнакПометки = Истина)
	
	Попытка
		
		ДокОбъект = ДокументСсылка.ПолучитьОбъект();
		ДокОбъект.УстановитьПометкуУдаления(ПризнакПометки);		
			
	Исключение
		
		Если НЕ ПовторнаяЗапись = Неопределено Тогда 
			ПовторнаяЗапись.Добавить(ДокументСсылка);
		КонецЕсли;
		
	КонецПопытки; 	
	
КонецПроцедуры

