// Заполняет список команд отчетов.
// 
// Параметры:
//   КомандыОтчетов - ТаблицаЗначений - состав полей см. в функции МенюОтчеты.СоздатьКоллекциюКомандОтчетов.
//   Параметры		- Структура передаваемых параметров.
//
Процедура ДобавитьКомандыОтчетов(КомандыОтчетов, Параметры= Неопределено) Экспорт
	энргВариантыОтчетовПереопределяемый.ДобавитьКомандуСтруктураПодчиненности(КомандыОтчетов);		
КонецПроцедуры

// Проверяет необходимо ли скорректировать связанные документы.
//
// Параметры:
//  ДокументОснование	-	ДокументСсылка.энргЗагрузкаПоказанийИзВнешнихИсточников, ДокументСсылка.энргЗагрузкаДанныхИзВнешнихИсточников, 
//  						ДокументСсылка.энргПлатежноеПоручениеВходящие, ДокументСсылка.энргОбходнойЛист, ДокументСсылка.энргПриходныйКассовыйОрдер, 
//  						ДокументСсылка.энргМассовыйВводПоказаний.
// 
//  ЗависимыеРеквизиты	-	Структура	-	см Документ.энргЗагрузкаДанныхИзВнешнихИсточников.ПолучитьЗависимыеРеквизиты.
// 
// Возвращаемое значение:
//   Булево.
//
Функция НеобходимоСкорректироватьСвязанныеДокументы(ДокументОснование, ЗависимыеРеквизиты) Экспорт 

	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	энргРегистрацияПоказанийАбонента.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.энргРегистрацияПоказанийАбонента КАК энргРегистрацияПоказанийАбонента
		|ГДЕ
		|	энргРегистрацияПоказанийАбонента.ДокументОснование = &ДокументОснование
		|	И НЕ энргРегистрацияПоказанийАбонента.Дата = &Дата
		|	И энргРегистрацияПоказанийАбонента.Проведен";
	
	Запрос.УстановитьПараметр("Дата", ЗависимыеРеквизиты.Дата);
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат НЕ РезультатЗапроса.Пустой();
	
КонецФункции

// Получает дату от связанных документов показаний.
//
// Параметры:
//  ДокументОснование		-	ДокументСсылка.энргЗагрузкаПоказанийИзВнешнихИсточников, ДокументСсылка.энргЗагрузкаДанныхИзВнешнихИсточников, 
//  							ДокументСсылка.энргПлатежноеПоручениеВходящие, ДокументСсылка.энргОбходнойЛист, ДокументСсылка.энргПриходныйКассовыйОрдер, 
//  							ДокументСсылка.энргМассовыйВводПоказаний.
//  ТекущаяДатаДокумента	-	Дата.
// 
// Возвращаемое значение:
//   Дата.
//
Функция ПолучитьДатуОтСвязанныхДокументовПоказаний(ДокументОснование, ТекущаяДатаДокумента) Экспорт 
	
	Результат = ТекущаяДатаДокумента;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	энргРегистрацияПоказанийАбонента.Дата КАК Дата
		|ИЗ
		|	Документ.энргРегистрацияПоказанийАбонента КАК энргРегистрацияПоказанийАбонента
		|ГДЕ
		|	энргРегистрацияПоказанийАбонента.ДокументОснование = &ДокументОснование
		|	И энргРегистрацияПоказанийАбонента.Проведен";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат Результат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Результат = Выборка.Дата;
	
	Возврат Результат;
	
КонецФункции

// Проверяет есть ли созданные регистрации показаний от документа основания.
//
// Параметры:
//  ДокументОснование	-	ДокументСсылка.энргЗагрузкаПоказанийИзВнешнихИсточников, ДокументСсылка.энргЗагрузкаДанныхИзВнешнихИсточников, 
//  						ДокументСсылка.энргПлатежноеПоручениеВходящие, ДокументСсылка.энргОбходнойЛист, ДокументСсылка.энргПриходныйКассовыйОрдер, 
//  						ДокументСсылка.энргМассовыйВводПоказаний.
// 
// Возвращаемое значение:
//   Булево.
//
Функция ЕстьСозданныеРегистрацииПоказанийОтДокументаОснования(ДокументОснование) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	энргРегистрацияПоказанийАбонента.Дата КАК Дата
		|ИЗ
		|	Документ.энргРегистрацияПоказанийАбонента КАК энргРегистрацияПоказанийАбонента
		|ГДЕ
		|	энргРегистрацияПоказанийАбонента.ДокументОснование = &ДокументОснование
		|	И НЕ энргРегистрацияПоказанийАбонента.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);	
	РезультатЗапроса = Запрос.Выполнить();
	Результат = НЕ РезультатЗапроса.Пустой();
	
	Возврат Результат; 	
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ДобавитьКомандыСозданияНаОсновании(КомандыСоздатьНаОсновании) Экспорт

	Документы.энргПриходныйКассовыйОрдер.ДобавитьКомандуСоздатьНаОсновании(КомандыСоздатьНаОсновании);  	
		
КонецПроцедуры

Процедура ДобавитьКомандуСоздатьНаОсновании(КомандыСоздатьНаОсновании) Экспорт 
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.энргРегистрацияПоказанийАбонента) Тогда
		КомандаСоздатьНаОсновании 					= КомандыСоздатьНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Идентификатор 	= Метаданные.Документы.энргРегистрацияПоказанийАбонента.ПолноеИмя();
		КомандаСоздатьНаОсновании.Представление 	= НСтр("ru = 'Регистрация показаний'");
		КомандаСоздатьНаОсновании.ПроверкаПроведенияПередСозданиемНаОсновании = Истина;
	КонецЕсли;

КонецПроцедуры

Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
	
	ПараметрыЗапроса  	= Новый Структура;
	Схема 				= Неопределено;
	
	ДобавитьТекстЗапросаПоказанияПриборовУчета(Схема, Регистры);
	
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		ВспомогательныеПараметры 	= Новый Структура;
		энргФормированиеТекстовЗапроса.УстановитьПерехватОбращенияКТаблицам(Схема, ДополнительныеСвойства.ТаблицыПодмены, ВспомогательныеПараметры); 
	КонецЕсли;
	
	КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);	
	ПричиныОтклоненияИсключая 		= Новый Массив;//энргРаботаСПоказаниямиПриборовУчетаСервер.ПричиныОтклоненияИсключая();
	
	ПараметрыЗапроса 				= Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы", ДокументСсылка);
	ПараметрыПроведения = ДополнительныеСвойства.ПараметрыПроведения;
	ПараметрыЗапроса.Вставить("ПричиныОтклоненияИсключая",ПричиныОтклоненияИсключая);
		
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		энргСхемаЗапросаСервер.ВыполнитьПакет(Схема, ПараметрыЗапроса));
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

Процедура УстановитьЗависимыеРеквизитыОтДокументаОснования(ДокументОснование, ЗависимыеРеквизиты, Контекст = Неопределено) Экспорт

	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда 
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(1, "Корректировка документов показаний");
	
	ЗависимыеПоляПерезаписиПоУмолчанию = "Дата,ПериодНачисления";
	ЗависимыеПоляПерезаписи = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Контекст, "ЗависимыеПоляПерезаписи", ЗависимыеПоляПерезаписиПоУмолчанию);
	
	ПовторноеПроведение = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргРегистрацияПоказанийАбонента.Ссылка КАК Ссылка,
	|	энргРегистрацияПоказанийАбонента.ДокументОснование КАК ДокументОснование
	|ИЗ
	|	Документ.энргРегистрацияПоказанийАбонента КАК энргРегистрацияПоказанийАбонента
	|ГДЕ
	|	энргРегистрацияПоказанийАбонента.ДокументОснование = &ДокументОснование
	|	И энргРегистрацияПоказанийАбонента.Проведен";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать(); 
	Всего = Выборка.Количество();
	Счетчик = 0;
	КоличествоИтераций = Счетчик;
	КолвоСообщений = Цел(Всего / 15);
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ЗначениеЗаполнено(Выборка.ДокументОснование) Тогда 
			Продолжить;
		КонецЕсли;
		
		Если КоличествоИтераций = КолвоСообщений Тогда
			Процент = Цел(Счетчик / Всего * 100);
			ДлительныеОперации.СообщитьПрогресс(Процент, "Скорректировано показаний " + Счетчик + " из " + Всего);
			КоличествоИтераций = 0;
		КонецЕсли;
		
		УстановитьЗависимыеРеквизиты(Выборка.Ссылка, ЗависимыеРеквизиты, ЗависимыеПоляПерезаписи, ПовторноеПроведение);
		
		Счетчик = Счетчик + 1;
		КоличествоИтераций = КоличествоИтераций + 1;
		
	КонецЦикла;	
	
	Для Каждого ДокументСсылка из ПовторноеПроведение Цикл 
		УстановитьЗависимыеРеквизиты(ДокументСсылка, ЗависимыеРеквизиты, ЗависимыеПоляПерезаписи, ПовторноеПроведение)
	КонецЦикла;
	
КонецПроцедуры

Процедура ПровестиДокументыПоДокументуОснованию(ДокументОснование) Экспорт
	 
	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда 
		Возврат;
	КонецЕсли;
	
	ПовторноеПроведение = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргРегистрацияПоказанийАбонента.Ссылка КАК Ссылка,
	|	энргРегистрацияПоказанийАбонента.ДокументОснование КАК ДокументОснование
	|ИЗ
	|	Документ.энргРегистрацияПоказанийАбонента КАК энргРегистрацияПоказанийАбонента
	|ГДЕ
	|	энргРегистрацияПоказанийАбонента.ДокументОснование = &ДокументОснование
	|	И НЕ энргРегистрацияПоказанийАбонента.Проведен
	|	И НЕ энргРегистрацияПоказанийАбонента.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать(); 
	Всего = Выборка.Количество();
	Счетчик = 0;
	КоличествоИтераций = Счетчик;
	КолвоСообщений = Цел(Всего / 15);
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ЗначениеЗаполнено(Выборка.ДокументОснование) Тогда 
			Продолжить;
		КонецЕсли;
		
		Если КоличествоИтераций = КолвоСообщений Тогда
			Процент = Цел(Счетчик / Всего * 100);
			ДлительныеОперации.СообщитьПрогресс(Процент, "Проведено " + Счетчик + " из " + Всего);
			КоличествоИтераций = 0;
		КонецЕсли;
		
		ПровестиДокумент(Выборка.Ссылка, ПовторноеПроведение);
		
		Счетчик = Счетчик + 1;
		КоличествоИтераций = КоличествоИтераций + 1;
		
	КонецЦикла;	
	
	Для Каждого ДокументСсылка из ПовторноеПроведение Цикл 
		ПровестиДокумент(ДокументСсылка);
	КонецЦикла;	
	
КонецПроцедуры

Процедура ОтменитьПроведениеДокументовПоДокументуОснованию(ДокументОснование) Экспорт 

