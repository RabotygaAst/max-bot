&НаКлиенте
Процедура ТочкиУчетаПриИзменении(Элемент)
	
	ТекущиеДанные 				= Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда 
		Возврат; 
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ТочкаУчета) Тогда
		ТекущиеДанные.Услуга  	= энргРаботаСТочкамиУчетаСервер.УслугаТочкиУчетаМКД(Объект.Организация,Объект.Район,Объект.МКД,ТекущиеДанные.ТочкаУчета,Объект.Дата);
		
		ДанныеУзлаУчета 		= ВернутьУзелУчета(ТекущиеДанные.ТочкаУчета);
		ЗаполнитьЗначенияСвойств(ТекущиеДанные,ДанныеУзлаУчета);
	Иначе
		ТекущиеДанные.Услуга 	= ПредопределенноеЗначение("Справочник.энргВидыУслуг.ПустаяСсылка");		
	КонецЕсли;

	
	
КонецПроцедуры

&НаСервере
Функция ВернутьУзелУчета(ТочкаУчета)  	
	
	Ответ = Новый Структура("ПриборУчета,ТипУзлаУчета",Справочники.энргПриборыУчетаАбонента.ПустаяСсылка(),Справочники.энргТипыПриборовУчета.ПустаяСсылка());
	
	Запрос = Новый Запрос;	
	Запрос.УстановитьПараметр("Организация",	Объект.Организация);
	Запрос.УстановитьПараметр("Район",			Объект.Район);
	Запрос.УстановитьПараметр("МКД",			Объект.МКД);	
	Запрос.УстановитьПараметр("ТочкаУчета",		ТочкаУчета);
	Запрос.УстановитьПараметр("Период",			?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия),КонецДня(Объект.ДатаФактическогоСобытия),Объект.Дата));
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргПриборыТочекМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
		|	энргПриборыТочекМКДСрезПоследних.ПриборУчета.ТипУзлаУчета КАК ТипУзлаУчета
		|ИЗ
		|	РегистрСведений.энргПриборыТочекМКД.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И МКД = &МКД
		|				И ТочкаУчета = &ТочкаУчета) КАК энргПриборыТочекМКДСрезПоследних";
	
	РезультатЗапроса 	= Запрос.Выполнить(); 	
	Выборка 			= РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Ответ,Выборка); 		
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

