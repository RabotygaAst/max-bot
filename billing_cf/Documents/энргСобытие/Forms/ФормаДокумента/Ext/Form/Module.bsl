		//	//Область = УправлениеПечатьюMSWordКлиент.ПолучитьОбластьМакетаMSWord(Макет, "СерединаДокумента");
		//	//Область_ = УправлениеПечатьюMSWordКлиент.ПрисоединитьОбласть(Документ, Область, , Ложь);
		//	//
		//	//Для каждого СтрокаОплаты Из ДанныеДляПечати.ТаблицаОплат Цикл
		//	
		//	Область = УправлениеПечатьюMSWordКлиент.ПолучитьОбластьМакетаMSWord(Макет, "Оплаты");
		//	Область_ = УправлениеПечатьюMSWordКлиент.ПрисоединитьОбласть(Документ, Область, , Ложь);
		//	УправлениеПечатьюMSWordКлиент.ЗаполнитьПараметры(Область_, ДанныеДляПечати);
