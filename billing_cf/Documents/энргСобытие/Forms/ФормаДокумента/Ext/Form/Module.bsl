&НаСервереБезКонтекста
Функция СудебноеУчреждение(Основание)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 
			|	отэкСудебныеУчастки.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.энргСудебныеУчастки.Строения КАК отэкСудебныеУчасткиСтроения
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСудебныеУчастки КАК отэкСудебныеУчастки
			|		ПО отэкСудебныеУчасткиСтроения.Ссылка = отэкСудебныеУчастки.Ссылка
			|ГДЕ
			|	отэкСудебныеУчасткиСтроения.Строение = &Строение
			|";
	
	Запрос.УстановитьПараметр("Строение",Основание.Мкд);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		
		Возврат Результат.Ссылка;
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;	
	
КонецФункции	

&НаСервереБезКонтекста
Функция ДополнитьИнформациейОСуде(Ссылка,ДанныеДляПечати)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	энргСобытиеПараметры.Значение КАК Значение,
	               |	ВЫБОР
	               |		КОГДА энргСобытиеПараметры.Значение ССЫЛКА Справочник.энргСуды
	               |			ТОГДА отэкСудыКонтактнаяИнформация.Представление
	               |		ИНАЧЕ отэкСудебныеУчасткиКонтактнаяИнформация.Представление
	               |	КОНЕЦ КАК Адрес
	               |ИЗ
	               |	Документ.энргСобытие.Параметры КАК энргСобытиеПараметры
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСудебныеУчастки.КонтактнаяИнформация КАК отэкСудебныеУчасткиКонтактнаяИнформация
	               |		ПО энргСобытиеПараметры.Значение = отэкСудебныеУчасткиКонтактнаяИнформация.Ссылка
	               |			И (отэкСудебныеУчасткиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес))
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСуды.КонтактнаяИнформация КАК отэкСудыКонтактнаяИнформация
	               |		ПО энргСобытиеПараметры.Значение = отэкСудыКонтактнаяИнформация.Ссылка
	               |			И (отэкСудыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес))
	               |ГДЕ
	               |	энргСобытиеПараметры.Параметр = &Параметр
	               |	И энргСобытиеПараметры.Ссылка = &Ссылка";
			 
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Параметр", ПланыВидовХарактеристик.бестПараметрыТиповСобытий.Суд_СудебныйУчасток);
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		
		
		ДанныеДляПечати.Вставить ("СудДляПечатиАдрес", Результат.Адрес);
		Если ТипЗнч(Результат.Значение) = Тип("СправочникСсылка.энргСудебныеУчастки") Тогда
		    ДанныеДляПечати.Вставить ("СудДляПечати", "Мировому судье " + ПолучитьСклоненияСтроки(Результат.Значение.Наименование, 
                                  ,"ПД=Родительный")[0]);
			ДанныеДляПечати.Вставить ("Судья",Результат.Значение.Судья.Наименование);
		Иначе
			ДанныеДляПечати.Вставить ("СудДляПечати", Результат.Значение.Наименование); 
			Если Результат.Значение.Судьи.Количество() <> 0 Тогда
				ДанныеДляПечати.Вставить ("Судья",Результат.Значение.Судьи[0].Судья.Наименование);
			Иначе
				ДанныеДляПечати.Вставить ("Судья","");
			КонецЕсли;	
		КонецЕсли;	
	Иначе	
		
		ДанныеДляПечати.Вставить ("СудДляПечати", "");
		ДанныеДляПечати.Вставить ("СудДляПечатиАдрес","");
		ДанныеДляПечати.Вставить ("Судья","");
		
	КонецЕсли;	
	
	Возврат ДанныеДляПечати;
	
КонецФункции	

&НаКлиенте
Процедура ФормированиеЗаявления(Команда)
	
	Для каждого ТекСтрокаТЧ Из Объект.Абоненты Цикл
		Если Не ЗначениеЗаполнено(ТекСтрокаТЧ.Основание) Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеДляПечати = ПолучитьПараметрыПечатиЗаявлениеИсполнительногоДокумента(ТекСтрокаТЧ.Основание);
		ДанныеДляПечати = ДополнитьИнформациейОСуде(Объект.Ссылка,ДанныеДляПечати);
		
		Адрес = ПечатьЗаявленияИсполнительногоДокумента();
		
		Если Адрес = Неопределено Тогда
			Продолжить;
		КонецЕсли;
			
		ДвоичныеДанныеМакета = ПолучитьИзВременногоХранилища(Адрес);
		
		#Если ВебКлиент Тогда
			ВременныйКаталог 	= УправлениеПечатьюСлужебныйКлиент.СоздатьВременныйКаталог("MSWord");
			ИмяВременногоФайла 	= ВременныйКаталог + Строка(Новый УникальныйИдентификатор) + ".tmp";
		#Иначе
			ИмяВременногоФайла 	= ПолучитьИмяВременногоФайла("docx");
		#КонецЕсли
		
		Макет = УправлениеПечатьюMSWordКлиент.ПолучитьМакетMSWord(ДвоичныеДанныеМакета, ИмяВременногоФайла);
		Документ = УправлениеПечатьюMSWordКлиент.ИнициализироватьПечатнуюФормуMSWord(Макет);
		
		Область = УправлениеПечатьюMSWordКлиент.ПолучитьОбластьМакетаMSWord(Макет, "Документ");
		Область_ = УправлениеПечатьюMSWordКлиент.ПрисоединитьОбласть(Документ, Область, , Ложь);
		УправлениеПечатьюMSWordКлиент.ЗаполнитьПараметры(Область_, ДанныеДляПечати);
			
		//Для каждого СтрокаНачисления Из ДанныеДляПечати.ТаблицаНачислений Цикл
		//	
		//	Область = УправлениеПечатьюMSWordКлиент.ПолучитьОбластьМакетаMSWord(Макет, "Начисления");
		//	Область_ = УправлениеПечатьюMSWordКлиент.ПрисоединитьОбласть(Документ, Область, , Ложь);
		//	УправлениеПечатьюMSWordКлиент.ЗаполнитьПараметры(Область_, СтрокаНачисления);
		//КонецЦикла;
