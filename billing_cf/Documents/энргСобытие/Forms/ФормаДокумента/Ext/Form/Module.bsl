&НаКлиенте
Процедура ПараметрыЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	// Вставить содержимое обработчика.
	Если Элементы.Параметры.ТекущиеДанные.Параметр = ПредопределенноеЗначение("ПланВидовХарактеристик.бестПараметрыТиповСобытий.Суд_СудебныйУчасток") Тогда
		
		//СтандартнаяОбработка = Ложь;
		Элементы.ПараметрыЗначение.ВыбиратьТип = Ложь;
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Строение",ЗначениеРеквизитаОбъекта(ЭтотОбъект.Основание,"МКД"));
	    //ФормаВыбора = ПолучитьФорму("Документ.энргСобытие.Форма.Форма",ПараметрыФормы,ЭтаФорма);
		ФормаВыбора = ПолучитьФорму("Справочник.энргСудебныеУчастки.Форма.ФормаВыбора",ПараметрыФормы,Элемент);
		//ФормаВыбора.РежимВыбора = Истина;
		ФормаВыбора.Открыть();
		
	КонецЕсли;	
	
КонецПроцедуры

