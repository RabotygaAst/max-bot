		//УправлениеПечатьюMSWordКлиент.ЗаполнитьПараметры(Область_, ДанныеДляПечати);
		
		УправлениеПечатьюMSWordКлиент.ПоказатьДокументMSWord(Документ);
		УправлениеПечатьюMSWordКлиент.ЗакрытьСоединение(Макет, Истина);
			
		
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПараметрыПечатиЗаявлениеИсполнительногоДокумента(Задача)

	Возврат Документы.энргСобытие.ПолучитьПараметрыПечатиЗаявлениеИсполнительногоДокумента(Задача);

КонецФункции 


&НаСервере
Функция ПечатьЗаявленияИсполнительногоДокумента()
	
	ДвоичныеДанные 	= УправлениеПечатью.МакетПечатнойФормы("Документ.энргСобытие.ПФ_DOC_ЗаявлениеИсполнительногоДокумента");
	Адрес			= ПоместитьВоВременноеХранилище(ДвоичныеДанные, ЭтаФорма.УникальныйИдентификатор);
		
	Возврат Адрес;
	
КонецФункции

