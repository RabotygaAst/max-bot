#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Перем СписокПолучателей, Подэтапы;
	
	энргРаботаСПрикрепленнымиФайламиСервер.ПриСозданииНаСервере(ЭтотОбъект);
	
	НеУчитоватьСв	= "";
	Если Параметры.Свойство("Абоненты", СписокПолучателей) Тогда
		НеУчитоватьСв = "Абоненты";
	 	Для каждого ТекСтрока Из СписокПолучателей Цикл
			СтрокаТЧ = Объект.Абоненты.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, ТекСтрока);
		КонецЦикла;
	ИначеЕсли Параметры.Свойство("Договоры", СписокПолучателей) Тогда 
		Для каждого ТекСтрока Из СписокПолучателей Цикл
			СтрокаТЧ = Объект.Абоненты.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, ТекСтрока);
		КонецЦикла;
	КонецЕсли;
		
	ЗаполнитьЗначенияСвойств(Объект, Параметры,, НеУчитоватьСв);
	
	// Заполнение таблицы подэтапами задачи
	Если Объект.Одинарный Тогда
		Если ЗначениеЗаполнено(Объект.Абоненты) Тогда
			СтрокаПолучателя = Объект.Абоненты[0];
		Иначе 
			СтрокаПолучателя = Объект.Абоненты.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаПолучателя, Параметры); 
		КонецЕсли;
		
		IDЭтапа 	= СтрокаПолучателя.IDЭтапа;
		Выполнен 	= СтрокаПолучателя.Успех;
		Основание 	= СтрокаПолучателя.Основание;
		Получатель 	= СтрокаПолучателя.Абонент;
		Результат	= СтрокаПолучателя.Результат;
		Если ЗначениеЗаполнено(Основание) Тогда
			Этап 	= Основание.Этап;
		КонецЕсли;
		
		Если Параметры.Свойство("Подэтапы", Подэтапы) Тогда
			
		ИначеЕсли ЗначениеЗаполнено(Основание) Тогда 
			Подэтапы = Документы.энргСобытие.ПолучитьПодэтапыЗадачи(Основание);
		Иначе
			Подэтапы = Новый Массив;
		КонецЕсли;

		Для каждого ТекПодэтап Из Подэтапы Цикл
			СтрокаТЗ = ПодэтапыЗадачи.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЗ, ТекПодэтап);
			
			Если ТекПодэтап.IDЭтапа = IDЭтапа Тогда
				Подэтап = ТекПодэтап.Подэтап;
			КонецЕсли;
		КонецЦикла;
		
		Если Объект.Ссылка.Пустая() Тогда
		
			Элементы.Параметры.ИзменятьСоставСтрок		= Истина;
			Элементы.ПараметрыПараметр.ТолькоПросмотр 	= Ложь;
		
		КонецЕсли;
	КонецЕсли;
	
	Справочники.энргШаблоныСообщений.ДобавлениеКомандПараметров(ЭтаФорма, "КомандыПараметрыТемы", "КомТемы", "ВставитьПараметр");
	Справочники.энргШаблоныСообщений.ДобавлениеКомандПараметров(ЭтаФорма, "КомандыПараметрыТекста", "КомТекста", "ВставитьПараметр");
	
	Элементы.МакетПечатнойФормы.СписокВыбора.Очистить();
	СписокМакетов = Справочники.энргВидыОперацийПИД.ПолучитьСписокМакетовПечати();
	Элементы.МакетПечатнойФормы.СписокВыбора.Добавить("", "Нет");
	Для каждого ТекЭлем Из СписокМакетов Цикл
		Элементы.МакетПечатнойФормы.СписокВыбора.Добавить(ТекЭлем.Значение, ТекЭлем.Представление);
	КонецЦикла;
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды 
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	//энргРаботаСПрикрепленнымиФайламиКлиент.ПередЗаписью(Отказ, ЭтотОбъект);
	
	Если Объект.Одинарный Тогда
	
		ПерваяСтрока = Объект.Абоненты[0];
		
		ПерваяСтрока.Абонент 	= Получатель;
		ПерваяСтрока.Основание 	= Основание;
		ПерваяСтрока.Успех 		= Выполнен;
		ПерваяСтрока.Результат 	= Результат;
		ПерваяСтрока.IDЭтапа	= IDЭтапа;
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	энргРаботаСПрикрепленнымиФайламиКлиент.ПослеЗаписи(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьФлажки(Команда)
	УстановитьФлагВсем(Истина);
КонецПроцедуры

&НаКлиенте
Процедура СнятьФлажки(Команда)
	УстановитьФлагВсем(Ложь);
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовФормы
&НаКлиенте
Процедура ТемаСобытияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ОткрытьФорму("Справочник.энргШаблоныСообщений.ФормаВыбора",, Элемент);
КонецПроцедуры

&НаКлиенте
Процедура ТемаСобытияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Объект.ТемаСобытия = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыбранноеЗначение, "ТекстШаблона"); 
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ТекстШаблонаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Объект.ТекстШаблона = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыбранноеЗначение, "ТекстШаблона"); 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТипСобытияПриИзменении(Элемент)
	УстановитьВидимость();
	
	ЗаполнитьПараметрыНаСервере();
		
КонецПроцедуры

&НаКлиенте
Процедура АбонентыОснованиеПриИзменении(Элемент)
	ТекСтрока = Элементы.Абоненты.ТекущиеДанные;
	Если ТекСтрока = Неопределено Или Не ЗначениеЗаполнено(ТекСтрока.Основание) Тогда
		Возврат;
	КонецЕсли;
	
	ТекСтрока.Абонент = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекСтрока.Основание, "Абонент");
КонецПроцедуры

&НаКлиенте
Процедура МакетПечатнойФормыПриИзменении(Элемент)
	УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура ШагНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Подэтапы = Новый Массив;
	Для каждого СтрокаТЗ Из ПодэтапыЗадачи Цикл
		СтрокаМассива = Новый Структура("IDЭтапа, Подэтап, Текущий, Выполнен, Отменен");
		ЗаполнитьЗначенияСвойств(СтрокаМассива, СтрокаТЗ);
		Подэтапы.Добавить(СтрокаМассива);
	КонецЦикла;
	
	ПарамФормы = Новый Структура("Подэтапы, IDЭтапа", Подэтапы, IDЭтапа);
	
	ОписОпов = Новый ОписаниеОповещения("ОбработкаВыбораЭтапа", ЭтотОбъект);
	ОткрытьФорму("Документ.энргСобытие.Форма.ФормаВыбораПодэтапа", ПарамФормы, Элемент,,,, ОписОпов, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

//&НаКлиенте
//Процедура ШагОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
//	// Вставить содержимое обработчика.
//КонецПроцедуры

#КонецОбласти

#Область ДействияКоманд
&НаКлиенте
Процедура ВставитьПараметр(Команда)
	Если Лев(Команда.Имя, 7) = "КомТемы" Тогда
		Элемент = Элементы.ТемаСобытия;
	Иначе
		Элемент = Элементы.ТекстШаблона;
	КонецЕсли;
	
	Элемент.ВыделенныйТекст = ВставитьПараметрНаСервере(Команда.Имя);
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьШаблон(Команда)
	ОткрытьФорму("Справочник.энргШаблоныСообщений.ФормаВыбора",, Элементы.ТекстШаблона);
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьСобытие(Команда)
	НедостаточноФайлов = Ложь;
	энргРаботаСПрикрепленнымиФайламиКлиент.ПередЗаписью(НедостаточноФайлов, ЭтотОбъект);
	Если НедостаточноФайлов Тогда
		Возврат;
	КонецЕсли;
	СписокВыделенныхСтрок = Новый Массив;
	Для каждого СтрокаТЧ Из Объект.Абоненты Цикл
		Если СтрокаТЧ.Флаг Или Объект.Одинарный Тогда
			СписокВыделенныхСтрок.Добавить(СтрокаТЧ.НомерСтроки);
		КонецЕсли;
	КонецЦикла;
	
	Записать();
	ВыполнениеСобытий(СписокВыделенныхСтрок);
	
	УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура ОтметитьНеОтправленные(Команда)
	Для каждого СтрокаТЧ Из Объект.Абоненты Цикл
	    СтрокаТЧ.Флаг = Не СтрокаТЧ.Успех;
	КонецЦикла;
КонецПроцедуры
#КонецОбласти

#Область ВспомогательныеФункции
&НаКлиенте
Процедура УстановитьВидимость()
	Элементы.ГруппаОдинарный.Видимость 			= Объект.Одинарный;
	Элементы.ГруппаМножественный.Видимость 		= Не Объект.Одинарный;
	Элементы.Шаг.Видимость						= ЗначениеЗаполнено(ПодэтапыЗадачи);
	Элементы.Организация.ТолькоПросмотр			= Не Объект.Одинарный;
	
	Элементы.ФормаПечатьЗаявленияОВынесенииСудебногоПриказа.Видимость 	= Объект.ТипСобытия = ПредопределенноеЗначение("Справочник.энргСпособСвязи.ФормированиеЗаявленияОВыдачеСудебногоПриказа");
	Элементы.ФормаПечатьФормированиеЗаявления.Видимость 				= Объект.ТипСобытия = ПредопределенноеЗначение("Справочник.энргСпособСвязи.ФормированиеЗаявленияОВынесенииИсполнительногоДокумента");
	
	ЕстьОтправка = ЭтоСобытиеСОтправкой(Объект.ТипСобытия);
	
	Элементы.ГруппаЭлементыОтправки.Видимость 	= ЕстьОтправка;
	Элементы.ФормаВыполнитьСобытие.Видимость 	= ЕстьОтправка;
	Элементы.КнопкиФлага.Видимость 				= ЕстьОтправка;
	Элементы.АбонентыФлаг.Видимость 			= ЕстьОтправка;
	Элементы.ПланируемаяДатаОтправки.Видимость 	= ЕстьОтправка;
	Элементы.Выполнен.ТолькоПросмотр			= ЕстьОтправка;
	Элементы.Результат.ТолькоПросмотр			= ЕстьОтправка;
	
	Если ЕстьОтправка Тогда
		ЭтоОтправкаЭП = Объект.ТипСобытия = ПредопределенноеЗначение("Справочник.энргСпособСвязи.ОтправкаПисьмаНаЭлектроннуюПочту");
		Элементы.ГруппаТема.Видимость		  = ЭтоОтправкаЭП;
		Элементы.МакетПечатнойФормы.Видимость = ЭтоОтправкаЭП;
		Элементы.ГруппаСообщение.Видимость	  = Не ЭтоОтправкаЭП ИЛИ Не ЗначениеЗаполнено(Объект.МакетПечатнойФормы);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ВставитьПараметрНаСервере(ИмяКоманды)
	Префикс = ?(Лев(ИмяКоманды, 7) = "КомТемы", "КомТемы", "КомТекста");
	Возврат Справочники.энргШаблоныСообщений.ЗаменаКоманды(ИмяКоманды, Префикс); 
КонецФункции

&НаКлиенте
Процедура УстановитьФлагВсем(ЗначФлага)
	Для каждого СтрокаТЧ Из Объект.Абоненты Цикл
	    СтрокаТЧ.Флаг = ЗначФлага;
	КонецЦикла;	
КонецПроцедуры

&НаСервере
Процедура ВыполнениеСобытий(СписокВыделенныхСтрок)

	ОбъектДок = РеквизитФормыВЗначение("Объект");
	ОбъектДок.ВыполнитьСобытия(СписокВыделенныхСтрок);

	ЗначениеВРеквизитФормы(ОбъектДок, "Объект");

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПараметрыНаСервере()

	ЗначПарам = Новый Соответствие;
	
	Для каждого СтрокаТЧ Из Объект.Параметры Цикл
		ЗначПарам.Вставить(СтрокаТЧ.Параметр, СтрокаТЧ.Значение);
	КонецЦикла;
	
	Объект.Параметры.Очистить();
	
	СписокПараметровТипа = Справочники.энргСпособСвязи.ПолучитьСписокПараметров(Объект.ТипСобытия);
	
	Для каждого Параметр Из СписокПараметровТипа Цикл
		
		Если ЗначениеЗаполнено(Параметр) Тогда
			СтрокаТЧ = Объект.Параметры.Добавить();
			
			СтрокаТЧ.Параметр = Параметр;
			
			Если Параметр = ПланыВидовХарактеристик.бестПараметрыТиповСобытий.ТелефонАбонента И Объект.Одинарный И ЗначениеЗаполнено(Объект.Абоненты) Тогда
				
				СтрокаТЧ.Значение = Документы.энргСобытие.ПолучитьТелефонАбонента(Объект.Абоненты[0].Абонент, Истина);
			ИначеЕсли  Параметр = ПланыВидовХарактеристик.бестПараметрыТиповСобытий.АдресЭлектроннойПочты И Объект.Одинарный И ЗначениеЗаполнено(Объект.Абоненты) Тогда
				
				СтрокаТЧ.Значение = Документы.энргСобытие.ПолучитьЭлектроннуюПочтуАбонента(Объект.Абоненты[0].Абонент);
			//++
			ИначеЕсли Параметр = ПланыВидовХарактеристик.бестПараметрыТиповСобытий.Суд_СудебныйУчасток Тогда
				
				СтрокаТч.Значение = СудебноеУчреждение(Объект.Абоненты[0].Основание);
						    
			Иначе
				
				Значение		  = ЗначПарам.Получить(Параметр);
				Если Значение <> Неопределено Тогда
					СтрокаТЧ.Значение = Значение;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиКомандФормы

// ВводНаОсновании
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуСоздатьНаОсновании(Команда)
	
	ВводНаОснованииКлиент.ВыполнитьПодключаемуюКомандуСоздатьНаОсновании(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры
// Конец ВводНаОсновании

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат)
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЭтоСобытиеСОтправкой(ТипСобытия)

