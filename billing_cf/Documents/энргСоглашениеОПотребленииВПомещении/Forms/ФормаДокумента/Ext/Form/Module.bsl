#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	слжСлужебныеОперацииПриСозданииНаСервере();
	
	энргЛокализацияСервер.ПриСозданииНаСервере_энргСоглашениеОПотребленииВПомещении(ЭтотОбъект);
		
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			ЗаполнитьПериодНачисленияСервер();
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ЗначениеЗаполнено(Объект.КлючПомещения) Тогда
			ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(Объект.КлючПомещения);
			ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);
		КонецЕсли;		
	КонецЕсли;
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании

	// МенюОтчеты
	МенюОтчеты.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюОтчеты);
	// Конец МенюОтчеты
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(ТекущийОбъект.КлючПомещения);
	ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);

	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"Абоненты");

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(ТекущийОбъект.КлючПомещения);
	ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"Абоненты");

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Строение = ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено поле ""Строение""",Объект.Ссылка,"Строение","ЭтотОбъект.Элементы",Отказ);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовШапки

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	ЗаполнитьПериодНачисленияСервер(); 	
КонецПроцедуры

&НаКлиенте
Процедура СтроениеПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Строение) Тогда
// {{MRG[ <-> ]
		СтроениеПомещениеПриИзмененииСервер();		
// }}MRG[ <-> ]
// {{MRG[ <-> ]
//		энргПользовательскийВводКлиент.ПриИзмененииСтроенияПомещения(ЭтаФорма);		
// }}MRG[ <-> ]
	Иначе
		ЭтаФорма.Строение 		= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
		Объект.КлючПомещения 	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПомещениеПриИзменении(Элемент)	
	СтроениеПомещениеПриИзмененииСервер(); 	
КонецПроцедуры

&НаКлиенте
Процедура УслугаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Услуга) тогда
		Объект.Абоненты.Очистить();	
		Объект.ФиксированныеОбъемы.Очистить(); 	
		Объект.ДолиРаспределенияОбъемаПомещения.Очистить();
		ЗаполнитьСписокАбонентов();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура АбонентыСпособРаспределенияПриИзменении(Элемент)
	
	ТекущиеДанные 							= Элементы.Абоненты.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;  
	
	СпособРаспределения 					= ТекущиеДанные.СпособРаспределения;
	
	Если не ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) тогда
		ТекущиеДанные.IDСтроки 							= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	КоллекцияФиксВеличина					= ЭтаФорма.Объект.ФиксированныеОбъемы;
	КоллекцияДолиРаспределения				= ЭтаФорма.Объект.ДолиРаспределенияОбъемаПомещения;
	
	СтруктураПоиска  						= Новый Структура("IDСтроки",ТекущиеДанные.IDСтроки);
	
	Если СпособРаспределения = ПредопределенноеЗначение("Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем") Тогда
		
		СтрокиФиксУдалить						= КоллекцияФиксВеличина.НайтиСтроки(СтруктураПоиска);	
		для Каждого СтрокаФиксУдалить из СтрокиФиксУдалить цикл		  		
			КоллекцияФиксВеличина.Удалить(СтрокаФиксУдалить);		
		КонецЦикла;  	 
		СтрокаФикс 						= КоллекцияФиксВеличина.добавить();
		СтрокаФикс["IDСтроки"]				= ТекущиеДанные.IDСтроки;
		
		СтрокиДолиУдалить						= КоллекцияДолиРаспределения.НайтиСтроки(СтруктураПоиска);	
		для Каждого СтрокаДолиУдалить из СтрокиДолиУдалить цикл		  		
			КоллекцияДолиРаспределения.Удалить(СтрокаДолиУдалить);		
		КонецЦикла;  	 

		
	ИначеЕсли СпособРаспределения = ПредопределенноеЗначение("Перечисление.энргСпособыРаспределенияОбъема.ДолевоеРаспределение") Тогда 
		
		СтрокиДолиУдалить						= КоллекцияДолиРаспределения.НайтиСтроки(СтруктураПоиска);	
		для Каждого СтрокаДолиУдалить из СтрокиДолиУдалить цикл		  		
			КоллекцияДолиРаспределения.Удалить(СтрокаДолиУдалить);		
		КонецЦикла;  	 
		СтрокаДоли 						= КоллекцияДолиРаспределения.добавить();
		СтрокаДоли["IDСтроки"]				= ТекущиеДанные.IDСтроки;

		СтрокиФиксУдалить						= КоллекцияФиксВеличина.НайтиСтроки(СтруктураПоиска);	
		для Каждого СтрокаФиксУдалить из СтрокиФиксУдалить цикл		  		
			КоллекцияФиксВеличина.Удалить(СтрокаФиксУдалить);		
		КонецЦикла; 
	ИначеЕсли СпособРаспределения = ПредопределенноеЗначение("Перечисление.энргСпособыРаспределенияОбъема.Остаток") Тогда 

		Элементы.АбонентыКоэффициентРаспределенияОстатка.АвтоОтметкаНезаполненного=Истина;	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АбонентыПомещениеПриИзменении(Элемент)
	ТекущиеДанные  = Элементы.Абоненты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеПомещения  				= СтроениеКлючПомещенияПоПомещению(ТекущиеДанные.Помещение);
	ТекущиеДанные.Строение 			= ДанныеПомещения.Строение;
	ТекущиеДанные.КлючПомещения 	= ДанныеПомещения.КлючПомещения;
КонецПроцедуры

&НаКлиенте
Процедура АбонентыПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные 							= Элементы.Абоненты.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если не ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) тогда
		ТекущиеДанные.IDСтроки				= Новый УникальныйИдентификатор;
	КонецЕсли;    
	
	Элементы.ФиксированныеОбъемы.ОтборСтрок		= Новый ФиксированнаяСтруктура("IDСтроки", ТекущиеДанные.IDСтроки);
	
	Элементы.ДолиРаспределенияОбъемаПомещения.ОтборСтрок		= Новый ФиксированнаяСтруктура("IDСтроки", ТекущиеДанные.IDСтроки);


КонецПроцедуры

&НаКлиенте
Процедура АбонентыТочкаУчетаПриИзменении(Элемент)
	
	ТекущиеДанные 				= Элементы["Абоненты"].ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекущиеДанные.ТочкаУчета) Тогда
		ТекущиеДанные.Услуга  	= энргРаботаСТочкамиУчетаСервер.УслугаТочкиУчета(Объект.Организация,Объект.Район,ТекущиеДанные.КлючПомещения,ТекущиеДанные.ТочкаУчета,Объект.Дата);	
	Иначе
		ТекущиеДанные.Услуга 	= ПредопределенноеЗначение("Справочник.энргВидыУслуг.ПустаяСсылка");
	КонецЕсли;  	
	
КонецПроцедуры

#КонецОбласти

