#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

#Область РаботаСПоследовательностью

Функция ГраницаНарушенияПоследовательности(МВТ, Знач ТаблицаДляПомещения, Знач Организация, Знач ПериодНачисления, Знач Район, Знач МКД = Неопределено, Знач Абонент = Неопределено) Экспорт 
	
	СоотвествиеПолей  	= Новый Структура("Организация,ПериодНачисления,Район", "Организация", "ПериодНачисления", "Район");
	ПараметрыЗапроса  	= Новый Структура("Организация,ПериодНачисления,Район", Организация, ПериодНачисления, Район);
	Если Не МКД = Неопределено Тогда
		СоотвествиеПолей.Вставить("МКД", "МКД");
		ПараметрыЗапроса.Вставить("МКД", МКД);
	КонецЕсли;
	Если Не Абонент = Неопределено Тогда
		СоотвествиеПолей.Вставить("Абонент", "Абонент");
		ПараметрыЗапроса.Вставить("Абонент", Абонент);
	КонецЕсли;
	
	ПараметрыВТ 		= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(СоотвествиеПолей));
	ПараметрыСхемы 		= Новый Структура("ПараметрыВТ", ПараметрыВТ); 	
	
	Схема  				= Неопределено;
	ЗаполнитьСхемуГраницаНарушенияПоследовательности(Схема, ПараметрыСхемы, ТаблицаДляПомещения);
	
	энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса,МВТ);
	Возврат Неопределено;
	
КонецФункции

Функция ДокументыДляПроведения(МВТ, Знач ТаблицаДляПомещения, Знач ИмяТаблицыГраницыНарушенияПоследовательности, Знач Организация, Знач ПериодНачисления, Знач Район, Знач МКД = Неопределено, Знач Абонент = Неопределено) Экспорт 
	
	СоотвествиеПолей  	= Новый Структура("Организация,ПериодНачисления,Район", "Организация", "ПериодНачисления", "Район");
	ПараметрыЗапроса  	= Новый Структура("Организация,ПериодНачисления,Район", Организация, ПериодНачисления, Район);
	Если Не МКД = Неопределено Тогда
		СоотвествиеПолей.Вставить("МКД", "МКД");
		ПараметрыЗапроса.Вставить("МКД", МКД);
	КонецЕсли;
	Если Не Абонент = Неопределено Тогда
		СоотвествиеПолей.Вставить("Абонент", "Абонент");
		ПараметрыЗапроса.Вставить("Абонент", Абонент);
	КонецЕсли;
	
	ПараметрыВТ 		= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(СоотвествиеПолей));
	ПараметрыСхемы 		= Новый Структура("ПараметрыВТ", ПараметрыВТ); 	
	
	Схема  				= Неопределено;
	ЗаполнитьСхемуДокументыДляПроведения(Схема, ПараметрыСхемы, ТаблицаДляПомещения);
	
	энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса, МВТ);
	Возврат Неопределено;
	
КонецФункции

Процедура ЗаполнитьСхемуДокументыДляПроведения(Схема, ПараметрыСхемы, ТаблицаДляПомещения) Экспорт 
	
	ЗаполнитьСхемуГраницаНарушенияПоследовательности(Схема, ПараметрыСхемы, "МинимумРегистратор");	
	
	Пакет = Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаДокументыДляВосстановленияПоследовательности());
	Пакет.ТаблицаДляПомещения = ТаблицаДляПомещения;  	
	
	Если ПараметрыСхемы.Свойство("ПараметрыВТ") Тогда
		ОтборПакета = Пакет.Операторы[0].Отбор;
		ДоступныеПоляОтбора = "Организация,ПериодНачисления,Район,МКД,Абонент";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОтборПакета, "ВзаиморасчетыПоследовательность", ПараметрыСхемы.ПараметрыВТ, ДоступныеПоляОтбора);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РаботаСПоследовательностью

Процедура ЗаполнитьСхемуМинимальнаяДатаРегистратора(Схема,ПараметрыСхемы,ТаблицаДляПомещения)
	
	Если Схема = Неопределено Тогда
		Схема = Новый СхемаЗапроса;
		Пакет = Схема.ПакетЗапросов[0];
	Иначе
		Пакет = Схема.ПакетЗапросов.Добавить();
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаМинимальнаяДатаРегистратораНарушенияПоследовательности());
	Пакет.ТаблицаДляПомещения = ТаблицаДляПомещения;	
	
	ОтборПакета = Пакет.Операторы[0].Отбор;
	Если ПараметрыСхемы.Свойство("ПараметрыВТ") Тогда
		ДоступныеПоляОтбора = "Организация,ПериодНачисления,Район,МКД,Абонент";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОтборПакета,"ВзаиморасчетыПоследовательность",ПараметрыСхемы.ПараметрыВТ,ДоступныеПоляОтбора);
	КонецЕсли;  
	
КонецПроцедуры

Процедура ЗаполнитьСхемуМинимальныйПорядокРегистратора(Схема,ПараметрыСхемы,ТаблицаДляПомещения)
	
	ЗаполнитьСхемуМинимальнаяДатаРегистратора(Схема,ПараметрыСхемы,"МинимумДатаРегистратора");
	
	Пакет = Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаМинимальныйПорядокРегистратораНарушенияПоследовательности());
	Пакет.ТаблицаДляПомещения = ТаблицаДляПомещения;
	
	ОтборПакета = Пакет.Операторы[0].Отбор;
	Если ПараметрыСхемы.Свойство("ПараметрыВТ") Тогда
		ДоступныеПоляОтбора = "Организация,ПериодНачисления,Район,МКД,Абонент";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОтборПакета,"ВзаиморасчетыПоследовательность",ПараметрыСхемы.ПараметрыВТ,ДоступныеПоляОтбора);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьСхемуГраницаНарушенияПоследовательности(Схема,ПараметрыСхемы,ТаблицаДляПомещения)
	
	ЗаполнитьСхемуМинимальныйПорядокРегистратора(Схема,ПараметрыСхемы,"МинимумДопПорядокРегистратора");
	
	Пакет = Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаГраницаНарушенияПоследовательности());
	Пакет.ТаблицаДляПомещения = ТаблицаДляПомещения;
	
	ОтборПакета = Пакет.Операторы[0].Отбор;
	Если ПараметрыСхемы.Свойство("ПараметрыВТ") Тогда
		ДоступныеПоляОтбора = "Организация,ПериодНачисления,Район,МКД,Абонент";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОтборПакета,"ВзаиморасчетыПоследовательность",ПараметрыСхемы.ПараметрыВТ,ДоступныеПоляОтбора);
	КонецЕсли;
	
КонецПроцедуры

Функция ТекстЗапросаМинимальнаяДатаРегистратораНарушенияПоследовательности()
	Текст  = 
	"ВЫБРАТЬ
	|	ВзаиморасчетыПоследовательность.Организация КАК Организация,
	|	ВзаиморасчетыПоследовательность.ПериодНачисления КАК ПериодНачисления,
	|	ВзаиморасчетыПоследовательность.Район КАК Район,
	|	ВзаиморасчетыПоследовательность.МКД КАК МКД,
	|	ВзаиморасчетыПоследовательность.Абонент КАК Абонент,
	|	МИНИМУМ(ВзаиморасчетыПоследовательность.ДатаРегистратора) КАК ДатаРегистратора
	|ИЗ
	|	РегистрСведений.энргВзаиморасчетыПоследовательность КАК ВзаиморасчетыПоследовательность
	|ГДЕ
	|	ВзаиморасчетыПоследовательность.СостояниеПроведения В (ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности), ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности))
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыПоследовательность.Организация,
	|	ВзаиморасчетыПоследовательность.ПериодНачисления,
	|	ВзаиморасчетыПоследовательность.Район,
	|	ВзаиморасчетыПоследовательность.МКД,
	|	ВзаиморасчетыПоследовательность.Абонент";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаМинимальныйПорядокРегистратораНарушенияПоследовательности()
	Текст  = 
	"ВЫБРАТЬ
	|	ВзаиморасчетыПоследовательность.Организация КАК Организация,
	|	ВзаиморасчетыПоследовательность.ПериодНачисления КАК ПериодНачисления,
	|	ВзаиморасчетыПоследовательность.Район КАК Район,
	|	ВзаиморасчетыПоследовательность.МКД КАК МКД,
	|	ВзаиморасчетыПоследовательность.Абонент КАК Абонент,
	|	ВзаиморасчетыПоследовательность.ДатаРегистратора КАК ДатаРегистратора,
	|	МИНИМУМ(ВЫБОР
	|			КОГДА ВзаиморасчетыПоследовательность.ДокРегистратор ССЫЛКА Документ.энргПерерасчет
	|				ТОГДА 0
	|			ИНАЧЕ 1
	|		КОНЕЦ) КАК ДопПорядок
	|ИЗ
	|	РегистрСведений.энргВзаиморасчетыПоследовательность КАК ВзаиморасчетыПоследовательность
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МинимумДатаРегистратора КАК МинимумДатаРегистратора
	|		ПО (ВзаиморасчетыПоследовательность.СостояниеПроведения В (ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности), ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности)))
	|			И ВзаиморасчетыПоследовательность.Организация = МинимумДатаРегистратора.Организация
	|			И ВзаиморасчетыПоследовательность.ПериодНачисления = МинимумДатаРегистратора.ПериодНачисления
	|			И ВзаиморасчетыПоследовательность.Район = МинимумДатаРегистратора.Район
	|			И ВзаиморасчетыПоследовательность.МКД = МинимумДатаРегистратора.МКД
	|			И ВзаиморасчетыПоследовательность.Абонент = МинимумДатаРегистратора.Абонент
	|			И ВзаиморасчетыПоследовательность.ДатаРегистратора = МинимумДатаРегистратора.ДатаРегистратора
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыПоследовательность.Организация,
	|	ВзаиморасчетыПоследовательность.ПериодНачисления,
	|	ВзаиморасчетыПоследовательность.Район,
	|	ВзаиморасчетыПоследовательность.МКД,
	|	ВзаиморасчетыПоследовательность.Абонент,
	|	ВзаиморасчетыПоследовательность.ДатаРегистратора";
	
	Возврат Текст;
КонецФункции

Функция ТекстЗапросаГраницаНарушенияПоследовательности()
	
	Текст  = 
	"ВЫБРАТЬ
	|	ВзаиморасчетыПоследовательность.Организация КАК Организация,
	|	ВзаиморасчетыПоследовательность.ПериодНачисления КАК ПериодНачисления,
	|	ВзаиморасчетыПоследовательность.Район КАК Район,
	|	ВзаиморасчетыПоследовательность.МКД КАК МКД,
	|	ВзаиморасчетыПоследовательность.Абонент КАК Абонент,
	|	ВзаиморасчетыПоследовательность.ДатаРегистратора КАК ДатаРегистратора,
	|	МинимумДопПорядокРегистратора.ДопПорядок КАК ДопПорядок,
	|	МИНИМУМ(ВзаиморасчетыПоследовательность.ДокРегистратор) КАК ДокРегистратор
	|ИЗ
	|	РегистрСведений.энргВзаиморасчетыПоследовательность КАК ВзаиморасчетыПоследовательность
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МинимумДопПорядокРегистратора КАК МинимумДопПорядокРегистратора
	|		ПО (ВзаиморасчетыПоследовательность.СостояниеПроведения В (ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности), ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности)))
	|			И ВзаиморасчетыПоследовательность.Организация = МинимумДопПорядокРегистратора.Организация
	|			И ВзаиморасчетыПоследовательность.ПериодНачисления = МинимумДопПорядокРегистратора.ПериодНачисления
	|			И ВзаиморасчетыПоследовательность.Район = МинимумДопПорядокРегистратора.Район
	|			И ВзаиморасчетыПоследовательность.МКД = МинимумДопПорядокРегистратора.МКД
	|			И ВзаиморасчетыПоследовательность.Абонент = МинимумДопПорядокРегистратора.Абонент
	|			И ВзаиморасчетыПоследовательность.ДатаРегистратора = МинимумДопПорядокРегистратора.ДатаРегистратора
	|			И (ВЫБОР
	|				КОГДА МинимумДопПорядокРегистратора.ДопПорядок = 0
	|					ТОГДА ВзаиморасчетыПоследовательность.ДокРегистратор ССЫЛКА Документ.энргПерерасчет
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыПоследовательность.Организация,
	|	ВзаиморасчетыПоследовательность.ПериодНачисления,
	|	ВзаиморасчетыПоследовательность.Район,
	|	ВзаиморасчетыПоследовательность.МКД,
	|	ВзаиморасчетыПоследовательность.Абонент,
	|	ВзаиморасчетыПоследовательность.ДатаРегистратора,
	|	МинимумДопПорядокРегистратора.ДопПорядок";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаДокументыДляВосстановленияПоследовательности()
	Текст = 
	"ВЫБРАТЬ
	|	ВзаиморасчетыПоследовательность.Организация КАК Организация,
	|	ВзаиморасчетыПоследовательность.ПериодНачисления КАК ПериодНачисления,
	|	ВзаиморасчетыПоследовательность.Район КАК Район,
	|	ВзаиморасчетыПоследовательность.СостояниеПроведения КАК СостояниеПроведения,
	|	ВзаиморасчетыПоследовательность.МКД КАК МКД,
	|	ВзаиморасчетыПоследовательность.Абонент КАК Абонент,
	|	ВзаиморасчетыПоследовательность.ДатаРегистратора КАК ДатаРегистратора,
	|	ВзаиморасчетыПоследовательность.ДокРегистратор КАК ДокРегистратор,
	|	ВзаиморасчетыПоследовательность.ЭтоОплата КАК ЭтоОплата,
	|	ВзаиморасчетыПоследовательность.Кассир КАК Кассир,
	|	ВзаиморасчетыПоследовательность.ИсточникПоступления КАК ИсточникПоступления,
	|	ВзаиморасчетыПоследовательность.ЭтоКорректировкаОплаты КАК ЭтоКорректировкаОплаты,
	|	МинимумРегистратор.ДопПорядок КАК ДопПорядок
	|ИЗ
	|	РегистрСведений.энргВзаиморасчетыПоследовательность КАК ВзаиморасчетыПоследовательность
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МинимумРегистратор КАК МинимумРегистратор
	|		ПО (ВЫБОР
	|				КОГДА МинимумРегистратор.ДатаРегистратора < ВзаиморасчетыПоследовательность.ДатаРегистратора
	|					ТОГДА ИСТИНА
	|				КОГДА МинимумРегистратор.ДатаРегистратора = ВзаиморасчетыПоследовательность.ДатаРегистратора
	|					ТОГДА ВЫБОР
	|							КОГДА МинимумРегистратор.ДопПорядок = 0
	|									И ВзаиморасчетыПоследовательность.ДокРегистратор ССЫЛКА Документ.энргНачисление
	|								ТОГДА ИСТИНА
	|							ИНАЧЕ МинимумРегистратор.ДокРегистратор <= ВзаиморасчетыПоследовательность.ДокРегистратор
	|						КОНЕЦ
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И ВзаиморасчетыПоследовательность.Организация = МинимумРегистратор.Организация
	|			И ВзаиморасчетыПоследовательность.ПериодНачисления = МинимумРегистратор.ПериодНачисления
	|			И ВзаиморасчетыПоследовательность.Район = МинимумРегистратор.Район
	|			И ВзаиморасчетыПоследовательность.МКД = МинимумРегистратор.МКД
