#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область РеализацияИнтерфейса_

Функция ЗавершениеПериодаНачисления(Организация,Район, ПериодНачисления) Экспорт  
	
	ПараметрыСхемы 		= Новый Структура;	
	ПараметрыВТ			= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", Новый Структура("Организация, ПериодНачисления", "Организация", "ПериодНачисления")));
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);
	Схема 				= Неопределено;	
	СхемаЗавершенияПериодаНачисления(Схема, ПараметрыСхемы, "");
	
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация", 		Организация);
	ПараметрыЗапроса.Вставить("Район", 				Район);
	ПараметрыЗапроса.Вставить("ПериодНачисления", 	ПериодНачисления);
		
	Результат 			= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	Если Результат.Пустой() Тогда
		Результат 		= '0001-01-01';
	Иначе
		Выборка 		= Результат.Выбрать();
		Выборка.Следующий();
		Результат 		= Выборка.Завершение;
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргДатыОтчетногоПериоды.ЗавершениеПериодаНачисления";
		ПараметрыМетода 			= Новый Структура("Организация,Район,ПериодНачисления", Организация, ПериодНачисления);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, Результат, ПараметрыМетода);
	 КонецЕсли;
	 
	 Возврат Результат;
	
КонецФункции

Процедура СхемаЗавершенияПериодаНачисления(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "ТекущиеДатыОтчетногоПериодаОбщиеНастройки") Экспорт  
	
	Если Схема = Неопределено Тогда
		Схема 							= Новый СхемаЗапроса;
		Пакет 							= Схема.ПакетЗапросов[0];		
	Иначе
		Пакет 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;			
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаТекущиеДатыЗавершенияПериодаНачисления());
	Пакет.ТаблицаДляПомещения 			= ТаблицаДляПомещения;
	Пакет.ВыбиратьРазрешенные 			= ?(ПараметрыОтбора.Свойство("ВыбиратьРазрешенные") и НЕ ПараметрыОтбора.ВыбиратьРазрешенные, ЛОЖЬ, ИСТИНА);
	ОператорВыбора 						= Пакет.Операторы[0];	
		
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация,Район,ПериодНачисления";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОператорВыбора.Отбор,"ДатыОтчетногоПериоды", ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);		
	КонецЕсли;
			
КонецПроцедуры

#КонецОбласти

#Область ТекстыЗапросов

Функция ТекстЗапросаТекущиеДатыЗавершенияПериодаНачисления()
	
	Текст =
	"ВЫБРАТЬ
	|	ДатыОтчетногоПериоды.Организация КАК Организация,
	|	ДатыОтчетногоПериоды.Район КАК Район,
	|	ДатыОтчетногоПериоды.ПериодНачисления КАК ПериодНачисления,
	|	ДатыОтчетногоПериоды.Завершение КАК Завершение
	|ИЗ
	|	РегистрСведений.энргДатыОтчетногоПериоды КАК ДатыОтчетногоПериоды";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#КонецЕсли