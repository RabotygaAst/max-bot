#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Параметры.Свойство("Организация", Организация);
	Параметры.Свойство("Район",		  Район);
	
	
	// Заполнение таблицы настроек
	//Источники = Метаданные.ПодпискиНаСобытия.бестПроверкаНаличияПрисоединенныхФайлов.Источник;
	
	Для каждого ТекДок Из Метаданные.Документы Цикл
	
		//Если Источники.СодержитТип(Тип("ДокументОбъект." + ТекДок.Имя)) Тогда 
		//	СтрокаТЧ = Настройки.Добавить();
		//	ЗаполнитьЗначенияСвойств(СтрокаТЧ, Параметры);
		//	СтрокаТЧ.ИмяДокумента = ТекДок.Имя;
		//	СтрокаТЧ.СинонимДокумента = ТекДок.Синоним;
		//КонецЕсли;
	КонецЦикла;
	Настройки.Сортировать("СинонимДокумента");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргНастройкиОбязательностиПрикрепленияФайлов.Организация КАК Организация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА &Район = НЕОПРЕДЕЛЕНО
		|					ИЛИ энргНастройкиОбязательностиПрикрепленияФайлов.Район = &Район
		|				ТОГДА энргНастройкиОбязательностиПрикрепленияФайлов.ОбязательноеПрикрепление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ОбязательноеПрикрепление,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА &Район <> НЕОПРЕДЕЛЕНО
		|					И энргНастройкиОбязательностиПрикрепленияФайлов.Район = ЗНАЧЕНИЕ(Справочник.энргЗоныОтвественности.ПустаяСсылка)
		|				ТОГДА энргНастройкиОбязательностиПрикрепленияФайлов.ОбязательноеПрикрепление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ОбязательноеПрикреплениеОрганизация,
		|	энргНастройкиОбязательностиПрикрепленияФайлов.ИмяДокумента КАК ИмяДокумента
		|ИЗ
		|	РегистрСведений.энргНастройкиОбязательностиПрикрепленияФайлов КАК энргНастройкиОбязательностиПрикрепленияФайлов
		|ГДЕ
		|	энргНастройкиОбязательностиПрикрепленияФайлов.Район В (&Район, ЗНАЧЕНИЕ(Справочник.энргЗоныОтвественности.ПустаяСсылка))
		|	И энргНастройкиОбязательностиПрикрепленияФайлов.Организация = &Организация
		|
		|СГРУППИРОВАТЬ ПО
		|	энргНастройкиОбязательностиПрикрепленияФайлов.Организация,
		|	энргНастройкиОбязательностиПрикрепленияФайлов.ИмяДокумента";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", ?(ЗначениеЗаполнено(Район), Район, Неопределено));
	
	Отбор = Новый Структура("Организация, ИмяДокумента");
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Отбор, Выборка);
		
		СтрокиТЧ = Настройки.НайтиСтроки(Отбор);
		Для каждого СтрокаТЧ Из СтрокиТЧ Цикл
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
		КонецЦикла;
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(Район) Тогда
		Колонка = Элементы.НастройкиОбязательноеПрикрепление;
		Колонка.Заголовок = "Обязательное прикрепление";
		Элементы.Переместить(Колонка, Элементы.Настройки);
		
		Элементы.НастройкиОбязательноеПрикреплениеОрганизация.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если ЗавершениеРаботы Тогда 
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Тогда
		Отказ = Истина;
		
		ПоказатьВопрос(Новый ОписаниеОповещения("ОбработкаОтветаНаЗакрытие", ЭтотОбъект), "Данные были изменены. Сохранить изменения?", РежимДиалогаВопрос.ДаНетОтмена);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Элементы.Организация.Видимость						= ЗначениеЗаполнено(Организация);
	Элементы.Район.Видимость							= ЗначениеЗаполнено(Район);
	Элементы.НастройкиПеренестиИзОрганизации.Видимость	= ЗначениеЗаполнено(Район);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыНастройки

&НаКлиенте
Процедура НастройкиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура НастройкиПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура НастройкиОбязательноеПрикреплениеПриИзменении(Элемент)
	Модифицированность = Истина;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Записать(Команда)
	ЗаписатьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	ЗаписатьНаСервере();
	
	Если Не Модифицированность Тогда
		Закрыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СнятьФлажки(Команда)
	Модифицированность = Истина;
	Для каждого СтрокаТЧ Из Настройки Цикл
		СтрокаТЧ.ОбязательноеПрикрепление = Ложь;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьФлажки(Команда)
	Модифицированность = Истина;
	Для каждого СтрокаТЧ Из Настройки Цикл
		СтрокаТЧ.ОбязательноеПрикрепление = Истина;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиИзОрганизации(Команда)
	Модифицированность = Истина;
	Для каждого СтрокаТЧ Из Настройки Цикл
		СтрокаТЧ.ОбязательноеПрикрепление = СтрокаТЧ.ОбязательноеПрикреплениеОрганизация;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаписатьНаСервере()

	НаборЗаписей = РегистрыСведений.энргНастройкиОбязательностиПрикрепленияФайлов.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Организация.Установить(Организация);
	НаборЗаписей.Отбор.Район.Установить(Район);
	
	Для каждого СтрокаТЧ Из Настройки Цикл
		Запись = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, СтрокаТЧ);
	КонецЦикла;
	
	Попытка
		НаборЗаписей.Записать(Истина);
		Модифицированность = Ложь;
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОтветаНаЗакрытие(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда 
		ЗаписатьНаСервере();
		Закрыть();
	ИначеЕсли РезультатВопроса = КодВозвратаДиалога.Нет Тогда 
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
