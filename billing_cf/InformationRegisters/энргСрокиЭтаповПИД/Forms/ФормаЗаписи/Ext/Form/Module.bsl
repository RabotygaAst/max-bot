#Область СобытияФормы


&НаКлиенте
Процедура ЭтапНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ПараметрыВыбора = Новый Структура;
	ПараметрыВыбора.Вставить("БезОграниченияОРП",Истина);
	
	ОбработкаВыбора = Новый ОписаниеОповещения("ПриЗакрытииФормыВыбораЭтапа", ЭтаФорма,"ПодборРеализации");
	
	ОткрытьФорму("Справочник.энргВидыОперацийПИД.ФормаВыбора", ПараметрыВыбора, ЭтаФорма, , , , ОбработкаВыбора);
КонецПроцедуры

&НаКлиенте
Процедура ПодэтапНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ПараметрыВыбора = Новый Структура;
	ПараметрыВыбора.Вставить("БезОграниченияОРП",Истина);
	
	ОбработкаВыбора = Новый ОписаниеОповещения("ПриЗакрытииФормыВыбораПодэтапа", ЭтаФорма,"ПодборРеализации");
	
	ОткрытьФорму("Справочник.энргВидыОперацийПИД.ФормаВыбора", ПараметрыВыбора,	ЭтаФорма, , , , ОбработкаВыбора);
КонецПроцедуры
#КонецОбласти

#Область ДополнительныеМетоды

&НаКлиенте
Процедура ПриЗакрытииФормыВыбораЭтапа(Значение, ДопПараметры) Экспорт
	Если Значение = Неопределено Тогда 
		Возврат;
    КонецЕсли; 
    Запись.Этап = Значение; 
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытииФормыВыбораПодэтапа(Значение, ДопПараметры) Экспорт
	Если Значение = Неопределено Тогда 
		Возврат;
    КонецЕсли; 
    Запись.Подэтап = Значение; 
КонецПроцедуры
#КонецОбласти