
Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	//ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюНабораЗаписей(ЭтотОбъект,Отказ,Замещение);
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ, Замещение)
	
	Регистратор 						= ЭтотОбъект.Отбор.Регистратор.Значение;
	
	ИнициализироватьДополнительныеСвойства(Регистратор);
	
	ЭтоОчистка 							= Ложь;
	Если ДополнительныеСвойства.Свойство("ЭтоОчистка") И ДополнительныеСвойства.ЭтоОчистка Тогда
		ЭтоОчистка 						= Истина;
	КонецЕсли;
	
	Если Не ЭтоОчистка Тогда
		ДобавитьОтложенныеДвижения(Регистратор);
		ДобавитьЗависимыеДанные(Регистратор);
	КонецЕсли; 	
	
	энргНачисления.ЗаписатьНаборыЗаписей(ДополнительныеСвойства.НаборыЗаписей, Замещение);
		
КонецПроцедуры

Процедура ИнициализироватьДополнительныеСвойства(Регистратор)
	
	Если ДополнительныеСвойства.Свойство("ДатаРегистратора") Тогда
		ДатаРегистратора 				= ДополнительныеСвойства.ДатаРегистратора;
	Иначе
		ДополнительныеСвойства.Вставить("ДатаРегистратора", Регистратор.Дата);
	КонецЕсли;	
	
	Если ДополнительныеСвойства.Свойство("Организация") Тогда
		Организация 					= ДополнительныеСвойства.Организация;
	ИначеЕсли  ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Регистратор,"Организация") Тогда
		ДополнительныеСвойства.Вставить("Организация", Регистратор.Организация);
	Иначе
		ДополнительныеСвойства.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("МКД") Тогда
		МКД 							= ДополнительныеСвойства.МКД;
	Иначе
		ДополнительныеСвойства.Вставить("МКД", Неопределено);
	КонецЕсли;

	Если ДополнительныеСвойства.Свойство("Район") Тогда
		Район 							= ДополнительныеСвойства.Район;
	ИначеЕсли  ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Регистратор,"Район") Тогда
		ДополнительныеСвойства.Вставить("Район", Регистратор.Район);
	Иначе
		ДополнительныеСвойства.Вставить("Район", Справочники.энргЗоныОтвественности.ПустаяСсылка());
	КонецЕсли;
	
	РазделыЗаписи 							= Новый Массив;
	
	НаборыЗаписей  							= Новый Структура;
	
	Если ТипЗнч(Регистратор) = Тип("ДокументСсылка.энргНачислениеМКД") Тогда
		РазделыЗаписи.Добавить(Новый Структура("Раздел, ПериодНачисления", Перечисления.энргРазделыЗаписи.СтабильныеПериодыМКД, КонецМесяца(ДополнительныеСвойства.ДатаРегистратора)+1));
		РазделыЗаписи.Добавить(Новый Структура("Раздел, ПериодНачисления", Перечисления.энргРазделыЗаписи.РаспределениеМКД, НачалоМесяца(ДополнительныеСвойства.ДатаРегистратора)));
		
		НачисленныйСреднийОбъем 			= РегистрыНакопления.энргНачисленныйСреднийОбъемМКД.СоздатьНаборЗаписей();
		НачисленныйСреднийОбъем.Отбор.Регистратор.установить(Регистратор);
		НачисленныйСреднийОбъем.ДополнительныеСвойства.Вставить("ЗаписьРазрешена", Истина);
		
		Если ЗначениеЗаполнено(МКД) И ДополнительныеСвойства.Свойство("ЭтоОчистка") И ДополнительныеСвойства.ЭтоОчистка Тогда
			НачисленныйСреднийОбъем.Прочитать();
			СтрокиУдалить 	= Новый Массив;
			Для Каждого СтрокаНабора ИЗ НачисленныйСреднийОбъем Цикл
				Если НЕ СтрокаНабора.МКД = МКД Тогда
					Продолжить;
				КонецЕсли;				
				СтрокиУдалить.Добавить(СтрокаНабора);
			КонецЦикла;
			
			Для Сч = 0 По СтрокиУдалить.ВГраница() Цикл
				НачисленныйСреднийОбъем.Удалить(СтрокиУдалить[Сч]);
			КонецЦикла;
			
		КонецЕсли;
	
		НаборыЗаписей.Вставить("энргНачисленныйСреднийОбъем", 	НачисленныйСреднийОбъем);		
	ИначеЕсли ТипЗнч(Регистратор) = Тип("ДокументСсылка.энргПерерасчетМКД") Тогда 
		Если ДополнительныеСвойства.Свойство("НаборНачисленныйСредний") Тогда
			НаборыЗаписей.Вставить("энргНачисленныйСреднийОбъем", 	ДополнительныеСвойства.НаборНачисленныйСредний);
		Иначе
			НачисленныйСреднийОбъем 			= РегистрыНакопления.энргНачисленныйСреднийОбъемМКД.СоздатьНаборЗаписей();
			НачисленныйСреднийОбъем.Отбор.Регистратор.установить(Регистратор);
			НачисленныйСреднийОбъем.ДополнительныеСвойства.Вставить("ЗаписьРазрешена", Истина); 
			
			Если ЗначениеЗаполнено(МКД) И ДополнительныеСвойства.Свойство("ЭтоОчистка") И ДополнительныеСвойства.ЭтоОчистка Тогда
				НачисленныйСреднийОбъем.Прочитать();
				СтрокиУдалить 	= Новый Массив;
				Для Каждого СтрокаНабора ИЗ НачисленныйСреднийОбъем Цикл
					Если НЕ СтрокаНабора.МКД = МКД Тогда
						Продолжить;
					КонецЕсли;				
					СтрокиУдалить.Добавить(СтрокаНабора);
				КонецЦикла;
				
				Для Сч = 0 По СтрокиУдалить.ВГраница() Цикл
					НачисленныйСреднийОбъем.Удалить(СтрокиУдалить[Сч]);
				КонецЦикла;
				
			КонецЕсли;
			
			НаборыЗаписей.Вставить("энргНачисленныйСреднийОбъем", 	НачисленныйСреднийОбъем);
		КонецЕсли;
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("РазделыЗаписи", РазделыЗаписи);	
			
	Если РазделыЗаписи.Количество() > 0 Тогда
		НаборОтложенныеДвижения 			= РегистрыСведений.энргОтложенныеДвиженияДокументов.СоздатьНаборЗаписей();
		НаборОтложенныеДвижения.Отбор.ДокРегистратор.Установить(Регистратор);
		НаборОтложенныеДвижения.ДополнительныеСвойства.Вставить("ЗамещатьОтложенныеДвижения", Истина);
		НаборыЗаписей.Вставить("энргОтложенныеДвиженияДокументов", 		НаборОтложенныеДвижения);				
	КонецЕсли;
			
	ДополнительныеСвойства.Вставить("НаборыЗаписей", НаборыЗаписей);
	
КонецПроцедуры

Процедура ДобавитьОтложенныеДвижения(Регистратор)
	перем НаборОтложенныеДвижения;
	
	НаборыЗаписей 							= ДополнительныеСвойства.НаборыЗаписей;
	
	Если Не НаборыЗаписей.Свойство("энргОтложенныеДвиженияДокументов", НаборОтложенныеДвижения) Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеСвойства.МКД = Неопределено Тогда 
		мМКД  								= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ЭтотОбъект.ВыгрузитьКолонку("МКД"));
	Иначе
		мМКД 								= Новый Массив;
		мМКД.Добавить(ДополнительныеСвойства.МКД);
	КонецЕсли;	
	
	РазделыЗаписи 							= ДополнительныеСвойства.РазделыЗаписи;
	СтабильныеМКД							= Перечисления.энргРазделыЗаписи.СтабильныеПериодыМКД;	
	Для Каждого СтрокаРаздела Из РазделыЗаписи Цикл	
		Если СтрокаРаздела.Раздел = СтабильныеМКД Тогда 
			НоваяЗапись 					= НаборОтложенныеДвижения.Добавить();
			НоваяЗапись.Организация		 	= ДополнительныеСвойства.Организация;
			НоваяЗапись.ПериодНачисления 	= СтрокаРаздела.ПериодНачисления;
			НоваяЗапись.Район 				= ДополнительныеСвойства.Район;
			НоваяЗапись.РазделЗаписи 		= СтрокаРаздела.Раздел;
			НоваяЗапись.ДокРегистратор 		= Регистратор;
			НоваяЗапись.ДатаРегистратора 	= ДополнительныеСвойства.ДатаРегистратора;
			НоваяЗапись.ЧастныйСектор 		= Ложь;
			НоваяЗапись.Строение 			= Справочники.энргСтроения.ПустаяСсылка();
		Иначе
			Для Каждого МКД Из мМКД Цикл
				НоваяЗапись 					= НаборОтложенныеДвижения.Добавить();
				НоваяЗапись.Организация		 	= ДополнительныеСвойства.Организация;
				НоваяЗапись.ПериодНачисления 	= СтрокаРаздела.ПериодНачисления;
				НоваяЗапись.Район 				= ДополнительныеСвойства.Район;
				НоваяЗапись.РазделЗаписи 		= СтрокаРаздела.Раздел;
				НоваяЗапись.ДокРегистратор 		= Регистратор;
				НоваяЗапись.ДатаРегистратора 	= ДополнительныеСвойства.ДатаРегистратора;
				НоваяЗапись.ЧастныйСектор 		= Ложь;
				НоваяЗапись.Строение 			= МКД;
			КонецЦикла;			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьЗависимыеДанные(Регистратор) 
	перем НачисленныйСредний;
	
	НаборыЗаписей 							= ДополнительныеСвойства.НаборыЗаписей;
	
	Если НЕ НаборыЗаписей.Свойство("энргНачисленныйСреднийОбъем", НачисленныйСредний) Тогда
		Возврат;
	КонецЕсли;
	
	//Если ЗначениеЗаполнено(ДополнительныеСвойства.Свойство("МКД")) Тогда
	//	МКД = ДополнительныеСвойства.МКД;
	//	НачисленныйСредний.Прочитать();
	//	СтрокиУдалить 										= Новый Массив;
	//	Для Каждого СтрокаНабора ИЗ НачисленныйСредний Цикл
	//		Если НЕ СтрокаНабора.МКД = МКД Тогда
	//			Продолжить;
	//		КонецЕсли;				
	//		СтрокиУдалить.Добавить(СтрокаНабора);
	//	КонецЦикла;
	//	
	//	Для Сч = 0 По СтрокиУдалить.ВГраница() Цикл
	//		НачисленныйСредний.Удалить(СтрокиУдалить[Сч]);
	//	КонецЦикла;
	//	
	//КонецЕсли;
		
	ВидОперацииПоСреднему  					= Перечисления.энргСпособНачислений.НачислениеПоСреднему;
	ВидОперацииПоСреднемуНормативу 			= Перечисления.энргСпособНачислений.СреднееПоНормативу;
	
	Для Каждого Строка Из ЭтотОбъект Цикл		
		Если (Строка.СпособНачисления = ВидОперацииПоСреднему Или Строка.СпособНачисления = ВидОперацииПоСреднемуНормативу)
			и Строка.СниматьНачисленныйСредний
			и Строка.ОбъемУслуги > 0 Тогда
			Запись  						= НачисленныйСредний.ДобавитьПриход();
			ЗаполнитьЗначенияСвойств(Запись,Строка);
			Запись.ПериодНачисления 		= НачалоМесяца(ДополнительныеСвойства.ДатаРегистратора);
		КонецЕсли;		
	КонецЦикла;	
	
КонецПроцедуры