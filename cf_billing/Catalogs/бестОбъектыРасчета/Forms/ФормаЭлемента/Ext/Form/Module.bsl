&НаСервере
Процедура МКДПриИзмененииНаСервере()
	
	ОбъектТек = РеквизитФормыВЗначение("Объект");
	УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектТек, ОбъектТек.МКД.Наименование, Справочники.ВидыКонтактнойИнформации.АдресОбъектаРасчета);  	
	УправлениеКонтактнойИнформацией.ПриЧтенииНаСервере(ЭтаФорма, ОбъектТек);
	ОбъектТек.Строение	= ОбъектТек.МКД;
	ЗначениеВРеквизитФормы(ОбъектТек,"Объект");	
КонецПроцедуры

&НаКлиенте
Процедура МКДПриИзменении(Элемент)
	
	МКДПриИзмененииНаСервере();

КонецПроцедуры

&НаСервере
Процедура СтроениеПриИзмененииНаСервере()
	ОбъектТек = РеквизитФормыВЗначение("Объект");
	
	Если ОбъектТек.Строение.ТипСтроения = Перечисления.энргТипыСтроений.МКД Тогда
		ОбъектТек.МКД	= ОбъектТек.Строение;
		Иначе
		ОбъектТек.МКД	= Справочники.энргСтроения.ПустаяСсылка();
		ОбъектТек.КонтактнаяИнформация.Очистить();
	КонецЕсли;
	
	УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектТек, ОбъектТек.Строение.Наименование, Справочники.ВидыКонтактнойИнформации.АдресОбъектаРасчета);  	
	УправлениеКонтактнойИнформацией.ПриЧтенииНаСервере(ЭтаФорма, ОбъектТек);
	ЗначениеВРеквизитФормы(ОбъектТек,"Объект");
КонецПроцедуры

&НаКлиенте
Процедура СтроениеПриИзменении(Элемент)
	СтроениеПриИзмененииНаСервере();
КонецПроцедуры


