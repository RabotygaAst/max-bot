	  |			И ВТ_Год.Год = ВТ_Сентябрь.Год
	  |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Октябрь КАК ВТ_Октябрь
	  |		ПО ВТ_Год.Услуга = ВТ_Октябрь.Услуга
	  |			И ВТ_Год.Год = ВТ_Октябрь.Год
	  |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Ноябрь КАК ВТ_Ноябрь
	  |		ПО ВТ_Год.Услуга = ВТ_Ноябрь.Услуга
	  |			И ВТ_Год.Год = ВТ_Ноябрь.Год
	  |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Декабрь КАК ВТ_Декабрь
	  |		ПО ВТ_Год.Услуга = ВТ_Декабрь.Услуга
	  |			И ВТ_Год.Год = ВТ_Декабрь.Год";
	
