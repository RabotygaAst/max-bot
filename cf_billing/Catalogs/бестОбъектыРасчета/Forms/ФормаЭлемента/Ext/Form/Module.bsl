&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Оповестить("ОбновитьДанныеОбъектаРасчета", Объект.Ссылка);
	ПослеЗаписиПереопределяемый(ПараметрыЗаписи);
КонецПроцедуры

#КонецОбласти

#Область Команды

&НаКлиенте
Процедура КомандаУстановитьНагрузку(Команда)
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ЗакрытиеФормыУстановитьПериодическиеПараметры", ЭтаФорма);

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗначенияЗаполнения = Новый Структура("ОбъектРасчета, Район, Организация", Объект.Ссылка, энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.МКД,"Район"), объект.Организация);
		ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЗначенияЗаполнения);
		ОткрытьФорму("Документ.бестУстановитьНагрузкуПоУслугам.ФормаОбъекта", ПараметрыФормы,ЭтаФорма,,,,ОповещениеОЗакрытии);
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура КомандаУстановитьУчастиеВРаспределенииВМКД(Команда)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗначенияЗаполнения = Новый Структура("ОбъектРасчета, Район", Объект.Ссылка, энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.МКД,"Район"));
		ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЗначенияЗаполнения);
		Форма = ПолучитьФорму("Документ.бестУстановитьУчастиеОбъектаВРаспределенииРесурсовВМКД.Форма.ФормаДокумента", ПараметрыФормы, ЭтаФорма);
		
		Форма.Элементы.ОбъектРасчета.Доступность = Ложь;
		Форма.Открыть();
	КонецЕсли;
КонецПроцедуры

