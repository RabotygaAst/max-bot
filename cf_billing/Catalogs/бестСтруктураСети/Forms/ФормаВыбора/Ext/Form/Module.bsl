#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	//УстановитьОтборСпискаПоКоду(ПолучитьВерхнийУровень());
	ТипСписка=0;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТипСпискаПриИзменении(Элемент)
	Если ТипСписка = 1 Тогда
		Список.Отбор.Элементы.Очистить();
		ТекущаяСтруктура = "";
		Элементы.Картинка.Видимость = Ложь;
	Иначе
		Элементы.Картинка.Видимость = Истина;
		УстановитьОтборСпискаПоКоду(ПолучитьВерхнийУровень());
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТекущаяСтруктураНажатие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ВернутьсяНазад();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	// Замена обработки выбора на "раскрытие" элемента
	Если Поле.Имя = "Картинка" Тогда
		СтандартнаяОбработка = Ложь;
		ТекущиеДанные  = Элемент.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		ТекущаяСтруктура = ТекущиеДанные.Ссылка;
		УстановитьОтборСтрокПоСтруктуре(ТекущиеДанные.Код);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьОтборСтрокПоСтруктуре(Код)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСтруктураСетиСрезПоследних.Приемник.Код КАК ПриемникКод
		|ИЗ
		|	РегистрСведений.бестСтруктураСети.СрезПоследних(, Источник.Код = &Код) КАК бестСтруктураСетиСрезПоследних";
	
	Запрос.УстановитьПараметр("Код", Код);
	
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьОтборСпискаПоКоду(РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ПриемникКод"));
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборСпискаПоКоду(МассивЭлементов)
	Список.Отбор.Элементы.Очистить();
	ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Код");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	ЭлементОтбора.Использование = Истина;
	ЭлементОтбора.ПравоеЗначение = МассивЭлементов; 		
КонецПроцедуры

&НаСервере
Функция ПолучитьВерхнийУровень()
	Запрос = Новый Запрос;
	//Запрос.Текст = 
	//	"ВЫБРАТЬ
	//	|	бестСтруктураСетиСрезПоследних.Приемник КАК Приемник
	//	|ПОМЕСТИТЬ ВТ_Приемник
	//	|ИЗ
	//	|	РегистрСведений.бестСтруктураСети.СрезПоследних КАК бестСтруктураСетиСрезПоследних
	//	|ГДЕ
	//	|	бестСтруктураСетиСрезПоследних.Актуальность
	//	|;
	//	|
	//	|////////////////////////////////////////////////////////////////////////////////
	//	|ВЫБРАТЬ
	//	|	бестСтруктураСетиСрезПоследних.Источник КАК Источник,
	//	|	бестСтруктураСетиСрезПоследних.Источник.Код КАК ИсточникКод
	//	|ИЗ
	//	|	РегистрСведений.бестСтруктураСети.СрезПоследних(
	//	|			,
	//	|			НЕ Источник В
	//	|					(ВЫБРАТЬ
	//	|						ВТ_Приемник.Приемник КАК Приемник
	//	|					ИЗ
	//	|						ВТ_Приемник КАК ВТ_Приемник)) КАК бестСтруктураСетиСрезПоследних
	//	|
	//	|СГРУППИРОВАТЬ ПО
	//	|	бестСтруктураСетиСрезПоследних.Источник";
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСтруктураСетиСрезПоследних.Источник КАК Источник,
		|	бестСтруктураСетиСрезПоследних.Источник.Код КАК ИсточникКод
		|ИЗ
		|	РегистрСведений.бестСтруктураСети.СрезПоследних(, ) КАК бестСтруктураСетиСрезПоследних
		|ГДЕ
		|	бестСтруктураСетиСрезПоследних.Актуальность
		|	И бестСтруктураСетиСрезПоследних.ВерхнийУровень";

	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ИсточникКод");

КонецФункции

&НаСервере
Процедура ВернутьсяНазад()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСтруктураСетиСрезПоследних.Источник КАК Источник,
		|	бестСтруктураСетиСрезПоследних.Источник.Код КАК ИсточникКод
		|ИЗ
		|	РегистрСведений.бестСтруктураСети.СрезПоследних(, Приемник = &ТекущаяСтруктура) КАК бестСтруктураСетиСрезПоследних
		|ГДЕ
		|	бестСтруктураСетиСрезПоследних.Актуальность
		|	И бестСтруктураСетиСрезПоследних.Источник <> ЗНАЧЕНИЕ(Справочник.бестСтруктураСети.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("ТекущаяСтруктура", ТекущаяСтруктура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ТекущаяСтруктура = ВыборкаДетальныеЗаписи.Источник;
		УстановитьОтборСтрокПоСтруктуре(ВыборкаДетальныеЗаписи.ИсточникКод);
	Иначе
		ТекущаяСтруктура = "";
		УстановитьОтборСпискаПоКоду(ПолучитьВерхнийУровень());
	КонецЕсли;		
КонецПроцедуры

#КонецОбласти

