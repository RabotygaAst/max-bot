//{{MRG[ <-> ]
//// Функиця получает список документов и справочников объектов метаданных.
//// .
//}}MRG[ <-> ]
&НаСервере
Функция ПолучитьСписокДокИСпр()
	
	СписокДокументов = Новый СписокЗначений;
	СписокСправочников = Новый СписокЗначений;
		
	Для каждого Объект Из Метаданные.Документы Цикл
		Попытка
			Значение = Документы[Объект.Имя].ПустаяСсылка();
			Представление = ?(Объект.Синоним = "", Объект.Имя, Объект.Синоним);
			СписокДокументов.Добавить(Значение, Представление);
		Исключение
			Продолжить;
		КонецПопытки;
	КонецЦикла;
	
	Для каждого Объект Из Метаданные.Справочники Цикл
		Попытка
			Значение = Справочники[Объект.Имя].ПустаяСсылка();
			Представление = ?(Объект.Синоним = "", Объект.Имя, Объект.Синоним);
			СписокСправочников.Добавить(Значение, Представление);
		Исключение
			Продолжить;
		КонецПопытки;
	КонецЦикла;
	
	СписокДокументов.СортироватьПоПредставлению();
	СписокСправочников.СортироватьПоПредставлению();
	
	РезультатСтруктура = Новый Структура("СписокДокументов,СписокСправочников", СписокДокументов, СписокСправочников);
	
	Возврат РезультатСтруктура;  
	
КонецФункции

