#Область РеализацияИнтерфейса

// Получает значения реквизитов по ссылке.
//
// Параметры:
//  АбонентСсылка	-	СправочникСсылка.энргАбоненты.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция РезультатЗначенияРеквизитовПоСсылке(АбонентСсылка) Экспорт 
		
	Запрос  	= Новый Запрос(ТекстЗапросаЗначенияРеквизитовПоСсылке());
	Запрос.УстановитьПараметр("Абонент",АбонентСсылка);
	Возврат Запрос.Выполнить();
	
КонецФункции

// Получает значения реквизитов объекта.
//
// Параметры:
//  АбонентСсылка		-	СправочникСсылка.энргАбоненты.
//  ПолучаемыеСвойства	-	Структура.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ЗначенияРеквизитовОбъекта(АбонентСсылка, ПолучаемыеСвойства) Экспорт	
	
	Результат 			= Новый Структура(ПолучаемыеСвойства);
	РезультатЗапроса  	= РезультатЗначенияРеквизитовПоСсылке(АбонентСсылка);
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка 		= РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЗаполнитьЗначенияСвойств(Результат,Выборка);
		АдресАбонента = Выборка.АдресОбъекта;
		КоличествоСимволовСтроки = СтрДлина(АдресАбонента);
		Фиктивное = СтрНайти(АдресАбонента, "фиктивное");
		Если Фиктивное > 0 Тогда 
			Разница = КоличествоСимволовСтроки - Фиктивное;
			АдресАбонента = Лев(АдресАбонента, СтрДлина(АдресАбонента) - Разница-3);
			Если Результат.Свойство("АдресОбъекта") Тогда
			Результат.АдресОбъекта = АдресАбонента;
			КонецЕсли;
		КонецЕсли;

	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает массив ссылок полнотекствого поиска.
//
// Параметры:
//  СтрокаПоиска	-	Строка.
// 
// Возвращаемое значение:
//   Массив из СправочникСсылка.энргАбоненты.
//
Функция МассивСсылокПолноТекствогоПоиска(СтрокаПоиска) Экспорт 
	перем РезультатЗапроса;
		
	мСтрокиПоиска 		= СтрРазделить(СтрокаПоиска," ",Ложь);
	Схема 				= Новый СхемаЗапроса();
	Схема.УстановитьТекстЗапроса(ТекстЗапросаПолноТекстовыйПоискЗапросом());
	Пакет 				= Схема.ПакетЗапросов[0];
	Оператор 			= Пакет.Операторы[0];
	Отбор	 			= Оператор.Отбор;
	ОтборЭталон 		= Отбор[0];
	Для Индекс = 1 По мСтрокиПоиска.ВГраница() Цикл
		Отбор.Добавить(СтрЗаменить(ОтборЭталон,"&СтрокаПоиска1","&СтрокаПоиска" + (Индекс+1)));
	КонецЦикла;
	
	Запрос  			= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Для Индекс = 0 По мСтрокиПоиска.ВГраница() Цикл
		Запрос.УстановитьПараметр("СтрокаПоиска" + (Индекс+1), мСтрокиПоиска[Индекс]);
	КонецЦикла;
	
	РезультатЗапроса 	= Запрос.Выполнить();
			
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Получает ссылку по ключевым параметрам.
//
// Параметры:
//  ДатаДокумента	-	Дата.
//  Организация		-	СправочникСсылка.Организации.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  КлючПомещения	-	СправочникСсылка.энргКлючиПомещений.
//  ФизЛицо			-	СправочникСсылка.энргКонтрагенты.
//  Поставщик		-	СправочникСсылка.Организации.
//  Услуги			-	Массив из СправочникСсылка.энргВидыУслуг.
// 
// Возвращаемое значение:
//   СправочникСсылка.энргАбоненты.
//
Функция СсылкаПоКлючевымПараметрам(ДатаДокумента,Организация,Район,КлючПомещения,ФизЛицо,Поставщик,Услуги) Экспорт 
			
	Запрос  		= Новый Запрос;
	МВТ	= новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Дата",				Новый Граница(НачалоДня(ДатаДокумента),ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Услуги",				Услуги);
	Запрос.УстановитьПараметр("ФизЛицо",			ФизЛицо);
	Запрос.УстановитьПараметр("КлючПомещения",		КлючПомещения);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Поставщик",			Поставщик);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	Услуги.Услуга КАК Услуга
	|ПОМЕСТИТЬ ВТ_Услуги
	|ИЗ
	|	&Услуги КАК Услуги
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргАбоненты.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_АбонентыЭтогоПомещения
	|ИЗ
	|	Справочник.энргАбоненты КАК энргАбоненты
	|ГДЕ
	|	энргАбоненты.ФизЛицо = &ФизЛицо
	|	И энргАбоненты.КлючПомещения = &КлючПомещения
	|	И энргАбоненты.Район = &Район
	|	И энргАбоненты.Организация = &Организация
	|	И энргАбоненты.Поставщик = &Поставщик
	|	И НЕ энргАбоненты.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеЛССрезПоследних.Абонент КАК Абонент
	|ПОМЕСТИТЬ ВТ_АктивныеАбонентыЭтогоПомещения
	|ИЗ
	|	РегистрСведений.энргСостояниеЛС.СрезПоследних(
	|			&Дата,
	|			Абонент В
	|				(ВЫБРАТЬ
	|					ВТ.Ссылка
	|				ИЗ
	|					ВТ_АбонентыЭтогоПомещения КАК ВТ)) КАК энргСостояниеЛССрезПоследних
	|ГДЕ
	|	энргСостояниеЛССрезПоследних.Состояние
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргАбонентыПомещенийСрезПоследних.Абонент КАК Абонент
	|ПОМЕСТИТЬ ВТ_АбонентыЭтогоПомещенияДляУказанныхУслуг
	|ИЗ
	|	РегистрСведений.энргАбонентыПомещений.СрезПоследних(
	|			&Дата,
	|			Услуга В
	|					(ВЫБРАТЬ
	|						ВТ.Услуга
	|					ИЗ
	|						ВТ_Услуги КАК ВТ)
	|				И КлючПомещения = &КлючПомещения) КАК энргАбонентыПомещенийСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	энргАбонентыПомещенийСрезПоследних.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_АктивныеАбонентыЭтогоПомещения.Абонент КАК Абонент
	|ИЗ
	|	ВТ_АктивныеАбонентыЭтогоПомещения КАК ВТ_АктивныеАбонентыЭтогоПомещения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_АбонентыЭтогоПомещенияДляУказанныхУслуг КАК ВТ_АбонентыЭтогоПомещенияДляУказанныхУслуг
	|		ПО ВТ_АктивныеАбонентыЭтогоПомещения.Абонент = ВТ_АбонентыЭтогоПомещенияДляУказанныхУслуг.Абонент
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_АктивныеАбонентыЭтогоПомещения.Абонент";
	
	Если ФизЛицо = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргАбоненты.ФизЛицо = &ФизЛицо", "ИСТИНА");
	КонецЕсли;
	
	РезультатЗапроса			= Запрос.Выполнить();
	Выборка 					= РезультатЗапроса.Выбрать(); 
	Если Выборка.Следующий() тогда
		Возврат Выборка.Абонент; 
	КонецЕсли;
	
	Возврат Справочники.энргАбоненты.ПустаяСсылка();
	
КонецФункции

// Заполняет объект по описанию.
//
// Параметры:
//  АбонентСсылка	-	СправочникСсылка.энргАбоненты.
//  ОписаниеОбъекта	-	Структура.
//  ЛицевойСчет		-	Строка.
//  ЭтоНоваяСсылка	-	Булево.
//
Процедура ЗаполнитьОбъектПоОписанию(АбонентСсылка, ОписаниеОбъекта, ЛицевойСчет, ЭтоНоваяСсылка) Экспорт 
	
	Если ЭтоНоваяСсылка Тогда
		АбонентОбъект 									= СоздатьЭлемент();
		АбонентОбъект.УстановитьСсылкуНового(АбонентСсылка);
	Иначе
		АбонентОбъект 									= АбонентСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЕстьИзменения 										= Ложь;
	Если НЕ АбонентОбъект.Организация = ОписаниеОбъекта.Организация Тогда 
		АбонентОбъект.Организация 						= ОписаниеОбъекта.Организация;
		ЕстьИзменения									= Истина;
	КонецЕсли;
	
	Если НЕ АбонентОбъект.Район = ОписаниеОбъекта.Район Тогда 
		АбонентОбъект.Район 							= ОписаниеОбъекта.Район;
		ЕстьИзменения									= Истина;
	КонецЕсли;
	
	Если НЕ АбонентОбъект.Родитель = ОписаниеОбъекта.ГруппаАбонента Тогда
		АбонентОбъект.Родитель 							= ОписаниеОбъекта.ГруппаАбонента;
		ЕстьИзменения									= Истина;
	КонецЕсли;
	
	Если НЕ АбонентОбъект.КлючПомещения = ОписаниеОбъекта.КлючПомещения Тогда
		АбонентОбъект.КлючПомещения 					= ОписаниеОбъекта.КлючПомещения;
		ЕстьИзменения									= Истина;
	КонецЕсли;
	
	Если НЕ АбонентОбъект.ФизЛицо = ОписаниеОбъекта.ФизЛицо Тогда
		АбонентОбъект.ФизЛицо 							= ОписаниеОбъекта.ФизЛицо;
		АбонентОбъект.Наименование 						= СокрЛП(ОписаниеОбъекта.ФизЛицо);
		ЕстьИзменения									= Истина;
	КонецЕсли;
	
	Если НЕ АбонентОбъект.ВидОбъекта = ОписаниеОбъекта.ВидОбъекта Тогда
		АбонентОбъект.ВидОбъекта 						= ОписаниеОбъекта.ВидОбъекта;
		ЕстьИзменения									= Истина;
	КонецЕсли;
		
	Если ЭтоНоваяСсылка Тогда  
		АбонентОбъект.ЛицевойСчет 						= ЛицевойСчет;
	КонецЕсли;
	
	Если ОписаниеОбъекта.Свойство("МуниципальноеОбразование") Тогда
		Если НЕ АбонентОбъект.МуниципальноеОбразование = ОписаниеОбъекта.МуниципальноеОбразование Тогда
			АбонентОбъект.МуниципальноеОбразование 		= ОписаниеОбъекта.МуниципальноеОбразование;
			ЕстьИзменения								= Истина;
		КонецЕсли;		
	КонецЕсли;
		
	Если ОписаниеОбъекта.Свойство("СтарыйЛС") Тогда
