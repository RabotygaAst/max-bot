#Область ТекстыЗапросов

Функция ТекстЗапросаЗначенияРеквизитовПоСсылке()
	Текст 		=
	"ВЫБРАТЬ
	|	Абоненты.Ссылка КАК Абонент,
	|	Абоненты.КлючПомещения КАК КлючПомещения,
	|	энргКлючиПомещений.Строение КАК Строение,
	|	энргКлючиПомещений.Помещение КАК Помещение,
	|	Абоненты.Район КАК Район,
	|	Абоненты.ЛицевойСчет КАК ЛицевойСчет,
	|	Абоненты.Организация КАК Организация,
	|	Абоненты.Родитель КАК ГруппаАбонента,
	|	энргКлючиПомещений.ЧастныйСектор КАК ЧастныйСектор,
	|	ВЫБОР
	|		КОГДА энргКлючиПомещений.ЧастныйСектор
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|		ИНАЧЕ энргКлючиПомещений.Строение
	|	КОНЕЦ КАК МКД,
	|	Абоненты.ФизЛицо КАК Контрагент,
	|	Абоненты.ВидОбъекта КАК ВидОбъекта,
	|	Абоненты.МуниципальноеОбразование КАК МуниципальноеОбразование,
	|	энргФилиалыАбонентовСрезПоследних.Филиал КАК АбонентскийОтдел
	|ПОМЕСТИТЬ НачальныеДанные
	|ИЗ
	|	Справочник.энргАбоненты КАК Абоненты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО Абоненты.КлючПомещения = энргКлючиПомещений.КлючПомещения
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргФилиалыАбонентов.СрезПоследних(, Абонент = &Абонент) КАК энргФилиалыАбонентовСрезПоследних
	|		ПО (энргФилиалыАбонентовСрезПоследних.Абонент = Абоненты.Ссылка)
	|ГДЕ
	|	Абоненты.Ссылка = &Абонент
	|
	|СГРУППИРОВАТЬ ПО
	|	энргКлючиПомещений.Строение,
	|	ВЫБОР
	|		КОГДА энргКлючиПомещений.ЧастныйСектор
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|		ИНАЧЕ энргКлючиПомещений.Строение
	|	КОНЕЦ,
	|	Абоненты.МуниципальноеОбразование,
	|	Абоненты.Район,
	|	Абоненты.ФизЛицо,
	|	Абоненты.Организация,
	|	Абоненты.ВидОбъекта,
	|	энргКлючиПомещений.Помещение,
	|	энргКлючиПомещений.ЧастныйСектор,
	|	Абоненты.Родитель,
	|	Абоненты.ЛицевойСчет,
	|	Абоненты.КлючПомещения,
	|	энргФилиалыАбонентовСрезПоследних.Филиал,
	|	Абоненты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НачальныеДанные.Абонент КАК Абонент,
	|	НачальныеДанные.КлючПомещения КАК КлючПомещения,
	|	НачальныеДанные.Строение КАК Строение,
	|	НачальныеДанные.Помещение КАК Помещение,
	|	НачальныеДанные.Район КАК Район,
	|	НачальныеДанные.ЛицевойСчет КАК ЛицевойСчет,
	|	НачальныеДанные.Организация КАК Организация,
	|	НачальныеДанные.ГруппаАбонента КАК ГруппаАбонента,
	|	НачальныеДанные.ЧастныйСектор КАК ЧастныйСектор,
	|	НачальныеДанные.МКД КАК МКД,
	|	НачальныеДанные.Контрагент КАК Контрагент,
	|	НачальныеДанные.ВидОбъекта КАК ВидОбъекта,
	|	НачальныеДанные.МуниципальноеОбразование КАК МуниципальноеОбразование,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА НачальныеДанные.Помещение.Фиктивное
	|				ТОГДА энргСтроенияКонтактнаяИнформация.Представление
	|			ИНАЧЕ ЕСТЬNULL(энргПомещенияКонтактнаяИнформация.Представление, энргСтроенияКонтактнаяИнформация.Представление)
	|		КОНЕЦ) КАК АдресОбъекта,
	|	МАКСИМУМ(ЕСТЬNULL(энргПомещенияКонтактнаяИнформация.Представление, энргСтроенияКонтактнаяИнформация.Представление)) КАК АдресОбъектаБезУсловий,
	|	НачальныеДанные.АбонентскийОтдел КАК АбонентскийОтдел
	|ИЗ
	|	НачальныеДанные КАК НачальныеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
	|		ПО НачальныеДанные.Строение = энргСтроенияКонтактнаяИнформация.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения.КонтактнаяИнформация КАК энргПомещенияКонтактнаяИнформация
	|		ПО НачальныеДанные.Помещение = энргПомещенияКонтактнаяИнформация.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	НачальныеДанные.МКД,
	|	НачальныеДанные.ЧастныйСектор,
	|	НачальныеДанные.ГруппаАбонента,
	|	НачальныеДанные.Помещение,
	|	НачальныеДанные.КлючПомещения,
	|	НачальныеДанные.ВидОбъекта,
	|	НачальныеДанные.Контрагент,
	|	НачальныеДанные.Район,
	|	НачальныеДанные.ЛицевойСчет,
	|	НачальныеДанные.Организация,
	|	НачальныеДанные.МуниципальноеОбразование,
	|	НачальныеДанные.Строение,
	|	НачальныеДанные.АбонентскийОтдел,
	|	НачальныеДанные.Абонент";
		
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаПолноТекстовыйПоискЗапросом()
	Текст  = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Ссылка КАК Ссылка,
	|	ВложенныйЗапрос.Наименование КАК Наименование,
	|	ВложенныйЗапрос.ЛицевойСчет КАК ЛицевойСчет,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ЕСТЬNULL(энргСтроения.Наименование, """") КАК Строение,
	|	ЕСТЬNULL(энргПомещения.Наименование, """") КАК Помещение
	|ИЗ
	|	(ВЫБРАТЬ
	|		Абоненты.Ссылка КАК Ссылка,
	|		Абоненты.Наименование КАК Наименование,
	|		Абоненты.ЛицевойСчет КАК ЛицевойСчет,
	|		ЕСТЬNULL(Организации.Наименование, """") КАК Организация,
	|		КлючиПомещений.Строение КАК Строение,
	|		КлючиПомещений.Помещение КАК Помещение
	|	ИЗ
	|		Справочник.энргАбоненты КАК Абоненты
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|			ПО Абоненты.Организация = Организации.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК КлючиПомещений
	|			ПО Абоненты.КлючПомещения = КлючиПомещений.КлючПомещения
	|	ГДЕ
	|		НЕ Абоненты.ПометкаУдаления
	|		И НЕ Абоненты.ЭтоГруппа) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения КАК энргСтроения
	|		ПО ВложенныйЗапрос.Строение = энргСтроения.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения КАК энргПомещения
	|		ПО ВложенныйЗапрос.Помещение = энргПомещения.Ссылка
	|ГДЕ
	|	(ВложенныйЗапрос.Наименование ПОДОБНО ""%"" + &СтрокаПоиска1 + ""%""
	|			ИЛИ ВложенныйЗапрос.ЛицевойСчет ПОДОБНО ""%"" + &СтрокаПоиска1 + ""%""
	|			ИЛИ ЕСТЬNULL(энргСтроения.Наименование, """") ПОДОБНО ""%"" + &СтрокаПоиска1 + ""%""
	|			ИЛИ ЕСТЬNULL(энргПомещения.Наименование, """") ПОДОБНО ""%"" + &СтрокаПоиска1 + ""%"")";
	
	Возврат Текст;
	
КонецФункции

