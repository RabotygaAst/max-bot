Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" и не Параметры.свойство("Ключ") тогда
		
		СтандартнаяОбработка 	= ложь;
		
		ЕстьЗначенияЗаполнения  	= Параметры.свойство("ЗначенияЗаполнения");
		
		Если ЕстьЗначенияЗаполнения тогда
			ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС");
			Параметры.ЗначенияЗаполнения.Вставить("ВидОперации",ВидОперации);
		КонецЕсли;
		
		ВыбраннаяФорма 			= "Документ.энргОперацияСЛицевымСчетом.Форма.ФормаДокументаОткрытиеЛС";
	КонецЕсли;
	
