
#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	энргЛокализацияСервер.ПриСозданииНаСервере_энргАбоненты(ЭтотОбъект);
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Элементы.Список.Отображение = ОтображениеТаблицы.Список;
КонецПроцедуры

#КонецОбласти

#Область СобытияСписок

&НаКлиенте
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ТекСтрока = Элементы.Список.ТекущиеДанные;

	Если ТекСтрока = Неопределено тогда
		Возврат;
	КонецЕсли;
			
	Если ТекСтрока.Свойство("Ссылка") Тогда 		
		ТекЭлемент = ТекСтрока.ссылка;
		
		УстановитьОтборПоВсемДинамическимСпискам(ТекСтрока);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область КомандыФормы

&НаКлиенте
Процедура ИзменитьВыделенные(Команда)
	ГрупповоеИзменениеОбъектовКлиент.ИзменитьВыделенные(Элементы.Список); 
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьЛС(Команда)
	
	ТекСтрока = Элементы.Список.ТекущиеДанные;
	Если ТекСтрока = Неопределено тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран абонент");
		Возврат;
	КонецЕсли;
	
	Если ТекСтрока.ЭтоГруппа тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Закрытие лицевого для группы не доступно");
		Возврат;
	КонецЕсли; 	
	
	ДанныеЗаполнения  = Новый Структура;
	ДанныеЗаполнения.Вставить("ВидОперации",ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСЛС_ЗакрытиеЛС"));
	ДанныеЗаполнения.Вставить("Абонент",ТекСтрока.ссылка);
	ДанныеЗаполнения.Вставить("Район",ТекСтрока.Район);
	ДанныеЗаполнения.Вставить("Организация",ТекСтрока.Организация);
	ДанныеЗаполнения.Вставить("КлючПомещения",ТекСтрока.КлючПомещения);
	
	ПараметрыОткрытия  =Новый Структура;
	ПараметрыОткрытия.Вставить("ЗначенияЗаполнения",ДанныеЗаполнения);
	ПараметрыОткрытия.Вставить("ЗаполнитьДокумент",Истина);	
	ОткрытьФорму("Документ.энргОперацияСЛицевымСчетом.Форма.ФормаДокументаЗакрытиеЛС",ПараметрыОткрытия);
	
КонецПроцедуры

