#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Функция - Сформировать печатную форму этапа
//
// Параметры:
//  МассивОбъектов		 - Массив 				- Массив объектов. 
//  ИмяМакета			 - Строка 				- Имя макета. 
//  ТабличныйДокумент	 - ТабличныйДокумент 	- Табличный документ.
//  ОбластиМакета		 - Структура 			- Области макета. 
//  ТекстОшибки			 - Строка 				- Текст ошибки. 
// 
// Возвращаемое значение:
//  Булево - Сформирована печатная форма или нет. 
//
Функция СформироватьПечатнуюФормуЭтапа(МассивОбъектов, ИмяМакета, ТабличныйДокумент, ОбластиМакета = Неопределено, ТекстОшибки = "") Экспорт 
	Результат = Ложь;
	
	Если ОбластиМакета = Неопределено Тогда
		ОбластиМакета = Новый Структура;
		ОбластиМакета.Вставить("БланкФилиала");
		ОбластиМакета.Вставить("Шапка");
		ОбластиМакета.Вставить("Квитанция");
	КонецЕсли;
		
	Попытка
		Макет = УправлениеПечатью.МакетПечатнойФормы("Справочник.энргВидыОперацийПИД." + ИмяМакета);
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		Возврат Результат;
	КонецПопытки;
	
	Для каждого КлючЗначение из ОбластиМакета Цикл
		Попытка
			ОбластиМакета[КлючЗначение.Ключ] = Макет.ПолучитьОбласть(КлючЗначение.Ключ);
		Исключение
			ОбластиМакета[КлючЗначение.Ключ] = Неопределено;
		КонецПопытки;
	КонецЦикла;
			
	ПервыйДокумент = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЕСТЬNULL(энргКонтрагенты.бестФамилия, """") КАК Фамилия,
		|	ЕСТЬNULL(энргКонтрагенты.бестИмя, """") КАК Имя,
		|	ЕСТЬNULL(энргКонтрагенты.бестОтчество, """") КАК Отчество,
		|	энргЗадачаПИД.АдресОбъекта КАК АдресОбъекта,
		|	энргЗадачаПИД.ЛицевойСчет КАК ЛицевойСчет,
		|	энргЗадачаПИД.СуммаЗадолженности КАК СуммаЗадолженности,
		|	энргЗадачаПИД.ДатаСледЭтапа КАК ДатаСледЭтапа,
		|	энргЗадачаПИД.Ссылка КАК Задача,
		|	Организации.ИНН КАК ИНН,
		|	БанковскиеСчета.НомерСчета КАК РасчСчет,
		|	БанковскиеСчета.Банк КАК Банк,
		|	Банки.Наименование КАК БанкНаименование,
		|	Банки.Код КАК БИК,
		|	Банки.КоррСчет КАК КоррСчет,
		|	Организации.Наименование КАК Организация,
		|	энргАбоненты.ВидОбъекта КАК ВидОбъекта,
		|	энргЗадачаПИД.Абонент КАК Абонент,
		|	энргАбоненты.КлючПомещения.Строение КАК МКД,
		|	ВЫБОР
		|		КОГДА энргЗадачаПИД.Район.НаименованиеПоставщика = """"
		|			ТОГДА энргЗадачаПИД.Район
		|		ИНАЧЕ энргЗадачаПИД.Район.НаименованиеПоставщика
		|	КОНЕЦ КАК Район,
		|	энргЗадачаПИД.Организация КАК ОрганизацияСсылка,
		|	энргЗадачаПИД.Дата КАК Дата,
		|	Организации.НаименованиеПолное КАК ОрганизацияНаименованиеПолное,
		|	Организации.НаименованиеСокращённое КАК ОрганизацияНаименованиеСокращённое,
		|	энргАбоненты.КлючПомещения КАК КлючПомещения,
		|	энргЗадачаПИД.Номер КАК НомерЗадачи,
		|	энргЗадачаПИД.Район КАК РайонСсылка,
		|	ВЫБОР
		|		КОГДА энргЗадачаПИД.Этап = ЗНАЧЕНИЕ(Справочник.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Уведомление)
		|			ТОГДА ""УФ""
		|		КОГДА энргЗадачаПИД.Этап = ЗНАЧЕНИЕ(Справочник.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Предупреждение)
		|			ТОГДА ""ПФ""
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК Постфикс,
		|	энргЗадачаПИД.Договор КАК Договор
		|ПОМЕСТИТЬ ВТ_ОсновныеДанные
		|ИЗ
		|	Задача.энргЗадачаПИД КАК энргЗадачаПИД
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		|		ПО энргЗадачаПИД.Абонент = энргАбоненты.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|		ПО энргЗадачаПИД.Договор = ДоговорыКонтрагентов.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
		|		ПО (ВЫБОР
		|				КОГДА энргЗадачаПИД.Договор <> ЗНАЧЕНИЕ(справочник.энргДоговорыКонтрагентов.пустаяссылка)
		|					ТОГДА ДоговорыКонтрагентов.Контрагент = энргКонтрагенты.Ссылка
		|				КОГДА энргЗадачаПИД.Абонент <> ЗНАЧЕНИЕ(справочник.энргабоненты.пустаяссылка)
		|					ТОГДА энргАбоненты.ФизЛицо = энргКонтрагенты.Ссылка
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчета
		|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторБанков КАК Банки
		|				ПО БанковскиеСчета.Банк = Банки.Ссылка
		|			ПО Организации.ОсновнойБанковскийСчет = БанковскиеСчета.Ссылка
		|		ПО энргЗадачаПИД.Организация = Организации.Ссылка
		|ГДЕ
		|	энргЗадачаПИД.Ссылка В(&МассивОбъектов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗоныОтвественностиФилиалы.Ссылка КАК Район,
		|	энргФилиалыИзменяемыеРеквизиты.Организация КАК Организация,
		|	МАКСИМУМ(энргФилиалыИзменяемыеРеквизиты.НомерСтроки) КАК НомерСтроки_Филиал,
		|	энргЗоныОтвественностиФилиалы.НомерСтроки КАК НомерСтроки_Район
		|ПОМЕСТИТЬ ВТ_ВсеФилиалы
		|ИЗ
		|	Справочник.энргЗоныОтвественности.Филиалы КАК энргЗоныОтвественностиФилиалы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргФилиалы.ИзменяемыеРеквизиты КАК энргФилиалыИзменяемыеРеквизиты
		|		ПО энргЗоныОтвественностиФилиалы.Филиал = энргФилиалыИзменяемыеРеквизиты.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ОсновныеДанные КАК ВТ_ОсновныеДанные
		|		ПО энргЗоныОтвественностиФилиалы.Ссылка = ВТ_ОсновныеДанные.РайонСсылка
		|			И (энргФилиалыИзменяемыеРеквизиты.Организация = ВТ_ОсновныеДанные.ОрганизацияСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	энргЗоныОтвественностиФилиалы.Ссылка,
		|	энргФилиалыИзменяемыеРеквизиты.Организация,
		|	энргЗоныОтвественностиФилиалы.НомерСтроки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ВсеФилиалы.Район КАК Район,
		|	ВТ_ВсеФилиалы.Организация КАК Организация,
		|	МАКСИМУМ(ВТ_ВсеФилиалы.НомерСтроки_Район) КАК НомерСтроки_Район
		|ПОМЕСТИТЬ ВТ_НомерСтрокиРайон
		|ИЗ
		|	ВТ_ВсеФилиалы КАК ВТ_ВсеФилиалы
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ВсеФилиалы.Район,
		|	ВТ_ВсеФилиалы.Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ВсеФилиалы.Район КАК Район,
		|	ВТ_ВсеФилиалы.Организация КАК Организация,
		|	энргКонтрагенты.КодПоОКПО КАК ОКПО_Филиала,
		|	энргКонтрагенты.ОГРН КАК ОГРН_Филиала,
		|	энргКонтрагенты.ИНН КАК ИНН_Филиала,
		|	энргКонтрагенты.КПП КАК КПП_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ЮридическийАдрес_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК Адрес_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК КонтактныйЦентр_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.СайтКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК АдресСайта_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ЭлекАдрес_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК Факс_Филиала,
		|	энргЗоныОтвественности.Префикс КАК Префикс,
		|	энргКонтрагенты.Наименование КАК НаименованиеРайона,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресАбонПунктаПоставщикаУслуг)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК АдресБлижайшегоПункта_Филиала
		|ПОМЕСТИТЬ ВТ_ДанныеФилиала
		|ИЗ
		|	ВТ_ВсеФилиалы КАК ВТ_ВсеФилиалы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_НомерСтрокиРайон КАК ВТ_НомерСтрокиРайон
		|		ПО ВТ_ВсеФилиалы.Организация = ВТ_НомерСтрокиРайон.Организация
		|			И ВТ_ВсеФилиалы.Район = ВТ_НомерСтрокиРайон.Район
		|			И ВТ_ВсеФилиалы.НомерСтроки_Район = ВТ_НомерСтрокиРайон.НомерСтроки_Район
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргЗоныОтвественности.Филиалы КАК энргЗоныОтвественностиФилиалы
		|		ПО ВТ_ВсеФилиалы.Район = энргЗоныОтвественностиФилиалы.Ссылка
		|			И ВТ_ВсеФилиалы.НомерСтроки_Район = энргЗоныОтвественностиФилиалы.НомерСтроки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргФилиалы.ИзменяемыеРеквизиты КАК энргФилиалыИзменяемыеРеквизиты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
		|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
		|				ПО энргКонтрагенты.Ссылка = энргКонтрагентыКонтактнаяИнформация.Ссылка
		|					И (энргКонтрагентыКонтактнаяИнформация.Вид В (ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.СайтКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресАбонПунктаПоставщикаУслуг)))
		|			ПО энргФилиалыИзменяемыеРеквизиты.Контрагент = энргКонтрагенты.Ссылка
		|		ПО ВТ_ВсеФилиалы.НомерСтроки_Филиал = энргФилиалыИзменяемыеРеквизиты.НомерСтроки
		|			И (энргЗоныОтвественностиФилиалы.Филиал = энргФилиалыИзменяемыеРеквизиты.Ссылка)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргЗоныОтвественности КАК энргЗоныОтвественности
		|		ПО ВТ_ВсеФилиалы.Район = энргЗоныОтвественности.Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ВсеФилиалы.Район,
		|	ВТ_ВсеФилиалы.Организация,
		|	энргКонтрагенты.КодПоОКПО,
		|	энргКонтрагенты.ОГРН,
		|	энргКонтрагенты.ИНН,
		|	энргКонтрагенты.КПП,
		|	энргЗоныОтвественности.Префикс,
		|	энргКонтрагенты.Наименование
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗначениеПлощадейМКДСрезПоследних.ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадьМКД)
		|				ТОГДА энргЗначениеПлощадейМКДСрезПоследних.Площадь
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ОбщаяПлощадьМКД,
		|	энргЗначениеПлощадейМКДСрезПоследних.МКД КАК МКД,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗначениеПлощадейМКДСрезПоследних.ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ПлощадьМОП)
		|				ТОГДА энргЗначениеПлощадейМКДСрезПоследних.Площадь
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ПлощатьМОП
		|ПОМЕСТИТЬ ВТ_ПлощадьМКД
		|ИЗ
		|	РегистрСведений.энргЗначениеПлощадейМКД.СрезПоследних(
		|			&Период,
		|			(Организация, Район, МКД) В
		|					(ВЫБРАТЬ
		|						ВТ.ОрганизацияСсылка,
		|						ВТ.РайонСсылка,
		|						ВТ.МКД
