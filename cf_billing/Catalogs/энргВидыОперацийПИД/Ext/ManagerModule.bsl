		|	ВТ_ОсновныеДанные.СуммаЗадолженности КАК СуммаЗадолженности,
		|	ВТ_ПериодЗадолженности.ЗадолженностьНачало КАК ЗадолженностьНачало,
		|	ВТ_ПериодЗадолженности.ЗадолженностьОкончание КАК ЗадолженностьОкончание,
		|	ВТ_ОсновныеДанные.ДатаСледЭтапа КАК ДатаСледЭтапа,
		|	ВТ_ОсновныеДанные.Задача КАК Задача,
		|	ВТ_ОсновныеДанные.ИНН КАК ИНН,
		|	ВТ_ОсновныеДанные.РасчСчет КАК РасчСчет,
		|	ВТ_ОсновныеДанные.Банк КАК Банк,
		|	ВТ_ОсновныеДанные.БИК КАК БИК,
		|	ВТ_ОсновныеДанные.КоррСчет КАК КоррСчет,
		|	ВТ_ОсновныеДанные.Организация КАК Организация,
		|	ВТ_ОсновныеДанные.ВидОбъекта КАК ВидОбъекта,
		|	ВТ_ОсновныеДанные.Абонент КАК Абонент,
		|	ВТ_ОсновныеДанные.МКД КАК МКД,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.НаименованиеРайона, ВТ_ОсновныеДанные.Район) КАК Район,
		|	ВТ_ОсновныеДанные.БанкНаименование КАК БанкНаименование,
		|	ВТ_ДанныеПослОплаты.ДатаПослОплаты КАК ДатаПослОплаты,
		|	ВТ_Проживающие.Количество КАК Проживающие,
		|	ВТ_Прописанные.Количество КАК Прописанные,
		|	ВТ_ПлощадьМКД.ОбщаяПлощадьМКД КАК ПлощадьДома,
		|	ВТ_ПлощадьМКД.ПлощатьМОП КАК ПлощадьМОП,
		|	ВТ_УКМКД.УК КАК УК,
		|	ЕСТЬNULL(ВТ_ПлощадьМКД.ОбщаяПлощадьМКД, 0) - ЕСТЬNULL(ВТ_ПлощадьМКД.ПлощатьМОП, 0) КАК ПлощадьЖП,
		|	энргТипСобственностиАбонентовСрезПоследних.ТипСобственности КАК ТипСобственности,
		|	ВТ_ОсновныеДанные.Дата КАК Дата,
		|	ВТ_ОсновныеДанные.ОрганизацияНаименованиеПолное КАК ОрганизацияНаименованиеПолное,
		|	ВТ_ОсновныеДанные.ОрганизацияНаименованиеСокращённое КАК ОрганизацияНаименованиеСокращённое,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.Адрес_Филиала, ВТ_ДопРеквизитыФилиала.Адрес_Филиала) КАК Адрес_Филиала,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.ЮридическийАдрес_Филиала, ВТ_ДопРеквизитыФилиала.ЮридическийАдрес_Филиала) КАК ЮридическийАдрес_Филиала,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.КонтактныйЦентр_Филиала, ВТ_ДопРеквизитыФилиала.КонтактныйЦентр_Филиала) КАК КонтактныйЦентр_Филиала,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.Факс_Филиала, ВТ_ДопРеквизитыФилиала.Факс_Филиала) КАК Факс_Филиала,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.ЭлекАдрес_Филиала, ВТ_ДанныеФилиала.ЭлекАдрес_Филиала) КАК ЭлекАдрес_Филиала,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.АдресСайта_Филиала, ВТ_ДопРеквизитыФилиала.АдресСайта_Филиала) КАК АдресСайта_Филиала,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.ОКПО_Филиала, ВТ_ДопРеквизитыФилиала.ОКПО_Филиала) КАК ОКПО_Филиала,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.ОГРН_Филиала, ВТ_ДопРеквизитыФилиала.ОГРН_Филиала) КАК ОГРН_Филиала,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.КПП_Филиала, ВТ_ДопРеквизитыФилиала.КПП_Филиала) КАК КПП_Филиала,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.ИНН_Филиала, ВТ_ДопРеквизитыФилиала.ИНН_Филиала) КАК ИНН_Филиала,
		|	ВТ_ОсновныеДанные.НомерЗадачи КАК НомерЗадачи,
		|	ВТ_ПлощадьПомещения.ПлощадьПомещения КАК ОбщаяПлощадь,
		|	ВТ_ПлощадьПомещения.ЖилаяПлощадьПомещения КАК ЖилаяПлощадь,
		|	ЕСТЬNULL(ВТ_ДанныеФилиала.Префикс, ВТ_ДанныеФилиала.Префикс) КАК Префикс,
		|	ВТ_ОсновныеДанные.Постфикс КАК Постфикс,
		|	ВТ_ОсновныеДанные.Договор КАК Договор,
		|	ВТ_ДанныеФилиала.АдресБлижайшегоПункта_Филиала КАК АдресБлижайшегоПункта_Филиала
		|ИЗ
		|	ВТ_ОсновныеДанные КАК ВТ_ОсновныеДанные
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеПослОплаты КАК ВТ_ДанныеПослОплаты
		|		ПО (ВЫБОР
		|				КОГДА ВТ_ОсновныеДанные.Договор <> ЗНАЧЕНИЕ(справочник.энргДоговорыКонтрагентов.пустаяссылка)
		|					ТОГДА ВТ_ОсновныеДанные.Договор = ВТ_ДанныеПослОплаты.Договор
		|				КОГДА ВТ_ОсновныеДанные.Абонент <> ЗНАЧЕНИЕ(справочник.энргабоненты.пустаяссылка)
		|					ТОГДА ВТ_ОсновныеДанные.Абонент = ВТ_ДанныеПослОплаты.Абонент
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ)
		|			И ВТ_ОсновныеДанные.Район = ВТ_ДанныеПослОплаты.Район
		|			И ВТ_ОсновныеДанные.ОрганизацияСсылка = ВТ_ДанныеПослОплаты.ОрганизацияСсылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Прописанные КАК ВТ_Прописанные
		|		ПО ВТ_ОсновныеДанные.КлючПомещения = ВТ_Прописанные.КлючПомещения
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Проживающие КАК ВТ_Проживающие
		|		ПО ВТ_ОсновныеДанные.КлючПомещения = ВТ_Проживающие.КлючПомещения
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПлощадьМКД КАК ВТ_ПлощадьМКД
		|		ПО ВТ_ОсновныеДанные.МКД = ВТ_ПлощадьМКД.МКД
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_УКМКД КАК ВТ_УКМКД
		|		ПО ВТ_ОсновныеДанные.МКД = ВТ_УКМКД.МКД
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргТипСобственностиАбонентов.СрезПоследних(
		|				,
		|				(Организация, Район, КлючПомещения) В
		|					(ВЫБРАТЬ
		|						ВТ.Организация,
		|						ВТ.Район,
		|						ВТ.КлючПомещения
		|					ИЗ
		|						ВТ_ОсновныеДанные КАК ВТ)) КАК энргТипСобственностиАбонентовСрезПоследних
		|		ПО ВТ_ОсновныеДанные.КлючПомещения = энргТипСобственностиАбонентовСрезПоследних.КлючПомещения
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеФилиала КАК ВТ_ДанныеФилиала
		|		ПО ВТ_ОсновныеДанные.РайонСсылка = ВТ_ДанныеФилиала.Район
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПлощадьПомещения КАК ВТ_ПлощадьПомещения
		|		ПО ВТ_ОсновныеДанные.ОрганизацияСсылка = ВТ_ПлощадьПомещения.Организация
		|			И ВТ_ОсновныеДанные.РайонСсылка = ВТ_ПлощадьПомещения.Район
		|			И ВТ_ОсновныеДанные.КлючПомещения = ВТ_ПлощадьПомещения.КлючПомещения
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПериодЗадолженности КАК ВТ_ПериодЗадолженности
		|		ПО ВТ_ОсновныеДанные.Задача = ВТ_ПериодЗадолженности.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДопРеквизитыФилиала КАК ВТ_ДопРеквизитыФилиала
		|		ПО ВТ_ОсновныеДанные.РайонСсылка = ВТ_ДопРеквизитыФилиала.Филиал";
	
	Запрос.УстановитьПараметр("МассивОбъектов",		МассивОбъектов);
	Запрос.УстановитьПараметр("ВидДвиженияРасход",	ВидДвиженияНакопления.Расход);
	Запрос.УстановитьПараметр("Период",				ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Префикс = "";
	СтрокаСтрук = "";
	Для каждого Колонка Из РезультатЗапроса.Колонки Цикл
		СтрокаСтрук = СтрокаСтрук + Префикс + Колонка.Имя;
		Префикс = ", ";
	КонецЦикла;
	
	СпиокОбъектов = Новый Массив;
	Пока Выборка.Следующий() Цикл
		ТекОбъект = Новый Структура(СтрокаСтрук);
		ЗаполнитьЗначенияСвойств(ТекОбъект, Выборка);
		
		ТекОбъект.ЗадолженностьНачало 	= Формат(ТекОбъект.ЗадолженностьНачало, "ДФ=dd.MM.yyyy");
		ТекОбъект.ЗадолженностьОкончание= Формат(ТекОбъект.ЗадолженностьОкончание, "ДФ=dd.MM.yyyy");
		Если Не ЗначениеЗаполнено(ТекОбъект.ДатаСледЭтапа) Или НачалоДня(ТекОбъект.Дата) = ТекОбъект.ДатаСледЭтапа Тогда
			ТекОбъект.ДатаСледЭтапа		= Формат(ТекОбъект.Дата+30*24*3600, "ДФ=dd.MM.yyyy");
		Иначе
			ТекОбъект.ДатаСледЭтапа		= Формат(ТекОбъект.ДатаСледЭтапа, "ДФ=dd.MM.yyyy");
		КонецЕсли;
		
		ТекОбъект.Вставить("ТекДата", ТекущаяДатаСеанса());
		ТекОбъект.НомерЗадачи = Строка(Выборка.Префикс) + "-" + УбратьЛидирующиеНули(ТекОбъект.НомерЗадачи) + ?(ЗначениеЗаполнено(Выборка.Постфикс), "/" + Выборка.Постфикс, "");

		ТекОбъект.Дата					= Формат(ТекОбъект.Дата, "ДФ=dd.MM.yyyy");
		ТекОбъект.ДатаПослОплаты		= ?(ЗначениеЗаполнено(ТекОбъект.ДатаПослОплаты), Формат(ТекОбъект.ДатаПослОплаты, "ДФ=dd.MM.yyyy"), "");
		Если Не ЗначениеЗаполнено(Выборка.Фамилия) Тогда
			ТекОбъект.Вставить("ФИО", Строка(Выборка.Абонент));
		Иначе
			ТекОбъект.Вставить("ФИО", Выборка.Фамилия + " " + ?(ЗначениеЗаполнено(Выборка.Имя), Лев(Выборка.Имя, 1) + ".", "")
									 + ?(ЗначениеЗаполнено(Выборка.Отчество), Лев(Выборка.Отчество, 1) + ".", ""));
		КонецЕсли;
		
		ТекОбъект.Вставить("ИО_Абонента", Выборка.Имя + ?(ЗначениеЗаполнено(Выборка.Отчество), " " + Выборка.Отчество, ""));
		ТекОбъект.Вставить("СуммаЗадолженностиРуб", Цел(Выборка.СуммаЗадолженности));
		ТекОбъект.Вставить("СуммаЗадолженностиКоп", Цел((Выборка.СуммаЗадолженности - ТекОбъект.СуммаЗадолженностиРуб) * 100));
		ТекОбъект.Вставить("ЛицевойСчет", СокрЛП(Выборка.ЛицевойСчет));
		ТекОбъект.Вставить("ОрганизацияПрописью", ВРег(Строка(Выборка.Организация)));
		Если ЗначениеЗаполнено(Выборка.ЮридическийАдрес_Филиала) И Выборка.ЮридическийАдрес_Филиала <> Выборка.Адрес_Филиала Тогда
			ФактЮрАдрес = "юридический адрес: " + Строка(Выборка.ЮридическийАдрес_Филиала) + Символы.ПС +
							"фактический адрес: " + Строка(Выборка.Адрес_Филиала);
			ТекОбъект.Вставить("ФактЮрАдрес", ФактЮрАдрес);
		Иначе
			ТекОбъект.Вставить("ФактЮрАдрес", Выборка.Адрес_Филиала);
		КонецЕсли;
		
		СпиокОбъектов.Добавить(ТекОбъект);
		
		
		РеквизитыКвитанции = Новый Структура;
		
		РеквизитыКвитанции.Вставить("ТекстПолучателя", 			СокрЛП(Выборка.Организация));
		РеквизитыКвитанции.Вставить("НомерСчетаПолучателя", 			Выборка.РасчСчет);
		РеквизитыКвитанции.Вставить("НаименованиеБанкаПолучателя", 		Выборка.БанкНаименование);
		РеквизитыКвитанции.Вставить("БИКБанкаПолучателя", 				Выборка.БИК);
		РеквизитыКвитанции.Вставить("СчетБанкаПолучателя", 				Выборка.КоррСчет);
		РеквизитыКвитанции.Вставить("СуммаЧислом",		 				Выборка.СуммаЗадолженности);
		РеквизитыКвитанции.Вставить("НомерЛицевогоСчетаПлательщика", 	ТекОбъект.ЛицевойСчет);
		ПериодОплаты = Формат(Выборка.Дата, "ДФ=MM")+"-"+Формат(Выборка.Дата, "ДФ=MM")+"."+Формат(Выборка.Дата, "ДФ=yyyy"); 
		РеквизитыКвитанции.Вставить("ПериодОплаты", 					ПериодОплаты);
		РеквизитыКвитанции.Вставить("ФамилияПлательщика", 				СокрЛП(Выборка.Абонент)); 
		
		ЗаполРекQR = Ложь;
		Если Не ЗначениеЗаполнено(РеквизитыКвитанции.ТекстПолучателя) Тогда
			ТекОбъект.Вставить("КартинкаQRКодаОшибка", "Не заполнена организация");
		ИначеЕсли Не ЗначениеЗаполнено(РеквизитыКвитанции.НомерСчетаПолучателя)Тогда
			ТекОбъект.Вставить("КартинкаQRКодаОшибка", "Не корректно заполнен основной банковский счёт организации");
		ИначеЕсли Не ЗначениеЗаполнено(РеквизитыКвитанции.БИКБанкаПолучателя) Или Не ЗначениеЗаполнено(РеквизитыКвитанции.НаименованиеБанкаПолучателя) Или Не ЗначениеЗаполнено(РеквизитыКвитанции.СчетБанкаПолучателя) Тогда
		    ТекОбъект.Вставить("КартинкаQRКодаОшибка", "Не корректно заполнен банк в основном банковском счёте организации");
		Иначе 
			ЗаполРекQR = Истина;
		КонецЕсли;
		
		Если ЗаполРекQR Тогда
			QRСтрока		= УправлениеПечатью.ФорматнаяСтрокаУФЭБС(РеквизитыКвитанции);
			
			Если Не ПустаяСтрока(QRСтрока) Тогда
				ДанныеQRКода = УправлениеПечатью.ДанныеQRКода(QRСтрока, 1, 120);
				Если НЕ ТипЗнч(ДанныеQRКода) = Тип("ДвоичныеДанные") Тогда
					Шаблон 			= Нстр("ru = 'Не удалось сформировать QR-код для абонента %1. Технические подробности см. в журнале регистрации.'");
					ТекстСообщения 	= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон, Выборка.Абонент);
					ТекОбъект.Вставить("КартинкаQRКодаОшибка", ТекстСообщения);
				Иначе
					КартинкаQRКода								= Новый Картинка(ДанныеQRКода);
					ТекОбъект.Вставить("КартинкаQRКода", КартинкаQRКода);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	
	Для каждого ОбъектПечати из СпиокОбъектов Цикл
		СписокОбл   = Новый Массив;
		ОшибкаQRКод = "";
		
		Для каждого ТекОбласть Из ОбластиМакета Цикл
		 	Если ТекОбласть = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ТекОбласть.Значение.Параметры.Заполнить(ОбъектПечати);
			Для каждого ТекРисунок Из ТекОбласть.Значение.Рисунки Цикл
				Если ТекРисунок.Имя = "QRКод" Тогда 
					ТекстОшибки = "";
					Если ОбъектПечати.Свойство("КартинкаQRКодаОшибка", ТекстОшибки) Тогда
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
						ОшибкаQRКод = ОшибкаQRКод + ?(ЗначениеЗаполнено(ОшибкаQRКод), "; ", "") + ТекстОшибки;
					Иначе
						ОбъектПечати.Свойство("КартинкаQRКода", ТекРисунок.Картинка);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;

			СписокОбл.Добавить(ТекОбласть.Значение);
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ОшибкаQRКод) Тогда
			ТекстОшибки = "Ошибка при формирование QRКода: " + ОшибкаQRКод;
			Возврат Истина;
		КонецЕсли;
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();	
		КонецЕсли;
		
		Для каждого ТекОбласть Из СписокОбл Цикл
			Результат = Истина;
			ТабличныйДокумент.Вывести(ТекОбласть);
		КонецЦикла;
		
		ПервыйДокумент = Ложь;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция УбратьЛидирующиеНули(Знач НомерДокумента)
	Если Не ЗначениеЗаполнено(НомерДокумента) Тогда
		Возврат "";
	КонецЕсли;
	
	Пока Лев(НомерДокумента, 1) = "0" И СтрДлина(НомерДокумента) > 8 Цикл
		НомерДокумента = Прав(НомерДокумента, СтрДлина(НомерДокумента)-1);
	КонецЦикла;
	
	Возврат НомерДокумента;
КонецФункции 

Функция ПолучитьСписокМакетовПечати() Экспорт 
	Результат		 = Новый СписокЗначений;
	МетаСпрЭтаповПИД = Метаданные.Справочники.энргВидыОперацийПИД;
	СпрЭтаповПИД	 = Справочники.энргВидыОперацийПИД;
	
	Для каждого ТекМакет Из МетаСпрЭтаповПИД.Макеты Цикл
		Префикс		  = "ПФ_MXL_";
		ДлинаПрефикса = СтрДлина(Префикс);
		Если Префикс <> Лев(ТекМакет.Имя, ДлинаПрефикса) Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяЭтапа	 = Сред(ТекМакет.Имя, ДлинаПрефикса+1);
		ИмяПредЭтапа = "ЭтапПретензионноИсковойДеятельности_" + ИмяЭтапа;
		ЭтапИмя 	 = Новый Структура(ИмяПредЭтапа);
		ЗаполнитьЗначенияСвойств(ЭтапИмя, СпрЭтаповПИД);
		Если Не ЗначениеЗаполнено(ЭтапИмя[ИмяПредЭтапа]) Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(ТекМакет.Имя, Строка(ЭтапИмя[ИмяПредЭтапа]));
	КонецЦикла;

	Возврат Результат;
КонецФункции

Процедура ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТолькоОРП = Неопределено;
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("СтрокаПоиска", ?(Параметры.СтрокаПоиска = Неопределено, "", Параметры.СтрокаПоиска) + "%");
	Запрос.УстановитьПараметр("ТолькоОРП", ?(Параметры.Свойство("ТолькоОРП", ТолькоОРП), ТолькоОРП, Ложь));
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	энргВидыОперацийПИД.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.энргВидыОперацийПИД КАК энргВидыОперацийПИД
		|ГДЕ
		|	НЕ энргВидыОперацийПИД.ПометкаУдаления
		|	И энргВидыОперацийПИД.Наименование ПОДОБНО &СтрокаПоиска
		|	И ВЫБОР
		|			КОГДА энргВидыОперацийПИД.Тип = ЗНАЧЕНИЕ(Перечисление.энргТипыЭтапов.ОграничениеРежимаПотребления)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ = &ТолькоОРП";
	
	ДанныеВыбора = Новый СписокЗначений;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДанныеВыбора.Добавить(Выборка.Ссылка);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти
	
