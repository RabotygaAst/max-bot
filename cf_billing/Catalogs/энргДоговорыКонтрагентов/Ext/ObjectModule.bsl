#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Автор = Пользователи.ТекущийПользователь();
	ДополнительныеСвойства.Вставить("ЭтоНовый", ЭтоНовый());
	
	Если Не ЗначениеЗаполнено(ОснованиеДопСоглашения) И Не БлокЮридическихЛиц Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	энргДоговорыКонтрагентов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
		|ГДЕ
		|	энргДоговорыКонтрагентов.Номер = &Номер
		|	И НЕ энргДоговорыКонтрагентов.ПометкаУдаления";
		Запрос.УстановитьПараметр("Номер", Номер);
		Результат = Запрос.Выполнить();
		Если Не (ЗначениеЗаполнено(Ссылка) Или Результат.Пустой()) Тогда
			Отказ = Истина;
		КонецЕсли;
		Если Отказ Тогда
			ТекстСообщения = НСтр("ru = 'Элемент справочника с таким же значением реквизита ""Номер договора"" уже существует'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры  

Процедура ПриЗаписи(Отказ)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("ДоходныйОснование") Тогда 
		бестРаботаСНезависимымСбытом.ЗаписатьВРегистрСвязиДоговоров(Ссылка, ДополнительныеСвойства.ДоходныйОснование);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("СправочникСсылка.энргДоговорыКонтрагентов") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения,, "ТипТарифа, ТипДоговора, Поставщик, ПоставщикКонтрагент, БанковскийСчетКонтрагента, Родитель, Владелец, ЭтоГруппа, Код");
		Контрагент = ДанныеЗаполнения.ПоставщикКонтрагент;
		ТипДоговора = Перечисления.бестТипыДоговоров.Расходный;
		ТипТарифа = Перечисления.бестТипыТарифаНезависимыйСбыт.ЦеноваяКатегорияГП; 
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);
	Иначе
		энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
	КонецЕсли;
	
	Если бестРаботаСНезависимымСбытом.ПолучитьУчетНезависимыйСбыт() И Не ЗначениеЗаполнено(ТипДоговора) Тогда
		ТипДоговора = Перечисления.бестТипыДоговоров.Доходный;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

