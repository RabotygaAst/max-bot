&НаКлиенте
Процедура СоздатьОбращениеНаОсновании(Команда)
	ТекСтрока = Элементы.Обращения.ТекущиеДанные;
	Если Не ТекСтрока = Неопределено Тогда
		 ТекПарам = Новый Структура;
		 ЗаполнениеСтруктурыДляОбращений(ТекПарам, ТекСтрока.Регистратор);
		
		ОткрытьФорму("Документ.бестОбращения.Форма." + ТекПарам.ИмяФормы, ТекПарам);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНовоеОбращение(Команда)
	ОповОЗакрФормыОбращ = Новый ОписаниеОповещения("ОбработкаЗакрытияФормыОбращения", ЭтаФорма);
	РекДокумента = Новый Структура("Организация, Район, Контрагент");
	ЗаполнитьЗначенияСвойств(РекДокумента, Объект);
	РекДокумента.Вставить("Договор", Объект.Ссылка);
	РекДокумента.Вставить("ЭтапОбращения", ПредопределенноеЗначение("Справочник.бестЭтапыОбращений.ЭтапОбращений_ПервичноеОбращение"));
	
	ТекОбъект = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекОбъект <> Неопределено Тогда
	    РекДокумента.Вставить("ОбъектРасчета", ТекОбъект.ОбъектРасчета);	
	КонецЕсли;
	ПарамФормы = Новый Структура("РекДокумента", РекДокумента);
	
	ОткрытьФорму("Документ.бестОбращения.Форма.ФормаДокументаОбращениеЮридическогоЛица", ПарамФормы,,,,,ОповОЗакрФормыОбращ);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаЗакрытияФормыОбращения(Результат, Параметры) Экспорт
	Элементы.Обращения.Обновить();
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеСтруктурыДляОбращений(ТекПарам, ТекДок)
	ТекПарам.Вставить("Основание", ?(ЗначениеЗаполнено(ТекДок.Основание), ТекДок.Основание, ТекДок));
	ТекВидОперации = ТекДок.ВидОперации;
	Если ТекВидОперации = Перечисления.бестВидыОпераций.бестОбращения_ОбращениеФизическогоЛица Тогда
		ИмяФормы = "ФормаДокументаОбращениеФизическогоЛица";
	ИначеЕсли 
		ТекВидОперации = Перечисления.бестВидыОпераций.бестОбращения_ОбращениеЮридическогоЛица Тогда
		ИмяФормы = "ФормаДокументаОбращениеЮридическогоЛица";
	КонецЕсли;	
	ТекПарам.Вставить("ВидОперации", ТекВидОперации);
	ТекПарам.Вставить("ИмяФормы", ИмяФормы);
КонецПроцедуры

&НаКлиенте
Процедура бестСостояниеПриборовУзловУчетаНППриАктивизацииСтроки(Элемент)
	ТекСтрока = Элементы.бестСостояниеПриборовУзловУчетаНП.ТекущиеДанные;
	Если НЕ ТекСтрока = Неопределено Тогда
	
		СоставУзлаУчета.Отбор.Элементы.Очистить();
		ЭлементОтбора = СоставУзлаУчета.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение 	 = Новый ПолеКомпоновкиДанных("УзелУчета");
		ЭлементОтбора.Использование 	= Истина;
		ЭлементОтбора.ПравоеЗначение 	= ТекСтрока.ПриборУчета;
		ЭлементОтбора.РежимОтображения 	= РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	
	КонецЕсли;
КонецПроцедуры

