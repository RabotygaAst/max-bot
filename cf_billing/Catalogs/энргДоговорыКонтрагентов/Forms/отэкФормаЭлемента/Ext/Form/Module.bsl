
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗаполнитьСтатус();
	КонецЕсли;
	
	//Если НЕ Параметры.Ключ.Пустая() Тогда
		УстановитьПараметрыОбъектыРасчета();
	//КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Объект, Параметры.ЗначенияЗаполнения);
	
	УправлениеВидимостью();
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыОбъектыРасчета()
	ТекДата				= ТекущаяДата();
	ТекОрганизация 		= Объект.Организация;
	ТекРайон			= Объект.Район;
	ТекДоговор			= Объект.Ссылка;
	
	ОбъектыРасчета.Параметры.УстановитьЗначениеПараметра("Период", 		КонецДня(ТекДата));
	ОбъектыРасчета.Параметры.УстановитьЗначениеПараметра("Организация", ТекОрганизация);
	ОбъектыРасчета.Параметры.УстановитьЗначениеПараметра("Район", 		ТекРайон);
	ОбъектыРасчета.Параметры.УстановитьЗначениеПараметра("Договор", 	ТекДоговор);	
	
	ТочкиУчета.Параметры.УстановитьЗначениеПараметра("Организация", ТекОрганизация);
	ТочкиУчета.Параметры.УстановитьЗначениеПараметра("Район", 		ТекРайон);
	ТочкиУчета.Параметры.УстановитьЗначениеПараметра("Договор", 	ТекДоговор);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", 		КонецДня(ТекДата));
	Запрос.УстановитьПараметр("Организация", 	ТекОрганизация);
	Запрос.УстановитьПараметр("Район", 			ТекРайон);
	Запрос.УстановитьПараметр("Договор", 		ТекДоговор);
	Запрос.Текст = "ВЫБРАТЬ
	               |	бестГарантированныеОбъемыСрезПоследних.Период КАК Период,
	               |	бестГарантированныеОбъемыСрезПоследних.Организация КАК Организация,
	               |	бестГарантированныеОбъемыСрезПоследних.Район КАК Район,
	               |	бестГарантированныеОбъемыСрезПоследних.Договор КАК Договор,
	               |	бестГарантированныеОбъемыСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	               |	ГОД(бестГарантированныеОбъемыСрезПоследних.Месяц) КАК Год,
	               |	бестГарантированныеОбъемыСрезПоследних.Услуга КАК Услуга,
	               |	СУММА(ВЫБОР
	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 1
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК Январь,
	               |	СУММА(ВЫБОР
	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 2
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК Февраль,
	               |	СУММА(ВЫБОР
	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 3
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
