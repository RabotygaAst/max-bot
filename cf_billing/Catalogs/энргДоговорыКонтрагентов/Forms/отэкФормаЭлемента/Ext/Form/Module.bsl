Процедура ОграничениеУслуги(Команда)
	ТекСтрока = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Отказ = Ложь;
	Если ТекСтрока = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо выбрать объект расчета из ТЧ 'Объекты расчета'!");
		Отказ = Истина;
	КонецЕсли;
	ТекСтрокаУслуга	= Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекСтрокаУслуга = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо выбрать строку с услугой из ТЧ 'Услуги'!");
		Отказ = Истина;
	КонецЕсли;	
	
	Если НЕ Отказ Тогда
	
		ПарамОтк 		= Новый Структура;
		ЗнчЗаполнения 	= Новый Структура;
		ЗнчЗаполнения.Вставить("ВидОперации", 	ПредопределенноеЗначение("Перечисление.бестВидыОпераций.ОперацияСУслугами_ОграничениеУслуги"));
		ЗнчЗаполнения.Вставить("Дата", 			ТекущаяДата());
		ЗнчЗаполнения.Вставить("Организация", 	Объект.Организация);
		ЗнчЗаполнения.Вставить("Район", 		Объект.Район);
		ЗнчЗаполнения.Вставить("Договор", 		Объект.Ссылка);
		ЗнчЗаполнения.Вставить("ОбъектРасчета", ТекСтрока.ОбъектРасчета);
		ЗнчЗаполнения.Вставить("ВидУслуги", 	ТекСтрокаУслуга.Услуга);
		
		ПарамОтк.Вставить("ЗначенияЗаполнения", ЗнчЗаполнения);
		ПарамОтк.Вставить("ЗаполнитьДокумент", 	Истина);
		ОткрытьФорму("Документ.бестОперацияСУслугамиНП.Форма.ФормаДокументаОграничениеУслуги", ПарамОтк);
		
	КонецЕсли;
КонецПроцедуры

