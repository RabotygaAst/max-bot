	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 2
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
	               |		КОНЕЦ + ВЫБОР
	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 3
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
	               |		КОНЕЦ + ВЫБОР
	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 4
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
	               |		КОНЕЦ + ВЫБОР
	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 5
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
	               |		КОНЕЦ + ВЫБОР
	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 6
