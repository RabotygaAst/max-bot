	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 10
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
	               |		КОНЕЦ + ВЫБОР
	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 11
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
	               |		КОНЕЦ + ВЫБОР
	               |			КОГДА МЕСЯЦ(бестГарантированныеОбъемыСрезПоследних.Месяц) = 12
	               |				ТОГДА бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК ИтогГод
	               |ИЗ
	               |	РегистрСведений.бестГарантированныеОбъемы КАК бестГарантированныеОбъемыСрезПоследних
	               |ГДЕ
	               |	бестГарантированныеОбъемыСрезПоследних.Договор = &Договор
	               |	И бестГарантированныеОбъемыСрезПоследних.Район = &Район
	               |	И бестГарантированныеОбъемыСрезПоследних.Организация = &Организация
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	бестГарантированныеОбъемыСрезПоследних.Период,
	               |	бестГарантированныеОбъемыСрезПоследних.Договор,
	               |	бестГарантированныеОбъемыСрезПоследних.Район,
	               |	бестГарантированныеОбъемыСрезПоследних.Услуга,
	               |	бестГарантированныеОбъемыСрезПоследних.ОбъектРасчета,
	               |	бестГарантированныеОбъемыСрезПоследних.Организация,
	               |	ГОД(бестГарантированныеОбъемыСрезПоследних.Месяц),
	               |	бестГарантированныеОбъемыСрезПоследних.Услуга.ЕдиницаИзмерения
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	НАЧАЛОПЕРИОДА(бестОбъемНачисленийНП.Период, МЕСЯЦ) КАК Период,
	               |	бестОбъемНачисленийНП.Регистратор КАК Регистратор,
	               |	бестОбъемНачисленийНП.Организация КАК Организация,
	               |	бестОбъемНачисленийНП.Район КАК Район,
	               |	бестОбъемНачисленийНП.Договор КАК Договор,
	               |	бестОбъемНачисленийНП.ОбъектРасчета КАК ОбъектРасчета,
	               |	бестОбъемНачисленийНП.Услуга КАК Услуга,
	               |	бестОбъемНачисленийНП.ТочкаУчета КАК ТочкаУчета,
	               |	бестОбъемНачисленийНП.ВидНачисления КАК ВидНачисления,
	               |	бестОбъемНачисленийНП.СпособНачисления КАК СпособНачисления,
	               |	бестОбъемНачисленийНП.ПриборУчета КАК ПриборУчета,
	               |	бестОбъемНачисленийНП.Шкала КАК Шкала,
	               |	бестОбъемНачисленийНП.ТарифнаяЗона КАК ТарифнаяЗона,
	               |	бестОбъемНачисленийНП.ПериодНачисления КАК ПериодНачисления,
	               |	бестОбъемНачисленийНП.ПериодРасчета КАК ПериодРасчета,
	               |	бестОбъемНачисленийНП.Распределение КАК Распределение,
	               |	бестОбъемНачисленийНП.Поставщик КАК Поставщик,
	               |	бестОбъемНачисленийНП.МКД КАК МКД,
	               |	бестОбъемНачисленийНП.ДолевоеРаспределение КАК ДолевоеРаспределение,
	               |	СУММА(бестОбъемНачисленийНП.ОбъемПоПрибору) КАК ОбъемПоПрибору,
	               |	СУММА(бестОбъемНачисленийНП.ОбъемУслуги) КАК ОбъемУслуги,
	               |	СУММА(бестОбъемНачисленийНП.ОбъемУслугиПотребленный) КАК ОбъемУслугиПотребленный,
	               |	СУММА(бестОбъемНачисленийНП.КоличествоЧасовШтатнойРаботыПУ) КАК КоличествоЧасовШтатнойРаботыПУ,
	               |	СУММА(бестОбъемНачисленийНП.ОбъемДосчитанный) КАК ОбъемДосчитанный
	               |ИЗ
	               |	РегистрНакопления.бестОбъемНачисленийНП КАК бестОбъемНачисленийНП
	               |ГДЕ
	               |	бестОбъемНачисленийНП.Организация = &Организация
	               |	И бестОбъемНачисленийНП.Район = &Район
	               |	И бестОбъемНачисленийНП.Договор = &Договор
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	бестОбъемНачисленийНП.ДолевоеРаспределение,
	               |	бестОбъемНачисленийНП.МКД,
	               |	бестОбъемНачисленийНП.Поставщик,
	               |	бестОбъемНачисленийНП.ПериодНачисления,
	               |	бестОбъемНачисленийНП.ТарифнаяЗона,
	               |	бестОбъемНачисленийНП.Шкала,
	               |	бестОбъемНачисленийНП.СпособНачисления,
	               |	бестОбъемНачисленийНП.ТочкаУчета,
	               |	бестОбъемНачисленийНП.Распределение,
	               |	бестОбъемНачисленийНП.Услуга,
	               |	бестОбъемНачисленийНП.ОбъектРасчета,
	               |	бестОбъемНачисленийНП.Договор,
	               |	бестОбъемНачисленийНП.Район,
	               |	бестОбъемНачисленийНП.Организация,
	               |	бестОбъемНачисленийНП.Регистратор,
	               |	бестОбъемНачисленийНП.ПериодРасчета,
	               |	бестОбъемНачисленийНП.ВидНачисления,
	               |	бестОбъемНачисленийНП.ПриборУчета,
	               |	НАЧАЛОПЕРИОДА(бестОбъемНачисленийНП.Период, МЕСЯЦ)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Период УБЫВ,
	               |	Услуга
	               |ИТОГИ ПО
	               |	Услуга,
	               |	Период";
	РезультатЗапроса 					= Запрос.ВыполнитьПакет();
	Выгрузка 							= РезультатЗапроса[0].Выгрузить();
	ДоговорныеВеличиныТЗ.Загрузить(Выгрузка);
	
	ТЗ	= Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Период");
	
	ВыборкаНачисления					= РезультатЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	СчетчикУслуг	= 1;
	Колонки								= "";
	Пока ВыборкаНачисления.Следующий() Цикл
		ТекУслуга						= ВыборкаНачисления.Услуга;
		ТЗ.Колонки.Добавить("Объем" + СчетчикУслуг,,Строка(ТекУслуга));
		Колонки							= Колонки + "Объем" + СчетчикУслуг + ",";
		ВыборкаПериод					= ВыборкаНачисления.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПериод.Следующий() Цикл
			ТекПериод					= ВыборкаПериод.Период;
			ВыборкаДетал				= ВыборкаПериод.Выбрать();
			Пока ВыборкаДетал.Следующий() Цикл
				Если ВыборкаДетал.Период= ТекПериод Тогда
					НовСтрока			= ТЗ.Добавить();
					НовСтрока.Период 	= ТекПериод;
				    НовСтрока["Объем" + СчетчикУслуг] = ВыборкаДетал.ОбъемУслугиПотребленный;			
				КонецЕсли;
			КонецЦикла;		
		КонецЦикла;
		СчетчикУслуг = СчетчикУслуг + 1;
	КонецЦикла;
	Колонки = ЛЕВ(Колонки, СтрДлина(Колонки) - 1);
	ТЗ.Свернуть("Период", Колонки);
	
	ЗаполнитьИтогиДоговорныхОбъемов();
КонецПроцедуры	

&НаКлиенте
Процедура УстановитьПараметрыДинамическихСписков(ТекОбъект = Неопределено)
	Если ТекОбъект = Неопределено Тогда 
