&НаКлиенте
Процедура История(Команда)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		УсловияОтбора 							= Новый Структура();
		УсловияОтбора.Вставить("Организация", 	Объект.Организация);
		УсловияОтбора.Вставить("Район", 		Объект.Район);
		УсловияОтбора.Вставить("Договор", 		Объект.Ссылка);
		ПараметрыФормы = Новый Структура("Отбор", УсловияОтбора);
		ОткрытьФорму("РегистрСведений.бестСтатусыЭтаповЗаключенияДоговора.ФормаСписка", ПараметрыФормы, ЭтаФорма);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Изменить(Команда)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		УсловияОтбора 							= Новый Структура();
		УсловияОтбора.Вставить("Организация", 	Объект.Организация);
		УсловияОтбора.Вставить("Район", 		Объект.Район);
		УсловияОтбора.Вставить("Договор", 		Объект.Ссылка);
		//УсловияОтбора.Вставить("Период", 		Объект.Дата);
		ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", УсловияОтбора);
		Обработчик = Новый ОписаниеОповещения("ЗаполнитьСтатус", ЭтотОбъект);
		ОткрытьФорму("РегистрСведений.бестСтатусыЭтаповЗаключенияДоговора.ФормаЗаписи", ПараметрыФормы, ЭтаФорма,,,,Обработчик);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтатус(Результат = Неопределено,ДопПараметры = Неопределено) Экспорт
	Статус = Документы.бестЗаключениеДоговоровСЮридическимиЛицами.ПолучитьСтатусДоговора(Объект.Ссылка, Объект.Организация, Объект.Район);
КонецПроцедуры
