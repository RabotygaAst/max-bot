	|					энргУстановленныеПараметрыРасчетаНорматива.ТипНачисления КАК ТипНачисления,
	|					МАКСИМУМ(энргУстановленныеПараметрыРасчетаНорматива.Период) КАК Период,
	|					энргУстановленныеПараметрыРасчетаНорматива.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|					энргУстановленныеПараметрыРасчетаНорматива.СоциальныйНорматив КАК СоциальныйНорматив
	|				ИЗ
	|					РегистрСведений.энргУстановленныеПараметрыРасчетаНорматива КАК энргУстановленныеПараметрыРасчетаНорматива
	|						ВНУТРЕННЕЕ СОЕДИНЕНИЕ ГраницыОтчетногоПериода КАК ГраницыОтчетногоПериода
	|						ПО энргУстановленныеПараметрыРасчетаНорматива.Период <= ГраницыОтчетногоПериода.ЗавершениеОП
	|							И (энргУстановленныеПараметрыРасчетаНорматива.Организация = &Организация)
	|							И (энргУстановленныеПараметрыРасчетаНорматива.Район = &Район)
	|							И (энргУстановленныеПараметрыРасчетаНорматива.ТипНачисления = &ТипНачисления)
	|				
	|				СГРУППИРОВАТЬ ПО
	|					ГраницыОтчетногоПериода.ПериодНачисления,
	|					энргУстановленныеПараметрыРасчетаНорматива.Услуга,
	|					энргУстановленныеПараметрыРасчетаНорматива.ТипНачисления,
	|					энргУстановленныеПараметрыРасчетаНорматива.НаправлениеИспользованияТУ,
	|					энргУстановленныеПараметрыРасчетаНорматива.СоциальныйНорматив
	|				
	|				ОБЪЕДИНИТЬ ВСЕ
	|				
	|				ВЫБРАТЬ
	|					ГраницыОтчетногоПериода.ПериодНачисления,
	|					энргУстановленныеПараметрыРасчетаНорматива.Услуга,
	|					энргУстановленныеПараметрыРасчетаНорматива.ТипНачисления,
	|					МАКСИМУМ(энргУстановленныеПараметрыРасчетаНорматива.Период),
	|					энргУстановленныеПараметрыРасчетаНорматива.НаправлениеИспользованияТУ,
	|					энргУстановленныеПараметрыРасчетаНорматива.СоциальныйНорматив
	|				ИЗ
	|					РегистрСведений.энргУстановленныеПараметрыРасчетаНорматива КАК энргУстановленныеПараметрыРасчетаНорматива
	|						ВНУТРЕННЕЕ СОЕДИНЕНИЕ ГраницыОтчетногоПериода КАК ГраницыОтчетногоПериода
	|						ПО энргУстановленныеПараметрыРасчетаНорматива.Период <= ГраницыОтчетногоПериода.ЗавершениеОП
	|							И (энргУстановленныеПараметрыРасчетаНорматива.Организация = &Организация)
	|							И (энргУстановленныеПараметрыРасчетаНорматива.Район = &Район)
	|							И (энргУстановленныеПараметрыРасчетаНорматива.ТипНачисления = ЗНАЧЕНИЕ(Перечисление.энргТипыНачислений.ИндивидуальныеНачисления))
	|						ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|						ПО энргУстановленныеПараметрыРасчетаНорматива.Услуга = энргВидыУслуг.Ссылка
	|							И (энргВидыУслуг.НормативДляИндивидуальных)
	|							И (НЕ &ТипНачисления = ЗНАЧЕНИЕ(Перечисление.энргТипыНачислений.ИндивидуальныеНачисления))
	|				
	|				СГРУППИРОВАТЬ ПО
	|					ГраницыОтчетногоПериода.ПериодНачисления,
	|					энргУстановленныеПараметрыРасчетаНорматива.Услуга,
	|					энргУстановленныеПараметрыРасчетаНорматива.ТипНачисления,
	|					энргУстановленныеПараметрыРасчетаНорматива.НаправлениеИспользованияТУ,
	|					энргУстановленныеПараметрыРасчетаНорматива.СоциальныйНорматив) КАК ВложенныйЗАпрос
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргУстановленныеПараметрыРасчетаНорматива КАК энргУстановленныеПараметрыРасчетаНорматива
	|					ПО ВложенныйЗАпрос.Услуга = энргУстановленныеПараметрыРасчетаНорматива.Услуга
	|						И ВложенныйЗАпрос.Период = энргУстановленныеПараметрыРасчетаНорматива.Период
	|						И (энргУстановленныеПараметрыРасчетаНорматива.Организация = &Организация)
	|						И (энргУстановленныеПараметрыРасчетаНорматива.Район = &Район)
	|						И ВложенныйЗАпрос.ТипНачисления = энргУстановленныеПараметрыРасчетаНорматива.ТипНачисления
	|						И ВложенныйЗАпрос.НаправлениеИспользованияТУ = энргУстановленныеПараметрыРасчетаНорматива.НаправлениеИспользованияТУ
	|						И ВложенныйЗАпрос.СоциальныйНорматив = энргУстановленныеПараметрыРасчетаНорматива.СоциальныйНорматив) КАК ВложенныйЗапрос
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ВложенныйЗапрос.ПериодНачисления,
	|			ВложенныйЗапрос.Услуга,
	|			ВложенныйЗапрос.НаправлениеИспользованияТУ,
	|			ВложенныйЗапрос.СоциальныйНорматив) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗначенияРазрезов КАК ЗначенияРазрезов
	|			ПО ВложенныйЗапрос.ПериодНачисления = ЗначенияРазрезов.ПериодНачисления
	|				И ВложенныйЗапрос.Услуга = ЗначенияРазрезов.Услуга
	|				И ВложенныйЗапрос.НаправлениеИспользованияТУ = ЗначенияРазрезов.НаправлениеИспользованияТУ) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКлючиНормативов КАК энргКлючиНормативов
	|		ПО (ВЫБОР
	|				КОГДА ВложенныйЗапрос.РазрезВидБлагоустройства
	|					ТОГДА ВложенныйЗапрос.ВидБлагоустройства = энргКлючиНормативов.ВидБлагоустройства
	|				ИНАЧЕ энргКлючиНормативов.ВидБлагоустройства = ЗНАЧЕНИЕ(Справочник.энргВидыБлагоустройств.ПустаяСсылка)
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ВложенныйЗапрос.РазрезВидСобственности
	|					ТОГДА ВложенныйЗапрос.ВидСобственности = энргКлючиНормативов.ВидСобственности
	|				ИНАЧЕ энргКлючиНормативов.ВидСобственности = ЗНАЧЕНИЕ(Перечисление.энргТипыСобственниковЖилья.ПустаяСсылка)
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ВложенныйЗапрос.РазрезИзмерительНаправленияИспользования
	|					ТОГДА ВложенныйЗапрос.Измеритель = энргКлючиНормативов.ИзмерительНаправленияИспользования
	|				ИНАЧЕ энргКлючиНормативов.ИзмерительНаправленияИспользования = ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ПустаяСсылка)
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ВложенныйЗапрос.РазрезГодПостройки
	|					ТОГДА ВЫБОР
	|							КОГДА энргКлючиНормативов.ГодПостройкиДо = 0
	|								ТОГДА ВложенныйЗапрос.ГодПостройки >= энргКлючиНормативов.ГодПостройкиОт
	|										И энргКлючиНормативов.ГодПостройкиОт > 0
	|							ИНАЧЕ ВложенныйЗапрос.ГодПостройки >= энргКлючиНормативов.ГодПостройкиОт
	|									И ВложенныйЗапрос.ГодПостройки < энргКлючиНормативов.ГодПостройкиДо
	|									И энргКлючиНормативов.ГодПостройкиОт > 0
	|						КОНЕЦ
	|				ИНАЧЕ энргКлючиНормативов.ГодПостройкиОт = 0
	|						И энргКлючиНормативов.ГодПостройкиДо = 0
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ВложенныйЗапрос.РазрезКоличествоКомнат
	|					ТОГДА ВЫБОР
	|							КОГДА энргКлючиНормативов.КоличествоКомнатДо = 0
	|								ТОГДА ВложенныйЗапрос.КоличествоКомнат >= энргКлючиНормативов.КоличествоКомнатОт
	|										И энргКлючиНормативов.КоличествоКомнатОт > 0
	|							ИНАЧЕ ВложенныйЗапрос.КоличествоКомнат >= энргКлючиНормативов.КоличествоКомнатОт
	|									И ВложенныйЗапрос.КоличествоКомнат < энргКлючиНормативов.КоличествоКомнатДо
	|									И энргКлючиНормативов.КоличествоКомнатОт > 0
	|						КОНЕЦ
	|				ИНАЧЕ энргКлючиНормативов.КоличествоКомнатОт = 0
	|						И энргКлючиНормативов.КоличествоКомнатДо = 0
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ВложенныйЗапрос.РазрезКоличествоЧеловек
	|					ТОГДА ВЫБОР
	|							КОГДА энргКлючиНормативов.КоличествоЧеловекДо = 0
	|								ТОГДА ВложенныйЗапрос.КоличествоПрописанных >= энргКлючиНормативов.КоличествоЧеловекОт
	|										И энргКлючиНормативов.КоличествоЧеловекОт > 0
	|							ИНАЧЕ ВложенныйЗапрос.КоличествоПрописанных >= энргКлючиНормативов.КоличествоЧеловекОт
	|									И ВложенныйЗапрос.КоличествоПрописанных < энргКлючиНормативов.КоличествоЧеловекДо
	|									И энргКлючиНормативов.КоличествоЧеловекОт > 0
	|						КОНЕЦ
	|				ИНАЧЕ энргКлючиНормативов.КоличествоЧеловекОт = 0
	|						И энргКлючиНормативов.КоличествоЧеловекДо = 0
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ВложенныйЗапрос.РазрезКоличествоПрописанных
	|					ТОГДА ВЫБОР
	|							КОГДА энргКлючиНормативов.КоличествоПрописанныхДо = 0
	|								ТОГДА ВложенныйЗапрос.КоличествоПрописанных >= энргКлючиНормативов.КоличествоПрописанныхОт
	|										И энргКлючиНормативов.КоличествоПрописанныхОт > 0
	|							ИНАЧЕ ВложенныйЗапрос.КоличествоПрописанных >= энргКлючиНормативов.КоличествоПрописанныхОт
	|									И ВложенныйЗапрос.КоличествоПрописанных < энргКлючиНормативов.КоличествоПрописанныхДо
	|									И энргКлючиНормативов.КоличествоПрописанныхОт > 0
	|						КОНЕЦ
	|				ИНАЧЕ энргКлючиНормативов.КоличествоПрописанныхОт = 0
	|						И энргКлючиНормативов.КоличествоПрописанныхДо = 0
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ВложенныйЗапрос.РазрезКоличествоПроживающих
	|					ТОГДА ВЫБОР
	|							КОГДА энргКлючиНормативов.КоличествоПроживающихДо = 0
	|								ТОГДА ВложенныйЗапрос.КоличествоПроживающих >= энргКлючиНормативов.КоличествоПроживающихОт
	|										И энргКлючиНормативов.КоличествоПроживающихОт > 0
	|							ИНАЧЕ ВложенныйЗапрос.КоличествоПроживающих >= энргКлючиНормативов.КоличествоПроживающихОт
	|									И ВложенныйЗапрос.КоличествоПроживающих < энргКлючиНормативов.КоличествоПроживающихДо
	|									И энргКлючиНормативов.КоличествоПроживающихОт > 0
	|						КОНЕЦ
	|				ИНАЧЕ энргКлючиНормативов.КоличествоПроживающихОт = 0
	|						И энргКлючиНормативов.КоличествоПроживающихДо = 0
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ВложенныйЗапрос.РазрезКоличествоЭтажей
	|					ТОГДА ВЫБОР
	|							КОГДА энргКлючиНормативов.КоличествоЭтажейДо = 0
	|								ТОГДА ВложенныйЗапрос.КоличествоЭтажей >= энргКлючиНормативов.КоличествоЭтажейОт
	|										И энргКлючиНормативов.КоличествоЭтажейОт > 0
	|							ИНАЧЕ ВложенныйЗапрос.КоличествоЭтажей >= энргКлючиНормативов.КоличествоЭтажейОт
	|									И ВложенныйЗапрос.КоличествоЭтажей < энргКлючиНормативов.КоличествоЭтажейДо
	|									И энргКлючиНормативов.КоличествоЭтажейОт > 0
	|						КОНЕЦ
	|				ИНАЧЕ энргКлючиНормативов.КоличествоЭтажейОт = 0
	|						И энргКлючиНормативов.КоличествоЭтажейДо = 0
	|			КОНЕЦ)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.ПериодНачисления,
	|	ВложенныйЗапрос.НачалоОП,
	|	ВложенныйЗапрос.ЗавершениеОП,
	|	ВложенныйЗапрос.НачПер,
	|	ВложенныйЗапрос.КонПер,
	|	ВложенныйЗапрос.ДокРегистратор,
	|	ВложенныйЗапрос.Услуга,
	|	ВложенныйЗапрос.НаправлениеИспользованияТУ,
	|	ВложенныйЗапрос.Измеритель";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗначенияРазрезов(ЕстьИзмерители)
	Текст = 
	"ВЫБРАТЬ
	|	ВсеПараметрыРасчета.Строение КАК Строение,
	|	ВсеПараметрыРасчета.Помещение КАК Помещение,
	|	ВсеПараметрыРасчета.Услуга КАК Услуга,
	|	ВсеПараметрыРасчета.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	МАКСИМУМ(ВсеПараметрыРасчета.ВидБлагоустройства) КАК ВидБлагоустройства,
	|	МАКСИМУМ(ВсеПараметрыРасчета.ВидСобственности) КАК ВидСобственности,
	|	МАКСИМУМ(ВсеПараметрыРасчета.ГодПостройки) КАК ГодПостройки,
	|	МАКСИМУМ(ВсеПараметрыРасчета.КоличествоКомнат) КАК КоличествоКомнат,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА НЕ ВсеПараметрыРасчета.КоличествоПроживающих = 0
	|				ТОГДА ВсеПараметрыРасчета.КоличествоПроживающих
	|			КОГДА НЕ ВсеПараметрыРасчета.КоличествоПрописанных = 0
	|				ТОГДА ВсеПараметрыРасчета.КоличествоПрописанных
	|			ИНАЧЕ ВсеПараметрыРасчета.КоличествоСобственников
	|		КОНЕЦ) КАК КоличествоЧеловек,
	|	МАКСИМУМ(ВсеПараметрыРасчета.КоличествоПроживающих) КАК КоличествоПроживающих,
	|	МАКСИМУМ(ВсеПараметрыРасчета.КоличествоПрописанных) КАК КоличествоПрописанных,
	|	МАКСИМУМ(ВсеПараметрыРасчета.КоличествоЭтажей) КАК КоличествоЭтажей,
	|	МАКСИМУМ(ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление)) КАК Измеритель
	|ПОМЕСТИТЬ ЗначенияРазрезов
	|ИЗ
	|	ВсеПараметрыРасчета КАК ВсеПараметрыРасчета
	|
	|СГРУППИРОВАТЬ ПО
	|	ВсеПараметрыРасчета.Строение,
	|	ВсеПараметрыРасчета.Помещение,
	|	ВсеПараметрыРасчета.Услуга,
	|	ВсеПараметрыРасчета.НаправлениеИспользованияТУ";
	
	Если ЕстьИзмерители Тогда
		Текст = Текст + 
		"
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВсеПараметрыРасчетаСИзмерителями.Строение КАК Строение,
		|	ВсеПараметрыРасчетаСИзмерителями.Помещение КАК Помещение,
		|	ВсеПараметрыРасчетаСИзмерителями.Услуга,
		|	ВсеПараметрыРасчетаСИзмерителями.НаправлениеИспользованияТУ,
		|	ЗНАЧЕНИЕ(Перечисление.энргТипыСобственниковЖилья.ПустаяСсылка),
		|	0,
		|	0,
		|	0,
		|	0,
		|	0,
		|	0,
		|	0,
		|	ВсеПараметрыРасчетаСИзмерителями.Измеритель
		|ИЗ
		|	ВсеПараметрыРасчетаСИзмерителями КАК ВсеПараметрыРасчетаСИзмерителями";
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

Функция ТекстКлючиНормативаПоРазрезам()
	
	Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Строение КАК Строение,
