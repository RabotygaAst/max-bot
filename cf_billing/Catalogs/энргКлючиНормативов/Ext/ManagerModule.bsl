	|				КОГДА ПоискКлючей.КоличествоПроживающихОт = энргКлючиНормативов.КоличествоПроживающихОт
	|						И ПоискКлючей.КоличествоПроживающихДо = энргКлючиНормативов.КоличествоПроживающихДо
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоПроживающихОт >= энргКлючиНормативов.КоличествоПроживающихОт
	|						И (ПоискКлючей.КоличествоПроживающихДо > энргКлючиНормативов.КоличествоПроживающихДо
	|							И энргКлючиНормативов.КоличествоПроживающихДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоПроживающихОт >= ПоискКлючей.КоличествоПроживающихОт
	|						И (энргКлючиНормативов.КоличествоПроживающихДо > ПоискКлючей.КоличествоПроживающихДо
	|							И ПоискКлючей.КоличествоПроживающихДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоПроживающихОт < энргКлючиНормативов.КоличествоПроживающихДо
	|						И ПоискКлючей.КоличествоПроживающихОт >= энргКлючиНормативов.КоличествоПроживающихОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоПроживающихОт < ПоискКлючей.КоличествоПроживающихДо
	|						И энргКлючиНормативов.КоличествоПроживающихОт >= ПоискКлючей.КоличествоПроживающихОт
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоПроживающихДо < энргКлючиНормативов.КоличествоПроживающихДо
	|						И ПоискКлючей.КоличествоПроживающихДо > энргКлючиНормативов.КоличествоПроживающихОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоПроживающихДо < ПоискКлючей.КоличествоПроживающихДо
	|						И энргКлючиНормативов.КоличествоПроживающихДо > ПоискКлючей.КоличествоПроживающихОт
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ПоискКлючей.КоличествоСобственниковОт = 0
	|						И ПоискКлючей.КоличествоСобственниковДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА энргКлючиНормативов.КоличествоСобственниковОт = 0
	|						И энргКлючиНормативов.КоличествоСобственниковДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА ПоискКлючей.КоличествоСобственниковОт = энргКлючиНормативов.КоличествоСобственниковОт
	|						И ПоискКлючей.КоличествоСобственниковДо = энргКлючиНормативов.КоличествоСобственниковДо
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоСобственниковОт >= энргКлючиНормативов.КоличествоСобственниковОт
	|						И (ПоискКлючей.КоличествоСобственниковДо > энргКлючиНормативов.КоличествоСобственниковДо
	|							И энргКлючиНормативов.КоличествоПроживающихДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоСобственниковОт >= ПоискКлючей.КоличествоСобственниковОт
	|						И (энргКлючиНормативов.КоличествоСобственниковДо > ПоискКлючей.КоличествоСобственниковДо
	|							И ПоискКлючей.КоличествоСобственниковДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоСобственниковОт < энргКлючиНормативов.КоличествоСобственниковДо
	|						И ПоискКлючей.КоличествоСобственниковОт >= энргКлючиНормативов.КоличествоСобственниковОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоСобственниковОт < ПоискКлючей.КоличествоСобственниковДо
	|						И энргКлючиНормативов.КоличествоСобственниковОт >= ПоискКлючей.КоличествоСобственниковОт
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоСобственниковДо < энргКлючиНормативов.КоличествоСобственниковДо
	|						И ПоискКлючей.КоличествоСобственниковДо > энргКлючиНормативов.КоличествоСобственниковОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоСобственниковДо < ПоискКлючей.КоличествоСобственниковДо
	|						И энргКлючиНормативов.КоличествоСобственниковДо > ПоискКлючей.КоличествоСобственниковОт
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ПоискКлючей.КоличествоПрописанныхОт = 0
	|						И ПоискКлючей.КоличествоПрописанныхДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА энргКлючиНормативов.КоличествоПрописанныхОт = 0
	|						И энргКлючиНормативов.КоличествоПрописанныхДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА ПоискКлючей.КоличествоПрописанныхОт = энргКлючиНормативов.КоличествоПрописанныхОт
	|						И ПоискКлючей.КоличествоПрописанныхДо = энргКлючиНормативов.КоличествоПрописанныхДо
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоПрописанныхОт >= энргКлючиНормативов.КоличествоПрописанныхОт
	|						И (ПоискКлючей.КоличествоПрописанныхДо > энргКлючиНормативов.КоличествоПрописанныхДо
	|							И энргКлючиНормативов.КоличествоПрописанныхДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоПрописанныхОт >= ПоискКлючей.КоличествоПрописанныхОт
	|						И (энргКлючиНормативов.КоличествоПрописанныхДо > ПоискКлючей.КоличествоПрописанныхДо
	|							И ПоискКлючей.КоличествоПрописанныхДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоПрописанныхОт < энргКлючиНормативов.КоличествоПрописанныхДо
	|						И ПоискКлючей.КоличествоПрописанныхОт >= энргКлючиНормативов.КоличествоПрописанныхОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоПрописанныхОт < ПоискКлючей.КоличествоПрописанныхДо
	|						И энргКлючиНормативов.КоличествоПрописанныхОт >= ПоискКлючей.КоличествоПрописанныхОт
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоПрописанныхДо < энргКлючиНормативов.КоличествоПрописанныхДо
	|						И ПоискКлючей.КоличествоПрописанныхДо > энргКлючиНормативов.КоличествоПрописанныхОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоПрописанныхДо < ПоискКлючей.КоличествоПрописанныхДо
	|						И энргКлючиНормативов.КоличествоПрописанныхДо > ПоискКлючей.КоличествоПрописанныхОт
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ПоискКлючей.КоличествоЭтажейОт = 0
	|						И ПоискКлючей.КоличествоЭтажейДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА энргКлючиНормативов.КоличествоЭтажейОт = 0
	|						И энргКлючиНормативов.КоличествоЭтажейДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА ПоискКлючей.КоличествоЭтажейОт = энргКлючиНормативов.КоличествоЭтажейОт
	|						И ПоискКлючей.КоличествоЭтажейДо = энргКлючиНормативов.КоличествоЭтажейДо
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоЭтажейОт >= энргКлючиНормативов.КоличествоЭтажейОт
	|						И (ПоискКлючей.КоличествоЭтажейДо > энргКлючиНормативов.КоличествоЭтажейДо
	|							И энргКлючиНормативов.КоличествоЭтажейДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоЭтажейОт >= ПоискКлючей.КоличествоЭтажейОт
	|						И (энргКлючиНормативов.КоличествоЭтажейДо > ПоискКлючей.КоличествоЭтажейДо
	|							И ПоискКлючей.КоличествоЭтажейДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоЭтажейОт < энргКлючиНормативов.КоличествоЭтажейДо
	|						И ПоискКлючей.КоличествоЭтажейОт >= энргКлючиНормативов.КоличествоЭтажейОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоЭтажейОт < ПоискКлючей.КоличествоЭтажейДо
	|						И энргКлючиНормативов.КоличествоЭтажейОт >= ПоискКлючей.КоличествоЭтажейОт
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоЭтажейДо < энргКлючиНормативов.КоличествоЭтажейДо
	|						И ПоискКлючей.КоличествоЭтажейДо > энргКлючиНормативов.КоличествоЭтажейОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоЭтажейДо < ПоискКлючей.КоличествоЭтажейДо
	|						И энргКлючиНормативов.КоличествоЭтажейДо > ПоискКлючей.КоличествоЭтажейОт
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И (НЕ энргКлючиНормативов.ПометкаУдаления)
	|			И ПоискКлючей.КонтрольнаяСумма <> энргКлючиНормативов.ХэшСумма
	|
	|УПОРЯДОЧИТЬ ПО
	|	Индекс";
	
	Результат 								= Запрос.Выполнить();
	
	Если НЕ Результат.Пустой() Тогда
		
		Выборка  								= Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			СтруктураДублей = Новый Структура;
			СтруктураДублей.Вставить("Индекс", Выборка.Индекс + 1);
			СтруктураДублей.Вставить("Дубль", Выборка.Ссылка);
			КлючиПараметров.Добавить(СтруктураДублей);
		КонецЦикла;
		
		Отказ = Истина;
		Возврат КлючиПараметров;
	Иначе
		
		
		Запрос									= Новый Запрос;
		Запрос.МенеджерВременныхТаблиц			= МВТ;
		Запрос.Текст 							=
		"ВЫБРАТЬ
		|	ПоискКлючей.Индекс КАК Индекс,
		|	ПоискКлючей.КонтрольнаяСумма КАК КонтрольнаяСумма,
		|	ЕСТЬNULL(энргКлючиНормативов.Ссылка, ЗНАЧЕНИЕ(Справочник.энргКлючиНормативов.ПустаяСсылка)) КАК Ссылка
		|ИЗ
		|	ПоискКлючей КАК ПоискКлючей
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиНормативов КАК энргКлючиНормативов
		|		ПО ПоискКлючей.КонтрольнаяСумма = энргКлючиНормативов.ХэшСумма
		|			И (НЕ энргКлючиНормативов.ПометкаУдаления)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Индекс";
		Результат 								= Запрос.Выполнить();
		
		Выборка  								= Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			Если НЕ ЗначениеЗаполнено(Выборка.Ссылка) Тогда 			 
				КлючиПараметров.Вставить(Выборка.Индекс,СоздатьЭлементПоПараметрам(КлючевыеЗначений[Выборка.Индекс], Выборка.КонтрольнаяСумма));
			Иначе
				КлючиПараметров.Вставить(Выборка.Индекс,Выборка.Ссылка);
			КонецЕсли;		
		КонецЦикла;
		
		Возврат КлючиПараметров;
	КонецЕсли;
КонецФункции

Функция ПараметрыНорматива(ДанныеЗаполнения) Экспорт 
	
	ПараметрыНорматива 							= Новый Структура("ВидБлагоустройства, ВидСобственности, ГодПостройки, КоличествоКомнат, КоличествоПроживающих, КоличествоПрописанных, КоличествоЧеловек, КоличествоЭтажей");
	Если ДанныеЗаполнения.Свойство("ВидБлагоустройства") Тогда
		ПараметрыНорматива.ВидБлагоустройства 	= ДанныеЗаполнения.ВидБлагоустройства;
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("ВидСобственности") Тогда
		ПараметрыНорматива.ВидСобственности 	= ДанныеЗаполнения.ВидСобственности;
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("ГодПостройки") Тогда
		ПараметрыНорматива.ГодПостройки 		= ДанныеЗаполнения.ГодПостройки;
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("КоличествоКомнат") Тогда
		ПараметрыНорматива.КоличествоКомнат 	= ДанныеЗаполнения.КоличествоКомнат;
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("КоличествоПроживающих") Тогда
		ПараметрыНорматива.КоличествоПроживающих 	= ДанныеЗаполнения.КоличествоПроживающих;
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("КоличествоПрописанных") Тогда
		ПараметрыНорматива.КоличествоПрописанных 	= ДанныеЗаполнения.КоличествоПрописанных;
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("КоличествоЧеловек") Тогда
		ПараметрыНорматива.КоличествоЧеловек 	= ДанныеЗаполнения.КоличествоЧеловек;
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("КоличествоЭтажей") Тогда
		ПараметрыНорматива.КоличествоЭтажей 	= ДанныеЗаполнения.КоличествоЭтажей;
	КонецЕсли;                       		

	Возврат Новый ФиксированнаяСтруктура(ПараметрыНорматива);	
	 	
КонецФункции

Функция ПолучаемыеСвойстваПомещения(СвойстваИсключая = "") Экспорт 
 	
	ПолучаемыеСвойства = 
	"ВидБлагоустройства,ВидСобственности,ГодПостройки,КоличествоКомнат,
	|КоличествоПрописанных,КоличествоПроживающих,КоличествоСобственников,КоличествоЭтажей,КоличествоЖильцов";
	
	Если НЕ ПустаяСтрока(СвойстваИсключая) Тогда
		яСвойстваИсключая 	= СтрЗаменить(СвойстваИсключая," ","");
		ПолучаемыеСвойства 	= СтрЗаменить(ПолучаемыеСвойства,яСвойстваИсключая,"");
	КонецЕсли;
	
	Возврат ПолучаемыеСвойства;
	
КонецФункции

Функция ТекстОпределенияКлючейНорматива(ЕстьИзмерители = Ложь, ИмяТаблицыВсеПараметрыРасчета = Неопределено) Экспорт 
	
	Схема 							= Неопределено;
	Постфикс 						= ?(ИмяТаблицыВсеПараметрыРасчета = Неопределено,"",ИмяТаблицыВсеПараметрыРасчета);
	РегистрыСведений.энргУстановленныеПараметрыРасчетаНорматива.ДействующуюРазрезыНорматива(Схема,Новый Структура,"ДействующуюРазрезыНорматива" + Постфикс);
		
	Пакет  							= Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(ТекстЗначенияРазрезов(ЕстьИзмерители));
	
	Если Не ИмяТаблицыВсеПараметрыРасчета = Неопределено Тогда
		Оператор 					= Пакет.Операторы[0];
		Источник 					= Оператор.Источники[0].Источник;
		Источник.ИмяТаблицы 		= ИмяТаблицыВсеПараметрыРасчета;
		Пакет.ТаблицаДляПомещения 	= Пакет.ТаблицаДляПомещения + Постфикс;
	КонецЕсли;
		
	Пакет  							= Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(ТекстКлючиНормативаПоРазрезам());
	Если Не ИмяТаблицыВсеПараметрыРасчета = Неопределено Тогда
		Пакет.ТаблицаДляПомещения 	= Пакет.ТаблицаДляПомещения + Постфикс;
		Источник 					= Пакет.Операторы[0].Источники[0].Источник.Запрос.Операторы[0].Источники[0].Источник;
		Источник.ИмяТаблицы 		= Источник.ИмяТаблицы + Постфикс;
		
		Источник 					= Пакет.Операторы[0].Источники[0].Источник.Запрос.Операторы[0].Источники[1].Источник;
		Источник.ИмяТаблицы 		= Источник.ИмяТаблицы + Постфикс; 	
	КонецЕсли;
	Возврат Схема.ПолучитьТекстЗапроса();
		
