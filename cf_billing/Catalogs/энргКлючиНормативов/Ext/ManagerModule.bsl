#Область ПроцедурыОбновленияИнформационнойБазы

Процедура ОбновитьКонтрольныеСуммы() Экспорт 
	ПараметрыНорматива 						= Перечисления.энргКлючевыеПараметрыНорматива.КлючиПараметров();
	
	Запрос  = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	*
	|ИЗ
	|	Справочник.энргКлючиНормативов КАК энргКлючиНормативов";
	
	Результат  						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл			 
		ОписаниеЗначения 			= Новый Структура(ПараметрыНорматива);
		ЗаполнитьЗначенияСвойств(ОписаниеЗначения, Выборка);
		ЭлементОбъект  				= Выборка.Ссылка.ПолучитьОбъект();
		ЭлементОбъект.ХэшСумма 		= энргОбщегоНазначения.КонтрольнаяСумма(ОписаниеЗначения);
		ЭлементОбъект.Записать();
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

Функция ДанныеКлючейНорматива() Экспорт 
	Запрос  = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргКлючиНормативов.Ссылка КАК Ссылка,
	|	энргКлючиНормативов.ВидБлагоустройства КАК ВидБлагоустройства,
	|	энргКлючиНормативов.ВидСобственности КАК ВидСобственности,
	|	энргКлючиНормативов.ГодПостройкиОт КАК ГодПостройкиОт,
	|	энргКлючиНормативов.ГодПостройкиДо КАК ГодПостройкиДо,
	|	энргКлючиНормативов.КоличествоКомнатОт КАК КоличествоКомнатОт,
	|	энргКлючиНормативов.КоличествоКомнатДо КАК КоличествоКомнатДо,
	|	энргКлючиНормативов.КоличествоЧеловекОт КАК КоличествоЧеловекОт,
	|	энргКлючиНормативов.КоличествоЧеловекДо КАК КоличествоЧеловекДо,
	|	энргКлючиНормативов.КоличествоПроживающихОт КАК КоличествоПроживающихОт,
	|	энргКлючиНормативов.КоличествоПроживающихДо КАК КоличествоПроживающихДо,
	|	энргКлючиНормативов.КоличествоПрописанныхОт КАК КоличествоПрописанныхОт,
	|	энргКлючиНормативов.КоличествоПрописанныхДо КАК КоличествоПрописанныхДо,
	|	энргКлючиНормативов.КоличествоЭтажейОт КАК КоличествоЭтажейОт,
	|	энргКлючиНормативов.КоличествоЭтажейДо КАК КоличествоЭтажейДо,
	|	энргКлючиНормативов.ИзмерительНаправленияИспользования КАК ИзмерительНаправленияИспользования
	|ИЗ
	|	Справочник.энргКлючиНормативов КАК энргКлючиНормативов";
	
	Результат  = Запрос.Выполнить();
	Возврат Результат; 
	
КонецФункции

Процедура КлючиПоСвойствамОбъекта(МоментВремени, Организация, Район, ТипНачисления,МВТ, ИмяТаблицы) Экспорт 
	ОписаниеПараметров 				= Перечисления.энргКлючевыеПараметрыНорматива.ОписаниеКлючевыхПараметров();
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Запрос.УстановитьПараметр("МоментВремени", 	МоментВремени);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("ТипНачисления", 	ТипНачисления);
	Текст 							= ТекстОпределенияКлючейНорматива();
	Текст 							= СтрЗаменить(Текст, "ПОМЕСТИТЬ КлючиНорматива", "ПОМЕСТИТЬ " + ИмяТаблицы + "");
	Запрос.Текст 					= Текст;
	Запрос.Выполнить();	
КонецПроцедуры

Функция НайтиИлиСоздатьКлючПараметра(КлючевыеЗначений, Отказ = Ложь) Экспорт 
	
	ПоискКлючей  														= Новый ТаблицаЗначений;
	ПоискКлючей.Колонки.Добавить("Индекс",								Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(4,0)));
	ПоискКлючей.Колонки.Добавить("КонтрольнаяСумма",					Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("ВидБлагоустройства",					Новый ОписаниеТипов("СправочникСсылка.энргВидыБлагоустройств"));
	ПоискКлючей.Колонки.Добавить("ВидСобственности",					Новый ОписаниеТипов("ПеречислениеСсылка.энргТипыСобственниковЖилья"));
	ПоискКлючей.Колонки.Добавить("ГодПостройкиОт",						Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("ГодПостройкиДо",						Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("ИзмерительНаправленияИспользования",	Новый ОписаниеТипов("СправочникСсылка.энргНаправлениеИспользованияТочекУчета"));
	ПоискКлючей.Колонки.Добавить("КоличествоКомнатОт",					Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("КоличествоКомнатДо",					Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("КоличествоЧеловекОт",					Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("КоличествоЧеловекДо",					Новый ОписаниеТипов("Число"));	
	ПоискКлючей.Колонки.Добавить("КоличествоПроживающихОт",				Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("КоличествоПроживающихДо",				Новый ОписаниеТипов("Число"));	
	ПоискКлючей.Колонки.Добавить("КоличествоПрописанныхОт",				Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("КоличествоПрописанныхДо",				Новый ОписаниеТипов("Число"));  	
	ПоискКлючей.Колонки.Добавить("КоличествоЭтажейОт",					Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("КоличествоЭтажейДо",					Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("КоличествоСобственниковОт",			Новый ОписаниеТипов("Число"));
	ПоискКлючей.Колонки.Добавить("КоличествоСобственниковДо",			Новый ОписаниеТипов("Число"));
	
	КлючиПараметров							= Новый Массив;
	
	ПараметрыНорматива 						= Перечисления.энргКлючевыеПараметрыНорматива.КлючиПараметров();
	
	Для Сч = 0 По КлючевыеЗначений.ВГраница() Цикл		 
		ОписаниеЗначения 					= Новый Структура(ПараметрыНорматива);
		ЗаполнитьЗначенияСвойств(ОписаниеЗначения, 	КлючевыеЗначений[Сч]);
		
		СтрокаПоиска 						= ПоискКлючей.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПоиска, 		КлючевыеЗначений[Сч]);
		СтрокаПоиска.Индекс  				= Сч;
		СтрокаПоиска.КонтрольнаяСумма 		= энргОбщегоНазначения.КонтрольнаяСумма(ОписаниеЗначения);		 
	КонецЦикла;	
	
	// ищем ключи
	МВТ 									= Новый МенеджерВременныхТаблиц;
	Запрос									= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц			= МВТ;
	Запрос.УстановитьПараметр("ПоискКлючей", ПоискКлючей);
	Запрос.Текст 							=
	"ВЫБРАТЬ
	|	ПоискКлючей.Индекс КАК Индекс,
	|	ПоискКлючей.КонтрольнаяСумма КАК КонтрольнаяСумма,
	|	ПоискКлючей.ВидБлагоустройства КАК ВидБлагоустройства,
	|	ПоискКлючей.ГодПостройкиОт КАК ГодПостройкиОт,
	|	ПоискКлючей.ВидСобственности КАК ВидСобственности,
	|	ПоискКлючей.ГодПостройкиДо КАК ГодПостройкиДо,
	|	ПоискКлючей.ИзмерительНаправленияИспользования КАК ИзмерительНаправленияИспользования,
	|	ПоискКлючей.КоличествоКомнатОт КАК КоличествоКомнатОт,
	|	ПоискКлючей.КоличествоКомнатДо КАК КоличествоКомнатДо,
	|	ПоискКлючей.КоличествоЧеловекОт КАК КоличествоЧеловекОт,
	|	ПоискКлючей.КоличествоЧеловекДо КАК КоличествоЧеловекДо,
	|	ПоискКлючей.КоличествоПроживающихОт КАК КоличествоПроживающихОт,
	|	ПоискКлючей.КоличествоПроживающихДо КАК КоличествоПроживающихДо,
	|	ПоискКлючей.КоличествоПрописанныхОт КАК КоличествоПрописанныхОт,
	|	ПоискКлючей.КоличествоПрописанныхДо КАК КоличествоПрописанныхДо,
	|	ПоискКлючей.КоличествоЭтажейОт КАК КоличествоЭтажейОт,
	|	ПоискКлючей.КоличествоЭтажейДо КАК КоличествоЭтажейДо,
	|	ПоискКлючей.КоличествоСобственниковОт КАК КоличествоСобственниковОт,
	|	ПоискКлючей.КоличествоСобственниковДо КАК КоличествоСобственниковДо
	|ПОМЕСТИТЬ ПоискКлючей
	|ИЗ
	|	&ПоискКлючей КАК ПоискКлючей
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргКлючиНормативов.Ссылка КАК Ссылка,
	|	ПоискКлючей.Индекс КАК Индекс
	|ИЗ
	|	ПоискКлючей КАК ПоискКлючей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКлючиНормативов КАК энргКлючиНормативов
	|		ПО ПоискКлючей.ВидБлагоустройства = энргКлючиНормативов.ВидБлагоустройства
	|			И ПоискКлючей.ВидСобственности = энргКлючиНормативов.ВидСобственности
	|			И ПоискКлючей.ИзмерительНаправленияИспользования = энргКлючиНормативов.ИзмерительНаправленияИспользования
	|			И (ВЫБОР
	|				КОГДА ПоискКлючей.ГодПостройкиОт = 0
	|						И ПоискКлючей.ГодПостройкиДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА энргКлючиНормативов.ГодПостройкиОт = 0
	|						И энргКлючиНормативов.ГодПостройкиДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА ПоискКлючей.ГодПостройкиОт = энргКлючиНормативов.ГодПостройкиОт
	|						И ПоискКлючей.ГодПостройкиДо = энргКлючиНормативов.ГодПостройкиДо
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.ГодПостройкиОт >= энргКлючиНормативов.ГодПостройкиОт
	|						И ПоискКлючей.ГодПостройкиДо > энргКлючиНормативов.ГодПостройкиОт
	|						И энргКлючиНормативов.ГодПостройкиДо = 0
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.ГодПостройкиОт >= ПоискКлючей.ГодПостройкиОт
	|						И энргКлючиНормативов.ГодПостройкиДо > ПоискКлючей.ГодПостройкиОт
	|						И ПоискКлючей.ГодПостройкиДо = 0
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.ГодПостройкиОт < энргКлючиНормативов.ГодПостройкиДо
	|						И ПоискКлючей.ГодПостройкиОт >= энргКлючиНормативов.ГодПостройкиОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.ГодПостройкиОт < ПоискКлючей.ГодПостройкиДо
	|						И энргКлючиНормативов.ГодПостройкиОт >= ПоискКлючей.ГодПостройкиОт
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.ГодПостройкиДо < энргКлючиНормативов.ГодПостройкиДо
	|						И ПоискКлючей.ГодПостройкиДо > энргКлючиНормативов.ГодПостройкиОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.ГодПостройкиДо < ПоискКлючей.ГодПостройкиДо
	|						И энргКлючиНормативов.ГодПостройкиДо > ПоискКлючей.ГодПостройкиОт
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ПоискКлючей.КоличествоКомнатОт = 0
	|						И ПоискКлючей.КоличествоКомнатДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА энргКлючиНормативов.КоличествоКомнатОт = 0
	|						И энргКлючиНормативов.КоличествоКомнатДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА ПоискКлючей.КоличествоКомнатОт = энргКлючиНормативов.КоличествоКомнатОт
	|						И ПоискКлючей.КоличествоКомнатДо = энргКлючиНормативов.КоличествоКомнатДо
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоКомнатОт >= энргКлючиНормативов.КоличествоКомнатОт
	|						И (ПоискКлючей.КоличествоКомнатДо > энргКлючиНормативов.КоличествоКомнатДо
	|							И энргКлючиНормативов.КоличествоКомнатДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоКомнатОт >= ПоискКлючей.КоличествоКомнатОт
	|						И (энргКлючиНормативов.КоличествоКомнатДо > ПоискКлючей.КоличествоКомнатДо
	|							И ПоискКлючей.КоличествоКомнатДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоКомнатОт < энргКлючиНормативов.КоличествоКомнатДо
	|						И ПоискКлючей.КоличествоКомнатОт >= энргКлючиНормативов.КоличествоКомнатОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоКомнатОт < ПоискКлючей.КоличествоКомнатДо
	|						И энргКлючиНормативов.КоличествоКомнатОт >= ПоискКлючей.КоличествоКомнатОт
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоКомнатДо < энргКлючиНормативов.КоличествоКомнатДо
	|						И ПоискКлючей.КоличествоКомнатДо > энргКлючиНормативов.КоличествоКомнатОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоКомнатДо < ПоискКлючей.КоличествоКомнатДо
	|						И энргКлючиНормативов.КоличествоКомнатДо > ПоискКлючей.КоличествоКомнатОт
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ПоискКлючей.КоличествоЧеловекОт = 0
	|						И ПоискКлючей.КоличествоЧеловекДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА энргКлючиНормативов.КоличествоЧеловекОт = 0
	|						И энргКлючиНормативов.КоличествоЧеловекДо = 0
	|					ТОГДА ЛОЖЬ
	|				КОГДА ПоискКлючей.КоличествоЧеловекОт = энргКлючиНормативов.КоличествоЧеловекОт
	|						И ПоискКлючей.КоличествоЧеловекДо = энргКлючиНормативов.КоличествоЧеловекДо
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоЧеловекОт >= энргКлючиНормативов.КоличествоЧеловекОт
	|						И (ПоискКлючей.КоличествоЧеловекДо > энргКлючиНормативов.КоличествоЧеловекДо
	|							И энргКлючиНормативов.КоличествоЧеловекДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоЧеловекОт >= ПоискКлючей.КоличествоЧеловекОт
	|						И (энргКлючиНормативов.КоличествоЧеловекДо > ПоискКлючей.КоличествоЧеловекДо
	|							И ПоискКлючей.КоличествоЧеловекДо = 0)
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоЧеловекОт < энргКлючиНормативов.КоличествоЧеловекДо
	|						И ПоискКлючей.КоличествоЧеловекОт >= энргКлючиНормативов.КоличествоЧеловекОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоЧеловекОт < ПоискКлючей.КоличествоЧеловекДо
	|						И энргКлючиНормативов.КоличествоЧеловекОт >= ПоискКлючей.КоличествоЧеловекОт
	|					ТОГДА ИСТИНА
	|				КОГДА ПоискКлючей.КоличествоЧеловекДо < энргКлючиНормативов.КоличествоЧеловекДо
	|						И ПоискКлючей.КоличествоЧеловекДо > энргКлючиНормативов.КоличествоЧеловекОт
	|					ТОГДА ИСТИНА
	|				КОГДА энргКлючиНормативов.КоличествоЧеловекДо < ПоискКлючей.КоличествоЧеловекДо
	|						И энргКлючиНормативов.КоличествоЧеловекДо > ПоискКлючей.КоличествоЧеловекОт
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|			И (ВЫБОР
	|				КОГДА ПоискКлючей.КоличествоПроживающихОт = 0
	|						И ПоискКлючей.КоличествоПроживающихДо = 0
