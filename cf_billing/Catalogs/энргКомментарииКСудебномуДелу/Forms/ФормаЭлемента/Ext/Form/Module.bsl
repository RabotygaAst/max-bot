#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Перем Дело, СтатусОтчет, СудебноеЗаседание; 
	
	ВременныйКаталог = ПолучитьИмяВременногоФайла(".tmp");
	ВременныйКаталог = СтрЗаменить(ВременныйКаталог, ".tmp", ""); 
	
	Если Объект.Ссылка.Пустая() Тогда
		Если Параметры.ЗначенияЗаполнения.Свойство("Дело", Дело) Тогда 
			Объект.Дело = Дело;
		КонецЕсли;
		Если Параметры.ЗначенияЗаполнения.Свойство("СтатусОтчет", СтатусОтчет) Тогда
			Объект.СтатусОтчет = СтатусОтчет;
		КонецЕсли;
		Если Параметры.ЗначенияЗаполнения.Свойство("СудебноеЗаседание", СудебноеЗаседание) Тогда
			Объект.СудебноеЗаседание = СудебноеЗаседание;
		КонецЕсли;
		Объект.Период = ТекущаяДатаСеанса();
	Иначе
		Элементы.Период.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	Если Объект.СтатусОтчет Тогда
		Заголовок = "Статус-отчет";
		АвтоЗаголовок = Ложь;
		
		ПолучитьФайлыНаСервере();
	ИначеЕсли Объект.СудебноеЗаседание Тогда
		Заголовок = "Судебное заседание";
		Элементы.Период.Заголовок = "Дата изменения статуса";
		АвтоЗаголовок = Ложь;
		
		ПолучитьФайлыНаСервере();
	Иначе
		Элементы.Переместить(Элементы.Комментарий, ЭтаФорма, Элементы.Страницы);
		Элементы.Страницы.Видимость	= Ложь;
	КонецЕсли;
	Элементы.ДатаСледующегоОтчёта.Видимость	= Объект.СтатусОтчет;
	Элементы.СудебнаяИнстанция.Видимость	= Объект.СудебноеЗаседание;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПолучитьФайлыНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	Попытка
		УдалитьФайлы(ВременныйКаталог); 
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Объект.СтатусОтчет И ЗначениеЗаполнено(Объект.ДатаСледующегоОтчёта) И Объект.Период >= Объект.ДатаСледующегоОтчёта Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата следующего отчёта должна быть позже текущего отчёта.");
		Возврат;
	КонецЕсли;
	
	АдресаФайлов  = Новый СписокЗначений;
	СтрокиУдалить = Новый Массив;
	
	Для каждого ТекСтрокаТЧ Из ПрикрепитьФайлы Цикл
		Если Не ТекСтрокаТЧ.ПрикрепленКДелу И ЗначениеЗаполнено(ТекСтрокаТЧ.АдресФайла) Тогда
			Попытка
				Двоичное = Новый ДвоичныеДанные(ТекСтрокаТЧ.АдресФайла);
				Адрес	 = ПоместитьВоВременноеХранилище(Двоичное, ЭтаФорма.УникальныйИдентификатор);
				АдресаФайлов.Добавить(Адрес, ТекСтрокаТЧ.ИмяФайла);
				СтрокиУдалить.Добавить(ТекСтрокаТЧ);
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
	Если АдресаФайлов.Количество() > 0 Тогда
		Для каждого ТекСтрокаТЧ Из СтрокиУдалить Цикл
			ПрикрепитьФайлы.Удалить(ТекСтрокаТЧ);
		КонецЦикла;

		ПараметрыЗаписи.Вставить("АдресаФайлов", АдресаФайлов);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Перем АдресаФайлов;
	
	Если ПараметрыЗаписи.Свойство("АдресаФайлов", АдресаФайлов) Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("АдресаФайлов", АдресаФайлов);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ПолучитьФайлыНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	ПолучитьФайлыНаКлиенте();
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы
&НаКлиенте
Процедура ПрикрепитьФайлыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выбор файла";
	Диалог.ПредварительныйПросмотр = Ложь;
	Диалог.ПроверятьСуществованиеФайла = Истина;
	Диалог.МножественныйВыбор = Ложь; 
	
	Диалог.Показать(Новый ОписаниеОповещения("ДобавитьВыбранныйФайл", ЭтотОбъект, Новый Структура("Диалог", Диалог)));	
КонецПроцедуры

&НаКлиенте
Процедура ПрикрепитьФайлыПередУдалением(Элемент, Отказ)
	ТекСтрокаТЗ = Элементы.ПрикрепитьФайлы.ТекущиеДанные;
	Если ТекСтрокаТЗ <> Неопределено И ТекСтрокаТЗ.ПрикрепленКДелу Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нельзя в отчёте удалять и изменять файлы, прикреплённые к делу.");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПрикрепитьФайлыАдресФайлаОткрытие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекЭлем = Элементы.ПрикрепитьФайлы.ТекущиеДанные;
	Если ТекЭлем <> Неопределено И ЗначениеЗаполнено(ТекЭлем.АдресФайла)  Тогда
		ЗапуститьПриложение(СокрЛП(ТекЭлем.АдресФайла)); 
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#Область ДополнительныеМетоды
&НаСервере
Процедура ПолучитьФайлыНаСервере()
	
	Перем Выборка, Запрос, РезультатЗапроса, СтрокаТЗ;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗадачаПИДПрисоединенныеФайлы.Наименование КАК Наименование,
		|	энргЗадачаПИДПрисоединенныеФайлы.Расширение КАК Расширение,
		|	энргЗадачаПИДПрисоединенныеФайлы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.энргКомментарииКСудебномуДелу.Файлы КАК энргКомментарииКСудебномуДелуФайлы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргЗадачаПИДПрисоединенныеФайлы КАК энргЗадачаПИДПрисоединенныеФайлы
		|		ПО энргКомментарииКСудебномуДелуФайлы.Файл = энргЗадачаПИДПрисоединенныеФайлы.Ссылка
		|ГДЕ
		|	энргКомментарииКСудебномуДелуФайлы.Ссылка = &Ссылка
		|	И НЕ энргЗадачаПИДПрисоединенныеФайлы.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Если Объект.СудебноеЗаседание Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Справочник.энргЗадачаПИДПрисоединенныеФайлы", "Справочник.энргБанкротствоПрисоединенныеФайлы");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если ПрикрепитьФайлы.НайтиСтроки(Новый Структура("Ссылка", Выборка.Ссылка)).Количество() > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТЗ = ПрикрепитьФайлы.Добавить();
		СтрокаТЗ.ПрикрепленКДелу	  = Истина;
		СтрокаТЗ.ИмяФайла			  = Выборка.Наименование + "." + Выборка.Расширение;
		СтрокаТЗ.Ссылка				  = Выборка.Ссылка;
		СтрокаТЗ.Расширение			  = Выборка.Расширение;
		СтрокаТЗ.АдресВременногоФайла = ПоместитьВоВременноеХранилище(РаботаСФайлами.ДвоичныеДанныеФайла(Выборка.Ссылка));
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьФайлыНаКлиенте()
	Перем ДвоичФайл, ИмяФайла, СтрокаТЗ;
	
	Для каждого СтрокаТЗ Из ПрикрепитьФайлы Цикл
		
		Если ЗначениеЗаполнено(СтрокаТЗ.АдресВременногоФайла) И ПустаяСтрока(СтрокаТЗ.АдресФайла) Тогда
			ИмяФайла  = ВременныйКаталог + "\" + Строка(Новый УникальныйИдентификатор) + "." + СтрокаТЗ.Расширение;
			
			ДвоичФайл = ПолучитьИзВременногоХранилища(СтрокаТЗ.АдресВременногоФайла);
			Попытка
				ДвоичФайл.Записать(ИмяФайла); 
				СтрокаТЗ.АдресФайла = ИмяФайла;
				СтрокаТЗ.АдресВременногоФайла = "";
			Исключение
			КонецПопытки;
		КонецЕсли;
		
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВыбранныйФайл(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	Диалог = ДополнительныеПараметры.Диалог;
	
	Если (ВыбранныеФайлы <> Неопределено) Тогда
		Модифицированность = Истина;
		Для каждого ПутьКФайлу Из ВыбранныеФайлы Цикл
			СтрокаТЗ = ПрикрепитьФайлы.Добавить();
			СтрокаТЗ.АдресФайла = ПутьКФайлу;
			СтрокаТЗ.ИмяФайла	= СтрЗаменить(Диалог.ПолноеИмяФайла, Диалог.Каталог, "");
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры 
#КонецОбласти
















