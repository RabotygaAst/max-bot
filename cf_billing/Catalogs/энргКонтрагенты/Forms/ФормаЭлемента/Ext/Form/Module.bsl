	Объект.бестИмя = Врег(Лев(СокрЛП(Объект.бестИмя), 1)) + Нрег(Сред(СокрЛП(Объект.бестИмя), 2));
	бестСформироватьНаименованиеПоФИО();
КонецПроцедуры

