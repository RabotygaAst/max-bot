Процедура ЭтоПлатежныйАгент()
	Если Объект.ПлатежныйАгент = Истина Тогда
		Элементы.ИсточникПоступленияДенежныхСредств.Доступность = Истина;
		Элементы.ИсточникПоказаний.Доступность = Истина;
	Иначе
		Элементы.ИсточникПоступленияДенежныхСредств.Доступность = Ложь;
		Элементы.ИсточникПоказаний.Доступность = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПлатежныйАгентПриИзменении(Элемент)
	ЭтоПлатежныйАгент();
