// Функция - Получить список параметров
//
// Параметры:
//  ТипСобытия	 - СправочникСсылка.энргСпособСвязи - Тип события. 
// 
// Возвращаемое значение:
//  Массив - список параметров.
//
Функция ПолучитьСписокПараметров(ТипСобытия) Экспорт 

	Если Не ЗначениеЗаполнено(ТипСобытия) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСпособСвязиПараметры.Параметр КАК Параметр
		|ИЗ
		|	Справочник.энргСпособСвязи.Параметры КАК энргСпособСвязиПараметры
		|ГДЕ
		|	энргСпособСвязиПараметры.Ссылка = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	энргСпособСвязиПараметры.НомерСтроки";
	
	Запрос.Параметры.Вставить("Ссылка", ТипСобытия);
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку(0);
КонецФункции

