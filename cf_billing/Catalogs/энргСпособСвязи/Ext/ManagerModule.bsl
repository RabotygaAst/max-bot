// Функция - Получить массив доступных типов событий
//
// Параметры:
//  ЭтапПИР	 - СправочникСсылка.энргВидыОперацийПИД - Этап ПИР. 
// 
// Возвращаемое значение:
//  Массив - Массив типов событий.
//
Функция ПолучитьМассивДоступныхТиповСобытий(ЭтапПИР) Экспорт
	Если НЕ ЗначениеЗаполнено(ЭтапПИР) Тогда
		Возврат Новый Массив;
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСпособСвязи.Ссылка КАК ТипСобытия,
		|	энргСпособСвязиЭтапыПИР.ЭтапПИР КАК ЭтапПИР
		|ПОМЕСТИТЬ ЭтапыПИРСобытий
		|ИЗ
		|	Справочник.энргСпособСвязи КАК энргСпособСвязи
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСпособСвязи.ЭтапыПИР КАК энргСпособСвязиЭтапыПИР
		|		ПО энргСпособСвязи.Ссылка = энргСпособСвязиЭтапыПИР.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВложенныйЗапрос.ТипСобытия КАК ТипСобытия
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВложенныйЗапрос.ТипСобытия КАК ТипСобытия
		|	ИЗ
		|		(ВЫБРАТЬ
		|			ЭтапыПИРСобытий.ТипСобытия КАК ТипСобытия,
		|			КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЭтапыПИРСобытий.ЭтапПИР) КАК КоличествоЭтапов
		|		ИЗ
		|			ЭтапыПИРСобытий КАК ЭтапыПИРСобытий
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ЭтапыПИРСобытий.ТипСобытия) КАК ВложенныйЗапрос
		|	ГДЕ
		|		ВложенныйЗапрос.КоличествоЭтапов = 0
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЭтапыПИРСобытий.ТипСобытия
		|	ИЗ
		|		ЭтапыПИРСобытий КАК ЭтапыПИРСобытий
		|	ГДЕ
		|		ЭтапыПИРСобытий.ЭтапПИР = &ЭтапПИР) КАК ВложенныйЗапрос";
	
	Запрос.Параметры.Вставить("ЭтапПИР", ЭтапПИР);
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ТипСобытия");
КонецФункции

