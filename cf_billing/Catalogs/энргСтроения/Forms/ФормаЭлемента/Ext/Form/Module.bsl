#Область ОписаниеПеременных

&НаКлиенте
Перем ПодтвержденоЗакрытиеФормы;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	энргЛокализацияСервер.ПриСозданииНаСервере_энргСтроения(ЭтотОбъект);
	энргРаботаСПрикрепленнымиФайламиСервер.ПриСозданииНаСервере(ЭтотОбъект);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		МодульУправлениеКонтактнойИнформацией = ОбщегоНазначения.ОбщийМодуль("УправлениеКонтактнойИнформацией");
		МодульУправлениеКонтактнойИнформацией.ПриСозданииНаСервере(ЭтотОбъект, Объект, "ГруппаКонтактнаяИнформация","Лево");
	КонецЕсли; 
		
	Если НЕ Параметры.Ключ.Пустая() Тогда
		ЗаполнитьУК(Объект.Ссылка);
	КонецЕсли;
	
	УстановитьОтборГИС();
	ЗаполнитьСвойстваДанными();
	УстановитьПризнакОРП();
	УстановитьОтборыДинамическихСписков();

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьВидимостьЭлементов();
	ПодтвержденоЗакрытиеФормы = Ложь;
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		МодульУправлениеКонтактнойИнформацией = ОбщегоНазначения.ОбщийМодуль("УправлениеКонтактнойИнформацией");
		МодульУправлениеКонтактнойИнформацией.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	НастроитьНадписьПостановление();
	ПрочитатьФилиалСтроения();
	
	Если объект.ТипСтроения<>Перечисления.энргТипыСтроений.МКД тогда
		элементы.Маршрут.Видимость=Ложь; 
	КонецЕсли;
	
	ЗаполнитьДанныеВетхостиСтроения();
	
	Если ЗначениеЗаполнено(ТекущийОбъект.Наименование) и ТекущийОбъект.ТипСтроения=Перечисления.энргТипыСтроений.МКД тогда
		 Элементы.МаршрутКонтроллера.Видимость=Ложь;
		Результат=ЗАполнитьМаршрут(Объект.Ссылка);
		Выборка=Результат.Выбрать();
		Выборка.Следующий();
		Объект.МаршрутКонтроллера=выборка.МАршрут;
	иначе 
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		МодульУправлениеКонтактнойИнформацией = ОбщегоНазначения.ОбщийМодуль("УправлениеКонтактнойИнформацией");
		МодульУправлениеКонтактнойИнформацией.ОбработкаПроверкиЗаполненияНаСервере(ЭтотОбъект, Объект, Отказ);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	энргРаботаСПрикрепленнымиФайламиКлиент.ПередЗаписью(Отказ, ЭтотОбъект);
	
	Если Не ПараметрыЗаписи.Свойство("ВопросЗадан") И Модифицированность Тогда
		
		СтруктураАдресов = АдресаПомещенийИАбонентов(Объект.Ссылка);
		МассивПомещений = СтруктураАдресов.Помещения;
		МассивАбонентов = СтруктураАдресов.Абоненты; 
		КоличествоПомещений = МассивПомещений.Количество();
		КоличествоАбонентов = МассивАбонентов.Количество();
		Если КоличествоПомещений > 0 И КоличествоАбонентов > 0 Тогда
			ТекстВопроса = НСтр("ru = 'Изменить адреса помещений и абонентов, относящихся к этому строению?'");
		ИначеЕсли КоличествоПомещений > 0 Тогда
			ТекстВопроса = НСтр("ru = 'Изменить адреса помещений, относящихся к этому строению?'");
		ИначеЕсли КоличествоАбонентов > 0 Тогда
			ТекстВопроса = НСтр("ru = 'Изменить адреса абонентов, относящихся к этому строению?'");
		Иначе
			Возврат;
		КонецЕсли;
		Отказ = Истина;
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("МассивПомещений",			МассивПомещений);
		ДополнительныеПараметры.Вставить("МассивАбонентов",			МассивАбонентов);
		ДополнительныеПараметры.Вставить("СоответствиеАбонентов",	СтруктураАдресов.СоответствиеАбонентов);
		ДополнительныеПараметры.Вставить("ОтборПомещений",			Новый Структура("Тип, Вид", ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес"), ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресПомещения")));
		ДополнительныеПараметры.Вставить("ОтборАбонентов",			Новый Структура("Тип, Вид", ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес"), ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресОбъекта")));
		ДополнительныеПараметры.Вставить("ПараметрыЗаписи", 		ПараметрыЗаписи);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ИзменитьАдресаПомещений", ЭтаФорма, ДополнительныеПараметры);
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
		
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		МодульУправлениеКонтактнойИнформацией = ОбщегоНазначения.ОбщийМодуль("УправлениеКонтактнойИнформацией");
		МодульУправлениеКонтактнойИнформацией.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	
	//СтрокиКИ 							= Объект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид",Справочники.ВидыКонтактнойИнформации.АдресДома));
	//Если СтрокиКИ.количество() > 0 тогда
	//	ТекущийОбъект.наименование  	= СтрокиКИ[0].Представление; 
	//КонецЕсли;
	ТекущийОбъект.ЗаполнитьНаименованиеСтроения();
	
	ОбновитьИнтерфейс 					= ТекущийОбъект.ЭтоНовый();		
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	//Если Не Отказ Тогда 
	ФИАС(ТекущийОбъект);
	//КонецЕсли;
	
	РС = РегистрыСведений.энргТехническаяВозможностьОРП;
	РС.УстановитьВозможностьОРП(Объект.Ссылка, Неопределено, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	энргРаботаСПрикрепленнымиФайламиКлиент.ПослеЗаписи(ЭтотОбъект);
	
	Если ОбновитьИнтерфейс Тогда
		ОбновитьИнтерфейс();
	КонецЕсли;
	
	УстановитьОтборГИС();
	УстановитьОтборыДинамическихСписков();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура УлицаНедобавленнаяВФИАСПриИзменении(Элемент)
	УлицаНедобавленнаяВФИАСПриИзмененииНаСервере();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВнестиИдентификаторДомаФИАС(Команда)
	Если Модифицированность Или Объект.Ссылка.Пустая() Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ОбработкаОтветаНаСохранение", ЭтотОбъект), "Данные изменены. Записать изменения?", РежимДиалогаВопрос.ДаНет);
	Иначе
		ЗапросФИАС();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	
	ПараметрыЗаписи = Новый Структура();
	ПараметрыЗаписи.Вставить("Закрыть", Истина);
	
	Если Записать(ПараметрыЗаписи) Тогда
		Закрыть();
	КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьВетхостьСтроения(Команда)
	Если Параметры.Ключ.Пустая() Тогда
		ПоказатьПредупреждение(,"Для добавления информации о ветхости необходимо записать элемент");
		Возврат;
	КонецЕсли;
	ОписаниеОповещения 		= новый ОписаниеОповещения("РегистрацияАварийностиСтроенияЗавершение", ЭтотОбъект);
	ПараметрыДляЗаполнения 	= новый Структура("ЗаполнитьДокумент, ДанныеДляЗаполнения", Истина,Новый Структура("Дата, Организация, Район, МКД", ТекущаяДата(), Объект.Организация, Объект.Район, Объект.Ссылка));
	ОткрытьФорму("Документ.энргРегистрацияАварийностиСтроения.Форма.ФормаДокумента", ПараметрыДляЗаполнения, Команда,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура КомандаИзменитьПостановление(Команда)
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ЗакрытиеФормыПостановление", ЭтаФорма);
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗначенияЗаполнения = Новый Структура("МКД, Район, Организация", Объект.Ссылка, Объект.Район, Объект.Организация);
		ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЗначенияЗаполнения);
		ОткрытьФорму("Документ.бестСменаРабочегоПостановленияМКД.ФормаОбъекта", ПараметрыФормы,ЭтаФорма,,,,ОповещениеОЗакрытии);
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
Процедура КомандаИсторияПостановления(Команда)
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		УсловияОтбора = Новый Структура("МКД", Объект.Ссылка);
		ПараметрыФормы = Новый Структура("Отбор", УсловияОтбора);
		ОткрытьФорму("РегистрСведений.бестРабочиеПостановленияМКД.ФормаСписка", ПараметрыФормы, ЭтаФорма);
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанные(Команда)
	ЗаполнитьСвойстваДанными();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьЭлементов()
	
	Если объект.ТипСтроения = ПредопределенноеЗначение("Перечисление.энргТипыСтроений.МКД") тогда
		Элементы.ОКТМО.Видимость 										= Истина;
		Элементы.КоличествоНежилыхПомещений.Видимость 					= Истина;
		Элементы.КоличествоКвартир.Видимость 							= Истина;
		Элементы.ГрЗначенияПлощадей.Видимость 							= Истина;
		Элементы.Начисления.Видимость 									= Истина;
	ИначеЕсли объект.ТипСтроения = ПредопределенноеЗначение("Перечисление.энргТипыСтроений.ОБЩ") тогда
		Элементы.ФормаУправления.Видимость 								= Ложь;
		Элементы.РасчетОбъемовВыполняетУК.Видимость 					= Ложь;
		Элементы.УК.Видимость											= Ложь;
		элементы.Маршрут.Видимость 										= Ложь;
		элементы.ГруппаВидыБлагоустройстваТарифныеКатегории.Видимость 	= Ложь;
		Элементы.Начисления.Видимость 									= Истина;
	Иначе 
		Элементы.ФормаУправления.Видимость 								= Ложь;
		Элементы.РасчетОбъемовВыполняетУК.Видимость 					= Ложь;
		Элементы.УК.Видимость											= Ложь;
		элементы.Маршрут.Видимость 										= Ложь;
		элементы.ГруппаВидыБлагоустройстваТарифныеКатегории.Видимость 	= Ложь;
		Элементы.Начисления.Видимость 									= Ложь;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборГИС()
	
	Перем ЭлементОтбора;
	
	ПолеКомпоновкиДанных = Новый ПолеКомпоновкиДанных("МКД");
	Отбор = Неопределено;
	Для каждого ТекОтбор Из ИдентификаторыГИСЖКХ.Отбор.Элементы Цикл
	    Если ПолеКомпоновкиДанных = ТекОтбор.ЛевоеЗначение Тогда
			Отбор = ТекОтбор;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Отбор = Неопределено Тогда
		ЭлементОтбора = ИдентификаторыГИСЖКХ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение	= Новый ПолеКомпоновкиДанных("МКД");
	Иначе
		ЭлементОтбора = Отбор;
	КонецЕсли;
	
	ЭлементОтбора.Использование 	= Истина;
	ЭлементОтбора.ПравоеЗначение 	= ?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Ссылка, Неопределено);
	ЭлементОтбора.РежимОтображения 	= РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;

КонецПроцедуры

Процедура УстановитьОтборыДинамическихСписков()
	
	СсылкаМКД = ?(Параметры.Ключ.Пустая(), Неопределено, Объект.Ссылка);	
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(НачисленияМКД,						"МКД", 						СсылкаМКД);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОтрицательныйОбъемРаспределенияМКД,	"МКД",						СсылкаМКД);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОтрицательныйОбъемРаспределенияМКД,	"ОбъемУслугиПотребленный", 	0);	
	
	РаспределениеОДН.Параметры.УстановитьЗначениеПараметра("Организация"	, Объект.Организация);
	РаспределениеОДН.Параметры.УстановитьЗначениеПараметра("Район"		, Объект.Район);
	РаспределениеОДН.Параметры.УстановитьЗначениеПараметра("МКД"			, СсылкаМКД);
	
	РаспределениеСверхнормативногоОДН.Параметры.УстановитьЗначениеПараметра("Организация"	, Объект.Организация);
	РаспределениеСверхнормативногоОДН.Параметры.УстановитьЗначениеПараметра("Район"		, Объект.Район);
	РаспределениеСверхнормативногоОДН.Параметры.УстановитьЗначениеПараметра("МКД"			, СсылкаМКД);
КонецПроцедуры

&НаСервере
Процедура УлицаНедобавленнаяВФИАСПриИзмененииНаСервере()
	Если ЗначениеЗаполнено(Объект.УлицаНедобавленнаяВФИАС) Тогда
		СтрокиКИ 							= Объект.УлицаНедобавленнаяВФИАС.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид",Справочники.ВидыКонтактнойИнформации.АдресНедобавленногоОбъекта));
		Если СтрокиКИ.количество() > 0 тогда
			Объект.КонтактнаяИнформация.Очистить();
			ОбъектТек = РеквизитФормыВЗначение("Объект");
			НовСтр = ОбъектТек.КонтактнаяИнформация.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтр, СтрокиКИ[0]);
			НовСтр.Вид =   Справочники.ВидыКонтактнойИнформации.АдресДома;
			//УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектТек, СтрокиКИ[0].Представление, Справочники.ВидыКонтактнойИнформации.АдресДома); 
			//УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектТек, СтрокиКИ[0].Представление, Справочники.ВидыКонтактнойИнформации.СтроительныйАдресДома);
			УправлениеКонтактнойИнформацией.ПриЧтенииНаСервере(ЭтаФорма, ОбъектТек);
			ЗначениеВРеквизитФормы(ОбъектТек,"Объект");

			
			//УправлениеКонтактнойИнформацией.ЗаписатьКонтактнуюИнформацию(Объект, СтрокиКИ[0].Значение,Справочники.ВидыКонтактнойИнформации.АдресДома,Перечисления.ТипыКонтактнойИнформации.Адрес);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

