&НаКлиенте
Процедура ИзменитьАдресаПомещений(РезультатВопроса, ДополнительныеПараметры) Экспорт 
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ОписаниеКИ = УправлениеКонтактнойИнформациейКлиентСервер.ОписаниеКонтактнойИнформацииНаФорме(ЭтотОбъект);
		СтрокиКИ = ОписаниеКИ.НайтиСтроки(Новый Структура("Вид", ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресДома")));
		Если СтрокиКИ.Количество() > 0 тогда
			ИзменитьАдресаПомещенийНаСервере(ДополнительныеПараметры.МассивПомещений, СтрокиКИ[0].Значение, ДополнительныеПараметры.ОтборПомещений);
			ИзменитьАдресаПомещенийНаСервере(ДополнительныеПараметры.МассивАбонентов, СтрокиКИ[0].Значение, ДополнительныеПараметры.ОтборАбонентов, ДополнительныеПараметры.СоответствиеАбонентов);
		КонецЕсли;
	КонецЕсли;
	
	ДополнительныеПараметры.ПараметрыЗаписи.Вставить("ВопросЗадан", Истина);
	Если Записать(ДополнительныеПараметры.ПараметрыЗаписи) И ДополнительныеПараметры.ПараметрыЗаписи.Свойство("Закрыть") Тогда
		Закрыть();
	КонецЕсли;
	
	//ПодтвержденоЗакрытиеФормы = Истина;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ИзменитьАдресаПомещенийНаСервере(МассивПомещений, АдресСтроения, Отбор, Соответствие = Неопределено)
	
	СтруктураJSONСтроения	= УправлениеКонтактнойИнформациейСлужебный.JSONВКонтактнуюИнформациюПоПолям(АдресСтроения, Перечисления.ТипыКонтактнойИнформации.Адрес);
	
	Для Каждого Помещение Из МассивПомещений Цикл
		
		ПомещениеОбъект = Помещение.ПолучитьОбъект();
		
		СтрокиАдреса = ПомещениеОбъект.КонтактнаяИнформация.НайтиСтроки(Отбор); 
		НадоЗаписать = Ложь;
		Для Каждого ТекСтрока Из СтрокиАдреса Цикл
			
			СтруктураJSONПомещения		= УправлениеКонтактнойИнформациейСлужебный.JSONВКонтактнуюИнформациюПоПолям(ТекСтрока.Значение, Перечисления.ТипыКонтактнойИнформации.Адрес);
			СтруктураJSONПомещенияНовая	= ОбщегоНазначения.СкопироватьРекурсивно(СтруктураJSONСтроения);
			
			СтруктураJSONПомещенияНовая.Вставить("apartments", СтруктураJSONПомещения.apartments);
			
			РаботаСАдресамиКлиентСервер.ОбновитьПредставлениеАдреса(СтруктураJSONПомещенияНовая, Ложь);
			ТекСтрока.Значение 		= УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(СтруктураJSONПомещенияНовая);
			ТекСтрока.Представление	= СтруктураJSONПомещенияНовая.Value;
			
			НадоЗаписать = Истина;
		КонецЦикла;
		
		Если Не НадоЗаписать И ЗначениеЗаполнено(Соответствие) Тогда
			АдресПомещения = Соответствие.Получить(Помещение);
			Если ЗначениеЗаполнено(АдресПомещения) Тогда
				ЗначениеАдреса = АдресПомещения;
			Иначе
				ЗначениеАдреса = АдресСтроения;
			КонецЕсли;
			УправлениеКонтактнойИнформацией.ЗаписатьКонтактнуюИнформацию(ПомещениеОбъект, ЗначениеАдреса, Справочники.ВидыКонтактнойИнформации.АдресОбъекта, Перечисления.ТипыКонтактнойИнформации.Адрес);
			
			НадоЗаписать = Истина;
		КонецЕсли;
		
		Если НадоЗаписать Тогда				
			ПомещениеОбъект.ДополнительныеСвойства.Вставить("НеПроверятьНаличиеФайла", Истина);
			ПомещениеОбъект.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			ПомещениеОбъект.ОбменДанными.Загрузка	= Истина;
			ПомещениеОбъект.Записать();
		КонецЕсли;
	КонецЦикла;	  
КонецПроцедуры

&НаСервереБезКонтекста
Функция АдресаПомещенийИАбонентов(Строение)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	энргПомещения.Ссылка КАК Помещение
	               |ИЗ
	               |	Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПомещения КАК энргПомещения
	               |		ПО энргКлючиПомещений.Помещение = энргПомещения.Ссылка
	               |			И (энргКлючиПомещений.Строение = &Строение)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	энргАбоненты.Ссылка КАК Абонент,
	               |	энргПомещенияКонтактнаяИнформация.Значение КАК АдресПомещения
	               |ИЗ
	               |	Справочник.энргАбоненты КАК энргАбоненты
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	               |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения.КонтактнаяИнформация КАК энргПомещенияКонтактнаяИнформация
	               |			ПО энргКлючиПомещений.Помещение = энргПомещенияКонтактнаяИнформация.Ссылка
	               |				И (энргПомещенияКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	               |					И энргПомещенияКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресПомещения))
	               |		ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.Ссылка
	               |			И (энргКлючиПомещений.Строение = &Строение)";
	Запрос.УстановитьПараметр("Строение", Строение);
	
	Пакет = Запрос.ВыполнитьПакет();
	МассивПомещений = Пакет.Получить(0).Выгрузить().ВыгрузитьКолонку("Помещение");
	
	ВыборкаАбонентов = Пакет.Получить(1).Выбрать();
	МассивАбонентов = Новый Массив;
	СоответствиеАбонентов = Новый Соответствие;
	Пока ВыборкаАбонентов.Следующий() Цикл
		МассивАбонентов.Добавить(ВыборкаАбонентов.Абонент);
		СоответствиеАбонентов.Вставить(ВыборкаАбонентов.Абонент, ВыборкаАбонентов.АдресПомещения);
	КонецЦикла;
	
	СтруктураАдресов = Новый Структура("Помещения, Абоненты, СоответствиеАбонентов", МассивПомещений, МассивАбонентов, СоответствиеАбонентов);
	Возврат СтруктураАдресов;

КонецФункции

&НаСервере 
Функция ЗаполнитьМаршрут(ТекОбъект)
		                             	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	энргМаршрутыКонтроллеровАдресаМаршрута.Представление КАК Представление,
	|	энргМаршрутыКонтроллеров.Ссылка КАК Маршрут,
	|	энргМаршрутыКонтроллеров.Владелец КАК Контроллер
	|ПОМЕСТИТЬ ВТ_Маршруты
	|ИЗ
	|	Справочник.энргМаршрутыКонтроллеров КАК энргМаршрутыКонтроллеров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргМаршрутыКонтроллеров.АдресаМаршрута КАК энргМаршрутыКонтроллеровАдресаМаршрута
	|		ПО энргМаршрутыКонтроллеров.Ссылка = энргМаршрутыКонтроллеровАдресаМаршрута.Ссылка
	|			И (НЕ энргМаршрутыКонтроллеров.ПометкаУдаления)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_Маршруты.Маршрут КАК Маршрут,
	|	ВТ_Маршруты.Контроллер КАК Контроллер
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргСтроения.Ссылка КАК МКД,
	|		энргСтроенияКонтактнаяИнформация.Представление КАК Представление
	|	ИЗ
	|		Справочник.энргСтроения КАК энргСтроения
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
	|			ПО энргСтроения.Ссылка = энргСтроенияКонтактнаяИнформация.Ссылка
	|				И (энргСтроения.Ссылка = &МКД)) КАК АдресМКД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Маршруты КАК ВТ_Маршруты
	|		ПО (АдресМКД.Представление ПОДОБНО ВТ_Маршруты.Представление + ""%"")";
	
	Запрос.УстановитьПараметр("МКД",ТекОбъект.ссылка); 	
	
	Результат = Запрос.Выполнить();
	Возврат Результат;		
КонецФункции

&НаСервере
Процедура УстановитьПризнакОРП()
	
	РезультатЗапроса = РегистрыСведений.энргТехническаяВозможностьОРП.ПолучитьВозможностьОРП(Объект.Ссылка);
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда 
		ТехническаяВозможностьПроведенияОРП = Выборка.ЕстьВозможность;
	Иначе
		ТехническаяВозможностьПроведенияОРП = Ложь;
	КонецЕсли;
КонецПроцедуры

