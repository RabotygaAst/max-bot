КонецПроцедуры

&НаСервере
Процедура ПослеВводаСтроки(Строка, Параметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Строка) Тогда 
	//	Или Строка = "00000000-0000-0000-0000-000000000000" Тогда 
		Возврат;
	КонецЕсли;
	
	СпрОбъект = РеквизитФормыВЗначение("Объект");
	НаборЗаписей = РегистрыСведений.энргИдентификаторыМКДГИСЖКХ.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.МКД.Установить(Объект.Ссылка);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() > 0 Тогда
		Запись = НаборЗаписей[0];
	Иначе
		Запись = НаборЗаписей.Добавить();
		Запись.МКД = Объект.Ссылка;
	КонецЕсли;
	Запись.ИдентификаторДомаФИАС = Строка;
	Запись.ОКТМО = СпрОбъект.ПолучитьДанныеИзАдреса("oktmo");
	НаборЗаписей.Записать();
	ЭтаФорма.Прочитать();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОтветаНаСохранение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Попытка
			Успех = Записать();
		Исключение
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр(ОписаниеОшибки()));
			Успех = Ложь;
		КонецПопытки;
		Если Не Успех Тогда 
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Не удалось записать'"));
		Иначе
			ЗапросФИАС();
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗапросФИАС()
	
	Перем Оповещение, СтрокаФИАС;
	
	Оповещение	= Новый ОписаниеОповещения("ПослеВводаСтроки", ЭтаФорма);
	
	СтрокаФИАС	= ПолучитьДанныеИзАдреса("houseId");	
	Если Не ЗначениеЗаполнено(СтрокаФИАС) Тогда
		СтрокаФИАС = "00000000-0000-0000-0000-000000000000";
		
	КонецЕсли;
	
	ПоказатьВводСтроки(Оповещение, СтрокаФИАС, "Введите Идентификатор дома по ФИАС или Идентификационный код дома в ГИС ЖКХ", 36, Ложь);
КонецПроцедуры

&НаСервере
Процедура ПрочитатьФилиалСтроения()
	
	Филиал = РегистрыСведений.энргФилиалыСтроений.ПолучитьПоследнее(,Новый Структура("Строение",Объект.Ссылка)).Филиал;
	
КонецПроцедуры

&Насервере
Процедура ФИАС(ТекущийОбъект) 
	Перем Оповещение, СтрокаФИАС;
	
	//Оповещение = Новый ОписаниеОповещения("ПослеВводаСтроки", ЭтаФорма);
	//СпрОбъект = РеквизитФормыВЗначение("Объект");
	СтрокаФИАС = ТекущийОбъект.ПолучитьДанныеИзАдреса("houseId");		
	//ПоказатьВводСтроки(Оповещение, СтрокаФИАС, "Введите Идентификатор дома по ФИАС или Идентификационный код дома в ГИС ЖКХ", 36, Ложь);
	
	НаборЗаписей = РегистрыСведений.энргИдентификаторыМКДГИСЖКХ.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.МКД.Установить(Объект.Ссылка);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() > 0 Тогда
		Запись = НаборЗаписей[0];
	Иначе
		Запись = НаборЗаписей.Добавить();
		Запись.МКД = Объект.Ссылка;
	КонецЕсли;
	Если СтрокаФИАС ="" тогда
		Возврат
	ИначеЕсли Не ЗначениеЗаполнено(Запись.ИдентификаторДомаФИАС) Тогда	
		Запись.ИдентификаторДомаФИАС = СтрокаФИАС;
	КонецЕсли;
	
	Запись.ОКТМО = ТекущийОбъект.ПолучитьДанныеИзАдреса("oktmo");
	НаборЗаписей.Записать();
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеИзАдреса(ИмяСв)
	 СпрОбъект = РеквизитФормыВЗначение("Объект");
	 Возврат	СпрОбъект.ПолучитьДанныеИзАдреса(ИмяСв);
КонецФункции

#Область Заполнение_Данных

&НаСервере
Процедура ЗаполнитьСвойстваДанными()
	ОчиститьОбновляемыеДанные();
	
	ЭтоМКД = объект.ТипСтроения = Перечисления.энргТипыСтроений.МКД;	

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВложенныйЗапрос.Помещение КАК Помещение,
		|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
		|	ВложенныйЗапрос.Абонент КАК Абонент,
		|	ВложенныйЗапрос.ТипПомещения КАК ТипПомещения
		|ПОМЕСТИТЬ ВТ_Помещения
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВложенныйЗапрос.Строение КАК МКД,
		|		ВложенныйЗапрос.Помещение КАК Помещение,
		|		ВложенныйЗапрос.Ссылка КАК КлючПомещения,
		|		энргАбоненты.Ссылка КАК Абонент,
		|		ВложенныйЗапрос.ТипПомещения КАК ТипПомещения
		|	ИЗ
		|		(ВЫБРАТЬ
		|			энргКлючиПомещений.КлючПомещения КАК Ссылка,
		|			энргКлючиПомещений.Строение КАК Строение,
		|			энргКлючиПомещений.Помещение КАК Помещение,
		|			энргПомещения.ТипПомещения КАК ТипПомещения
		|		ИЗ
		|			РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
		|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения КАК энргПомещения
		|				ПО энргКлючиПомещений.Помещение = энргПомещения.Ссылка
		|					И (НЕ энргПомещения.ПометкаУдаления)
		|					И энргКлючиПомещений.Строение = энргПомещения.Строение
		|		ГДЕ
		|			энргКлючиПомещений.Строение = &Строение
		|			И НЕ энргКлючиПомещений.Помещение = ЗНАЧЕНИЕ(Справочник.энргПомещения.ПустаяСсылка)
		|		
		|		СГРУППИРОВАТЬ ПО
		|			энргКлючиПомещений.КлючПомещения,
		|			энргКлючиПомещений.Строение,
		|			энргКлючиПомещений.Помещение,
		|			энргПомещения.ТипПомещения) КАК ВложенныйЗапрос
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		|			ПО ВложенныйЗапрос.Ссылка = энргАбоненты.КлючПомещения
		|				И (НЕ энргАбоненты.ПометкаУдаления)
		|				И (НЕ энргАбоненты.ЭтоГруппа)
		|	
		|	СГРУППИРОВАТЬ ПО
		|		энргАбоненты.Ссылка,
		|		ВложенныйЗапрос.Помещение,
		|		ВложенныйЗапрос.Ссылка,
		|		ВложенныйЗапрос.Строение,
		|		ВложенныйЗапрос.ТипПомещения) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.КлючПомещения,
		|	ВложенныйЗапрос.Помещение,
		|	ВложенныйЗапрос.Абонент,
		|	ВложенныйЗапрос.ТипПомещения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Помещения.Помещение КАК Помещение,
		|	ВТ_Помещения.КлючПомещения КАК КлючПомещения,
		|	ВТ_Помещения.Абонент КАК Абонент,
		|	ВТ_Помещения.ТипПомещения КАК ТипПомещения
		|ПОМЕСТИТЬ ВТ_АбонентыПомещений
		|ИЗ
		|	ВТ_Помещения КАК ВТ_Помещения
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргСостояниеЛС.СрезПоследних(
		|				&Период,
		|				Организация = &Организация
		|					И Район = &Район
		|					И Абонент В
		|						(ВЫБРАТЬ
		|							ВТ_Помещения.Абонент КАК Абонент
		|						ИЗ
		|							ВТ_Помещения КАК ВТ_Помещения)) КАК энргСостояниеЛССрезПоследних
		|		ПО ВТ_Помещения.Абонент = энргСостояниеЛССрезПоследних.Абонент
		|			И (энргСостояниеЛССрезПоследних.Состояние)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗначенияПлощадейСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргЗначенияПлощадейСрезПоследних.Площадь КАК Площадь
		|ПОМЕСТИТЬ ВТ_Площали
		|ИЗ
		|	РегистрСведений.энргЗначенияПлощадей.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадь)
		|				И КлючПомещения В
		|					(ВЫБРАТЬ
		|						ВТ_АбонентыПомещений.КлючПомещения КАК КлючПомещения
		|					ИЗ
		|						ВТ_АбонентыПомещений КАК ВТ_АбонентыПомещений)) КАК энргЗначенияПлощадейСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестАктивностьТочекУчетаНПСрезПоследних.Организация КАК Организация,
		|	бестАктивностьТочекУчетаНПСрезПоследних.Район КАК Район,
		|	бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
		|ПОМЕСТИТЬ АктивныеОбъектыРасчетов
		|ИЗ
		|	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ОбъектРасчета.МКД = &Строение) КАК бестАктивностьТочекУчетаНПСрезПоследних
		|ГДЕ
		|	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестЗначенияПлощадейНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
		|	бестЗначенияПлощадейНПСрезПоследних.Площадь КАК Площадь
		|ПОМЕСТИТЬ ЗначенияПлощадейНП
		|ИЗ
		|	РегистрСведений.бестЗначенияПлощадейНП.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадьНП)
		|				И ОбъектРасчета В
		|					(ВЫБРАТЬ
		|						АктивныеОбъектыРасчетов.ОбъектРасчета КАК ОбъектРасчета
		|					ИЗ
		|						АктивныеОбъектыРасчетов КАК АктивныеОбъектыРасчетов)) КАК бестЗначенияПлощадейНПСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
		|	МАКСИМУМ(бестДоговорыТочекУчетаСрезПоследних.Договор) КАК Договор
		|ПОМЕСТИТЬ ДоговорОбъектаРасчета
		|ИЗ
		|	РегистрСведений.бестДоговорыТочекУчета.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ОбъектРасчета В
		|					(ВЫБРАТЬ
		|						АктивныеОбъектыРасчетов.ОбъектРасчета КАК ОбъектРасчета
		|					ИЗ
		|						АктивныеОбъектыРасчетов КАК АктивныеОбъектыРасчетов)) КАК бестДоговорыТочекУчетаСрезПоследних
		|
		|СГРУППИРОВАТЬ ПО
		|	бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_АбонентыПомещений.Помещение КАК Помещение,
		|	ВТ_АбонентыПомещений.КлючПомещения КАК КлючПомещения,
		|	ВТ_АбонентыПомещений.Абонент КАК Абонент,
		|	ЕСТЬNULL(ВТ_Площали.Площадь, 0) КАК Площадь,
		|	ВТ_АбонентыПомещений.ТипПомещения КАК ТипПомещения
		|ИЗ
		|	ВТ_АбонентыПомещений КАК ВТ_АбонентыПомещений
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Площали КАК ВТ_Площали
		|		ПО ВТ_АбонентыПомещений.КлючПомещения = ВТ_Площали.КлючПомещения
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	АктивныеОбъектыРасчетов.ОбъектРасчета,
		|	ЗНАЧЕНИЕ(Справочник.энргКлючиПомещений.ПустаяСсылка),
		|	ДоговорОбъектаРасчета.Договор.Контрагент,
		|	ЕСТЬNULL(ЗначенияПлощадейНП.Площадь, 0),
		|	ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.НежилоеПомещение)
		|ИЗ
		|	АктивныеОбъектыРасчетов КАК АктивныеОбъектыРасчетов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияПлощадейНП КАК ЗначенияПлощадейНП
		|		ПО АктивныеОбъектыРасчетов.ОбъектРасчета = ЗначенияПлощадейНП.ОбъектРасчета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДоговорОбъектаРасчета КАК ДоговорОбъектаРасчета
		|		ПО АктивныеОбъектыРасчетов.ОбъектРасчета = ДоговорОбъектаРасчета.ОбъектРасчета
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТипПомещения,
		|	Помещение";
	
	
	Запрос.УстановитьПараметр("Период"		, ТекущаяДата());
	Запрос.УстановитьПараметр("Организация"	, Объект.Организация);
	Запрос.УстановитьПараметр("Район"		, Объект.Район);
	Запрос.УстановитьПараметр("Строение"	, ?(Параметры.Ключ.Пустая(), Неопределено, Объект.Ссылка));
	
	РезультатЗапроса 	= Запрос.Выполнить(); 	
	Выборка 			= РезультатЗапроса.Выбрать();
	ТипКвартира			= Перечисления.энргТипыПомещений.Квартира;
	ТипНежилое			= Перечисления.энргТипыПомещений.НежилоеПомещение;
	Пока Выборка.Следующий() Цикл
		Если ЭтоМКД Тогда
			Если Выборка.ТипПомещения = ТипКвартира Тогда
				КоличествоКвартир 			= КоличествоКвартир 			+ 1;
				ПлощадьЖилыхПомещений 		= ПлощадьЖилыхПомещений 		+ Выборка.Площадь;
			ИначеЕсли Выборка.ТипПомещения = ТипНежилое Тогда 
				КоличествоНежилыхПомещений 	= КоличествоНежилыхПомещений 	+ 1;			
				ПлощадьНежилыхПомещений 	= ПлощадьНежилыхПомещений 		+ Выборка.Площадь;
			КонецЕсли;			
		КонецЕсли;
		
		НоваяСтрока = Помещения.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);		
	КонецЦикла;
	
	Если ЭтоМКД Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗначениеПлощадейМКДСрезПоследних.ВидПлощади КАК ВидПлощади,
		|	энргЗначениеПлощадейМКДСрезПоследних.Площадь КАК Площадь
		|ИЗ
		|	РегистрСведений.энргЗначениеПлощадейМКД.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И МКД = &Строение
		|				И ВидПлощади В (ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадьМКД), ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ПлощадьМОП))) КАК энргЗначениеПлощадейМКДСрезПоследних";
		
		Запрос.УстановитьПараметр("Период"		, ТекущаяДата());
		Запрос.УстановитьПараметр("Организация"	, Объект.Организация);
		Запрос.УстановитьПараметр("Район"		, Объект.Район);
		Запрос.УстановитьПараметр("Строение"	, ?(Параметры.Ключ.Пустая(), Неопределено, Объект.Ссылка));
		
		РезультатЗапроса 	= Запрос.Выполнить();		
		Выборка 			= РезультатЗапроса.Выбрать();
		ВидПлощадьОбщая			= Перечисления.энргВидыПлощадей.ОбщаяПлощадьМКД;
		ВидПлощадьМОП			= Перечисления.энргВидыПлощадей.ПлощадьМОП;
		Пока Выборка.Следующий() Цикл
			Если Выборка.ВидПлощади = ВидПлощадьМОП Тогда
				ПлощадьМОП 		= Выборка.Площадь;
			КонецЕсли;
			Если Выборка.ВидПлощади = ВидПлощадьОбщая Тогда
				ОбщаяПлощадь 	= Выборка.Площадь;
			КонецЕсли; 			
		КонецЦикла;
		
	КонецЕсли; 
 
КонецПроцедуры

Процедура ОчиститьОбновляемыеДанные()
	Помещения.Очистить();
	КоличествоКвартир 			= 0;
	КоличествоНежилыхПомещений 	= 0;
	ПлощадьЖилыхПомещений 		= 0;			
	ПлощадьНежилыхПомещений 	= 0;
	ОбщаяПлощадь 				= 0;			
	ПлощадьМОП 					= 0;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеВетхостиСтроения()
	
	ПроцентВетхости = Справочники.энргСтроения.ПолучитьПроцентВетхостиСтроения(ТекущаяДата(), Объект.Организация, Объект.Район, Объект.Ссылка);
	
	ПроцентБольшеНуля					= ПроцентВетхости > 0;
	ВетхостьСтроения 					= ПроцентБольшеНуля;
	Элементы.ПроцентВетхости.Видимость 	= ПроцентБольшеНуля;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти