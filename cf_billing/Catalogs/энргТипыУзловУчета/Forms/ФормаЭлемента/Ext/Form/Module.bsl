
#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Для Каждого ТекСтр из Объект.СоставУзла Цикл
		ТекСтр.Шкалы 	= ЗаполнитьТекстСвойстваШкалы(ТекСтр.IDСтроки);
	КонецЦикла;
	
	ЗаполнитьДоступныеКВыборуШкалы();
КонецПроцедуры

#Конецобласти

&НаКлиенте
Процедура ВидКанальностиПриИзменении(Элемент)
	ЗаполнитьДоступныеКВыборуШкалы();
КонецПроцедуры


#Область СобытияТаблицыСоставУзла

&НаКлиенте
Процедура СоставУзлаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда
		ТекущиеДанные = Элементы.СоставУзла.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;	
		
		ТекущиеДанные.IDСтроки 	= новый УникальныйИдентификатор;
		ТекущиеДанные.Шкалы 	= ЗаполнитьТекстСвойстваШкалы(ТекущиеДанные.IDСтроки); 		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоставУзлаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "СоставУзлаШкалы" Тогда
		 ОткрытьФормуШкалыТипаИзмерителя();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоставУзлаПередУдалением(Элемент, Отказ)
	ТекущиеДанные = Элементы.СоставУзла.ТекущиеДанные;
	ОчиститьШкалыТипаИзмерителя(ТекущиеДанные.IDСтроки);
КонецПроцедуры


&НаКлиенте
Процедура ОткрытьФормуШкалыТипаИзмерителя()
	ТекущиеДанные		= Элементы.СоставУзла.ТекущиеДанные;
	
	ОписаниеОповещения 	= Новый ОписаниеОповещения("ШкалыТипаИзмерителяЗавершение", ЭтотОбъект, Новый Структура("ТекущиеДанные", ТекущиеДанные));
	ОткрытьФорму("Обработка.энргОперацияУзламиУчета.Форма.ФормаШкалыТипаИзмерителя", ПолучитьМассивДоступныхШкал(ТекущиеДанные.IDСтроки),,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивДоступныхШкал(IDСтроки)
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("IDСтроки", IDСтроки);
	ШкалыИзмерителя = Объект.ШкалыТипаИзмерителя.НайтиСтроки(ПараметрыОтбора);
	мШкалИзмерителя = Новый Массив;
	Для каждого стр из ШкалыИзмерителя Цикл
		мШкалИзмерителя.Добавить(стр.Шкала);
	КонецЦикла;
	Возврат Новый Структура("ДоступныеКВыборуШкалы,ЗаполненныеШкалы", Обработки.энргОперацияУзламиУчета.ПолучитьМассивДоступныхШкал(ДоступныеКВыборуШкалы, Объект.ШкалыТипаИзмерителя), мШкалИзмерителя);
КонецФункции

&НаКлиенте
Процедура ШкалыТипаИзмерителяЗавершение(Результат, ДополнительныеПараметры) Экспорт	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 		= ДополнительныеПараметры.ТекущиеДанные;
	
	ТекущиеДанные.Шкалы = ЗаполнитьТекстСвойстваШкалы(ТекущиеДанные.IDСтроки, Результат.ВыбранныеШкалы);
	ЗаполнитьШкалыИзРезультата(ТекущиеДанные.IDСтроки, Результат.ВыбранныеШкалы);
	
КонецПроцедуры

#КонецОбласти 


#Область ВспомогательныеПроцедурыИФункции

&НаСервере
Функция ЗаполнитьТекстСвойстваШкалы(IDСтроки, МассивСтрок = Неопределено)
	Если МассивСтрок = Неопределено Тогда
		МассивСтрок 	= Объект.ШкалыТипаИзмерителя.НайтиСтроки(Новый Структура("IDСтроки", IDСтроки));
	КонецЕсли;
	
	Текст = "";
	Для Каждого ТекШкала из МассивСтрок Цикл
		Текст = Текст + СокрЛП(ТекШкала.Шкала) + Символы.ПС;
	КонецЦикла;
	Текст = СокрЛП(Текст);
	
	Возврат ?(Текст = "", "Не заполнены", Текст);
КонецФункции

&НаСервере
Процедура ЗаполнитьДоступныеКВыборуШкалы()
	ДоступныеКВыборуШкалы.Очистить();	
	
	РезультатЗапроса 	= Справочники.энргВидыКанальности.ПолучитьШкалыВидаКанальности(Объект.ВидКанальности);
	Выборка 			= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл		
		НоваяСтрока = ДоступныеКВыборуШкалы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
	КонецЦикла;
КонецПроцедуры 

&НаСервере
Процедура ЗаполнитьШкалыИзРезультата(IDСтроки, ВыбранныеШкалы)
	
	ОчиститьШкалыТипаИзмерителя(IDСтроки);
	
	Для Каждого ТекСтрЗаполнения из ВыбранныеШкалы Цикл
		НоваяСтрока = Объект.ШкалыТипаИзмерителя.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрЗаполнения);
		НоваяСтрока.IDСтроки = IDСтроки;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьШкалыТипаИзмерителя(IDСтроки)
	МассивСтрокУдаления = Объект.ШкалыТипаИзмерителя.НайтиСтроки(Новый Структура("IDСтроки", IDСтроки));
	Для Каждого ТекСтрУдаления из МассивСтрокУдаления Цикл
		Объект.ШкалыТипаИзмерителя.Удалить(ТекСтрУдаления);
	КонецЦикла;
КонецПроцедуры

#КонецОбласти


