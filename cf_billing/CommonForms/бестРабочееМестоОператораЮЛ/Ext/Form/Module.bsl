
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СтруктураФО = ЗаполнитьСтруктуруЗначенийФО();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СтруктураФО);
	
	ДокументыДоговораНастройкиКД = ДокументыДоговора.КомпоновщикНастроек.ПолучитьНастройки();
	
	УстановитьОперации();
	
	ПриСозданииНаСервереПереопределеляемый(Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьДоступностьКнопкиОбновитьДанные();
	НастроитьВидимостьЭлементов();
	УстановитьВидимостьДанныхОбъектовРасчета(Ложь);
	НайтиИндексыНастроек(ЭтотОбъект);
	ЗаполнитьПараметрыДинамическогоСпискаДолевыеТУ();
	ЗаполнитьПараметрыДинамическогоСпискаСубабоненты();
	ЗаполнитьПараметрыДинамическогоСпискаДокументыДоговора();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СтрокаПоискаДоговораПриИзменении(Элемент)
	НайтиДоговорПоСтрокеПоиска();
КонецПроцедуры

&НаКлиенте
Процедура ОтчетПоПДОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка, ДополнительныеПараметры)
	СтандартнаяОбработка = Ложь;
	ЗначениеПоляРасшифровки = ЗначениеПоляРасшифровки(Расшифровка, ОтчетПоПДДанныеРасшифровки);
	Если Не ЗначениеПоляРасшифровки = Неопределено Тогда
		ПоказатьЗначение(, ЗначениеПоляРасшифровки);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтчетПоПДТипПриИзменении(Элемент)
	ОтчетПоПДИспользоватьОтборПоТипу = Истина;
	ОтчетПоПД = ВыполнитьОтборПоТипуПД(ОтчетПоПДКомпоновщикНастроек, ОтчетПоПДИспользоватьОтборПоТипу, ОтчетПоПДТип);
КонецПроцедуры

&НаКлиенте
Процедура ОтчетПоПДИспользоватьОтборПоТипуПриИзменении(Элемент)
	ОтчетПоПД = ВыполнитьОтборПоТипуПД(ОтчетПоПДКомпоновщикНастроек, ОтчетПоПДИспользоватьОтборПоТипу, ОтчетПоПДТип);
КонецПроцедуры

&НаКлиенте
Процедура ОтчетПоПДПериодПриИзменении(Элемент)
	ИзменитьАктуальностьДанныхОтчетаПоПД(Ложь);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОбъектыРасчета

&НаКлиенте
Процедура ОбъектыРасчетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ПоказатьЗначение(, ОбъектРасчета);
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ОбъектРасчета = ТекущиеДанные.ОбъектРасчета;
	Элементы.ТочкиПоставки.ОтборСтрок = Новый ФиксированнаяСтруктура("ОбъектРасчета", ОбъектРасчета);
	ОбновитьДеревоОтображенияПоУмолчанию(ТекущиеДанные, "ОбъектРасчета", "ДеревоОтображенияДанныхПоТУ", ДеревоОтображенияДанныхПоТУ, ДеревоДанныеПоТУ);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТочкиПоставки

&НаКлиенте
Процедура ТочкиПоставкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "ТочкиПоставкиСтатус" Тогда
		СтандартнаяОбработка = Ложь;
		ТекущиеДанные = Элементы.ТочкиПоставки.ТекущиеДанные;
		Отбор  = Новый Структура("ТочкаПоставки", ТекущиеДанные.ТочкаПоставки);
		ПараметрыОткрытия  = Новый Структура("Отбор", Отбор);
		ОткрытьФорму("РегистрСведений.энргАктивностьТочекПоставки.ФормаСписка", ПараметрыОткрытия);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоОтображенияДанныхПоТУ

&НаКлиенте
Процедура ДеревоОтображенияДанныхПоТУПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.ДеревоОтображенияДанныхПоТУ.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТочкаУчета = ТекущиеДанные.ТочкаУчета;
	ПриборУчета = ТекущиеДанные.ПриборУчета; 
	
	ОбновитьДеревоОтображенияПоУмолчанию(ТекущиеДанные, 
											"ТочкаУчета", 
											"ДеревоОтображенияДанныхПоПУ", 
											ДеревоОтображенияДанныхПоПУ, 
											ДеревоДанныеПоПУ);
	ОбновитьДеревоОтображенияПоУмолчанию(ТекущиеДанные, 
											"ТочкаУчета", 
											"ДеревоОтображенияДанныхПоИзмерительномуКомплексу", 
											ДеревоОтображенияДанныхПоИзмерительномуКомплексу, 
											ДеревоДанныеПоИзмерительномуКомплексу);
КонецПроцедуры
										
&НаКлиенте
Процедура ДеревоОтображенияДанныхПоТУВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ОткрытьЗначениеСсылкиВДереве("ДеревоОтображенияДанныхПоТУ", Поле.Имя);
КонецПроцедуры
										
#КонецОбласти 

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоОтображенияДанныхПоПУ

&НаКлиенте
Процедура ДеревоОтображенияДанныхПоПУВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ОткрытьЗначениеСсылкиВДереве("ДеревоОтображенияДанныхПоПУ", Поле.Имя);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоОтображенияДанныхПоИзмерительномуКомплексу

&НаКлиенте
Процедура ДеревоОтображенияДанныхПоИзмерительномуКомплексуВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ОткрытьЗначениеСсылкиВДереве("ДеревоОтображенияДанныхПоИзмерительномуКомплексу", Поле.Имя);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДолевыеТУ

&НаКлиенте
Процедура ДолевыеТУПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.ДолевыеТУ.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьПараметрыДинамическогоСпискаСубабоненты(ТекущиеДанные);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДокументыДоговора

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НайтиДоговорПоСтрокеПоиска(Команда = Неопределено)
	
	ПараметрыФормы = Новый Структура("СтрокаНачальногоПоиска, ТекущаяСтрока, НезависимыйСбыт", СтрокаПоискаДоговора, Договор, НезависимыйСбыт);
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаВыбораДоговора", ЭтотОбъект);
	ОткрытьФорму("Справочник.энргДоговорыКонтрагентов.Форма.ФормаПоискаПоСтроке", ПараметрыФормы, ЭтаФорма,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);  
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДоговор(Команда)
	Если ЗначениеЗаполнено(Договор) Тогда
		ПоказатьЗначение(,Договор);
	Иначе
		НайтиДоговорПоСтрокеПоиска();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьИнформациюПоОбъектам(Команда)
	ВидимостьДанныхОбъектов = Не ОбщегоНазначенияКлиентСервер.ЗначениеСвойстваЭлементаФормы(Элементы, "ГруппаИнформацияПоОбъектам", "Видимость");
	УстановитьВидимостьДанныхОбъектовРасчета(ВидимостьДанныхОбъектов);
КонецПроцедуры 

&НаКлиенте
Процедура СформироватьОтчетПоПД(Команда)
	Если Не ЗначениеЗаполнено(ОтчетПоПДПериод.ДатаОкончания) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Не заполнен период формирования отчета!'");
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	ПоляДоговора = ОсновныеПоляДоговора();
	ПоляДоговора.Вставить("ДатаНачала", ОтчетПоПДПериод.ДатаНачала);
	ПоляДоговора.Вставить("ДатаОкончания", ОтчетПоПДПериод.ДатаОкончания);
	Если ОтчетПоПДИспользоватьОтборПоТипу Тогда
		ПоляДоговора.Вставить("ТипПД", ОтчетПоПДТип);
	КонецЕсли;
	
	// 1. Запуск фонового задания на сервере.
	ДлительнаяОперация = ЗапуститьФоновоеЗаданиеФормированияОтчетаПоПД(УникальныйИдентификатор, ПоляДоговора);

	// 2. Подключение обработчика завершения фонового задания.
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения = "Идет получение данных";
	Оповещение = Новый ОписаниеОповещения("ПриЗавершенииФормированияОтчетаПоПД", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанные(Команда)
	СтруктураФО = ЗаполнитьСтруктуруЗначенийФО();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СтруктураФО);
	НастроитьВидимостьЭлементов();
	ВидимостьДанныхОбъектов = ОбщегоНазначенияКлиентСервер.ЗначениеСвойстваЭлементаФормы(Элементы, "ГруппаИнформацияПоОбъектам", "Видимость");
	ЗаполнитьДанныеДоговора(ВидимостьДанныхОбъектов);
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьИсториюПоказаний(Команда)
	КлючиПараметров = "Организация, Район, ОбъектРасчета, ТочкаУчета, ПриборУчета";
	ПараметрыФормы = Новый Структура(КлючиПараметров);
	ЗаполнитьЗначенияСвойств(ПараметрыФормы, ЭтотОбъект, КлючиПараметров);
	ОткрытьФорму("ОбщаяФорма.бестФормаИсторияПоказаний", ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ЗарегистрироватьПоказания(Команда)
	ВыбратьОперациюИзСпискаЗавершение(Новый Структура("Значение", "бестРегистрацияПоказанийНП__бестРегистрацияПоказанийНП_РегистрацияПоказаний"), Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьФормулуРасчета(Команда)
	ТекущиеДанные = Элементы.ДолевыеТУ.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ЗначениеЗаполнено(Договор) Тогда
		КлючиДопЗначЗапол = "ДолеваяТочкаУчета, Услуга";
	Иначе
		КлючиДопЗначЗапол = "Организация, Район, Договор, ОбъектРасчета, ДолеваяТочкаУчета, Услуга";
	КонецЕсли;
	ДопЗначЗапол = Новый Структура(КлючиДопЗначЗапол);
	ЗаполнитьЗначенияСвойств(ДопЗначЗапол, ТекущиеДанные);
	ДопЗначЗапол.ДолеваяТочкаУчета = ТекущиеДанные.ТочкаУчета;
	ОткрытьФормуНовогоДокумента("бестУстановитьФормулуРасчетаТочекУчетаНП", 
									"бестУстановитьФормулуРасчетаТочекУчетаНП_НачислениеПоФормуле", 
									,
									ДопЗначЗапол)
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСуммуНачислений(Команда)
	СтруктураСуммНачислений = ДанныеОСуммахНачислений(Организация, Район, Договор); 
	СуммаБезНДС = СтруктураСуммНачислений.СуммаБезНДС;
	СуммаНДС = СтруктураСуммНачислений.СуммаНДС;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ЗаполнитьДанныеДоговора(ВидимостьДанныхОбъектов = Ложь)

	ДанныеДоговора = ДанныеДоговора(Договор);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ОткрытьДоговор", "Заголовок", ДанныеДоговора.ПредставлениеДоговора);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеДоговора);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВзаимодействиеСЭДОНет", "Видимость", Не ДанныеДоговора.ВзаимодействиеСЭДО И Не НезависимыйСбыт);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВзаимодействиеСЭДОДа", "Видимость", ДанныеДоговора.ВзаимодействиеСЭДО И Не НезависимыйСбыт);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДоговорТарифнаяСетка", "Видимость", ДанныеДоговора.ФиксированныйТариф);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДоговорЦеноваяКатегория", "Видимость", Не ДанныеДоговора.ФиксированныйТариф);
	РасходныеДоговоры.ЗагрузитьЗначения(ДанныеДоговора.РасходныеДоговоры);
	
	УстановитьВидимостьДанныхОбъектовРасчета(ВидимостьДанныхОбъектов);
	
	ЗаполнитьПараметрыДинамическогоСпискаДолевыеТУ();
	ЗаполнитьПараметрыДинамическогоСпискаДокументыДоговора();
	
	Для каждого эл из ДокументыДоговора.КомпоновщикНастроек.Настройки.Отбор.Элементы Цикл
		Если эл.ПредставлениеПользовательскойНастройки = "ЗаполнениеДоговор" Тогда
			эл.ПравоеЗначение = Договор;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	УстановитьОтборОбъектаРасчетаПоДоговору(ЭтотОбъект);
	
	ИзменитьАктуальностьДанныхОтчетаПоПД(Ложь); 
	
	ЗаполнитьДанныеДоговораПереопределяемый(ВидимостьДанныхОбъектов);

КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеДоговора(Договор)

	ДанныеДоговора = Новый Структура("ПредставлениеДоговора, Организация, Район, Контрагент, 
										|СтатусДоговора, ДатаСостоянияДоговора, ВзаимодействиеСЭДО,
										|ЮридическийАдресКонтрагента, ЭлектронныйАдресКонтрагента,
										|ФиксированныйТариф, ИннКпп, ОкпоОгрн, РасходныеДоговоры");
	Пакет = бестРаботаСРабочимМестомОператораЮЛ.ДанныеДоговораДляРабочегоМестаОператора(Договор);
	Выборка = Пакет.Получить(Пакет.ВГраница()).Выбрать();
	Выборка.Следующий();
	
	ЗаполнитьЗначенияСвойств(ДанныеДоговора, Выборка);
	
	Шаблон = НСтр("ru = '%1/%2'");
	Если ЗначениеЗаполнено(Выборка.ИНН) И ЗначениеЗаполнено(Выборка.КПП) Тогда
		ДанныеДоговора.ИннКпп = СтрШаблон(Шаблон, Выборка.ИНН, Выборка.КПП);
	ИначеЕсли ЗначениеЗаполнено(Выборка.ИНН) Тогда
		ДанныеДоговора.ИннКпп = Выборка.ИНН;
	ИначеЕсли ЗначениеЗаполнено(Выборка.КПП) Тогда
		ДанныеДоговора.ИннКпп = Выборка.КПП;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Выборка.ОКПО) И ЗначениеЗаполнено(Выборка.ОГРН) Тогда
		ДанныеДоговора.ОкпоОгрн = СтрШаблон(Шаблон, Выборка.ОКПО, Выборка.ОГРН);
	ИначеЕсли ЗначениеЗаполнено(Выборка.ОКПО) Тогда
		ДанныеДоговора.ОкпоОгрн = Выборка.ОКПО;
	ИначеЕсли ЗначениеЗаполнено(Выборка.ОГРН) Тогда
		ДанныеДоговора.ОкпоОгрн = Выборка.ОГРН;
	КонецЕсли;
	
	ДанныеДоговора.РасходныеДоговоры = Пакет.Получить(0).Выгрузить().ВыгрузитьКолонку("Договор");
	
	ДополнитьДанныеДоговора(ДанныеДоговора, Договор);
	
	Возврат ДанныеДоговора;

КонецФункции

&НаКлиенте
Процедура УстановитьВидимостьДанныхОбъектовРасчета(Видимость)
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ГруппаИнформацияПоОбъектам",
		"Видимость",
		Видимость);
		
	ЗаголовокКнопки = ОбщегоНазначенияКлиентСервер.ЗначениеСвойстваЭлементаФормы(Элементы, "ЗаполнитьИнформациюПоОбъектам", "Заголовок");	
	Если Видимость Тогда
		ЧтоЗаменить = "Показать";
		НаЧтоЗаменить = "Скрыть";
	Иначе
		ЧтоЗаменить = "Скрыть";
		НаЧтоЗаменить = "Показать";
	КонецЕсли;
	ЗаголовокКнопки = СтрЗаменить(ЗаголовокКнопки, ЧтоЗаменить, НаЧтоЗаменить); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ЗаполнитьИнформациюПоОбъектам",
		"Заголовок",
		ЗаголовокКнопки);	
	
	Если Видимость Тогда 
		ЗаполнитьДанныеПоОбъектамРасчета();		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеПоОбъектамРасчета()
	
	ОчиститьКоллекции();
	
	ПоляДоговора = ОсновныеПоляДоговора();
	ПоляДоговора.Вставить("Контрагент", Контрагент);
	ПоляДоговора.Вставить("НезависимыйСбыт", НезависимыйСбыт);
	ПоляДоговора.Вставить("ИспользоватьТарифныеЗоны", ИспользоватьТарифныеЗоны);
	ПоляДоговора.Вставить("ИспользоватьШкалыПриборовУчета", ИспользоватьШкалыПриборовУчета);
	ПоляДоговора.Вставить("ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ", ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ);
	
	// 1. Запуск фонового задания на сервере.
	ДлительнаяОперация = ЗапуститьФоновоеЗаданиеПолученияДанныхПоОбъектамРасчета(УникальныйИдентификатор, ПоляДоговора, ОбъектыРасчета, ТочкиПоставки);

	// 2. Подключение обработчика завершения фонового задания.
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения = "Идет получение данных";
	Оповещение = Новый ОписаниеОповещения("ПриЗавершенииПолученияДанныхПоОбъектамРасчета", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьКоллекции()
	
	ДеревоДанныеПоТУ.ПолучитьЭлементы().Очистить();
	ДеревоДанныеПоПУ.ПолучитьЭлементы().Очистить();
	ДеревоДанныеПоИзмерительномуКомплексу.ПолучитьЭлементы().Очистить();
	ДеревоОтображенияДанныхПоТУ.ПолучитьЭлементы().Очистить();
	ДеревоОтображенияДанныхПоПУ.ПолучитьЭлементы().Очистить();
	ДеревоОтображенияДанныхПоИзмерительномуКомплексу.ПолучитьЭлементы().Очистить();
	
	ОбъектыРасчета.Очистить();
	ТочкиПоставки.Очистить();
	ОчиститьКоллекцииПереопределяемый();
	
КонецПроцедуры

&НаКлиенте
