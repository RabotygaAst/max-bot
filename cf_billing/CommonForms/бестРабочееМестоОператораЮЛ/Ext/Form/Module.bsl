&НаСервереБезКонтекста
Функция ПолучитьДанныеОбъектов(Результат, Знач ДеревоДанныеПоТУ, Знач ДеревоДанныеПоПУ, Знач ДеревоДанныеПоИзмерительномуКомплексу)
	
	ДанныеВременногоХранилища = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	УдалитьИзВременногоХранилища(Результат.АдресРезультата);
	
	ДанныеПоУмолчанию = ДанныеВременногоХранилища.ДанныеПоУмолчанию;
	
	МассивОбъектов = ОбщегоНазначения.ТаблицаЗначенийВМассив(ДанныеВременногоХранилища.ОбъектыРасчета);
	МассивТП = ОбщегоНазначения.ТаблицаЗначенийВМассив(ДанныеВременногоХранилища.ТочкиПоставки);
	
	СтрокаДерева = ДеревоДанныеПоТУ.ПолучитьЭлементы();
	ОбщегоНазначения.ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, ДанныеВременногоХранилища.ДеревоДанныеПоТУ);
	
	СтрокаДерева = ДеревоДанныеПоПУ.ПолучитьЭлементы();
	ОбщегоНазначения.ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, ДанныеВременногоХранилища.ДеревоДанныеПоПУ);
	
	СтрокаДерева = ДеревоДанныеПоИзмерительномуКомплексу.ПолучитьЭлементы();
	ОбщегоНазначения.ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, ДанныеВременногоХранилища.ДеревоДанныеПоИзмерительномуКомплексу);
	
	Возврат Новый Структура("ДанныеПоУмолчанию, МассивОбъектов, МассивТП, ДеревоДанныеПоТУ, ДеревоДанныеПоПУ, ДеревоДанныеПоИзмерительномуКомплексу", 
								ДанныеПоУмолчанию, МассивОбъектов, МассивТП, ДеревоДанныеПоТУ, ДеревоДанныеПоПУ, ДеревоДанныеПоИзмерительномуКомплексу);
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьДанныеОтчета(Результат)
	
	РезультатВыполненияОтчета = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	УдалитьИзВременногоХранилища(Результат.АдресРезультата);
	
	ОтчетДанныеРасшифровки = ПоместитьВоВременноеХранилище(РезультатВыполненияОтчета.ДанныеРасшифровкиКомпоновки, Новый УникальныйИдентификатор);
	
	ДанныеОтчета = Новый Структура("Отчет, ОтчетДанныеРасшифровки, НастройкиКД", 
										РезультатВыполненияОтчета.ТабДок, ОтчетДанныеРасшифровки, РезультатВыполненияОтчета.НастройкиКД);
	Возврат ДанныеОтчета;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(КоллекцияЭлементовДерева, Строки)
	
	Для Каждого Строка Из Строки Цикл
		
		ЭлементДерева = КоллекцияЭлементовДерева.Добавить();		
		ЗаполнитьЗначенияСвойств(ЭлементДерева, Строка);
		
		Если Строка.ПолучитьЭлементы().Количество() > 0 Тогда
			
			ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(ЭлементДерева.ПолучитьЭлементы(), Строка.ПолучитьЭлементы());
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДеревоОтображенияПоУмолчанию(ТекущиеДанные, ИмяПоляПоиска, ИмяЭлементаДереваОтображения, ДеревоОтображения, ДеревоИсточник)
	
	КоллекцияСтрокВернегоУровня = ДеревоОтображения.ПолучитьЭлементы();
	КоллекцияСтрокВернегоУровня.Очистить();
	
	ЗначениеПоиска  = ТекущиеДанные[ИмяПоляПоиска];	
	СтрокиДерева 	= ДеревоИсточник.ПолучитьЭлементы();
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		
		Если СтрокаДерева[ИмяПоляПоиска] = ЗначениеПоиска Тогда 
			ЭлементДерева = КоллекцияСтрокВернегоУровня.Добавить(); 
			ЗаполнитьЗначенияСвойств(ЭлементДерева, СтрокаДерева);
			ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(ЭлементДерева.ПолучитьЭлементы(), СтрокаДерева.ПолучитьЭлементы());			
		КонецЕсли;
		
	КонецЦикла;
	
	ДеревоЭлемент = Элементы[ИмяЭлементаДереваОтображения];
	Для Каждого СтрокаДерева Из КоллекцияСтрокВернегоУровня Цикл		
		ДеревоЭлемент.Развернуть(СтрокаДерева.ПолучитьИдентификатор(), Истина);		
	КонецЦикла; 	
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьОперациюИзСпискаЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры)
	
	Если ВыбранныйЭлемент = Неопределено тогда
		Возврат;
	КонецЕсли;
	ВидОперации 		= Неопределено;
	МассивСтрок  		= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВыбранныйЭлемент.Значение, "__");
	ИмяДокумента  		= МассивСтрок[0];
	Если МассивСтрок.Количество() > 1 тогда
		ВидОперации 	= МассивСтрок[1]; 
	КонецЕсли;
	
	ОткрытьФормуНовогоДокумента(ИмяДокумента, ВидОперации);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуНовогоДокумента(ИмяДокумента, ВидОперации, ЗаполнитьДокумент = Истина, ДопЗначЗапол = Неопределено)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗаполнитьДокумент", ЗаполнитьДокумент);
	Если ЗаполнитьДокумент Тогда
		КлючиЗначений = "Организация, Район, Контрагент, Договор, ОбъектРасчета, ТочкаУчета, ПриборУчета"; 
		ЗначенияЗаполнения = Новый Структура(КлючиЗначений);
		ЗаполнитьЗначенияСвойств(ЗначенияЗаполнения, ЭтотОбъект, КлючиЗначений); 
		ЗначенияЗаполнения.Вставить("Дата", ТекущаяДата());
	Иначе
		ЗначенияЗаполнения = Новый Структура;
	КонецЕсли;
	
	Если ТипЗнч(ДопЗначЗапол) = Тип("Структура") Тогда
		Для каждого ТекЗнач Из ДопЗначЗапол Цикл
			ЗначенияЗаполнения.Вставить(ТекЗнач.Ключ, ТекЗнач.Значение);
		КонецЦикла;
	КонецЕсли;
	Если ВидОперации <> Неопределено тогда
		ИмяВидаОперации = СтрШаблон("Перечисление.бестВидыОпераций.%1", ВидОперации);
		ЗначенияЗаполнения.Вставить("ВидОперации", ПредопределенноеЗначение(ИмяВидаОперации));
	КонецЕсли;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	ИмяФормыДокумента = СтрШаблон("Документ.%1.ФормаОбъекта", ИмяДокумента);
	ОткрытьФорму(ИмяФормыДокумента, ПараметрыФормы);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗначениеПоляРасшифровки(Расшифровка, ОтчетДанныеРасшифровки)
	ДанныеРасшифровки = ПолучитьИзВременногоХранилища(ОтчетДанныеРасшифровки);
	
	ЭлементРасшифровки = ДанныеРасшифровки.Элементы.Получить(Расшифровка);
	Если ЭлементРасшифровки.ОсновноеДействие = ДействиеОбработкиРасшифровкиКомпоновкиДанных.ОткрытьЗначение Тогда
		ПоляРасшифровки = ЭлементРасшифровки.ПолучитьПоля(); 
		Если ЗначениеЗаполнено(ПоляРасшифровки[0].Значение) Тогда
			Возврат ПоляРасшифровки[0].Значение;
		КонецЕсли;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

&НаСервереБезКонтекста
Функция ВыполнитьОтборПоТипуПД(КомпоновщикНастроекДанныхОтчета, ИспользованиеОтбора, ТипПД)
	
	ТабДок = Новый ТабличныйДокумент;
	
	ПолеТипПД = Новый ПолеКомпоновкиДанных("ПлатежныйДокументТипЗадолженности");
	ИдентификаторПользовательскойНастройки = Неопределено;
	Для каждого ОтборКД Из КомпоновщикНастроекДанныхОтчета.Настройки.Отбор.Элементы Цикл
		Если ОтборКД.ЛевоеЗначение = ПолеТипПД Тогда
			ИдентификаторПользовательскойНастройки = ОтборКД.ИдентификаторПользовательскойНастройки;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ИдентификаторПользовательскойНастройки) Тогда
		Возврат ТабДок;
	КонецЕсли;
	
	Для каждого ПараметрНастроекКД Из КомпоновщикНастроекДанныхОтчета.ПользовательскиеНастройки.Элементы Цикл
		Если ТипЗнч(ПараметрНастроекКД) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда 
			Если ПараметрНастроекКД.ИдентификаторПользовательскойНастройки = ИдентификаторПользовательскойНастройки Тогда
				ПараметрНастроекКД.ПравоеЗначение = ТипПД;
				ПараметрНастроекКД.Использование = ИспользованиеОтбора;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Отчет = Отчеты.бестАнализПлатежныхДокументовЭЭ.Создать();
	Отчет.КомпоновщикНастроек.ЗагрузитьНастройки(КомпоновщикНастроекДанныхОтчета.Настройки);
	Отчет.КомпоновщикНастроек.ЗагрузитьПользовательскиеНастройки(КомпоновщикНастроекДанныхОтчета.ПользовательскиеНастройки);
	Отчет.КомпоновщикНастроек.ЗагрузитьФиксированныеНастройки(КомпоновщикНастроекДанныхОтчета.ФиксированныеНастройки);
	Отчет.СкомпоноватьРезультат(ТабДок);
	
	Возврат ТабДок;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗаполнитьСтруктуруЗначенийФО()
	СтруктураФО = Новый Структура;
	СтруктураФО.Вставить("НезависимыйСбыт", энргОбщегоНазначения.ЗначениеФункциональнойОпции("бестУчетНезависимыйСбыт"));
	СтруктураФО.Вставить("ИспользоватьТарифныеЗоны", энргОбщегоНазначения.ЗначениеФункциональнойОпции("бестИспользоватьТарифныеЗоны"));
	СтруктураФО.Вставить("ИспользоватьШкалыПриборовУчета", энргОбщегоНазначения.ЗначениеФункциональнойОпции("бестИспользоватьШкалыПриборовУчета"));
	СтруктураФО.Вставить("ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ", энргОбщегоНазначения.ЗначениеФункциональнойОпции("бестИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ"));
	СтруктураФО.Вставить("ИспользоватьДанныеДляРасчетаТепловойЭнергииТеплоносителяИХВСЮЛ", энргОбщегоНазначения.ЗначениеФункциональнойОпции("бестИспользоватьДанныеДляРасчетаТепловойЭнергииТеплоносителяИХВСЮЛ"));
	Возврат СтруктураФО;
КонецФункции

&НаКлиенте
Процедура НастроитьВидимостьЭлементов()

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВзаимодействиеСЭДО", "Видимость", Не НезависимыйСбыт);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаОтчетПоПД", "Видимость", ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДолевыеТУУслуга", "Видимость", Не ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СубабонентыГруппаКолонокВода", "Видимость", ИспользоватьДанныеДляРасчетаТепловойЭнергииТеплоносителяИХВСЮЛ);
	Если ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ Тогда
		ЗаголовокСтраницыТранзит = НСтр("ru = 'Транзит'");
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаДолевыеСхемыРасчетаТУ", "Заголовок", ЗаголовокСтраницыТранзит);
		ЗаголовокКнопкиДобавитьТранзит = НСтр("ru = 'Добавить транзитных потребителей'");
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СубабонентыУстановитьФормулуРасчета", "Заголовок", ЗаголовокКнопкиДобавитьТранзит);
	КонецЕсли;

КонецПроцедуры

