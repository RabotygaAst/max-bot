#Область ОбработчикиСобытийОповещения

// Процедура - Обработка выбора договора
//
// Параметры:
//  Результат				 - СправочникСсылка.энргДоговорыКонтрагентов 
//  ДополнительныеПараметры	 - Структура 
//
&НаКлиенте
Процедура ОбработкаВыбораДоговора(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекСтрока  			= Результат;
	
	Если ТекСтрока = Неопределено тогда
		Возврат;
	КонецЕсли;
	
	Если ТекСтрока.Ссылка = Договор тогда
		Возврат;
	КонецЕсли;
	Договор = ТекСтрока.Ссылка;
	УстановитьДоступностьКнопкиОбновитьДанные();
	ЗаполнитьДанныеДоговора();
	
КонецПроцедуры
 
// Процедура - Вызывается при завершении получения данных по объектам расчета и заполняет реквизиты формы
//
// Параметры:
//  Результат				 - Структура - Результат выполнения фонового задания
//  ДополнительныеПараметры	 - Структура 
//
&НаКлиенте
Процедура ПриЗавершенииПолученияДанныхПоОбъектамРасчета(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		ПоказатьПредупреждение( ,Результат.КраткоеПредставлениеОшибки);
		
		Возврат;
	КонецЕсли;
	
	ДанныеОбъектов = ПолучитьДанныеОбъектов(Результат, ДеревоДанныеПоТУ, ДеревоДанныеПоПУ, ДеревоДанныеПоИзмерительномуКомплексу);
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеОбъектов.ДанныеПоУмолчанию);
	
	ЗаполнитьТЧФормы(ДанныеОбъектов.МассивОбъектов, "ОбъектыРасчета");
	ЗаполнитьТЧФормы(ДанныеОбъектов.МассивТП, "ТочкиПоставки");
	
	СтрокаДерева = ДеревоДанныеПоТУ.ПолучитьЭлементы();
	ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, ДанныеОбъектов.ДеревоДанныеПоТУ.ПолучитьЭлементы());
	
	СтрокаДерева = ДеревоДанныеПоПУ.ПолучитьЭлементы();
	ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, ДанныеОбъектов.ДеревоДанныеПоПУ.ПолучитьЭлементы());
	
	СтрокаДерева = ДеревоДанныеПоИзмерительномуКомплексу.ПолучитьЭлементы();
	ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, ДанныеОбъектов.ДеревоДанныеПоИзмерительномуКомплексу.ПолучитьЭлементы());
	ПриЗавершенииПолученияДанныхПоОбъектамРасчетаПереопределяемый(Результат, ДополнительныеПараметры);
	
КонецПроцедуры

// Процедура - Вызывается при завершении формирования отчета по ПД и выводит табличный документ на форму
//
// Параметры:
//  Результат				 - Структура - Результат выполнения фонового задания
//  ДополнительныеПараметры	 - Структура 
//
&НаКлиенте
Процедура ПриЗавершенииФормированияОтчетаПоПД(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		ПоказатьПредупреждение(, Результат.КраткоеПредставлениеОшибки);
		
		Возврат;
	КонецЕсли;
	
	ДанныеОтчета = ПолучитьДанныеОтчета(Результат);
	
	ОтчетПоПД = ДанныеОтчета.Отчет;
	ОтчетПоПДДанныеРасшифровки = ДанныеОтчета.ОтчетДанныеРасшифровки;
	ОтчетПоПДКомпоновщикНастроек.ЗагрузитьНастройки(ДанныеОтчета.НастройкиКД);
	
	ИзменитьАктуальностьДанныхОтчетаПоПД(Истина);

КонецПроцедуры

