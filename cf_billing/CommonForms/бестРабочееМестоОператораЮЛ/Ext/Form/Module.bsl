&НаСервере
Процедура УстановитьОперации()
	
	//Договоры
	СоздатьКнопкуОперации("бестЗаключениеДоговоровСЮридическимиЛицами", НСтр("ru = 'Регистрация характеристик договора'"), Элементы.ДокументыДоговораШапкаОперацииДоговоры, Истина);
	
	//Услуги
	СоздатьКнопкуОперации("бестОперацияСУслугамиНП", НСтр("ru = 'Подключение/отключение услуг'"), Элементы.ДокументыДоговораШапкаОперацииУслуги, Истина);
	СоздатьКнопкуОперации("бестСменаПоставщикаНП", НСтр("ru = 'Изменение поставщика услуг'"), Элементы.ДокументыДоговораШапкаОперацииУслуги);
	
	//Приборы
	СоздатьКнопкуОперации("бестОперацияСПриборомУчетаНП", НСтр("ru = 'Акт ввода/ вывода/ замены ПУ'"), Элементы.ДокументыДоговораШапкаОперацииПУ, Истина);
	СоздатьКнопкуОперации("бестУстановитьДатуПоверкиПУ", НСтр("ru = 'Изменение даты поверки приборов учета'"), Элементы.ДокументыДоговораШапкаОперацииПУ);
	СоздатьКнопкуОперации("бестИзменитьНомерПломбыПрибораУчета", НСтр("ru = 'Операция с пломбами'"), Элементы.ДокументыДоговораШапкаОперацииПУ);	
		
	//Показания
	СоздатьКнопкуОперации("бестРегистрацияПоказанийНП", НСтр("ru = 'Регистрация показаний'"), Элементы.ДокументыДоговораШапкаОперацииПоказания, Истина);
	СоздатьКнопкуОперации("бестРегистрацияПоказанийНПОбщий", НСтр("ru = 'Регистрация показаний (массовый ввод)'"), Элементы.ДокументыДоговораШапкаОперацииПоказания);
	
	Если ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ Тогда
		
		//Договоры
		СоздатьКнопкуОперации("энргОперацияСТочкамиПоставки", НСтр("ru = 'Операция с точками поставки'"), Элементы.ДокументыДоговораШапкаОперацииДоговоры);
		СоздатьКнопкуОперации("бестУстановитьТочкиПоставкиНаОбъектРасчета", НСтр("ru = 'Установить точки поставки на объект расчета'"), Элементы.ДокументыДоговораШапкаОперацииДоговоры);
		
		//Услуги
		СоздатьКнопкуОперации("бестИзменитьПараметрыТочкиУчета", НСтр("ru = 'Изменение параметров точки учета'"), Элементы.ДокументыДоговораШапкаОперацииУслуги);
		
		//Показания
		СоздатьКнопкуОперации("бестПочасоваяВедомость", НСтр("ru = 'Почасовая ведомость'"), Элементы.ДокументыДоговораШапкаОперацииПоказания);
		СоздатьКнопкуОперации("ОбработкабестЗагрузитьДанныеИзВнешнихИсточников", НСтр("ru = 'Загрузить данные из внешних источников'"), Элементы.ДокументыДоговораШапкаОперацииПоказания);
		СоздатьКнопкуОперации("ОбработкабестВыгрузкаИнтервальныхДанныхExcel", НСтр("ru = 'Выгрузка данных почасовых ведомостей'"), Элементы.ДокументыДоговораШапкаОперацииПоказания);
		
		//Оплата
		СоздатьКнопкуОперации("ОбработкабестФормированиеПлатежныхДокументов", НСтр("ru = 'Формирование платежных документов'"), Элементы.ДокументыДоговораШапкаОперацииОплата, Истина);
		СоздатьКнопкуОперации("бестПлатежныйДокумент", НСтр("ru = 'Платежный документ'"), Элементы.ДокументыДоговораШапкаОперацииОплата);
		СоздатьКнопкуОперации("бестПлатежноеПоручениеВходящееЭЭЮрЛица", НСтр("ru = 'Платежное поручение (входящие) ЭЭ'"), Элементы.ДокументыДоговораШапкаОперацииОплата);
		СоздатьКнопкуОперации("бестСчетФактураНаАванс", НСтр("ru = 'Счет-фактура на аванс'"), Элементы.ДокументыДоговораШапкаОперацииОплата);
		СоздатьКнопкуОперации("бестКорректировкаЗадолженности", НСтр("ru = 'Корректировка оплат'"), Элементы.ДокументыДоговораШапкаОперацииОплата);
		
		//Начисления
		СоздатьКнопкуОперации("бестПерерасчетЭЭ", НСтр("ru = 'Перерасчет ЭЭ'"), Элементы.ДокументыДоговораШапкаОперацииНачисления);
		СоздатьКнопкуОперации("ОбработкабестРасчетПоЦеновымКатегориям", НСтр("ru = 'Расчет по ценовым категориям'"), Элементы.ДокументыДоговораШапкаОперацииНачисления); 
		
	КонецЕсли;
	
	Если Не ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ Или ИспользоватьДанныеДляРасчетаТепловойЭнергииТеплоносителяИХВСЮЛ Тогда
		
		//Оплата
		СоздатьКнопкуОперации("бестПлатежноеПоручениеВходящееЮрЛица", НСтр("ru = 'Платежное поручение (входящие)'"), Элементы.ДокументыДоговораШапкаОперацииОплата);
		
		//Начисления
		СоздатьКнопкуОперации("бестПерерасчетНП", НСтр("ru = 'Перерасчет'"), Элементы.ДокументыДоговораШапкаОперацииНачисления);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьКнопкуОперации(ИмяОперации, Заголовок, Родитель, ЭтоВажное = Ложь) 
	
    Команда	= Команды.Добавить(ИмяОперации);
    Команда.Действие = "ВыполнитьОперацию";

    Кнопка = Элементы.Добавить(ИмяОперации, Тип("КнопкаФормы"), Родитель);
    Кнопка.Заголовок	= Заголовок;
    Кнопка.ИмяКоманды	= ИмяОперации;
	
	Если ЭтоВажное Тогда 
		Кнопка.ЦветФона = Новый Цвет(250,204,31);
		ЖирныйШрифт = Новый Шрифт(,,Истина);
		Кнопка.Шрифт = ЖирныйШрифт;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОперацию(Команда)
	ИмяКоманды = Команда.Имя;
	СтрокаОбработка = "Обработка";
	СтрокаОперацияСТП = "энргОперацияСТочкамиПоставки";
	Если СтрНайти(ИмяКоманды, СтрокаОбработка) Тогда
		ИмяКоманды = СтрЗаменить(ИмяКоманды, СтрокаОбработка, "");
		ОткрытьФормуОбработки(ИмяКоманды);
	ИначеЕсли СтрНайти(ИмяКоманды, СтрокаОперацияСТП) Тогда
		МассивТП = МассивТП();
		ДопЗначенияЗаполнения = Новый Структура("МассивТП", МассивТП);
		ЗначенияЗаполнения = Новый Структура("ДопЗначенияЗаполнения", ДопЗначенияЗаполнения);
		ПараметрыФормы = Новый Структура("ЗаполнитьДокумент, ЗначенияЗаполнения", Истина, ЗначенияЗаполнения);
		ИмяФормыДокумента = СтрШаблон("Документ.%1.ФормаОбъекта", ИмяКоманды);
		ОткрытьФорму(ИмяФормыДокумента, ПараметрыФормы);
	Иначе
		ОткрытьФормуНовогоДокумента(ИмяКоманды, Неопределено);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуОбработки(ИмяОбработки)

	КлючиПараметров = "Организация, Район, Договор, ТочкаУчета";
	ПараметрыФормы = Новый Структура(КлючиПараметров);
	ЗаполнитьЗначенияСвойств(ПараметрыФормы, ЭтотОбъект, КлючиПараметров);
	ИмяФормыДокумента = СтрШаблон("Обработка.%1.Форма", ИмяОбработки);
	ОткрытьФорму(ИмяФормыДокумента, ПараметрыФормы);

КонецПроцедуры

