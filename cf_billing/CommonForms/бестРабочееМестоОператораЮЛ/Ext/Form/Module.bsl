&НаСервереБезКонтекста
Функция ЗапуститьФоновоеЗаданиеПолученияДанныхПоОбъектамРасчета(УникальныйИдентификатор, ПоляДоговора, Знач ОбъектыРасчетаОригинал, Знач ТочкиПоставкиОригинал)
	ДеревоДанныеПоТУ = НовоеДеревоТочекУчета();
	ДеревоДанныеПоПУ = НовоеДеревоПриборовУчета();
	ДеревоДанныеПоИзмерительномуКомплексу = НовоеДеревоИзмерительныйКомплекс();
	ОбъектыРасчета			= ОбъектыРасчетаОригинал.Выгрузить();
	ТочкиПоставки			= ТочкиПоставкиОригинал.Выгрузить();
		
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0; // запускать сразу
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Получение данных объектов расчета для рабочего стола'");
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения, 
		"бестРаботаСРабочимМестомОператораЮЛ.ЗаполнитьДанныеОбъектовРасчета",
		ПоляДоговора,
		ДеревоДанныеПоТУ,
		ДеревоДанныеПоПУ,
		ДеревоДанныеПоИзмерительномуКомплексу, 
		ОбъектыРасчета, 
		ТочкиПоставки);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

&НаСервереБезКонтекста
