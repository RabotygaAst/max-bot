&НаКлиенте
Процедура ИзменитьАктуальностьДанныхОтчетаПоПД(ДанныеАктуальны)
	
	Элементы.ОтчетПоПД.ОтображениеСостояния.Видимость = Не ДанныеАктуальны;
	Если ДанныеАктуальны Тогда
		Элементы.ОтчетПоПД.ОтображениеСостояния.ДополнительныйРежимОтображения = ДополнительныйРежимОтображения.НеИспользовать;
	Иначе
		Элементы.ОтчетПоПД.ОтображениеСостояния.ДополнительныйРежимОтображения = ДополнительныйРежимОтображения.Неактуальность;
		Элементы.ОтчетПоПД.ОтображениеСостояния.Текст = НСтр("ru = 'Изменились настройки. Нажмите ""Сформировать"" для получения отчета.'");
	КонецЕсли;

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура НайтиИндексыНастроек(ЭтотОбъект)

	ПКДОбъектРасчета = Новый ПолеКомпоновкиДанных("ОбъектРасчета");
	
	ОтборыКД = ЭтотОбъект.ДокументыДоговораНастройкиКД.Отбор.Элементы;
	
	ИдентификаторПользовательскойНастройкиОбъектаРасчета = "";
	
	Для Каждого ЭлементОтбора Из ОтборыКД Цикл
		Если ЭлементОтбора.ЛевоеЗначение = ПКДОбъектРасчета Тогда
			ИдентификаторПользовательскойНастройкиОбъектаРасчета = ЭлементОтбора.ИдентификаторПользовательскойНастройки;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ПользовательскиеНастройки = ЭтотОбъект.ДокументыДоговора.КомпоновщикНастроек.ПользовательскиеНастройки;
	
	ЭлементПользовательскихНастроекКДОбъектРасчета = ПользовательскиеНастройки.Элементы.Найти(ИдентификаторПользовательскойНастройкиОбъектаРасчета);
	ЭтотОбъект.ДокументыДоговораИндексНастройкиОбъектаРасчета = ПользовательскиеНастройки.Элементы.Индекс(ЭлементПользовательскихНастроекКДОбъектРасчета);
	УстановитьОтборОбъектаРасчетаПоДоговору(ЭтотОбъект);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборОбъектаРасчетаПоДоговору(ЭтотОбъект)

	ПользовательскиеНастройки = ЭтотОбъект.ДокументыДоговора.КомпоновщикНастроек.ПользовательскиеНастройки;
	НастройкаОбъектРасчета = ПользовательскиеНастройки.Элементы.Получить(ЭтотОбъект.ДокументыДоговораИндексНастройкиОбъектаРасчета);
	
	СтруктураДоговор = энргОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭтотОбъект.Договор, "Организация, Район");
	ПарамерПериод = Новый ПараметрВыбора("Период", ТекДата());
	ПараметрОрганизация = Новый ПараметрВыбора("Организация", ЭтотОбъект.Организация);
	ПараметрРайон = Новый ПараметрВыбора("Район", ЭтотОбъект.Район);
	ПараметрДоговор = Новый ПараметрВыбора("Договор", ЭтотОбъект.Договор);
	
	НовыйМассив = Новый Массив();
	НовыйМассив.Добавить(ПарамерПериод);
	НовыйМассив.Добавить(ПараметрОрганизация);
	НовыйМассив.Добавить(ПараметрРайон);
	НовыйМассив.Добавить(ПараметрДоговор);
	
	НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
	
	ИмяЭлементаОбъектРасчета = СтрШаблон("КомпоновщикНастроекПользовательскиеНастройкиЭлемент%1Значение", ЭтотОбъект.ДокументыДоговораИндексНастройкиОбъектаРасчета);
	ЭлементФормыОбъектРасчета = ЭтотОбъект.Элементы[ИмяЭлементаОбъектРасчета];
	ЭлементФормыОбъектРасчета.ПараметрыВыбора = НовыеПараметры;

КонецПроцедуры

