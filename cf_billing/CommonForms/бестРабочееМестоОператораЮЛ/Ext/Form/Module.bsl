&НаКлиенте
Процедура ОткрытьЗначениеСсылкиВДереве(ИмяТаблицыФормы, ИмяПоля)

	ИмяКлючаТаблицы = СтрШаблон("%1Ключ", ИмяТаблицыФормы);
	ИмяЗначенияТаблицы = СтрШаблон("%1Значение", ИмяТаблицыФормы);
	ТекущиеДанные = Элементы[ИмяТаблицыФормы].ТекущиеДанные;
	Если ИмяПоля = ИмяКлючаТаблицы И ЭтоЗначениеСсылочногоТипа(ТекущиеДанные.Ключ) Тогда
		 ПоказатьЗначение(, ТекущиеДанные.Ключ);
	КонецЕсли;
	Если ИмяПоля = ИмяЗначенияТаблицы И ЭтоЗначениеСсылочногоТипа(ТекущиеДанные.Значение) Тогда
		 ПоказатьЗначение(, ТекущиеДанные.Значение);
	КонецЕсли;

КонецПроцедуры

