	ТекПарам		= Новый Структура();
	
	ЗаписатьНовыеПлощадиНаСервере(ТекАбонент, ТекПарам);
	
	ОткрытьФорму("Документ.энргУстановитьЗначениеПлощади.Форма.ФормаДокумента", ТекПарам);
