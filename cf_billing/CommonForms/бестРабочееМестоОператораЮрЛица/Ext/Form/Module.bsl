&НаСервере
Процедура ЗаполнитьДанныеАбонентаСервер(Абонент,Лицевойсчет)
	
	Район 									= Абонент.Район;
	ДанныеЗаполнения  						= Новый Структура("ДанныеАбонента,КоличествоКомнат,КоличествоПрописанных, КоличествоПроживающих, КоличествоСобственников,ТипПлиты,ГруппаПотребителей,ВидБлагоустройства,ЗначенияПлощадей,ТочкиПриборы,ДанныеСостоянияЛС,ДанныеКонтроллера, ОтключатьВНеполивнойСезон, Этажность");
	ДанныеЗаполнения.ДанныеАбонента  		= Новый Структура("Район,АдресОбъекта,АдресОбъектаЗначенияПолей,ВидОбъекта,МКД,ГруппаАбонента, ОтключатьВНеполивнойСезон, ОснованиеСобственности");
	энргРаботаСЛицевымСчетомСервер.ПараметрыРасчетаАбонента(Организация, Район, Абонент,ТекущаяДата(),ДанныеЗаполнения);
			
	ДанныеАбонента  						= ДанныеЗаполнения.ДанныеАбонента;
	ЭтаФорма.Район		 					= ДанныеАбонента.Район;
	ЭтаФорма.ЛицевойСчет 					= Лицевойсчет;
	ЭтаФорма.АдресОбъекта 					= ДанныеАбонента.АдресОбъекта;
	ЭтаФорма.ВидОбъекта 					= ДанныеАбонента.ВидОбъекта;
	ЭтаФорма.МКД						 	= ДанныеАбонента.МКД;
	ЭтаФорма.ОснованиеСобственности			= ?(ЗначениеЗаполнено(ДанныеЗаполнения.ДанныеАбонента.ОснованиеСобственности.Серия) или ЗначениеЗаполнено(ДанныеЗаполнения.ДанныеАбонента.ОснованиеСобственности.Номер), ДанныеЗаполнения.ДанныеАбонента.ОснованиеСобственности.Серия + " № " + ДанныеЗаполнения.ДанныеАбонента.ОснованиеСобственности.Номер + " от " + Формат(ДанныеЗаполнения.ДанныеАбонента.ОснованиеСобственности.ДатаВыдачи, "ДФ=dd.MM.yyyy"), "");
	ЭтаФорма.КоличествоКомнат				= ДанныеЗаполнения.КоличествоКомнат;
	ЭтаФорма.КоличествоПрописанных			= ДанныеЗаполнения.КоличествоПрописанных;
	ЭтаФорма.КоличествоПроживающих			= ДанныеЗаполнения.КоличествоПроживающих;
	ЭтаФорма.КоличествоСобственников		= ДанныеЗаполнения.КоличествоСобственников;
	ЭтаФорма.ТипПлиты						= ДанныеЗаполнения.ТипПлиты;
	ЭтаФорма.ТарифнаяГруппа					= ДанныеЗаполнения.ГруппаПотребителей;
	ЭтаФорма.ВидБлагоустройства				= ДанныеЗаполнения.ВидБлагоустройства;
	ЭтаФорма.СостояниеЛС					= ДанныеЗаполнения.ДанныеСостоянияЛС.СостояниеЛС;
	ЭтаФорма.ДатаСостоянияЛС				= ДанныеЗаполнения.ДанныеСостоянияЛС.ДатаСостоянияЛС;
	ЭтаФорма.Контроллер						= ДанныеЗаполнения.ДанныеКонтроллера.Контроллер;
	ЭтаФорма.Маршрут						= ДанныеЗаполнения.ДанныеКонтроллера.Маршрут;
	ЭтаФорма.ОтключатьВНеполивнойСезон		= ДанныеЗаполнения.ОтключатьВНеполивнойСезон;
	
	ЗначенияПлощадей.Очистить();
	
	Для Каждого КлючЗначение из  ДанныеЗаполнения.ЗначенияПлощадей цикл
		СтрокаПлощади 						= ЗначенияПлощадей.Добавить();
		СтрокаПлощади.ВидПлощади 			= КлючЗначение.ключ;
		СтрокаПлощади.Значение 				= КлючЗначение.Значение;
	КонецЦикла;   	
	
	ПараметрыНорматива  					= Справочники.энргКлючиНормативов.ПараметрыНорматива(ДанныеЗаполнения);
		
	РезультатПриборы 						= энргРаботаСприборамиУчетаСервер.ДанныеПриборовУчета(Неопределено,Организация,Район,Абонент,ДанныеЗаполнения.ГруппаПотребителей,ПараметрыНорматива);
	//ВыборкаПриборы  						= РезультатПриборы.выбрать();
	//ТочкиУчета.Очистить();
	//
	//Пока ВыборкаПриборы.следующий() цикл
	//	СтрокаТЧ 							= ТочкиУчета.Добавить();
	//	ЗаполнитьЗначенияСвойств(СтрокаТЧ,ВыборкаПриборы);
	//КонецЦикла;  	
	
	ШкалыПриборовУчета.Очистить();
	ПоказанияПриборовУчета.Очистить();
	ТочкиУчета.Очистить();
	
	Выборка  									= РезультатПриборы.выбрать();
	ТекТочкаУчета 								= Неопределено;
	ТекШкала 									= Неопределено;
	IDСтрокиТочки 								= Неопределено;
	IDСтрокиШкалы 								= Неопределено;
	Пока Выборка.следующий() цикл 
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= ТочкиУчета.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТочкиУчета,Выборка);
			IDСтрокиТочки 						= Новый УникальныйИдентификатор;
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.Шкала) И (НоваяТочка Или НЕ ТекШкала = Выборка.Шкала) Тогда
			СтрокаШкалы  						= ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			ЗаполнитьЗначенияСвойств(СтрокаШкалы,Выборка);
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ТарифнаяЗона) Тогда
			СтрокаПоказаний 						= ПоказанияПриборовУчета.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаПоказаний,Выборка);
			СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		КонецЕсли;

		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекШкала 								= Выборка.Шкала;
	КонецЦикла; 
	
	Если ИспользоватьТарифныеЗоны и ИспользоватьШкалыПриборовУчета Тогда
		
		
	ИначеЕсли ИспользоватьТарифныеЗоны Тогда
		
		Для Каждого СтрокаТочки Из ТочкиУчета Цикл
			СтрокиШкал							= ШкалыПриборовУчета.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", СтрокаТочки.IDСтроки));
			Если СтрокиШкал.Количество()  = 0 Тогда
				Продолжить;
			КонецЕсли;				  
			СтрокаШкал							= СтрокиШкал[0];
			СтрокаТочки.IDСтрокиШкалы			= СтрокаШкал.IDСтроки;
			СтрокаТочки.ВидДифференцированности	= СтрокаШкал.ВидДифференцированности;			
		КонецЦикла;	
		
	КонецЕсли;
	
	ПериодНачисления  						= Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ТекущаяДата(), Организация, Район);
	Задолженность.Очистить();
	РезультатВзаиморасчеты 					= энргРаботаСТочкамиУчетаСервер.ДанныеДляОплатыАбонента(ТекущаяДата(),Организация,ПериодНачисления,ДанныеАбонента.Район,ДанныеАбонента.МКД,Абонент);
	Выборка									= РезультатВзаиморасчеты.выбрать();
	
	Пока Выборка.следующий() цикл
		Если Выборка.Задолженность <> 0 тогда
			СтрокаУслуги  					= Задолженность.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаУслуги,Выборка); 
		КонецЕсли;
	КонецЦикла; 
		
КонецПроцедуры

