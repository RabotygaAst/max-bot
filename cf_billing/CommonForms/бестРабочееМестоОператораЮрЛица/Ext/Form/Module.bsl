#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	Организация = энргОрганизацииСервер.ОрганизацияПоУмолчанию();

	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	отборЭтоГруппа 					=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	отборЭтоГруппа.ЛевоеЗначение 	= Новый ПолеКомпоновкиДанных("ЭтоГруппа");
	отборЭтоГруппа.ПравоеЗначение 	= Ложь;
	отборЭтоГруппа.ВидСравнения 	= ВидСравненияКомпоновкиДанных.Равно; 	
КонецПроцедуры   

&НаКлиенте
Процедура СтраницыОтчетаПриСменеСтраницы(Элемент, ТекущаяСтраница)
	Если ТекущаяСтраница = Элементы.СтраницыОтчета.ПодчиненныеЭлементы.СтраницаКарточкаАбонента тогда
		Если ТекАбонент <> АбонентКарточка тогда
			ПериодФормированияНачало  					= ДобавитьМесяц(НачалоГода(ТекущаяДата()),-36);
			ПериодФормированияКонец 					= КонецГода(ТекущаяДата());	
			
			ПериодФормированияКарточки.ДатаНачала 		= ПериодФормированияНачало;
			ПериодФормированияКарточки.ДатаОкончания 	= ПериодФормированияКонец;
			
			ОбновитьКарточкуКлиент(ПериодФормированияНачало,ПериодФормированияКонец);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовШапки

&НаКлиенте
Процедура ФИОИзменениеТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)
	СтандартнаяОбработка 				= Ложь;
	Если Не ЗначениеЗаполнено(Текст) и НЕ ЗначениеЗаполнено(Адрес) тогда
		Абоненты.Отбор.Элементы.Очистить();
	ИначеЕсли ЗначениеЗаполнено(Текст) и ЗначениеЗаполнено(Адрес) Тогда
		Абоненты.Отбор.Элементы.Очистить();
		УстановитьОтборВСпискеАбонентов(Текст,Адрес, Контрагент);
	Иначе
		Абоненты.Отбор.Элементы.Очистить();
		УстановитьОтборВСпискеАбонентов(Текст,Адрес);
	КонецЕсли; 	 		
КонецПроцедуры

&НаКлиенте
Процедура АдресИзменениеТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)
	СтандартнаяОбработка 				= Ложь;
	Если Не ЗначениеЗаполнено(ФИО) и НЕ ЗначениеЗаполнено(Текст) тогда
		Абоненты.Отбор.Элементы.Очистить();
	ИначеЕсли ЗначениеЗаполнено(ФИО) и ЗначениеЗаполнено(Текст) Тогда
		Абоненты.Отбор.Элементы.Очистить();
		УстановитьОтборВСпискеАбонентов(ФИО,Текст);
	Иначе
		Абоненты.Отбор.Элементы.Очистить();
		УстановитьОтборВСпискеАбонентов(ФИО,Текст);
	КонецЕсли; 	
КонецПроцедуры    

