&НаКлиенте
Процедура ОбновитьКарточкуКлиент(ПериодФормированияНачало,ПериодФормированияКонец) 

	//ОбщегоНазначенияКлиентСервер.УстановитьСостояниеПоляТабличногоДокумента(Элементы.РезультатОтчетаКарточка,"ФОРМИРОВАНИЕОТЧЕТА");

	//Если не ОбновитьКарточкуСервер(ПериодФормированияНачало,ПериодФормированияКонец,ТекАбонент) тогда
	//	ПодключитьОбработчикОжидания("Подключаемый_ПроверитьВыполнениеЗадания",2,Истина);
	//КонецЕсли;
	//
	
	ОбновитьКарточкуСервер(ПериодФормированияНачало,ПериодФормированияКонец,ТекАбонент);
	ПодключитьОбработчикОжидания("Подключаемый_ПроверитьВыполнениеЗадания",1,Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПроверитьВыполнениеЗадания()  
	
	ПараметрыОбработчикаОжидания = Новый Структура("ТекущийИнтервал,КоэффициентУвеличенияИнтервала,МаксимальныйИнтервал",2,1,10);
	
	Попытка
		Если ЗаданиеВыполнено(ИдентификаторЗадания) Тогда
			РезультатОтчетаКарточка 		= ПолучитьИзВременногоХранилища(АдресХранилища);
			ОтображениеСостояния 			= Элементы.РезультатОтчетаКарточка.ОтображениеСостояния;
			ОтображениеСостояния.Видимость 	= Ложь;
			ОтображениеСостояния.ДополнительныйРежимОтображения = ДополнительныйРежимОтображения.НеИспользовать; 
			АбонентКарточка 				= ТекАбонент;
		Иначе
			ДлительныеОперацииКлиент.ОбновитьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания);
			ПодключитьОбработчикОжидания(
				"Подключаемый_ПроверитьВыполнениеЗадания", 
				ПараметрыОбработчикаОжидания.ТекущийИнтервал, 
				Истина);
		КонецЕсли;
	Исключение
		ВызватьИсключение;
	КонецПопытки;	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборВСпискеАбонентов(ФИО,АдресАбонента, ТекКонтрагент=Неопределено)
		
	Абоненты.Отбор.Элементы.Очистить();
	
	отборЭтоГруппа 								=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	отборЭтоГруппа.ЛевоеЗначение 				= Новый ПолеКомпоновкиДанных("ЭтоГруппа");
	отборЭтоГруппа.ПравоеЗначение 				= Ложь;
	отборЭтоГруппа.ВидСравнения 				= ВидСравненияКомпоновкиДанных.Равно;
	
	Если ЗначениеЗаполнено(ФИО) тогда
		ЭтоЛС 									= СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Лев(ФИО,3),Истина,Истина); 
		Если ЭтоЛС тогда
			
			ОтборГруппа  						= Абоненты.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
			ОтборГруппа.ТипГруппы 				= ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
			
			ОтборЛС  							= ОтборГруппа.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборЛС.ЛевоеЗначение 				= Новый ПолеКомпоновкиДанных("ЛицевойСчет");
			ОтборЛС.ПравоеЗначение 				= ФИО;
			ОтборЛС.ВидСравнения 				= ВидСравненияКомпоновкиДанных.Содержит;		
			
			ОтборстарыйЛС  						= ОтборГруппа.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборстарыйЛС.ЛевоеЗначение 		= Новый ПолеКомпоновкиДанных("СтарыйЛС");
			ОтборстарыйЛС.ПравоеЗначение 		= ФИО;
			ОтборстарыйЛС.ВидСравнения 			= ВидСравненияКомпоновкиДанных.Содержит; 		
		иначе
			ОтборНаименование 					=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборНаименование.ЛевоеЗначение 	= Новый ПолеКомпоновкиДанных("Наименование");
			ОтборНаименование.ПравоеЗначение	= ФИО;
			ОтборНаименование.ВидСравнения 		= ВидСравненияКомпоновкиДанных.Содержит;
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(АдресАбонента) тогда
		
		МассивПодСтрок 							= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(АдресАбонента," ");
		
		ОтборАдрес 								=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборАдрес.ЛевоеЗначение 				= Новый ПолеКомпоновкиДанных("КонтактнаяИнформация.Тип");
		ОтборАдрес.ПравоеЗначение				= ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес");
		ОтборАдрес.ВидСравнения 				= ВидСравненияКомпоновкиДанных.Равно;
		
		ОтборАдрес 								=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборАдрес.ЛевоеЗначение 				= Новый ПолеКомпоновкиДанных("КонтактнаяИнформация.Вид");
		ОтборАдрес.ПравоеЗначение				= ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресОбъекта");
		ОтборАдрес.ВидСравнения 				= ВидСравненияКомпоновкиДанных.Равно;
		
		для Каждого подстрока из МассивПодСтрок цикл
			ОтборАдрес 							=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборАдрес.ЛевоеЗначение 			= Новый ПолеКомпоновкиДанных("КонтактнаяИнформация.Представление");
			ОтборАдрес.ПравоеЗначение			= подстрока;
			ОтборАдрес.ВидСравнения 			= ВидСравненияКомпоновкиДанных.Содержит;
		КонецЦикла;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекКонтрагент) тогда
		
		ОтборАдрес 								=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборАдрес.ЛевоеЗначение 				= Новый ПолеКомпоновкиДанных("ФизЛицо");
		ОтборАдрес.ПравоеЗначение				= ТекКонтрагент;
		ОтборАдрес.ВидСравнения 				= ВидСравненияКомпоновкиДанных.Равно;
		
	КонецЕсли;
	
КонецПроцедуры

