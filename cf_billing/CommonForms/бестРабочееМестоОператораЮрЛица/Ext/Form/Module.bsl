&НаКлиенте
Процедура ОткрытьДокументОткрытияЛС(Команда)
	ДокОткрытия = ПолучитьДокументОткрытияЛССервер(ТекАбонент);
	ПараметрыФормы = Новый Структура("Ключ", ДокОткрытия);
	ОткрытьФорму("Документ.энргОперацияСЛицевымСчетом.ФормаОбъекта", ПараметрыФормы,ЭтаФорма);	
КонецПроцедуры

&НаСервере
Функция ПолучитьДокументОткрытияЛССервер(Абонент)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	энргОперацияСЛицевымСчетом.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.энргОперацияСЛицевымСчетом КАК энргОперацияСЛицевымСчетом
	|ГДЕ
	|	энргОперацияСЛицевымСчетом.Проведен
	|	И энргОперацияСЛицевымСчетом.Абонент = &Абонент
	|	И энргОперацияСЛицевымСчетом.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС)";
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Возврат Документы.энргОперацияСЛицевымСчетом.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура КонтрагентОчистка(Элемент, СтандартнаяОбработка)
	Если не ЗначениеЗаполнено(Контрагент) тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Абоненты,"Ссылка",ПредопределенноеЗначение("Справочник.энргАбоненты.ПустаяСсылка"));
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	СтандартнаяОбработка 				= Ложь;
	Если Не ЗначениеЗаполнено(Контрагент) тогда
		Абоненты.Отбор.Элементы.Очистить();
	Иначе
		Абоненты.Отбор.Элементы.Очистить();
		УстановитьОтборВСпискеАбонентов("","",Контрагент);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаписатьНовыеПлощадиНаСервере(ТекАбонент, ТекПарам)

	ЗнчЗаполения = Новый Структура;
	ЗнчЗаполения.Вставить("Дата", ТекущаяДата());
	ЗнчЗаполения.Вставить("Организация", 	ТекАбонент.Организация);
	ЗнчЗаполения.Вставить("Район", 			ТекАбонент.Район);
	ЗнчЗаполения.Вставить("МКД", 			ТекАбонент.МКД);
	ЗнчЗаполения.Вставить("Абонент", 		ТекАбонент);
	ЗнчЗаполения.Вставить("ЛицевойСчет",	ТекАбонент.ЛицевойСчет);
	
	ТЗПлощади				= Новый Массив;
	Для каждого стр из ЗначенияПлощадей Цикл
		Если стр.ЗначениеИзменено и Не стр.Значение = стр.НовоеЗначение Тогда
			ТЗПлощади.Добавить(Новый Структура("ВидПлощади, Значение", стр.ВидПлощади, стр.НовоеЗначение));
		КонецЕсли;
	КонецЦикла;	
	ЗнчЗаполения.Вставить("Площади",	ТЗПлощади);
	
	ТекПарам.Вставить("ЗначенияЗаполнения", ЗнчЗаполения);
	 
КонецПроцедуры

&НаКлиенте
