&НаСервере
Процедура  ЗаполнитьПоказанияПУ(ТекДата, ТекАбонент, ТекПриборУчета)
	Запрос = Новый ЗАпрос;
	Запрос.УстановитьПараметр("Абонент",		ТекАбонент);
	Запрос.УстановитьПараметр("Дата", 			ТекДата);
	Запрос.УстановитьПараметр("ПриборУчета",	ТекПриборУчета);
	Текст = "ВЫБРАТЬ
	        |	ВложенныйЗапрос.Абонент КАК Абонент,
	        |	ВложенныйЗапрос.ЛицевойСчет КАК ЛицевойСчет,
	        |	энргСтроения.Город КАК Город,
	        |	ВложенныйЗапрос.Помещение КАК Квартира,
	        |	энргСтроения.Корпус КАК Корпус,
	        |	энргСтроения.Улица КАК Улица,
	        |	ВложенныйЗапрос.Район КАК Район,
	        |	ВложенныйЗапрос.ФизЛицо КАК ФизЛицо,
	        |	ВложенныйЗапрос.Организация КАК Организация,
	        |	ВложенныйЗапрос.СтарыйЛС КАК СтарыйЛС,
	        |	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	        |	ВложенныйЗапрос.Строение КАК Строение,
	        |	ВложенныйЗапрос.Помещение КАК Помещение,
	        |	энргПомещения.НомерДляСортировки КАК НомерДляСортировки
	        |ПОМЕСТИТЬ ВрТ0
	        |ИЗ
	        |	(ВЫБРАТЬ
	        |		энргАбоненты.Ссылка КАК Абонент,
	        |		энргАбоненты.ЛицевойСчет КАК ЛицевойСчет,
	        |		энргАбоненты.Организация КАК Организация,
	        |		энргАбоненты.Район КАК Район,
	        |		энргАбоненты.СтарыйЛС КАК СтарыйЛС,
	        |		энргАбоненты.КлючПомещения КАК КлючПомещения,
	        |		энргКлючиПомещений.Строение КАК Строение,
	        |		энргКлючиПомещений.Помещение КАК Помещение,
	        |		энргАбоненты.ФизЛицо КАК ФизЛицо
	        |	ИЗ
	        |		Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	        |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	        |			ПО (энргАбоненты.КлючПомещения = энргКлючиПомещений.Ссылка)
	        |	ГДЕ
	        |		1 = 1
	        |		И энргАбоненты.Ссылка = &Абонент
	        |	
	        |	СГРУППИРОВАТЬ ПО
	        |		энргКлючиПомещений.Строение,
	        |		энргКлючиПомещений.Помещение,
	        |		энргАбоненты.Ссылка,
	        |		энргАбоненты.ЛицевойСчет,
	        |		энргАбоненты.Организация,
	        |		энргАбоненты.Район,
	        |		энргАбоненты.СтарыйЛС,
	        |		энргАбоненты.КлючПомещения,
	        |		энргАбоненты.ФизЛицо) КАК ВложенныйЗапрос
	        |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения КАК энргСтроения
	        |		ПО ВложенныйЗапрос.Строение = энргСтроения.Ссылка
	        |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения КАК энргПомещения
	        |		ПО ВложенныйЗапрос.Помещение = энргПомещения.Ссылка
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ВложенныйЗапрос.Абонент,
	        |	ВложенныйЗапрос.ЛицевойСчет,
	        |	ВложенныйЗапрос.Район,
	        |	ВложенныйЗапрос.Организация,
	        |	ВложенныйЗапрос.СтарыйЛС,
	        |	ВложенныйЗапрос.КлючПомещения,
	        |	ВложенныйЗапрос.ФизЛицо,
	        |	энргСтроения.Город,
	        |	ВложенныйЗапрос.Помещение,
	        |	энргСтроения.Корпус,
	        |	энргСтроения.Улица,
	        |	ВложенныйЗапрос.Строение,
	        |	энргПомещения.НомерДляСортировки,
	        |	ВложенныйЗапрос.Помещение
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВрТ0.Абонент КАК Абонент,
	        |	ВрТ0.ЛицевойСчет КАК ЛицевойСчет,
	        |	ВрТ0.Город КАК Город,
	        |	ВрТ0.Квартира КАК Квартира,
	        |	ВрТ0.Корпус КАК Корпус,
	        |	ВрТ0.Улица КАК Улица,
	        |	ВрТ0.Район КАК Район,
	        |	ВрТ0.ФизЛицо КАК ФизЛицо,
	        |	ВрТ0.Организация КАК Организация,
	        |	ВрТ0.СтарыйЛС КАК СтарыйЛС,
	        |	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	        |	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета.Расположение КАК Расположение,
	        |	ВрТ0.КлючПомещения КАК КлючПомещения,
	        |	ВрТ0.Строение КАК Строение,
	        |	ВрТ0.Помещение КАК Помещение,
	        |	ВрТ0.НомерДляСортировки КАК НомерДляСортировки
	        |ПОМЕСТИТЬ ВрТ1
	        |ИЗ
	        |	ВрТ0 КАК ВрТ0
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(&Дата, ) КАК энргАктивностьТочекУчетаСрезПоследних
	        |		ПО ВрТ0.КлючПомещения = энргАктивностьТочекУчетаСрезПоследних.КлючПомещения
	        |			И ВрТ0.Организация = энргАктивностьТочекУчетаСрезПоследних.Организация
	        |			И ВрТ0.Район = энргАктивностьТочекУчетаСрезПоследних.Район
	        |			И (энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена))
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ВрТ0.Район,
	        |	ВрТ0.ФизЛицо,
	        |	ВрТ0.СтарыйЛС,
	        |	ВрТ0.Организация,
	        |	ВрТ0.Квартира,
	        |	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета,
	        |	ВрТ0.Абонент,
	        |	ВрТ0.Улица,
	        |	ВрТ0.Город,
	        |	ВрТ0.ЛицевойСчет,
	        |	ВрТ0.Корпус,
	        |	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета.Расположение,
	        |	ВрТ0.КлючПомещения,
	        |	ВрТ0.Строение,
	        |	ВрТ0.Помещение,
	        |	ВрТ0.НомерДляСортировки
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВрТ1.Абонент КАК Абонент,
	        |	ВрТ1.ЛицевойСчет КАК ЛицевойСчет,
	        |	ВрТ1.Город КАК Город,
	        |	ВрТ1.Квартира КАК Квартира,
	        |	ВрТ1.Корпус КАК Корпус,
	        |	ВрТ1.Улица КАК Улица,
	        |	ВрТ1.Район КАК Район,
	        |	ВрТ1.ФизЛицо КАК ФизЛицо,
	        |	ВрТ1.Организация КАК Организация,
