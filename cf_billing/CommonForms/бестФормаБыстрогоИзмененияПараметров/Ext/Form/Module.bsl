#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ВидОперации 				= Параметры.ВидОперации;
	ЗаголовокЗначения 			= Параметры.ЗаголовокЗначения;
	Абонент						= Параметры.Абонент;
	КлючПомещения				= Параметры.КлючПомещения;
	Район						= Параметры.Район;
	Организация					= Параметры.Организация;
	ПериодНачисления			= Параметры.ПериодНачисления;
	Дата						= Параметры.Дата;
	РавноКоличествуПроживающих	= Параметры.РавноКоличествуПроживающих;
	РавноКоличествуПрописанных	= Параметры.РавноКоличествуПрописанных;
	ТекПриборУчета				= Параметры.ПриборУчета;
	
	УправлениеВидимостьюРеквизитов(ВидОперации, ЗаголовокЗначения);
	
	Если Не ТекПриборУчета		= Неопределено Тогда
		ЗаполнитьПоказанияПУ(Дата, Абонент, ТекПриборУчета);	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФОрмыПоказания

&НаКлиенте
Процедура ПоказанияТекущееПоказаниеПриИзменении(Элемент)
	текСтрока = Элементы.Показания.ТекущиеДанные;
	ДопПараметры	= Новый Структура;
	//ДопПараметры.Вставить("ТекущийОбъект", 	Объект.Ссылка);
	ДопПараметры.Вставить("ТекстВопроса", "");	
	
	ПересчитатьСтрокуПриборовУчета(текСтрока,Дата,Ложь,ДопПараметры);	
	
	Если ЗначениеЗаполнено(ДопПараметры.ТекстВопроса) Тогда
		ДопПараметры.Вставить("ТекСтрока", 		ТекСтрока.ПолучитьИдентификатор());	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	Если ВидОперации = "энргУстановитьЗначениеПлощади" Тогда
		ДокументИзменениеПлощади();
	ИначеЕсли ВидОперации = "энргУстановитьКоличествоПроживающих" Тогда	
		ДокументИзменениеКоличестваПроживающих();
	ИначеЕсли ВидОперации = "энргУстановитьКоличествоПрописанных" Тогда
		ДокументИзменениеКоличестваПрописанных();
	ИначеЕсли ВидОперации = "энргУстановитьКоличествоСобственников" Тогда
		ДокументИзменениеКоличестваСобственников();
	ИначеЕсли ВидОперации = "энргУстановитьКоличествоКомнат" Тогда	
		ДокументИзменениеКоличестваКомнат();
	КонецЕсли;
	
	ЭтаФорма.Закрыть();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УправлениеВидимостьюРеквизитов(ВидОперации, Заголовок)
	Если ВидОперации = "энргУстановитьЗначениеПлощади" Тогда
		Элементы.ВидПлощади.Видимость 					= Истина;
		Элементы.РавноКоличествуПрописанных.Видимость	= Ложь;					
		Элементы.РавноКоличествуПроживающих.Видимость 	= Ложь;
		Элементы.ИсточникПоказаний.Видимость 			= Ложь;
		Элементы.Показания.Видимость 					= Ложь;
	КонецЕсли;
	Если ВидОперации = "энргУстановитьКоличествоКомнат" Тогда
		Элементы.РавноКоличествуПрописанных.Видимость	= Ложь;					
		Элементы.РавноКоличествуПроживающих.Видимость 	= Ложь;
		Элементы.ВидПлощади.Видимость 					= Ложь;
		Элементы.Показания.Видимость 					= Ложь;
		Элементы.ИсточникПоказаний.Видимость 			= Ложь;
	КонецЕсли;
	Если ВидОперации = "энргУстановитьКоличествоПроживающих" Тогда
		Элементы.ВидПлощади.Видимость 					= Ложь;
		Элементы.РавноКоличествуПрописанных.Видимость 	= Истина;					
		Элементы.РавноКоличествуПроживающих.Видимость 	= Ложь;
		Элементы.Показания.Видимость 					= Ложь;
		Элементы.ИсточникПоказаний.Видимость 			= Ложь;
	КонецЕсли;
	Если ВидОперации = "энргУстановитьКоличествоПрописанных" Тогда
		Элементы.ВидПлощади.Видимость 					= Ложь;
		Элементы.РавноКоличествуПроживающих.Видимость 	= Истина;
		Элементы.РавноКоличествуПрописанных.Видимость 	= Ложь;
		Элементы.Показания.Видимость 					= Ложь;
		Элементы.ИсточникПоказаний.Видимость 			= Ложь;
	КонецЕсли;	
	Если ВидОперации = "энргУстановитьКоличествоСобственников" Тогда
		Элементы.ВидПлощади.Видимость 					= Ложь;
		Элементы.РавноКоличествуПроживающих.Видимость 	= Ложь;
		Элементы.РавноКоличествуПрописанных.Видимость 	= Ложь;
		Элементы.Показания.Видимость 					= Ложь;
		Элементы.ИсточникПоказаний.Видимость 			= Ложь;
	КонецЕсли;	
	
	ЭтаФорма.Заголовок				= Заголовок;
	//Элементы.Значение.Заголовок 	= Заголовок;
КонецПроцедуры

&НаСервере
Процедура ДокументИзменениеПлощади()
	ТекДок	= Документы.энргУстановитьЗначениеПлощади.СоздатьДокумент();
	ТекДок.Дата 			= Дата;
	ТекДок.ПериодНачисления = ПериодНачисления;
	ТекДок.Абонент 			= Абонент;
	ТекДок.КлючПомещения	= КлючПомещения;
	ТекДок.Организация		= Организация;
	ТекДок.Район			= Район;
	
	НовСтрока				= ТекДок.Площади.Добавить();
	НовСтрока.ВидПлощади	= ВидПлощади;
	НовСтрока.Значение		= Значение;
	
	ТекДок.Записать(РежимЗаписиДокумента.Проведение);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По абоненту " + Строка(Абонент) + " с ЛС " + Абонент.ЛицевойСчет + " создан документ " + Строка(ТекДок.Ссылка));	
КонецПроцедуры

