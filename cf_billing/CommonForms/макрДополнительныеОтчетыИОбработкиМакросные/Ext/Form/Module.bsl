КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОбработку(Команда)
	
	ТекДанные	=  Элементы.Обработки.ТекущиеДанные;
	
	Если НЕ ТекДанные = Неопределено И ТипЗнч(ТекДанные.Ссылка) = Тип("СправочникСсылка.макрПечатныеФормы") Тогда
		//ОповеститьОВыборе(Обработки[Элементы.Обработки.ТекущаяСтрока].Ссылка);
		Если ЗначениеЗаполнено(ОбъектыНазначения) Тогда
			энргОбщегоНазначенияКлиент.ПечатьМакросовОбъекта(ОбъектыНазначения[0].Значение, Обработки[Элементы.Обработки.ТекущаяСтрока].Ссылка);
		КонецЕсли;	
	Иначе
		ВыполнитьОбработкуПоПараметрам();
	КонецЕсли;
	
КонецПроцедуры

