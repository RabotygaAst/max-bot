&НаКлиенте
Процедура ВыполнитьВсеОперации(Команда)
	ВыполняемыеОперации 						= Новый Структура;
	ПолучитьСписокОпераций(ВыполняемыеОперации);
	ДействияПередВыполнениемОперации(ВыполняемыеОперации, Неопределено, Истина);
	ПериодНачисленияТекущий 					= ПериодНачисления;
	
	Если Не ЗначениеЗаполнено(ПериодНачисленияПо) Тогда
		ПредставлениеТекущийПериодНачисления 	= энргОбщегоНазначенияКлиент.ПолучитьПредставлениеПериодаРегистрации(ПериодНачисленияТекущий);
		ЗапуститьВыполнениеОпераций(ВыполняемыеОперации);
		Возврат;
	КонецЕсли;  	
	
	ЕстьОшибки 									= Ложь;
	
	Пока ПериодНачисленияТекущий <= ПериодНачисленияПо Цикл		
		Если ЕстьОшибки Тогда
			Прервать;
		КонецЕсли;
		
		ПредставлениеТекущийПериодНачисления 	= энргОбщегоНазначенияКлиент.ПолучитьПредставлениеПериодаРегистрации(ПериодНачисленияТекущий);
		ЗапуститьВыполнениеОпераций(ВыполняемыеОперации);
		ПериодНачисленияТекущий 				= КонецМесяца(ПериодНачисленияТекущий) + 1;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьВсеОперацииПоНП(Команда)
	ВыполняемыеОперации 						= Новый Структура;
	ПолучитьСписокОпераций(ВыполняемыеОперации,,,Истина);
	ПериодНачисленияТекущий 					= ПериодНачисления;
	
	Если Не ЗначениеЗаполнено(ПериодНачисленияПо) Тогда
		ПредставлениеТекущийПериодНачисления 	= энргОбщегоНазначенияКлиент.ПолучитьПредставлениеПериодаРегистрации(ПериодНачисленияТекущий);
		ЗапуститьВыполнениеОпераций(ВыполняемыеОперации);
		Возврат;
	КонецЕсли;  	
	
	ЕстьОшибки 									= Ложь;
	
	Пока ПериодНачисленияТекущий <= ПериодНачисленияПо Цикл		
		Если ЕстьОшибки Тогда
			Прервать;
		КонецЕсли;
		
		ПредставлениеТекущийПериодНачисления 	= энргОбщегоНазначенияКлиент.ПолучитьПредставлениеПериодаРегистрации(ПериодНачисленияТекущий);
		ЗапуститьВыполнениеОпераций(ВыполняемыеОперации);
		ПериодНачисленияТекущий 				= КонецМесяца(ПериодНачисленияТекущий) + 1;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьРезультатВыполненияОпераций(Команда)
	
	Отборы = Новый Структура; 	
	ПараметрыПредзаполнения = Новый Структура;
	ПараметрыПредзаполнения.Вставить("ПериодНачисления", ПериодНачисления);
	ПараметрыПредзаполнения.Вставить("Организация", Организация);
	ПараметрыПредзаполнения.Вставить("Район", Район);
	Если ОтборПоДому Тогда
		
		Если ЗначениеЗаполнено(Дом) Тогда 
			ПараметрыПредзаполнения.Вставить("МКД", Дом);
		Иначе 
			ПараметрыПредзаполнения.Вставить("ЧастныйСектор", Истина);
		КонецЕсли;
		
	КонецЕсли;   	
	
	Отборы.Вставить("ПараметрыПредзаполнения", ПараметрыПредзаполнения);
	ОткрытьФорму(
		"Отчет.энргРезультатВыполненияОперацийНачислений.Форма.ФормаОтчета",
		Отборы,,,,,,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	
КонецПроцедуры



