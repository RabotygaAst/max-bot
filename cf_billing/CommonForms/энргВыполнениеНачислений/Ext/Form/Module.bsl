КонецПроцедуры

&НаКлиенте
Процедура ОтменитьЗакрытиеПериода(Команда)
	
	ИмяМодуля 						= "энргНачисления.ОтменитьЗакрытьПериода";
	
	ПараметрыОпераций = Новый Структура;
	ПараметрыОпераций.Вставить("Организация",		Организация);
	ПараметрыОпераций.Вставить("ПериодНачисления",	ПериодНачисления);
	ПараметрыОпераций.Вставить("Район",				Район);
	
	Если ОтборПоДому тогда
		ПараметрыОпераций.Вставить("МКД",Дом);
	КонецЕсли;		
	
	Если ВыполнятьВФоне тогда	
		
		МассивПараметров = Новый Массив;
		для Каждого стр из ПараметрыОпераций цикл
			МассивПараметров.Добавить(стр.значение);
		КонецЦикла;	
		IDЗадания 			= ВыполнитьФоновоеЗадание(ИмяМодуля,МассивПараметров,"");
	иначе
		СтрокаМодуля 		= ИмяМодуля + "(";
		Счетчик 			= 0;
		для Каждого стр из ПараметрыОпераций цикл
			СтрокаМодуля 	= СтрокаМодуля +?(Счетчик= 0,"",",")+ "ПараметрыОпераций." + стр.ключ;
			Счетчик = Счетчик+1;
		КонецЦикла;
		СтрокаМодуля 		= СтрокаМодуля + ")";
		Попытка
			Выполнить (СтрокаМодуля);
		Исключение 			
			ОписаниеОшибки  = ИнформацияОбОшибке();
			//СлужебныеСообщения.ДобавитьСтроку(ОписаниеОшибки.Описание);
		КонецПопытки;
		УстановитьДоступностьЭлементовФормы(Истина);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДругуюФорму(Команда)
	ОткрываемаяФорма  					= ПолучитьФорму("ОбщаяФорма.энргВыполнениеНачислений",,,Новый УникальныйИдентификатор);
	ОткрываемаяФорма.Организация  		= Организация;
	ОткрываемаяФорма.ПериодНачисления  	= ПериодНачисления;	
	ОткрываемаяФорма.ТекущийЭлемент  	= ОткрываемаяФорма.элементы.Район;
	ОткрываемаяФорма.открыть();
КонецПроцедуры

