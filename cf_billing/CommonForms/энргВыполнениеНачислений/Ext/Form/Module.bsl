&НаСервере
Процедура  ОтменитьФоновоеЗаданиеСервер()
	Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(IDЗадания);
	
	Если Задание = Неопределено тогда
		Возврат;
	КонецЕсли;
	
	СостояниеЗадания  		=  Задание.Состояние;
	
	Если СостояниеЗадания <> ПредопределенноеЗначение("СостояниеФоновогоЗадания.Активно") тогда
		Возврат;
	КонецЕсли;
	
	Задание.Отменить();
КонецПроцедуры

