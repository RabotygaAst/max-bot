	ЗаполнитьИменаМодулей();
	//ПериодНачисленияПо 					= НачалоМесяца(ТекущаяДата()); 	
	//ПредставлениеПериодаРегистрацииПо 	= энргОбщегоНазначенияКлиент.ПолучитьПредставлениеПериодаРегистрации(ПериодНачисленияПо);
		
	//Если НЕ ЗначениеЗаполнено(Район) Тогда
	//	ВыполнятьВФоне 							= истина;
	//КонецЕсли;
	СбрасыватьСостояниеПоследовательности 	= Истина;
	СтруктураОшибок 						= Новый Структура;
	ВыполнятьВФоне 							= Истина;
	
