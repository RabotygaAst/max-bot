#Область ФоновоеВыполнениеЗадачи

&НаКлиенте
Функция ЗапуститьФоновыеВыполнениеОпераций(ВыполняемыеОперации, ТекРайон = Неопределено)
	
	АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
	
	МассивРайнов	= ПолучитьМассивРайонов();
	
	ПараметрыОтборов = Новый Структура;
	ПараметрыОтборов.Вставить("Организация",			 	Организация);
	ПараметрыОтборов.Вставить("ПериодНачисления",		 	ПериодНачисленияТекущий);
	ПараметрыОтборов.Вставить("ПериодНачисленияТекущий", 	ПериодНачисленияТекущий);
	ПараметрыОтборов.Вставить("ТекРайон",				 	Неопределено);
	ПараметрыОтборов.Вставить("Район",					 	МассивРайнов[0]);
	ПараметрыОтборов.Вставить("Абонент",					Неопределено);
	ПараметрыОтборов.Вставить("ОтборПоДому",			 	ОтборПоДому);
	ПараметрыОтборов.Вставить("ИсключаяОтдельностоящие", 	ИсключаяОтдельностоящие);
	ПараметрыОтборов.Вставить("СбрасыватьСостояниеПоследовательности", СбрасыватьСостояниеПоследовательности);
	ПараметрыОтборов.Вставить("Договор", 					Договор);
	ПараметрыОтборов.Вставить("АдресРезультата", 			АдресРезультата);
	ПараметрыОтборов.Вставить("Дом", 						Дом);
	ПараметрыОтборов.Вставить("СписокМКД", 					Неопределено);
	ПараметрыОтборов.Вставить("СбрасыватьВзаиморасчеты",	СбрасыватьВзаиморасчеты);
	ПараметрыОтборов.Вставить("СбрасыватьПоказания",		СбрасыватьПоказания);
	ПараметрыОтборов.Вставить("МассивКлючейПомещений",		Неопределено);
	ПараметрыОтборов.Вставить("МассивАбонентов",			Неопределено);
	ПараметрыОтборов.Вставить("ФинальноеНачисление",		Ложь);
	
	МассивРайнов.Удалить(0);
	//Если ОтборПоДому Тогда 
	//	ПараметрыОтборов.Вставить("Дом", Дом);
	//КонецЕсли;
	
	ЗапуститьФоновоеЗаданиеКлиент(ПараметрыОтборов, ВыполняемыеОперации, МассивРайнов);
	
		
КонецФункции

&НаКлиенте
Функция ЗапуститьФоновоеЗаданиеКлиент(ПараметрыОтборов, ВыполняемыеОперации, МассивРайнов)
	
	ПредставлениеОперации = "Выполнение операций начислений по району " + ПараметрыОтборов.Район + " за " + Формат(ПериодНачисления, "ДФ='ММММ гггг'");	
	Если ОтборПоДому тогда
		ПредставлениеОперации = ПредставлениеОперации + " отбор по дому: " + ?(ЗначениеЗаполнено(ПараметрыОтборов.Дом), ПараметрыОтборов.Дом, "Частный сектор");
	КонецЕсли;
	
	ПредставлениеОперации	= ПредставлениеОперации + " (" + ПользователиКлиент.ТекущийПользователь() + ")";
	
	// 1. Запуск фонового задания на сервере.
	ДлительнаяОперация = ЗапуститьФоновоеЗаданиеСервер(ПараметрыОтборов, ВыполняемыеОперации, ИменаМодулей, ПредставлениеОперации);
	
	// 2. Подключение обработчика завершения фонового задания.
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;	
	ДополнительныеПараметры = Новый Структура("АдресРезультата,МассивРайнов,ВыполняемыеОперации,ПараметрыОтбора", ПараметрыОтборов.АдресРезультата, МассивРайнов, ВыполняемыеОперации, ПараметрыОтборов);
	Оповещение = Новый ОписаниеОповещения("ПриЗавершенииФоновогоЗадания", ЭтотОбъект, ДополнительныеПараметры);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);

КонецФункции


&НаКлиенте
Функция ПолучитьМассивРайонов()
	
	МассивРайонов = Новый Массив;
	
	МассивРайонов.Добавить(Район);

	Возврат МассивРайонов;

КонецФункции


&НаСервереБезКонтекста
Функция ЗапуститьФоновоеЗаданиеСервер(ПараметрыОтборов, ВыполняемыеОперации, ИменаМодулей, ПредставлениеОперации)
	
	ИмяМетода = "энргВыполнениеНачислений.энргВыполнитьНачисления";
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();	
	ПараметрыВыполнения.ОжидатьЗавершение = 0; // запускать сразу
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = ПредставлениеОперации;
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения, 
		ИмяМетода,
		ПараметрыОтборов,
		ВыполняемыеОперации,
		ИменаМодулей);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

&НаКлиенте
Процедура ПриЗавершенииФоновогоЗадания(РезультатВыполнения, ДополнительныеПараметры) Экспорт
	
	УстановитьДоступностьЭлементовФормы(Истина);
	
	ДанныеВХ = ПолучитьИзВременногоХранилища(ДополнительныеПараметры.АдресРезультата);
	УдалитьИзВременногоХранилища(ДополнительныеПараметры.АдресРезультата);
	
	Если ДанныеВХ = Неопределено Тогда
		Возврат;
	КонецЕсли; 	
	
	Для Каждого СтрокаРезультата из ДанныеВХ Цикл
		
		ЭлементКартинка = Элементы["Статус" + СтрокаРезультата.ЭлементОшибок];		
		ЭлементОшибок 	= Элементы["Ошибки" + СтрокаРезультата.ЭлементОшибок];
		
		Если НЕ СтрокаРезультата.ЕстьОшибки Тогда
			
			ЭлементКартинка.Картинка  	= БиблиотекаКартинок.Успешно32;
			ЭлементОшибок.Заголовок 	= "Нет Ошибок";
			ЭлементОшибок.Доступность 	= Ложь;
			
		Иначе 
			
			ЭлементОшибок.Заголовок 	= "Есть ошибки";
			ЭлементКартинка.Картинка  	= БиблиотекаКартинок.Ошибка32;
			ЭлементОшибок.Доступность 	= Истина;			
			СтруктураОшибок.Вставить(СтрокаРезультата.ЭлементОшибок, СтрокаРезультата.ОписаниеОшибки);
			
		КонецЕсли;
		
	КонецЦикла; 	
	
	Если РезультатВыполнения.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение( ,РезультатВыполнения.КраткоеПредставлениеОшибки);
		Возврат;
	КонецЕсли; 	
	
	ЧислоРайонов = ДополнительныеПараметры.МассивРайнов.Количество();
	Если ЧислоРайонов = 0 Тогда
		ПоказатьПредупреждение( , "Задание завершено.");
		Возврат;
	КонецЕсли;

