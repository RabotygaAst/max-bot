&НаКлиенте
Процедура ВыборАбонентскогоОтделаЗавершение(Значение, ДополнительныеПараметры) Экспорт  
	
	Если Значение  = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Районы 									= РайоныПоФилиалу(Значение); 
	
	Если Районы.Количество() > 0 Тогда
		 ЭтаФорма.Район 					= Районы[0];
	КонецЕсли;
	
	
	Для Сч = 1 По Районы.ВГраница() Цикл
		ОткрываемаяФорма  					= ПолучитьФорму("ОбщаяФорма.энргВыполнениеНачислений",,,Новый УникальныйИдентификатор);
		ОткрываемаяФорма.Организация  		= Организация;
		ОткрываемаяФорма.ПериодНачисления  	= ПериодНачисления;	
		ОткрываемаяФорма.Район			  	= Районы[Сч];
		ОткрываемаяФорма.открыть();
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборЗначенияЗавершение(Значение, ДополнительныеПараметры) Экспорт  
	
	Если Значение  = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ДополнительныеПараметры.Свойство("ИмяЭлемента") ИЛИ НЕ ЗначениеЗаполнено(ДополнительныеПараметры.ИмяЭлемента) Тогда
		Возврат;
	КонецЕсли;
	
	ЭтаФорма[ДополнительныеПараметры.ИмяЭлемента] 	= Значение;
	
	ЗаполняемыПоля 									= ДополнительныеПараметры.ЗаполняемыПоля;
	Индекс 											= ДополнительныеПараметры.Индекс;
	Индекс 											= Индекс + 1;
	ВыбратьЗначениеПоля(ЗаполняемыПоля, Индекс);
КонецПроцедуры

&НаСервереБезКонтекста
Функция РайоныПоФилиалу(Филиал)
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Филиал", Филиал);
	Запрос.Текст 	=
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	энргЗоныОтвественностиФилиалы.Ссылка КАК Район
	|ИЗ
	|	Справочник.энргЗоныОтвественности.Филиалы КАК энргЗоныОтвественностиФилиалы
	|ГДЕ
	|	энргЗоныОтвественностиФилиалы.Филиал = &Филиал";
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Район");	
	
КонецФункции

&НаСервере
Процедура СкрытьФизическиеЛица()
	Элементы.ГруппаРегламетныеОперацииМКД.Видимость							= Ложь;
	Элементы.ГруппаРегламетныеОперацииИндивидуальные.Видимость				= Ложь;
	Элементы.ГруппаРассчетНачисленийМКД.Видимость							= Ложь;
	Элементы.ГруппаРассчетНачисленийФизическихЛиц.Видимость					= Ложь;
	Элементы.ГруппаРаспределениеНачисленногоМКДОбъема.Видимость				= Ложь;
	Элементы.ГруппаКорректировкаПотребленияСезонныхУслуг.Видимость			= Ложь;
	Элементы.ГруппаВосстановлениеПоследовательностиВзаиморасчетов.Видимость	= Ложь;
	Элементы.ГруппаНачислениеПени.Видимость									= Ложь;
	Элементы.ВыполнитьВсеОперации.Видимость									= Ложь;
	Элементы.ГруппаОтборДоговор.Видимость									= Истина;
КонецПроцедуры 

&НаСервере
Процедура СкрытьНезависимыйСбыт()
	НС = бестРаботаСНезависимымСбытом.ПолучитьУчетНезависимыйСбыт();
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВыполнитьВсеОперации", "Видимость", Не НС);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаРегламетныеОперацииМКД", "Видимость", Не НС);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаРегламетныеОперацииИндивидуальные", "Видимость", Не НС);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаРассчетНачисленийМКД", "Видимость", Не НС);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаРассчетНачисленийФизическихЛиц", "Видимость", Не НС);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаРаспределениеНачисленногоМКДОбъема", "Видимость", Не НС);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаКорректировкаПотребленияСезонныхУслуг", "Видимость", Не НС);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаВосстановлениеПоследовательностиВзаиморасчетов", "Видимость", Не НС);                   
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеДляОткрытияНовыхФорм(ЗаполняемыПоля)
	
	Поля = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ЗаполняемыПоля,",");
	Для Сч = 0 По Поля.ВГраница() Цикл
		ИмяПоля 	= Поля[Сч];
		Если ИмяПоля = "Филиал" Тогда
			ВыбратьЗначениеПоля(Поля, Сч);
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ЭтаФорма[ИмяПоля]) Тогда
			ВыбратьЗначениеПоля(Поля, Сч);
			Прервать;
		КонецЕсли;		 
	КонецЦикла;
		
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьЗначениеПоля(ЗаполняемыПоля, Индекс)
	
	Если Индекс > ЗаполняемыПоля.ВГраница() Тогда
		Возврат;
	КонецЕсли;
		
	Если ЗаполняемыПоля[Индекс] = "Организация" Тогда
		Оповещение = Новый ОписаниеОповещения("ВыборЗначенияЗавершение", ЭтаФорма,Новый Структура("ИмяЭлемента, ЗаполняемыПоля, Индекс","Организация", ЗаполняемыПоля, Индекс));
		ПоказатьВводЗначения(Оповещение,Неопределено,"Укажите организацию для выполнения начислений",Тип("СправочникСсылка.Организации"));
	КонецЕсли;
		
	Если ЗаполняемыПоля[Индекс] = "ПериодНачисления" Тогда
		Оповещение = Новый ОписаниеОповещения("ВыборЗначенияЗавершение", ЭтаФорма,Новый Структура("ИмяЭлемента, ЗаполняемыПоля, Индекс","Район", ЗаполняемыПоля, Индекс));
		ПоказатьВводДаты(Оповещение,'0001-01-01',"Укажите период начисления для выполнения начислений",ЧастиДаты.Дата);
	КонецЕсли;
	
	Если ЗаполняемыПоля[Индекс] = "Филиал" Тогда
		Оповещение = Новый ОписаниеОповещения("ВыборАбонентскогоОтделаЗавершение", ЭтаФорма,Новый Структура("ИмяЭлемента","Район"));
		ПоказатьВводЗначения(Оповещение,Неопределено,"Укажите абонентский",Тип("СправочникСсылка.энргФилиалы"));
	КонецЕсли;   	

КонецПроцедуры

&НаКлиенте
Функция ПараметрыОперацииПоЗаданию(ИмяЗадания,ТекРайон = Неопределено)
	
	ПараметрыОпераций   = Новый Структура;
	ПараметрыОпераций.Вставить("Организация",		Организация);
	ПараметрыОпераций.Вставить("ПериодНачисления",	ПериодНачисленияТекущий);
	Если ТекРайон <> Неопределено Тогда
		ПараметрыОпераций.Вставить("Район",				ТекРайон);
	Иначе 
		ПараметрыОпераций.Вставить("Район",				Район);
	КонецЕсли;
	
	Если ОтборПоДому И ЗначениеЗаполнено(Дом) Тогда
		ПараметрыОпераций.Вставить("ЧастныйСектор",		Ложь);
	ИначеЕсли ОтборПоДому Тогда
		ПараметрыОпераций.Вставить("ЧастныйСектор",		Истина);
	Иначе
		ПараметрыОпераций.Вставить("ЧастныйСектор",		Неопределено);
	КонецЕсли;
	
	//Если ИмяЗадания <> "ВосстановлениеПоследовательностиДокументовНП" тогда
		Если ОтборПоДому тогда
			ПараметрыОпераций.Вставить("МКД",Дом);
			ПараметрыОпераций.Вставить("МКД_НП",	?(ИсключаяОтдельностоящие, ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка"),Дом));
	
		иначе
			ПараметрыОпераций.Вставить("МКД",		Неопределено);
			ПараметрыОпераций.Вставить("МКД_НП",	Неопределено);
		КонецЕсли; 
	//КонецЕсли; 
	
	ПараметрыОпераций.Вставить("Строение",					Дом);
	ПараметрыОпераций.Вставить("Помещение",					Неопределено);
	ПараметрыОпераций.Вставить("Абонент",					Неопределено);
	ПараметрыОпераций.Вставить("СписокМКД",					Неопределено);
	ПараметрыОпераций.Вставить("ИсключаяОтдельностоящие",	ИсключаяОтдельностоящие);
	ПараметрыОпераций.Вставить("СбрасыватьВзаиморасчеты",	СбрасыватьВзаиморасчеты);
	ПараметрыОпераций.Вставить("СбрасыватьПоказания",		СбрасыватьПоказания);
	ПараметрыОпераций.Вставить("МассивКлючейПомещений",		Неопределено);
	ПараметрыОпераций.Вставить("МассивАбонентов",			Неопределено);
	ПараметрыОпераций.Вставить("ФинальноеНачисление",		Ложь);
	//Если ИмяЗадания = "ЗаполнениеНачальныхОстатков" тогда
		ПараметрыОпераций.Вставить("СбрасыватьСостояниеПоследовательности",СбрасыватьСостояниеПоследовательности);
	//КонецЕсли; 	
	
	Если ЗначениеЗаполнено(Договор) Тогда
		ПараметрыОпераций.Вставить("мОбъектыРасчета",	ПолучитьМассивОбъектов(Организация, Район, ПериодНачисленияТекущий, Договор));
		ПараметрыОпераций.Вставить("Договор",			Договор);
	Иначе
		ПараметрыОпераций.Вставить("мОбъектыРасчета",	Неопределено);
		ПараметрыОпераций.Вставить("Договор",			Неопределено);
	КонецЕсли;
	
	Возврат ПараметрыОпераций;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьМассивОбъектов(Организация, Район, Период, Договор)
	МассивОбъектов = Неопределено;
	РезультатЗапроса = РегистрыСведений.бестДоговорыТочекУчета.ПолучитьДанныеДоговоров(Организация, Район, Период, Договор);
	ТЗ = РезультатЗапроса.Выгрузить();
	Если ТЗ.Количество() <> 0 Тогда
		ТЗ.Свернуть("ОбъектРасчета");
		МассивОбъектов = ТЗ.ВыгрузитьКолонку("ОбъектРасчета");
	КонецЕсли;
	Возврат МассивОбъектов;
КонецФункции

