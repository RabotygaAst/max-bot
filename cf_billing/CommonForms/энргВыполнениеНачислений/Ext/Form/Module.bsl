&НаКлиенте
Функция ВыбратьВыполняемоеДействие(Элемент)
	ИмяОперации 		= СтрЗаменить(Элемент.Имя,"Декорация","");
	ОднаСтрокаМеню 		= Ложь;
	Операции 			= Операции();
	Для Каждого КлючЗначение Из Операции Цикл
		Если НЕ ИмяОперации = КлючЗначение.Значение Тогда
			Продолжить;
		КонецЕсли;
		
		Индекс  		= Число(СтрЗаменить(КлючЗначение.Ключ,"Операция",""));
		ОднаСтрокаМеню 	= Индекс = 0;		
	КонецЦикла;	
	
	МассивОпераций  	= Новый Массив;
	МассивОпераций.Добавить("Выполнить операцию");
	Если не ОднаСтрокаМеню тогда
		МассивОпераций.Добавить("Выполнить все до текущей операции");
		МассивОпераций.Добавить("Выполнить начиная с этой операции");
	КонецЕсли;
	Список  = Новый СписокЗначений;
	Список.ЗагрузитьЗначения(МассивОпераций);
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВыборИзМенюЗавершение",ЭтотОбъект,Новый Структура("ИмяОперации",ИмяОперации));
	ПоказатьВыборИзМеню(ОписаниеОповещения,Список,Элемент);	
КонецФункции

&НаКлиенте
Процедура ВыборИзМенюЗавершение(ВыбранныйЭлемент,ДополнительныеПараметры) Экспорт 	
	
	Если ВыбранныйЭлемент = Неопределено тогда
		Возврат;
	КонецЕсли;
	
	Значение  				= ВыбранныйЭлемент.значение;
	Предыдущие 				= Неопределено;
	Если Значение = "Выполнить все до текущей операции" тогда 	 
		Предыдущие 			= истина;
	ИначеЕсли Значение = "Выполнить начиная с этой операции" тогда
		Предыдущие 			= ложь;
	КонецЕсли; 	
	
	ПериодНачисленияТекущий = ПериодНачисления;
	ВыполняемыеОперации 	= Новый Структура;
	ПолучитьСписокОпераций(ВыполняемыеОперации,ДополнительныеПараметры.ИмяОперации,Предыдущие);
	
	ДействияПередВыполнениемОперации(ВыполняемыеОперации, ДополнительныеПараметры, Предыдущие);
	
	Если Не ЗначениеЗаполнено(ПериодНачисленияПо) Тогда
		ПредставлениеТекущийПериодНачисления 	= энргОбщегоНазначенияКлиент.ПолучитьПредставлениеПериодаРегистрации(ПериодНачисленияТекущий);
		ЗапуститьВыполнениеОпераций(ВыполняемыеОперации);
		Возврат;
	КонецЕсли;  	
	
	ЕстьОшибки	= Ложь;
	
	Пока ПериодНачисленияТекущий <= ПериодНачисленияПо Цикл		
		Если ЕстьОшибки Тогда
			Прервать;
		КонецЕсли;
		ПредставлениеТекущийПериодНачисления 	= энргОбщегоНазначенияКлиент.ПолучитьПредставлениеПериодаРегистрации(ПериодНачисленияТекущий);
		ЗапуститьВыполнениеОпераций(ВыполняемыеОперации);
		ПериодНачисленияТекущий	= КонецМесяца(ПериодНачисленияТекущий) + 1;
	КонецЦикла;   
КонецПроцедуры

&НаКлиенте
Процедура ДействияПередВыполнениемОперации(ВыполняемыеОперации, ДополнительныеПараметры, Предыдущие)
	// переопределено в расширении	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьСписокОпераций(ВыполняемыеОперации,ИмяОперации=Неопределено,ВыполнятьПредыдущие=Неопределено,ТолькоОперацииНП = Ложь)
	
	Операции = Операции(ТолькоОперацииНП);
	
	Если ИмяОперации =Неопределено тогда // выполнение всех операций
		для Каждого стр из Операции цикл
			ВыполняемыеОперации.вставить(стр.ключ,стр.Значение);
		КонецЦикла;
		Возврат ;
	иначе
		
	КонецЕсли;
	
	для Каждого стр из Операции цикл
		Если стр.Значение = ИмяОперации тогда
			ИндексОперации  = Число(СтрЗаменить(стр.Ключ,"Операция",""));
		КонецЕсли; 		
	КонецЦикла;
	
	Если ВыполнятьПредыдущие = Неопределено тогда
		// выполняем только одну операцию		
		ВыполняемыеОперации.вставить("Операция" + 0,Операции["Операция" + ИндексОперации]);
		Возврат;
	КонецЕсли;	
	
	Если ВыполнятьПредыдущие тогда
		для Строка = 0 по ИндексОперации-1 цикл
			ВыполняемыеОперации.вставить("Операция" + Строка,Операции["Операция" + Строка]);
		КонецЦикла; 		
	иначе
		Счетчик  = 0;
		для Строка = ИндексОперации по Операции.Количество() - 1 цикл
			ВыполняемыеОперации.вставить("Операция" + Счетчик,Операции["Операция" + Строка]);
			Счетчик = Счетчик + 1;
		КонецЦикла;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьВыполнениеОпераций(ВыполняемыеОперации)
	ПараметрыОпераций   = Новый Структура;
	ПараметрыОпераций.Вставить("Организация",		Организация);
	ПараметрыОпераций.Вставить("ПериодНачисления",	ПериодНачисленияТекущий);
	ПараметрыОпераций.Вставить("Район",				Район);
	Если ОтборПоДому тогда
		ПараметрыОпераций.Вставить("Дом",Дом);
	КонецЕсли; 
	
	Если НЕ ВсеПоляЗаполнены() Тогда
		Возврат;
	КонецЕсли; 	
	
	УстановитьКартинки();
	
	УстановитьДоступностьЭлементовФормы(Ложь);
	
	ИндексТекОперации = 0;
	Если Не ВыполнятьВФоне тогда
		//СлужебныеСообщения.Очистить();
		для Каждого стр из ВыполняемыеОперации цикл
			ВыполнитьОперацию(ВыполняемыеОперации["Операция" + ИндексТекОперации]);
		КонецЦикла;		
	иначе
		//ВыполнитьОперацию(ВыполняемыеОперации["Операция" + ИндексТекОперации]); было
		ЗапуститьФоновыеВыполнениеОпераций(ВыполняемыеОперации); //стало
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьВыполнениеЗадания()
	
	СтруктураСостояниеЗаданий	=  ВернутьСтруктуруЗадания();
	
	ЭлементКартинка  			= Элементы["Статус" + ВыполняемыеОперации["Операция" + ИндексТекОперации]];
	ЭлементОшибок 				= Элементы["Ошибки" + ВыполняемыеОперации["Операция" + ИндексТекОперации]];
	
	Ошибки 						= СтруктураСостояниеЗаданий.Ошибки;
	ЕСли Ошибки<>Неопределено тогда
		
		ОписаниеОшибки 				= Новый Структура;
		ОписаниеОшибки.Вставить("ПериодНачисления", ПериодНачисления);
		ОписаниеОшибки.Вставить("Ораганизация", 	Организация);
		ОписаниеОшибки.Вставить("Район",			Район);
		ОписаниеОшибки.Вставить("МКД",				Дом);
		ОписаниеОшибки.Вставить("ОтборПоМКД",		ОтборПоДому);
		ОписаниеОшибки.Вставить("Ошибки",			Ошибки);			
		Если  Ошибки.Количество()> 0 тогда
			ЭлементОшибок.Доступность 	= истина;
			ЭлементОшибок.Заголовок 	= "Ошибок ("+Ошибки.Количество() +")"; 						
			СтруктураОшибок.вставить(ВыполняемыеОперации["Операция" + ИндексТекОперации],ОписаниеОшибки);
		КонецЕсли;  
	КонецЕсли;
	
	Если 		СтруктураСостояниеЗаданий.Активно 			тогда
		ПодключитьОбработчикОжидания("ПроверитьВыполнениеЗадания",10,Истина);
		// ничего не делаем 					
	ИначеЕсли 	СтруктураСостояниеЗаданий.Завершено 			тогда
		
		// устанавливаем картинку удачного завершения задания 		
		ЭлементКартинка.картинка  	= БиблиотекаКартинок.Успешно32;					
		
		// если есть запускаем следующее задание
		ИндексТекОперации  =ИндексТекОперации + 1;
		Если ВыполняемыеОперации.количество() - 1 >= ИндексТекОперации тогда
			ВыполнитьОперацию(ВыполняемыеОперации["Операция" + ИндексТекОперации]);
		иначе
			// отжимаем гиперссылку
			УстановитьДоступностьЭлементовФормы(Истина);
		КонецЕсли;
		
	ИначеЕсли 	СтруктураСостояниеЗаданий.ЗавершеноАварийно 	тогда
		
		// устанавливаем картинку не удачного завершения
		ЭлементКартинка.картинка  	= БиблиотекаКартинок.Ошибка32;
		
		// отжимаем гиперссылку
		УстановитьДоступностьЭлементовФормы(Истина);						
		
	ИначеЕсли СтруктураСостояниеЗаданий.Отменено тогда
		
		// устанавливаем картинку не удачного завершения
		ЭлементКартинка.картинка  	= БиблиотекаКартинок.Ошибка32;
		
		// отжимаем гиперссылку
		УстановитьДоступностьЭлементовФормы(Истина);
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ВернутьСтруктуруЗадания()
	Задание 												= ФоновыеЗадания.НайтиПоУникальномуИдентификатору(IDЗадания);
	СтруктураСостояниеЗаданий								= Новый Структура;
	СостояниеЗадания										= Задание.Состояние;
	СтруктураСостояниеЗаданий.Вставить("Активно", 			СостояниеЗадания = ПредопределенноеЗначение("СостояниеФоновогоЗадания.Активно"));
	СтруктураСостояниеЗаданий.Вставить("Завершено", 		СостояниеЗадания = ПредопределенноеЗначение("СостояниеФоновогоЗадания.Завершено"));
	СтруктураСостояниеЗаданий.Вставить("ЗавершеноАварийно", СостояниеЗадания = ПредопределенноеЗначение("СостояниеФоновогоЗадания.ЗавершеноАварийно"));
	СтруктураСостояниеЗаданий.Вставить("Отменено", 			СостояниеЗадания = ПредопределенноеЗначение("СостояниеФоновогоЗадания.Отменено"));
	СтруктураСостояниеЗаданий.Вставить("Ошибки",			Задание.ПолучитьСообщенияПользователю());
	Если НЕ Задание.ИнформацияОбОшибке						= Неопределено Тогда 
		//СлужебныеСообщения.ДобавитьСтроку(Задание.ИнформацияОбОшибке.Описание);
	КонецЕсли;
	
	Возврат СтруктураСостояниеЗаданий;
КонецФункции

&НаКлиенте
Процедура ВыполнитьОперацию(ИмяОперации,ТекРайон = Неопределено)
	
	ИмяМодуля 								= ИменаМодулей[ИмяОперации];
	
	ПараметрыОпераций 						= ПараметрыОперацииПоЗаданию(ИмяОперации,ТекРайон);

	
	Если ВыполнятьВФоне тогда			
		
		МассивПараметров 					= Новый Массив;
		для Каждого стр из ПараметрыОпераций цикл
			МассивПараметров.Добавить(стр.значение);
		КонецЦикла;	
		ПредставлениеОперации  				= ИмяОперации + " по району " + ПараметрыОпераций.Район + "за период: " + ПараметрыОпераций.периодНачисления + "";  
		
		Если ПараметрыОпераций.свойство("Дом") тогда
			ПредставлениеОперации 			= ПредставлениеОперации + " отбор по дому: " + ПараметрыОпераций.Дом;
		КонецЕсли;
		
		СвойстваЗадания  					= ВыполнитьФоновоеЗадание(ИмяМодуля,МассивПараметров,ПредставлениеОперации);
		
		IDЗадания 							= СвойстваЗадания.УникальныйИдентификатор;
		ЭлементКартинка  					= Элементы["Статус" + ИмяОперации];
		ЭлементКартинка.картинка  			= БиблиотекаКартинок.ДлительнаяОперация48;
		
		ЭлементОшибок 						= Элементы["Ошибки" + ВыполняемыеОперации["Операция" + ИндексТекОперации]];
		ЭлементОшибок.Заголовок 			= "Нет Ошибок";
		
		Если СтруктураОшибок.свойство(ИмяОперации) тогда
			СтруктураОшибок[ИмяОперации] 	= Новый Массив;
		КонецЕсли;			
		
		ПодключитьОбработчикОжидания("ПроверитьВыполнениеЗадания",2,Истина);
		
	иначе
		СтрокаМодуля 						= ИмяМодуля + "(";
		Счетчик 							= 0;
		для Каждого стр из ПараметрыОпераций цикл
			СтрокаМодуля 					= СтрокаМодуля +?(Счетчик= 0,"",",")+ "ПараметрыОпераций." + стр.ключ;
			Счетчик 						= Счетчик+1;
		КонецЦикла;
		СтрокаМодуля 						= СтрокаМодуля + ")";
		
		ЭлементКартинка  					= Элементы["Статус" + ИмяОперации];
		
		ЭлементОшибок 						= Элементы["Ошибки" + ВыполняемыеОперации["Операция" + ИндексТекОперации]];
		ЭлементОшибок.Заголовок 			= "Нет Ошибок";
		
		Попытка
			Если ИмяОперации = "ЗаполнениеНачальныхОстатковМКД" Тогда
				энргРаботаСПоследовательностями.ОтложенныеДвиженияДокументовНачисленияМКД(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиДокументовМКД" Тогда
				энргРаботаСПоследовательностями.ВосстановитьПоследовательностьСтабильныеПериодыМКД(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиПоказанийМКД" Тогда
				энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоказанияПУМКД(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ЗаполнениеНачальныхОстатков" Тогда
				энргРаботаСПоследовательностями.ОтложенныеДвиженияДокументовНачисления(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиДокументов" Тогда
				энргРаботаСПоследовательностями.ВосстановитьПоследовательностьСтабильныеПериоды(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиПоказанийПУ" Тогда  
				
				Если СбрасыватьПоказания Тогда
					 СброситьПоследовательностьПоказанийНаСервере(ПараметрыОпераций);
				КонецЕсли;
				
				энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоказанияПУ(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ПерерасчетСреднихНачисленийМКД" Тогда
				энргНачисления.СнятьСредниеНачисленияМКД(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "РасчетНачисленийНаМКД" Тогда
				энргНачисления.НачислениеНаОДН(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ПерерасчетСреднихНачислений" Тогда
				энргНачисления.СнятьСредниеНачисления(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "УстановкаЗначенийДифференцированныхТарифов" Тогда
				энргНачисления.УстановитьЗначенияДифференцированныхТарифов(ПараметрыОпераций);	
			ИначеЕсли ИмяОперации = "ИндивидуальныеНачисления" Тогда
				энргНачисления.Начислить(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "РаспределениеОбъемаМКД" Тогда
				энргНачисления.РаспредениеОбъемаМКД(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "НачислениеПроцентовРассрочки" Тогда
				энргНачисления.НачислениеПоРассрочке(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ПерерасчетПриУстановкеПрибораУчетаСезонныхУслуг" Тогда
				энргНачисления.ИзменитьПризнакСостояниеПрибора(ПараметрыОпераций);				
			ИначеЕсли ИмяОперации = "КорректировкаПотребленияСезонныхУслуг" Тогда
				энргНачисления.СкорректироватьПотреблениеСезонныхУслуг(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "КорректировкаПотребленияСезонныхУслугМКД" Тогда
				энргНачисления.СкорректироватьПотреблениеСезонныхУслугМКД(ПараметрыОпераций);	
			ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиВзаиморасчетов" Тогда
				
				Если СбрасыватьВзаиморасчеты Тогда
					 СброситьВзаиморасчетыНаСервере(ПараметрыОпераций);
				КонецЕсли;
				
				энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "НачислениеПени" Тогда
				энргНачисления.НачислитьПеню(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ЗакрытиеПериодаНачисления" Тогда
				энргНачисления.ЗакрытьПериодДляРедактирования(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ЗаполнениеНачальныхОстатковНП" Тогда
				бестРаботаСПоследовательностямиНП.ОтложенныеДвиженияДокументовНачисленияНП(ПараметрыОпераций, ПараметрыОпераций.мОбъектыРасчета);
			ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиДокументовНП" Тогда
				бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьСтабильныеПериодыНП(ПараметрыОпераций, ПараметрыОпераций.мОбъектыРасчета);
			ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиПоказанийПУНП" Тогда
				бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьПоказанияПУНП(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "ИндивидуальныеНачисленияНП" Тогда
				бестНачисленияНП.Начислить(ПараметрыОпераций, ПараметрыОпераций.мОбъектыРасчета);
			ИначеЕсли ИмяОперации = "РасчетЛьгот" Тогда
				энргНачисления.НачислитьЛьготы(ПараметрыОпераций);
			ИначеЕсли ИмяОперации = "НачисленияПоДолевымСхемам" Тогда
				бестНачисленияНП.НачисленияПоДолевымСхемам(ПараметрыОпераций);	
			ИначеЕсли ИмяОперации = "НачислениеПоДСИзРазныхРО" Тогда
				бестНачисленияНП.НачисленияПоДолевымСхемам(ПараметрыОпераций,,, Истина);
			ИначеЕсли ИмяОперации = "ПерерасчетСреднихНачисленийНП" Тогда
				бестНачисленияНП.СнятьСредниеНачисленияНП(ПараметрыОпераций, ПараметрыОпераций.Договор);
			ИначеЕсли ИмяОперации = "НачисленияПоСхемамСтруктурыСети" Тогда
				бестНачисленияНП.НачисленияПоСхемамСтруктурыСети(ПараметрыОпераций, ПараметрыОпераций.Договор);	
			ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиВзаиморасчетовНП" Тогда
				бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьВзаиморасчетыНП(ПараметрыОпераций, ПараметрыОпераций.Договор);
			ИначеЕсли ИмяОперации = "ДополнительныеНачисленияЮЛ" Тогда
				бестНачисленияНП.ДополнительныеНачисленияЮЛ(ПараметрыОпераций, ПараметрыОпераций.Договор);	
			Иначе
				Выполнить (СтрокаМодуля);
			КонецЕсли;
			ИндексТекОперации 				= ИндексТекОперации + 1;
			ЭлементКартинка.картинка  		= БиблиотекаКартинок.Успешно32;
			ЭлементОшибок.Заголовок 		= "Нет Ошибок";
			ЭлементОшибок.Доступность 		= Ложь;
		Исключение
			ЕстьОшибки 						= Истина;
			ИндексТекОперации 				= ИндексТекОперации + 1;
			ЭлементОшибок.Заголовок 		= "Есть ошибки";
			ЭлементКартинка.картинка  		= БиблиотекаКартинок.Ошибка32;
			ЭлементОшибок.Доступность 		= Истина;
			ОписаниеОшибки  				= ИнформацияОбОшибке();
			Ошибки 							= Новый Массив;
			Ошибки.Добавить(Новый Структура("Текст", ОписаниеОшибки.Описание + Символы.ПС + КраткоеПредставлениеОшибки(ОписаниеОшибки)));
			
			ОписаниеОшибки 					= Новый Структура;
			ОписаниеОшибки.Вставить("ПериодНачисления", ПериодНачисления);
			ОписаниеОшибки.Вставить("Ораганизация", 	Организация);
			ОписаниеОшибки.Вставить("Район",			Район);
			ОписаниеОшибки.Вставить("МКД",				Дом);
			ОписаниеОшибки.Вставить("ОтборПоМКД",		ОтборПоДому);
			ОписаниеОшибки.Вставить("Ошибки",			Ошибки);
			
			СтруктураОшибок.Вставить(ИмяОперации, ОписаниеОшибки);			
		КонецПопытки;
		УстановитьДоступностьЭлементовФормы(Истина);
	КонецЕсли;	 	
КонецПроцедуры

&НаСервере
Функция ВыполнитьФоновоеЗадание(ИмяМодуля,МассивПараметров,ПредставлениеОперации)
	Задание 					= ФоновыеЗадания.Выполнить(ИмяМодуля, МассивПараметров,,ПредставлениеОперации);
	ЗаданиеВыполнено  			= Ложь;
	
	Возврат Новый Структура("УникальныйИдентификатор,ЗаданиеВыполнено",Задание.УникальныйИдентификатор,ЗаданиеВыполнено);
КонецФункции

&НаКлиенте
Процедура ПоказатьОшибкиПользователю(Элемент)
	
	ИмяОперации 								= СтрЗаменить(Элемент.Имя,"Ошибки","");
		
	Если ИмяОперации = "" тогда
		Возврат;
	КонецЕсли; 	
	
	ОчиститьСообщения();
	ОписаниеОшибки								= СтруктураОшибок[ИмяОперации];
	ЕстьОшибки  								= ОписаниеОшибки.Ошибки.Количество() > 0;
	
	Если ЕстьОшибки тогда
		ОткрытьФорму("ОбщаяФорма.энргОписаниеОшибкиВыполненияНачислений",Новый Структура("ИмяОперации, ОписаниеОшибки", ИмяОперации, ОписаниеОшибки),ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли; 	
	
КонецПроцедуры

&НаКлиенте
Функция ВсеПоляЗаполнены()
	Отказ 									= Ложь;	
	Если Не ПараметрыОпераций.Свойство("Организация") ИЛИ Не ЗначениеЗаполнено(ПараметрыОпераций.Организация) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите организацию", ,"Организация");
		Отказ 								= Истина;
	КонецЕсли;
	
	Если Не ПараметрыОпераций.Свойство("ПериодНачисления") ИЛИ Не ЗначениеЗаполнено(ПараметрыОпераций.ПериодНачисления) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите период начисления", ,"ПредставлениеПериодаРегистрации");
		Отказ 								= Истина;
	КонецЕсли;
	
	Если Не ПараметрыОпераций.Свойство("Район") ИЛИ Не ЗначениеЗаполнено(ПараметрыОпераций.Район) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите район", ,"Район");
		Отказ 								= Истина;
	КонецЕсли;
	
	Возврат НЕ Отказ;
КонецФункции      

&НаКлиенте
Функция Операции(ТолькоОперацииНП = Ложь)
	
	Операции 	= Новый Структура;
	
	мОперации 	= Новый Массив;
	
	#Область РегламетныеОперации
	
	#Область МногоквартирныеДома
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("ЗаполнениеНачальныхОстатковМКД");
		мОперации.Добавить("ВосстановлениеПоследовательностиДокументовМКД");
		мОперации.Добавить("ВосстановлениеПоследовательностиПоказанийМКД");
	КонецЕсли;
	#КонецОбласти
	
	#Область ФизическиеЛица
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("ЗаполнениеНачальныхОстатков");
		мОперации.Добавить("ВосстановлениеПоследовательностиДокументов");
		мОперации.Добавить("ВосстановлениеПоследовательностиПоказанийПУ");
	КонецЕсли;
	#КонецОбласти
	
	#Область НежилыеПомещения
	мОперации.Добавить("ЗаполнениеНачальныхОстатковНП");
	мОперации.Добавить("ВосстановлениеПоследовательностиДокументовНП"); 
	мОперации.Добавить("ВосстановлениеПоследовательностиПоказанийПУНП");
	#КонецОбласти
	
	#КонецОбласти
	
	#Область РассчетНачислений
	
	#Область МногоквартирныеДома
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("РасчетНачисленийНаМКД");
		мОперации.Добавить("ПерерасчетСреднихНачисленийМКД");
		мОперации.Добавить("КорректировкаПотребленияСезонныхУслугМКД");
	КонецЕсли;
	#КонецОбласти
	
	#Область ФизическиеЛица
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("ИндивидуальныеНачисления");	
		мОперации.Добавить("ПерерасчетСреднихНачислений");
		мОперации.Добавить("УстановкаЗначенийДифференцированныхТарифов");
		мОперации.Добавить("ПерерасчетПриУстановкеПрибораУчетаСезонныхУслуг");
		мОперации.Добавить("НачислениеПроцентовРассрочки");
		мОперации.Добавить("РасчетЛьгот");
	КонецЕсли;
	#КонецОбласти
	
	#Область НежилыеПомещения
	мОперации.Добавить("ИндивидуальныеНачисленияНП");
	мОперации.Добавить("НачисленияПоДолевымСхемам");
	мОперации.Добавить("НачислениеПоДСИзРазныхРО");
	мОперации.Добавить("ПерерасчетСреднихНачисленийНП");
	#КонецОбласти
	
	#КонецОбласти
	
	#Область РаспределениеИКорректировка
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("РаспределениеОбъемаМКД");
		мОперации.Добавить("КорректировкаПотребленияСезонныхУслуг");
		мОперации.Добавить("ВосстановлениеПоследовательностиВзаиморасчетов");
		мОперации.Добавить("НачислениеПени");
		
	КонецЕсли;
	мОперации.Добавить("НачисленияПоСхемамСтруктурыСети");
	мОперации.Добавить("ДополнительныеНачисленияЮЛ");
	мОперации.Добавить("ВосстановлениеПоследовательностиВзаиморасчетовНП");
	#КонецОбласти
	
	#Область ПрочииОперации
	мОперации.Добавить("ЗакрытиеПериодаНачисления");
	#КонецОбласти 	
	
	Для Сч = 0 По мОперации.ВГраница() Цикл
		Операции.Вставить("Операция" + Формат("" + Сч,"ЧРГ=' '; ЧГ=0"),мОперации[Сч]);
	КонецЦикла; 	
	
	Возврат Операции;
КонецФункции

&НаКлиенте
