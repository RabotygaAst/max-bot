#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗаполнитьДанныеПоУмолчанию(); 	
	
	Если Параметры.Свойство("ПараметрыШапки") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Параметры.ПараметрыШапки);
		ЗаполнитьПриборыУчетаСервер();
	КонецЕсли;  	
КонецПроцедуры

Процедура ЗаполнитьДанныеПоУмолчанию()
	ВидОперации 					= Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги;
	Дата							= ТекущаяДата();
	Организация 					= Справочники.Организации.ОрганизацияПоУмолчанию();
	Если ЗначениеЗаполнено(Организация) Тогда		
		ПериодНачисления 			= Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Дата, Организация,Район);
	КонецЕсли;
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета);
КонецПроцедуры

#КонецОбласти

#Область СобытияКоманд

&НаКлиенте
Процедура СформироватьДокументы(Команда)
	Успешно = Ложь;
	СформироватьДокументыНаСервере(Успешно);
	
	Если Успешно Тогда
		ПоказатьПредупреждение(, "Документы созданы успешно");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура СформироватьДокументыНаСервере(Успешно)
	
	ИмяДокумента = ПолучитьИмяДокумента();
	Если ИмяДокумента = "" Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеТаблиц = Новый Структура("ТочкиУчета, ШкалыПриборовУчета, ПоказанияПриборовУчета, Ссылка", ТочкиУчета, ШкалыПриборовУчета, ПоказанияПриборовУчета, Неопределено);
	энргШкалыТарифныеЗоныСервер.ЗаполнитьОбъектПоПредставлениюФормы(ДанныеТаблиц, ДанныеТаблиц, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
	// создаем документы
	ТочкиУчета.Сортировать("КлючПомещения");	
	
	Попытка
		НачатьТранзакцию();
		
		ТекКлючПомещения 	= Неопределено;
		НовыйДокумент		= Неопределено;
		
		Для Каждого ТекТочкаУчета из ТочкиУчета Цикл
			Если НЕ ТекКлючПомещения = ТекТочкаУчета.КлючПомещения Тогда
				Если НЕ НовыйДокумент = Неопределено Тогда
					// Проводим документ предыдущего Абонента
					НовыйДокумент.ДополнительныеСвойства.Вставить("НеПроверятьНаличиеФайла", Истина);
					НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
				КонецЕсли;
				
				НовыйДокумент = Документы[ИмяДокумента].СоздатьДокумент();
				ЗаполнитьШапкуДокумента(НовыйДокумент, ТекТочкаУчета);
			КонецЕсли;
			
			НоваяСтрока = НовыйДокумент.ТочкиУчета.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекТочкаУчета);
			
			ЗаполнитьСвязанныеТабЧасти(НовыйДокумент, ТекТочкаУчета);
			
			ТекКлючПомещения = ТекТочкаУчета.КлючПомещения
		КонецЦикла;
		
		Если НЕ НовыйДокумент = Неопределено Тогда
			// Проводим документ последнего Абонента
			НовыйДокумент.ДополнительныеСвойства.Вставить("НеПроверятьНаличиеФайла", Истина);
			НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
		Успешно = Истина;
	Исключение 		
		ОтменитьТранзакцию(); 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка при создании документа: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки; 	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьШапкуДокумента(НовыйДокумент, ТекТочкаУчета)
	
	НовыйДокумент.Дата 				= Дата;
	НовыйДокумент.ПериодНачисления 	= ПериодНачисления;
	НовыйДокумент.ВидОперации 		= ВидОперации;
	НовыйДокумент.Организация 		= Организация;
	НовыйДокумент.Район 			= Район;
	НовыйДокумент.Абонент 			= ТекТочкаУчета.Абонент;
	НовыйДокумент.КлючПомещения 	= ТекТочкаУчета.КлючПомещения;
	НовыйДокумент.бестПричинаЗакрытияЛС = ПричинаЗакрытияЛС;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвязанныеТабЧасти(НовыйДокумент, ТекТочкаУчета)
	
	СтрокиШкал 		= ШкалыПриборовУчета.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекТочкаУчета.IDСтроки));
	ТабЧастьШкал	= НовыйДокумент.ШкалыПриборовУчета;
	
	Для Каждого ТекШкала из СтрокиШкал Цикл
		НоваяСтрока = ТабЧастьШкал.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекШкала);
		
		ЗаполнитьПоказания(НовыйДокумент, ТекШкала);
	КонецЦикла;
	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоказания(НовыйДокумент, ТекШкала)
	
	СтрокиПоказаний		= ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки", ТекШкала.IDСтроки));
	ТабЧастьПоказаний	= НовыйДокумент.ПоказанияПриборовУчета;
	
	Для Каждого ТекПоказания из СтрокиПоказаний Цикл
		НоваяСтрока = ТабЧастьПоказаний.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекПоказания);
	КонецЦикла; 	
	
КонецПроцедуры



&НаКлиенте
Процедура Заполнить(Команда)
	ЗаполнитьНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере()
	ЗаполнитьПриборыУчетаСервер();
КонецПроцедуры

#КонецОбласти

#Область СобытияРеквизитовШапки 

&НаКлиенте
Процедура СтроениеПриИзменении(Элемент)
	ДанныеСтроения = энргРаботаСЛицевымСчетомКлиент.СтруктруаЗначенийЗаполненияМКД();
	энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыМКД(Строение, ДанныеСтроения);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеСтроения);
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаСервере
Функция ПолучитьИмяДокумента()
	ИмяДокумента = "";
	Если ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСЛС_ЗакрытиеЛС Тогда
		ИмяДокумента = "энргОперацияСЛицевымСчетом";
	ИначеЕсли  ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги Тогда
		ИмяДокумента = "энргОперацияСУслугами";
	КонецЕсли;
	
	Возврат ИмяДокумента; 	
КонецФункции

&НаСервере
Процедура ЗаполнитьПриборыУчетаСервер(ИдентификаторСтроки = Неопределено)
	
	//ТочкаУчета  									= Неопределено;
	//Если ИдентификаторСтроки = Неопределено Тогда
	//	ТаблицаТЧ 									= ПоказанияПриборовУчета.Выгрузить();
	//	ШкалыПриборовУчета.Очистить();
	//	ПоказанияПриборовУчета.Очистить();
	//	ТочкиУчета.Очистить();
	//Иначе
	//	СтрокаТочкиУчета  							= ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
	//	ТочкаУчета 									= СтрокаТочкиУчета.ТочкаУчета;
	//	ПоискШкал	 								= Новый Структура("IDСтрокиТочкиУчета",СтрокаТочкиУчета.IDСтроки);
	//	СтрокиШкал  								= ШкалыПриборовУчета.НайтиСтроки(ПоискШкал);
	//	Для Каждого СтрокаШкалы Из СтрокиШкал Цикл
	//		ПоискПоказаний 							= Новый Структура("IDСтроки", СтрокаШкалы.IDСтроки);
	//		СтрокиПоказаний 						= ПоказанияПриборовУчета.НайтиСтроки(ПоискПоказаний);
	//		Для Каждого СтрокаПоказаний Из СтрокиПоказаний Цикл
	//			ПоказанияПриборовУчета.Удалить(СтрокаПоказаний);
	//		КонецЦикла;
	//		ШкалыПриборовУчета.Удалить(СтрокаШкалы);
	//	КонецЦикла;		
	//КонецЕсли;

	Результат 										= энргСостояниеПриборовУчета.ДействующиеПриборыУчетаПоМаршруту(Дата, Организация, Район, Неопределено, Строение); 
	
	Выборка  										= Результат.выбрать();
	ТекТочкаУчета 									= Неопределено;
	ТекШкала 										= Неопределено;
	IDСтрокиТочки 									= Неопределено;
	IDСтрокиШкалы 									= Неопределено;
	Пока Выборка.следующий() цикл
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			Если ИдентификаторСтроки = Неопределено Тогда
				СтрокаТочкиУчета  					= ТочкиУчета.Добавить();
				IDСтрокиТочки 						= Новый УникальныйИдентификатор;
				СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
				СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			иначе 				
				СтрокаТочкиУчета  					= ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
				IDСтрокиТочки 						= СтрокаТочкиУчета.IDСтроки;
			КонецЕсли;
			СтрокаТочкиУчета.Услуга 				= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 			= Выборка.ПриборУчета;
			СтрокаТочкиУчета.КлючПомещения 			= Выборка.КлючПомещения;
			// todo: Сделать заполнение абонента
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) Тогда
			Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
				СтрокаШкалы  						= ШкалыПриборовУчета.Добавить();
				IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
				СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
				СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
				СтрокаШкалы.Шкала 					= Выборка.Шкала;
				СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
