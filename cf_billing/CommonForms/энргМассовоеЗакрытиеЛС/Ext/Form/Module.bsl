			СтрокаПоказаний 						= ПоказанияПриборовУчета.Добавить();
			СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
			СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		КонецЕсли;
		
		ТекТочкаУчета 								= Выборка.ТочкаУчета;
		ТекШкала 									= Выборка.Шкала;
	КонецЦикла; 
	
	
	ЗаполнитьНомерСтрокиТаблицы(ТочкиУчета);
	ЗаполнитьНомерСтрокиТаблицы(ШкалыПриборовУчета);
	ЗаполнитьНомерСтрокиТаблицы(ПоказанияПриборовУчета);
	
	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Организация,ТочкиУчета,ШкалыПриборовУчета,ПоказанияПриборовУчета,Район); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Организация,ТаблицаПоказанийДляЗаполнения,Дата);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,ПоказанияПриборовУчета);
		
	ДанныеТаблиц = Новый Структура("ТочкиУчета, ШкалыПриборовУчета, ПоказанияПриборовУчета, Ссылка", ТочкиУчета, ШкалыПриборовУчета, ПоказанияПриборовУчета, Неопределено);
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(ДанныеТаблиц, ДанныеТаблиц, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
	ЗаполнитьАбонентов();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНомерСтрокиТаблицы(ТаблицаНумерации)
	
	НомерСтроки = 0;
	Для Каждого ТекСтрока из ТаблицаНумерации Цикл
		НомерСтроки 			= НомерСтроки + 1;
		ТекСтрока.НомерСтроки	= НомерСтроки;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАбонентов()
	
	Ключи 			= ТочкиУчета.Выгрузить(,"КлючПомещения").ВыгрузитьКолонку("КлючПомещения");
	КлючиАбонентов 	= АбонентыКлючейПомещений(Ключи);
	Для Каждого СтрТУ Из ТочкиУчета Цикл
		СтрТУ.Абонент = КлючиАбонентов.Получить(СтрТУ.КлючПомещения);
	КонецЦикла; 
	
КонецПроцедуры  

&НаСервере
Функция АбонентыКлючейПомещений(Ключи)
	
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргАбоненты.Ссылка КАК Абонент,
		|	энргАбоненты.КлючПомещения КАК КлючПомещения
		|ИЗ
		|	Справочник.энргАбоненты КАК энргАбоненты
		|ГДЕ
		|	НЕ энргАбоненты.ПометкаУдаления
		|	И энргАбоненты.КлючПомещения В(&КлючПомещения)
		|	И энргАбоненты.Организация = &Организация";
	
	Запрос.УстановитьПараметр("КлючПомещения"	, Ключи);
	Запрос.УстановитьПараметр("Организация"		, Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Результат.Вставить(ВыборкаДетальныеЗаписи.КлючПомещения,ВыборкаДетальныеЗаписи.Абонент);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СобытияТаблицыФормыЕстьШкалыЕстьТарифныеЗоны

&НаКлиенте
Процедура ТочкиУчетаПриИзменении(Элемент)
	
	ТекущаяСтрока 				= Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущаяСтрока;
	ЗаполнитьПриборыУчетаСервер(ТекущаяСтрока);
		
КонецПроцедуры

#Область СобытияТаблицыФормыТочкиУчетаЕстьШкалыЕстьТарифныеЗоны

&НаКлиенте
Процедура ПроверкаУдаленияСтроки(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросУдаленияСтроки",ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Удалить всю строку вместо значения ячейки?",РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросУдаленияСтроки(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			энргРаботаСПоставщикамиКлиент.ПередУдалением(ЭтаФорма,ДополнительныеПараметры.ТекущиеДанные);
			Объект[ДополнительныеПараметры.ТЧ].Удалить(ДополнительныеПараметры.НомерСтроки);	
		КонецЕсли;
		
	КонецЕсли;	
КонецПроцедуры

#КонецОбласти

#Область СобытияТаблицыФормыПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны

&НаКлиенте
Процедура ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоныТекущиеПоказанияПриИзменении(Элемент)
