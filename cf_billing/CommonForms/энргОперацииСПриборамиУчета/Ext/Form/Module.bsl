	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	ВидКанальности 							= ТекущиеДанные.ВидКанальности;
	
	СоставКанальности 						= энргРаботаСТочкамиУчетаСервер.СоставКанальности(ВидКанальности);
	// энргРаботаСВидомКанальности {
	ПриИзмененииВидаКанальности(ЭтотОбъект,ТекущиеДанные.IDСтроки,ТекущиеДанные.IDСтрокиШкалы,СоставКанальности,"ШкалыПриборовУчета","ПоказанияПриборовУчета",Истина); 
	// энргРаботаСВидомКанальности }
	
	СоставУслуги = энргРаботаСПоставщикамиСервер.ПолучитьСоставУслугиСоШкалами(Услуга, ВидКанальности);
	бестРаботаСТочкамиУчетаНПКлиент.ПриИзмененииВидаКанальности(ЭтотОбъект, ТекущиеДанные, СоставУслуги, "ШкалыУслуг", Истина);
	
	Если ЗначениеЗаполнено(ВидКанальности) Тогда
		
		СтрокиШкал = ШкалыПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки",ТекущиеДанные.IDСтрокиШкалы));
		Для Каждого ТекСтрокаШкал из СтрокиШкал Цикл
			
			СтрокаТарЗон = ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки",ТекСтрокаШкал.IDСтрокиТарифнаяЗона));			
			Если СтрокаТарЗон.Количество() = 0 Тогда
				ДобавитьСтрокуСТарфинойЗоной(ТекСтрокаШкал.IDСтрокиТарифнаяЗона,0);				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ТочкиУчетаЕстьШкалыНетТарифныхЗонПриАктивизацииСтроки(Элемент);
	
КонецПроцедуры

