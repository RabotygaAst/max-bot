КонецПроцедуры

&НаСервере
Функция ПолучитьСписокУслугДляВыбора(ТекУслуга)
	
	СписокУслуг = Новый СписокЗначений; 	
	СписокУслуг.Добавить(ТекУслуга);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргВидыУслугСоставляющиеУслуг.Услуга КАК Услуга
	|ИЗ
	|	Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|ГДЕ
	|	энргВидыУслугСоставляющиеУслуг.Ссылка В(&СписокУслуг)";
	
	Запрос.УстановитьПараметр("СписокУслуг", СписокУслуг);
	
	РезультатЗапроса 		= Запрос.Выполнить();   	
	ВыборкаДетальныеЗаписи 	= РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СписокУслуг.Добавить(ВыборкаДетальныеЗаписи.Услуга);
	КонецЦикла;
	
	Возврат СписокУслуг;
	
КонецФункции

&НаКлиенте
Процедура ПередУдалениемОбщая() 
	
	ИмяТаблицыТочек 	= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 		= Элементы[ИмяТаблицыТочек].ТекущиеДанные;  	
	
	ТаблицыФормы	= Новый Массив;	
	ТаблицыФормы.Добавить("ШкалыПриборовУчета");
	
	ТаблицыФормыВторогоУровня	= Новый Массив;
	ТаблицыФормыВторогоУровня.Добавить("ПоказанияПриборовУчета");
	
	УдалитьЗависимыеСтроки(ТекущиеДанные.IDСтрокиШкалы, ЭтотОбъект, ТаблицыФормы, "", ТаблицыФормыВторогоУровня,"IDСтроки");
	
	ТаблицыФормы	= Новый Массив;	
	ТаблицыФормы.Добавить("ШкалыУслуг");
	ТаблицыФормы.Добавить("ФормулыРасчетаУслуг");
	
	Если ПриборыУзловУчета.Количество() = 1 Тогда
		УдалитьЗависимыеСтроки(ТекущиеДанные.IDСтроки, ЭтотОбъект, ТаблицыФормы,,,"IDСтроки");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСтрокуСТарфинойЗоной(IDСтрокиТарифнаяЗона,ТекущиеПоказания)
	
	//Показания
	СтрокаПоказаний 					= ПоказанияПриборовУчета.Добавить();
	СтрокаПоказаний.IDСтроки           	= IDСтрокиТарифнаяЗона;
	СтрокаПоказаний.IDСтрокиТочкиУчета 	= IDСтроки;
	СтрокаПоказаний.ТарифнаяЗона 		= ПредопределенноеЗначение("Справочник.энргТарифныеЗоны.БезРазбивки");
	СтрокаПоказаний.ТекущиеПоказания 	= ТекущиеПоказания;
	
КонецПроцедуры

#КонецОбласти


