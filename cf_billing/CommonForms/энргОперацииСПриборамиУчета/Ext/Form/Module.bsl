#Область СОБЫТИЯ_ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	IDСтроки 						= Параметры.IDСтроки;
	Услуга 							= Параметры.Услуга;
	
	//Если Параметры.ПриборыУзловУчета.Количество() > 0 Тогда
		ЗаполнитьТЧИзПараметров(Параметры.ПриборыУзловУчета			, ПриборыУзловУчета);
		ЗаполнитьТЧИзПараметров(Параметры.ШкалыПриборовУчета		, ШкалыПриборовУчета);
		ЗаполнитьТЧИзПараметров(Параметры.ПоказанияПриборовУчета	, ПоказанияПриборовУчета);
		ЗаполнитьТЧИзПараметров(Параметры.ФормулыРасчетаУслуг		, ФормулыРасчетаУслуг);
		ЗаполнитьТЧИзПараметров(Параметры.ШкалыУслуг				, ШкалыУслуг);
	//Иначе
	//	ЗаполнитьТЧИзПараметров(Параметры.ПриборыУзловУчета			, ПриборыУзловУчета);
	//	ЗаполнитьТЧИзПараметров(Параметры.ШкалыПриборовУчета		, ШкалыПриборовУчета);
		Для каждого стр из ШкалыПриборовУчета Цикл
			Если НЕ ЗначениеЗаполнено(стр.IDСтрокиТарифнаяЗона) Тогда
				стр.IDСтрокиТарифнаяЗона = Новый УникальныйИдентификатор;
			КонецЕсли;
		КонецЦикла;
	//КонецЕсли;

	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета,Неопределено);
	
	УправлениеВидимостью(Параметры, "ЭлементыДляСкрытия"	, Ложь);
	УправлениеВидимостью(Параметры, "ЭлементыДляОтображения", Истина);
	
	//Если Параметры.Свойство("ЭлементыДляСкрытия") Тогда
	//	Для Каждого ТекЭлемент Из Параметры.ЭлементыДляСкрытия Цикл	
	//		Элемент = СтрЗаменить(ТекЭлемент,"ПрефиксТочекУчета",ПрефиксТочекУчета);
	//		УправлениеВидимостью(Элемент,Ложь);
	//	КонецЦикла;
	//КонецЕсли;
	
	мСписокУслуг 					= энргРаботаСПоставщикамиСервер.ПолучитьСоставУслуги(Услуга);
	ТаблицаФормулыРасчетаУслуг 		= Элементы.ФормулыРасчетаУслуг;
	ПолеУслуга  					= ТаблицаФормулыРасчетаУслуг.ПодчиненныеЭлементы.Найти("ФормулыРасчетаУслугУслуга");
	ПолеУслуга.СписокВыбора.ЗагрузитьЗначения(мСписокУслуг);
	
	//Если Параметры.ПриборыУзловУчета.Количество() > 0 Тогда
	//	//Для каждого стр из ПриборыУзловУчета Цикл
	//	//	стр.ВидИзмерителя = стр.ТипПрибораУчета.Родитель;
	//	//КонецЦикла;
	//Иначе
		Для каждого стр из ПриборыУзловУчета Цикл
			Если не ЗначениеЗаполнено(стр.IDСтроки) тогда
				стр.IDСтроки = Новый УникальныйИдентификатор;
			КонецЕсли;
		КонецЦикла;
	//КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЧИзПараметров(ТабЧастьИзДокумента,Таблица)
	Для Каждого ТекСтрока из ТабЧастьИзДокумента Цикл
		НоваяСтрока = Таблица.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,ТекСтрока);
	КонецЦикла;
КонецПроцедуры 

&НаСервере
Процедура УправлениеВидимостью(Параметры, Свойство, Видимость)	
	
	Если Параметры.Свойство(Свойство) Тогда
		ИзменяемыеЭлементы = Параметры[Свойство];
		Для Каждого ТекЭлемент Из ИзменяемыеЭлементы Цикл	
			ИмяЭлемента = СтрЗаменить(ТекЭлемент, "ПрефиксТочекУчета", ПрефиксТочекУчета);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяЭлемента, "Видимость", Видимость); 
		КонецЦикла;
	КонецЕсли;
	
	//Элементы[Элемент].Видимость = Видимость;	
	
КонецПроцедуры

#КонецОбласти

#Область ВОЗВРАТ_РЕЗУЛЬТАТА

&НаКлиенте
Процедура Ок(Команда)
	ПараметрыЗакрытия = Новый Структура;
	ПараметрыЗакрытия.Вставить("ПриборыУзловУчета"		,ПриборыУзловУчета);
	ПараметрыЗакрытия.Вставить("ШкалыПриборовУчета"		,ШкалыПриборовУчета);
	ПараметрыЗакрытия.Вставить("ПоказанияПриборовУчета"	,ПоказанияПриборовУчета);
	ПараметрыЗакрытия.Вставить("ФормулыРасчетаУслуг"	,ФормулыРасчетаУслуг);
	ПараметрыЗакрытия.Вставить("ШкалыУслуг"				,ШкалыУслуг);
	
	Закрыть(ПараметрыЗакрытия);
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	Закрыть();
КонецПроцедуры

#КонецОбласти

#Область ПЕРЕОПРЕДЕЛЕННЫЕ_МЕТОДЫ

&НаКлиенте
Процедура ПриИзмененииВидаКанальности(Форма,IDСтрокиТочкиУчета,IDСтроки,Шкалы,ИмяТаблицыШкалы,ИмяТаблицыПоказания, ДанныеФормы = Ложь)
	
	Если не ЗначениеЗаполнено(IDСтроки) тогда
		IDСтроки 							= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	Если не ДанныеФормы тогда 
		КоллекцияШкалы							= Форма.Объект[ИмяТаблицыШкалы];
		КоллекцияТарифныеЗоны					= Форма.Объект[ИмяТаблицыПоказания];
	иначе
		КоллекцияШкалы							= Форма[ИмяТаблицыШкалы];
		КоллекцияТарифныеЗоны					= Форма[ИмяТаблицыПоказания]; 		
	КонецЕсли;
	
	// Ищем строки по индентификатору
	СтруктураПоиска  						= Новый Структура("IDСтроки",IDСтроки);
	
	СтрокиШкалыУдалить						= КоллекцияШкалы.НайтиСтроки(СтруктураПоиска);	
	
	для Каждого СтрокаШкалаУдалить из СтрокиШкалыУдалить цикл		
		СтрокиТарифныхЗон 					= КоллекцияТарифныеЗоны.НайтиСтроки(Новый Структура("IDСтроки", СтрокаШкалаУдалить["IDСтрокиТарифнаяЗона"]));//["IDСтроки"]));
		для Каждого СтрокаТарифнойЗоны из СтрокиТарифныхЗон цикл
			КоллекцияТарифныеЗоны.Удалить(СтрокаТарифнойЗоны);
		КонецЦикла;   		
		КоллекцияШкалы.Удалить(СтрокаШкалаУдалить);		
	КонецЦикла;  	 
	
	
	для Каждого Шкала из Шкалы цикл		
		СтрокаШкалы 						= КоллекцияШкалы.добавить();
		СтрокаШкалы["IDСтрокиТочкиУчета"]	= IDСтрокиТочкиУчета;
		СтрокаШкалы["IDСтроки"]				= IDСтроки;
		СтрокаШкалы["IDСтрокиТарифнаяЗона"]	= Новый УникальныйИдентификатор;
		СтрокаШкалы.Шкала		 			= Шкала;				
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЗависимыеСтроки(IDСтроки, Объект, ТаблицыФормы, ПостФиксКолонки = "", ТаблицыВторогоУровня = Неопределено, РеквизитID)
	
	СтруктураПоиска  				= Новый Структура(РеквизитID + ПостФиксКолонки,IDСтроки);
	Для Каждого ТаблицаФормы из ТаблицыФормы цикл
		Коллекция  					= Объект[ТаблицаФормы];
		Строки  					= Коллекция.НайтиСтроки(СтруктураПоиска);	
		Для Каждого УдаляемаяСтрока из Строки Цикл 
			Если ТаблицыВторогоУровня <> Неопределено Тогда 
				СтруктураПоиска2  				= Новый Структура(РеквизитID,УдаляемаяСтрока.IDСтрокиТарифнаяЗона);//IDСтроки);
				Для Каждого ТаблицаФормы2 Из ТаблицыВторогоУровня Цикл
					Коллекция2  				= Объект[ТаблицаФормы2];
					Строки2  					= Коллекция2.НайтиСтроки(СтруктураПоиска2);	
					Для Каждого УдаляемаяСтрока2 из Строки2 Цикл 
						Коллекция2.Удалить(УдаляемаяСтрока2);
					КонецЦикла;
				КонецЦикла;			
			КонецЕсли;
			
			Коллекция.Удалить(УдаляемаяСтрока);
		КонецЦикла; 
	КонецЦикла;  
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииВидаДифференцированности(Форма,IDСтроки,IDСтрокиТочкиУчета,Состав,ИмяТабЧасти,ИмяТабЧастиФормулы,ДанныеФормы  = Ложь, ВыводПрибораУчета = Неопределено)
	
	СоотвествиеПоказаний 							= Новый Соответствие;
	
	Если не ЗначениеЗаполнено(IDСтроки) тогда
		IDСтроки 									= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	Если не ДанныеФормы тогда 
		Коллекция 									= Форма.Объект[ИмяТабЧасти];
	иначе
		Коллекция 									= Форма[ИмяТабЧасти];
	КонецЕсли;
	
	// Ищем строки по индентификатору
	СтруктураПоиска  								= Новый Структура("IDСтроки",IDСтроки);
	Если ВыводПрибораУчета <> Неопределено тогда
		СтруктураПоиска.Вставить("ВыводПрибораУчета", ВыводПрибораУчета);
	КонецЕсли;
	
	СтрокиСоотвествия 								= Коллекция.НайтиСтроки(СтруктураПоиска);	
	
	для Каждого СтрокаСоотвествия из СтрокиСоотвествия цикл
		СоотвествиеПоказаний.Вставить(СтрокаСоотвествия.ТарифнаяЗона,СтрокаСоотвествия.ТекущиеПоказания);
		Коллекция.Удалить(СтрокаСоотвествия);
	КонецЦикла;  	 
	
	для Каждого СтрокаСостава из Состав цикл		
		СтрокаПоказаний 							= Коллекция.добавить();
		СтрокаПоказаний.IDСтроки 					= IDСтроки;
		СтрокаПоказаний.IDСтрокиТочкиУчета 			= IDСтрокиТочкиУчета;
		СтрокаПоказаний.ТарифнаяЗона 				= СтрокаСостава;
		Если СоотвествиеПоказаний[СтрокаСостава] <> Неопределено тогда
			СтрокаПоказаний.ТекущиеПоказания 	= СоотвествиеПоказаний[СтрокаСостава];
		КонецЕсли; 
		
		Если ВыводПрибораУчета<>Неопределено тогда
			СтрокаПоказаний.ВыводПрибораУчета 		= ВыводПрибораУчета;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ВСПОМОГАТАЕЛЬНЫЕ_МЕТОДЫ

