&НаКлиенте
Процедура ТочкиУчетаНетШкалНетТарифныхЗонТекущиеПоказанияПриИзменении(Элемент)
	ТекущиеДанные 	= Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	ЗаполнитьПоказания(ТекущиеДанные.IDСтрокиШкалы,ТекущиеДанные.ТекущиеПоказания);	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоказания(IDСтрокиШкалы, ТекущиеПоказания)
	
	МассивСтрокШкал = ШкалыПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки",IDСтрокиШкалы));
	Если МассивСтрокШкал.количество() > 0 Тогда
		МассивСтрокПоказаний = ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки",МассивСтрокШкал[0].IDСтрокиТарифнаяЗона));
		Если МассивСтрокПоказаний.количество() > 0 Тогда
			МассивСтрокПоказаний[0].ТекущиеПоказания = ТекущиеПоказания;  
		КонецЕсли;	 
	КонецЕсли;
	
КонецПроцедуры 

