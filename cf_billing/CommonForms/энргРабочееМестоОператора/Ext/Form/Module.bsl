#Область РаботаСДаннымиПомещения

&НаСервереБезКонтекста
Процедура ДополнитьДаннымиПомещения(ПоляАбонента, Результат)
	
	ПакетРезультатов = энргРаботаСРабочимМестомОператора.РезультатЗапросаДанныеПомещения(ПоляАбонента.ТекущаяДата, ПоляАбонента.Организация, ПоляАбонента.Район, ПоляАбонента.КлючПомещения, ПоляАбонента.Абонент);
	ЧислоПакетов	 = ПакетРезультатов.Количество();
	
	РезультатЗапроса = ПакетРезультатов[ЧислоПакетов - 2];
	ОбработатьРезультатЗапросаКоличестваЧеловек(РезультатЗапроса, Результат);
	
	РезультатЗапроса = ПакетРезультатов[ЧислоПакетов - 1];
	ОбработатьРезультатЗапросаЗначенияПлощадей(РезультатЗапроса, Результат);
	
КонецПроцедуры


&НаСервереБезКонтекста
Процедура ОбработатьРезультатЗапросаКоличестваЧеловек(РезультатЗапроса, Результат)
	
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	
	Выборка	= РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	ЗаполнитьЗначенияСвойств(Результат, Выборка);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОбработатьРезультатЗапросаЗначенияПлощадей(РезультатЗапроса, Результат)
	
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	
	Выборка	= РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Новый Структура("ВидПлощади, Значение");
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);		
		
		Результат.СписокПлощадей.Добавить(НоваяСтрока);
	КонецЦикла; 
	
КонецПроцедуры

