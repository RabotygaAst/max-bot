	Результат.Вставить("АдресОбъектаБезУсловий");	
	Результат.Вставить("ВидОбъекта");
	Результат.Вставить("МКД");
	Результат.Вставить("РабочийТелефон");
	Результат.Вставить("ДомашнийТелефон");
	Результат.Вставить("ЭлектроннаяПочта");
	Результат.Вставить("СуммаКОплате", 0);
	Результат.Вставить("СуммаКОплатеПени", 0);
	Результат.Вставить("СуммаЗадолженностиНаДату", 0);	
	Результат.Вставить("СостояниеЛС", Ложь);
	Результат.Вставить("ДатаСостоянияЛС", Дата(1, 1, 1));
	Результат.Вставить("ДанныеЗадолженностиНа", Дата(1, 1, 1));
	Результат.Вставить("Договор");
	Результат.Вставить("ПризнакСудебнойЗадолженности", Ложь);
	Результат.Вставить("ПризнакРассрочкиЗадолженности", Ложь);
			
	Возврат Результат;
	
