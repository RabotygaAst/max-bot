&НаКлиенте
Процедура ЗаполнитьОбщиеДанныеАбонента()
	
	УстановитьОтборыПоАбонентуСвязанныеВкладки(); 	
	УстановитьВидимостьДанныхТочекУчета(Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ОткрытьАбонента",
		"Заголовок",
		?(ЗначениеЗаполнено(ТекАбонент), Строка(ТекАбонент), "<Абонент не выбран>"));
	
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ЛицевойСчет",
		"Видимость",
		Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"АдресОбъекта",
		"Видимость",
		Истина);	
		
	ПоляАбонента 			   = ОсновныеПоляАбонента();
	ДополнительныеПоляАбонента = НовыеДополнительныеПоляАбонента();
	ПоляПомещения 			   = НовыеПоляДанныхПомещения();
	
	ЗаполнитьОбщиеДанныеАбонентаНаСервере(ПоляАбонента, ДополнительныеПоляАбонента, ПоляПомещения);
	ЗаполнитьНаФормеПолученныеПоля(ДополнительныеПоляАбонента, ПоляПомещения);	
	УстановитьВидимостьСостоянияЛС();
	УстановитьВидимостьНаличияРассрочкиИСудебнойЗадолженности();
		
	ЗначенияПлощадей.Очистить();
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ПоляПомещения.СписокПлощадей, ЗначенияПлощадей);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, 
		"ЗначенияПлощадей", 
		"Видимость", 
		ЗначенияПлощадей.Количество() > 0);		
		
	ЗаполнитьОбщиеДанныеАбонентаПереопределяемый(ПоляАбонента);
	
КонецПроцедуры

