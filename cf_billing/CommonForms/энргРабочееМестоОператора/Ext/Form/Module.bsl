#Область СобытияВкладкиКарточкаАбонента

&НаКлиенте
Процедура ОбновитьКарточкуКлиент(ПериодФормированияНачало,ПериодФормированияКонец) 
	Ошибка = Ложь;
	Если НЕ ЗначениеЗаполнено(ТекАбонент) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран абонент");
		Ошибка = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПериодФормированияКарточки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран период формирования");
		Ошибка = Истина;
	КонецЕсли;
	
	Если Ошибка Тогда 
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСостояниеПоляТабличногоДокумента(Элементы.РезультатОтчетаКарточка, "ФормированиеОтчета");
	// 1. Запуск фонового задания на сервере.
	ДлительнаяОперация = ОбновитьКарточкуСервер(ПериодФормированияНачало, ПериодФормированияКонец, ТекАбонент, ТекКлючПомещения, ТекОрганизация);
	
	// 2. Подключение обработчика завершения фонового задания.
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	Оповещение = Новый ОписаниеОповещения("Подключаемый_ПроверитьВыполнениеЗадания", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ОбновитьКарточкуСервер(НачалоПериода,КонецПериода,Абонент,КлючПомещения,Организация) 
	
	ПараметрыКарточки = Новый Структура(
		"НачалоПериода,КонецПериода,Район,МКД,Абонент,КлючПомещения,Организация,МораторнаяЗадолженность,РеструктуризированнаяЗадолженность",
		НачалоПериода,КонецПериода,Район,?(КлючПомещения.ЧастныйСектор,Справочники.энргСтроения.ПустаяСсылка(),КлючПомещения.Строение),Абонент,КлючПомещения,Организация,Истина,Истина);
	
	Если ЗначениеЗаполнено(ИдентификаторЗадания) Тогда
		ДлительныеОперации.ОтменитьВыполнениеЗадания(ИдентификаторЗадания);
	КонецЕсли;
	Если ЗначениеЗаполнено(АдресХранилища) Тогда 
		УдалитьИзВременногоХранилища(АдресХранилища);
	КонецЕсли;
	
	ИдентификаторАдресаХранилища = Новый УникальныйИдентификатор;
	АдресХранилища = ПоместитьВоВременноеХранилище(Неопределено, ИдентификаторАдресаХранилища);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ПараметрыВыполнения.ОжидатьЗавершение = 0; // запускать сразу
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Формирование карточки абонента'");
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения,
		"Отчеты.энргКарточкаАбонента.СформироватьСобытияАбонента", 
		ПараметрыКарточки,
		АдресХранилища);
	
	ИдентификаторЗадания = ДлительнаяОперация.ИдентификаторЗадания;
	АбонентКарточка = ТекАбонент;
	РезультатОтчетаКарточка.Очистить();
	
	Если ДлительнаяОперация.Статус = "Выполнено" Тогда
		РезультатОтчетаКарточка = ПолучитьИзВременногоХранилища(АдресХранилища);
		СменитьСостояниеОтображенияКарточкиАбонента(Элементы.РезультатОтчетаКарточка);	
		УдалитьИзВременногоХранилища(АдресХранилища);
	КонецЕсли;  
	
	Возврат ДлительнаяОперация; 
	
КонецФункции

&НаКлиенте
Процедура Подключаемый_ПроверитьВыполнениеЗадания(Результат, ДополнительныеПараметры) Экспорт  
	
	СменитьСостояниеОтображенияКарточкиАбонента(Элементы.РезультатОтчетаКарточка);
	
	Если Результат = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		УдалитьИзВременногоХранилища(АдресХранилища);
		ПоказатьПредупреждение( ,Результат.КраткоеПредставлениеОшибки);
		
		Возврат;
	КонецЕсли;
	
	РезультатОтчетаКарточка = ПолучитьИзВременногоХранилища(АдресХранилища);
	УдалитьИзВременногоХранилища(АдресХранилища);
		
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура СменитьСостояниеОтображенияКарточкиАбонента(РезультатОтчетаКарточка)
	
	ОтображениеСостояния = РезультатОтчетаКарточка.ОтображениеСостояния;
	ОтображениеСостояния.Видимость 	= Ложь;
	ОтображениеСостояния.ДополнительныйРежимОтображения = ДополнительныйРежимОтображения.НеИспользовать;	
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ВыбратьОперациюИзСписка(СписокОпераций,Элемент)
	
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВыбратьОперациюИзСпискаЗавершение",ЭтотОбъект);
	
	Если Элемент = Неопределено Тогда
		ПоказатьВыборИзМеню(ОписаниеОповещения,СписокОпераций,);
	Иначе
		ПоказатьВыборИзМеню(ОписаниеОповещения,СписокОпераций,Элемент);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьОперациюИзСпискаЗавершение(ВыбранныйЭлемент,ДополнительныеПараметры) Экспорт 
	
	Если ВыбранныйЭлемент = Неопределено тогда
		Возврат;
	КонецЕсли;
	ВидОперации 		= Неопределено;
	МассивСтрок  		= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВыбранныйЭлемент.значение,"__");
	ИмяДокумента  		= МассивСтрок[0];
	Если МассивСтрок.количество()> 1 тогда
		ВидОперации 	= МассивСтрок[1]; 
	КонецЕсли;
	
	ОткрытьФормуНовогоДокумента(ИмяДокумента,ВидОперации);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуНовогоДокумента(ИмяДокумента,ВидОперации,ЗаполнитьДокумент = истина, ДопЗначЗапол = Неопределено)
	
	ПараметрыФормы = Новый Структура;
	
	ПараметрыФормы.Вставить("ЗаполнитьДокумент",ЗаполнитьДокумент);
	Если ЗаполнитьДокумент тогда
		ЗначенияЗаполнения  				= энргРаботаСЛицевымСчетомКлиент.СтруктруаЗначенийЗаполненияАбонента();
		ЗначенияЗаполнения.КлючПомещения  	= ТекКлючПомещения;
		ЗначенияЗаполнения.Организация  	= ТекОрганизация;
		ЗначенияЗаполнения.Район		  	= текРайон;
		ЗначенияЗаполнения.Абонент  		= ТекАбонент; 
		ЗначенияЗаполнения.Вставить("Дата", ТекущаяДата());
	иначе
		ЗначенияЗаполнения = Новый Структура;
	КонецЕсли;
	
	Если ТипЗнч(ДопЗначЗапол) = Тип("Структура") Тогда
		Для каждого ТекЗнач Из ДопЗначЗапол Цикл
			ЗначенияЗаполнения.Вставить(ТекЗнач.Ключ, ТекЗнач.Значение);
		КонецЦикла;
	КонецЕсли;
	ЕСли ВидОперации <>Неопределено тогда
		ЗначенияЗаполнения.Вставить("ВидОперации",ПредопределенноеЗначение("Перечисление.энргВидыОпераций." + ВидОперации));
	КонецЕсли;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения",ЗначенияЗаполнения);
	ОткрытьФорму("Документ." + ИмяДокумента +".ФормаОбъекта",ПараметрыФормы); 
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОткрытияСсылки(Элемент,ТаблицаИстории,СтандартнаяОбработка, ОтборПоАбоненту = Ложь)
	Если ТаблицаИстории = "" тогда
		Возврат;
	КонецЕсли;
	СтандартнаяОбработка 	= Ложь;
	
	СтруктураОтбора  = Новый Структура;
	Если ОтборПоАбоненту Тогда
		СтруктураОтбора.Вставить("Абонент",ТекАбонент);	
	Иначе
		СтруктураОтбора.Вставить("КлючПомещения",ТекКлючПомещения);
	КонецЕсли;
	
	ПараметрыОткрытия  = Новый Структура("Отбор",СтруктураОтбора);
	ОткрытьФорму("РегистрСведений." + ТаблицаИстории + ".ФормаСписка",ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
