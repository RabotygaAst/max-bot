&НаКлиенте
Процедура ДокументыАбонентаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекДанные = Элементы.ДокументыАбонента.ТекущиеДанные;
	
	Если ТекДанные.Тип = Тип("ДокументСсылка.энргВводНачальныхОстатков") Тогда
		
		ПараметрыФормы = Новый Структура("Ключ", ВыбраннаяСтрока);
		ПараметрыФормы.Вставить("Абонент", ТекАбонент);
		ОткрытьФорму("Документ.энргВводНачальныхОстатков.ФормаОбъекта", ПараметрыФормы);
		
	КонецЕсли;
	
КонецПроцедуры

