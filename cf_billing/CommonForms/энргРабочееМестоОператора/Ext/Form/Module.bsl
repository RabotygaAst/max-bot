&НаКлиенте
Процедура Начисление(Команда)
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("ВыполнятьВФоне"	, Ложь);
	ПараметрыЗаполнения.Вставить("Организация"		, ТекОрганизация);
	ПараметрыЗаполнения.Вставить("Район"			, текРайон);
	
	СтруктураВозврат = ПолучитьСтроение();
	ПараметрыЗаполнения.Вставить("ОтборПоДому"	, СтруктураВозврат.ОтборПоДому);
	ПараметрыЗаполнения.Вставить("Дом"			, СтруктураВозврат.Дом);
	ОткрытьФорму("ОбщаяФорма.энргВыполнениеНачислений",Новый Структура("ПараметрыЗаполнения",ПараметрыЗаполнения),,Новый УникальныйИдентификатор);
КонецПроцедуры

