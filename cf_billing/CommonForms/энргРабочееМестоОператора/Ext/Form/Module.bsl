&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Элементы.СуммаКОплате.Заголовок = "Задолженность, с учетом тек. периода";
	Элементы.СуммаКОплатеПени.Заголовок = "в том числе пени";
	КолвоМесяцевДоПоверки			= 2;
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ДокументыАбонента,"Абонент",ТекАбонент);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ЖильцыЛьготныхКатегорий,"Абонент",ТекАбонент);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ЖильцыЛьготныхКатегорий,"Период",ТекущаяДата());	
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ЛицевойСчет",
		"Видимость",
		Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"АдресОбъекта",
		"Видимость",
		Ложь);	
	
	УстановитьВидимостьДанныхТочекУчета(Ложь);
	
	#Если ВебКлиент Тогда
		Элементы.СтрокаПоискаАбонента.Видимость = Ложь;
		Элементы.НайтиАбонентаПоСтрокеПоиска.Видимость = Ложь;
	#Иначе
		Элементы.НайтиАбонентаПоСтрокеПоискаГиперссылка.Видимость = Ложь;
	#КонецЕсли
	
КонецПроцедуры   

&НаКлиенте
Процедура СтраницыСведенияОбАбонентеПриСменеСтраницы(Элемент, ТекущаяСтраница)
	Если ТекущаяСтраница = Элементы.СтраницыСведенияОбАбоненте.ПодчиненныеЭлементы.СтраницаКарточкаАбонента тогда
		Если ТекАбонент <> АбонентКарточка тогда			
			ПериодФормированияКонец 					= КонецМесяца(ТекущаяДата()) + 1;
			ПериодФормированияНачало  					= ДобавитьМесяц(ПериодФормированияКонец, -4);
			
			ПериодФормированияКарточки.ДатаНачала 		= ПериодФормированияНачало;
			ПериодФормированияКарточки.ДатаОкончания 	= ПериодФормированияКонец;
			
			ОбновитьКарточкуКлиент(ПериодФормированияНачало,ПериодФормированияКонец);
		КонецЕсли;
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницыСведенияОбАбоненте.ПодчиненныеЭлементы.СтраницаПриборыСИстекающимСрокомПоверки 
		И ПриборыСИстекающимСрокомПоверки.Количество() = 0 тогда
		
		ОбновитьПриборыСИстекающимСрокомПоверкиНаСервере();
		
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницыСведенияОбАбоненте.ПодчиненныеЭлементы.СтраницаПрикрепленныеФайлы Тогда
		ЗаполнитьПрисоединенныеФайлы();
		
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницыСведенияОбАбоненте.ПодчиненныеЭлементы.СтраницаИсторияОплаты Тогда
		ОбновитьТаблицуИсторииОплат();
	КонецЕсли;
КонецПроцедуры

