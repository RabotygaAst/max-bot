&НаСервере
Процедура ОбновитьТаблицуИсторииОплат()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргИсторияОплаты.Период КАК Период,
	|	энргИсторияОплаты.Регистратор КАК Регистратор,
	|	энргИсторияОплаты.Абонент КАК Абонент,
	|	энргИсторияОплаты.ДатаПлатежа КАК ДатаПлатежа,
	|	ВЫБОР
	|		КОГДА энргИсторияОплаты.СуммаПлатежа = 0
	|			ТОГДА энргИсторияОплаты.СуммаКРаспределению
	|		ИНАЧЕ энргИсторияОплаты.СуммаПлатежа
	|	КОНЕЦ КАК СуммаПлатежа,
	|	энргИсторияОплаты.ИсточникПоступления КАК ИсточникПоступления,
	|	"""" КАК Примечание,
	|	энргИсторияОплаты.СуммаАвизо КАК СуммаАвизо
	|ИЗ
	|	РегистрСведений.энргИсторияОплаты КАК энргИсторияОплаты
	|ГДЕ
	|	НЕ энргИсторияОплаты.Регистратор ССЫЛКА Документ.энргПлатежноеПоручениеВходящие
	|	И энргИсторияОплаты.Организация = &Организация
	|	И энргИсторияОплаты.Район = &Район
	|	И энргИсторияОплаты.Абонент = &Абонент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргПлатежноеПоручениеВходящие.Дата,
	|	энргПлатежноеПоручениеВходящие.Ссылка,
	|	энргПлатежноеПоручениеВходящиеОплата.Абонент,
	|	энргПлатежноеПоручениеВходящиеОплата.ДатаПлатежногоДокумента,
	|	энргПлатежноеПоручениеВходящиеОплата.СуммаОплаты,
	|	энргПлатежноеПоручениеВходящие.ИсточникПоступления,
	|	энргПлатежноеПоручениеВходящиеОплата.Примечание,
	|	энргПлатежноеПоручениеВходящиеОплата.Авизо
	|ИЗ
	|	Документ.энргПлатежноеПоручениеВходящие КАК энргПлатежноеПоручениеВходящие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПлатежноеПоручениеВходящие.Оплата КАК энргПлатежноеПоручениеВходящиеОплата
	|		ПО энргПлатежноеПоручениеВходящие.Ссылка = энргПлатежноеПоручениеВходящиеОплата.Ссылка
	|			И (энргПлатежноеПоручениеВходящие.Проведен)
	|			И (энргПлатежноеПоручениеВходящиеОплата.Абонент = &Абонент)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргПлатежноеПоручениеВходящие.Дата,
	|	энргПлатежноеПоручениеВходящие.Ссылка,
	|	энргПлатежноеПоручениеВходящиеПереносСуммыОплаты.АбонентПереноса,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	энргПлатежноеПоручениеВходящиеПереносСуммыОплаты.СуммаПереноса,
	|	энргПлатежноеПоручениеВходящие.ИсточникПоступления,
	|	"""",
	|	NULL
	|ИЗ
	|	Документ.энргПлатежноеПоручениеВходящие КАК энргПлатежноеПоручениеВходящие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПлатежноеПоручениеВходящие.ПереносСуммыОплаты КАК энргПлатежноеПоручениеВходящиеПереносСуммыОплаты
	|		ПО энргПлатежноеПоручениеВходящие.Ссылка = энргПлатежноеПоручениеВходящиеПереносСуммыОплаты.Ссылка
	|			И (энргПлатежноеПоручениеВходящиеПереносСуммыОплаты.АбонентПереноса = &Абонент)
	|			И (энргПлатежноеПоручениеВходящие.Проведен)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргПерерасчет.Дата,
	|	энргПерерасчет.Ссылка,
	|	энргПерерасчет.Абонент,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	NULL,
	|	энргПерерасчет.ИсточникПоступления,
	|	энргПерерасчет.Примечание,
	|	энргПерерасчетКорректировкаОплаты.СуммаВозврата
	|ИЗ
	|	Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет КАК энргПерерасчет
	|		ПО энргПерерасчетКорректировкаОплаты.Ссылка = энргПерерасчет.Ссылка
	|ГДЕ
	|	энргПерерасчет.Абонент = &Абонент
	|	И энргПерерасчет.ВидОперации = &ВидОперации
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период";
	
	
	Запрос.УстановитьПараметр("Организация"	, ТекОрганизация);
	Запрос.УстановитьПараметр("Район"		, текРайон);
	Запрос.УстановитьПараметр("Абонент"		, ТекАбонент);
	Запрос.УстановитьПараметр("ВидОперации", Перечисления.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты);
	
	РезультатЗапроса 	= Запрос.Выполнить(); 	
	Выборка 			= РезультатЗапроса.Выбрать();
	ТаблицаИсторияОплат.Очистить();
	
	Пока Выборка.Следующий() Цикл
		НСтрока = ТаблицаИсторияОплат.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, Выборка);
	КонецЦикла;	
КонецПроцедуры 

#КонецОбласти


#Область НОВЫЙ_РАБОЧИЙ_СТОЛ

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоТочек

&НаКлиенте
Процедура ДеревоТочекПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда 
		Возврат;
	КонецЕсли; 	
	
	ТекТочкаУчета = ТекущиеДанные.ТочкаУчета;
	ТекПриборУчета = ТекущиеДанные.ПриборУчета;
	
	ОбновитьДеревоОтображенияПоУмолчанию(ТекущиеДанные, "ПриборУчета", "ДеревоОтображенияДанныхПоПУ", ДеревоОтображенияДанныхПоПУ, ДеревоДанныхПоПУ);
	ОбновитьДеревоОтображенияПоУмолчанию(ТекущиеДанные, "ТочкаУчета", "ДеревоОтображенияДанныхПоУслугам", ДеревоОтображенияДанныхПоУслугам, ДеревоДанныхПоУслугам);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДеревоОтображенияПоУмолчанию(ТекущиеДанные, ИмяПоляПоиска, ИмяЭлементаДереваОтображения, ДеревоОтображения, ДеревоИсточник)
	
	КоллекцияСтрокВернегоУровня = ДеревоОтображения.ПолучитьЭлементы();
	КоллекцияСтрокВернегоУровня.Очистить();
	
	ЗначениеПоиска  = ТекущиеДанные[ИмяПоляПоиска];	
	СтрокиДерева 	= ДеревоИсточник.ПолучитьЭлементы();
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		
		Если СтрокаДерева[ИмяПоляПоиска] = ЗначениеПоиска Тогда 			
			ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(КоллекцияСтрокВернегоУровня, СтрокаДерева.ПолучитьЭлементы());			
		КонецЕсли;
		
	КонецЦикла;
	
	ДеревоЭлемент = Элементы[ИмяЭлементаДереваОтображения];
	Для Каждого СтрокаДерева Из КоллекцияСтрокВернегоУровня Цикл		
