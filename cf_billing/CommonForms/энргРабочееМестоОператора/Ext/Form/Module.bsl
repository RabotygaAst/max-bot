&НаСервере
Процедура ЗаполнитьВидыБлагоустройстваТарифныеКатегории(Период,Организация,Район,КлючПомещения)  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	энргВидБлагоустройствАбонентаСрезПоследних.Услуга КАК Услуга,
	               |	энргВидБлагоустройствАбонентаСрезПоследних.ВидБлагоустройства КАК ВидБлагоустройства,
	               |	"""" КАК ГруппаПотребителей
	               |ПОМЕСТИТЬ ВТ_ВидБлагоустройства
	               |ИЗ
	               |	РегистрСведений.энргВидБлагоустройствАбонента.СрезПоследних(
	               |			&Период,
	               |			Организация = &Организация
	               |				И Район = &Район
	               |				И КлючПомещения = &КлючПомещения) КАК энргВидБлагоустройствАбонентаСрезПоследних
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	энргГруппыПотребителейАбонентовСрезПоследних.Услуга,
	               |	"""",
	               |	энргГруппыПотребителейАбонентовСрезПоследних.ГруппаПотребителей
	               |ИЗ
	               |	РегистрСведений.энргГруппыПотребителейАбонентов.СрезПоследних(
	               |			&Период,
	               |			Организация = &Организация
	               |				И Район = &Район
	               |				И КлючПомещения = &КлючПомещения) КАК энргГруппыПотребителейАбонентовСрезПоследних
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ВидБлагоустройства.Услуга КАК Услуга,
	               |	МАКСИМУМ(ВТ_ВидБлагоустройства.ВидБлагоустройства) КАК ВидБлагоустройстваИндивидуальный,
	               |	МАКСИМУМ(ВТ_ВидБлагоустройства.ГруппаПотребителей) КАК ТарифнаяКатегория
	               |ПОМЕСТИТЬ ВТ_Услуги
	               |ИЗ
	               |	ВТ_ВидБлагоустройства КАК ВТ_ВидБлагоустройства
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ_ВидБлагоустройства.Услуга
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	энргПоставщикиУслугАбонентаСрезПоследних.Услуга КАК Услуга,
	               |	МАКСИМУМ(энргПоставщикиУслугАбонентаСрезПоследних.Поставщик) КАК Поставщик
	               |ПОМЕСТИТЬ ВТ_Поставщики
	               |ИЗ
	               |	РегистрСведений.энргПоставщикиУслугАбонента.СрезПоследних(
	               |			&Период,
	               |			КлючПомещения = &КлючПомещения
	               |				И Организация = &Организация
	               |				И Район = &Район) КАК энргПоставщикиУслугАбонентаСрезПоследних
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	энргПоставщикиУслугАбонентаСрезПоследних.Услуга
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_Услуги.Услуга КАК Услуга,
	               |	ВТ_Услуги.ВидБлагоустройстваИндивидуальный КАК ВидБлагоустройстваИндивидуальный,
	               |	ВТ_Услуги.ТарифнаяКатегория КАК ТарифнаяКатегория,
	               |	ВТ_Поставщики.Поставщик КАК Поставщик
	               |ПОМЕСТИТЬ ВТ_ПоставщикиИУслуги
	               |ИЗ
	               |	ВТ_Услуги КАК ВТ_Услуги
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Поставщики КАК ВТ_Поставщики
	               |		ПО ВТ_Услуги.Услуга = ВТ_Поставщики.Услуга
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	энргЗначенияТарифовСрезПоследних.Услуга КАК Услуга,
	               |	энргЗначенияТарифовСрезПоследних.ГруппаПотребителей КАК ГруппаПотребителей,
	               |	МАКСИМУМ(энргЗначенияТарифовСрезПоследних.Значение) КАК Значение
	               |ПОМЕСТИТЬ ВТ_Тарифы
	               |ИЗ
	               |	РегистрСведений.энргЗначенияТарифов.СрезПоследних(
	               |			&Период,
	               |			Организация = &Организация
	               |				И Район = &Район
	               |				И (Услуга, Поставщик, ГруппаПотребителей) В
	               |					(ВЫБРАТЬ
	               |						вт.Услуга,
	               |						вт.Поставщик,
	               |						вт.ТарифнаяКатегория
	               |					ИЗ
	               |						ВТ_ПоставщикиИУслуги КАК вт)) КАК энргЗначенияТарифовСрезПоследних
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	энргЗначенияТарифовСрезПоследних.Услуга,
	               |	энргЗначенияТарифовСрезПоследних.ГруппаПотребителей
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Норматив.ЗначениеНорматива КАК ЗначениеНорматива,
	               |	Норматив.ВидБлагоустройства КАК ВидБлагоустройства,
	               |	Норматив.Услуга КАК Услуга
	               |ПОМЕСТИТЬ ВТ_Норматив
	               |ИЗ
	               |	ВТ_ПоставщикиИУслуги КАК ВТ_ПоставщикиИУслуги
	               |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |			энргКлючиНормативов.ВидБлагоустройства КАК ВидБлагоустройства,
	               |			энргЗначенияНормативовПотребленияСрезПоследних.Услуга КАК Услуга,
	               |			МАКСИМУМ(энргЗначенияНормативовПотребленияСрезПоследних.ЗначениеНорматива) КАК ЗначениеНорматива
	               |		ИЗ
	               |			РегистрСведений.энргЗначенияНормативовПотребления.СрезПоследних(
	               |					&Период,
	               |					Организация = &Организация
	               |						И Район = &Район
	               |						И Услуга В
	               |							(ВЫБРАТЬ
	               |								вт.Услуга
	               |							ИЗ
	               |								ВТ_ПоставщикиИУслуги КАК вт)) КАК энргЗначенияНормативовПотребленияСрезПоследних
	               |				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиНормативов КАК энргКлючиНормативов
	               |				ПО энргЗначенияНормативовПотребленияСрезПоследних.КлючНорматива = энргКлючиНормативов.Ссылка
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			энргЗначенияНормативовПотребленияСрезПоследних.Услуга,
	               |			энргКлючиНормативов.ВидБлагоустройства) КАК Норматив
	               |		ПО ВТ_ПоставщикиИУслуги.Услуга = Норматив.Услуга
	               |			И ВТ_ПоставщикиИУслуги.ВидБлагоустройстваИндивидуальный = Норматив.ВидБлагоустройства
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_Тарифы.Значение КАК ЗначениеТарифа,
	               |	ВТ_Норматив.ЗначениеНорматива КАК НормаТарифа,
	               |	ВТ_ПоставщикиИУслуги.ВидБлагоустройстваИндивидуальный КАК ВидБлагоустройстваИндивидуальный,
	               |	ВТ_ПоставщикиИУслуги.Услуга КАК Услуга,
	               |	ВТ_ПоставщикиИУслуги.ТарифнаяКатегория КАК ТарифнаяКатегория,
	               |	ВТ_ПоставщикиИУслуги.Услуга.Код КАК КодУслуги,
	               |	ВТ_ПоставщикиИУслуги.Поставщик КАК Поставщик
	               |ИЗ
	               |	ВТ_ПоставщикиИУслуги КАК ВТ_ПоставщикиИУслуги
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Тарифы КАК ВТ_Тарифы
	               |		ПО ВТ_ПоставщикиИУслуги.Услуга = ВТ_Тарифы.Услуга
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Норматив КАК ВТ_Норматив
	               |		ПО ВТ_ПоставщикиИУслуги.Услуга = ВТ_Норматив.Услуга" ;
	
	Запрос.УстановитьПараметр("КлючПомещения"	, КлючПомещения);
	Запрос.УстановитьПараметр("Организация"		, Организация);
	Запрос.УстановитьПараметр("Период"			, Период);
	Запрос.УстановитьПараметр("Район"			, Район);
	
	
	//Запрос.УстановитьПараметр("Услуга"			, Услуга);
	
	РезультатЗапроса 	= Запрос.Выполнить(); 	
	Выборка 			= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ВидыБлагоустройстваТарифныеКатегории.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
