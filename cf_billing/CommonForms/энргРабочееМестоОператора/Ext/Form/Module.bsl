&НаСервереБезКонтекста
Процедура ДополнитьСуммуКОплате(ПоляАбонента, Результат)
	
	Период = НачалоМесяца(ДобавитьМесяц(ПоляАбонента.ТекущаяДата, 1));
	Организация 		= ПоляАбонента.Организация; 
	ПериодНачисления 	= ПоляАбонента.ПериодНачисления; 
	Район 				= ПоляАбонента.Район; 
	МКД 				= ПоляАбонента.МКД; 
	Абонент 			= ПоляАбонента.Абонент; 
	
	ТЗЗадолженности	= энргРаботаСТочкамиУчетаСервер.ДанныеДляОплатыАбонента(Период, Организация, ПериодНачисления, Район, МКД, Абонент, Истина).Выгрузить();
	СуммаКОплате		= ТЗЗадолженности.Итог("Задолженность");
	СуммаКОплатеПени	= ТЗЗадолженности.Итог("ЗадолженностьПени");
	Если СуммаКОплате <= 0 Тогда		
		Аванс = энргРаботаСТочкамиУчетаСервер.ДанныеОбАвансеАбонента(Период, Организация, Район, Абонент);
		СуммаКОплате = ?(Аванс > 0, -Аванс, 0);
	КонецЕсли;	
	
	Результат.СуммаКОплате		= СуммаКОплате;
	Результат.СуммаКОплатеПени	= СуммаКОплатеПени;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДополнитьСуммуЗадолженностиНаДату(ПоляАбонента, Результат)
	ПериодНачисления 		= ПоляАбонента.ПериодНачисления;
	Организация 			= ПоляАбонента.Организация; 
	Район 					= ПоляАбонента.Район; 
	МКД 					= ПоляАбонента.МКД; 
	Абонент 				= ПоляАбонента.Абонент;
	
	ГраницыОтчетногоПериода = Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация, Район, ПериодНачисления);	
	ДанныеЗадолженностиНа 	= ГраницыОтчетногоПериода.НачалоОП;	
	
	Схема = Неопределено;
	ПараметрыСхемы 	= Новый Структура;
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", Новый Структура("Организация,Район,МКД,Абонент", "Организация","Район","МКД","Абонент")));
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);
	ПараметрыСхемы.Вставить("Период", Новый Структура("ИмяПараметра", "Период"));
	РегистрыНакопления.энргВзаиморасчеты.ДанныеОперативнойЗадолженности(Схема,ПараметрыСхемы,"");
	ПараметрыЗапроса = Новый Структура("Период,Организация,Район,МКД,Абонент", ДанныеЗадолженностиНа, Организация, Район, МКД, Абонент);
	
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;	
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Результат.СуммаЗадолженностиНаДату	= Выборка.Сумма;
	Результат.ДанныеЗадолженностиНа		= ДанныеЗадолженностиНа;

КонецПроцедуры

#КонецОбласти

#Область РаботаСВкладкойДокументыАбонента

&НаКлиенте
Процедура УстановитьОтборПоАбонентуВкладкуДокументыАбонента()
	
	ЗначениеЗаголовка = ?(ЗначениеЗаполнено(ТекАбонент), Строка(ТекАбонент), "<Абонент не выбран>");
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ОткрытьАбонента",
		"Заголовок",
		ЗначениеЗаголовка);
		
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ДокументыАбонента, "Абонент", ТекАбонент);
	Для каждого эл из ДокументыАбонента.КомпоновщикНастроек.Настройки.Отбор.Элементы Цикл
		Если эл.ПредставлениеПользовательскойНастройки = "ЗаполнениеАбонент" Тогда
			эл.ПравоеЗначение = ТекАбонент;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

