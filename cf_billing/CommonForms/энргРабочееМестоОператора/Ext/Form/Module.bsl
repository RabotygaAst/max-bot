&НаСервере
Функция ПолучитьМассивКодовСоставляющихУслуги(Услуга)
	
	мКодыУслуг = Новый Массив;
	
	Если НЕ Услуга.СоставнаяУслуга Тогда				
		
		мКодыУслуг.Добавить(Услуга.Код);
		Возврат мКодыУслуг;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	энргВидыУслугСоставляющиеУслуг.Услуга.Код КАК Код,
	|	энргВидыУслугСоставляющиеУслуг.Услуга КАК Услуга
	|ИЗ
	|	Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|ГДЕ
	|	энргВидыУслугСоставляющиеУслуг.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Услуга);
	Результат = Запрос.Выполнить();
	
	мКодыУслуг = Результат.Выгрузить().ВыгрузитьКолонку("Код");
	
	Возврат мКодыУслуг;
	
КонецФункции

&НаСервере
Функция ПолучитьЗначениеТарифа(ТочкиУчета)
	ЗначениеТарифа = 0;
	Для Каждого Строка Из ТочкиУчета Цикл
		Если ЗначениеЗаполнено(Строка.ЗначениеТарифа) 
			И ЗначениеТарифа < Число(Строка.ЗначениеТарифа) Тогда
			ЗначениеТарифа = Число(Строка.ЗначениеТарифа);
		КонецЕсли;
	КонецЦикла;
	Возврат ЗначениеТарифа;
КонецФункции

&НаСервере
Процедура ОбновитьПриборыСИстекающимСрокомПоверкиНаСервере()
	ПриборыСИстекающимСрокомПоверки.Очистить();
	
	Схема 				= Неопределено;
	СтруктураПараметров = Новый Структура;	
	СтруктураПараметров.Вставить("Период",  Новый Структура("ИмяПараметра", "Период"));	
	
	РегистрыСведений.энргДатыПоверкиПрибораУчета.ДатыПоверокДействующихПриборовУчета(Схема, СтруктураПараметров,"ДатыПоверокДействующихПриборовУчета");
	//РегистрыСведений.энргАбонентыПомещений.ТекущийАбонентВПомещении(Схема, СтруктураПараметров, "АбонентыПомещений");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВведенныеПриборыДействующихТочек.Организация КАК Организация,
	|	ВведенныеПриборыДействующихТочек.Район КАК Район,
	|	АбонентыПомещений.Абонент КАК Абонент,
	|	ВведенныеПриборыДействующихТочек.КлючПомещения КАК КлючПомещения,
	|	ВведенныеПриборыДействующихТочек.ТочкаУчета КАК ТочкаУчета,
	|	ВведенныеПриборыДействующихТочек.ПриборУчета КАК ПриборУчета,
	|	ДатыПоверокДействующихПриборовУчета.ДатаПоверки КАК ДатаПоверки,
	|	энргАбоненты.ФизЛицо КАК ФизЛицо
	|ПОМЕСТИТЬ СрокПоверок
	|ИЗ
	|	ДействующиеПриборыУчетаПомещения КАК ВведенныеПриборыДействующихТочек
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыПоверокДействующихПриборовУчета КАК ДатыПоверокДействующихПриборовУчета
	|		ПО ВведенныеПриборыДействующихТочек.Организация = ДатыПоверокДействующихПриборовУчета.Организация
	|			И ВведенныеПриборыДействующихТочек.Район = ДатыПоверокДействующихПриборовУчета.Район
	|			И ВведенныеПриборыДействующихТочек.КлючПомещения = ДатыПоверокДействующихПриборовУчета.КлючПомещения
	|			И ВведенныеПриборыДействующихТочек.ПриборУчета = ДатыПоверокДействующихПриборовУчета.ПриборУчета
	|			И (РАЗНОСТЬДАТ(&НачалоПериода, НАЧАЛОПЕРИОДА(ДатыПоверокДействующихПриборовУчета.ДатаПоверки, МЕСЯЦ), МЕСЯЦ) <= &СрокПоверки)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АбонентыПомещений КАК АбонентыПомещений
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ПО АбонентыПомещений.Абонент = энргАбоненты.Ссылка
	|		ПО ВведенныеПриборыДействующихТочек.Организация = АбонентыПомещений.Организация
	|			И ВведенныеПриборыДействующихТочек.Район = АбонентыПомещений.Район
	|			И ВведенныеПриборыДействующихТочек.КлючПомещения = АбонентыПомещений.КлючПомещения");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.Организация КАК Организация,
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.Район КАК Район,
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.КлючПомещения КАК КлючПомещения,
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.Шкала КАК Шкала,
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.ВидДифференцированности КАК ВидДифференцированности
	|ПОМЕСТИТЬ ВидДифференцированностиВведенныхПриборов
	|ИЗ
	|	РегистрСведений.энргВидыДифференцированностиПриборовУчета.СрезПоследних(
	|			&Период,
	|			(Организация, Район, КлючПомещения, ПриборУчета) В
	|				(ВЫБРАТЬ
	|					СрокПоверок.Организация,
	|					СрокПоверок.Район,
	|					СрокПоверок.КлючПомещения,
	|					СрокПоверок.ПриборУчета
	|				ИЗ
	|					СрокПоверок КАК СрокПоверок)) КАК энргВидыДифференцированностиПриборовУчетаСрезПоследних");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	МАКСИМУМ(ВложенныйЗапрос.Адрес) КАК Адрес,
	|	МАКСИМУМ(ВложенныйЗапрос.Телефон) КАК Телефон,
	|	МАКСИМУМ(ВложенныйЗапрос.Почта) КАК Почта
	|ПОМЕСТИТЬ ДанныеАбонентов
	|ИЗ
	|	(ВЫБРАТЬ
	|		СрокПоверок.Абонент КАК Абонент,
	|		ЕСТЬNULL(энргАбонентыКонтактнаяИнформация.Представление, """") КАК Адрес,
	|		"""" КАК Телефон,
	|		"""" КАК Почта
	|	ИЗ
	|		СрокПоверок КАК СрокПоверок
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
