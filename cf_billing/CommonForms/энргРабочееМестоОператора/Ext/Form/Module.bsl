	СписокоОпераций  = СписокОперацийСПриборамУчета();
	КнопкаКоманды = Элементы.Найти("ВыполнитьОперацииСПриборамиУчета");
	ВыбратьОперациюИзСписка(СписокоОпераций,КнопкаКоманды);
КонецПроцедуры

