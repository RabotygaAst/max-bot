&НаКлиенте
Процедура РезультатОтчетаКарточкаОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка, ДополнительныеПараметры)
	
	Если ТипЗнч(Расшифровка) = Тип("ДокументСсылка.энргВводНачальныхОстатков") Тогда
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура("Ключ", Расшифровка);
		ПараметрыФормы.Вставить("Абонент",АбонентКарточка);
		ОткрытьФорму("Документ.энргВводНачальныхОстатков.ФормаОбъекта", ПараметрыФормы,ЭтаФорма);
	ИначеЕсли ТипЗнч(Расшифровка) = Тип("ДокументСсылка.энргНачисление") И ЗначениеЗаполнено(АбонентКарточка) Тогда
		
		СтандартнаяОбработка = Ложь;
		
		ПараметрыФормы 		= Новый Структура("Ключ", Расшифровка);
		ФормаДокумента 		= ПолучитьФорму("Документ.энргНачисление.ФормаОбъекта",ПараметрыФормы,ЭтаФорма);
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		ФормаДокумента.ОбъемНачислений,
		"Абонент",
		АбонентКарточка,
		ВидСравненияКомпоновкиДанных.Равно,
		,
		Истина,
		РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ,
		"Абонент");
		
		ФормаДокумента.Открыть();
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДанныхОперативнойзадолженностиНаДату(Знач Абонент, Знач ПериодЗадолженности)
	Схема 										= Неопределено;
	ПараметрыСхемы 								= Новый Структура;
	ПараметрыВТ 								= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", Новый Структура("Организация,Район,МКД,Абонент", "Организация","Район","МКД","Абонент")));
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);
	ПараметрыСхемы.Вставить("Период", 			Новый Структура("ИмяПараметра", "Период"));
	РегистрыНакопления.энргВзаиморасчеты.ДанныеОперативнойЗадолженности(Схема,ПараметрыСхемы,"");
	ПараметрыЗапроса 							= Новый Структура("Период,Организация,Район,МКД,Абонент", ПериодЗадолженности,Организация,Район,МКД,Абонент);
	
	Результат  									= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	СуммаЗадолженностиНаДату					= 0;
	Если Не Результат.Пустой() Тогда
		Выборка 								= Результат.Выбрать();
		Выборка.Следующий();
		СуммаЗадолженностиНаДату 				= Выборка.Сумма;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументСистемыОтборОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ДокументСистемыОтборТип = ВыбранноеЗначение;
	
	ЗаполнитьДокументСистемыОтбор();
	ЗаполнитьПрисоединенныеФайлы();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДокументСистемыОтбор()
	
	МетаданныеДокумента = Метаданные.НайтиПоТипу(ДокументСистемыОтборТип);	
	ДокументСистемыОтбор = МетаданныеДокумента.Синоним;
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодФайловОтборПриИзменении(Элемент)
	ЗаполнитьПрисоединенныеФайлы();
КонецПроцедуры

&НаКлиенте
Процедура ПрикрепленныеФайлыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекДанные = Элементы.ПрикрепленныеФайлы.ТекущиеДанные;
	
	Если Поле.Имя = "ПрикрепленныеФайлыДокументСистемы" Тогда
		
		ИмяМетаданных = ПолучитьИмяМетаданных(ТекДанные.ДокументСистемы);
		ПараметрыОткрытия = Новый Структура("Ключ", ТекДанные.ДокументСистемы);
		ОткрытьФорму(ИмяМетаданных + ".ФормаОбъекта", ПараметрыОткрытия, ЭтаФорма);
		
	ИначеЕсли Поле.Имя = "ПрикрепленныеФайлыПрисоединенныйФайл" Тогда
		
		ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаДляОткрытия(ТекДанные.ПрисоединенныйФайл, Неопределено, УникальныйИдентификатор);
		РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла, Ложь);
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьИмяМетаданных(Элемент)
	
	Если ТипЗнч(Элемент) = Тип("Тип") Тогда
		ТипМетаданных = Элемент;
	Иначе
		ТипМетаданных = ТипЗнч(Элемент);
	КонецЕсли;
	
	МетаданныеДокумента = Метаданные.НайтиПоТипу(ТипМетаданных);
	
	Возврат МетаданныеДокумента.ПолноеИмя();
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗначенияРеквизитовПриборовСервер(мПриборыУчета, ПолучаемыеРеквизитыПрибора)
