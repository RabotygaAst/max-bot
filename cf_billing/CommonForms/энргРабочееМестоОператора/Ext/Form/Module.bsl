	Организация         = Результат.Организация;
	ТекОрганизация		= Результат.Организация;
	ТекРайон 			= Результат.Район;
	Район               = Результат.Район;
	ТекКлючПомещения 	= Результат.КлючПомещения;
	ТекАбонент 			= Результат.Ссылка;
	ТекЛС				= Результат.ЛицевойСчет;	 
	
	ЗаполнитьОбщиеДанныеАбонента();	

