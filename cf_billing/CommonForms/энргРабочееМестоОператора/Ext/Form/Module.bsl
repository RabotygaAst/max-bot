&НаКлиенте
Процедура ТекТочкаУчетаПриИзменении(Элемент)
	Префикс		= "_РекПУ_";
	ИменаГрупп	= Новый Структура("ГруппаИнфТУ_, ГруппаИнфПУ_, ГруппаПоказания_");
	
	ПрефиксБлага				= "_РекВидБлага_";
	ИменаГруппБлага				= Новый Структура("ГруппаВидБлагаПоУслуге_");
	мКодыУслуг					= Новый Массив;
	
	мПриборыУчета 				= ДанныеПоПрибору();
	ПолучаемыеРеквизитыПрибора 	= "РегистрируетОбъем";
	ЗначенияРеквизитовПриборов 	= ЗначенияРеквизитовПриборовСервер(мПриборыУчета, ПолучаемыеРеквизитыПрибора);
	
	Для каждого ТекСтрока Из ТочкиУчета Цикл
		
		Ид = Формат(ТекСтрока.ПолучитьИдентификатор(), "ЧН=0; ЧГ=0");
		Видимость = ТекСтрока.ТочкаУчета = ТекТочкаУчета;
		
		Для каждого ИмяГруппы Из ИменаГрупп Цикл
			ТекГруппа = Элементы.Найти(Префикс + ИмяГруппы.Ключ + Ид);
			Если ТекГруппа <> Неопределено Тогда
				ТекГруппа.Видимость = Видимость;
			КонецЕсли;
		КонецЦикла;
		
		Если Видимость Тогда			
			мКодыУслуг = ПолучитьМассивКодовСоставляющихУслуги(ТекСтрока.Услуга);
			Если НЕ ЗначенияРеквизитовПриборов[ТекСтрока.ПриборУчета] = Неопределено Тогда
				ТекПриборУчетаОбъем = ЗначенияРеквизитовПриборов[ТекСтрока.ПриборУчета]["РегистрируетОбъем"];
			КонецЕсли;			
		КонецЕсли;				
	КонецЦикла;
	
	Для Каждого СтрокаБлага ИЗ ВидыБлагоустройстваТарифныеКатегории Цикл
		
		Видимость = мКодыУслуг.Найти(СтрокаБлага.КодУслуги) <> Неопределено;
		
		Для каждого ИмяГруппы Из ИменаГруппБлага Цикл
			ТекГруппа = Элементы.Найти(ПрефиксБлага + ИмяГруппы.Ключ + СтрокаБлага.КодУслуги);
			Если ТекГруппа <> Неопределено Тогда
				ТекГруппа.Видимость = Видимость;
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ИмяРеквизитаПоказания) И Элементы.Найти(ИмяРеквизитаПоказания)<> Неопределено Тогда
		Если ТекПриборУчетаОбъем Тогда
			Элементы[ИмяРеквизитаПоказания].Заголовок = "Объем";
		Иначе
			Элементы[ИмяРеквизитаПоказания].Заголовок = "Показания";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

