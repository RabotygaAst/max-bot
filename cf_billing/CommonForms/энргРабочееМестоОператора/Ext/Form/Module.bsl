	ПоказатьЗначение(,Элементы.ЖильцыЛьготныхКатегорий.ТекущиеДанные.Регистратор);
КонецПроцедуры

&НаСервере
Функция ПолучитьСтроение()
	СтруктураВозврат = Новый Структура;
	СтруктураВозврат.Вставить("ОтборПоДому", Ложь);
	СтруктураВозврат.Вставить("Дом", Справочники.энргСтроения.ПустаяСсылка());
	Если ТекКлючПомещения.Строение.ТипСтроения = Перечисления.энргТипыСтроений.МКД Тогда
		СтруктураВозврат.ОтборПоДому = Истина;
		СтруктураВозврат.Дом = ТекКлючПомещения.Строение;
	ИначеЕсли ТекКлючПомещения.Строение.ТипСтроения = Перечисления.энргТипыСтроений.ЖД Тогда
		СтруктураВозврат.ОтборПоДому = Истина;
	КонецЕсли;
	Возврат СтруктураВозврат;
КонецФункции

&НаСервере
Процедура ЗаполнитьСписокДляУдаления(СписокЭлементовУдалить, СписокРеквизитовУдалить, Элемент)
	
	Для каждого ТекЭлемент Из Элемент.ПодчиненныеЭлементы Цикл
		
		Если ТипЗнч(ТекЭлемент) = Тип("ГруппаФормы") Тогда
			
			ЗаполнитьСписокДляУдаления(СписокЭлементовУдалить, СписокРеквизитовУдалить, ТекЭлемент);
		ИначеЕсли ТипЗнч(ТекЭлемент) = Тип("ПолеФормы") Тогда
			СписокРеквизитовУдалить.Добавить(ТекЭлемент.Имя);
		КонецЕсли;
		
		СписокЭлементовУдалить.Добавить(ТекЭлемент);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВводНовогоПоказанияПУ(Результат, ДополнительныеПараметры) Экспорт
	
	Элемент = ДополнительныеПараметры.Элемент;
	
	Если Результат <> Неопределено Тогда  
		УстановитьПоказаниеПУ(Элемент.Имя, Результат);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПоказаниеПУ(ИмяЭлемента, Результат)
	Префикс		= "_РекПУ_";
	Показание   = Результат.Показание;
	
	СтрокиТУ = ТочкиУчета.НайтиСтроки(Новый Структура("ТочкаУчета", ТекТочкаУчета));
	Если ЗначениеЗаполнено(СтрокиТУ) Тогда
		СтрокаТУ = СтрокиТУ[0];
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран прибор учета.");
		Возврат;
	КонецЕсли;
	
	Ид	= Формат(СтрокаТУ.ПолучитьИдентификатор(), "ЧН=0; ЧГ=0");
	ИдПоказаний = СтрЗаменить(ИмяЭлемента, Префикс + Ид + "_", "");
	ИдПоказаний = СтрЗаменить(ИдПоказаний, "_ПредыдущиеПоказания", "");
	ИдПоказаний = Число(ИдПоказаний);
	СтрокаПоказ = ПоказанияПриборовУчета.НайтиПоИдентификатору(ИдПоказаний);
	
	Если СтрокаПоказ = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить показания прибора учета.");
		Возврат;
	Иначе
		СтрокиШкалы = ШкалыПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки", СтрокаПоказ.IDСтроки));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокиШкалы) Тогда
		СтрокаШкалы = СтрокиШкалы[0];
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить показания прибора учета.");
		Возврат;
	КонецЕсли;
	
	// Создание и заполнение документа, для регистрации показаний
	ДокОбъект = Документы.энргРегистрацияПоказанийАбонента.СоздатьДокумент();
	ШапкаДок = Новый Структура("Абонент, КлючПомещения, Организация, Район, Дата", ТекАбонент, ТекКлючПомещения, ТекОрганизация, текРайон, Результат.Дата);
	ШапкаДок.Вставить("ВидОперации"			, Перечисления.энргВидыОпераций.энргРегистрацияПоказанийАбонента_РегистрацияПоказанийАбонента);
	ШапкаДок.Вставить("ИсточникПоказаний"	, Результат.ИсточникПоказаний);
	ШапкаДок.Вставить("ПериодНачисления"	, Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ШапкаДок.Дата, ТекОрганизация,текРайон));
	ЗаполнитьЗначенияСвойств(ДокОбъект, ШапкаДок);
	
	ИдТУ    = Новый УникальныйИдентификатор;
	ИдШкала = Новый УникальныйИдентификатор;
	
	СтрокаДокТочкиУчета = ДокОбъект.ТочкиУчета.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДокТочкиУчета, СтрокаТУ);
	СтрокаДокТочкиУчета.IDСтроки = ИдТУ;
	
	СтрокаДокШкалыПУ = ДокОбъект.ШкалыПриборовУчета.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДокШкалыПУ, СтрокаШкалы);
	СтрокаДокШкалыПУ.IDСтроки			= ИдШкала;
	СтрокаДокШкалыПУ.IDСтрокиТочкиУчета = ИдТУ;
	
	СтрокаДокПоказанияПУ = ДокОбъект.ПоказанияПриборовУчета.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДокПоказанияПУ, СтрокаПоказ);
	СтрокаДокПоказанияПУ.IDСтроки = ИдШкала;
	
	СтрокаДокПоказанияПУ.Переворот = Ложь;
	Если СтрокаДокТочкиУчета.ПриборУчета.РегистрируетОбъем Тогда
		СтрокаДокПоказанияПУ.Разница = Показание;
		СтрокаДокПоказанияПУ.ПредыдущиеПоказания = 0;
	Иначе
		СтрокаДокПоказанияПУ.Разница = Показание-СтрокаДокПоказанияПУ.ПредыдущиеПоказания;
	КонецЕсли;
	СтрокаДокПоказанияПУ.СостояниеПоказаний 	= Перечисления.энргСостояниеПоказаний.Приняты;
	СтрокаДокПоказанияПУ.ТекущиеПоказания		= Показание;
	СтрокаДокПоказанияПУ.ПоказанияПредоставлены = Истина;
	
	Попытка
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);	
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить показания прибора учета по причине: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки;
	
	// энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоАбоненту(ТекОрганизация, ДокОбъект.ПериодНачисления, текРайон, ТекКлючПомещения.ЧастныйСектор,ТекКлючПомещения.Строение, ТекКлючПомещения.Помещение);
	СтрокаПоказ.ПредыдущиеПоказания		= Показание;
	СтрокаПоказ.ДатаПоследнихПоказаний  = ДокОбъект.Дата;
	ЭтаФорма[ИмяЭлемента]				= Показание;
	ИмяЭлеДатаПоказ						= СтрЗаменить(ИмяЭлемента, "_ПредыдущиеПоказания", "_ДатаПоследнихПоказаний");
	ЭтаФорма[ИмяЭлеДатаПоказ]			= ДокОбъект.Дата;
КонецПроцедуры 

&НаКлиенте
Процедура СуммаКОплатеНажатие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка 	= Ложь;
	ПериодНачисления  		= ВернутьПериодНАчисления();
	
	ПараметрыОткрытия 		= новый Структура();
	ПараметрыОткрытия.Вставить("Период"				, НачалоМесяца(ДобавитьМесяц(ТекущаяДата(), 1)) );
	ПараметрыОткрытия.Вставить("ПериодНачисления"	, ПериодНачисления);
	ПараметрыОткрытия.Вставить("Организация"		, ТекОрганизация);
	ПараметрыОткрытия.Вставить("Район"				, текРайон);
	ПараметрыОткрытия.Вставить("МКД"				, МКД);
	ПараметрыОткрытия.Вставить("Абонент"			, ТекАбонент);
	ОткрытьФорму("РегистрНакопления.энргВзаиморасчетыПоМесяцам.Форма.ФормаДетализацияЗадолженности",ПараметрыОткрытия);
КонецПроцедуры

&НаСервере
Функция  ВернутьПериодНачисления()
	ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ТекущаяДата(), Организация,Район);
	
	Возврат ПериодНачисления;
КонецФункции

&НаКлиенте
Процедура НаправлениеИспользованияТУПриНажатии(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ПараметрыОтбора = Новый Структура();
	ФормаСписка = ПолучитьФорму("РегистрСведений.энргЗначенияИзмерителейТочекУчета.Форма.ФормаПоказаний", ПараметрыОтбора, ЭтаФорма);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
	ФормаСписка.Список,
	"Родитель",
	ЭтаФорма[Элемент.Имя],
	ВидСравненияКомпоновкиДанных.Равно,
	,
	Истина);
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
	ФормаСписка.Список,
	"ТочкаУчета",
	ТекТочкаУчета,
	ВидСравненияКомпоновкиДанных.Равно,
	,
	Истина);		
	
	ФормаСписка.Открыть();
	
КонецПроцедуры

Функция РазницаДатВМесяцах(Дата1, Дата2) 
	
	ДатаНач	= ?(Дата1 < Дата2, Дата1, Дата2);
	ДатаКон	= ?(Дата1 < Дата2, Дата2, Дата1);
	
	Годы    = Год( датаКон ) - Год( датаНач );
	Месяцы  = Месяц( датаКон ) - Месяц( датаНач );
	
	Разность = месяцы + годы * 12;
	
	Возврат Разность;
	
КонецФункции

