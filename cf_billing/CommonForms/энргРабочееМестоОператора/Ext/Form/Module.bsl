КонецФункции

&НаСервере
Функция ПолучитьСостояниеЛСАбонента(Организация, Район, Абонент)
	Результат = Новый Структура("Период, Состояние", Дата(1,1,1), Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргСостояниеЛССрезПоследних.Период КАК Период,
	|	энргСостояниеЛССрезПоследних.Состояние КАК Состояние
	|ИЗ
	|	РегистрСведений.энргСостояниеЛС.СрезПоследних(
	|			&ТекДата,
	|			Абонент = &Абонент
	|				И Район = &Район
	|				И Организация = &Организация) КАК энргСостояниеЛССрезПоследних";
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат =  Новый Структура("Период, Состояние", Выборка.Период, Выборка.Состояние);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции


