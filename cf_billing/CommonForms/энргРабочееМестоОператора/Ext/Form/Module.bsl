#Область РаботаСТочкамиУчета

&НаКлиенте
Процедура ЗаполнитьДанныеПоТочкамУчета()
	
	Если НЕ ЗначениеЗаполнено(ТекАбонент) Тогда 
		Возврат;
	КонецЕсли;
	
	ОчиститьКоллекции();
	
	ПоляАбонента = ОсновныеПоляАбонента();
	ПоляАбонента.Вставить("КоличествоКомнат",		КоличествоКомнат);
	ПоляАбонента.Вставить("КоличествоПроживающих",	КоличествоПроживающих);
	ПоляАбонента.Вставить("КоличествоПрописанных",	КоличествоПрописанных);
	ПоляАбонента.Вставить("КоличествоСобственников",КоличествоСобственников);	
	
	// 1. Запуск фонового задания на сервере.
	ДлительнаяОперация = ЗапуститьФоновоеЗаданиеПолученияДанныхПоТочкамУчета(УникальныйИдентификатор, ПоляАбонента, ТочкиУчета, ШкалыПриборовУчета, ПоказанияПриборовУчета);;

	// 2. Подключение обработчика завершения фонового задания.
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения = "Идет получение данных";
	Оповещение = Новый ОписаниеОповещения("ПриЗавершенииПоискаНастроек", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗавершенииПоискаНастроек(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		ПоказатьПредупреждение( ,Результат.КраткоеПредставлениеОшибки);
		
		Возврат;
	КонецЕсли;
	
	РезультатПреобразования = ОбновитьДеревьяДанныхТочекУчета(Результат, ДеревоТочек, ДеревоДанныхПоПУ, ДеревоДанныхПоУслугам);
	УстановитьВидимостьПолюДереваТУ(РезультатПреобразования.ЕстьОРП);
	
	СтрокаДерева = ДеревоТочек.ПолучитьЭлементы();
	ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, РезультатПреобразования.ДеревоТочек.ПолучитьЭлементы());
	
	СтрокаДерева = ДеревоДанныхПоПУ.ПолучитьЭлементы();
	ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, РезультатПреобразования.ДеревоДанныхПоПУ.ПолучитьЭлементы());
	
	СтрокаДерева = ДеревоДанныхПоУслугам.ПолучитьЭлементы();
	ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, РезультатПреобразования.ДеревоДанныхПоУслугам.ПолучитьЭлементы());
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьДеревьяДанныхТочекУчета(Результат, Знач ДеревоТочек, Знач ДеревоДанныхПоПУ, Знач ДеревоДанныхПоУслугам)
	
	ДанныеВременногоХранилища = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	УдалитьИзВременногоХранилища(Результат.АдресРезультата);
	
	
	СтрокаДерева = ДеревоТочек.ПолучитьЭлементы();
	ОбщегоНазначения.ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, ДанныеВременногоХранилища.ДеревоТочек);
	
	СтрокаДерева = ДеревоДанныхПоПУ.ПолучитьЭлементы();
	ОбщегоНазначения.ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, ДанныеВременногоХранилища.ДеревоДанныхПоПУ);
	
	СтрокаДерева = ДеревоДанныхПоУслугам.ПолучитьЭлементы();
	ОбщегоНазначения.ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(СтрокаДерева, ДанныеВременногоХранилища.ДеревоДанныхПоУслугам); 	
	
	Возврат Новый Структура("ДеревоТочек, ДеревоДанныхПоПУ, ДеревоДанныхПоУслугам, ЕстьОРП", ДеревоТочек, ДеревоДанныхПоПУ, ДеревоДанныхПоУслугам, ДанныеВременногоХранилища.ЕстьОРП);
	
КонецФункции



&НаСервереБезКонтекста
Функция ЗапуститьФоновоеЗаданиеПолученияДанныхПоТочкамУчета(УникальныйИдентификатор, ПоляАбонента, Знач ТочкиУчетаОригинал, Знач ШкалыПриборовУчетаОригинал, Знач ПоказанияПриборовУчетаОригинал)	
		
	ТочкиУчета 				= ТочкиУчетаОригинал.Выгрузить();
	ШкалыПриборовУчета 		= ШкалыПриборовУчетаОригинал.Выгрузить();
	ПоказанияПриборовУчета 	= ПоказанияПриборовУчетаОригинал.Выгрузить();
	
	ДеревоТочек 			= НовоеДеревоТочекУчета();	
	ДеревоДанныхПоПУ 		= НовоеДеревоПриборовУчета();	
	ДеревоДанныхПоУслугам 	= НовоеДеревоДетализацииУслуг();
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0; // запускать сразу
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Получение данных точек учета рабочего стола'");
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения, 
		"энргРаботаСРабочимМестомОператора.ЗаполнитьДанныеТочекУчета",
		ПоляАбонента, 
		ДеревоТочек, 
		ДеревоДанныхПоПУ, 
		ДеревоДанныхПоУслугам, 
		ТочкиУчета, 
		ШкалыПриборовУчета, 
		ПоказанияПриборовУчета);
	
	Возврат ДлительнаяОперация;
	
КонецФункции 

&НаСервереБезКонтекста
Функция НовоеДеревоТочекУчета()
	
	Результат = Новый ДеревоЗначений;	
	Результат.Колонки.Добавить("ТочкаУчета", Новый ОписаниеТипов("СправочникСсылка.энргТочкиУчета"));
	Результат.Колонки.Добавить("Услуга", Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	Результат.Колонки.Добавить("ПриборУчета", Новый ОписаниеТипов("СправочникСсылка.энргПриборыУчетаАбонента"));
	Результат.Колонки.Добавить("НаправлениеИспользованияТУ", Новый ОписаниеТипов("СправочникСсылка.энргНаправлениеИспользованияТочекУчета"));
	Результат.Колонки.Добавить("НетВозможностьУстановкиПУ", Новый ОписаниеТипов("Булево"));
	Результат.Колонки.Добавить("РасчетТолькоПоПоказаниям", Новый ОписаниеТипов("Булево"));
	Результат.Колонки.Добавить("Техническая", Новый ОписаниеТипов("Булево"));
	Результат.Колонки.Добавить("СтруктураСети", Новый ОписаниеТипов("СправочникСсылка.бестСтруктураСети"));
	Результат.Колонки.Добавить("Абонент", Новый ОписаниеТипов("СправочникСсылка.энргАбоненты"));
	Результат.Колонки.Добавить("СлужебноеПоле", ОбщегоНазначения.ОписаниеТипаСтрока(0));
	Результат.Колонки.Добавить("ПериодСостоянияТУ" , Новый ОписаниеТипов("Дата"));
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция НовоеДеревоПриборовУчета()
	
	Результат = Новый ДеревоЗначений;
	Результат.Колонки.Добавить("Значение1", ОбщегоНазначения.ОписаниеТипаСтрока(0));
	Результат.Колонки.Добавить("Значение2", ОбщегоНазначения.ОписаниеТипаСтрока(0));
	Результат.Колонки.Добавить("Значение3", ОбщегоНазначения.ОписаниеТипаСтрока(0));
	Результат.Колонки.Добавить("ПриборУчета", Новый ОписаниеТипов("СправочникСсылка.энргПриборыУчетаАбонента"));
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция НовоеДеревоДетализацииУслуг()
	
	ОсновнаяКолонкаТипы = Новый Массив;
	ОсновнаяКолонкаТипы.Добавить("Строка");
    ОсновнаяКолонкаТипы.Добавить("СправочникСсылка.энргВидыУслуг");
	ОсновнаяКолонкаТипы.Добавить("СправочникСсылка.энргТарифныеЗоны");
	ОписаниеСоставногоТипа = Новый ОписаниеТипов(ОсновнаяКолонкаТипы);
	
	ЗначенияКолонкаТипы = Новый Массив;
	ЗначенияКолонкаТипы.Добавить("Строка");
    ЗначенияКолонкаТипы.Добавить("СправочникСсылка.энргГруппыПотребителей");
	ЗначенияКолонкаТипы.Добавить("СправочникСсылка.энргВидыБлагоустройств");
	ЗначенияКолонкаТипы.Добавить("СправочникСсылка.энргКонтрагенты");
	ОписаниеСоставногоТипаЗначения = Новый ОписаниеТипов(ЗначенияКолонкаТипы);
	
	Результат = Новый ДеревоЗначений;
	Результат.Колонки.Добавить("ТочкаУчета", Новый ОписаниеТипов("СправочникСсылка.энргТочкиУчета"));    	
	Результат.Колонки.Добавить("Услуга", ОписаниеСоставногоТипа);
	Результат.Колонки.Добавить("Значение1", ОписаниеСоставногоТипаЗначения);
	Результат.Колонки.Добавить("Значение2", ОбщегоНазначения.ОписаниеТипаСтрока(0));
	
	Возврат Результат;
	
КонецФункции


&НаКлиенте
Процедура ОчиститьКоллекции()
	
	ДеревоТочек.ПолучитьЭлементы().Очистить();
	ДеревоДанныхПоПУ.ПолучитьЭлементы().Очистить();
	ДеревоОтображенияДанныхПоПУ.ПолучитьЭлементы().Очистить();
	ДеревоДанныхПоУслугам.ПолучитьЭлементы().Очистить();
	ДеревоОтображенияДанныхПоУслугам.ПолучитьЭлементы().Очистить(); 
	
	ТочкиУчета.Очистить();
	ШкалыПриборовУчета.Очистить();
	ПоказанияПриборовУчета.Очистить();
	
КонецПроцедуры

