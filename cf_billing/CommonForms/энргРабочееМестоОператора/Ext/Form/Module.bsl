	Результат.Вставить("КоличествоПрописанных", 0); 
	Результат.Вставить("КоличествоПроживающих", 0);
	Результат.Вставить("КоличествоСобственников", 0);
	Результат.Вставить("СписокПлощадей", Новый Массив); 
	
	Возврат Результат;
	
КонецФункции

