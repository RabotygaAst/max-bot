	ПараметрыОтбора = Новый Структура ("Отбор", ЗначениеОтбора);
	ОткрытьФорму("Документ.энргПриходныйКассовыйОрдер.ФормаСписка",ПараметрыОтбора,ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
