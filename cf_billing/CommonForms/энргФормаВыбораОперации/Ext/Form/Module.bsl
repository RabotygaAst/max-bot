#Область ОбработчикиСобытий

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗаполнитьЗначенияСвойств(ЭтотОбъект,Параметры.ЗначенияЗаполнения);	
	ВыборОперации 							= Параметры.ВыборОперации;	
	Если ВыборОперации тогда 
		энргРаботаСВидамиОперацийСервер.ЗаполнитьСписокВозможныхОперацийФормаСписка(Параметры.ИмяДокумента,СписокОпераций);
		ИмяДокумента 						= Параметры.ИмяДокумента;
		Основание 							= Параметры.Основание;
		ЭтаФорма.Заголовок 					= "Выбор вида операции";
	иначе
		СписокОпераций 						= Параметры.ВозможныеЗначения;
		ЭтаФорма.Заголовок 					= "Тип выбираемого объекта";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СписокОперацийВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	//Если  ТекущийЭлемент.ТекущаяСтрока<>0 тогда
	//	текущаяСтрока =   ТекущийЭлемент.ТекущаяСтрока-1;
	//иначе 
		текущаяСтрока = ТекущийЭлемент.ТекущаяСтрока;
	//КонецЕсли;
	ВыбранноеЗначение  	= СписокОпераций[текущаяСтрока].Значение;
	Если ВыборОперации тогда
		ПрефиксФормы 		= энргРаботаСВидамиОперацийВызовСервера.ПрефиксФормы(ИмяДокумента,ВыбранноеЗначение);
		Парам = Новый Структура;
		Парам.Вставить("Основание",Основание);
		
		Если ЗначениеЗаполнено(Абонент) Тогда
			СтруктураЗаполнения = Новый Структура;
			Если Не ПрефиксФормы = "ОткрытиеЛС" Тогда  
				СтруктураЗаполнения.Вставить("Абонент", Абонент);
			КонецЕсли;
			Соответствие = Новый Соответствие;
			Соответствие.Вставить("КлючПомещения");
			Соответствие.Вставить("Район");
			Соответствие.Вставить("Организация");
			энргОбщегоНазначения.ПолучитьЗначенияРеквизитов(, Абонент, Соответствие);
			
			СтруктураЗаполнения.Вставить("КлючПомещения", Соответствие["КлючПомещения"]);
			СтруктураЗаполнения.Вставить("Район", Соответствие["Район"]);
			СтруктураЗаполнения.Вставить("Организация", Соответствие["Организация"]);
			Если ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргПерерасчет_ИзменениеПараметраРассчета") Или ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргПерерасчет_КорректировкаОплаты") Тогда
				СтруктураПомещения		= Новый Структура("КлючПомещения, Абонент", Соответствие["КлючПомещения"], Абонент);
				Помещения				= Новый Массив;
				Помещения.Добавить(СтруктураПомещения);
				СтруктураЗаполнения.Вставить("Помещения", Помещения);
			КонецЕсли;
			Парам.Вставить("ЗначенияЗаполнения", СтруктураЗаполнения);
			Парам.Вставить("ЗаполнитьДокумент", Истина);
		ИначеЕсли ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСТочкамиПоставки_ОтключениеТочкиПоставки") Тогда
			СтруктураЗаполнения = Новый Структура;
			СтруктураЗаполнения.Вставить("ДопЗначенияЗаполнения", ДопЗначенияЗаполнения);
			Парам.Вставить("ЗначенияЗаполнения", СтруктураЗаполнения);
			Парам.Вставить("ЗаполнитьДокумент", Истина);
		КонецЕсли;
		энргРаботаСВидамиОперацийКлиент.ОткрытьФормуНовогоДокументаПоВидуОперации(ИмяДокумента, ВыбранноеЗначение, ПрефиксФормы, Парам);
		ЭтаФорма.Закрыть();
	иначе
		ОповеститьОВыборе(ВыбранноеЗначение);
	КонецЕсли;
КонецПроцедуры


// Стандартная не работает, заменил временно на это!
&НаКлиенте
Процедура Выбрать(Команда)
	
	СписокОперацийВыбор(Элементы.СписокОпераций,  ТекущийЭлемент.ТекущаяСтрока, Элементы.СписокОпераций.ТекущийЭлемент, Истина);
КонецПроцедуры




#КонецОбласти
