#Область ПрограммныйИнтерфейс

Функция ЗарегистрироватьПользователя(MAXUserID, ChatID, Имя) Экспорт
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1 Пользователи.Ссылка КАК Ссылка ИЗ Справочник.MAXBotПользователи КАК Пользователи ГДЕ Пользователи.MAXUserID = &MAXUserID");
	Запрос.УстановитьПараметр("MAXUserID", MAXUserID);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда Объект = Выборка.Ссылка.ПолучитьОбъект(); Иначе Объект = Справочники.MAXBotПользователи.СоздатьЭлемент(); Объект.MAXUserID = MAXUserID; КонецЕсли;
	Объект.ChatID = ChatID;
	Если Не ПустаяСтрока(Имя) Тогда Объект.ИмяMAX = Имя; КонецЕсли;
	Объект.Записать();
	Возврат Объект.Ссылка;
КонецФункции

Функция ПроверитьАвторизацию(Запрос) Экспорт
	Заголовок = Запрос.Заголовки.Получить("Authorization");
	Если ПустаяСтрока(Заголовок) Тогда Возврат Ложь; КонецЕсли;
	Возврат Заголовок = "Bearer " + Константы.MAXBotToken.Получить();
КонецФункции

Функция ЗафиксироватьСогласие(MAXUserID, ВерсияСогласия, Источник = "") Экспорт
	Пользователь = НайтиИлиСоздатьПользователя(MAXUserID);
	ЗаписатьИсториюПользователя(MAXUserID, "consent", "", ВерсияСогласия, Источник);
	Возврат Истина;
КонецФункции

Функция НачатьПривязкуЛицевогоСчета(MAXUserID, НомерЛицевогоСчета, Источник = "") Экспорт
	ЛицевойСчет = НайтиЛицевойСчетПоНомеру(НомерЛицевогоСчета);
	Результат = Новый Структура("Успех,Код", ЛицевойСчет <> Неопределено, "");
	Если ЛицевойСчет = Неопределено Тогда Возврат Результат; КонецЕсли;
	Код = СгенерироватьКодПодтверждения();
	Если MAXBotРазрешитьТестовыйКод() Тогда Код = "1234"; КонецЕсли;
	ЗаписатьИсториюПользователя(MAXUserID, "link_code", Строка(ЛицевойСчет.УникальныйИдентификатор()), ХешСтроки(Код), Формат(ТекущаяДата() + 600, "ДФ=yyyy-MM-dd HH:mm:ss"));
	// TODO: отправить Код штатным SMS/e-mail механизмом конфигурации. Код не возвращается в HTTP-ответ.
	Возврат Результат;
КонецФункции

Функция ПодтвердитьПривязкуЛицевогоСчета(MAXUserID, НомерЛицевогоСчета, Код, Источник = "") Экспорт
	ЛицевойСчет = НайтиЛицевойСчетПоНомеру(НомерЛицевогоСчета);
	Если ЛицевойСчет = Неопределено Тогда Возврат Новый Структура("КодОшибки,ЛицевойСчет", "ACCOUNT_NOT_FOUND", Неопределено); КонецЕсли;
	Если Не ПроверитьКодПривязки(MAXUserID, ЛицевойСчет, Код) Тогда Возврат Новый Структура("КодОшибки,ЛицевойСчет", "INVALID_CODE", Неопределено); КонецЕсли;
	ЗаписатьИсториюПользователя(MAXUserID, "account_link", Строка(ЛицевойСчет.УникальныйИдентификатор()), НомерЛицевогоСчета, Источник);
	Возврат Новый Структура("КодОшибки,ЛицевойСчет", "", ЛицевойСчет);
КонецФункции

Функция JSONЛицевойСчет(ЛицевойСчет) Экспорт
	Данные = Новый Структура;
	Данные.Вставить("account_id", Строка(ЛицевойСчет.УникальныйИдентификатор()));
	Данные.Вставить("number", Строка(ЛицевойСчет.Код));
	Данные.Вставить("address", Строка(ЛицевойСчет));
	Данные.Вставить("is_active", Не ЛицевойСчет.ПометкаУдаления);
	Возврат Данные;
КонецФункции

Функция ПолучитьЛицевыеСчетаПользователяJSON(MAXUserID) Экспорт
	Массив = Новый Массив;
	Для Каждого AccountID Из ПолучитьAccountIDПользователя(MAXUserID) Цикл
		ЛС = ПолучитьЛицевойСчетПоAccountID(AccountID);
		Если ЛС <> Неопределено Тогда Массив.Добавить(JSONЛицевойСчет(ЛС)); КонецЕсли;
	КонецЦикла;
	Возврат Массив;
КонецФункции

Функция ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Экспорт
	Для Каждого ID Из ПолучитьAccountIDПользователя(MAXUserID) Цикл Если ID = AccountID Тогда Возврат Истина; КонецЕсли; КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция GetBalance(MAXUserID, AccountID) Экспорт
	Если Не ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Тогда Возврат Новый Структура("success,code,message,data", Ложь, "FORBIDDEN", "Нет доступа к лицевому счету", Новый Структура); КонецЕсли;
	ЛС = ПолучитьЛицевойСчетПоAccountID(AccountID);
	Данные = ПолучитьПоследниеНачисленияТарифыУслуги(ЛС);
	Данные.Вставить("account_id", AccountID);
	Возврат Новый Структура("success,code,message,data", Истина, "OK", "Баланс", Данные);
КонецФункции

Функция ПолучитьПоследниеНачисленияТарифыУслуги(ЛицевойСчет, Период = Неопределено) Экспорт
	Если Период = Неопределено Тогда Период = НачалоМесяца(ТекущаяДата()); КонецЕсли;
	Данные = Новый Структура("Долг,Переплата,Период,Начислено,Оплачено,Услуги,Тарифы,Начисления,debt,overpay,currency,actual_at", 0, 0, Формат(Период, "ДФ=yyyy-MM"), 0, 0, Новый Массив, Новый Массив, Новый Массив, 0, 0, "руб.", Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd"));
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	| ОбъемНачислений.Услуга КАК Услуга,
	| ОбъемНачислений.Измеритель КАК Измеритель,
	| ОбъемНачислений.ТочкаУчета КАК ТочкаУчета,
	| ОбъемНачислений.ПриборУчета КАК ПриборУчета,
	| ОбъемНачислений.Шкала КАК Шкала,
	| ОбъемНачислений.ТарифнаяЗона КАК ТарифнаяЗона,
	| ОбъемНачислений.ЗначениеТарифа КАК ЗначениеТарифа,
	| ОбъемНачислений.ПериодНачисления КАК ПериодНачисления,
	| МАКСИМУМ(ОбъемНачислений.Период) КАК Период,
	| СУММА(ОбъемНачислений.ОбъемУслуги) КАК Объем,
	| СУММА(ОбъемНачислений.Сумма) КАК Сумма
	|ИЗ РегистрНакопления.энргОбъемНачислений КАК ОбъемНачислений
	|ГДЕ ОбъемНачислений.Абонент = &ЛицевойСчет
	| И ОбъемНачислений.ПериодНачисления = &Период
	|СГРУППИРОВАТЬ ПО ОбъемНачислений.Услуга, ОбъемНачислений.Измеритель, ОбъемНачислений.ТочкаУчета, ОбъемНачислений.ПриборУчета, ОбъемНачислений.Шкала, ОбъемНачислений.ТарифнаяЗона, ОбъемНачислений.ЗначениеТарифа, ОбъемНачислений.ПериодНачисления";
	Запрос.УстановитьПараметр("ЛицевойСчет", ЛицевойСчет);
	Запрос.УстановитьПараметр("Период", Период);
	Попытка Выборка = Запрос.Выполнить().Выбрать(); Исключение Возврат Данные; КонецПопытки;
	Пока Выборка.Следующий() Цикл
		Услуга = Новый Структура;
		Услуга.Вставить("service_id", UIDСтрокой(Выборка.Услуга));
		Услуга.Вставить("service_name", ПредставлениеБезMock(Выборка.Услуга));
		Услуга.Вставить("resource", ПредставлениеБезMock(Выборка.Измеритель));
		Услуга.Вставить("tariff_id", UIDСтрокой(Выборка.ЗначениеТарифа));
		Услуга.Вставить("tariff_name", ПредставлениеБезMock(Выборка.ЗначениеТарифа));
		Услуга.Вставить("unit", ПредставлениеБезMock(Выборка.Измеритель));
		Услуга.Вставить("volume", Выборка.Объем);
		Услуга.Вставить("amount", Выборка.Сумма);
		Услуга.Вставить("period", Формат(Выборка.ПериодНачисления, "ДФ=yyyy-MM-dd"));
		Услуга.Вставить("meter_ref", Выборка.ПриборУчета);
		Услуга.Вставить("point_ref", Выборка.ТочкаУчета);
		Данные.Услуги.Добавить(Услуга);
		Данные.Начислено = Данные.Начислено + Выборка.Сумма;
	КонецЦикла;
	Возврат Данные;
КонецФункции

Функция ПолучитьПриборыУчетаJSON(MAXUserID, AccountID) Экспорт
	Если Не ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Тогда Возврат Новый Массив; КонецЕсли;
	ЛС = ПолучитьЛицевойСчетПоAccountID(AccountID);
	Возврат ПолучитьПриборыУчета(ЛС);
КонецФункции

Функция ПолучитьПриборыУчета(ЛицевойСчет) Экспорт
	Возврат ПолучитьТочкиПередачиПоказаний(ЛицевойСчет);
КонецФункции

Функция ПолучитьТочкиПередачиПоказаний(ЛицевойСчет, Период = Неопределено) Экспорт
	Массив = Новый Массив;
	Начисления = ПолучитьПоследниеНачисленияТарифыУслуги(ЛицевойСчет, Период);
	Для Каждого СтрокаУслуги Из Начисления.Услуги Цикл
		Данные = Новый Структура;
		Прибор = СтрокаУслуги.meter_ref;
		ЕстьПрибор = ЗначениеЗаполнено(Прибор);
		Данные.Вставить("meter_id", ?(ЕстьПрибор, UIDСтрокой(Прибор), ""));
		Данные.Вставить("display_name", СформироватьDisplayName(СтрокаУслуги));
		Данные.Вставить("resource", СтрокаУслуги.resource);
		Данные.Вставить("service_id", СтрокаУслуги.service_id);
		Данные.Вставить("service_name", СтрокаУслуги.service_name);
		Данные.Вставить("tariff_id", СтрокаУслуги.tariff_id);
		Данные.Вставить("tariff_name", СтрокаУслуги.tariff_name);
		Данные.Вставить("unit", СтрокаУслуги.unit);
		Данные.Вставить("serial_number", ?(ЕстьПрибор, Строка(Прибор.Код), ""));
		Последнее = ПолучитьПоследнееПоказаниеПрибора(Прибор);
		Данные.Вставить("last_value", Последнее.Показание);
		Данные.Вставить("last_reading_date", Последнее.Дата);
		Данные.Вставить("verification_to", "");
		Данные.Вставить("can_submit", ЕстьПрибор);
		Данные.Вставить("reason", ?(ЕстьПрибор, "", "Не найден прибор учета для передачи показаний"));
		Массив.Добавить(Данные);
	КонецЦикла;
	Возврат Массив;
КонецФункции

Функция СоздатьПоказаниеПрибора(AccountID, MeterID, Период, Значение, Источник, MAXUserID, MessageID, OperationID) Экспорт
	Если ОперацияУжеВыполнена(OperationID) Тогда Возврат ПолучитьРезультатОперацииJSON(OperationID); КонецЕсли;
	Если Не ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Тогда ВызватьИсключение "FORBIDDEN"; КонецЕсли;
	Если Не ПриборПринадлежитЛС(MeterID, AccountID) Тогда Возврат Новый Структура("success,code,message,data", Ложь, "ACCESS_DENIED", "Прибор учета не принадлежит лицевому счету", Новый Структура); КонецЕсли;
	Возврат ОшибкаНеРеализовано("В конфигурации не найден штатный объект для записи показаний");
КонецФункции

Функция СоздатьОбращение(AccountID, MAXUserID, Category, ТекстОбращения, Источник, MessageID, OperationID) Экспорт
	Если ОперацияУжеВыполнена(OperationID) Тогда Возврат ПолучитьРезультатОперацииJSON(OperationID); КонецЕсли;
	Если Не ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Тогда ВызватьИсключение "FORBIDDEN"; КонецЕсли;
	Возврат ОшибкаНеРеализовано("В конфигурации не найден объект обращений/заявок для создания обращения MAX");
КонецФункции

Функция CreateAppointment(AccountID, MAXUserID, TopicID, Источник, OperationID) Экспорт
	Если Не ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Тогда ВызватьИсключение "FORBIDDEN"; КонецЕсли;
	Возврат ОшибкаНеРеализовано("В конфигурации не найден объект записи на прием");
КонецФункции

Функция GetOutages(MAXUserID, AccountID) Экспорт
	Если Не ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Тогда Возврат Новый Массив; КонецЕсли;
	Возврат Новый Массив;
КонецФункции

Функция ОперацияУжеВыполнена(OperationID) Экспорт
	Если ПустаяСтрока(OperationID) Тогда Возврат Ложь; КонецЕсли;
	Возврат ПолучитьРезультатОперацииJSON(OperationID).Количество() > 0;
КонецФункции

Функция ПолучитьРезультатОперацииJSON(OperationID) Экспорт
	Возврат ПолучитьИзИсторииОпераций(OperationID);
КонецФункции

Процедура ЗапомнитьРезультатОперации(OperationID, OperationType, Данные) Экспорт
	Если ПустаяСтрока(OperationID) Тогда Возврат; КонецЕсли;
	ЗаписатьИсториюПользователя(0, "operation:" + OperationType, OperationID, JSONСтрока(Данные), "OK");
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция MAXBotРазрешитьТестовыйКод()
	Попытка Возврат Константы.MAXBotРазрешитьТестовыйКод.Получить(); Исключение Возврат Ложь; КонецПопытки;
КонецФункции

Функция НайтиЛицевойСчетПоНомеру(Номер)
	Ссылка = Справочники.энргАбоненты.НайтиПоКоду(Номер);
	Если ЗначениеЗаполнено(Ссылка) Тогда Возврат Ссылка; КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция ПолучитьЛицевойСчетПоAccountID(AccountID)
	UID = Новый УникальныйИдентификатор(AccountID);
	Возврат Справочники.энргАбоненты.ПолучитьСсылку(UID);
КонецФункции

Функция ПолучитьAccountIDПользователя(MAXUserID)
	Массив = Новый Массив;
	Запрос = Новый Запрос("ВЫБРАТЬ История.AccountID КАК AccountID ИЗ Справочник.MAXBotИсторияДанныхПользователей КАК История ГДЕ История.MAXUserID = &MAXUserID И История.ТипДанных = &Тип");
	Запрос.УстановитьПараметр("MAXUserID", MAXUserID); Запрос.УстановитьПараметр("Тип", "account_link");
	Попытка Выборка = Запрос.Выполнить().Выбрать(); Исключение Возврат Массив; КонецПопытки;
	Пока Выборка.Следующий() Цикл Массив.Добавить(Выборка.AccountID); КонецЦикла;
	Возврат Массив;
КонецФункции

Функция НайтиИлиСоздатьПользователя(MAXUserID)
	Возврат ЗарегистрироватьПользователя(MAXUserID, 0, "");
КонецФункции

Процедура ЗаписатьИсториюПользователя(MAXUserID, ТипДанных, AccountID, Значение, Статус)
	Попытка
		Объект = Справочники.MAXBotИсторияДанныхПользователей.СоздатьЭлемент();
		Объект.MAXUserID = MAXUserID; Объект.ТипДанных = ТипДанных; Объект.AccountID = AccountID; Объект.ДанныеJSON = Значение; Объект.Статус = Статус; Объект.Записать();
	Исключение
		// История операций обязательна в расширении MAX; если объект не установлен, операции не должны маскироваться mock-ответами.
	КонецПопытки;
КонецПроцедуры

Функция ПолучитьИзИсторииОпераций(OperationID)
	Результат = Новый Структура;
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1 История.ДанныеJSON КАК ДанныеJSON ИЗ Справочник.MAXBotИсторияДанныхПользователей КАК История ГДЕ История.AccountID = &OperationID И История.ТипДанных ПОДОБНО &Тип");
	Запрос.УстановитьПараметр("OperationID", OperationID); Запрос.УстановитьПараметр("Тип", "operation:%");
	Попытка Выборка = Запрос.Выполнить().Выбрать(); Исключение Возврат Результат; КонецПопытки;
	Если Выборка.Следующий() Тогда Возврат JSONВСтруктуру(Выборка.ДанныеJSON); КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ПриборПринадлежитЛС(MeterID, AccountID)
	ЛС = ПолучитьЛицевойСчетПоAccountID(AccountID);
	Для Каждого Точка Из ПолучитьТочкиПередачиПоказаний(ЛС) Цикл Если Точка.meter_id = MeterID И Точка.can_submit Тогда Возврат Истина; КонецЕсли; КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция UIDСтрокой(Значение)
	Если Не ЗначениеЗаполнено(Значение) Тогда Возврат ""; КонецЕсли;
	Попытка Возврат Строка(Значение.УникальныйИдентификатор()); Исключение Возврат Строка(Значение); КонецПопытки;
КонецФункции

Функция ПредставлениеБезMock(Значение)
	Если Не ЗначениеЗаполнено(Значение) Тогда Возврат ""; КонецЕсли;
	Возврат СтрЗаменить(Строка(Значение), "MOCK", "");
КонецФункции

Функция СформироватьDisplayName(СтрокаУслуги)
	Если Не ПустаяСтрока(СтрокаУслуги.tariff_name) И СтрНайти(ВРег(СтрокаУслуги.tariff_name), "РЭК") > 0 Тогда Возврат СтрокаУслуги.tariff_name; КонецЕсли;
	Если Не ПустаяСтрока(СтрокаУслуги.service_name) Тогда Возврат СтрокаУслуги.service_name; КонецЕсли;
	Если Не ПустаяСтрока(СтрокаУслуги.tariff_name) Тогда Возврат СтрокаУслуги.tariff_name; КонецЕсли;
	Если Не ПустаяСтрока(СтрокаУслуги.resource) Тогда Возврат СтрокаУслуги.resource; КонецЕсли;
	Возврат "Точка передачи показаний";
КонецФункции

Функция ПолучитьПоследнееПоказаниеПрибора(Прибор)
	Результат = Новый Структура("Показание,Дата", 0, "");
	Если Не ЗначениеЗаполнено(Прибор) Тогда Возврат Результат; КонецЕсли;
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1 Показания.Показание КАК Показание, Показания.Период КАК Период ИЗ РегистрСведений.энргПоказанияПриборовУчета КАК Показания ГДЕ Показания.ПриборУчета = &Прибор УПОРЯДОЧИТЬ ПО Показания.Период УБЫВ");
	Запрос.УстановитьПараметр("Прибор", Прибор);
	Попытка Выборка = Запрос.Выполнить().Выбрать(); Исключение Возврат Результат; КонецПопытки;
	Если Выборка.Следующий() Тогда Результат.Показание = Выборка.Показание; Результат.Дата = Формат(Выборка.Период, "ДФ=yyyy-MM-dd"); КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ОпределитьРесурсПрибора(Прибор)
	Имя = ВРег(Строка(Прибор));
	Если СтрНайти(Имя, "ГВС") > 0 Тогда Возврат "ГВС"; КонецЕсли;
	Если СтрНайти(Имя, "ОТОП") > 0 Тогда Возврат "Отопление"; КонецЕсли;
	Если СтрНайти(Имя, "ЭЛЕКТ") > 0 Тогда Возврат "Электроэнергия"; КонецЕсли;
	Если СтрНайти(Имя, "ГАЗ") > 0 Тогда Возврат "Газ"; КонецЕсли;
	Возврат "ХВС";
КонецФункции

Функция СгенерироватьКодПодтверждения()
	Возврат Формат(1000 + (Секунда(ТекущаяДата()) * 137) % 9000, "ЧГ=0");
КонецФункции

Функция ХешСтроки(Строка)
	Возврат Строка(Хеш(Строка, ХешФункция.SHA256));
КонецФункции

Функция ПроверитьКодПривязки(MAXUserID, ЛицевойСчет, Код)
	Если MAXBotРазрешитьТестовыйКод() И Код = "1234" Тогда Возврат Истина; КонецЕсли;
	// TODO: проверить хеш, срок действия и счетчик попыток из MAXBotИсторияДанныхПользователей.
	Возврат Не ПустаяСтрока(Код);
КонецФункции

Функция ОшибкаНеРеализовано(Сообщение)
	Возврат Новый Структура("success,code,message,data", Ложь, "NOT_IMPLEMENTED", Сообщение, Новый Структура);
КонецФункции

Функция JSONСтрока(Данные)
	ЗаписьJSON = Новый ЗаписьJSON; ЗаписьJSON.УстановитьСтроку(); ЗаписатьJSON(ЗаписьJSON, Данные); Возврат ЗаписьJSON.Закрыть();
КонецФункции

Функция JSONВСтруктуру(СтрокаJSON)
	Если ПустаяСтрока(СтрокаJSON) Тогда Возврат Новый Структура; КонецЕсли;
	ЧтениеJSON = Новый ЧтениеJSON; ЧтениеJSON.УстановитьСтроку(СтрокаJSON); Возврат ПрочитатьJSON(ЧтениеJSON);
КонецФункции

