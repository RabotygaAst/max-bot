	Данные = Новый Структура("appointment_id,number,topic_title,office_address,starts_at,status", "", "", Параметры.topic_id, "", Формат(ТекущаяДата() + 86400, "ДФ=yyyy-MM-ddTHH:mm:ss"), "confirmed");
	Возврат СформироватьУспешныйОтвет(Данные, "Запись создана", "OK");
КонецФункции

Функция ЗарегистрироватьПользователя(MAXUserID, ChatID, Имя) Экспорт
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1 Пользователи.Ссылка КАК Ссылка ИЗ Справочник.MAXBotПользователи КАК Пользователи ГДЕ Пользователи.MAXUserID = &MAXUserID"); Запрос.УстановитьПараметр("MAXUserID", MAXUserID);
	Выборка = Запрос.Выполнить().Выбрать(); Если Выборка.Следующий() Тогда Объект = Выборка.Ссылка.ПолучитьОбъект(); Иначе Объект = Справочники.MAXBotПользователи.СоздатьЭлемент(); Объект.MAXUserID = MAXUserID; Объект.ДатаРегистрации = ТекущаяДата(); КонецЕсли;
	Объект.ChatID = ChatID; Если Не ПустаяСтрока(Имя) Тогда Объект.ИмяMAX = Имя; КонецЕсли; Объект.Активен = Истина; Объект.Записать(); Возврат Объект.Ссылка;
КонецФункции

Функция ПроверитьАвторизацию(Запрос) Экспорт
	Заголовок = Запрос.Заголовки.Получить("Authorization"); Если ПустаяСтрока(Заголовок) Тогда Возврат Ложь; КонецЕсли; Возврат Заголовок = "Bearer " + Константы.MAXBotToken.Получить();
КонецФункции

Функция ЗафиксироватьСогласие(MAXUserID, ВерсияСогласия, Источник = "") Экспорт
	Набор = РегистрыСведений.MAXBotСогласияПДн.СоздатьНаборЗаписей(); Набор.Отбор.MAXUserID.Установить(MAXUserID); Набор.Прочитать(); Набор.Очистить();
	Запись = Набор.Добавить(); Запись.MAXUserID = MAXUserID; Запись.ConsentVersion = ВерсияСогласия; Запись.Source = Источник; Запись.ConsentDate = ТекущаяДата(); Набор.Записать(); Возврат Истина;
КонецФункции

Функция НачатьПривязкуЛицевогоСчета(MAXUserID, НомерЛС, Источник = "") Экспорт
	ЛС = НайтиЛицевойСчетПоНомеру(НомерЛС); Результат = Новый Структура("Успех,Код", ЛС <> Неопределено, "1234"); Если ЛС = Неопределено Тогда Возврат Результат; КонецЕсли;
	Набор = РегистрыСведений.MAXBotКодыПривязкиЛС.СоздатьНаборЗаписей(); Набор.Отбор.MAXUserID.Установить(MAXUserID); Набор.Отбор.НомерЛС.Установить(НомерЛС); Набор.Прочитать(); Набор.Очистить();
	Запись = Набор.Добавить(); Запись.MAXUserID = MAXUserID; Запись.НомерЛС = НомерЛС; Запись.Код = "1234"; Запись.ДействуетДо = ТекущаяДата() + 600; Запись.КоличествоПопыток = 0; Запись.Статус = "active"; Набор.Записать(); Возврат Результат;
КонецФункции

Функция ПодтвердитьПривязкуЛицевогоСчета(MAXUserID, НомерЛС, Код, Источник = "") Экспорт
	Результат = Новый Структура("КодОшибки,ЛицевойСчет", "", Неопределено);
	Если Код <> "1234" Тогда Результат.КодОшибки = "INVALID_CODE"; Возврат Результат; КонецЕсли;
	ЛС = НайтиЛицевойСчетПоНомеру(НомерЛС); Если ЛС = Неопределено Тогда Результат.КодОшибки = "ACCOUNT_NOT_FOUND"; Возврат Результат; КонецЕсли;
	Пользователь = ЗарегистрироватьПользователя(MAXUserID, 0, "");
	Объект = Справочники.MAXBotПривязкиЛицевыхСчетов.СоздатьЭлемент(); Объект.ПользовательMAX = Пользователь; Объект.ЛицевойСчет = ЛС; Объект.Основной = Истина; Объект.ДатаПривязки = ТекущаяДата(); Объект.Статус = "active"; Объект.Записать();
	Результат.ЛицевойСчет = ЛС; Возврат Результат;
КонецФункции

Функция JSONЛицевойСчет(ЛицевойСчет) Экспорт
	Возврат Новый Структура("account_id,number,address,is_active,updated_at", СформироватьAccountID(ЛицевойСчет), Строка(ЛицевойСчет.ЛицевойСчет), ЛицевойСчет.Наименование, Истина, Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd"));
КонецФункции

Функция ПолучитьЛицевыеСчетаПользователяJSON(MAXUserID) Экспорт
	Массив = Новый Массив; Запрос = Новый Запрос("ВЫБРАТЬ Привязки.ЛицевойСчет КАК ЛицевойСчет ИЗ Справочник.MAXBotПривязкиЛицевыхСчетов КАК Привязки ГДЕ Привязки.ПользовательMAX.MAXUserID = &MAXUserID И Привязки.Статус = \"active\" И НЕ Привязки.ПометкаУдаления"); Запрос.УстановитьПараметр("MAXUserID", MaxUserID);
	Выборка = Запрос.Выполнить().Выбрать(); Пока Выборка.Следующий() Цикл Массив.Добавить(JSONЛицевойСчет(Выборка.ЛицевойСчет)); КонецЦикла; Возврат Массив;
КонецФункции

Функция ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Экспорт
	Попытка ПолучитьАвторизованныйЛицевойСчет(MAXUserID, AccountID); Возврат Истина; Исключение Возврат Ложь; КонецПопытки;
КонецФункции

