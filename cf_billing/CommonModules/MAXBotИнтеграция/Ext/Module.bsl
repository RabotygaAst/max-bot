Функция ЗарегистрироватьПользователя(MAXUserID, ChatID, Имя) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Пользователи.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.MAXBotПользователи КАК Пользователи
	|ГДЕ
	|	Пользователи.MAXUserID = &MAXUserID");
	Запрос.УстановитьПараметр("MAXUserID", MAXUserID);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Объект = Выборка.Ссылка.ПолучитьОбъект();
	Иначе
		Объект = Справочники.MAXBotПользователи.СоздатьЭлемент();
		Объект.MAXUserID = MAXUserID;
	КонецЕсли;
	
	Объект.ChatID = ChatID;
	Если Не ПустаяСтрока(Имя) Тогда
		Объект.ИмяMAX = Имя;
	КонецЕсли;
	Объект.Записать();
	
	Возврат Объект.Ссылка;
КонецФункции

Функция ПроверитьАвторизацию(Запрос) Экспорт
	
	Заголовок = Запрос.Заголовки.Получить("Authorization");
	
	Если ПустаяСтрока(Заголовок) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Ожидаемый = "Bearer " + Константы.MAXBotToken.Получить();
	
	Возврат Заголовок = Ожидаемый;
	
КонецФункции

