#Область ПрограммныйИнтерфейс

Функция StartUser(Параметры) Экспорт
	ЗарегистрироватьПользователя(Параметры.max_user_id, Параметры.chat_id, ?(Параметры.Свойство("first_name"), Параметры.first_name, ""));
	Возврат СформироватьУспешныйОтвет(Новый Структура, "Пользователь зарегистрирован", "OK");
КонецФункции

Функция SaveConsent(Параметры) Экспорт
	ЗафиксироватьСогласие(Параметры.max_user_id, Параметры.consent_version, ?(Параметры.Свойство("source"), Параметры.source, ""));
	Возврат СформироватьУспешныйОтвет(Новый Структура, "Согласие зафиксировано", "OK");
КонецФункции

Функция StartAccountLink(Параметры) Экспорт
	Результат = НачатьПривязкуЛицевогоСчета(Параметры.max_user_id, Параметры.account_number, ?(Параметры.Свойство("source"), Параметры.source, "MAX"));
	Если Не Результат.Успех Тогда Возврат СформироватьОтветОшибки("ACCOUNT_NOT_FOUND", "Лицевой счет не найден"); КонецЕсли;
	Возврат СформироватьУспешныйОтвет(Новый Структура, "Лицевой счет найден, код отправлен", "OK");
КонецФункции

Функция ConfirmAccountLink(Параметры) Экспорт
	Результат = ПодтвердитьПривязкуЛицевогоСчета(Параметры.max_user_id, Параметры.account_number, Параметры.code, ?(Параметры.Свойство("source"), Параметры.source, "MAX"));
	Если Результат.КодОшибки <> "" Тогда Возврат СформироватьОтветОшибки(Результат.КодОшибки, "Ошибка подтверждения привязки"); КонецЕсли;
	Возврат СформироватьУспешныйОтвет(JSONЛицевойСчет(Результат.ЛицевойСчет), "Счет привязан", "OK");
КонецФункции

Функция GetAccounts(MaxUserID) Экспорт
	Возврат СформироватьУспешныйОтвет(ПолучитьЛицевыеСчетаПользователяJSON(MaxUserID), "Список счетов", "OK");
КонецФункции

Функция GetBalance(MaxUserID, AccountID) Экспорт
	ЛицевойСчет = ПолучитьАвторизованныйЛицевойСчет(MaxUserID, AccountID);
	Детализация = ПолучитьПоследниеНачисленияТарифыУслуги(ЛицевойСчет);
	Данные = Новый Структура;
	Данные.Вставить("account_id", СформироватьAccountID(ЛицевойСчет));
	Данные.Вставить("debt", Детализация.Долг);
	Данные.Вставить("overpay", Детализация.Переплата);
	Данные.Вставить("currency", "руб.");
	Данные.Вставить("actual_at", Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd"));
	Возврат СформироватьУспешныйОтвет(Данные, "Баланс", "OK");
КонецФункции

Функция GetMeters(MaxUserID, AccountID) Экспорт
	ЛицевойСчет = ПолучитьАвторизованныйЛицевойСчет(MaxUserID, AccountID);
	Возврат СформироватьУспешныйОтвет(ПолучитьПриборыУчета(ЛицевойСчет), "Приборы", "OK");
КонецФункции

Функция SendReading(MaxUserID, AccountID, MeterID, Параметры) Экспорт
	ПолучитьАвторизованныйЛицевойСчет(MaxUserID, AccountID);
	Результат = СоздатьПоказаниеПрибора(AccountID, MeterID, Параметры.period, Параметры.value, Параметры.source, MaxUserID, ?(Параметры.Свойство("message_id"), Параметры.message_id, ""), ?(Параметры.Свойство("operation_id"), Параметры.operation_id, ""));
	Данные = Новый Структура("document_number,document_date,meter_id,value", Результат.Номер, Формат(Результат.Дата, "ДФ=yyyy-MM-dd"), MeterID, Параметры.value);
	Возврат СформироватьУспешныйОтвет(Данные, "Показание принято", "OK");
КонецФункции

Функция CreateAppeal(MaxUserID, AccountID, Параметры) Экспорт
	ПолучитьАвторизованныйЛицевойСчет(MaxUserID, AccountID);
	Результат = СоздатьОбращение(AccountID, MaxUserID, Параметры.category, Параметры.text, Параметры.source, ?(Параметры.Свойство("message_id"), Параметры.message_id, ""), ?(Параметры.Свойство("operation_id"), Параметры.operation_id, ""));
	Данные = Новый Структура("appeal_id,number,status,sla", ?(Результат.Ссылка = Неопределено, Результат.Номер, Строка(Результат.Ссылка.УникальныйИдентификатор())), Результат.Номер, "зарегистрировано", Результат.СрокИсполненияСтрокой);
	Возврат СформироватьУспешныйОтвет(Данные, "Обращение создано", "OK");
КонецФункции

Функция GetHelp() Экспорт
	Возврат СформироватьУспешныйОтвет(Новый Структура("text", "Команды: /start, авторизоваться, баланс, квитанция YYYY-MM, показания, показание <meter_id> <значение>, обращение <текст>, отключения, запись."), "Справка", "OK");
КонецФункции

Функция GetOrganization() Экспорт
	Данные = Новый Структура("name,phone,email,site,work_hours,office_address,customer_service_hours", "", "", "", "", "", "", "");
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1 Организации.Наименование КАК Наименование ИЗ Справочник.Организации КАК Организации ГДЕ НЕ Организации.ПометкаУдаления");
	Выборка = Запрос.Выполнить().Выбрать(); Если Выборка.Следующий() Тогда Данные.name = Выборка.Наименование; КонецЕсли;
	Возврат СформироватьУспешныйОтвет(Данные, "Сведения об организации", "OK");
КонецФункции

Функция GetEmergency() Экспорт
