Функция GetOutages(MaxUserID, AccountID) Экспорт
	ПолучитьАвторизованныйЛицевойСчет(MaxUserID, AccountID);
	Возврат СформироватьУспешныйОтвет(Новый Массив, "Отключения", "OK");
КонецФункции

Функция GetAppointmentTopics() Экспорт
	Темы = Новый Массив; Темы.Добавить(Новый Структура("topic_id,title", "billing", "Начисления и перерасчеты")); Темы.Добавить(Новый Структура("topic_id,title", "meters", "Приборы учета")); Темы.Добавить(Новый Структура("topic_id,title", "contract", "Договор"));
	Возврат СформироватьУспешныйОтвет(Темы, "Темы приема", "OK");
