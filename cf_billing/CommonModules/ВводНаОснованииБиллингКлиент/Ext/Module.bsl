
#Область СозданиеПерерасчет

Функция ОткрытиеЛицевогоСчетаНаОснованииЗакрытияЛС(ОписаниеКоманды) Экспорт 
	СсылкаДок = Неопределено;
	Если СтрНайти(ОписаниеКоманды.Форма.ИмяФормы, "ФормаСписка") <> 0 Тогда
		СсылкаДок = ОписаниеКоманды.Форма.Элементы.Список.ТекущаяСтрока;
	ИначеЕсли СтрНайти(ОписаниеКоманды.Форма.ИмяФормы, "ФормаДокумента") <> 0 Тогда
		СсылкаДок = ОписаниеКоманды.Форма.Объект.Ссылка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СсылкаДок) 
			И СсылкаДок.ВидОперации <> ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСЛС_ЗакрытиеЛС") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("Основание", СсылкаДок);
	ОткрытьФорму("Документ.энргОперацияСЛицевымСчетом.Форма.ФормаДокументаОткрытиеЛС", ПараметрыФормы);	
КонецФункции

Функция ПерерасчетНаОснованиииОперацияСЛицевымСчетом(ОписаниеКоманды) Экспорт  
	СсылкаДок = Неопределено;
	Если СтрНайти(ОписаниеКоманды.Форма.ИмяФормы, "ФормаСписка") <> 0 Тогда
		СсылкаДок = ОписаниеКоманды.Форма.Элементы.Список.ТекущаяСтрока;
	ИначеЕсли СтрНайти(ОписаниеКоманды.Форма.ИмяФормы, "ФормаДокумента") <> 0 Тогда
		СсылкаДок = ОписаниеКоманды.Форма.Объект.Ссылка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СсылкаДок) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПарамФормы = Новый Структура("Организация, Район, Договор"); 
	энргОбщегоНазначения.ПолучитьЗначенияРеквизитов("Документ", СсылкаДок, ПарамФормы);
	
	ПарамФормы.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.бестВидыОпераций.Перерасчет_РучнойПерерасчет"));
	ПарамФормы.Вставить("Основание", СсылкаДок);

	ОткрытьФорму("Документ.бестПерерасчетНП.Форма.ФормаДокументаРучнойПерерасчет", ПарамФормы);
КонецФункции

Функция ПерерасчетНаОснованиииОперацииСЛС(ОписаниеКоманды) Экспорт  
	СсылкаДок = Неопределено;
	Если СтрНайти(ОписаниеКоманды.Форма.ИмяФормы, "ФормаСписка") <> 0 Тогда
		СсылкаДок = ОписаниеКоманды.Форма.Элементы.Список.ТекущаяСтрока;
	ИначеЕсли СтрНайти(ОписаниеКоманды.Форма.ИмяФормы, "ФормаДокумента") <> 0 Тогда
		СсылкаДок = ОписаниеКоманды.Форма.Объект.Ссылка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СсылкаДок) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПарамФормы = Новый Структура("Организация, Район, Договор, Абонент, КлючПомещения"); 
	энргОбщегоНазначения.ПолучитьЗначенияРеквизитов("Документ", СсылкаДок, ПарамФормы);
	
	ПарамФормы.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет"));
	ПарамФормы.Вставить("Основание", СсылкаДок);
	Если ЗначениеЗаполнено(ПарамФормы.Абонент) Тогда
		ЛицевойСчет = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПарамФормы.Абонент, "ЛицевойСчет");
		ПарамФормы.Вставить("ЛицевойСчет", ЛицевойСчет);
	КонецЕсли;
	Если ЗначениеЗаполнено(ПарамФормы.КлючПомещения) Тогда
		Строение = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПарамФормы.КлючПомещения, "Строение");
		ПарамФормы.Вставить("Строение", Строение);
	КонецЕсли;

	ОткрытьФорму("Документ.энргПерерасчет.Форма.ФормаДокументаСвязанныйПерерасчет", ПарамФормы);
КонецФункции

