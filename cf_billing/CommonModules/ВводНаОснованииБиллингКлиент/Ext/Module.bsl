Функция ПерерасчетНаОснованиииУстановитьФормулуРасчетаТочекУчета(ОписаниеКоманды) Экспорт  
		
	ОбъектыОснований 			= ОписаниеКоманды.ОбъектыОснований;
	Если ОбъектыОснований.Количество() = 0 Тогда
		ТекстСообщения  		= НСтр("ru = 'Для выбранного документа перерасчет не требуется'");
		ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(ТекстСообщения);
		Возврат Неопределено;			
	КонецЕсли;
	
	ДанныеДляПерерасчета 		= энргРаботаСПериодомДействия.ЗаполнитьДанныеДляПерерасчета(ОбъектыОснований[0],"ТочкиУчета"); 
	
	Если НЕ ДанныеДляПерерасчета = Неопределено тогда
		энргРаботаСПериодомДействияКлиент.ОткрытьФормуДокументаПерерасчет(ДанныеДляПерерасчета);		
	КонецЕсли;
	
КонецФункции

Функция РасходныйКассовыйОрдерНаОснованииПерерасчет(ОписаниеКоманды) Экспорт 
	СсылкаДок = Неопределено;
	Если СтрНайти(ОписаниеКоманды.Форма.ИмяФормы, "ФормаСписка") <> 0 Тогда
		СсылкаДок = ОписаниеКоманды.Форма.Элементы.Список.ТекущаяСтрока;
	ИначеЕсли СтрНайти(ОписаниеКоманды.Форма.ИмяФормы, "ФормаДокумента") <> 0 Тогда
		СсылкаДок = ОписаниеКоманды.Форма.Объект.Ссылка;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СсылкаДок) Тогда			
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("Основание", СсылкаДок);
	ОткрытьФорму("Документ.энргРасходныйКассовыйОрдер.Форма.ФормаДокумента", ПараметрыФормы);	
КонецФункции

