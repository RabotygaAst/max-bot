#Область ФункцииПереходаВерсий

&НаСервере
Процедура ЗаполнитьИзмерения_МКД()
	
	Запрос  								= Новый Запрос;
	Запрос.Текст 							= 
	"ВЫБРАТЬ
	|	энргНомераСтрокСтабильногоПериодаМКД.Регистратор,
	|	МАКСИМУМ(энргНомераСтрокСтабильногоПериодаМКД.Период) КАК Период
	|ИЗ
	|	РегистрСведений.энргНомераСтрокСтабильногоПериодаМКД КАК энргНомераСтрокСтабильногоПериодаМКД
	|
	|СГРУППИРОВАТЬ ПО
	|	энргНомераСтрокСтабильногоПериодаМКД.Регистратор";
	
	Результат  								= Запрос.Выполнить();
	Выборка  								= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		Набор  								= РегистрыСведений.энргНомераСтрокСтабильногоПериодаМКД.СоздатьНаборЗаписей();
		Набор.Отбор.регистратор.установить(Выборка.Регистратор);
		Набор.Прочитать();
		Для Каждого СтрокаНабора из Набор цикл
			СтрокаНабора.ДокРегистратор 	= Выборка.Регистратор;
			СтрокаНабора.ДатаРегистратора 	= Выборка.Период;
		КонецЦикла;
		Набор.Записать();
	КонецЦикла; 	
КонецПроцедуры


#КонецОбласти
