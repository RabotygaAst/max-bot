	Пакет = Запрос.ВыполнитьПакет();
	ИндексПоследнегоПакета = Пакет.ВГраница();
	
	СтруктураВозврата = Новый Структура();
	СтруктураВозврата.Вставить("Авансы", Пакет.Получить(ИндексПоследнегоПакета));
	СтруктураВозврата.Вставить("Переплаты", Пакет.Получить(ИндексПоследнегоПакета - 1));
	
	Возврат СтруктураВозврата;
	
