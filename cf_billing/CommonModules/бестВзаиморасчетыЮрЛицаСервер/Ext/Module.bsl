// Функция - Получить фактическую задолженность по периодам
// Получение остатков из РН бестВзаиморасчетыПоМесяцамЭЭ с возможностью отбора по Срезу или по Периоду
// начисления (ПериодНачало, ПериодКонец)
//
// Параметры:
//  Организация	 - СправочникСсылка.Организации 
//  Район		 - СправочникСсылка.энргЗоныОтвественности  
//  Договор		 - СправочникСсылка.энргДоговорыКонтрагентов 
//  ПериодНачало - Дата
//  ПериодКонец	 - Дата 
//  ПериодСрез	 - Дата
//  ВключатьГраницу	 - Булево 
// 
// Возвращаемое значение:
//   РезультатЗапроса 
//
Функция ПолучитьФактическуюЗадолженностьПоПериодам(Организация, Район, Договор ,ПериодНачало = Неопределено, 
		ПериодКонец = Неопределено, ПериодСрез = Неопределено, ВключатьГраницу = Ложь) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестВзаиморасчетыПоМесяцамЭЭОстатки.ПериодНачисления КАК ПериодНачисления,
		|	бестВзаиморасчетыПоМесяцамЭЭОстатки.СуммаОстаток КАК Задолженность,
		|	бестВзаиморасчетыПоМесяцамЭЭОстатки.ПлатежныйДокумент КАК ПлатежныйДокумент,
		|	бестВзаиморасчетыПоМесяцамЭЭОстатки.СуммаНДСОстаток КАК СуммаНДС
		|ИЗ
		|	РегистрНакопления.бестВзаиморасчетыПоМесяцамЭЭ.Остатки(
		|			&ПериодСрез,
		|			Организация = &Организация
		|				И Район = &Район
		|				И Договор = &Договор
		|				И (ПериодНачисления МЕЖДУ &ПериодНачало И &ПериодКонец)) КАК бестВзаиморасчетыПоМесяцамЭЭОстатки";
	
	Если ПериодСрез = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ПериодСрез", "");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "(ПериодНачисления МЕЖДУ &ПериодНачало И &ПериодКонец)", "ИСТИНА"); 
		Если ВключатьГраницу Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестВзаиморасчетыПоМесяцамЭЭОстатки.ПериодНачисления КАК ПериодНачисления,", "");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестВзаиморасчетыПоМесяцамЭЭОстатки.ПлатежныйДокумент КАК ПлатежныйДокумент,", "");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Задолженность", "Сумма"); 
		КонецЕсли;
	КонецЕсли;
	
	Граница = Новый Граница(ПериодСрез, ?(ВключатьГраницу, ВидГраницы.Включая, ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Договор", 		Договор);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("ПериодКонец", 	ПериодКонец);
	Запрос.УстановитьПараметр("ПериодНачало", 	ПериодНачало);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("ПериодСрез",	 	Граница);
	
	Возврат Запрос.Выполнить();
	
КонецФункции

