// Функция - Получить задолженность по ПД
// Получение задолженности по платежным документам
//
// Параметры:
//  Организация			 - СправочникСсылка.Организации 
//  Район				 - СправочникСсылка.энргЗоныОтвественности 
//  мДокументНачисления	 - Массив - Массив элементов с типом ДокументСсылка.бестПлатежныйДокумент
//  Период				 - Дата 
// 
// Возвращаемое значение:
//   Соответствие 
//
Функция ПолучитьЗадолженностьПоПД(Организация, Район, мДокументНачисления, Период) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестВзаиморасчетыПоМесяцамЭЭОстатки.СуммаОстаток КАК СуммаОстаток,
		|	бестВзаиморасчетыПоМесяцамЭЭОстатки.ПлатежныйДокумент КАК ПлатежныйДокумент
		|ИЗ
		|	РегистрНакопления.бестВзаиморасчетыПоМесяцамЭЭ.Остатки(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ПлатежныйДокумент <> ЗНАЧЕНИЕ(Документ.бестПлатежныйДокумент.ПустаяСсылка)
		|				И ПлатежныйДокумент В (&ПлатежныйДокумент)) КАК бестВзаиморасчетыПоМесяцамЭЭОстатки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бестВзаиморасчетыПоАвансовымСчетамОстатки.СуммаОстаток,
		|	бестВзаиморасчетыПоАвансовымСчетамОстатки.ПлатежныйДокумент
		|ИЗ
		|	РегистрНакопления.бестВзаиморасчетыПоАвансовымСчетам.Остатки(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ПлатежныйДокумент <> ЗНАЧЕНИЕ(Документ.бестПлатежныйДокумент.ПустаяСсылка)
		|				И ПлатежныйДокумент В (&ПлатежныйДокумент)) КАК бестВзаиморасчетыПоАвансовымСчетамОстатки";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("ПлатежныйДокумент", мДокументНачисления);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	СоответствиеЗадолженности = Новый Соответствие;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СоответствиеЗадолженности.Вставить(ВыборкаДетальныеЗаписи.ПлатежныйДокумент,
			ВыборкаДетальныеЗаписи.СуммаОстаток);
	КонецЦикла;
	
	Возврат СоответствиеЗадолженности;
КонецФункции

