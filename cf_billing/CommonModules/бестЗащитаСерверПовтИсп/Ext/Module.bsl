// Возвращает серию.
// 
// Возвращаемое значение:
//  Строка - серия 6585
//
Функция Серия() Экспорт 
	Возврат "6585";	
КонецФункции

// Инструменты начислений НП
// 
// Возвращаемое значение:
//  ОбработкаОбъект.бестИнструментыНачисленийНП
//
Функция ИнструментыНачисленийНП() Экспорт	
	
	ИспользоватьПодсистемуСЛК = ИспользоватьПодсистемуСЛК();
	
	Если ИспользоватьПодсистемуСЛК Тогда
		ИнструментОбъект = слкМенеджерЗащиты.СоздатьОбъект(Серия(), "слкОбъектыСЛК.бестИнструментыНачисленийНП");
	Иначе
		ИнструментОбъект = Обработки.бестИнструментыНачисленийНП.Создать();	
	КонецЕсли;
	
	Возврат ИнструментОбъект;

КонецФункции

