// Процедура - Начислить.
// Создание документа бестНачислениеНП.
//
// Параметры:
//  Параметры		-	Структура:
//							* Организация				-	СправочникСсылка.Организации.
//							* Район						-	СправочникСсылка.энргЗоныОтвественности.
//							* ПериодНачисления			-	Дата.
//							* МКД_НП					-	СправочникСсылка.энргСтроения.
//							* ИсключаяОтдельностоящие	-	Булево.
//  мОбъектыРасчета	-	Массив значений типа СправочникСсылка.бестОбъектыРасчета.
//  Документ		-	ДокументСсылка.бестНачислениеНП.
//
Процедура Начислить(Параметры,мОбъектыРасчета = Неопределено,Документ  = Неопределено) Экспорт
	
	Инструменты = бестЗащитаСерверПовтИсп.ИнструментыНачисленийНП();
	Если Инструменты = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект"; 
		Возврат;
	КонецЕсли; 
	Инструменты.Начислить(Параметры.Организация, Параметры.ПериодНачисления, Параметры.Район,Параметры.МКД_НП,Параметры.ИсключаяОтдельностоящие,мОбъектыРасчета,Документ);
	
КонецПроцедуры

