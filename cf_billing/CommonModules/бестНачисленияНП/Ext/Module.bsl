// Описание документа начисления.
//
// Параметры:
//  ИмяДокумента-	Строка	-	имя документа, для которого требуется получить описание.
// 
// Возвращаемое значение:
//	 Структура.
//
Функция ОписаниеДокументаНачисления(ИмяДокумента) Экспорт 
	
	Описание 			= Новый Структура;
	
	МетаданныеДокумета  = Метаданные.Документы[ИмяДокумента];
	
	для Каждого Реквизит из МетаданныеДокумета.Реквизиты цикл
		Описание.Вставить(Реквизит.имя);
	КонецЦикла;
	
	Для Каждого ТабЧасть из МетаданныеДокумета.ТабличныеЧасти цикл
		
		ТаблицаТЧ		= Новый ТаблицаЗначений;
		
		для Каждого РеквизитТЧ из ТабЧасть.реквизиты цикл
			ТаблицаТЧ.Колонки.Добавить(РеквизитТЧ.Имя,РеквизитТЧ.тип);
		КонецЦикла;
		Описание.Вставить(ТабЧасть.имя,ТаблицаТЧ);
	КонецЦикла;
	
	Возврат Описание;	
КонецФункции

