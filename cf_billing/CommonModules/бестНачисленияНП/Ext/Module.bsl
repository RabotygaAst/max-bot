// Записать наборы записей.
//
// Параметры:
//  СтруктураНаборов	-	Структура.
//
Процедура ЗаписатьНаборыЗаписей(СтруктураНаборов) Экспорт 
	
	Ключи = Новый СписокЗначений;
	Для Каждого КлючЗначение Из СтруктураНаборов Цикл
		Ключи.Добавить(КлючЗначение.Ключ);
	КонецЦикла;
	
	Ключи.СортироватьПоЗначению();
	
	Для Каждого СтрокаСписка Из Ключи Цикл
		СтруктураНаборов[СтрокаСписка.Значение].Записать();
	КонецЦикла;	
	
КонецПроцедуры

// Сформировать строку для запроса.
//
// Параметры:
//  ИмяРегистра		-	Строка	-	имя регистра накопления, для которого формируется строка запроса.
//  ИмяТаблицы		-	Строка	-	имя таблицы в запросе.
//  ИсключаемыеПоля	-	Строка	-	список полей, разделенных запятой, которые нужно исключить из результата.
//  ПерваяСтрока	-	Булево	-	флаг, указывающий что это первая строка в списке полей.
//  ПоследняяСтрока	-	Булево	-	флаг, указывающий что это последняя строка в списке полей.
//  ЭтоГруппировка	-	Булево	-	флаг, указывающий что строка формируется для раздела СГРУППИРОВАТЬ ПО.
// 
// Возвращаемое значение:
//  Строка	-	строка для использования в запросе.
//
Функция СформироватьСтрокуДляЗапроса(ИмяРегистра,ИмяТаблицы,ИсключаемыеПоля,ПерваяСтрока = Ложь, ПоследняяСтрока = Истина ,ЭтоГруппировка = ложь) Экспорт
	
	ОписаниеТаблицы = бестНачисленияНП.ИзмеренияТаблицыОбъемов(ИмяРегистра); 
	
	ПоляИсключая 	= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИсключаемыеПоля,,Истина);
	ПоляИзмерений 	= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ОписаниеТаблицы.Измерения,,Истина);
	ПоляРесурсов	= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ОписаниеТаблицы.Ресурсы,,Истина);
	
	Если ПерваяСтрока Тогда
		Сч 			= 0;
	Иначе
		Сч 			= 1;
	КонецЕсли;

	Результат  		= "";
	Для Каждого Поле Из ПоляИзмерений Цикл
		Если НЕ ПоляИсключая.Найти(Поле) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Результат 	= Результат + ?(Сч > 0, Символы.ПС,"") + ИмяТаблицы + "." + Поле + ?(Не ЭтоГруппировка, " КАК " + Поле + ",", ","); 
		Сч 			= Сч + 1;		
	КонецЦикла;	
	
	Для Каждого Поле Из ПоляРесурсов Цикл
		Если НЕ ПоляИсключая.Найти(Поле) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Результат 	= Результат + ?(Сч > 0, Символы.ПС,"") + ИмяТаблицы + "." + Поле + ?(Не ЭтоГруппировка, " КАК " + Поле + ",", ","); 
		Сч 			= Сч + 1;		
	КонецЦикла;
	
	Если ПоследняяСтрока Тогда
		Результат 	= Лев(Результат, СтрДлина(Результат) - 1);
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

