// Текст границ отчетного периода.
//
// Параметры:
//  НачПерНач					-	Дата	-	дата начала периода.
//  КонПерНач					-	Дата	-	дата начала периода.
//  УчитыватьНачалоВеденияУчета	-	Булево	-	флаг, указывающий необходимость учета даты начала ведения учета.
// 
// Возвращаемое значение:
//  Строка	-	текст запроса формирующий таблицу с границами отчетных периодов.
//
Функция ТекстГраницОтчетногоПериода(НачПерНач,КонПерНач,УчитыватьНачалоВеденияУчета = ложь) Экспорт
	Нач				= НачПерНач; 	
	
	Шаблон 			=
	"ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&Район КАК Район,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ПериодНачисления, СЕКУНДА, -1), МЕСЯЦ), ДЕНЬ, ВЫБОР
	|			КОГДА бестДатыОтчетногоПериодыОбщиеНастройки.Завершение = 31
	|				ТОГДА ДЕНЬ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ПериодНачисления, МЕСЯЦ), СЕКУНДА, -1))
	|			ИНАЧЕ бестДатыОтчетногоПериодыОбщиеНастройки.Завершение
	|		КОНЕЦ) КАК НачалоОП,
	|	ДОБАВИТЬКДАТЕ(&ПериодНачисления, ДЕНЬ, ВЫБОР
	|			КОГДА бестДатыОтчетногоПериодыОбщиеНастройки.Завершение = 31
	|				ТОГДА ДЕНЬ(КОНЕЦПЕРИОДА(&ПериодНачисления, МЕСЯЦ))
	|			ИНАЧЕ бестДатыОтчетногоПериодыОбщиеНастройки.Завершение
	|		КОНЕЦ) КАК ЗавершениеОП,
	|	РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ПериодНачисления, СЕКУНДА, -1), МЕСЯЦ), ДЕНЬ, ВЫБОР
	|				КОГДА бестДатыОтчетногоПериодыОбщиеНастройки.Завершение = 31
	|					ТОГДА ДЕНЬ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ПериодНачисления, МЕСЯЦ), СЕКУНДА, -1))
	|				ИНАЧЕ бестДатыОтчетногоПериодыОбщиеНастройки.Завершение
	|			КОНЕЦ), ДОБАВИТЬКДАТЕ(&ПериодНачисления, ДЕНЬ, ВЫБОР
	|				КОГДА бестДатыОтчетногоПериодыОбщиеНастройки.Завершение = 31
	|					ТОГДА ДЕНЬ(КОНЕЦПЕРИОДА(&ПериодНачисления, МЕСЯЦ))
	|				ИНАЧЕ бестДатыОтчетногоПериодыОбщиеНастройки.Завершение
	|			КОНЕЦ), ДЕНЬ) КАК ДнейВПериоде
	|ИЗ
	|	(ВЫБРАТЬ
	|		бестДатыОтчетногоПериодыОбщиеНастройки.Завершение КАК Завершение
	|	ИЗ
	|		РегистрСведений.бестДатыОтчетногоПериодыОбщиеНастройки КАК бестДатыОтчетногоПериодыОбщиеНастройки
	|	ГДЕ
	|		бестДатыОтчетногоПериодыОбщиеНастройки.Организация = &Организация) КАК бестДатыОтчетногоПериодыОбщиеНастройки";
	Текст 				= "";
	Сч					= 0;
	Пока Истина цикл
		Если  Нач >КонПерНач тогда
			Прервать;;
		КонецЕсли;
		СтрокаПериода 		= "ДАТАВРЕМЯ(" +СтрЗаменить(СтрЗаменить(Год(Нач)," ",""),Символы.НПП,"") + "," + СтрЗаменить(СтрЗаменить(МЕСЯЦ(Нач)," ",""),Символы.НПП,"") + "," +  СтрЗаменить(СтрЗаменить(ДЕНЬ(Нач)," ",""),Символы.НПП,"") + ")";
		
		Если Сч> 0 тогда
			Текст 			= Текст + Символы.ПС + "ОБЪЕДИНИТЬ ВСЕ" +Символы.ПС; 						
		КонецЕсли;
		
		Текст 				= Текст + СтрЗаменить(Шаблон,"&ПериодНачисления",СтрокаПериода);
		Если Сч = 0 тогда
			Текст 			= СтрЗаменить(Текст,"%%ФормируемВременную%%","ПОМЕСТИТЬ ГраницыОтчетногоПериода");
		иначе 
			Текст 			= СтрЗаменить(Текст,"%%ФормируемВременную%%",""); 						
		КонецЕсли;		
		Сч 					= Сч + 1;
		Нач 				= ДобавитьМесяц(Нач,1);
	КонецЦикла;
	
	Если УчитыватьНачалоВеденияУчета тогда
		НачалоВеденияУчета 	= энргОбщегоНазначения.ЗначениеКонстанты("энргДатаНачалаВеденияУчета");
		Если ЗначениеЗаполнено(НачалоВеденияУчета) тогда
			Год 			= СтрЗаменить(Год(НачалоВеденияУчета),Символы.НПП,"");
			Месяц 			= СтрЗаменить(Месяц(НачалоВеденияУчета),Символы.НПП,"");
			День 			= СтрЗаменить(День(НачалоВеденияУчета),Символы.НПП,"");
			СтрокаЗапроса  	= "ДАТАВРЕМЯ(" + Год + "," + Месяц + "," + День + ")";
			СтрокаПоиска	= "" +СтрокаЗапроса +" КАК ПериодНачисления,
			|	ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(" + СтрокаЗапроса + ", СЕКУНДА, -1), МЕСЯЦ), ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеПредыдущего, бестДатыОтчетногоПериодыОбщиеНастройки.Завершение)) КАК НачалоОП,
			|	ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, бестДатыОтчетногоПериодыОбщиеНастройки.Завершение)) КАК ЗавершениеОП,
			|	РазностьДат(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", СЕКУНДА, -1), МЕСЯЦ), ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеПредыдущего, бестДатыОтчетногоПериодыОбщиеНастройки.Завершение)),ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, бестДатыОтчетногоПериодыОбщиеНастройки.Завершение)), СЕКУНДА, -1),День)+1  КАК ДнейВПериоде";
			
			СтрокаЗамены 	= "" + СтрокаЗапроса +" КАК ПериодНачисления,
			|	" + СтрокаЗапроса +" КАК НачалоОП,
			|	ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, бестДатыОтчетногоПериодыОбщиеНастройки.Завершение)) как ЗавершениеОП,
			|	РазностьДат(" + СтрокаЗапроса +",ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, бестДатыОтчетногоПериодыОбщиеНастройки.Завершение)),ДЕНЬ)  КАК ДнейВПериоде";
			
			Текст 			= СтрЗаменить(Текст,СтрокаПоиска,СтрокаЗамены);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#КонецОбласти