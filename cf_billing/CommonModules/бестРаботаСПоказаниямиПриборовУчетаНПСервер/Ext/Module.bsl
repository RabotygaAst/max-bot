	Отбор = Новый Структура("IDСтроки, ТарифнаяЗона"); 
	
	Пока выборка.Следующий() Цикл 
		СтрокаДанных = тзТаблицаПоказаний[Выборка.НомерСтроки -1];
		
		Отбор.IDСтроки  	= СтрокаДанных.IDСтроки;
