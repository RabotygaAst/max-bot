#Область ПрограммныйИнтерфейс

// Обновляет показания прибора учета.
//
// Параметры:
//  ТабЧасть			-	ДанныеФормыКоллекция	-	ТЧ с показаниями.
//  Параметры			-	Структура:
//   * ТочкаУчета	-	СправочникСсылка.энргТочкиУчета.
//   * Услуга		-	СправочникСсылка.энргВидыУслуг.
//  ВыводПрибораУчета	-	Булево.
//
Процедура ОбновитьПоказанияПрибораУчета(ТабЧасть, Параметры, ВыводПрибораУчета = Неопределено) Экспорт 
			
	// заполняем табличную часть приборы
	Запрос	= Новый Запрос;
	МВТ		= Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц	= МВТ;

	МаксимальныеПоказанияСрезПоследних(МВТ,"энргМаксимальныеПоказанияСрезПоследних",Параметры);
	Текст = "
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона
	|ПОМЕСТИТЬ ТарифныеЗоныПриборовУчета
	|ИЗ
	|	Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
	|		ГДЕ энргВидыДифференцированностиТарифныеЗоны.Ссылка = &ВидДифференцированности
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТарифныеЗоныПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргМаксимальныеПоказанияСрезПоследних.Период КАК ДатаПоследнихПоказаний,
	|	энргМаксимальныеПоказанияСрезПоследних.Показание КАК ПредыдущиеПоказания
	|ИЗ
	|	ТарифныеЗоныПриборовУчета КАК ТарифныеЗоныПриборовУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ энргМаксимальныеПоказанияСрезПоследних КАК энргМаксимальныеПоказанияСрезПоследних
	|		ПО ТарифныеЗоныПриборовУчета.ТарифнаяЗона = энргМаксимальныеПоказанияСрезПоследних.ТарифнаяЗона
	|";  
	
	Запрос.Текст	= Текст;
	Запрос.УстановитьПараметр("ВидДифференцированности", Параметры.ВидДифференцированности);
	Результат		= Запрос.Выполнить();
	Выборка			= Результат.Выбрать();
	
	СоотвествиеПоказаний 					= Новый Соответствие;
	// Ищем строки по индентификатору
	Если ВыводПрибораУчета <> Неопределено Тогда
		СтруктураПоиска  						= Новый Структура("IDСтроки,ВыводПрибораУчета", Параметры.IDСтроки, ВыводПрибораУчета);
	Иначе
		СтруктураПоиска  						= Новый Структура("IDСтроки", Параметры.IDСтроки);	
	КонецЕсли;
	СтрокиСоотвествия 						= ТабЧасть.НайтиСтроки(СтруктураПоиска);	
	 
	для Каждого СтрокаСоотвествия из СтрокиСоотвествия цикл
		СоотвествиеПоказаний.Вставить(СтрокаСоотвествия.ТарифнаяЗона,СтрокаСоотвествия.ТекущиеПоказания);
		ТабЧасть.Удалить(СтрокаСоотвествия);
	КонецЦикла;  
	
	
	Пока выборка.Следующий() цикл		 
		СтрокаПоказаний  			= ТабЧасть.добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПоказаний, Выборка);
		СтрокаПоказаний.IDСтроки 	= Параметры.IDСтроки; 		
		Если ВыводПрибораУчета <> Неопределено Тогда
			СтрокаПоказаний.ВыводПрибораУчета 	= ВыводПрибораУчета;
		КонецЕсли;
		
		Если СоотвествиеПоказаний[выборка.ТарифнаяЗона] <> Неопределено тогда
			СтрокаПоказаний.ТекущиеПоказания 	= СоотвествиеПоказаний[выборка.ТарифнаяЗона];
		КонецЕсли;
		
	КонецЦикла;   
	
КонецПроцедуры

// Дополняет МВТ данными из РС бестМаксимальныеПоказанияНП.
//
// Параметры:
//  МВТ			-	МенеджерВременныхТаблиц.
//  ИмяТаблицы	-	Строка.
//  Параметры	-	Структура:
//   * Организация		-	СправочникСсылка.Организации.
//   * Район			-	СправочникСсылка.энргЗоныОтвественности.
//   * Дата				-	Дата.
//   * ОбъектРасчета	-	СправочникСсылка.бестОбъектыРасчета.
//
Процедура МаксимальныеПоказанияСрезПоследних(МВТ,ИмяТаблицы,Параметры) Экспорт
	
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Текст = 
	"ВЫБРАТЬ
	|	бестМаксимальныеПоказанияНП.Район КАК Район,
	|	бестМаксимальныеПоказанияНП.ПриборУчета КАК ПриборУчета,
	|	бестМаксимальныеПоказанияНП.Шкала КАК Шкала,
	|	бестМаксимальныеПоказанияНП.ТарифнаяЗона КАК ТарифнаяЗона,
	|	бестМаксимальныеПоказанияНП.Период КАК Период,
	|	бестМаксимальныеПоказанияНП.Регистратор КАК Регистратор,
	|	бестМаксимальныеПоказанияНП.Разделитель КАК Разделитель,
	|	бестМаксимальныеПоказанияНП.Показание КАК Показание,
	|	бестМаксимальныеПоказанияНП.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ Набор
	|ИЗ
	|	РегистрСведений.бестМаксимальныеПоказанияНП КАК бестМаксимальныеПоказанияНП
	|ГДЕ
	|	бестМаксимальныеПоказанияНП.Организация = &Организация
	|	И бестМаксимальныеПоказанияНП.Район = &Район
	|	И бестМаксимальныеПоказанияНП.ПриборУчета = &ПриборУчета
	|	И бестМаксимальныеПоказанияНП.Период <= &МоментВремениПериод
	|	И бестМаксимальныеПоказанияНП.Регистратор <= &МоментВремениРегистратор
	|	И бестМаксимальныеПоказанияНП.ОбъектРасчета В(&ОбъектРасчета)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Набор.Район КАК Район,
	|	Набор.ПриборУчета КАК ПриборУчета,
	|	Набор.Шкала КАК Шкала,
	|	Набор.ТарифнаяЗона КАК ТарифнаяЗона,
	|	МАКСИМУМ(Набор.Период) КАК Период,
	|	Набор.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ МаксимальнаяДатаРегистратора
	|ИЗ
	|	Набор КАК Набор
	|
	|СГРУППИРОВАТЬ ПО
	|	Набор.Район,
	|	Набор.ПриборУчета,
	|	Набор.Шкала,
	|	Набор.ТарифнаяЗона,
	|	Набор.ОбъектРасчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МаксимальнаяДатаРегистратора.Район КАК Район,
	|	МаксимальнаяДатаРегистратора.ПриборУчета КАК ПриборУчета,
	|	МаксимальнаяДатаРегистратора.Шкала КАК Шкала,
	|	МаксимальнаяДатаРегистратора.ТарифнаяЗона КАК ТарифнаяЗона,
	|	МаксимальнаяДатаРегистратора.Период КАК Период,
	|	МАКСИМУМ(Набор.Регистратор) КАК Регистратор,
	|	МаксимальнаяДатаРегистратора.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ МаксимумРегистратор
	|ИЗ
	|	МаксимальнаяДатаРегистратора КАК МаксимальнаяДатаРегистратора
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Набор КАК Набор
	|		ПО МаксимальнаяДатаРегистратора.Район = Набор.Район
	|			И МаксимальнаяДатаРегистратора.ПриборУчета = Набор.ПриборУчета
	|			И МаксимальнаяДатаРегистратора.Шкала = Набор.Шкала
	|			И МаксимальнаяДатаРегистратора.ТарифнаяЗона = Набор.ТарифнаяЗона
	|			И МаксимальнаяДатаРегистратора.Период = Набор.Период
	|			И МаксимальнаяДатаРегистратора.ОбъектРасчета = Набор.ОбъектРасчета
	|
	|СГРУППИРОВАТЬ ПО
	|	МаксимальнаяДатаРегистратора.Район,
	|	МаксимальнаяДатаРегистратора.ПриборУчета,
	|	МаксимальнаяДатаРегистратора.Шкала,
	|	МаксимальнаяДатаРегистратора.ТарифнаяЗона,
	|	МаксимальнаяДатаРегистратора.Период,
	|	МаксимальнаяДатаРегистратора.ОбъектРасчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МаксимумРегистратор.Район КАК Район,
	|	МаксимумРегистратор.ПриборУчета КАК ПриборУчета,
	|	МаксимумРегистратор.Шкала КАК Шкала,
	|	МаксимумРегистратор.ТарифнаяЗона КАК ТарифнаяЗона,
	|	МаксимумРегистратор.Период КАК Период,
	|	МаксимумРегистратор.Регистратор КАК Регистратор,
	|	МАКСИМУМ(Набор.Разделитель) КАК Разделитель,
	|	МаксимумРегистратор.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ МаксимумРазделить
	|ИЗ
	|	МаксимумРегистратор КАК МаксимумРегистратор
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Набор КАК Набор
	|		ПО МаксимумРегистратор.Район = Набор.Район
	|			И МаксимумРегистратор.ПриборУчета = Набор.ПриборУчета
	|			И МаксимумРегистратор.Шкала = Набор.Шкала
	|			И МаксимумРегистратор.ТарифнаяЗона = Набор.ТарифнаяЗона
	|			И МаксимумРегистратор.Период = Набор.Период
	|			И МаксимумРегистратор.Регистратор = Набор.Регистратор
	|			И МаксимумРегистратор.ОбъектРасчета = Набор.ОбъектРасчета
	|
	|СГРУППИРОВАТЬ ПО
	|	МаксимумРегистратор.Регистратор,
	|	МаксимумРегистратор.Район,
	|	МаксимумРегистратор.ПриборУчета,
	|	МаксимумРегистратор.Шкала,
	|	МаксимумРегистратор.ТарифнаяЗона,
	|	МаксимумРегистратор.Период,
	|	МаксимумРегистратор.ОбъектРасчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Набор.Район КАК Район,
	|	Набор.ПриборУчета КАК ПриборУчета,
	|	Набор.Шкала КАК Шкала,
	|	Набор.ТарифнаяЗона КАК ТарифнаяЗона,
	|	Набор.Период КАК Период,
	|	Набор.Регистратор КАК Регистратор,
	|	Набор.Разделитель КАК Разделитель,
	|	Набор.Показание КАК Показание,
	|	Набор.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ энргМаксимальныеПоказанияСрезПоследних
	|ИЗ
	|	Набор КАК Набор
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МаксимумРазделить КАК МаксимумРазделить
	|		ПО Набор.Район = МаксимумРазделить.Район
	|			И Набор.ПриборУчета = МаксимумРазделить.ПриборУчета
	|			И Набор.Шкала = МаксимумРазделить.Шкала
	|			И Набор.ТарифнаяЗона = МаксимумРазделить.ТарифнаяЗона
	|			И Набор.Период = МаксимумРазделить.Период
	|			И Набор.Регистратор = МаксимумРазделить.Регистратор
	|			И Набор.Разделитель = МаксимумРазделить.Разделитель
	|			И Набор.ОбъектРасчета = МаксимумРазделить.ОбъектРасчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ Набор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МаксимальнаяДатаРегистратора
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МаксимумРегистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МаксимумРазделить";
	
	Если не Параметры.свойство("Район") тогда
		Текст = СтрЗаменить(Текст,"энргМаксимальныеПоказанияРазделитель.Район = &Район","Истина");
	иначе
		Запрос.УстановитьПараметр("Район",Параметры.Район);
	КонецЕсли;
	 	
	Если не Параметры.свойство("ПриборУчета") тогда
		Текст = СтрЗаменить(Текст,"И бестМаксимальныеПоказанияНП.ПриборУчета = &ПриборУчета","");
	ИначеЕсли ТипЗнч(Параметры.ПриборУчета) = тип("Массив") тогда
		Текст = СтрЗаменить(Текст,"И бестМаксимальныеПоказанияНП.ПриборУчета = &ПриборУчета","И бестМаксимальныеПоказанияНП.ПриборУчета в (&ПриборыУчета)");
		Запрос.УстановитьПараметр("ПриборыУчета",Параметры.ПриборУчета)
	иначе	
		Запрос.УстановитьПараметр("ПриборУчета",Параметры.ПриборУчета);
	КонецЕсли;

	Если не Параметры.свойство("Дата") тогда
		Текст = СтрЗаменить(Текст,"И бестМаксимальныеПоказанияНП.Период <= &МоментВремениПериод","");
		Текст = СтрЗаменить(Текст,"И бестМаксимальныеПоказанияНП.Регистратор <= &МоментВремениРегистратор","");
	ИначеЕсли Параметры.Дата = Неопределено тогда
		Текст = СтрЗаменить(Текст,"И бестМаксимальныеПоказанияНП.Период <= &МоментВремениПериод","");
		Текст = СтрЗаменить(Текст,"И бестМаксимальныеПоказанияНП.Регистратор <= &МоментВремениРегистратор","");
	ИначеЕсли ТипЗнч(Параметры.Дата) = Тип("Дата") тогда 
		Текст = СтрЗаменить(Текст,"И бестМаксимальныеПоказанияНП.Регистратор <= &МоментВремениРегистратор","");
		Запрос.УстановитьПараметр("МоментВремениПериод",Параметры.Дата); 
		
	ИначеЕсли  ТипЗнч(Параметры.Дата) = Тип("Граница")
		и  Параметры.Дата.ВидГраницы = ВидГраницы.Исключая
		и ТипЗнч(Параметры.Дата.Значение) = Тип("Дата")  тогда	
		Текст = СтрЗаменить(Текст,"И бестМаксимальныеПоказанияНП.Период <= &МоментВремениПериод","И бестМаксимальныеПоказанияНП.Период < &МоментВремениПериод");
		Текст = СтрЗаменить(Текст,"И бестМаксимальныеПоказанияНП.Регистратор <= &МоментВремениРегистратор","");
		Запрос.УстановитьПараметр("МоментВремениПериод",Параметры.Дата.Значение);
	иначе 		
		Запрос.УстановитьПараметр("МоментВремениПериод",Параметры.Дата.дата);
		Запрос.УстановитьПараметр("МоментВремениРегистратор",Параметры.Дата.ссылка);
	КонецЕсли;
	
	Если не Параметры.свойство("ОбъектРасчета") тогда
		Текст = СтрЗаменить(Текст,"бестМаксимальныеПоказанияНП.ОбъектРасчета В(&ОбъектРасчета)","Истина");
	иначе
		Запрос.УстановитьПараметр("ОбъектРасчета",Параметры.ОбъектРасчета);
	КонецЕсли;

	
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);

	Текст 			= СтрЗаменить(Текст,"ПОМЕСТИТЬ энргМаксимальныеПоказанияСрезПоследних","ПОМЕСТИТЬ " + ИмяТаблицы);	
	Запрос.Текст 	= Текст;
	Запрос.Выполнить();
	
КонецПроцедуры 

// Заполняет ТЧ показания прибора учета.
//
// Параметры:
//  ТочкиУчета		 - СправочникСсылка.энргТочкиУчета.
//  ШкалыПриборов	 - СправочникСсылка.энргШкалыПриборовУчета.
//  ТаблицаПоказаний - ТЧ с показаниями.
//  МоментВремени	 - МоментВремени.
//  Организация		 - СправочникСсылка.Организации.
//  Район			 - СправочникСсылка.энргЗоныОтвественности.
//  КонтрольныйСъем	 - Булево.
//  ЭтоВывод		 - Булево.
//
Процедура ОбновитьТЧПоказанияПрибораУчета(ТочкиУчета,ШкалыПриборов,ТаблицаПоказаний,МоментВремени,Организация,Район,КонтрольныйСъем = ложь, ЭтоВывод = Ложь) Экспорт 
		
	// заполняем табличную часть приборы
	Если ТипЗнч(МоментВремени) = тип("Граница") тогда
		ПериодНачисления 					= Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(МоментВремени.Значение, Организация, Район);
	иначе
		ПериодНачисления 					= Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(МоментВремени, Организация, Район);
	КонецЕсли;
			              	
	Если ТипЗнч(ТаблицаПоказаний)  = Тип("ТаблицаЗначений") тогда
		тзТаблицаПоказаний 					= ТаблицаПоказаний;		
	иначе                  		
		тзТаблицаПоказаний					= ТаблицаПоказаний.Выгрузить();
	КонецЕсли;
	
	тзТаблицаПоказаний.Колонки.добавить("ТочкаУчета",				Новый ОписаниеТипов("СправочникСсылка.энргТочкиУчета"));
	тзТаблицаПоказаний.Колонки.добавить("Услуга",					Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
