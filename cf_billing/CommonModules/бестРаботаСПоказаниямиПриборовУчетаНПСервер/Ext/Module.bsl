Процедура ПроверитьОшибкуПрофиля(ПоказанияПриборовУчета) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПоказанияПриборовУчета.НомерСтроки КАК НомерСтроки,
		|	ПоказанияПриборовУчета.IDСтроки КАК IDСтроки,
		|	ПоказанияПриборовУчета.Разница КАК Разница,
		|	ПоказанияПриборовУчета.ОбъемПочасовойВедомости КАК ОбъемПочасовойВедомости,
		|	ПоказанияПриборовУчета.СостояниеПоказаний КАК СостояниеПоказаний
		|ПОМЕСТИТЬ ИсходнаяТаблица
		|ИЗ
		|	&ПоказанияПриборовУчета КАК ПоказанияПриборовУчета
		|ГДЕ
		|	ПоказанияПриборовУчета.ОбъемПочасовойВедомости > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсходнаяТаблица.IDСтроки КАК IDСтроки,
		|	СУММА(ИсходнаяТаблица.Разница) КАК Разница,
		|	МАКСИМУМ(ИсходнаяТаблица.ОбъемПочасовойВедомости) КАК ОбъемПочасовойВедомости
		|ПОМЕСТИТЬ ОтклоненныеПоказания
		|ИЗ
		|	ИсходнаяТаблица КАК ИсходнаяТаблица
		|
		|СГРУППИРОВАТЬ ПО
		|	ИсходнаяТаблица.IDСтроки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсходнаяТаблица.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	ОтклоненныеПоказания КАК ОтклоненныеПоказания
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИсходнаяТаблица КАК ИсходнаяТаблица
		|		ПО ОтклоненныеПоказания.IDСтроки = ИсходнаяТаблица.IDСтроки
		|			И (ИсходнаяТаблица.СостояниеПоказаний = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты))
		|			И (ОтклоненныеПоказания.Разница = ИсходнаяТаблица.ОбъемПочасовойВедомости = ЛОЖЬ)";
	
	Запрос.УстановитьПараметр("ПоказанияПриборовУчета", ПоказанияПриборовУчета.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Отклонены = Перечисления.энргСостояниеПоказаний.Отклонены;
	ПричинаОтклонения = Перечисления.энргПричиныОтклоненияПоказаний.ОшибкаПрофиля;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтрокаДанных = ПоказанияПриборовУчета[ВыборкаДетальныеЗаписи.НомерСтроки - 1]; 
		СтрокаДанных.СостояниеПоказаний  = Отклонены;
		СтрокаДанных.ПричинаОтклонения	 = ПричинаОтклонения;
	КонецЦикла;
	
КонецПроцедуры

