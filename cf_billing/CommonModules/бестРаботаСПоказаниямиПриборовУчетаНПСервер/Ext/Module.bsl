		СтрокаПоказаний 	= ТаблицаПоказаний.НайтиСтроки(Отбор)[0];
		ЗаполнитьЗначенияСвойств(СтрокаПоказаний, Выборка);
		
	КонецЦикла;
	
КонецПроцедуры

