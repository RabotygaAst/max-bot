// Процедура - Регламетные процедуры биллинг 
// Запуск из РЗ бестРегламентныеПроцедурыНП
//
Процедура РегламетныеПроцедурыБиллинг() Экспорт 
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.энргРегламентныеПроцедуры);
	
	УстановитьПривилегированныйРежим(Истина);
	
	Инструменты  		= энргФабрикаИнструментовНачисления.бестРаботаСПоследовательностямиНП();
	Если Инструменты = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект";
		Возврат;
	КонецЕсли; 
	Инструменты.РегламетныеПроцедурыБиллинг();
	
КонецПроцедуры

// Процедура - Восстановить последовательность взаиморасчетов ЭЭ  
// Запуск из РЗ бестВосстановлениеПоследовательностиВзаиморасчетовЭЭ
//
Процедура ВосстановитьПоследовательностьВзаиморасчетовЭЭ() Экспорт  
	
	Текст  							= 
	"ВЫБРАТЬ
	|	бестВзаиморасчетыПоследовательность.Организация КАК Организация,
	|	бестВзаиморасчетыПоследовательность.Район КАК Район,
	|	МИНИМУМ(бестВзаиморасчетыПоследовательность.ПериодНачисления) КАК ПериодНачисления
	|ИЗ
	|	РегистрСведений.бестВзаиморасчетыПоследовательность КАК бестВзаиморасчетыПоследовательность
	|ГДЕ
	|	НЕ бестВзаиморасчетыПоследовательность.СостояниеПроведения = ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности)
	|
	|СГРУППИРОВАТЬ ПО
	|	бестВзаиморасчетыПоследовательность.Организация,
	|	бестВзаиморасчетыПоследовательность.Район";
	
	Запрос  						= Новый Запрос(Текст);
	Результат  						= Запрос.Выполнить();
	Выборка 						= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ПараметрыЗадания  			= Новый Массив;
		ПараметрыЗадания.Добавить(Выборка.Организация);
		ПараметрыЗадания.Добавить(Выборка.ПериодНачисления);
		ПараметрыЗадания.Добавить(Выборка.Район);
		ФоновыеЗадания.Выполнить("бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьВзаиморасчетыНПЭЭ",ПараметрыЗадания);
	КонецЦикла;
		
КонецПроцедуры

