#Область ПрограммныйИнтерфейс

// Функция - Получает данные договора для рабочего места оператора
//
// Параметры:
//  Договор - СправочникСсылка.энргДоговорыКонтрагентов 
// 
// Возвращаемое значение:
//  Массив - массив пакетов запроса, содержащих данные договора
//
Функция ДанныеДоговораДляРабочегоМестаОператора(Договор) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДанныеДоговора();
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДатаСеанса());
	Возврат Запрос.ВыполнитьПакет();

КонецФункции

// Функция - Заполняет данные объектов расчета
//
// Параметры:
//  ПоляДоговора							 - Структура 
//  ДеревоДанныеПоТУ						 - ДеревоЗначений 
//  ДеревоДанныеПоПУ						 - ДеревоЗначений
//  ДеревоДанныеПоИзмерительномуКомплексу	 - ДеревоЗначений 
//  ОбъектыРасчета							 - ТаблицаЗначений 
//  ТочкиПоставки							 - ТаблицаЗначений 
// 
// Возвращаемое значение:
//   - Структура
//
Функция ЗаполнитьДанныеОбъектовРасчета(ПоляДоговора, Знач ДеревоДанныеПоТУ, Знач ДеревоДанныеПоПУ, Знач ДеревоДанныеПоИзмерительномуКомплексу, Знач ОбъектыРасчета, Знач ТочкиПоставки) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДанныеОбъектовРасчета();
	Запрос.УстановитьПараметр("Организация", ПоляДоговора.Организация);
	Запрос.УстановитьПараметр("Район", ПоляДоговора.Район);
	Запрос.УстановитьПараметр("Договор", ПоляДоговора.Договор);
	Запрос.УстановитьПараметр("Контрагент", ПоляДоговора.Контрагент);
	Пакет = Запрос.ВыполнитьПакет();
	ИндексПоследнегоЗапроса = Пакет.ВГраница();
	
	ВыборкаТочкиПоставки = Пакет.Получить(6).Выбрать();
	ВыборкаОбъектыРасчета = Пакет.Получить(ИндексПоследнегоЗапроса - 2).Выбрать();
	ВыборкаТУ = Пакет.Получить(ИндексПоследнегоЗапроса - 1).Выбрать();
	ВыборкаПотери = Пакет.Получить(ИндексПоследнегоЗапроса - 5).Выбрать();
	ВыборкаВидыЭнергии = Пакет.Получить(ИндексПоследнегоЗапроса - 4).Выбрать();
	ВыборкаПломбы = Пакет.Получить(ИндексПоследнегоЗапроса - 3).Выбрать();
	ВыборкаИзмерительныйКомплекс = Пакет.Получить(ИндексПоследнегоЗапроса).Выбрать();
	
	ТЗСтруктураСети = Справочники.бестСтруктураСети.АктуальныеДанныеСтруктурыСети().Выгрузить();
	
	СоответствиеПотери = ЗаполнитьСоответствиеПотерь(ВыборкаПотери, ПоляДоговора.ИспользоватьТарифныеЗоны);
	СоответствиеВидыЭнергии = ЗаполнитьСоответствиеВидовЭнергии(ВыборкаВидыЭнергии);
	СоответствиеПломбы = ЗаполнитьСоответствиеПломб(ВыборкаПломбы);
	
	ЗаполнитьТЗОбъектыРасчета(ПоляДоговора, ВыборкаОбъектыРасчета, ОбъектыРасчета);
	
	ЗаполнитьТЗТочкиПоставки(ВыборкаТочкиПоставки, ТочкиПоставки, ТЗСтруктураСети);
	
	ДанныеПоУмолчанию = Новый Структура("Заполнено, ОбъектРасчета, ТочкаУчета, ПриборУчета", Ложь);
	
	ТекущиеДанные = Новый Структура("ТУ, Услуга, Шкала, ТарифнаяЗона");
	
	Пока ВыборкаТУ.Следующий() Цикл
		
		Если Не ДанныеПоУмолчанию.Заполнено Тогда
			ЗаполнитьЗначенияСвойств(ДанныеПоУмолчанию, ВыборкаТУ);
			ДанныеПоУмолчанию.Заполнено = Истина;
		КонецЕсли;
		
		Если Не ТекущиеДанные.ТУ = ВыборкаТУ.ТочкаУчета Тогда
			СтрокиДерева = Новый Структура("СтрокаТУ, СтрокаУслуга, СтрокаШкала, СтрокаПоказания, СтрокаТипИзмерителя");
		
			ЗаполнитьОбщиеДанныеДереваТУ(ВыборкаТУ, ДеревоДанныеПоТУ, ПоляДоговора, СтрокиДерева);
			ЗаполнитьДеревоПоСоответствию(ВыборкаТУ, "ТочкаУчета", СоответствиеПотери, СтрокиДерева.СтрокаТУ, НСтр("ru = 'Потери'"));
			
			ЗаполнитьОбщиеДанныеДереваПУ(ВыборкаТУ, ДеревоДанныеПоПУ, ПоляДоговора, СоответствиеВидыЭнергии, СоответствиеПломбы);
			ЗаполнитьДеревоПоСоответствию(ВыборкаТУ, "ПриборУчета", СоответствиеПломбы, ДеревоДанныеПоПУ, НСтр("ru = 'Данные пломб'"));
		КонецЕсли;
		
		ЗаполнитьДанныеОбУслугеДереваТУ(ВыборкаТУ, СтрокиДерева.СтрокаТУ, СтрокиДерева.СтрокаУслуга, ПоляДоговора, ТекущиеДанные, СтрокиДерева);
		
		ЗаполнитьДанныеПоказанийПУ(ВыборкаТУ, ДеревоДанныеПоПУ, ПоляДоговора, ТекущиеДанные, СтрокиДерева);
		
		ТекущиеДанные.ТУ = ВыборкаТУ.ТочкаУчета;
		ТекущиеДанные.Услуга = ВыборкаТУ.Услуга;
		ТекущиеДанные.Шкала = ВыборкаТУ.Шкала;
		ТекущиеДанные.ТарифнаяЗона = ВыборкаТУ.ТарифнаяЗона;
			
	КонецЦикла;
	
	Пока ВыборкаИзмерительныйКомплекс.Следующий() Цикл
		ЗаполнитьОбщиеДанныеДереваИзмерительногоКомплекса(ВыборкаИзмерительныйКомплекс, ДеревоДанныеПоИзмерительномуКомплексу, СтрокиДерева);
		ЗаполнитьДеревоПоСоответствию(ВыборкаИзмерительныйКомплекс, "ПриборУчета", СоответствиеПломбы, ДеревоДанныеПоИзмерительномуКомплексу, НСтр("ru = 'Данные пломб'"));
	КонецЦикла;
	
	Возврат Новый Структура("ДанныеПоУмолчанию, ОбъектыРасчета, ТочкиПоставки, ДеревоДанныеПоТУ, ДеревоДанныеПоПУ, ДеревоДанныеПоИзмерительномуКомплексу", 
								ДанныеПоУмолчанию, ОбъектыРасчета, ТочкиПоставки, ДеревоДанныеПоТУ, ДеревоДанныеПоПУ, ДеревоДанныеПоИзмерительномуКомплексу);

КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

	Функция ДанныеОСуммахНачислений(Организация, Район, Договор) Экспорт

	СтруктураСумм = Новый Структура("СуммаБезНДС, СуммаНДС", 0, 0);
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	бестОбъемНачисленийНП.Организация КАК Организация,
	               |	бестОбъемНачисленийНП.Район КАК Район,
	               |	бестОбъемНачисленийНП.Договор КАК Договор,
	               |	бестОбъемНачисленийНП.ПериодНачисления КАК ПериодНачисления
	               |ПОМЕСТИТЬ ВТ_ПериодыНачислений
	               |ИЗ
	               |	РегистрНакопления.бестОбъемНачисленийНП КАК бестОбъемНачисленийНП
	               |ГДЕ
	               |	НЕ бестОбъемНачисленийНП.Распределение
	               |	И бестОбъемНачисленийНП.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Начисление)
	               |	И бестОбъемНачисленийНП.Организация = &Организация
	               |	И бестОбъемНачисленийНП.Район = &Район
	               |	И бестОбъемНачисленийНП.Договор = &Договор
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	бестОбъемНачисленийЭлектроэнергии.Организация,
	               |	бестОбъемНачисленийЭлектроэнергии.Район,
	               |	бестОбъемНачисленийЭлектроэнергии.Договор,
	               |	бестОбъемНачисленийЭлектроэнергии.ПериодНачисления
	               |ИЗ
	               |	РегистрНакопления.бестОбъемНачисленийЭлектроэнергии КАК бестОбъемНачисленийЭлектроэнергии
	               |ГДЕ
	               |	НЕ бестОбъемНачисленийЭлектроэнергии.Распределение
	               |	И бестОбъемНачисленийЭлектроэнергии.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Начисление)
	               |	И бестОбъемНачисленийЭлектроэнергии.Организация = &Организация
	               |	И бестОбъемНачисленийЭлектроэнергии.Район = &Район
	               |	И бестОбъемНачисленийЭлектроэнергии.Договор = &Договор
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ПериодыНачислений.Организация КАК Организация,
	               |	ВТ_ПериодыНачислений.Район КАК Район,
	               |	ВТ_ПериодыНачислений.Договор КАК Договор,
	               |	МАКСИМУМ(ВТ_ПериодыНачислений.ПериодНачисления) КАК ПериодНачисления
	               |ПОМЕСТИТЬ ВТ_ПоследнийПериод
	               |ИЗ
	               |	ВТ_ПериодыНачислений КАК ВТ_ПериодыНачислений
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ_ПериодыНачислений.Район,
	               |	ВТ_ПериодыНачислений.Договор,
	               |	ВТ_ПериодыНачислений.Организация
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВЫБОР
	               |		КОГДА бестОбъемНачисленийНП.НДСВнутри
	               |			ТОГДА бестОбъемНачисленийНП.Сумма - бестОбъемНачисленийНП.СуммаНДС
	               |		ИНАЧЕ бестОбъемНачисленийНП.Сумма
	               |	КОНЕЦ КАК СуммаБезНДС,
	               |	бестОбъемНачисленийНП.СуммаНДС КАК СуммаНДС
	               |ПОМЕСТИТЬ ВТ_Суммы
	               |ИЗ
	               |	ВТ_ПоследнийПериод КАК ВТ_ПоследнийПериод
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.бестОбъемНачисленийНП КАК бестОбъемНачисленийНП
	               |		ПО ВТ_ПоследнийПериод.Организация = бестОбъемНачисленийНП.Организация
	               |			И ВТ_ПоследнийПериод.Район = бестОбъемНачисленийНП.Район
	               |			И ВТ_ПоследнийПериод.Договор = бестОбъемНачисленийНП.Договор
	               |			И ВТ_ПоследнийПериод.ПериодНачисления = бестОбъемНачисленийНП.ПериодНачисления
	               |			И (НЕ бестОбъемНачисленийНП.Распределение)
	               |			И (бестОбъемНачисленийНП.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Начисление))
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ВЫБОР
	               |		КОГДА бестОбъемНачисленийЭлектроэнергии.НДСВнутри
	               |			ТОГДА бестОбъемНачисленийЭлектроэнергии.Сумма - бестОбъемНачисленийЭлектроэнергии.СуммаНДС
	               |		ИНАЧЕ бестОбъемНачисленийЭлектроэнергии.Сумма
	               |	КОНЕЦ,
	               |	бестОбъемНачисленийЭлектроэнергии.СуммаНДС
	               |ИЗ
	               |	ВТ_ПоследнийПериод КАК ВТ_ПоследнийПериод
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.бестОбъемНачисленийЭлектроэнергии КАК бестОбъемНачисленийЭлектроэнергии
	               |		ПО ВТ_ПоследнийПериод.Организация = бестОбъемНачисленийЭлектроэнергии.Организация
	               |			И ВТ_ПоследнийПериод.Район = бестОбъемНачисленийЭлектроэнергии.Район
	               |			И ВТ_ПоследнийПериод.Договор = бестОбъемНачисленийЭлектроэнергии.Договор
	               |			И ВТ_ПоследнийПериод.ПериодНачисления = бестОбъемНачисленийЭлектроэнергии.ПериодНачисления
	               |			И (НЕ бестОбъемНачисленийЭлектроэнергии.Распределение)
	               |			И (бестОбъемНачисленийЭлектроэнергии.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Начисление))
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	СУММА(ВТ_Суммы.СуммаБезНДС) КАК СуммаБезНДС,
	               |	СУММА(ВТ_Суммы.СуммаНДС) КАК СуммаНДС
	               |ИЗ
	               |	ВТ_Суммы КАК ВТ_Суммы";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("Договор", Договор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураСумм, Выборка);
	КонецЕсли;
	Возврат СтруктураСумм;

КонецФункции

#КонецОбласти

 		#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаДанныеДоговора()

	Возврат "ВЫБРАТЬ
	        |	бестСвязьДоговоров.СвязанныйДоговор КАК Договор
	        |ИЗ
	        |	РегистрСведений.бестСвязьДоговоров КАК бестСвязьДоговоров
	        |ГДЕ
	        |	бестСвязьДоговоров.ОснованиеДляДоговора = &Договор
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	энргДоговорыКонтрагентов.Ссылка КАК Договор,
	        |	энргДоговорыКонтрагентов.Организация КАК Организация,
	        |	энргДоговорыКонтрагентов.Район КАК Район,
	        |	энргДоговорыКонтрагентов.Контрагент КАК Контрагент,
	        |	энргДоговорыКонтрагентов.ВзаимодействиеСЭДО КАК ВзаимодействиеСЭДО,
	        |	энргКонтрагенты.ИНН КАК ИНН,
	        |	энргКонтрагенты.КПП КАК КПП,
	        |	энргКонтрагенты.ОГРН КАК ОГРН,
	        |	энргКонтрагенты.КодПоОКПО КАК ОКПО,
	        |	МАКСИМУМ(ВЫБОР
	        |			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента)
	        |				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
	        |		КОНЕЦ) КАК ЮридическийАдресКонтрагента,
	        |	МАКСИМУМ(ВЫБОР
	        |			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтрагента)
	        |				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
	        |		КОНЕЦ) КАК ЭлектронныйАдресКонтрагента,
	        |	ВЫБОР
	        |		КОГДА НЕ энргДоговорыКонтрагентов.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)
	        |				И энргДоговорыКонтрагентов.ДатаОкончанияДействия <= &ТекДата
	        |			ТОГДА энргДоговорыКонтрагентов.ДатаОкончанияДействия
	        |		ИНАЧЕ энргДоговорыКонтрагентов.ДатаНачалаДействия
	        |	КОНЕЦ КАК ДатаСостоянияДоговора,
	        |	энргДоговорыКонтрагентов.ТипТарифа = ЗНАЧЕНИЕ(Перечисление.бестТипыТарифаНезависимыйСбыт.ФиксированныйТариф) КАК ФиксированныйТариф,
	        |	энргДоговорыКонтрагентов.Представление КАК ПредставлениеДоговора,
	        |	ПРЕДСТАВЛЕНИЕ(энргДоговорыКонтрагентов.Статус) КАК СтатусДоговора
	        |ИЗ
	        |	Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	        |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
	        |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
	        |			ПО энргКонтрагенты.Ссылка = энргКонтрагентыКонтактнаяИнформация.Ссылка
	        |				И (энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента)
	        |					ИЛИ энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтрагента))
	        |		ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагенты.Ссылка
	        |ГДЕ
	        |	энргДоговорыКонтрагентов.Ссылка = &Договор
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	энргКонтрагенты.ИНН,
	        |	энргКонтрагенты.КодПоОКПО,
	        |	энргКонтрагенты.КПП,
