Функция ЗаполнитьСоответствиеПотерь(ВыборкаПотери, ИспользоватьТарифныеЗоны)

	ШаблонФиксОбъем = НСтр("ru = 'Фиксированный объем потерь (%1)'");
	ШаблонПроцент = НСтр("ru = 'Процент потерь (%1)'");
	СоответствиеПотери = Новый Соответствие;
	Пока ВыборкаПотери.Следующий() Цикл 
		
		ПолеГруппировкиПотерь = ВыборкаПотери.ВидПотерьПредставление;
		Если ИспользоватьТарифныеЗоны Тогда 
			ПолеГруппировкиПотерь = ВыборкаПотери.ТарифнаяЗонаПредставление;
		КонецЕсли;
		МассивПотери = СоответствиеПотери.Получить(ВыборкаПотери.ТочкаУчета);
		Если МассивПотери = Неопределено Тогда
			МассивПотери = Новый Массив;
		КонецЕсли; 
		
		КлючФиксОбъем = СтрШаблон(ШаблонФиксОбъем, ПолеГруппировкиПотерь); 
		КлючПроцент = СтрШаблон(ШаблонПроцент, ПолеГруппировкиПотерь);
		
		СтруктураПотери = Новый Структура("Ключ, Значение");
		СтруктураПотери.Ключ = КлючФиксОбъем;
		СтруктураПотери.Значение = ВыборкаПотери.ФиксированныйОбъемПотерь;
		МассивПотери.Добавить(СтруктураПотери);
		
		СтруктураПотери = Новый Структура("Ключ, Значение");
		СтруктураПотери.Ключ = КлючПроцент;
		СтруктураПотери.Значение = ВыборкаПотери.ПроцентПотерь;
		МассивПотери.Добавить(СтруктураПотери);
		
		СоответствиеПотери.Вставить(ВыборкаПотери.ТочкаУчета, МассивПотери);
	
	КонецЦикла;
	Возврат СоответствиеПотери;

КонецФункции

Функция ЗаполнитьСоответствиеВидовЭнергии(ВыборкаВидыЭнергии)

	СоответствиеВидыЭнергии = Новый Соответствие;
	ШаблонВидЭнергии = НСтр("ru = '%1 / %2'");
	Пока ВыборкаВидыЭнергии.Следующий() Цикл
		ВидЭнергии = СоответствиеВидыЭнергии.Получить(ВыборкаВидыЭнергии.ТипПрибораУчета);
		Если ВидЭнергии = Неопределено Тогда
			ВидЭнергии = ВыборкаВидыЭнергии.ВидЭнергии;
		Иначе
			ВидЭнергии = СтрШаблон(ШаблонВидЭнергии, ВидЭнергии, ВыборкаВидыЭнергии.ВидЭнергии);
		КонецЕсли;
	КонецЦикла;
	Возврат СоответствиеВидыЭнергии;

КонецФункции

Функция ЗаполнитьСоответствиеПломб(ВыборкаПломбы)

	СоответствиеПломбы = Новый Соответствие;
	ШаблонПломбы = НСтр("ru = '%1 / %2'");
	Пока ВыборкаПломбы.Следующий() Цикл 
		
		МассивПломб = СоответствиеПломбы.Получить(ВыборкаПломбы.ПриборУчета);
		Если МассивПломб = Неопределено Тогда
			МассивПломб = Новый Массив;
		КонецЕсли; 
		
		СтруктураПломбы = Новый Структура("Ключ, Значение");
		СтруктураПломбы.Ключ = ВыборкаПломбы.НомерПломбы; 
		ДатаОперацииСПломбой = Формат(ВыборкаПломбы.ДатаОперацииСПломбой, "ДЛФ=D");
		СтруктураПломбы.Значение = СтрШаблон(ШаблонПломбы, ВыборкаПломбы.МестоУстановки, ДатаОперацииСПломбой);
		МассивПломб.Добавить(СтруктураПломбы);
		
		СоответствиеПломбы.Вставить(ВыборкаПломбы.ПриборУчета, МассивПломб);
	
	КонецЦикла;
	Возврат СоответствиеПломбы;

КонецФункции

Процедура ЗаполнитьТЗОбъектыРасчета(ПоляДоговора, ВыборкаОбъектыРасчета, ОбъектыРасчета)
