Процедура ЗаполнитьТЗТочкиПоставки(ВыборкаТочкиПоставки, ТочкиПоставки, ТЗСтруктураСети)
	Пока ВыборкаТочкиПоставки.Следующий() Цикл
		СтрокаТП = ТочкиПоставки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТП, ВыборкаТочкиПоставки);
		СхемаПрисоединения = ВыборкаТочкиПоставки.СтруктураСетиПредставление;
		СтруктураСети = ВыборкаТочкиПоставки.СтруктураСети;
		Справочники.бестСтруктураСети.ЗаполнитьСхемуПрисоединения(СтруктураСети, ТЗСтруктураСети, СхемаПрисоединения);
		СтрокаТП.СхемаПрисоединения = СхемаПрисоединения;
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьОбщиеДанныеДереваТУ(ВыборкаТУ, ДеревоДанныеПоТУ, ПоляДоговора, СтрокиДерева)
	
	СтрокаТУ = ДеревоДанныеПоТУ.Строки.Добавить();
	СтрокиДерева.СтрокаТУ = СтрокаТУ;
	ЗаполнитьЗначенияСвойств(СтрокаТУ, ВыборкаТУ);
	СтрокаТУ.Ключ = НСтр("ru = 'Точка учета'");
	СтрокаТУ.Значение = ВыборкаТУ.ТочкаУчетаПредставление;
	
	СтрокаОбщиеДанныеТУ = СтрокаТУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаОбщиеДанныеТУ, ВыборкаТУ);
	СтрокаОбщиеДанныеТУ.Ключ = НСтр("ru = 'Общие данные'");
	
	СтрокаДерева = СтрокаОбщиеДанныеТУ.Строки.Добавить(); 
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
	СтрокаДерева.Ключ = НСтр("ru = 'Точка поставки'");
	СтрокаДерева.Значение = ВыборкаТУ.ТочкаПоставкиПредставление;
	
	Если ПоляДоговора.НезависимыйСбыт Тогда
		СтрокаДерева = СтрокаОбщиеДанныеТУ.Строки.Добавить(); 
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Тип тарифа'");
		СтрокаДерева.Значение = ВыборкаТУ.ТипТарифаПредставление;
		
		СтрокаДерева = СтрокаОбщиеДанныеТУ.Строки.Добавить(); 
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Значение скидки'");
		СтрокаДерева.Значение = ВыборкаТУ.ЗначениеСкидки;
		
		Если ВыборкаТУ.ТипТарифа = Перечисления.бестТипыТарифаНезависимыйСбыт.ФиксированныйТариф Тогда
			СтрокаДерева = СтрокаОбщиеДанныеТУ.Строки.Добавить(); 
			ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
			СтрокаДерева.Ключ = НСтр("ru = 'Тарифная сетка'");
			СтрокаДерева.Значение = ВыборкаТУ.ТарифнаяСетка;
		КонецЕсли;
	КонецЕсли;
	
	Если ПоляДоговора.НезависимыйСбыт И ВыборкаТУ.ТипТарифа = Перечисления.бестТипыТарифаНезависимыйСбыт.ЦеноваяКатегорияГП
		Или Не ПоляДоговора.НезависимыйСбыт И ВыборкаТУ.ИспользоватьРасчетЭлектроэнергии Тогда
		СтрокаДерева = СтрокаОбщиеДанныеТУ.Строки.Добавить(); 
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Ценовая категория'");
		СтрокаДерева.Значение = ВыборкаТУ.ЦеноваяКатегорияПредставление;
	КонецЕсли; 
	
	Если Не ВыборкаТУ.ИспользоватьРасчетЭлектроэнергии ИЛИ ВыборкаТУ.ЦеноваяКатегория = Перечисления.бестЦеновыеКатегории.Население Тогда
		СтрокаДерева = СтрокаОбщиеДанныеТУ.Строки.Добавить(); 
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Тарифная категория'");
		СтрокаДерева.Значение = ВыборкаТУ.ТарифнаяКатегория;
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьОбщиеДанныеДереваПУ(ВыборкаТУ, ДеревоДанныеПоПУ, ПоляДоговора, СоответствиеВидыЭнергии, СоответствиеПломбы)
	
	СтрокаОбщиеДанныеПУ = ДеревоДанныеПоПУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаОбщиеДанныеПУ, ВыборкаТУ);
	СтрокаОбщиеДанныеПУ.Ключ = НСтр("ru = 'Общие данные'");
	
	СтрокаДерева = СтрокаОбщиеДанныеПУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
	СтрокаДерева.Ключ = НСтр("ru = 'Номер прибора учета'"); 
	СтрокаДерева.Значение = ВыборкаТУ.ПриборУчета; 
	
	СтрокаДерева = СтрокаОбщиеДанныеПУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
	СтрокаДерева.Ключ = НСтр("ru = 'Тип СИ'"); 
	СтрокаДерева.Значение = ВыборкаТУ.ТипСИ; 
	
	СтрокаДерева = СтрокаОбщиеДанныеПУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
	СтрокаДерева.Ключ = НСтр("ru = 'Дата установки'"); 
	СтрокаДерева.Значение = Формат(ВыборкаТУ.ДатаУстановки, "ДЛФ=D"); 
	
	СтрокаДерева = СтрокаОбщиеДанныеПУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
	СтрокаДерева.Ключ = НСтр("ru = 'Балансовая принадлежность'"); 
	СтрокаДерева.Значение = ВыборкаТУ.БалансоваяПринадлежность; 
	
	СтрокаДерева = СтрокаОбщиеДанныеПУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
	СтрокаДерева.Ключ = НСтр("ru = 'Дата фактической поверки'"); 
	СтрокаДерева.Значение = Формат(ВыборкаТУ.ДатаПоверки, "ДЛФ=D"); 
	
	СтрокаДерева = СтрокаОбщиеДанныеПУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
	СтрокаДерева.Ключ = НСтр("ru = 'Дата следующей поверки'"); 
	СтрокаДерева.Значение = Формат(ВыборкаТУ.ДатаСледующейПоверки, "ДЛФ=D"); 
	
	СтрокаДерева = СтрокаОбщиеДанныеПУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
	СтрокаДерева.Ключ = НСтр("ru = 'Вид энергии'"); 
	СтрокаДерева.Значение = СоответствиеВидыЭнергии.Получить(ВыборкаТУ.ТипПрибораУчета); 
	
	ЗаголовокКоэффициентПУ = НСтр("ru = 'Коэффициент ПУ'");
	
	Если ПоляДоговора.ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ Тогда
		СтрокаДерева = СтрокаОбщиеДанныеПУ.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Система учета электроэнергии'"); 
		СтрокаДерева.Значение = ВыборкаТУ.СистемаУчетаЭлектроэнергии;
		
		ЗаголовокКоэффициентПУ = НСтр("ru = 'Коэффициент трансформации'");
	КонецЕсли;
	
	СтрокаДерева = СтрокаОбщиеДанныеПУ.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
	СтрокаДерева.Ключ = ЗаголовокКоэффициентПУ; 
	СтрокаДерева.Значение = ВыборкаТУ.КоэффициентПУ;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеОбУслугеДереваТУ(ВыборкаТУ, СтрокаТУ, СтрокаУслуга, ПоляДоговора, ТекущиеДанные, СтрокиДерева) 
	
	Если (Не ТекущиеДанные.ТУ = ВыборкаТУ.ТочкаУчета Или Не ТекущиеДанные.Услуга = ВыборкаТУ.Услуга Или Не ТекущиеДанные.ТарифнаяЗона = ВыборкаТУ.ТарифнаяЗона) И Не ВыборкаТУ.ИспользоватьРасчетРеактивнойЭнергии Тогда
		
		Если Не ТекущиеДанные.ТУ = ВыборкаТУ.ТочкаУчета Или Не ТекущиеДанные.Услуга = ВыборкаТУ.Услуга Тогда
			СтрокаУслуга = СтрокаТУ.Строки.Добавить();
			СтрокиДерева.СтрокаУслуга = СтрокаУслуга;
			ЗаполнитьЗначенияСвойств(СтрокаУслуга, ВыборкаТУ);
			СтрокаУслуга.Ключ = НСтр("ru = 'Услуга'");
			СтрокаУслуга.Значение = ВыборкаТУ.Услуга;
			
			СтрокаДерева = СтрокаУслуга.Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
			СтрокаДерева.Ключ = НСтр("ru = 'Поставщик'");
			СтрокаДерева.Значение = ВыборкаТУ.Поставщик;
		Иначе
			СтрокаУслуга = СтрокиДерева.СтрокаУслуга;
		КонецЕсли;
		СтрокаРодительТУ = СтрокаУслуга;
		
		Если ПоляДоговора.ИспользоватьТарифныеЗоны И ЗначениеЗаполнено(ВыборкаТУ.ТарифнаяЗона) Тогда
			СтрокаТарифнаяЗона = СтрокаРодительТУ.Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТарифнаяЗона, ВыборкаТУ);
			СтрокаТарифнаяЗона.Ключ = ВыборкаТУ.ТарифнаяЗона; 
			СтрокаРодительТУ = СтрокаТарифнаяЗона;
		КонецЕсли;
		
		СтрокаДерева = СтрокаРодительТУ.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Способ расчета'");
		СтрокаДерева.Значение = ВыборкаТУ.СпособНачисленияПредставление;
		
		СтрокаДерева = СтрокаРодительТУ.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Значение тарифа'");
		СтрокаДерева.Значение = ВыборкаТУ.Тариф;
		
		СтрокаРасчет = СтрокаРодительТУ.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаРасчет, ВыборкаТУ);
		ШаблонРасчет = НСтр("ru = 'Расчет за период %1'");
		ПериодНачисления = Формат(ВыборкаТУ.ПериодНачисления, "ДФ='ММММ yyyy'");
		СтрокаРасчет.Ключ = СтрШаблон(ШаблонРасчет, ПериодНачисления);
		
		СтрокаДерева = СтрокаРасчет.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Объем услуги'");
		СтрокаДерева.Значение = ВыборкаТУ.ОбъемУслуги;
		
		СтрокаДерева = СтрокаРасчет.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Сумма без НДС'");
		СтрокаДерева.Значение = ВыборкаТУ.Сумма;		
	КонецЕсли;
	
КонецПроцедуры 

Процедура ЗаполнитьДанныеПоказанийПУ(ВыборкаТУ, ДеревоДанныеПоПУ, ПоляДоговора, ТекущиеДанные, СтрокиДерева)
	
	ШаблонШкала = НСтр("ru = 'Шкала (%1)'");
	Если ВыборкаТУ.ЕстьПоследниеПоказания И Не (ТекущиеДанные.ТУ = ВыборкаТУ.ТочкаУчета И ТекущиеДанные.Шкала = ВыборкаТУ.Шкала И ТекущиеДанные.ТарифнаяЗона = ВыборкаТУ.ТарифнаяЗона) Тогда 
		Если СтрокиДерева.СтрокаПоказания = Неопределено Тогда
			СтрокаПоказания = ДеревоДанныеПоПУ.Строки.Добавить();
			СтрокиДерева.СтрокаПоказания = СтрокаПоказания;
			ЗаполнитьЗначенияСвойств(СтрокаПоказания, ВыборкаТУ);
			СтрокаПоказания.Ключ = НСтр("ru = 'Данные показаний'");
		Иначе
			СтрокаПоказания = СтрокиДерева.СтрокаПоказания;
		КонецЕсли;
		СтрокаРодительПУ = СтрокаПоказания;
		Если ПоляДоговора.ИспользоватьШкалыПриборовУчета Тогда
			Если Не ТекущиеДанные.ТУ = ВыборкаТУ.ТочкаУчета Или Не ТекущиеДанные.Шкала = ВыборкаТУ.Шкала Тогда
				СтрокаШкала = СтрокаРодительПУ.Строки.Добавить();
				СтрокиДерева.СтрокаШкала = СтрокаШкала;
				ЗаполнитьЗначенияСвойств(СтрокаШкала, ВыборкаТУ);
				СтрокаШкала.Ключ = СтрШаблон(ШаблонШкала, ВыборкаТУ.ШкалаПредставление);
			Иначе
				СтрокаШкала = СтрокиДерева.СтрокаШкала;
			КонецЕсли;
			СтрокаРодительПУ = СтрокаШкала;
		КонецЕсли;
		
		Если (Не ТекущиеДанные.ТУ = ВыборкаТУ.ТочкаУчета Или Не ТекущиеДанные.ТарифнаяЗона = ВыборкаТУ.ТарифнаяЗона) И ПоляДоговора.ИспользоватьТарифныеЗоны И ЗначениеЗаполнено(ВыборкаТУ.ТарифнаяЗона) Тогда
			СтрокаТарифнаяЗона = СтрокаРодительПУ.Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТарифнаяЗона, ВыборкаТУ);
			СтрокаТарифнаяЗона.Ключ = ВыборкаТУ.ТарифнаяЗона; 
			СтрокаРодительПУ = СтрокаТарифнаяЗона;
		КонецЕсли;
		
		СтрокаДерева = СтрокаРодительПУ.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Последние показания'"); 
		СтрокаДерева.Значение = ВыборкаТУ.Показание;
		
		СтрокаДерева = СтрокаРодительПУ.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаТУ);
		СтрокаДерева.Ключ = НСтр("ru = 'Дата последних показаний'"); 
		СтрокаДерева.Значение = Формат(ВыборкаТУ.ДатаПоказания, "ДЛФ=D");
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьДеревоПоСоответствию(Выборка, ИмяПоляПоиска, Соответствие, СтрокаДереваРодитель, Заголовок)

	Массив = Соответствие.Получить(Выборка[ИмяПоляПоиска]);
	Если Не Массив = Неопределено Тогда
		СтрокаЗаголовок = СтрокаДереваРодитель.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаЗаголовок, Выборка);
		СтрокаЗаголовок.Ключ = Заголовок;
		
		Для Каждого ЭлементМассива Из Массив Цикл
			СтрокаДерева = СтрокаЗаголовок.Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДерева, Выборка);
			ЗаполнитьЗначенияСвойств(СтрокаДерева, ЭлементМассива);
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьОбщиеДанныеДереваИзмерительногоКомплекса(ВыборкаИзмерительныйКомплекс, ДеревоДанныеПоИзмерительномуКомплексу, СтрокиДерева)

	СтрокаТипИзмерителя = СтрокиДерева.СтрокаТипИзмерителя;
	СтрокаТипИзмерителя = ДеревоДанныеПоИзмерительномуКомплексу.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаТипИзмерителя, ВыборкаИзмерительныйКомплекс);
	СтрокаТипИзмерителя.Ключ = ВыборкаИзмерительныйКомплекс.ТипИзмерителя;
	
	СтрокаДерева = СтрокаТипИзмерителя.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаИзмерительныйКомплекс);
	СтрокаДерева.Ключ = НСтр("ru = 'Номер прибора учета'"); 
	СтрокаДерева.Значение = ВыборкаИзмерительныйКомплекс.ПриборУчета;
	
	СтрокаДерева = СтрокаТипИзмерителя.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаИзмерительныйКомплекс);
	СтрокаДерева.Ключ = НСтр("ru = 'Тип СИ'"); 
	СтрокаДерева.Значение = ВыборкаИзмерительныйКомплекс.ТипСИ;
	
	СтрокаДерева = СтрокаТипИзмерителя.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаИзмерительныйКомплекс);
	СтрокаДерева.Ключ = НСтр("ru = 'Дата установки'"); 
	СтрокаДерева.Значение = Формат(ВыборкаИзмерительныйКомплекс.ДатаУстановки, "ДЛФ=D");
	
	СтрокаДерева = СтрокаТипИзмерителя.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаИзмерительныйКомплекс);
	СтрокаДерева.Ключ = НСтр("ru = 'Дата фактической поверки'"); 
	СтрокаДерева.Значение = Формат(ВыборкаИзмерительныйКомплекс.ДатаПоверки, "ДЛФ=D");
	
	СтрокаДерева = СтрокаТипИзмерителя.Строки.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаДерева, ВыборкаИзмерительныйКомплекс);
	СтрокаДерева.Ключ = НСтр("ru = 'Дата следующей поверки'"); 
	СтрокаДерева.Значение = Формат(ВыборкаИзмерительныйКомплекс.ДатаСледующейПоверки, "ДЛФ=D");

КонецПроцедуры

#КонецОбласти