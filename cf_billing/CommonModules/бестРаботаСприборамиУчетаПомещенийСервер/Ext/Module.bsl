// Функция возвращает тарифные зоны текущего вида дифференцированности
Функция ПолучитьТарифныеЗоныПоВидуДифференцированности(ВидДифферинцированности) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидДифференцированности", ВидДифферинцированности);
	Запрос.Текст = "ВЫБРАТЬ
	               |	энргВидыДиффиринцированностиПУСписокТарифныхЗон.ТарифнаяЗона КАК ТарифнаяЗона
	               |ИЗ
	               |	Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДиффиринцированностиПУСписокТарифныхЗон
	               |ГДЕ
	               |	энргВидыДиффиринцированностиПУСписокТарифныхЗон.Ссылка = &ВидДифференцированности
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	энргВидыДиффиринцированностиПУСписокТарифныхЗон.ТарифнаяЗона";
	Результат = Запрос.Выполнить();
	Выгрузка  = Результат.Выгрузить();
	Возврат Выгрузка;
КонецФункции

Процедура УдалитьСтрокиВТарифныеЗоныПоКлючу(Ключ, ТЧ) Экспорт
	Отбор = Новый Структура("IDСтроки", Ключ);
	ИщемСтроки = ТЧ.НайтиСтроки(Отбор);
	Если ИщемСтроки.Количество() > 0 Тогда
		Для НайденнаяСтрока = 0 по ИщемСтроки.Количество()-1 Цикл
			ТЧ.Удалить(ИщемСтроки[НайденнаяСтрока]);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция ВидыДифференцированностиПриборов(ДокументСсылка)
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	ТаблицаТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	ТаблицаШкалыПриборов.Шкала КАК Шкала,
	|	ВЫБОР
	|		КОГДА ТаблицаШкалыПриборов.ВидДифференцированности = ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)
	|		ИНАЧЕ ТаблицаШкалыПриборов.ВидДифференцированности
	|	КОНЕЦ КАК ВидДифференцированности
	|ИЗ
	|	Документ.энргОперацииСПомещениями.ТочкиУчета КАК ТаблицаТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацииСПомещениями.ШкалыПриборовУчета КАК ТаблицаШкалыПриборов
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаШкалыПриборов.Ссылка
	|			И ТаблицаТочкиУчета.IDСтроки = ТаблицаШкалыПриборов.IDСтрокиТочкиУчета
	|			И (ТаблицаТочкиУчета.Ссылка = &ДокументСсылка)
	|			И (НЕ ТаблицаТочкиУчета.ПриборУчета = Значение(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|			И (ТаблицаШкалыПриборов.Ссылка = &ДокументСсылка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацииСПомещениями КАК ТаблицаДокумента
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаДокумента.Ссылка
	|			И (ТаблицаДокумента.Ссылка = &ДокументСсылка)
	|			И (ТаблицаДокумента.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацииСПомещениями_ОткрытиеПомещения))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТаблицаТочкиУчета.ПриборУчета,
	|	ТаблицаШкалыПриборов.Шкала,
	|	ВЫБОР
	|		КОГДА ТаблицаШкалыПриборов.ВидДифференцированности = ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)
	|		ИНАЧЕ ТаблицаШкалыПриборов.ВидДифференцированности
	|	КОНЕЦ
	|ИЗ
	|	Документ.энргОперацияСУслугамиПомещений.ТочкиУчета КАК ТаблицаТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугамиПомещений.ШкалыПриборовУчета КАК ТаблицаШкалыПриборов
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаШкалыПриборов.Ссылка
	|			И ТаблицаТочкиУчета.IDСтроки = ТаблицаШкалыПриборов.IDСтрокиТочкиУчета
	|			И (ТаблицаТочкиУчета.Ссылка = &ДокументСсылка)
	|			И (НЕ ТаблицаТочкиУчета.ПриборУчета = Значение(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|			И (ТаблицаШкалыПриборов.Ссылка = &ДокументСсылка)
