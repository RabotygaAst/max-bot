	|	ВспомогательныеДанныеПУ.МаксимальноВозможныеПоказания,
	|	ВспомогательныеДанныеПУ.Коэффициент КАК КоэффициентПУ,
	|	ЕСТЬNULL(МаксимальныеПоказателиПотребления.МаксимальноеПотребления, 0) КАК МаксимальноВозможныйОбъемПотребления,
	|	ЕСТЬNULL(ЗначениеТарифовСоставных.Значение, 0) * ЕСТЬNULL(ФормулыТочекУчета.Коэффициент, 1) КАК ЗначениеТарифа,
	|	ЕСТЬNULL(ЗначениеТарифовСоставных.ПредставлениеЗначения, 0) КАК ПредставлениеЗначениеТарифа
	|ИЗ
	|	ВспомогательныеДанныеПУ КАК ВспомогательныеДанныеПУ
	|		ЛЕВОЕ СОЕДИНЕНИЕ МаксимальныеПоказателиПотребления КАК МаксимальныеПоказателиПотребления
	|		ПО ВспомогательныеДанныеПУ.Услуга = МаксимальныеПоказателиПотребления.Услуга
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЗначениеТарифовСоставных КАК ЗначениеТарифовСоставных
	|		ПО ВспомогательныеДанныеПУ.Услуга = ЗначениеТарифовСоставных.Услуга
	|		ЛЕВОЕ СОЕДИНЕНИЕ ФормулыТочекУчета КАК ФормулыТочекУчета
	|		ПО ВспомогательныеДанныеПУ.ТочкаУчета = ФормулыТочекУчета.ТочкаУчета";	
	Результат  = Запрос.Выполнить();
	Возврат Результат;

КонецФункции

Функция ДействующиеПриборыУчетаТочкиУчетаЮрЛиц(Период, Организация, Район, Договор, ОбъектРасчета, ТочкаУчета) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Период);
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("Договор",				Договор);
	Запрос.УстановитьПараметр("ОбъектРасчета",			ОбъектРасчета);
	Запрос.УстановитьПараметр("ТочкаУчета",				ТочкаУчета);
	
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	бестПриборыТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочекУчета
	|ИЗ
	|	РегистрСведений.бестПриборыТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета = &ТочкаУчета) КАК бестПриборыТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВведенныеПриборы
	|ИЗ
	|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета = &ТочкаУчета) КАК бестСостояниеПриборовУчетаНПСрезПоследних
	|ГДЕ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ ВТ_Услуги
	|ИЗ
	|	РегистрСведений.бестУслугиТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета = &ТочкаУчета) КАК бестУслугиТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.Шкала КАК Шкала,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ВидДифференцированности КАК ВидДифференцированности
	|ПОМЕСТИТЬ КанальностьТочекУчета
	|ИЗ
	|	РегистрСведений.бестВидыДифференцированностиПриборовУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета = &ТочкаУчета) КАК бестВидыДифференцированностиПриборовУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриборыТочекУчета.ПриборУчета КАК ПриборУчета,
	|	ВТ_Услуги.Услуга КАК Услуга,
	|	КанальностьТочекУчета.ВидДифференцированности КАК ВидДифференцированности,
	|	КанальностьТочекУчета.Шкала КАК Шкала
	|ИЗ
	|	ПриборыТочекУчета КАК ПриборыТочекУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВведенныеПриборы КАК ВведенныеПриборы
	|		ПО ПриборыТочекУчета.ПриборУчета = ВведенныеПриборы.ПриборУчета
	|			И ПриборыТочекУчета.ТочкаУчета = ВведенныеПриборы.ТочкаУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Услуги КАК ВТ_Услуги
	|		ПО ПриборыТочекУчета.ТочкаУчета = ВТ_Услуги.ТочкаУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КанальностьТочекУчета КАК КанальностьТочекУчета
	|		ПО ПриборыТочекУчета.ПриборУчета = КанальностьТочекУчета.ПриборУчета";	
	Результат  = Запрос.Выполнить();
	Возврат Результат;

КонецФункции

Функция ТаблицаЗначенийТарифов(Период,Организация,Район,Абонент,Поставщик = Неопределено) Экспорт  
	
	ТаблицаТарифа  	= Новый ТаблицаЗначений;
	ТаблицаТарифа.Колонки.Добавить("Поставщик",				Новый ОписаниеТипов("СправочникСсылка.энргКонтрагенты"));
	ТаблицаТарифа.Колонки.Добавить("Услуга",				Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	ТаблицаТарифа.Колонки.Добавить("ТарифнаяЗона",			Новый ОписаниеТипов("СправочникСсылка.энргТарифныеЗоны"));
	ТаблицаТарифа.Колонки.Добавить("Значение",				Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(10,5)));
	ТаблицаТарифа.Колонки.Добавить("ПредставлениеЗначения",	Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Период",			Период);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.УстановитьПараметр("Абонент",		Абонент);
	Если Период<> Неопределено тогда
		Запрос.УстановитьПараметр("Период",		Период);
	КонецЕсли;
	Если Поставщик <> Неопределено тогда
		Запрос.УстановитьПараметр("Поставщик",	Поставщик);
	КонецЕсли;
	
	Текст 			=
	"ВЫБРАТЬ
	|	энргГруппыПотребителейАбонентовСрезПоследних.ГруппаПотребителей КАК ГруппаПотребителей
	|ПОМЕСТИТЬ ГруппаПотребителейАбонента
	|ИЗ
	|	РегистрСведений.энргГруппыПотребителейАбонентов.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Абонент = &Абонент
	|				И Район = &Район) КАК энргГруппыПотребителейАбонентовСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗначенияТарифовСрезПоследних.Поставщик КАК Поставщик,
	|	энргЗначенияТарифовСрезПоследних.Услуга КАК Услуга,
	|	энргЗначенияТарифовСрезПоследних.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргЗначенияТарифовСрезПоследних.Значение КАК Значение
	|ПОМЕСТИТЬ ЗначениеТарифов
	|ИЗ
	|	РегистрСведений.энргЗначенияТарифов.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Поставщик = &Поставщик
	|				И ГруппаПотребителей В
	|					(ВЫБРАТЬ
	|						ГруппаПотребителейАбонента.ГруппаПотребителей
	|					ИЗ
	|						ГруппаПотребителейАбонента КАК ГруппаПотребителейАбонента)) КАК энргЗначенияТарифовСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Поставщик КАК Поставщик,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ВложенныйЗапрос.Значение КАК Значение
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЗначениеТарифов.Поставщик КАК Поставщик,
	|		ЗначениеТарифов.Услуга КАК Услуга,
	|		ЗначениеТарифов.Значение КАК Значение,
	|		ЗначениеТарифов.ТарифнаяЗона КАК ТарифнаяЗона
	|	ИЗ
	|		ЗначениеТарифов КАК ЗначениеТарифов
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЗначениеТарифов.Поставщик,
	|		энргВидыУслугСоставляющиеУслуг.Ссылка,
	|		ЗначениеТарифов.Значение,
	|		ЗначениеТарифов.ТарифнаяЗона
	|	ИЗ
	|		Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗначениеТарифов КАК ЗначениеТарифов
	|			ПО энргВидыУслугСоставляющиеУслуг.Услуга = ЗначениеТарифов.Услуга) КАК ВложенныйЗапрос
	|
	|УПОРЯДОЧИТЬ ПО
	|	Поставщик,
	|	Услуга,
	|	ТарифнаяЗона,
	|	Значение";
	
	Если Период = Неопределено тогда
		Текст 										= СтрЗаменить(Текст,"&Период","");
	КонецЕсли;
	
	Если Поставщик = Неопределено тогда
		Текст 										= СтрЗаменить(Текст,"И Поставщик = &Поставщик","");
	КонецЕсли;
	
	Запрос.Текст 									= Текст;
	Результат 										= Запрос.Выполнить();
	Выборка  										= Результат.Выбрать();
	ТекПоставщик  									= Неопределено;
	ТекУслуга  										= Неопределено;
	ТекТарифнаяЗона									= Неопределено;
	
	Пока Выборка.Следующий() цикл
		Если ТекПоставщик<> Выборка.Поставщик ИЛИ ТекУслуга<> Выборка.Услуга ИЛИ ТекТарифнаяЗона <> Выборка.ТарифнаяЗона тогда
			СтрокаТаблицы  							= ТаблицаТарифа.Добавить();
			СтрокаТаблицы.Поставщик 				= Выборка.Поставщик;			
			СтрокаТаблицы.Услуга 					= Выборка.Услуга;
			СтрокаТаблицы.ТарифнаяЗона 				= Выборка.ТарифнаяЗона;
			СтрокаТаблицы.Значение					= Выборка.Значение;
			СтрокаТаблицы.ПредставлениеЗначения 	= СтрокаТаблицы.ПредставлениеЗначения + ?(Не ЗначениеЗаполнено(СтрокаТаблицы.ПредставлениеЗначения),"","/") +  Строка(Выборка.Значение);
		иначе
			СтрокаТаблицы.Значение					= СтрокаТаблицы.Значение + Выборка.Значение;
			СтрокаТаблицы.ПредставлениеЗначения 	= СтрокаТаблицы.ПредставлениеЗначения + ?(Не ЗначениеЗаполнено(СтрокаТаблицы.ПредставлениеЗначения),"","/") +  Строка(Выборка.Значение); 
		КонецЕсли;
		ТекПоставщик 								= Выборка.Поставщик;
		ТекУслуга 									= Выборка.Услуга;
		ТекТарифнаяЗона								= Выборка.ТарифнаяЗона;
	КонецЦикла;  
	
	Возврат ТаблицаТарифа;
КонецФункции

Функция ТаблицаНормыПотребления(Период,Организация,Район,ПараметрыНорматива)
	
	ТаблицаНорм  					= Новый ТаблицаЗначений;
	ТаблицаНорм.Колонки.Добавить("Услуга",					Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	ТаблицаНорм.Колонки.Добавить("ЗначениеНормы",				Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(10,5)));
	ТаблицаНорм.Колонки.Добавить("ПредставлениеЗначенияНормы",Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	
	МВТ  							= Новый МенеджерВременныхТаблиц;
		 
	Справочники.энргКлючиНормативов.КлючиПоСвойствамОбъекта(Период, Организация,Район,Перечисления.энргТипыНачислений.ИндивидуальныеНачисления,МВТ,"КлючиНормативов", ПараметрыНорматива); 
	
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Если Период<> Неопределено тогда
		Запрос.УстановитьПараметр("Период",			Период);
	КонецЕсли;
	
	Текст 							=
	"ВЫБРАТЬ
	|	энргЗначенияНормативовПотребления.КлючНорматива КАК КлючНорматива,
	|	энргЗначенияНормативовПотребления.Услуга КАК Услуга,
	|	энргЗначенияНормативовПотребления.ЗначениеНорматива КАК ЗначениеНорматива
	|ПОМЕСТИТЬ НормыПотребления
	|ИЗ
	|	РегистрСведений.энргЗначенияНормативовПотребления.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТипНачисления = ЗНАЧЕНИЕ(Перечисление.энргТипыНачислений.ИндивидуальныеНачисления)) КАК энргЗначенияНормативовПотребления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.Значение КАК Значение
	|ИЗ
	|	(ВЫБРАТЬ
	|		НормыПотребления.Услуга КАК Услуга,
	|		НормыПотребления.ЗначениеНорматива КАК Значение
	|	ИЗ
	|		НормыПотребления КАК НормыПотребления
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ КлючиНормативов КАК КлючиНормативов
	|			ПО НормыПотребления.Услуга = КлючиНормативов.Услуга
	|				И НормыПотребления.КлючНорматива = КлючиНормативов.КлючНорматива
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВложенныйЗапрос.Услуга,
	|		ВложенныйЗапрос.ЗначениеНорматива
	|	ИЗ
	|		(ВЫБРАТЬ
	|			энргВидыУслугСоставляющиеУслуг.Ссылка КАК Услуга,
	|			НормыПотребления.КлючНорматива КАК КлючНорматива,
	|			НормыПотребления.ЗначениеНорматива КАК ЗначениеНорматива
	|		ИЗ
	|			Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ НормыПотребления КАК НормыПотребления
	|				ПО энргВидыУслугСоставляющиеУслуг.Услуга = НормыПотребления.Услуга) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ КлючиНормативов КАК КлючиНормативов
	|			ПО ВложенныйЗапрос.Услуга = КлючиНормативов.Услуга
	|				И ВложенныйЗапрос.КлючНорматива = КлючиНормативов.КлючНорматива) КАК ВложенныйЗапрос
	|
	|УПОРЯДОЧИТЬ ПО
	|	Услуга,
	|	Значение";
	
	Если Период = Неопределено тогда
		Текст 											= СтрЗаменить(Текст,"&Период","");
	КонецЕсли;
	
	Запрос.Текст 										= Текст;
	Результат 											= Запрос.Выполнить();
	Выборка  											= Результат.Выбрать();
	ТекУслуга  											= Неопределено;
	
	Пока Выборка.Следующий() цикл
		Если ТекУслуга<> Выборка.Услуга тогда
			СтрокаТаблицы  							= ТаблицаНорм.Добавить();
			СтрокаТаблицы.Услуга 						= Выборка.Услуга;
			СтрокаТаблицы.ЗначениеНормы				= Выборка.Значение;
			СтрокаТаблицы.ПредставлениеЗначенияНормы 	= СтрокаТаблицы.ПредставлениеЗначенияНормы + ?(Не ЗначениеЗаполнено(СтрокаТаблицы.ПредставлениеЗначенияНормы),"","/") +  Строка(Выборка.Значение);
		иначе
			СтрокаТаблицы.ЗначениеНормы				= СтрокаТаблицы.ЗначениеНормы + Выборка.Значение;
			СтрокаТаблицы.ПредставлениеЗначенияНормы 	= СтрокаТаблицы.ПредставлениеЗначенияНормы + ?(Не ЗначениеЗаполнено(СтрокаТаблицы.ПредставлениеЗначенияНормы),"","/") +  Строка(Выборка.Значение); 
		КонецЕсли;	
		ТекУслуга 										= Выборка.Услуга;
	КонецЦикла;  
	
	Возврат ТаблицаНорм;
КонецФункции

Функция ТаблицаЗначенийТарифовГруппыАбонентов(Период,Организация,Район,СписокАбонентов,Поставщик = Неопределено) Экспорт  
	
	ТаблицаТарифа  	= Новый ТаблицаЗначений;
	ТаблицаТарифа.Колонки.Добавить("Поставщик",				Новый ОписаниеТипов("СправочникСсылка.энргКонтрагенты"));
	ТаблицаТарифа.Колонки.Добавить("Услуга",				Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	ТаблицаТарифа.Колонки.Добавить("ТарифнаяЗона",			Новый ОписаниеТипов("СправочникСсылка.энргТарифныеЗоны"));
	ТаблицаТарифа.Колонки.Добавить("Значение",				Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(10,5)));
	ТаблицаТарифа.Колонки.Добавить("ПредставлениеЗначения",	Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Период",				Период);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("СписокАбонентов",	СписокАбонентов);
	Если Период<> Неопределено тогда
		Запрос.УстановитьПараметр("Период",		Период);
	КонецЕсли;
	Если Поставщик <> Неопределено тогда
		Запрос.УстановитьПараметр("Поставщик",	Поставщик);
	КонецЕсли;
	
	Текст 			=
	"ВЫБРАТЬ
	|	энргГруппыПотребителейАбонентовСрезПоследних.ГруппаПотребителей КАК ГруппаПотребителей,
	|	энргГруппыПотребителейАбонентовСрезПоследних.Абонент КАК Абонент
	|ПОМЕСТИТЬ ГруппаПотребителейАбонента
	|ИЗ
	|	РегистрСведений.энргГруппыПотребителейАбонентов.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Абонент В (&СписокАбонентов)
	|				И Район = &Район) КАК энргГруппыПотребителейАбонентовСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗначенияТарифовСрезПоследних.Поставщик КАК Поставщик,
	|	энргЗначенияТарифовСрезПоследних.Услуга КАК Услуга,
	|	энргЗначенияТарифовСрезПоследних.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргЗначенияТарифовСрезПоследних.Значение КАК Значение
	|ПОМЕСТИТЬ ЗначениеТарифов
	|ИЗ
	|	РегистрСведений.энргЗначенияТарифов.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Поставщик = &Поставщик
	|				И ГруппаПотребителей В
	|					(ВЫБРАТЬ
	|						ГруппаПотребителейАбонента.ГруппаПотребителей
	|					ИЗ
	|						ГруппаПотребителейАбонента КАК ГруппаПотребителейАбонента)) КАК энргЗначенияТарифовСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ГруппаПотребителейАбонента КАК ГруппаПотребителейАбонента
	|		ПО энргЗначенияТарифовСрезПоследних.ГруппаПотребителей = ГруппаПотребителейАбонента.ГруппаПотребителей
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Поставщик КАК Поставщик,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ВложенныйЗапрос.Значение КАК Значение
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЗначениеТарифов.Поставщик КАК Поставщик,
	|		ЗначениеТарифов.Услуга КАК Услуга,
	|		ЗначениеТарифов.Значение КАК Значение,
	|		ЗначениеТарифов.ТарифнаяЗона КАК ТарифнаяЗона
	|	ИЗ
	|		ЗначениеТарифов КАК ЗначениеТарифов
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЗначениеТарифов.Поставщик,
	|		энргВидыУслугСоставляющиеУслуг.Ссылка,
	|		ЗначениеТарифов.Значение,
	|		ЗначениеТарифов.ТарифнаяЗона
	|	ИЗ
	|		Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗначениеТарифов КАК ЗначениеТарифов
	|			ПО энргВидыУслугСоставляющиеУслуг.Услуга = ЗначениеТарифов.Услуга) КАК ВложенныйЗапрос
	|
	|УПОРЯДОЧИТЬ ПО
	|	Поставщик,
	|	Услуга,
	|	ТарифнаяЗона,
	|	Значение";
	
	Если Период = Неопределено тогда
		Текст 										= СтрЗаменить(Текст,"&Период","");
	КонецЕсли;
	
	Если Поставщик = Неопределено тогда
		Текст 										= СтрЗаменить(Текст,"И Поставщик = &Поставщик","");
	КонецЕсли;
	
	Запрос.Текст 									= Текст;
	Результат 										= Запрос.Выполнить();
	Выборка  										= Результат.Выбрать();
	ТекПоставщик  									= Неопределено;
	ТекУслуга  										= Неопределено;
	ТекТарифнаяЗона									= Неопределено;
	
	Пока Выборка.Следующий() цикл
		Если ТекПоставщик<> Выборка.Поставщик ИЛИ ТекУслуга<> Выборка.Услуга ИЛИ ТекТарифнаяЗона <> Выборка.ТарифнаяЗона тогда
			СтрокаТаблицы  							= ТаблицаТарифа.Добавить();
			СтрокаТаблицы.Поставщик 				= Выборка.Поставщик;			
			СтрокаТаблицы.Услуга 					= Выборка.Услуга;
			СтрокаТаблицы.ТарифнаяЗона 				= Выборка.ТарифнаяЗона;
			СтрокаТаблицы.Значение					= Выборка.Значение;
			СтрокаТаблицы.ПредставлениеЗначения 	= СтрокаТаблицы.ПредставлениеЗначения + ?(Не ЗначениеЗаполнено(СтрокаТаблицы.ПредставлениеЗначения),"","/") +  Строка(Выборка.Значение);
		иначе
			СтрокаТаблицы.Значение					= СтрокаТаблицы.Значение + Выборка.Значение;
			СтрокаТаблицы.ПредставлениеЗначения 	= СтрокаТаблицы.ПредставлениеЗначения + ?(Не ЗначениеЗаполнено(СтрокаТаблицы.ПредставлениеЗначения),"","/") +  Строка(Выборка.Значение); 
		КонецЕсли;
		ТекПоставщик 								= Выборка.Поставщик;
		ТекУслуга 									= Выборка.Услуга;
		ТекТарифнаяЗона								= Выборка.ТарифнаяЗона;
	КонецЦикла;  
	
	Возврат ТаблицаТарифа;
КонецФункции

Функция ДействующиеПриборыУчетаГруппыАбонентов(Период,Организация, Район,МВТ) Экспорт 
	
	
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Период",			Период);
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргГруппыПотребителейАбонентовСрезПоследних.Абонент КАК Абонент,
	|	энргГруппыПотребителейАбонентовСрезПоследних.ГруппаПотребителей КАК ГруппаПотребителей
	|ПОМЕСТИТЬ ГруппыПотребителей
	|ИЗ
	|	РегистрСведений.энргГруппыПотребителейАбонентов.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						втАбоненты.Абонент
	|					ИЗ
	|						втАбоненты КАК втАбоненты)) КАК энргГруппыПотребителейАбонентовСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргАктивностьТочекУчетаСрезПоследних.Абонент КАК Абонент,
	|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаАбонента
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						втАбоненты.Абонент
	|					ИЗ
	|						втАбоненты КАК втАбоненты)
	|				И Район = &Район) КАК энргАктивностьТочекУчетаСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргВладельцыТочекУчетаСрезПоследних.АбонентВладелец КАК АбонентВладелец
	|ПОМЕСТИТЬ ТочкиУчетаАбонента
	|ИЗ
	|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаАбонента.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаАбонента КАК АктивныеТочкиУчетаАбонента)) КАК энргВладельцыТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТочкиУчетаАбонента.ТочкаУчета КАК ТочкаУчета,
	|	АктивныеТочкиУчетаАбонента.Абонент КАК Абонент
	|ПОМЕСТИТЬ ДействующиеТочкиУчета
	|ИЗ
	|	ТочкиУчетаАбонента КАК ТочкиУчетаАбонента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АктивныеТочкиУчетаАбонента КАК АктивныеТочкиУчетаАбонента
	|		ПО ТочкиУчетаАбонента.ТочкаУчета = АктивныеТочкиУчетаАбонента.ТочкаУчета
	|			И ТочкиУчетаАбонента.АбонентВладелец = АктивныеТочкиУчетаАбонента.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПриборыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргПриборыТочекУчетаСрезПоследних.Абонент КАК Абонент
	|ПОМЕСТИТЬ ПриборыТочекУчета
	|ИЗ
	|	РегистрСведений.энргПриборыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						втАбоненты.Абонент
	|					ИЗ
	|						втАбоненты КАК втАбоненты)) КАК энргПриборыТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДействующиеТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	ПриборыТочекУчета.ПриборУчета КАК ПриборУчета,
	|	ДействующиеТочкиУчета.Абонент КАК Абонент
	|ПОМЕСТИТЬ ПриборыДействующихТочек
	|ИЗ
	|	ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПриборыТочекУчета КАК ПриборыТочекУчета
	|		ПО ДействующиеТочкиУчета.ТочкаУчета = ПриборыТочекУчета.ТочкаУчета
	|			И ДействующиеТочкиУчета.Абонент = ПриборыТочекУчета.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Абонент КАК Абонент,
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВведенныеПриборы
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовУчетаАбонента.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						втАбоненты.Абонент
	|					ИЗ
	|						втАбоненты КАК втАбоненты)) КАК энргСостояниеПриборовУчетаАбонентаСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргУслугиТочекУчетаСрезПоследних.Абонент КАК Абонент,
	|	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ УслугиТочекУчета
	|ИЗ
	|	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						втАбоненты.Абонент
	|					ИЗ
	|						втАбоненты КАК втАбоненты)
	|				И Район = &Район) КАК энргУслугиТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.Абонент КАК Абонент,
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.Шкала КАК Шкала,
	|	энргВидыДифференцированностиПриборовУчетаСрезПоследних.ВидДифференцированности КАК ВидДифференцированности
	|ПОМЕСТИТЬ ВидыДифференцированностиПриборовУчета
	|ИЗ
	|	РегистрСведений.энргВидыДифференцированностиПриборовУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						втАбоненты.Абонент
	|					ИЗ
	|						втАбоненты КАК втАбоненты)
	|				И Район = &Район) КАК энргВидыДифференцированностиПриборовУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.Абонент КАК Абонент,
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ПриборыДействующихТочек.Абонент КАК Абонент,
	|			ПриборыДействующихТочек.ТочкаУчета КАК ТочкаУчета,
	|			ПриборыДействующихТочек.ПриборУчета КАК ПриборУчета
	|		ИЗ
	|			ПриборыДействующихТочек КАК ПриборыДействующихТочек
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВведенныеПриборы КАК ВведенныеПриборы
	|				ПО ПриборыДействующихТочек.ПриборУчета = ВведенныеПриборы.ПриборУчета
	|					И ПриборыДействующихТочек.ТочкаУчета = ВведенныеПриборы.ТочкаУчета
	|					И ПриборыДействующихТочек.Абонент = ВведенныеПриборы.Абонент) КАК ВложенныйЗапрос
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|			ПО ВложенныйЗапрос.ПриборУчета = энргПриборыУчетаАбонента.Ссылка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВложенныйЗапрос.ВидКанальности = энргВидыКанальностиШкалы.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Вложенныйзапрос.Абонент КАК Абонент,
	|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
	|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
	|	Вложенныйзапрос.Шкала КАК Шкала,
	|	Вложенныйзапрос.Услуга КАК Услуга,
	|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеПоПриборам.Абонент КАК Абонент,
	|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|		ДанныеПоПриборам.Шкала КАК Шкала,
	|		ЕСТЬNULL(УслугиТочекУчета.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|		ЕСТЬNULL(ВидыДифференцированностиПриборовУчета.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности
	|	ИЗ
	|		ДанныеПоПриборам КАК ДанныеПоПриборам
	|			ЛЕВОЕ СОЕДИНЕНИЕ УслугиТочекУчета КАК УслугиТочекУчета
	|			ПО ДанныеПоПриборам.ТочкаУчета = УслугиТочекУчета.ТочкаУчета
	|				И ДанныеПоПриборам.Абонент = УслугиТочекУчета.Абонент
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВидыДифференцированностиПриборовУчета КАК ВидыДифференцированностиПриборовУчета
	|			ПО ДанныеПоПриборам.ПриборУчета = ВидыДифференцированностиПриборовУчета.ПриборУчета
	|				И ДанныеПоПриборам.Шкала = ВидыДифференцированностиПриборовУчета.Шкала
	|				И ДанныеПоПриборам.Абонент = ВидыДифференцированностиПриборовУчета.Абонент) КАК Вложенныйзапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
	|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Вложенныйзапрос.Абонент,
	|	Вложенныйзапрос.ТочкаУчета,
	|	Вложенныйзапрос.Шкала";
	Результат  = Запрос.Выполнить();
	Возврат Результат;
КонецФункции

Функция ДействующиеПриборыУчетаМКД(Период,Организация,Район,МКД) Экспорт 
			
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("МКД",					МКД);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаМКД
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И МКД = &МКД
	|				И Район = &Район) КАК энргАктивностьТочекУчетаМКДСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ТочкиУчетаМКД
	|ИЗ
	|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаМКД.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаМКД КАК АктивныеТочкиУчетаМКД)) КАК энргВладельцыТочекУчетаСрезПоследних
	|ГДЕ
	|	энргВладельцыТочекУчетаСрезПоследних.АбонентВладелец = &МКД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктивныеТочкиУчетаМКД.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ДействующиеТочкиУчета
	|ИЗ
	|	АктивныеТочкиУчетаМКД КАК АктивныеТочкиУчетаМКД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТочкиУчетаМКД КАК ТочкиУчетаМКД
	|		ПО АктивныеТочкиУчетаМКД.ТочкаУчета = ТочкиУчетаМКД.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПриборыТочекМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыТочекМКДСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочекМКД
	|ИЗ
	|	РегистрСведений.энргПриборыТочекМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД) КАК энргПриборыТочекМКДСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДействующиеТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	ПриборыТочекМКД.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыДействующихТочекМКД
	|ИЗ
	|	ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПриборыТочекМКД КАК ПриборыТочекМКД
	|		ПО ДействующиеТочкиУчета.ТочкаУчета = ПриборыТочекМКД.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеПриборовМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргСостояниеПриборовМКДСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВведенныеПриборыМКД
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД) КАК энргСостояниеПриборовМКДСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргУслугиТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргУслугиТочекУчетаМКДСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ УслугиТочекУчетаМКД
	|ИЗ
	|	РегистрСведений.энргУслугиТочекУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД) КАК энргУслугиТочекУчетаМКДСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВидыДифференцированностиПриборовУчетаМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргВидыДифференцированностиПриборовУчетаМКДСрезПоследних.Шкала КАК Шкала,
	|	энргВидыДифференцированностиПриборовУчетаМКДСрезПоследних.ВидДифференцированности КАК ВидДифференцированности
	|ПОМЕСТИТЬ ВидыДифференцированностиТочекУчетаМКД
	|ИЗ
	|	РегистрСведений.энргВидыДифференцированностиПриборовУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД) КАК энргВидыДифференцированностиПриборовУчетаМКДСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ПриборыДействующихТочекМКД.ТочкаУчета КАК ТочкаУчета,
	|			ПриборыДействующихТочекМКД.ПриборУчета КАК ПриборУчета
	|		ИЗ
	|			ПриборыДействующихТочекМКД КАК ПриборыДействующихТочекМКД
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВведенныеПриборыМКД КАК ВведенныеПриборы
	|				ПО ПриборыДействующихТочекМКД.ПриборУчета = ВведенныеПриборы.ПриборУчета
	|					И ПриборыДействующихТочекМКД.ТочкаУчета = ВведенныеПриборы.ТочкаУчета) КАК ВложенныйЗапрос
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|			ПО ВложенныйЗапрос.ПриборУчета = энргПриборыУчетаАбонента.Ссылка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВложенныйЗапрос.ВидКанальности = энргВидыКанальностиШкалы.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
	|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
	|	Вложенныйзапрос.Шкала КАК Шкала,
	|	Вложенныйзапрос.Услуга КАК Услуга,
	|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|		ДанныеПоПриборам.Шкала КАК Шкала,
	|		ЕСТЬNULL(УслугиТочекУчетаМКД.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|		ЕСТЬNULL(ВидыДифференцированностиТочекУчетаМКД.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности
	|	ИЗ
	|		ДанныеПоПриборам КАК ДанныеПоПриборам
	|			ЛЕВОЕ СОЕДИНЕНИЕ УслугиТочекУчетаМКД КАК УслугиТочекУчетаМКД
	|			ПО ДанныеПоПриборам.ТочкаУчета = УслугиТочекУчетаМКД.ТочкаУчета
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВидыДифференцированностиТочекУчетаМКД КАК ВидыДифференцированностиТочекУчетаМКД
	|			ПО ДанныеПоПриборам.ПриборУчета = ВидыДифференцированностиТочекУчетаМКД.ПриборУчета
	|				И ДанныеПоПриборам.Шкала = ВидыДифференцированностиТочекУчетаМКД.Шкала) КАК Вложенныйзапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
	|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Вложенныйзапрос.ТочкаУчета,
	|	Вложенныйзапрос.Шкала";	
	Результат  = Запрос.Выполнить();
	Возврат Результат;
КонецФункции

Функция ДействующиеУслугиМКД(Период,Организация,Район,МКД) Экспорт 
			
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("МКД",					МКД);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргУслугиТочекУчетаМКДСрезПоследних.Услуга КАК Услуга,
	|	энргУслугиТочекУчетаМКДСрезПоследних.Организация КАК Организация,
	|	энргУслугиТочекУчетаМКДСрезПоследних.Район КАК Район,
	|	энргУслугиТочекУчетаМКДСрезПоследних.МКД КАК МКД
	|ИЗ
	|	РегистрСведений.энргУслугиТочекУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД) КАК энргУслугиТочекУчетаМКДСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	энргУслугиТочекУчетаМКДСрезПоследних.Услуга,
	|	энргУслугиТочекУчетаМКДСрезПоследних.Организация,
