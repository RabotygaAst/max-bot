Процедура ВывестиВсеПриборыПомещения(Движения,Период,ДанныеШапки) Экспорт 
	
	Запрос  = Новый Запрос;
	Если ДанныеШапки.свойство("МКД") тогда
		Запрос.МенеджерВременныхТаблиц = ДанныеШапки.МВТ;
	КонецЕсли;	
	Запрос.УстановитьПараметр("Период",Период);
	Запрос.УстановитьПараметр("Район",ДанныеШапки.Район);
	Запрос.УстановитьПараметр("Организация",ДанныеШапки.Организация);	
	Запрос.УстановитьПараметр("Помещение",ДанныеШапки.Помещение);
	Запрос.Текст ="ВЫБРАТЬ
	|	бестПриборыТочекУчетаПомещенийСрезПоследних.ТочкаУчета,
	|	бестПриборыТочекУчетаПомещенийСрезПоследних.ПриборУчета
	|ПОМЕСТИТЬ АктивныеПриборы
	|ИЗ
	|	РегистрСведений.бестПриборыТочекУчетаПомещений.СрезПоследних(
	|			&Период,
	|			Район = &Район
    |				И Организация = &Организация
	|				И Помещение = &Помещение
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочки.ТочкаУчета
	|					ИЗ
	|						АктивныеТочки КАК АктивныеТочки)) КАК бестПриборыТочекУчетаПомещенийСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестСостояниеПриборовУчетаПомещенийСрезПоследних.ТочкаУчета,
	|	бестСостояниеПриборовУчетаПомещенийСрезПоследних.ПриборУчета
	|ИЗ
	|	РегистрСведений.бестСостояниеПриборовУчетаПомещений.СрезПоследних(
	|			&Период,
	|			Район = &Район
    |				И Организация = &Организация
	|				И Помещение = &Помещение
	|				И (ТочкаУчета, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						АктивныеПриборы.ТочкаУчета,
	|						АктивныеПриборы.ПриборУчета
	|					ИЗ
	|						АктивныеПриборы КАК АктивныеПриборы)) КАК бестСостояниеПриборовУчетаПомещенийСрезПоследних
	|ГДЕ
	|	бестСостояниеПриборовУчетаПомещенийСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)";
	Результат 		= Запрос.Выполнить();
	Выборка 		= Результат.Выбрать();
	Набор 			= Движения.бестСостояниеПриборовУчетаПомещений;
	
	Пока Выборка.Следующий() цикл
		Запись  					= Набор.добавить();
		Запись.Период  				= ДанныеШапки.Дата;
		Запись.Район  				= ДанныеШапки.Район;
		Запись.Организация			= ДанныеШапки.Организация;
		Запись.Помещение  			= ДанныеШапки.Помещение;
		Запись.ТочкаУчета  			= Выборка.ТочкаУчета;
		Запись.ПриборУчета 			= Выборка.ПриборУчета;
		Запись.Состояние 			= Перечисления.энргСостояниеПриборовУчета.Вывод;
		Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
		Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;
	КонецЦикла;
	
КонецПроцедуры

Процедура СброситьРасчетПоФормуле(Движения,ДанныеШапки) Экспорт  
	Набор 							= Движения.энргРасчетныеСпособыТочекУчета;
	
	Запрос  						= Новый Запрос;
	Запрос.УстановитьПараметр("Район", 		ДанныеШапки.Район);
	Запрос.УстановитьПараметр("Абонент", 	ДанныеШапки.Абонент);
	Запрос.УстановитьПараметр("Период", 	ДанныеШапки.Дата);
	Запрос.УстановитьПараметр("Организация",ДанныеШапки.Организация);
	Запрос.Текст 					="
	|ВЫБРАТЬ
	|	энргРасчетныеСпособыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ИЗ
	|	РегистрСведений.энргРасчетныеСпособыТочекУчета.СрезПоследних(
	|			&Период,
	|			Район = &Район
    |				И Организация = &Организация
	|				И Абонент = &Абонент) КАК энргРасчетныеСпособыТочекУчетаСрезПоследних
	|ГДЕ
	|	энргРасчетныеСпособыТочекУчетаСрезПоследних.РасчетныйСпособ";
	Результат  							= Запрос.Выполнить();
	Выборка  							= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		СтрокаНабора  					= Набор.добавить();
		СтрокаНабора.Период 			= ДанныеШапки.Дата;
		СтрокаНабора.Район 				= ДанныеШапки.Район;
		СтрокаНабора.Организация		= ДанныеШапки.Организация;
		СтрокаНабора.Абонент 			= ДанныеШапки.Абонент;
		СтрокаНабора.ТочкаУчета 		= Выборка.ТочкаУчета;
		СтрокаНабора.РасчетныйСпособ 	= Ложь;
		СтрокаНабора.ПериодНачисления 	= ДанныеШапки.ПериодНачисления;
		СтрокаНабора.ПериодРегистрации 	= ДанныеШапки.ПериодРегистрации;;
	КонецЦикла;  	
КонецПроцедуры

