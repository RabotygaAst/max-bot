#Область СлужебныеПроцедурыИФункции



Процедура ПриЧтенииНаСервере(Форма, ИмяКоллекции) Экспорт 
		
	Коллекция 				= Форма.Объект[ИмяКоллекции];
	Запрос 					= Новый Запрос;
	Запрос.УстановитьПараметр("ДанныеТабЧасти",Коллекция.Выгрузить()); 
	Запрос.Текст 			= 
	"ВЫБРАТЬ
	|	ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|	ДанныеТабЧасти.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ДанныеТабЧасти
	|ИЗ
	|	&ДанныеТабЧасти КАК ДанныеТабЧасти
	|ГДЕ
	|	НЕ ДанныеТабЧасти.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|	энргПриборыУчетаАбонента.Код КАК ЗаводскойНомер,
	|	энргПриборыУчетаАбонента.ТипПрибораУчета КАК ТипПрибораУчета,
	|	энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности
	|ИЗ
	|	ДанныеТабЧасти КАК ДанныеТабЧасти
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ДанныеТабЧасти.ПриборУчета = энргПриборыУчетаАбонента.Ссылка";
	
	Результат  									= Запрос.Выполнить();
	Выборка 									= Результат.Выбрать();
	                       	
	Пока Выборка.Следующий() Цикл
		СтрокаДляЗаполнения 					= Коллекция[Выборка.НомерСтроки - 1];
		ЗаполнитьЗначенияСвойств(СтрокаДляЗаполнения, Выборка,,"НомерСтроки");
	КонецЦикла;
	
	Для Каждого СтрокаТочки Из Коллекция Цикл
		
		
		Если Не ЗначениеЗаполнено(СтрокаТочки.ОписаниеПрибора) Тогда
			Продолжить;
		КонецЕсли;
		
		ПриборЗаполнен 							= ЗначениеЗаполнено(СтрокаТочки.ПриборУчета);
			
		Чтение 									= Новый ЧтениеJSON();
		Чтение.УстановитьСтроку(СтрокаТочки.ОписаниеПрибора);
		Описание								= ПрочитатьJSON(Чтение);
		Для Каждого КлючЗначение Из Описание Цикл
			Если КлючЗначение.Ключ = "ТипПрибораУчета" Тогда
				Если НЕ ЗначениеЗаполнено(СтрокаТочки.ТипПрибораУчета) тогда
					СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргТипыПриборовУчета.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
				КонецЕсли;
			ИначеЕсли КлючЗначение.Ключ = "ВидКанальности" Тогда
				Если НЕ ЗначениеЗаполнено(СтрокаТочки.ВидКанальности) Тогда 
					СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргВидыКанальности.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
				КонецЕсли;
			ИначеЕсли КлючЗначение.Ключ = "ВидДифференцированности" Тогда
				Если НЕ ЗначениеЗаполнено(СтрокаТочки.ВидДифференцированности) Тогда
					СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргВидыДифференцированности.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
				КонецЕсли;
			ИначеЕсли КлючЗначение.Ключ = "IDСтрокиШкалы" Тогда
				Если Не ЗначениеЗаполнено(СтрокаТочки.IDСтрокиШкалы) Тогда
					СтрокаТочки[КлючЗначение.Ключ] 	= Новый УникальныйИдентификатор(КлючЗначение.Значение);
				КонецЕсли;
			Иначе
				СтрокаТочки[КлючЗначение.Ключ] 	= КлючЗначение.Значение;
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла;	
	
КонецПроцедуры

#Область РаботаСНаборамиЗаписей

Процедура ЗаписатьКоэффициентПУ(ДанныеШапки,Движения,ИмяКоллекци,СоотвествиеКолонок) Экспорт
	Набор  								= Движения.бестКоэффциентыПриборовУчетаПомещений;
	для Каждого стр из ДанныеШапки[ИмяКоллекци] цикл
		Если ЗначениеЗаполнено(Стр[СоотвествиеКолонок.ПриборУчета]) Тогда
			Запись  					= Набор.добавить();
			Запись.Период  				= ДанныеШапки.Дата;
			Запись.Организация	 		= ДанныеШапки.Организация;
			Запись.Район	 			= ДанныеШапки.Район;
			Запись.Помещение	 		= ДанныеШапки.Помещение;
			Запись.ПриборУчета 			= Стр[СоотвествиеКолонок.ПриборУчета];
			Запись.Коэффициент 			= Стр[СоотвествиеКолонок.КоэффициентПУ];
			Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
			Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;  
		КонецЕсли;
	КонецЦикла; 	
КонецПроцедуры

Процедура ЗаписатьКоэффициентПУРезультатЗапроса(Результат,Движения) Экспорт
	Набор  							= Движения.энргКоэффциентыПриборовУчета;
	Выборка  						= Результат.выбрать();
	Пока Выборка.следующий() цикл
		Запись  					= Набор.добавить();
		Запись.Период  				= Выборка.Период;
		Запись.Район	 			= Выборка.Район;
		Запись.Организация	 		= Выборка.Организация;
		Запись.Абонент	 			= Выборка.Абонент;
		Запись.ПриборУчета 			= Выборка.ПриборУчета;
		Запись.Коэффициент 			= Выборка.КоэффициентПУ;
		Запись.ПериодРегистрации	= Выборка.ПериодРегистрации;
		Запись.ПериодНачисления		= Выборка.ПериодНачисления; 		
	КонецЦикла; 	
КонецПроцедуры

Процедура ЗаписатьПоказания(ДанныеШапки,Движения,ИмяСвойства,СоотвествиеКолонок) Экспорт  
	
	Набор  								= Движения["энргПоказанияПриборовУчета"];
	
	АбонентУказанВШапке  				= ДанныеШапки.свойство("Абонент");
	ДатаУказанаВШапке	  				= ДанныеШапки.свойство("Дата");
	
	УказаноСостояние  					= СоотвествиеКолонок.свойство("СостояниеПоказаний");
	
	Если ТипЗнч(ДанныеШапки[ИмяСвойства]) = тип("РезультатЗапроса") тогда
		Выборка  = ДанныеШапки[ИмяСвойства].выбрать();
		
		ТекАбонент  						= Неопределено;
		ТекПриборУчета 						= Неопределено;
		ТекРазделитель  					= 0; 
		
		Пока Выборка.следующий() цикл
			Если ЗначениеЗаполнено(Выборка[СоотвествиеКолонок.ПриборУчета]) Тогда
				
				Если ТекАбонент = Выборка.Абонент и ТекПриборУчета = Выборка.ПриборУчета тогда
					ТекРазделитель 			= ТекРазделитель + 1;
				иначе
					ТекРазделитель 			= 0;
				КонецЕсли; 
				
				Запись  					= Набор.добавить();
				Запись.Период  				= Выборка.период;
				Запись.Район  				= Выборка.Район;
				Запись.Организация	 		= Выборка.Организация;
				Запись.Абонент 				= Выборка.Абонент;
				Запись.ПриборУчета 			= Выборка.ПриборУчета;
				Запись.ТарифнаяЗона 		= Выборка.ТарифнаяЗона;
				Запись.Показание 			= Выборка.ТекущиеПоказания;
				Запись.СостояниеПоказаний 	= ?(УказаноСостояние,?(Не ЗначениеЗаполнено(Выборка[СоотвествиеКолонок.СостояниеПоказаний]),Перечисления.энргСостояниеПоказаний.Приняты,Выборка[СоотвествиеКолонок.СостояниеПоказаний]),Перечисления.энргСостояниеПоказаний.Приняты) ;
				Запись.ПериодНачисления 	= ДанныеШапки.ПериодНачисления;
				Запись.ПериодРегистрации 	= Выборка.ПериодРегистрации;
				Запись.КС 					= ?(ДанныеШапки.свойство("КС"),ДанныеШапки.КС,Ложь);
				Запись.Разделитель  		= ТекРазделитель;
				Запись.НомерСтрокиТЧ  		= Выборка.НомерСтроки;
				
				ТекАбонент  				= Выборка.Абонент;
				ТекПриборУчета 				= Выборка.ПриборУчета;				
			КонецЕсли;
		КонецЦикла; 
	иначе
		для Каждого стр из ДанныеШапки[ИмяСвойства] цикл
			Если ЗначениеЗаполнено(Стр[СоотвествиеКолонок.ПриборУчета]) Тогда
				Запись  					= Набор.добавить();
				Запись.Период  				= ?(ДатаУказанаВШапке,ДанныеШапки.Дата,Стр[СоотвествиеКолонок.Дата]);
				Запись.Район  				= ДанныеШапки.Район;
				Запись.Организация	 		= ДанныеШапки.Организация;
				Запись.Абонент 				= ?(АбонентУказанВШапке,ДанныеШапки.Абонент,Стр[СоотвествиеКолонок.Абонент]);
				Запись.ПриборУчета 			= Стр[СоотвествиеКолонок.ПриборУчета];
				Запись.ТарифнаяЗона 		= Стр[СоотвествиеКолонок.ТарифнаяЗона];
				Запись.Показание 			= Стр[СоотвествиеКолонок.ТекущиеПоказания];
				Запись.СостояниеПоказаний 	= ?(УказаноСостояние,?(Не ЗначениеЗаполнено(Стр[СоотвествиеКолонок.СостояниеПоказаний]),Перечисления.энргСостояниеПоказаний.Приняты,Стр[СоотвествиеКолонок.СостояниеПоказаний]),Перечисления.энргСостояниеПоказаний.Приняты) ;
				Запись.ПериодНачисления 	= ДанныеШапки.ПериодНачисления;
				Запись.ПериодРегистрации 	= ДанныеШапки.ПериодРегистрации;
				Запись.КС 					= ?(ДанныеШапки.свойство("КС"),ДанныеШапки.КС,Ложь);
				Запись.НомерСтрокиТЧ  		= ?(ДанныеШапки.свойство("НомерСтрокиТЧ"),ДанныеШапки.НомерСтрокиТЧ,0);
				Запись.Переворот            = ?(СоотвествиеКолонок.свойство("Переворот"),Стр[СоотвествиеКолонок.Переворот],Ложь);
			КонецЕсли;
		КонецЦикла; 
	КонецЕсли; 		
КонецПроцедуры

Процедура ЗаписатьПоказанияРезультатЗапроса(ДанныеШапки, Движения) Экспорт 
	
	Набор  								= Движения["бестПоказанияПриборовУчетаПомещений"];
	РезультатЗапроса 					= ДанныеПоказанийПриборовУчета(ДанныеШапки.Документ);
	Выборка 							= РезультатЗапроса.выбрать();
	
	ТекПомещение  						= Неопределено;
	ТекПриборУчета 						= Неопределено;
	ТекТарифнаяЗона 					= Неопределено;
	ТекРазделитель 						= 0;
	
	Пока Выборка.следующий() цикл
		Если ТекПомещение = Выборка.Помещение и ТекПриборУчета = Выборка.ПриборУчета  и ТекТарифнаяЗона = Выборка.ТарифнаяЗона тогда
			ТекРазделитель 				= ТекРазделитель + 1;
		иначе
			ТекРазделитель 				= 0;
		КонецЕсли;	
		Запись  						= Набор.добавить();		
		ЗаполнитьЗначенияСвойств(Запись,Выборка);
		Запись.Период  					= ДанныеШапки.Дата;
		Запись.ПериодРегистрации		= ДанныеШапки.ПериодРегистрации;
		Запись.ПериодНачисления			= ДанныеШапки.ПериодНачисления;
		Запись.Разделитель 				= ТекРазделитель;
		ТекПомещение  					= Выборка.Помещение;
		ТекПриборУчета 					= Выборка.ПриборУчета;
		ТекТарифнаяЗона 				= Выборка.ТарифнаяЗона;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьДанныеВыводаПомещений(ДанныеШапки,Движения,ИмяСвойства,СоотвествиеКолонок) Экспорт 
	
	Набор  									= Движения["энргВыводПриборовУчетаПомещений"];
	
	ДатаУказанаВШапке	  					= ДанныеШапки.свойство("Дата");	
	
	для Каждого стр из ДанныеШапки[ИмяСвойства] цикл
		Если ЗначениеЗаполнено(Стр[СоотвествиеКолонок.ПриборУчета]) Тогда
			Запись  					= Набор.добавить();
			Запись.Период  				= ?(ДатаУказанаВШапке,ДанныеШапки.Дата,Стр[СоотвествиеКолонок.Дата]);
			Запись.Район  				= ДанныеШапки.Район;
			Запись.Организация	 		= ДанныеШапки.Организация;
			Запись.МКД  				= ДанныеШапки.МКД;
			Запись.Помещение  			= ДанныеШапки.Помещение;
			Запись.ТочкаУчета 			= Стр[СоотвествиеКолонок.ТочкаУчета];
			Запись.ПриборУчета 			= Стр[СоотвествиеКолонок.ПриборУчета];
			Запись.ПериодНачисления 	= ДанныеШапки.ПериодНачисления;
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры  

Процедура ЗаписатьДатуПоверки(ДанныеШапки,Движения,ИмяКоллекции,СоотвествиеКолонок) Экспорт  
	Набор  = Движения["бестДатыПоверкиПрибораУчетаПомещений"];
	для Каждого стр из ДанныеШапки[ИмяКоллекции] цикл
		Если ЗначениеЗаполнено(стр[СоотвествиеКолонок.ПриборУчета]) Тогда
			Запись  			= Набор.добавить();
			Запись.Период  				= ДанныеШапки.Дата;
			Запись.Район  				= ДанныеШапки.Район;
			Запись.Организация	 		= ДанныеШапки.Организация;
			Запись.Помещение  			= ДанныеШапки.Помещение;
			Запись.ПриборУчета 			= стр[СоотвествиеКолонок.ПриборУчета];
			Запись.ДатаПоверки 			= стр[СоотвествиеКолонок.ДатаПоверкиСчетчика];
			Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
			Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления; 
		КонецЕсли;
	КонецЦикла; 		
КонецПроцедуры

Процедура ЗаписатьДатуПоверкиРезультатЗапроса(Результат,Движения) Экспорт  
	Набор  							= Движения["энргДатыПоверкиПрибораУчета"];
	Выборка 						= Результат.выбрать();
