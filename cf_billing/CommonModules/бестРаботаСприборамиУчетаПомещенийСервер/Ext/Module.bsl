Процедура СоздатьПриборыУчета(ПараметрыПриборовУчета,ТочкиУчета) Экспорт  
	ВызватьИсключение "Табличная часть была Изменена обращаться к Симонову"; 
	
	Запрос  		= Новый Запрос;
	Запрос.Текст 	="ВЫБРАТЬ
	|	энргОперацияСПриборомУчетаМКДПоказанияПУВВод.ПриборУчета,
	|	энргОперацияСПриборомУчетаМКДПоказанияПУВВод.ТипПрибораУчета,
	|	энргОперацияСПриборомУчетаМКДПоказанияПУВВод.ЗаводскойНомер
	|ПОМЕСТИТЬ ТекущиеДанные
	|ИЗ
	|	Документ.энргОперацияСПриборомУчетаМКД.ПоказанияПУВВод КАК энргОперацияСПриборомУчетаМКДПоказанияПУВВод
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";
	
	для Каждого стр из ПараметрыПриборовУчета.МассивПриборов цикл
		стрТочки  				= ТочкиУчета[стр-1];
		ДанныеПрибора 			= Новый Структура();
		// ДанныеПрибора.Вставить("Код",				стрТочки.ЗаводскойНомер);
		ДанныеПрибора.Вставить("Код",				стрТочки.ЗаводскойНомер);
		ДанныеПрибора.Вставить("ДатаВыпуска",		стрТочки.ДатаВыпуска);
		ДанныеПрибора.Вставить("ТипПрибораУчета",	стрТочки.ТипПрибораУчета);
		стрТочки.ПриборУчета  	= СоздатьТочкуУчета(ДанныеПрибора);
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьДанныеПрибораУчета(ВидКанальности, ЗаводскойНомер, ПриборУчетаСсылка)
	
	ПриборОбъект 				= ПриборУчетаСсылка.ПолучитьОбъект();
	ПриборОбъект.ВидКанальности = ВидКанальности;
	ПриборОбъект.Код 			= ЗаводскойНомер;
	ПриборОбъект.Записать();
	
КонецПроцедуры

Функция СоздатьТочкуУчета(ДанныеПрибора) Экспорт 
	
	ПриборОбъект  			= Справочники.энргПриборыУчетаАбонента.СоздатьЭлемент();
	ЗаполнитьЗначенияСвойств(ПриборОбъект,ДанныеПрибора);
	ПриборОбъект.Записать();
	Возврат ПриборОбъект.Ссылка;
КонецФункции

Функция ДействующиеПриборыУчетаАбонента(Период,Организация,Район,Абонент) Экспорт 
		
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Абонент",				Абонент);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаАбонента
	|ИЗ
