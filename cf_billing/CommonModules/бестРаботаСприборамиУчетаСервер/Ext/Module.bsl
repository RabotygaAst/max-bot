	|	ЕСТЬNULL(СреднийОбъемПотребления.Объем, 0) * ЕСТЬNULL(ПовышающийКоэф.ПовышающийКоэффициент, 1) * ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(ЕСТЬNULL(бестПоказанияПриборовУчетаНПСрезПоследних.Период, ДАТАВРЕМЯ(1, 1, 1)), &ПериодНачисления, МЕСЯЦ) = 0
