	|			И ВрТ15.Услуга = бестНагрузкаПоУслугамНПСрезПоследних.Услуга
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестГарантированныеОбъемы.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район
	|					И Месяц = МЕСЯЦ(&ПериодНачисления)) КАК бестГарантированныеОбъемыСрезПоследних
	|		ПО ВрТ15.ОбъектРасчета = бестГарантированныеОбъемыСрезПоследних.ОбъектРасчета
	|			И ВрТ15.Услуга = бестГарантированныеОбъемыСрезПоследних.Услуга
	|		ЛЕВОЕ СОЕДИНЕНИЕ КоличествоЧасовРаботыТУТекПериод КАК КоличествоЧасовРаботыТУТекПериод
	|		ПО ВрТ15.ТочкаУчета = КоличествоЧасовРаботыТУТекПериод.ТочкаУчета
	|			И ВрТ15.Услуга = КоличествоЧасовРаботыТУТекПериод.Услуга
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДопускККомУчету КАК ДопускККомУчету
	|		ПО ВрТ15.ТочкаУчета = ДопускККомУчету.ТочкаУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестДоговорыТочекУчета.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район) КАК бестДоговорыТочекУчетаСрезПоследних
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|			ПО бестДоговорыТочекУчетаСрезПоследних.Договор = энргДоговорыКонтрагентов.Ссылка
	|		ПО ВрТ15.ОбъектРасчета = бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета
	|			И ВрТ15.ТочкаУчета = бестДоговорыТочекУчетаСрезПоследних.ТочкаУчета
	|			И ВрТ15.Услуга = бестДоговорыТочекУчетаСрезПоследних.Услуга
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОбъектРасчета,
	|	ТочкаУчета,
	|	Услуга
	|АВТОУПОРЯДОЧИВАНИЕ";	
	//Результат  = Запрос.Выполнить();
	
	Если НЕ ЗначениеЗаполнено(ОбъектРасчета) Тогда
		Текст = СтрЗаменить(Текст, "ОбъектРасчета = &ОбъектРасчета", " ИСТИНА ");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТочкаУчета) Тогда
		Текст = СтрЗаменить(Текст, "ТочкаУчета = &ТочкаУчета", " ИСТИНА ");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(МКД) Тогда
		Текст = СтрЗаменить(Текст, "бестОбъектыРасчета.МКД = &МКД", "ИСТИНА");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Договор) Тогда
		Текст = СтрЗаменить(Текст, "бестДоговорыТочекУчетаСрезПоследних.Договор = &Договор", "ИСТИНА");
	КонецЕсли;
	
	Запрос.Текст	= Текст;
	Пакет			= запрос.ВыполнитьПакетСПромежуточнымиДанными();
	Результат		= Пакет[Пакет.Количество() - 1];
	Возврат Результат;
КонецФункции

// Получает данные для массового ввода.
// Устаревшая, используется только для документа бестРегистрацияПоказанийНПОбщий.
// Параметры:
//  Период				-	Дата.
//  ПериодНачисления	-	Дата.
//  Организация			-	СправочникСсылка.энргЗоныОтвественности.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  Договор				-	СправочникСсылка.энргДоговорыКонтрагентов.
//  МКД					-	СправочникСсылка.энргСтроения.
//  ОбъектРасчета		-	СправочникСсылка.бестОбъектыРасчета.
//  ТочкаУчета			-	СправочникСсылка.энргТочкиУчета.
//  Услуга				-	СправочникСсылка.энргВидыУслуг.
//  Контролер			-	СправочникСсылка.энргСотрудники.
//  
// Возвращаемое значение:
//  Массив	-	массив с пакетами результата запроса.
//
Функция ДанныеДляМассовогоВвода(Период, ПериодНачисления, Организация, Район, Договор, МКД, ОбъектРасчета, ТочкаУчета, Услуга, Контролер = Неопределено) Экспорт	
	
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления);
	
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП;
	
	МВТ  									= Новый МенеджерВременныхТаблиц;
	Параметры  								= Новый Структура("Организация,Район,Дата",Организация, Район, новый Граница(Период, ВидГраницы.Исключая));
	Если ЗначениеЗаполнено(ОбъектРасчета) Тогда
		Параметры.Вставить("ОбъектРасчета", ОбъектРасчета);
	КонецЕсли;
	
	бестРаботаСПоказаниямиПриборовУчетаНПСервер.МаксимальныеПоказанияСрезПоследних(МВТ,"энргМаксимальныеПоказанияСрезПоследних",Параметры);

	
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц			= МВТ;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("Договор",				Договор);
	Запрос.УстановитьПараметр("МКД",					МКД);
	Запрос.УстановитьПараметр("ОбъектРасчета",			ОбъектРасчета);
	Запрос.УстановитьПараметр("ТочкаУчета",				ТочкаУчета);
	Запрос.УстановитьПараметр("Услуга",					Услуга);
	Запрос.УстановитьПараметр("Контролер",				Контролер);
	
	Запрос.УстановитьПараметр("ПериодНачисления",		ПериодНачисления);
	
	Запрос.УстановитьПараметр("НачалоПредМесяца",		ДобавитьМесяц(НачалоПериодаРасчета, -1));
	Запрос.УстановитьПараметр("КонецПредМесяца",		ДобавитьМесяц(КонецПериодаРасчета, -1));
	Запрос.УстановитьПараметр("НачалоМесяцаПредГод",	ДобавитьМесяц(НачалоПериодаРасчета, -12));
	Запрос.УстановитьПараметр("КонецМесяцаПредГод",		ДобавитьМесяц(КонецПериодаРасчета, -12));
	
	Текст 	=  
	"ВЫБРАТЬ
	|	бестДоговорыТочекУчетаСрезПоследних.Организация КАК Организация,
	|	бестДоговорыТочекУчетаСрезПоследних.Район КАК Район,
	|	бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестДоговорыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестДоговорыТочекУчетаСрезПоследних.Услуга КАК Услуга,
	|	бестДоговорыТочекУчетаСрезПоследних.Договор КАК Договор
	|ПОМЕСТИТЬ ВТ_Отбор
	|ИЗ
	|	РегистрСведений.бестДоговорыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета = &ТочкаУчета) КАК бестДоговорыТочекУчетаСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ПО бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета = бестОбъектыРасчета.Ссылка
	|ГДЕ
	|	бестДоговорыТочекУчетаСрезПоследних.Договор = &Договор
	|	И бестОбъектыРасчета.Контролер = &Контролер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестАктивностьТочекУчетаНПСрезПоследних.Организация КАК Организация,
	|	бестАктивностьТочекУчетаНПСрезПоследних.Район КАК Район
	|ПОМЕСТИТЬ АктивныеТочкиУчетаОбъекта
	|ИЗ
	|	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			(Организация, Район, ОбъектРасчета, ТочкаУчета) В
	|				(ВЫБРАТЬ
	|					ВТ.Организация,
	|					ВТ.Район,
	|					ВТ.ОбъектРасчета,
	|					ВТ.ТочкаУчета
	|				ИЗ
	|					ВТ_Отбор КАК ВТ)) КАК бестАктивностьТочекУчетаНПСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ПО бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета = бестОбъектыРасчета.Ссылка
	|ГДЕ
	|	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|	И бестОбъектыРасчета.МКД = &МКД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.Организация КАК Организация,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.Район КАК Район,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	ВТ_Отбор.Договор КАК Договор
	|ПОМЕСТИТЬ ВведенныеПриборы
	|ИЗ
	|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаОбъекта.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта)
	|				И ОбъектРасчета = &ОбъектРасчета) КАК бестСостояниеПриборовУчетаНПСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
	|			И (НЕ энргПриборыУчетаАбонента.ПометкаУдаления)
	|			И (НЕ энргПриборыУчетаАбонента.РегистрируетОбъем)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Отбор КАК ВТ_Отбор
	|		ПО бестСостояниеПриборовУчетаНПСрезПоследних.Организация = ВТ_Отбор.Организация
	|			И бестСостояниеПриборовУчетаНПСрезПоследних.Район = ВТ_Отбор.Район
	|			И бестСостояниеПриборовУчетаНПСрезПоследних.ОбъектРасчета = ВТ_Отбор.ОбъектРасчета
	|			И бестСостояниеПриборовУчетаНПСрезПоследних.ТочкаУчета = ВТ_Отбор.ТочкаУчета
	|ГДЕ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга,
	|	бестУслугиТочекУчетаНПСрезПоследних.Организация КАК Организация,
	|	бестУслугиТочекУчетаНПСрезПоследних.Район КАК Район,
	|	бестУслугиТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ УслугиТочекУчета
	|ИЗ
	|	РегистрСведений.бестУслугиТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ОбъектРасчета, ТочкаУчета) В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаОбъекта.ОбъектРасчета КАК ОбъектРасчета,
	|						АктивныеТочкиУчетаОбъекта.ТочкаУчета КАК ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта)) КАК бестУслугиТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВведенныеПриборы.ТочкаУчета КАК ТочкаУчета,
	|	ВведенныеПриборы.ПриборУчета КАК ПриборУчета,
	|	ВведенныеПриборы.Организация КАК Организация,
	|	ВведенныеПриборы.Район КАК Район,
	|	УслугиТочекУчета.Услуга КАК Услуга,
	|	ВведенныеПриборы.ОбъектРасчета КАК ОбъектРасчета,
	|	ВведенныеПриборы.Договор КАК Договор
	|ПОМЕСТИТЬ ПриборыУчетаСУслугой
	|ИЗ
	|	ВведенныеПриборы КАК ВведенныеПриборы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ УслугиТочекУчета КАК УслугиТочекУчета
	|		ПО ВведенныеПриборы.Организация = УслугиТочекУчета.Организация
	|			И ВведенныеПриборы.Район = УслугиТочекУчета.Район
	|			И ВведенныеПриборы.ОбъектРасчета = УслугиТочекУчета.ОбъектРасчета
	|			И ВведенныеПриборы.ТочкаУчета = УслугиТочекУчета.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.Шкала КАК Шкала,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ВидДифференцированности КАК ВидДифференцированности,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ ВидыДифференцированностиТочекУчета
	|ИЗ
	|	РегистрСведений.бестВидыДифференцированностиПриборовУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаОбъекта.ОбъектРасчета
	|					ИЗ
	|						АктивныеТочкиУчетаОбъекта)) КАК бестВидыДифференцированностиПриборовУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриборыУчетаСУслугой.ОбъектРасчета КАК ОбъектРасчета,
	|	ПриборыУчетаСУслугой.ТочкаУчета КАК ТочкаУчета,
	|	ПриборыУчетаСУслугой.ПриборУчета.ВидКанальности КАК ВидКанальности,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала,
	|	ПриборыУчетаСУслугой.ПриборУчета КАК ПриборУчета,
	|	ПриборыУчетаСУслугой.Услуга КАК Услуга,
	|	ПриборыУчетаСУслугой.Договор КАК Договор
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	ПриборыУчетаСУслугой КАК ПриборыУчетаСУслугой
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ПриборыУчетаСУслугой.ПриборУчета.ВидКанальности = энргВидыКанальностиШкалы.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестКоэффциентыПриборовУчетаНПСрезПоследних.Организация КАК Организация,
