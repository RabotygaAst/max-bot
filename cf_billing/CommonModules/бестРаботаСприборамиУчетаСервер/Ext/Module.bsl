#Область ПрограммныйИнтерфейс

// Получает действующие приборы учета по объекту расчета.
//
// Параметры:
//  Период									-	Дата.
//  Организация								-	СправочникСсылка.Организации.
//  Район									-	СправочникСсылка.энргЗоныОтвественности.
//  ОбъектРасчета							-	СправочникСсылка.бестОбъектыРасчета.
//  СТочкамиБезПриборов						-	Булево.
//  БезУзлов								-	Булево.
//  МВТ										-	МенеджерВременныхТаблиц.
//  ПростыеУслуги							-	Булево.
//  ТочкаУслуги								-	Справочник.энргТочкиУчета.
//  СПриборамиБезВидаДифференцированности	-	Булево.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ДействующиеПриборыУчетаПоОбъектуРасчета(Период,Организация,Район,ОбъектРасчета = Неопределено,СТочкамиБезПриборов = Ложь, БезУзлов = Ложь, МВТ = Неопределено, ПростыеУслуги = Ложь, ТочкаУслуги = Неопределено, СПриборамиБезВидаДифференцированности = Ложь) Экспорт 
	
	Запрос  		= Новый Запрос;
	Если МВТ <> Неопределено Тогда
		Запрос.МенеджерВременныхТаблиц = МВТ;
	КонецЕсли;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",			ОбъектРасчета);
	Запрос.УстановитьПараметр("ТочкаУчета",				ТочкаУслуги);
	
	Запрос.Текст = ТекстЗапросаДействующиеПриборыУчетаПоОбъектуРасчета(ОбъектРасчета,СТочкамиБезПриборов, БезУзлов, ПростыеУслуги, ТочкаУслуги, СПриборамиБезВидаДифференцированности);	
	
	Если МВТ = Неопределено Тогда
		Пакет = запрос.ВыполнитьПакетСПромежуточнымиДанными();
		Результат = Пакет[Пакет.Количество() - 1];
		Возврат Результат;
	Иначе
		Результат  = Запрос.Выполнить();
	КонецЕсли;
КонецФункции

// Получает действующие приборы учета по объекту с показаниями.
//
// Параметры:
//  Период									-	Дата.
//  Организация								-	СправочникСсылка.Организации.
//  Район									-	СправочникСсылка.энргЗоныОтвественности.
//  ОбъектРасчета							-	СправочникСсылка.бестОбъектыРасчета.
// 
// Возвращаемое значение:
//  РезультатЗапроса.
//
Функция ДействующиеПриборыУчетаПоОбъектуРасчетаСПоказаниями(Период,Организация,Район,ОбъектРасчета = Неопределено) Экспорт 

	Запрос  		= Новый Запрос;  
	МВТ				= Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",			ОбъектРасчета);
	
	Запрос.Текст = ТекстЗапросаДействующиеПриборыУчетаПоОбъектуРасчета(ОбъектРасчета,Ложь, Ложь, Ложь, Неопределено, Ложь);	
	
	Параметры  								= Новый Структура("Организация,Район,Дата,ОбъектРасчета",Организация, Район, Новый Граница(Период,ВидГраницы.Исключая), ОбъектРасчета);   	
	
	бестРаботаСПоказаниямиПриборовУчетаНПСервер.МаксимальныеПоказанияСрезПоследних(МВТ,"энргМаксимальныеПоказанияСрезПоследних",Параметры);
	
	Запрос.МенеджерВременныхТаблиц	 = МВТ;
	
	Запрос.Текст = Запрос.Текст + 
	"; ВЫБРАТЬ
	|	Итог.ОбъектРасчета КАК ОбъектРасчета,
	|	Итог.ТочкаУчета КАК ТочкаУчета,
	|	Итог.Шкала КАК Шкала,
	|	Итог.Услуга КАК Услуга,
	|	Итог.ВидДифференцированности КАК ВидДифференцированности,
	|	Итог.ТарифнаяЗона КАК ТарифнаяЗона,
	|	Итог.ПриборУчета КАК ПриборУчета,
	|	Итог.РегистрируетОбъем КАК РегистрируетОбъем,
	|	Итог.ЗаводскойНомерПриборУчета КАК ЗаводскойНомерПриборУчета,
	|	Итог.ВидПараметра КАК ВидПараметра,
	|	Итог.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	Итог.ВидКанальности КАК ВидКанальности,
	|	энргМаксимальныеПоказанияСрезПоследних.Показание КАК Показание
	|ИЗ
	|	Итог КАК Итог
	|		ЛЕВОЕ СОЕДИНЕНИЕ энргМаксимальныеПоказанияСрезПоследних КАК энргМаксимальныеПоказанияСрезПоследних
	|		ПО Итог.ПриборУчета = энргМаксимальныеПоказанияСрезПоследних.ПриборУчета
	|			И Итог.Шкала = энргМаксимальныеПоказанияСрезПоследних.Шкала
	|			И Итог.ТарифнаяЗона = энргМаксимальныеПоказанияСрезПоследних.ТарифнаяЗона
	|
	|УПОРЯДОЧИТЬ ПО
	|	Итог.ОбъектРасчета,
	|	Итог.ТочкаУчета,
	|	Итог.ПриборУчета,
	|	Итог.Шкала";
	
	Пакет = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	Результат = Пакет[Пакет.Количество() - 1];
	
	Возврат Результат;
КонецФункции

Функция ТекстЗапросаДействующиеПриборыУчетаПоОбъектуРасчета(ОбъектРасчета, СТочкамиБезПриборов, БезУзлов, ПростыеУслуги, ТочкаУслуги, СПриборамиБезВидаДифференцированности)
   Текст 	=
	"ВЫБРАТЬ
	|	бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаОбъекта
	|ИЗ
	|	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета = &ТочкаУчета) КАК бестАктивностьТочекУчетаНПСрезПоследних
	|ГДЕ
	|	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|                                          
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестПриборыТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочекУчета
	|ИЗ
	|	РегистрСведений.бестПриборыТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ТочкаУчета, ОбъектРасчета) В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаОбъекта.ТочкаУчета КАК ТочкаУчета,
	|						АктивныеТочкиУчетаОбъекта.ОбъектРасчета КАК ОбъектРасчета
	|					ИЗ
	|						АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта)) КАК бестПриборыТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета.ВидКанальности КАК ВидКанальности
	|ПОМЕСТИТЬ ВведенныеПриборы
	|ИЗ
	|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ОбъектРасчета, ТочкаУчета, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						ПриборыТочекУчета.ОбъектРасчета КАК ОбъектРасчета,
	|						ПриборыТочекУчета.ТочкаУчета КАК ТочкаУчета,
	|						ПриборыТочекУчета.ПриборУчета КАК ПриборУчета
	|					ИЗ
	|						ПриборыТочекУчета КАК ПриборыТочекУчета)) КАК бестСостояниеПриборовУчетаНПСрезПоследних
	|ГДЕ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ УслугиТочекУчета
	|ИЗ
	|	РегистрСведений.бестУслугиТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ОбъектРасчета, ТочкаУчета) В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаОбъекта.ОбъектРасчета КАК ОбъектРасчета,
	|						АктивныеТочкиУчетаОбъекта.ТочкаУчета КАК ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта)) КАК бестУслугиТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВведенныеПриборы.ОбъектРасчета КАК ОбъектРасчета,
	|	ВведенныеПриборы.ТочкаУчета КАК ТочкаУчета,
	|	ВведенныеПриборы.ВидКанальности КАК ВидКанальности,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала,
	|	ВведенныеПриборы.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	ВведенныеПриборы КАК ВведенныеПриборы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВведенныеПриборы.ВидКанальности = энргВидыКанальностиШкалы.Ссылка
	|ГДЕ
	|	НЕ ВведенныеПриборы.ПриборУчета.РегистрируетОбъем
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.Шкала КАК Шкала,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ВидДифференцированности КАК ВидДифференцированности
	|ПОМЕСТИТЬ ВидыДифференцированностиТочекУчета
	|ИЗ
	|	РегистрСведений.бестВидыДифференцированностиПриборовУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ПриборУчета В
	|					(ВЫБРАТЬ
	|						ДанныеПоПриборам.ПриборУчета КАК ПриборУчета
	|					ИЗ
	|						ДанныеПоПриборам КАК ДанныеПоПриборам)) КАК бестВидыДифференцированностиПриборовУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестПараметрыИзмерителейСрезПоследних.Измеритель КАК Измеритель,
	|	бестПараметрыИзмерителейСрезПоследних.ВидПараметра КАК ВидПараметра,
	|	бестПараметрыИзмерителейСрезПоследних.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	бестПараметрыИзмерителейСрезПоследних.Шкала КАК Шкала
	|ПОМЕСТИТЬ ВТ_ПараметрыИзмерителей
	|ИЗ
	|	РегистрСведений.бестПараметрыИзмерителей.СрезПоследних(
	|			&Период,
	|			Измеритель В
	|				(ВЫБРАТЬ
	|					ДанныеПоПриборам.ПриборУчета КАК ПриборУчета
	|				ИЗ
	|					ДанныеПоПриборам КАК ДанныеПоПриборам)) КАК бестПараметрыИзмерителейСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////";
	
	
	Если ПростыеУслуги Тогда
		Текст 	=  Текст + Символы.ПС +
		"ВЫБРАТЬ
		|	Вложенныйзапрос.ОбъектРасчета КАК ОбъектРасчета,
		|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
		|	Вложенныйзапрос.Шкала КАК Шкала,
		|	ВЫБОР
		|		КОГДА энргВидыУслугСоставляющиеУслуг.Услуга ЕСТЬ NULL
		|			ТОГДА Вложенныйзапрос.Услуга
		|		ИНАЧЕ энргВидыУслугСоставляющиеУслуг.Услуга
		|	КОНЕЦ КАК Услуга,
		|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
		|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона,
		|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
		|	Вложенныйзапрос.ПриборУчета.РегистрируетОбъем КАК РегистрируетОбъем,
		|	Вложенныйзапрос.ПриборУчета.Код КАК ЗаводскойНомерПриборУчета,
		|	ВТ_ПараметрыИзмерителей.ВидПараметра КАК ВидПараметра,
		|	ВТ_ПараметрыИзмерителей.РасположениеИзмерителя КАК РасположениеИзмерителя,
		|	Вложенныйзапрос.ВидКанальности КАК ВидКанальности
		|ПОМЕСТИТЬ Итог
		|ИЗ
		|	(ВЫБРАТЬ
		|		ДанныеПоПриборам.ОбъектРасчета КАК ОбъектРасчета,
		|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
		|		ДанныеПоПриборам.Шкала КАК Шкала,
		|		ЕСТЬNULL(УслугиТочекУчета.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
		|		ЕСТЬNULL(ВидыДифференцированностиТочекУчета.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности,
		|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
		|		ДанныеПоПриборам.ВидКанальности КАК ВидКанальности
		|	ИЗ
		|		ДанныеПоПриборам КАК ДанныеПоПриборам
		|			ЛЕВОЕ СОЕДИНЕНИЕ УслугиТочекУчета КАК УслугиТочекУчета
		|			ПО ДанныеПоПриборам.ТочкаУчета = УслугиТочекУчета.ТочкаУчета
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВидыДифференцированностиТочекУчета КАК ВидыДифференцированностиТочекУчета
		|			ПО ДанныеПоПриборам.ПриборУчета = ВидыДифференцированностиТочекУчета.ПриборУчета
		|				И ДанныеПоПриборам.Шкала = ВидыДифференцированностиТочекУчета.Шкала) КАК Вложенныйзапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
		|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПараметрыИзмерителей КАК ВТ_ПараметрыИзмерителей
		|		ПО Вложенныйзапрос.ПриборУчета = ВТ_ПараметрыИзмерителей.Измеритель
		|			И Вложенныйзапрос.Шкала = ВТ_ПараметрыИзмерителей.Шкала
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
		|		ПО Вложенныйзапрос.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка";
		
	Иначе
		Текст 	=  Текст + Символы.ПС +
		"ВЫБРАТЬ
		|	Вложенныйзапрос.ОбъектРасчета КАК ОбъектРасчета,
		|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
		|	Вложенныйзапрос.Шкала КАК Шкала,
		|	Вложенныйзапрос.Услуга КАК Услуга,
		|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
		|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона,
		|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
		|	Вложенныйзапрос.ПриборУчета.РегистрируетОбъем КАК РегистрируетОбъем,
		|	Вложенныйзапрос.ПриборУчета.Код КАК ЗаводскойНомерПриборУчета,
		|	ВТ_ПараметрыИзмерителей.ВидПараметра КАК ВидПараметра,
		|	ВТ_ПараметрыИзмерителей.РасположениеИзмерителя КАК РасположениеИзмерителя,
		|	Вложенныйзапрос.ВидКанальности КАК ВидКанальности
		|ПОМЕСТИТЬ Итог
		|ИЗ
		|	(ВЫБРАТЬ
		|		ДанныеПоПриборам.ОбъектРасчета КАК ОбъектРасчета,
		|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
		|		ДанныеПоПриборам.Шкала КАК Шкала,
		|		ЕСТЬNULL(УслугиТочекУчета.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
		|		ЕСТЬNULL(ВидыДифференцированностиТочекУчета.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности,
		|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
		|		ДанныеПоПриборам.ВидКанальности КАК ВидКанальности
		|	ИЗ
		|		ДанныеПоПриборам КАК ДанныеПоПриборам
		|			ЛЕВОЕ СОЕДИНЕНИЕ УслугиТочекУчета КАК УслугиТочекУчета
		|			ПО ДанныеПоПриборам.ТочкаУчета = УслугиТочекУчета.ТочкаУчета
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВидыДифференцированностиТочекУчета КАК ВидыДифференцированностиТочекУчета
		|			ПО ДанныеПоПриборам.ПриборУчета = ВидыДифференцированностиТочекУчета.ПриборУчета
		|				И ДанныеПоПриборам.Шкала = ВидыДифференцированностиТочекУчета.Шкала) КАК Вложенныйзапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
		|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПараметрыИзмерителей КАК ВТ_ПараметрыИзмерителей
		|		ПО Вложенныйзапрос.ПриборУчета = ВТ_ПараметрыИзмерителей.Измеритель
		|			И Вложенныйзапрос.Шкала = ВТ_ПараметрыИзмерителей.Шкала";
	КонецЕсли;
	
	Если СТочкамиБезПриборов Тогда
		Если ПростыеУслуги Тогда
			Текст 	= Текст 	+ Символы.ПС + 
			"ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	АктивныеТочкиУчетаОбъекта.ОбъектРасчета,
			|	АктивныеТочкиУчетаОбъекта.ТочкаУчета,
			|	NULL,
			|	ВЫБОР
			|		КОГДА энргВидыУслугСоставляющиеУслуг.Услуга ЕСТЬ NULL
			|			ТОГДА УслугиТочекУчета.Услуга
			|		ИНАЧЕ энргВидыУслугСоставляющиеУслуг.Услуга
			|	КОНЕЦ КАК Услуга,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL
			|ИЗ
			|	АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ УслугиТочекУчета КАК УслугиТочекУчета
			|		ПО АктивныеТочкиУчетаОбъекта.ТочкаУчета = УслугиТочекУчета.ТочкаУчета
			|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеПоПриборам КАК ДанныеПоПриборам
			|		ПО АктивныеТочкиУчетаОбъекта.ОбъектРасчета = ДанныеПоПриборам.ОбъектРасчета
			|			И АктивныеТочкиУчетаОбъекта.ТочкаУчета = ДанныеПоПриборам.ТочкаУчета
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
			|		ПО УслугиТочекУчета.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
			|ГДЕ
			|	ДанныеПоПриборам.ПриборУчета ЕСТЬ NULL";
		Иначе
			Текст 	= Текст 	+ Символы.ПС + 
			"ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	АктивныеТочкиУчетаОбъекта.ОбъектРасчета,
			|	АктивныеТочкиУчетаОбъекта.ТочкаУчета,
			|	NULL,
			|	УслугиТочекУчета.Услуга,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL,
			|	NULL
			|ИЗ
			|	АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ УслугиТочекУчета КАК УслугиТочекУчета
			|		ПО АктивныеТочкиУчетаОбъекта.ТочкаУчета = УслугиТочекУчета.ТочкаУчета
			|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеПоПриборам КАК ДанныеПоПриборам
			|		ПО АктивныеТочкиУчетаОбъекта.ОбъектРасчета = ДанныеПоПриборам.ОбъектРасчета
			|			И АктивныеТочкиУчетаОбъекта.ТочкаУчета = ДанныеПоПриборам.ТочкаУчета
			|ГДЕ
			|	ДанныеПоПриборам.ПриборУчета ЕСТЬ NULL";
		КонецЕсли;
	КонецЕсли;
	
	Если СПриборамиБезВидаДифференцированности Тогда
		Текст = СтрЗаменить(Текст, 
									"ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны",
									"ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны");
	КонецЕсли;
	
	Текст 	=  Текст + Символы.ПС +
	";
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.ОбъектРасчета КАК ОбъектРасчета,
	|	Итог.ТочкаУчета КАК ТочкаУчета,
	|	Итог.Шкала КАК Шкала,
	|	Итог.Услуга КАК Услуга,
	|	Итог.ВидДифференцированности КАК ВидДифференцированности,
	|	Итог.ТарифнаяЗона КАК ТарифнаяЗона,
	|	Итог.ПриборУчета КАК ПриборУчета,
	|	Итог.РегистрируетОбъем КАК РегистрируетОбъем,
	|	Итог.ЗаводскойНомерПриборУчета КАК ЗаводскойНомерПриборУчета,
	|	Итог.ВидПараметра КАК ВидПараметра,
	|	Итог.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	Итог.ВидКанальности КАК ВидКанальности
	|ИЗ
	|	Итог КАК Итог
	|	УПОРЯДОЧИТЬ ПО
	|	Итог.ОбъектРасчета,
	|	Итог.ТочкаУчета,
	|	Итог.ПриборУчета,
	|	Итог.Шкала";
	
	
	Если НЕ БезУзлов Тогда
		
		Текст = СтрЗаменить(Текст,"НЕ ВложенныйЗапрос.ПриборУчета.РегистрируетОбъем", "ИСТИНА");
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ОбъектРасчета) Тогда
		Текст = СтрЗаменить(Текст, "ОбъектРасчета = &ОбъектРасчета", "Истина");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТочкаУслуги) Тогда
		Текст = СтрЗаменить(Текст, "ТочкаУчета = &ТочкаУчета", "Истина");  
	КонецЕсли;
	
	Если ТипЗнч(ОбъектРасчета) = Тип("Массив") Тогда
		Текст = СтрЗаменить(Текст,"ОбъектРасчета = &ОбъектРасчета", "ОбъектРасчета В (&ОбъектРасчета)");
	КонецЕсли;
	
		
	
	Возврат Текст;	

КонецФункции

// Получает действующие приборы учета по объекту расчета с измерителями.
// Получение измерителей, используется в объектах рнт.
//
// Параметры:
//  Период				-	Дата.
//  Организация			-	СправочникСсылка.Организации.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  ОбъектРасчета		-	СправочникСсылка.бестОбъектыРасчета.
//  ТочкаУчета			-	СправочникСсылка.энргТочкиУчета.
//  МВТ					-	МенеджерВременныхТаблиц.
// 
// Возвращаемое значение:
//  Массив	-	массив с пакетами результата запроса.
//
Функция ДействующиеПриборыУчетаПоОбъектуРасчетаСИзмерителями(Период,Организация,Район,ОбъектРасчета = Неопределено,ТочкаУчета = Неопределено,МВТ = Неопределено) Экспорт 
	
	Запрос  		= Новый Запрос;
	Если МВТ <> Неопределено Тогда
		Запрос.МенеджерВременныхТаблиц = МВТ;
	КонецЕсли;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаОбъекта
	|ИЗ
	|	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета = &ТочкаУчета) КАК бестАктивностьТочекУчетаНПСрезПоследних
	|ГДЕ
	|	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестПриборыТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочекУчета
	|ИЗ
	|	РегистрСведений.бестПриборыТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ТочкаУчета, ОбъектРасчета) В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаОбъекта.ТочкаУчета КАК ТочкаУчета,
	|						АктивныеТочкиУчетаОбъекта.ОбъектРасчета КАК ОбъектРасчета
	|					ИЗ
	|						АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта)) КАК бестПриборыТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета.ВидКанальности КАК ВидКанальности
	|ПОМЕСТИТЬ ВведенныеПриборы
	|ИЗ
	|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ОбъектРасчета, ТочкаУчета, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						ПриборыТочекУчета.ОбъектРасчета КАК ОбъектРасчета,
	|						ПриборыТочекУчета.ТочкаУчета КАК ТочкаУчета,
	|						ПриборыТочекУчета.ПриборУчета КАК ПриборУчета
	|					ИЗ
	|						ПриборыТочекУчета КАК ПриборыТочекУчета)) КАК бестСостояниеПриборовУчетаНПСрезПоследних
	|ГДЕ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ УслугиТочекУчета
	|ИЗ
	|	РегистрСведений.бестУслугиТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ОбъектРасчета, ТочкаУчета) В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаОбъекта.ОбъектРасчета КАК ОбъектРасчета,
	|						АктивныеТочкиУчетаОбъекта.ТочкаУчета КАК ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта)) КАК бестУслугиТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВведенныеПриборы.ОбъектРасчета КАК ОбъектРасчета,
	|	ВведенныеПриборы.ТочкаУчета КАК ТочкаУчета,
	|	ВведенныеПриборы.ВидКанальности КАК ВидКанальности,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала,
	|	ВведенныеПриборы.ПриборУчета КАК ПриборУчета,
	|	энргПриборыУчетаАбонента.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	энргПриборыУчетаАбонента.РегистрируетОбъем КАК РегистрируетОбъем,
	|	энргПриборыУчетаАбонента.ТипУзлаУчета КАК ТипУзлаУчета
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	ВведенныеПриборы КАК ВведенныеПриборы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВведенныеПриборы.ВидКанальности = энргВидыКанальностиШкалы.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ВведенныеПриборы.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
	|ГДЕ
	|	НЕ ВведенныеПриборы.ПриборУчета.РегистрируетОбъем
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.Шкала КАК Шкала,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ВидДифференцированности КАК ВидДифференцированности
	|ПОМЕСТИТЬ ВидыДифференцированностиТочекУчета
	|ИЗ
	|	РегистрСведений.бестВидыДифференцированностиПриборовУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ПриборУчета В
	|					(ВЫБРАТЬ
	|						ДанныеПоПриборам.ПриборУчета КАК ПриборУчета
	|					ИЗ
	|						ДанныеПоПриборам КАК ДанныеПоПриборам)) КАК бестВидыДифференцированностиПриборовУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестПараметрыИзмерителейСрезПоследних.Измеритель КАК Измеритель,
	|	бестПараметрыИзмерителейСрезПоследних.ВидПараметра КАК ВидПараметра,
	|	бестПараметрыИзмерителейСрезПоследних.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	бестПараметрыИзмерителейСрезПоследних.Шкала КАК Шкала
	|ПОМЕСТИТЬ ВТ_ПараметрыИзмерителей
	|ИЗ
	|	РегистрСведений.бестПараметрыИзмерителей.СрезПоследних(
	|			&Период,
	|			Измеритель В
	|				(ВЫБРАТЬ
	|					ДанныеПоПриборам.ПриборУчета КАК ПриборУчета
	|				ИЗ
	|					ДанныеПоПриборам КАК ДанныеПоПриборам)) КАК бестПараметрыИзмерителейСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестПриборыУзловУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестПриборыУзловУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	ИСТИНА КАК ВспомогательноеОборудование,
	|	бестПриборыУзловУчетаНПСрезПоследних.ТипИзмерителя КАК ТипИзмерителя,
	|	энргПриборыУчетаАбонента.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	бестПриборыУзловУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ Измерители
	|ИЗ
	|	РегистрСведений.бестПриборыУзловУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ОбъектРасчета, ТочкаУчета, УзелУчета) В
	|					(ВЫБРАТЬ
	|						ДанныеПоПриборам.ОбъектРасчета КАК ОбъектРасчета,
	|						ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|						ДанныеПоПриборам.ПриборУчета КАК ПриборУчета
	|					ИЗ
	|						ДанныеПоПриборам КАК ДанныеПоПриборам)) КАК бестПриборыУзловУчетаНПСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО бестПриборыУзловУчетаНПСрезПоследних.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Вложенныйзапрос.ОбъектРасчета КАК ОбъектРасчета,
	|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
	|	Вложенныйзапрос.Шкала КАК Шкала,
	|	Вложенныйзапрос.Услуга КАК Услуга,
	|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона,
	|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
	|	Вложенныйзапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	ВТ_ПараметрыИзмерителей.ВидПараметра КАК ВидПараметра,
	|	Вложенныйзапрос.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	Вложенныйзапрос.ВидКанальности КАК ВидКанальности,
	|	Вложенныйзапрос.ТипУзлаУчета КАК ТипУзлаУчета,
	|	энргТипыПриборовУчета.Родитель КАК ТипИзмерителя
	|ПОМЕСТИТЬ Итог
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеПоПриборам.ОбъектРасчета КАК ОбъектРасчета,
	|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|		ДанныеПоПриборам.Шкала КАК Шкала,
	|		ЕСТЬNULL(УслугиТочекУчета.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|		ЕСТЬNULL(ВидыДифференцированностиТочекУчета.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности,
	|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|		ДанныеПоПриборам.ВидКанальности КАК ВидКанальности,
	|		ДанныеПоПриборам.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|		ДанныеПоПриборам.РегистрируетОбъем КАК РегистрируетОбъем,
	|		ДанныеПоПриборам.ТипУзлаУчета КАК ТипУзлаУчета
	|	ИЗ
	|		ДанныеПоПриборам КАК ДанныеПоПриборам
	|			ЛЕВОЕ СОЕДИНЕНИЕ УслугиТочекУчета КАК УслугиТочекУчета
	|			ПО ДанныеПоПриборам.ТочкаУчета = УслугиТочекУчета.ТочкаУчета
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВидыДифференцированностиТочекУчета КАК ВидыДифференцированностиТочекУчета
	|			ПО ДанныеПоПриборам.ПриборУчета = ВидыДифференцированностиТочекУчета.ПриборУчета
	|				И ДанныеПоПриборам.Шкала = ВидыДифференцированностиТочекУчета.Шкала) КАК Вложенныйзапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
	|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПараметрыИзмерителей КАК ВТ_ПараметрыИзмерителей
	|		ПО Вложенныйзапрос.ПриборУчета = ВТ_ПараметрыИзмерителей.Измеритель
	|			И Вложенныйзапрос.Шкала = ВТ_ПараметрыИзмерителей.Шкала
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргТипыПриборовУчета КАК энргТипыПриборовУчета
	|		ПО Вложенныйзапрос.ПриборУчета.ТипПрибораУчета = энргТипыПриборовУчета.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.ОбъектРасчета КАК ОбъектРасчета,
	|	Итог.ТочкаУчета КАК ТочкаУчета,
	|	Итог.Шкала КАК Шкала,
	|	Итог.Услуга КАК Услуга,
	|	Итог.ВидДифференцированности КАК ВидДифференцированности,
	|	Итог.ТарифнаяЗона КАК ТарифнаяЗона,
	|	Итог.ПриборУчета КАК ПриборУчетаВывод,
	|	Итог.РегистрируетОбъем КАК РегистрируетОбъем,
	|	Итог.ВидПараметра КАК ВидПараметра,
	|	Итог.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	Итог.ВидКанальности КАК ВидКанальности,
	|	Итог.ТипУзлаУчета КАК ТипУзлаУчета,
	|	Итог.ТипИзмерителя КАК ТипИзмерителя
	|ИЗ
	|	Итог КАК Итог
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТочкаУчета,
	|	Шкала
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Измерители.ТочкаУчета КАК ТочкаУчета,
	|	Измерители.ПриборУчета КАК ПриборУчета,
	|	Измерители.ВспомогательноеОборудование КАК ВспомогательноеОборудование,
	|	Измерители.ТипИзмерителя КАК ТипИзмерителя,
	|	Измерители.РасположениеИзмерителя КАК РасположениеИзмерителя
	|ИЗ
	|	Измерители КАК Измерители";
	
	Если ОбъектРасчета = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ОбъектРасчета = &ОбъектРасчета", "");
	Иначе
		Запрос.УстановитьПараметр("ОбъектРасчета",			ОбъектРасчета);
	КонецЕсли;
	
	Если ТочкаУчета = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТочкаУчета = &ТочкаУчета", "");
	Иначе
		Запрос.УстановитьПараметр("ТочкаУчета",			ТочкаУчета);
	КонецЕсли;
	
	Возврат Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
КонецФункции

// Получает массив действующих приборов учета.
//
// Параметры:
//  Период			-	Дата.
//  Организация		-	СправочникСсылка.Организации.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  ОбъектРасчета	-	СправочникСсылка.бестОбъектыРасчета.
//  ТочкаУчета		-	СправочникСсылка.энргТочкиУчета.
//  СИзмерителями	-	Булево.
// 
// Возвращаемое значение:
//   Массив	из СправочникСсылка.энргПриборыУчетаАбонента.
//
Функция ПолучитьМассивДействующихПриборовУчета(Период,Организация,Район,ОбъектРасчета,ТочкаУчета = Неопределено, СИзмерителями = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Если СИзмерителями Тогда
		Запрос.Текст =	
		"ВЫБРАТЬ
		|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
		|	бестСостояниеПриборовУчетаНПСрезПоследних.Организация КАК Организация,
		|	бестСостояниеПриборовУчетаНПСрезПоследних.Район КАК Район,
		|	бестСостояниеПриборовУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
		|	бестСостояниеПриборовУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета
		|ПОМЕСТИТЬ Узлы
		|ИЗ
		|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ОбъектРасчета = &ОбъектРасчета
		|				И ТочкаУчета = &ТочкаУчета) КАК бестСостояниеПриборовУчетаНПСрезПоследних
		|ГДЕ
		|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние <> ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Вывод)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестПриборыУзловУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
		|ИЗ
		|	Узлы КАК Узлы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестПриборыУзловУчетаНП.СрезПоследних(
		|				&Период,
		|				Организация = &Организация
		|					И Район = &Район
		|					И ОбъектРасчета = &ОбъектРасчета
		|					И ТочкаУчета = &ТочкаУчета) КАК бестПриборыУзловУчетаНПСрезПоследних
		|		ПО Узлы.Организация = бестПриборыУзловУчетаНПСрезПоследних.Организация
		|			И Узлы.Район = бестПриборыУзловУчетаНПСрезПоследних.Район
		|			И Узлы.ОбъектРасчета = бестПриборыУзловУчетаНПСрезПоследних.ОбъектРасчета
		|			И Узлы.ТочкаУчета = бестПриборыУзловУчетаНПСрезПоследних.ТочкаУчета
		|			И Узлы.ПриборУчета = бестПриборыУзловУчетаНПСрезПоследних.УзелУчета
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Узлы.ПриборУчета
		|ИЗ
		|	Узлы КАК Узлы";
		
	Иначе
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
		|ИЗ
		|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ОбъектРасчета = &ОбъектРасчета
		|				И ТочкаУчета = &ТочкаУчета) КАК бестСостояниеПриборовУчетаНПСрезПоследних
		|ГДЕ
		|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние <> ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Вывод)";
		
	КонецЕсли;
	
	
	
	Запрос.УстановитьПараметр("Период"			,Период);
	Запрос.УстановитьПараметр("Организация"		,Организация);
	Запрос.УстановитьПараметр("Район"			,Район);
	Запрос.УстановитьПараметр("ОбъектРасчета"	,ОбъектРасчета);
	Если НЕ ЗначениеЗаполнено(ТочкаУчета) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТочкаУчета = &ТочкаУчета", "Истина");
	Иначе
		Запрос.УстановитьПараметр("ТочкаУчета"		,ТочкаУчета);
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ПриборУчета");		
	
КонецФункции

// Получает выведеные приборы.
//
// Параметры:
//  ПараметрыОперации	-	Структура:
//   * МоментВремени	-	Дата.
//   * Организация		-	СправочникСсылка.Организации.
//   * Район			-	СправочникСсылка.энргЗоныОтвественности.
//   * ОбъектРасчета	-	СправочникСсылка.бестОбъектыРасчета.
//   * МассивТочекУчета	-	Массив из СправочникСсылка.энргТочкиУчета.
// 
// Возвращаемое значение:
//   Булево.
//
Функция ПриборыВыведены(ПараметрыОперации) Экспорт 
	Запрос  =		Новый Запрос;
	Запрос.установитьПараметр("МоментВремени",		ПараметрыОперации.МоментВремени);
	Запрос.установитьПараметр("Организация",		ПараметрыОперации.Организация);
	Запрос.установитьПараметр("Район",				ПараметрыОперации.Район);
	Запрос.установитьПараметр("ОбъектРасчета",		ПараметрыОперации.ОбъектРасчета);
	Запрос.установитьПараметр("МассивТочекУчета",	ПараметрыОперации.МассивТочекУчета);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	бестПриборыТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочек
	|ИЗ
	|	РегистрСведений.бестПриборыТочекУчетаНП.СрезПоследних(
	|			&МоментВремени,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета В (&МассивТочекУчета)) КАК бестПриборыТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ИЗ
	|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
	|			&МоментВремени,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТочкаУчета В (&МассивТочекУчета)
	|				И (ОбъектРасчета, ТочкаУчета, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						ПриборыТочек.ОбъектРасчета,
	|						ПриборыТочек.ТочкаУчета,
	|						ПриборыТочек.ПриборУчета
	|					ИЗ
	|						ПриборыТочек КАК ПриборыТочек)) КАК бестСостояниеПриборовУчетаНПСрезПоследних
	|ГДЕ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеприборовУчета.Ввод)";
	Результат = Запрос.Выполнить();
	Возврат Результат.Пустой();
КонецФункции

#Область УстаревшиеМетоды  

// Получает начало конец действия коммерческого учета.
// Устаревшая.
// Параметры:
//  Организация			-	СправочникСсылка.энргЗоныОтвественности.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  Дата				-	Дата.
//  СтрокаТУ			-	Объект.ТочкиУчета.
//  МКД					-	СправочникСсылка.энргСтроения.
//  Договор				-	СправочникСсылка.энргДоговорыКонтрагентов.
//  ОбъектРасчета		-	СправочникСсылка.бестОбъектыРасчета.
//
Процедура ПолучитьНачалоКонецДействияКоммерческогоУчета(Организация, Район, Дата, СтрокаТУ, МКД = Неопределено, Договор = Неопределено, ОбъектРасчета = Неопределено) Экспорт
	Если ЗначениеЗаполнено(МКД) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргДопускПриборовУчетаККоммерческомуУчетуМКДСрезПоследних.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
		|	энргДопускПриборовУчетаККоммерческомуУчетуМКДСрезПоследних.КонецПериодаКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета
		|ИЗ
		|	РегистрСведений.энргДопускПриборовУчетаККоммерческомуУчетуМКД.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ТочкаУчета = &ТочкаУчета
		|				И ПриборУчета = &ПриборУчета
		|				И МКД = &МКД) КАК энргДопускПриборовУчетаККоммерческомуУчетуМКДСрезПоследних";
		
		Запрос.УстановитьПараметр("Дата", Дата);
		Запрос.УстановитьПараметр("МКД", МКД);
		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.УстановитьПараметр("ПриборУчета", СтрокаТУ.ПриборУчета);
		Запрос.УстановитьПараметр("Район", Район);
		Запрос.УстановитьПараметр("ТочкаУчета", СтрокаТУ.ТочкаУчета);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтрокаТУ.НачалоДействияКоммерскогоУчета = ВыборкаДетальныеЗаписи.НачалоДействияКоммерскогоУчета;
			СтрокаТУ.КонецПериодаКоммерскогоУчета = ВыборкаДетальныеЗаписи.КонецПериодаКоммерскогоУчета;
		КонецЦикла;
		
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестДопускПриборовУчетаККоммерческомуУчетуСрезПоследних.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
		|	бестДопускПриборовУчетаККоммерческомуУчетуСрезПоследних.КонецПериодаКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета
		|ИЗ
		|	РегистрСведений.бестДопускПриборовУчетаККоммерческомуУчету.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ТочкаУчета = &ТочкаУчета
		|				И ПриборУчета = &ПриборУчета
		|				И ОбъектРасчета = &ОбъектРасчета) КАК бестДопускПриборовУчетаККоммерческомуУчетуСрезПоследних";
		
		Запрос.УстановитьПараметр("Дата", Дата);
		Запрос.УстановитьПараметр("ОбъектРасчета", ОбъектРасчета);
		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.УстановитьПараметр("ПриборУчета", СтрокаТУ.ПриборУчета);
		Запрос.УстановитьПараметр("Район", Район);
		Запрос.УстановитьПараметр("ТочкаУчета", СтрокаТУ.ТочкаУчета);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтрокаТУ.НачалоДействияКоммерскогоУчета = ВыборкаДетальныеЗаписи.НачалоДействияКоммерскогоУчета;
			СтрокаТУ.КонецДействияКоммерскогоУчета = ВыборкаДетальныеЗаписи.КонецПериодаКоммерскогоУчета;
		КонецЦикла;
		
	КонецЕсли;
КонецПроцедуры

// Получает бест способ начисления норматива.
// Устаревшая.
// Параметры:
//  Организация		-	СправочникСсылка.энргЗоныОтвественности.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  Дата			-	Дата.
//  СтрокаТУ		-	Объект.ТочкиУчета.
//  ОбъектРасчета	-	СправочникСсылка.бестОбъектыРасчета.
//
Процедура ПолучитьбестСпособНачисленияНорматива(Организация, Район, Дата, СтрокаТУ, ОбъектРасчета) Экспорт	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестСпособНачисленияНормативаНПСрезПоследних.СпособРасчетаНорматива КАК СпособРасчетаНорматива
	|ИЗ
	|	РегистрСведений.бестСпособНачисленияНормативаНП.СрезПоследних(
	|			&Дата,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТочкаУчета = &ТочкаУчета
	|				И Услуга = &Услуга
	|				И ОбъектРасчета = &ОбъектРасчета) КАК бестСпособНачисленияНормативаНПСрезПоследних";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("ОбъектРасчета", ОбъектРасчета);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ТочкаУчета", СтрокаТУ.ТочкаУчета);
	Запрос.УстановитьПараметр("Услуга", СтрокаТУ.Услуга);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтрокаТУ.СпособРасчетаНорматива = ВыборкаДетальныеЗаписи.СпособРасчетаНорматива;
	КонецЦикла;
	
КонецПроцедуры

// Получает действующие приборы учета по договору для узлов.
// Устаревшая.
// Параметры:
//  Период				-	Дата.
//  Организация			-	СправочникСсылка.энргЗоныОтвественности.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  ПериодНачисления	-	Дата.
//  Договор				-	СправочникСсылка.энргДоговорыКонтрагентов.
//  ОбъектРасчета		-	СправочникСсылка.бестОбъектыРасчета.
//  ТочкаУчета			-	СправочникСсылка.энргТочкиУчета.
//  МКД					-	СправочникСсылка.энргСтроения.
// 
// Возвращаемое значение:
//  Массив	-	массив с пакетами результата запроса.
//
Функция ДействующиеПриборыУчетаПоДоговоруДляУзлов(Период,Организация,Район,ПериодНачисления, Договор = Неопределено, ОбъектРасчета = Неопределено, ТочкаУчета = Неопределено, МКД = Неопределено) Экспорт 
	
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления);
	
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП;
	
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Период);
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("ПериодНачисления",		ПериодНачисления);
	Запрос.УстановитьПараметр("НачалоПериода",			НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("КонецПериода",			КонецПериодаРасчета);
	Запрос.УстановитьПараметр("Договор",				Договор);
	Запрос.УстановитьПараметр("ОбъектРасчета",			ОбъектРасчета);
	Запрос.УстановитьПараметр("ТочкаУчета",				ТочкаУчета);
	Запрос.УстановитьПараметр("МКД",					МКД);
	Запрос.УстановитьПараметр("НачалоПериодаКонецДня",	НачалоПериодаРасчета + 59 + 59*60);
	
	
	
	Текст 	=
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Сезонность КАК Сезонность,
	|	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), ГОД, ВложенныйЗапрос.ГодНачало - 1), МЕСЯЦ, ВложенныйЗапрос.МесяцНачала - 1), ДЕНЬ, ВложенныйЗапрос.ДеньНачала - 1) КАК НачалоПериодаДействия,
	|	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), ГОД, ВложенныйЗапрос.ГодОкончания - 1), МЕСЯЦ, ВложенныйЗапрос.МесяцОкончания - 1), ДЕНЬ, ВложенныйЗапрос.ДеньОкончания - 1) КАК КонецПериодаДействия,
	|	энргВидыУслуг.Ссылка КАК Услуга
	|ПОМЕСТИТЬ ОтопительныйПериод
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргДлительностиПериодов.Сезонность КАК Сезонность,
	|		ДЕНЬ(энргДлительностиПериодов.НачалоПериода) КАК ДеньНачала,
	|		МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) КАК МесяцНачала,
	|		ДЕНЬ(энргДлительностиПериодов.КонецПериода) КАК ДеньОкончания,
	|		МЕСЯЦ(энргДлительностиПериодов.КонецПериода) КАК МесяцОкончания,
	|		ВЫБОР
	|			КОГДА МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) > МЕСЯЦ(энргДлительностиПериодов.КонецПериода)
	|					И МЕСЯЦ(энргДлительностиПериодов.КонецПериода) >= МЕСЯЦ(&Период)
	|				ТОГДА ГОД(&Период) - 1
	|			ИНАЧЕ ГОД(&Период)
	|		КОНЕЦ КАК ГодНачало,
	|		ВЫБОР
	|			КОГДА МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) > МЕСЯЦ(энргДлительностиПериодов.КонецПериода)
	|					И МЕСЯЦ(энргДлительностиПериодов.КонецПериода) >= МЕСЯЦ(&Период)
	|				ТОГДА ГОД(&Период)
	|			ИНАЧЕ ГОД(&Период) + 1
	|		КОНЕЦ КАК ГодОкончания
	|	ИЗ
	|		РегистрСведений.энргДлительностиПериодов.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район) КАК энргДлительностиПериодов) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО ВложенныйЗапрос.Сезонность = энргВидыУслуг.Сезонность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестДоговорыТочекУчетаСрезПоследних.Организация КАК Организация,
	|	бестДоговорыТочекУчетаСрезПоследних.Район КАК Район,
	|	бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестДоговорыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестДоговорыТочекУчетаСрезПоследних.Услуга КАК Услуга,
	|	бестДоговорыТочекУчетаСрезПоследних.Договор КАК Договор
	|ПОМЕСТИТЬ ВТ_Отбор
	|ИЗ
	|	РегистрСведений.бестДоговорыТочекУчета.СрезПоследних(
	|			&КонецПериода,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета = &ТочкаУчета) КАК бестДоговорыТочекУчетаСрезПоследних
	|ГДЕ
	|	бестДоговорыТочекУчетаСрезПоследних.Договор = &Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестАктивностьТочекУчетаНПСрезПоследних.Период КАК Период
	|ПОМЕСТИТЬ АктивныеТочкиУчетаОбъекта
	|ИЗ
	|	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
	|			&НачалоПериода,
	|			(Организация, Район, ОбъектРасчета, ТочкаУчета) В
	|				(ВЫБРАТЬ
	|					ВТ.Организация,
	|					ВТ.Район,
	|					ВТ.ОбъектРасчета,
	|					ВТ.ТочкаУчета
	|				ИЗ
	|					ВТ_Отбор КАК ВТ)) КАК бестАктивностьТочекУчетаНПСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ПО бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета = бестОбъектыРасчета.Ссылка
	|ГДЕ
	|	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|	И бестОбъектыРасчета.МКД = &МКД
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бестАктивностьТочекУчетаНП.ТочкаУчета,
	|	бестАктивностьТочекУчетаНП.ОбъектРасчета,
	|	бестАктивностьТочекУчетаНП.Период
	|ИЗ
	|	РегистрСведений.бестАктивностьТочекУчетаНП КАК бестАктивностьТочекУчетаНП
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ПО бестАктивностьТочекУчетаНП.ОбъектРасчета = бестОбъектыРасчета.Ссылка
	|ГДЕ
	|	бестАктивностьТочекУчетаНП.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|	И бестАктивностьТочекУчетаНП.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И бестОбъектыРасчета.МКД = &МКД
	|	И (бестАктивностьТочекУчетаНП.Организация, бестАктивностьТочекУчетаНП.Район, бестАктивностьТочекУчетаНП.ОбъектРасчета, бестАктивностьТочекУчетаНП.ТочкаУчета) В
	|			(ВЫБРАТЬ
	|				ВТ.Организация,
	|				ВТ.Район,
	|				ВТ.ОбъектРасчета,
	|				ВТ.ТочкаУчета
	|			ИЗ
	|				ВТ_Отбор КАК ВТ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестАктивностьТочекУчетаНП.ТочкаУчета КАК ТочкаУчета,
	|	бестАктивностьТочекУчетаНП.ОбъектРасчета КАК ОбъектРасчета,
	|	бестАктивностьТочекУчетаНП.Период КАК Период,
	|	бестАктивностьТочекУчетаНП.Состояние КАК Состояние
	|ПОМЕСТИТЬ СостояниеТочкиУчетаТекПериод
	|ИЗ
	|	РегистрСведений.бестАктивностьТочекУчетаНП КАК бестАктивностьТочекУчетаНП
