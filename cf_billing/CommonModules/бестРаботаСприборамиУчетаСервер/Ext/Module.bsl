	|	Вложенныйзапрос.ОбъектРасчета,
	|	Вложенныйзапрос.ТочкаУчета,
	|	Вложенныйзапрос.Шкала";
	
	
	Если НЕ ЗначениеЗаполнено(МКД) Тогда
		Текст = СтрЗаменить(Текст, "бестОбъектыРасчета.МКД = &МКД", "ИСТИНА");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Контролер) Тогда
		Текст = СтрЗаменить(Текст, "бестОбъектыРасчета.Контролер = &Контролер", "ИСТИНА");
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Договор) Тогда
		Текст = СтрЗаменить(Текст, "бестДоговорыТочекУчетаСрезПоследних.Договор = &Договор", "ИСТИНА");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ОбъектРасчета) Тогда
		Текст = СтрЗаменить(Текст, "ОбъектРасчета = &ОбъектРасчета", "ИСТИНА");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТочкаУчета) Тогда
		Текст = СтрЗаменить(Текст, "ТочкаУчета = &ТочкаУчета", "ИСТИНА");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Услуга) Тогда
		Текст = СтрЗаменить(Текст, "УслугиТочекУчета.Услуга = &Услуга", "ИСТИНА");
	КонецЕсли;
	
	Запрос.Текст 	= Текст;
	
	Результат  = Запрос.Выполнить();
	
	Возврат Результат;
	
КонецФункции

// Записывает показания результат запроса.
// Устаревшая, проведение осуществлять через ОМ бестПроведениеСерверНП.
// Параметры:
//  РезультатЗапроса	-	РезультатЗапроса.
//  Движения			-	Движения.
//
Процедура ЗаписатьПоказанияРезультатЗапроса(РезультатЗапроса,Движения) Экспорт 
	
	Набор  								= Движения["бестПоказанияПриборовУчетаНП"];
	Выборка 							= РезультатЗапроса.выбрать();
	
	ТекДоговор  						= Неопределено;
	ТекПриборУчета 						= Неопределено;
	ТекШкала							= Неопределено;
	ТекТарифнаяЗона 					= Неопределено;
	ТекРазделитель 						= 0;
	
	Пока Выборка.следующий() цикл
		Если ТекПриборУчета = Выборка.ПриборУчета и ТекШкала = Выборка.Шкала и ТекТарифнаяЗона = Выборка.ТарифнаяЗона тогда
			ТекРазделитель 				= ТекРазделитель + 1;
		иначе
			ТекРазделитель 				= 0;
		КонецЕсли;	
		Запись  						= Набор.добавить();
		ЗаполнитьЗначенияСвойств(Запись,Выборка);		
		Запись.Разделитель 				= ТекРазделитель;
		
		ТекПриборУчета 					= Выборка.ПриборУчета;
		ТекШкала 						= Выборка.Шкала;
		ТекТарифнаяЗона 				= Выборка.ТарифнаяЗона;
	КонецЦикла;
	
КонецПроцедуры

// Получает показания результата запроса.
// Устаревша, используется только для документа бестПроведениеСерверНП.
// Параметры:
//  Период			-	Дата.
//  Организация		-	СправочникСсылка.энргЗоныОтвественности.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  ОбъектРасчета	-	СправочникСсылка.бестОбъектыРасчета.
//  ТочкаУчета		-	СправочникСсылка.энргТочкиУчета.
// 
// Возвращаемое значение:
// 	СправочникСсылка.энргПриборыУчетаАбонента	-	прибор учета.
//
Функция ПолучитьПриборУчетаПоТочке(Период, Организация = Неопределено, Район = Неопределено, ОбъектРасчета = Неопределено, ТочкаУчета) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестПриборыТочекУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ИЗ
	|	РегистрСведений.бестПриборыТочекУчетаНП.СрезПоследних(
	|			&МоментВремени,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета
	|				И ТочкаУчета = &ТочкаУчета) КАК бестПриборыТочекУчетаНПСрезПоследних";
	
	Запрос.УстановитьПараметр("МоментВремени", Период);
	Если ЗначениеЗаполнено(Организация) Тогда
		Запрос.УстановитьПараметр("Организация", Организация);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Организация = &Организация", "Истина");
	КонецЕсли;
	Если ЗначениеЗаполнено(Район) Тогда
		Запрос.УстановитьПараметр("Район", Район);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Район = &Район", "Истина");
	КонецЕсли;
	Если ЗначениеЗаполнено(ОбъектРасчета) Тогда
		Запрос.УстановитьПараметр("ОбъектРасчета", ОбъектРасчета);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ОбъектРасчета = &ОбъектРасчета", "Истина");
	КонецЕсли;

	Запрос.УстановитьПараметр("ТочкаУчета", ТочкаУчета);
	
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Возврат Результат.ПриборУчета;
	Иначе
		Справочники.энргПриборыУчетаАбонента.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#КонецОбласти