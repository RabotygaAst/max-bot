
#Область СлужебныйПрограммныйИнтерфейс

Процедура энргВыполнениеНачислений() Экспорт
	
	ТекВремя = ТекущаяУниверсальнаяДата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргРасписаниеНачислений.Организация КАК Организация,
	|	энргРасписаниеНачислений.Район КАК Район,
	|	энргРасписаниеНачислений.ПериодНачисления КАК ПериодНачисления,
	|	энргРасписаниеНачислений.ИсключаяОтдельностоящие КАК ИсключаяОтдельностоящие,
	|	энргРасписаниеНачислений.СбрасыватьВзаиморасчеты КАК СбрасыватьВзаиморасчеты,
	|	энргРасписаниеНачислений.СбрасыватьПоказания КАК СбрасыватьПоказания
	|ИЗ
	|	РегистрСведений.энргРасписаниеНачислений КАК энргРасписаниеНачислений
	|
	|УПОРЯДОЧИТЬ ПО
	|	энргРасписаниеНачислений.ПорядокЗапуска";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	МенеджерРС = РегистрыСведений.энргРасписаниеНачислений;
	Пока Выборка.Следующий() Цикл
		
		ПараметрыОтборов = НовыеПараметрыОпераций();		
		ПараметрыОтборов.Организация				= Выборка.Организация;
		ПараметрыОтборов.Район						= Выборка.Район;	
		ПараметрыОтборов.ПериодНачисления			= НачалоМесяца(Выборка.ПериодНачисления);			
		ПараметрыОтборов.ПериодНачисленияТекущий	= ПараметрыОтборов.ПериодНачисления;
		ПараметрыОтборов.ИсключаяОтдельностоящие	= Выборка.ИсключаяОтдельностоящие;
		ПараметрыОтборов.СбрасыватьВзаиморасчеты	= Выборка.СбрасыватьВзаиморасчеты;
		ПараметрыОтборов.СбрасыватьПоказания		= Выборка.СбрасыватьПоказания;
		
		ВыполняемыеОперации = Новый Структура;
		ПолучитьСписокОпераций(ВыполняемыеОперации);		
		ИменаМодулей = ЗаполнитьИменаМодулей();
		
		// запускаем начисления
		энргВыполнитьНачисления(ПараметрыОтборов, ВыполняемыеОперации, ИменаМодулей);		
		
		Если ТранзакцияАктивна() Тогда
			//Прервать;
			ОтменитьТранзакцию();
			Продолжить;
		КонецЕсли;
		
		ОчиститьОчередьНачислений(МенеджерРС, Выборка);
		
	КонецЦикла;  	
		
КонецПроцедуры

Процедура энргВыполнитьНачисления(ПараметрыОтборов, ВыполняемыеОперации, ИменаМодулей) Экспорт
	
	Результат = Новый Массив;	
	ПрефиксСобытия = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОтборов, "ПрефиксСобытия", ПрефиксСобытияПоУмолчанию());
	ИндексТекОперации = 0;
	
	Контекст = Новый Структура;
	Контекст.Вставить("ПредставлениеОпераций", ПредставлениеОпераций());
	Контекст.Вставить("ИдентификаторЗадания", "" + Новый УникальныйИдентификатор);
	Контекст.Вставить("ПрефиксСобытия", ПрефиксСобытия);
	Контекст.Вставить("ТранзакцияАктивна", Ложь);
	Контекст.Вставить("ПорядокОперации", ИндексТекОперации);
	Контекст.Вставить("Пользователь", Пользователи.ТекущийПользователь());
	Контекст.Вставить("ФиксаторРезультатаВыполнения", РегистрыСведений.энргРезультатВыполненияОперацийНачислений);
	
	
	Для Каждого ТекущаяОперация из ВыполняемыеОперации Цикл 
		
		ИмяОперации = ВыполняемыеОперации["Операция" + ИндексТекОперации];
		ВыполнитьОперацию(ИмяОперации, ПараметрыОтборов, ИменаМодулей, Результат, Контекст);
		ИндексТекОперации = ИндексТекОперации + 1;
		Контекст.ПорядокОперации = ИндексТекОперации;
		
		Если НЕ ПараметрыОтборов.АдресРезультата = Неопределено Тогда 
			Попытка
				
				ПоместитьВоВременноеХранилище(Результат, ПараметрыОтборов.АдресРезультата);	
				
			Исключение
				Инфо = ИнформацияОбОшибке();
			КонецПопытки;
		КонецЕсли;
		
		Если Контекст.ТранзакцияАктивна Тогда
			Прервать;
		КонецЕсли;
				
	КонецЦикла;		
	
КонецПроцедуры

Функция НовыеПараметрыОпераций() Экспорт 
		
	Результат = Новый Структура;
	Результат.Вставить("Организация",			 	Неопределено);
	Результат.Вставить("ПериодНачисления",		 	Неопределено);
	Результат.Вставить("ПериодНачисленияТекущий",	Неопределено);
	Результат.Вставить("ТекРайон",				 	Неопределено);
	Результат.Вставить("Район",					 	Неопределено);
	Результат.Вставить("Абонент",				 	Неопределено);
	Результат.Вставить("ОтборПоДому",			 	Ложь);
	Результат.Вставить("ИсключаяОтдельностоящие", 	Ложь);
	Результат.Вставить("СбрасыватьСостояниеПоследовательности", Истина);
	Результат.Вставить("Договор", 					Справочники.энргДоговорыКонтрагентов.ПустаяСсылка());
	Результат.Вставить("АдресРезультата", 			Неопределено);
	Результат.Вставить("Дом", 						Справочники.энргСтроения.ПустаяСсылка());
	Результат.Вставить("ПрефиксСобытия",			ПрефиксСобытияПоУмолчанию());
	Результат.Вставить("СписокМКД",					Неопределено);
	Результат.Вставить("МассивКлючейПомещений",		Неопределено);
	Результат.Вставить("МассивАбонентов",			Неопределено);
	Результат.Вставить("ФинальноеНачисление",		Ложь);
	Результат.Вставить("СбрасыватьВзаиморасчеты",	Ложь);
	Результат.Вставить("СбрасыватьПоказания",		Ложь);
	
	Возврат Результат;
	
КонецФункции

Функция ПрефиксСобытияПоУмолчанию() Экспорт 
		
	Возврат "Фоновое начисление";
	
КонецФункции


#Область ОписаниеОпераций

Функция Операции(ТолькоОперацииНП = Ложь) Экспорт
	
	Операции 	= Новый Структура;
	
	мОперации 	= Новый Массив;
	
	#Область РегламетныеОперации
	
	#Область МногоквартирныеДома
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("ЗаполнениеНачальныхОстатковМКД");
		мОперации.Добавить("ВосстановлениеПоследовательностиДокументовМКД");
		мОперации.Добавить("ВосстановлениеПоследовательностиПоказанийМКД");
	КонецЕсли;
	#КонецОбласти
	
	#Область ФизическиеЛица
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("ЗаполнениеНачальныхОстатков");
		мОперации.Добавить("ВосстановлениеПоследовательностиДокументов");
		мОперации.Добавить("ВосстановлениеПоследовательностиПоказанийПУ");
	КонецЕсли;
	#КонецОбласти
	
	#Область НежилыеПомещения
	мОперации.Добавить("ЗаполнениеНачальныхОстатковНП");
	мОперации.Добавить("ВосстановлениеПоследовательностиДокументовНП"); 
	мОперации.Добавить("ВосстановлениеПоследовательностиПоказанийПУНП");
	#КонецОбласти
	
	#КонецОбласти
	
	#Область РассчетНачислений
	
	#Область МногоквартирныеДома
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("ПерерасчетСреднихНачисленийМКД");
		мОперации.Добавить("РасчетНачисленийНаМКД");
		мОперации.Добавить("КорректировкаПотребленияСезонныхУслугМКД");
	КонецЕсли;
	#КонецОбласти
	
	#Область ФизическиеЛица
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("ИндивидуальныеНачисления");	
		мОперации.Добавить("ПерерасчетСреднихНачислений");
		мОперации.Добавить("УстановкаЗначенийДифференцированныхТарифов");
		мОперации.Добавить("ПерерасчетПриУстановкеПрибораУчетаСезонныхУслуг");
		мОперации.Добавить("НачислениеПроцентовРассрочки");
		мОперации.Добавить("РасчетЛьгот");
	КонецЕсли;
	#КонецОбласти
	
	#Область НежилыеПомещения
	мОперации.Добавить("ИндивидуальныеНачисленияНП");
	мОперации.Добавить("НачисленияПоДолевымСхемам");
	мОперации.Добавить("ПерерасчетСреднихНачисленийНП");
	#КонецОбласти
	
	#КонецОбласти
	
	#Область РаспределениеИКорректировка
	Если НЕ ТолькоОперацииНП Тогда
		мОперации.Добавить("РаспределениеОбъемаМКД");
		мОперации.Добавить("КорректировкаПотребленияСезонныхУслуг");
		мОперации.Добавить("ВосстановлениеПоследовательностиВзаиморасчетов");
		мОперации.Добавить("НачислениеПени");
		
	КонецЕсли;
	мОперации.Добавить("НачисленияПоСхемамСтруктурыСети");
	мОперации.Добавить("ДополнительныеНачисленияЮЛ");
	мОперации.Добавить("ВосстановлениеПоследовательностиВзаиморасчетовНП");
	#КонецОбласти
	
	#Область ПрочииОперации
	мОперации.Добавить("ЗакрытиеПериодаНачисления");
	#КонецОбласти 	
	
	Для Сч = 0 По мОперации.ВГраница() Цикл
		Операции.Вставить("Операция" + Формат("" + Сч,"ЧРГ=' '; ЧГ=0"),мОперации[Сч]);
	КонецЦикла; 	
	
	Возврат Операции;
КонецФункции

