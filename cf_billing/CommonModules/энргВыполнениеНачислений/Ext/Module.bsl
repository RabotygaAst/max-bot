КонецФункции

Функция ЗаполнитьИменаМодулей() Экспорт
	
	ИменаМодулей = Новый Структура;
	
	ИменаМодулей.Вставить("ЗаполнениеНачальныхОстатковМКД",								"энргРаботаСПоследовательностями.ОтложенныеДвиженияДокументовНачисленияМКД");
	ИменаМодулей.Вставить("ВосстановлениеПоследовательностиДокументовМКД",				"энргРаботаСПоследовательностями.ВосстановитьПоследовательностьСтабильныеПериодыМКД");
	ИменаМодулей.Вставить("ВосстановлениеПоследовательностиПоказанийМКД",				"энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоказанияПУМКД");
	
	ИменаМодулей.Вставить("ЗаполнениеНачальныхОстатков",								"энргРаботаСПоследовательностями.ОтложенныеДвиженияДокументовНачисления");
	ИменаМодулей.Вставить("ВосстановлениеПоследовательностиДокументов",					"энргРаботаСПоследовательностями.ВосстановитьПоследовательностьСтабильныеПериоды");
	ИменаМодулей.Вставить("ВосстановлениеПоследовательностиПоказанийПУ",				"энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоказанияПУ");
	
	ИменаМодулей.Вставить("ЗаполнениеНачальныхОстатковНП",								"бестРаботаСПоследовательностямиНП.ОтложенныеДвиженияДокументовНачисленияНП");
	ИменаМодулей.Вставить("ВосстановлениеПоследовательностиДокументовНП",				"бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьСтабильныеПериодыНП");
	ИменаМодулей.Вставить("ВосстановлениеПоследовательностиПоказанийПУНП",				"бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьПоказанияПУНП");
	
	ИменаМодулей.Вставить("ПерерасчетСреднихНачисленийМКД",								"энргНачисления.СнятьСредниеНачисленияМКД");
	ИменаМодулей.Вставить("РасчетНачисленийНаМКД",										"энргНачисления.НачислениеНаОДН");
	ИменаМодулей.Вставить("КорректировкаПотребленияСезонныхУслугМКД",					"энргНачисления.СкорректироватьПотреблениеСезонныхУслугМКД");
    
	ИменаМодулей.Вставить("ИндивидуальныеНачисления",									"энргНачисления.Начислить");
	ИменаМодулей.Вставить("ПерерасчетСреднихНачислений",								"энргНачисления.СнятьСредниеНачисления");
	ИменаМодулей.Вставить("УстановкаЗначенийДифференцированныхТарифов",					"энргНачисления.УстановитьЗначенияДифференцированныхТарифов");
	ИменаМодулей.Вставить("ПерерасчетПриУстановкеПрибораУчетаСезонныхУслуг",			"энргНачисления.ИзменитьПризнакСостояниеПрибора");
	ИменаМодулей.Вставить("НачислениеПроцентовРассрочки",								"энргНачисления.НачислениеПоРассрочке");
	ИменаМодулей.Вставить("РасчетЛьгот",												"энргНачисления.НачислитьЛьготы");
	
	ИменаМодулей.Вставить("ИндивидуальныеНачисленияНП",									"бестНачисленияНП.Начислить");
	ИменаМодулей.Вставить("ПерерасчетСреднихНачисленийНП",								"бестНачисленияНП.СнятьСредниеНачисленияНП");
	ИменаМодулей.Вставить("НачисленияПоДолевымСхемам",   								"бестНачисленияНП.НачисленияПоДолевымСхемам"); 
	
	ИменаМодулей.Вставить("РаспределениеОбъемаМКД",										"энргНачисления.РаспредениеОбъемаМКД");
	ИменаМодулей.Вставить("КорректировкаПотребленияСезонныхУслуг",						"энргНачисления.СкорректироватьПотреблениеСезонныхУслуг");
	ИменаМодулей.Вставить("НачисленияПоСхемамСтруктурыСети",							"бестНачисленияНП.НачисленияПоСхемамСтруктурыСети");
	ИменаМодулей.Вставить("ДополнительныеНачисленияЮЛ",									"бестНачисленияНП.ДополнительныеНачисленияЮЛ");
	ИменаМодулей.Вставить("ВосстановлениеПоследовательностиВзаиморасчетов",				"энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты");
	ИменаМодулей.Вставить("ВосстановлениеПоследовательностиВзаиморасчетовНП",			"бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьВзаиморасчетыНП");
	ИменаМодулей.Вставить("НачислениеПени",												"энргНачисления.НачислитьПеню");
	
	ИменаМодулей.Вставить("ЗакрытиеПериодаНачисления",									"энргНачисления.ЗакрытьПериодДляРедактирования");
	
	Возврат ИменаМодулей;
КонецФункции
	
#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ВыполнениеОпераций

Процедура ВыполнитьОперацию(ИмяОперации, ПараметрыОтборов, ИменаМодулей, РезультатВыполнения, Контекст)
	
	ПропускатьЗаписьРезультатВФиксатор = ИмяОперации = "ЗакрытиеПериодаНачисления";
	СтрокаЗаписиРезультата = Контекст.ФиксаторРезультатаВыполнения.ПолучитьОписаниеОбъекта();
	ЗаполнитьСтрокуРезультатаОперации(СтрокаЗаписиРезультата, ПараметрыОтборов, Контекст, ИмяОперации);	
	
	РезультатВыполненияОперации = РезультатВыполненияОперации();
	РезультатВыполненияОперации.ЭлементОшибок = ИмяОперации;
	
	ИмяМодуля = ИменаМодулей[ИмяОперации];
	СтрокаМодуля = ИмяМодуля + "(ПараметрыОпераций)"; 	
	ПараметрыОпераций = ПараметрыОперацииПоЗаданию(ПараметрыОтборов);
	
	ПредставлениеРайона = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыОпераций.Район, "Наименование");
	ПредставлениеОперации = "" + Контекст.ПредставлениеОпераций[ИмяОперации] + " по району: " + ПредставлениеРайона + " за " + Формат(ПараметрыОпераций.ПериодНачисления, "ДФ='ММММ гггг'") + "";	
	Если ПараметрыОтборов.ОтборПоДому тогда
		
		ЭтоМКД = ЗначениеЗаполнено(ПараметрыОтборов.Дом);
		ПредставлениеОперации = ПредставлениеОперации + " отбор по дому: " + ?(ЭтоМКД, ПараметрыОтборов.Дом, "Частный сектор");
		
		Если ЭтоМКД Тогда 
			СтрокаЗаписиРезультата.МКД = ПараметрыОтборов.Дом;			
		Иначе 
			СтрокаЗаписиРезультата.ЧастныйСектор = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(1, ПредставлениеОперации);
	
	СтрокаЗаписиРезультата.Строение = ПараметрыОпераций.Строение;
	СтрокаЗаписиРезультата.ПредставлениеОперации = Контекст.ПредставлениеОпераций[ИмяОперации];
	СтрокаЗаписиРезультата.ПредставлениеОперацииСОтборами = ПредставлениеОперации;
	ИмяСобытия = Контекст.ПрефиксСобытия + "." + ПредставлениеРайона + ".Начало операции." + ИмяОперации;
	ЗаписьЖурналаРегистрации(
		ИмяСобытия,
		УровеньЖурналаРегистрации.Информация,,
		Контекст.ИдентификаторЗадания,
		"" + ПредставлениеОперации);		
	
		
	Если НЕ ПропускатьЗаписьРезультатВФиксатор Тогда 
		ЗаписатьНачалоОперации(Контекст, СтрокаЗаписиРезультата);	
	КонецЕсли;
		
	Попытка
		Если ИмяОперации = "ЗаполнениеНачальныхОстатковМКД" Тогда
			энргРаботаСПоследовательностями.ОтложенныеДвиженияДокументовНачисленияМКД(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиДокументовМКД" Тогда
			энргРаботаСПоследовательностями.ВосстановитьПоследовательностьСтабильныеПериодыМКД(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиПоказанийМКД" Тогда
			энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоказанияПУМКД(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ЗаполнениеНачальныхОстатков" Тогда
			энргРаботаСПоследовательностями.ОтложенныеДвиженияДокументовНачисления(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиДокументов" Тогда
			энргРаботаСПоследовательностями.ВосстановитьПоследовательностьСтабильныеПериоды(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиПоказанийПУ" Тогда
			
			Если ПараметрыОтборов.СбрасыватьПоказания Тогда
				СброситьПоследовательностьПоказаний(ПараметрыОтборов);
			КонецЕсли;
			
			энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоказанияПУ(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ПерерасчетСреднихНачисленийМКД" Тогда
			энргНачисления.СнятьСредниеНачисленияМКД(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "РасчетНачисленийНаМКД" Тогда
			энргНачисления.НачислениеНаОДН(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ПерерасчетСреднихНачислений" Тогда
			энргНачисления.СнятьСредниеНачисления(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ИндивидуальныеНачисления" Тогда
			энргНачисления.Начислить(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "РаспределениеОбъемаМКД" Тогда
			энргНачисления.РаспредениеОбъемаМКД(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "НачислениеПроцентовРассрочки" Тогда
			энргНачисления.НачислениеПоРассрочке(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ПерерасчетПриУстановкеПрибораУчетаСезонныхУслуг" Тогда
			энргНачисления.ИзменитьПризнакСостояниеПрибора(ПараметрыОпераций);				
		ИначеЕсли ИмяОперации = "КорректировкаПотребленияСезонныхУслуг" Тогда
			энргНачисления.СкорректироватьПотреблениеСезонныхУслуг(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "КорректировкаПотребленияСезонныхУслугМКД" Тогда
			энргНачисления.СкорректироватьПотреблениеСезонныхУслугМКД(ПараметрыОпераций);	
		ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиВзаиморасчетов" Тогда
			
			Если ПараметрыОтборов.СбрасыватьВзаиморасчеты Тогда
				СброситьВзаиморасчеты(ПараметрыОтборов);
			КонецЕсли;

			энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "НачислениеПени" Тогда
			энргНачисления.НачислитьПеню(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ЗакрытиеПериодаНачисления" Тогда
			энргНачисления.ЗакрытьПериодДляРедактирования(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ЗаполнениеНачальныхОстатковНП" Тогда
			бестРаботаСПоследовательностямиНП.ОтложенныеДвиженияДокументовНачисленияНП(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиДокументовНП" Тогда
			бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьСтабильныеПериодыНП(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиПоказанийПУНП" Тогда
			бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьПоказанияПУНП(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ИндивидуальныеНачисленияНП" Тогда
			бестНачисленияНП.Начислить(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "РасчетЛьгот" Тогда
			энргНачисления.НачислитьЛьготы(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "НачисленияПоДолевымСхемам" Тогда
			бестНачисленияНП.НачисленияПоДолевымСхемам(ПараметрыОпераций);	
			//энргНачисления.НачислитьПоФормуламРасчета(ПараметрыОпераций.Организация,ПараметрыОпераций.ПериодНачисления,ПараметрыОпераций.Район);	
		ИначеЕсли ИмяОперации = "ПерерасчетСреднихНачисленийНП" Тогда
			бестНачисленияНП.СнятьСредниеНачисленияНП(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "НачисленияПоСхемамСтруктурыСети" Тогда
			бестНачисленияНП.НачисленияПоСхемамСтруктурыСети(ПараметрыОпераций);	
		ИначеЕсли ИмяОперации = "ВосстановлениеПоследовательностиВзаиморасчетовНП" Тогда
			бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьВзаиморасчетыНП(ПараметрыОпераций);
		ИначеЕсли ИмяОперации = "ДополнительныеНачисленияЮЛ" Тогда
			бестНачисленияНП.ДополнительныеНачисленияЮЛ(ПараметрыОпераций);	
		Иначе
			Выполнить (СтрокаМодуля);
		КонецЕсли;
		
		
	Исключение
		
		ОписаниеОшибки = ИнформацияОбОшибке();		
		
		РезультатВыполненияОперации.ЕстьОшибки 		= Истина;
		РезультатВыполненияОперации.Заголовок 		= "Есть ошибки";
		РезультатВыполненияОперации.Доступность 	= Истина;	
		
		РезультатВыполненияОперации.ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ОписаниеОшибки);		
		РезультатВыполненияОперации.Ошибки.Добавить(Новый Структура("Текст", ОписаниеОшибки.Описание + Символы.ПС + КраткоеПредставлениеОшибки(ОписаниеОшибки)));
		
		ОписаниеОшибки = РезультатВыполненияОперации.ОписаниеОшибки;
		ОписаниеОшибки.Вставить("ПериодНачисления", ПараметрыОтборов.ПериодНачисления);
		ОписаниеОшибки.Вставить("Ораганизация", 	ПараметрыОтборов.Организация);
		ОписаниеОшибки.Вставить("Район",			ПараметрыОтборов.Район);
		ОписаниеОшибки.Вставить("МКД",				Справочники.энргСтроения.ПустаяСсылка());
		Если ПараметрыОтборов.Свойство("Дом") тогда
			ОписаниеОшибки.МКД = ПараметрыОтборов.Дом;
		КонецЕсли;
		ОписаниеОшибки.Вставить("ОтборПоМКД",		ПараметрыОтборов.ОтборПоДому);
		ОписаниеОшибки.Вставить("Ошибки",			РезультатВыполненияОперации.Ошибки); 		
					
	КонецПопытки; 	
	
	РезультатВыполнения.Добавить(РезультатВыполненияОперации);
	ДлительныеОперации.СообщитьПрогресс(100, ПредставлениеОперации);
	
	ИмяСобытия = Контекст.ПрефиксСобытия + "." + ПредставлениеРайона + ".Завершение операции." + ИмяОперации;
	УровеньЖурналаЗавершенияОперации = УровеньЖурналаРегистрации.Информация;
	
	СтрокаЗаписиРезультата.ДатаЗавершения = ТекущаяДатаСеанса();
	СтрокаЗаписиРезультата.ВыполненаУспешно = Истина;
	Если РезультатВыполненияОперации.ЕстьОшибки Тогда 
		УровеньЖурналаЗавершенияОперации = УровеньЖурналаРегистрации.Ошибка;
		
		СтрокаЗаписиРезультата.ВыполненаУспешно = Ложь;
		СтрокаЗаписиРезультата.Ошибки = РезультатВыполненияОперации.ПодробноеПредставлениеОшибки;
	КонецЕсли;
		
	ЗаписьЖурналаРегистрации(
		ИмяСобытия,
		УровеньЖурналаЗавершенияОперации,,
		Контекст.ИдентификаторЗадания,
		"" + ПредставлениеОперации + Символы.ПС 
			+ "Результат: " 
			+ Символы.ПС + "ЕстьОшибки: " + РезультатВыполненияОперации.ЕстьОшибки
			+ Символы.ПС + "Причина: " + РезультатВыполненияОперации.ПодробноеПредставлениеОшибки);   	
			
			
	Если НЕ ПропускатьЗаписьРезультатВФиксатор Тогда
		ЗаписатьЗавершениеОперации(Контекст, СтрокаЗаписиРезультата);
	КонецЕсли;
	
	Если ТранзакцияАктивна() Тогда
		
		Контекст.ТранзакцияАктивна = Истина;
		ИмяСобытия = Контекст.ПрефиксСобытия + "." + ПредставлениеРайона + ".Активная транзакция." + ИмяОперации;
		ЗаписьЖурналаРегистрации(
			ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка,,
			Контекст.ИдентификаторЗадания,
			"Транзакция не завершилась"); 				
				
	КонецЕсли;		
	
КонецПроцедуры

Процедура СброситьВзаиморасчеты(ПараметрыОтборов) Экспорт
	Набор  = РегистрыСведений.энргВзаиморасчетыПоследовательность.СоздатьНаборЗаписей();
	Набор.Отбор.Организация.Установить(ПараметрыОтборов.Организация);
	Набор.Отбор.ПериодНачисления.Установить(ПараметрыОтборов.ПериодНачисления);
	Набор.Отбор.Район.Установить(ПараметрыОтборов.Район);
	Если ПараметрыОтборов.Свойство("Дом") И ЗначениеЗаполнено(ПараметрыОтборов.Дом) Или ПараметрыОтборов.Свойство("ОтборПоДому") И ПараметрыОтборов.ОтборПоДому ТОгда
		Набор.Отбор.МКД.Установить(ПараметрыОтборов.Дом);
	КонецЕсли;
	Если ЗначениеЗаполнено(ПараметрыОтборов.Абонент) ТОгда
		Набор.Отбор.Абонент.Установить(ПараметрыОтборов.Абонент);
	КонецЕсли;
	
	Набор.Прочитать();
	
	Для Каждого Строка Из Набор Цикл
		Если Строка.СостояниеПроведения = Перечисления.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности Тогда
			Строка.СостояниеПроведения = Перечисления.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности;
		КонецЕсли;
	КонецЦикла;
	
	Набор.Записать();
КонецПроцедуры

Процедура СброситьПоследовательностьПоказаний(ПараметрыОтборов) Экспорт
	Набор  = РегистрыСведений.энргПоказанияПУПоследовательность.СоздатьНаборЗаписей();
	Набор.Отбор.Организация.Установить(ПараметрыОтборов.Организация);
	Набор.Отбор.ПериодНачисления.Установить(ПараметрыОтборов.ПериодНачисления);
	Набор.Отбор.Район.Установить(ПараметрыОтборов.Район);
	Если ПараметрыОтборов.Свойство("Дом") И ЗначениеЗаполнено(ПараметрыОтборов.Дом)  Тогда 
		Набор.Отбор.Строение.Установить(ПараметрыОтборов.Дом);
	ИначеЕсли ПараметрыОтборов.Свойство("МКД") И ЗначениеЗаполнено(ПараметрыОтборов.МКД)  ТОгда
		Набор.Отбор.Строение.Установить(ПараметрыОтборов.МКД);
	КонецЕсли;
	
	Если ПараметрыОтборов.Свойство("Дом") И НЕ ЗначениеЗаполнено(ПараметрыОтборов.Дом) И ПараметрыОтборов.Свойство("ОтборПоДому") И ПараметрыОтборов.ОтборПоДому ТОгда
		Набор.Отбор.ЧастныйСектор.Установить(Истина);
	ИначеЕсли ПараметрыОтборов.Свойство("ЧастныйСектор") И ПараметрыОтборов.ЧастныйСектор = Истина ТОгда
		Набор.Отбор.ЧастныйСектор.Установить(Истина);
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ПараметрыОтборов.Абонент)ТОгда  
		Набор.Отбор.Строение.Установить(ПараметрыОтборов.Абонент.КлючПомещения.Строение);
		Набор.Отбор.Помещение.Установить(ПараметрыОтборов.Абонент.КлючПомещения.Помещение);
	КонецЕсли;
	
	Набор.Прочитать();
	
	Для Каждого Строка Из Набор Цикл
		Если Строка.СостояниеПроведения = Перечисления.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности Тогда
			Строка.СостояниеПроведения = Перечисления.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности;
		КонецЕсли;
	КонецЦикла;
	
	Набор.Записать();
КонецПроцедуры

Функция РезультатВыполненияОперации()
	
	Результат = Новый Структура;
	Результат.Вставить("ЕстьОшибки"		, Ложь);
	Результат.Вставить("Заголовок"		, "Нет Ошибок");
	Результат.Вставить("Доступность"	, Ложь);
	Результат.Вставить("ИмяОперации"	, "");	
	Результат.Вставить("ЭлементОшибок"	, "");
	Результат.Вставить("ПодробноеПредставлениеОшибки"	, "");
	Результат.Вставить("Ошибки"			, Новый Массив);
	Результат.Вставить("ОписаниеОшибки"	, Новый Структура);
	
	Возврат Результат
	
КонецФункции


Функция ПараметрыОперацииПоЗаданию(ПараметрыОтборов)
	
	ПараметрыОпераций   = Новый Структура;
	ПараметрыОпераций.Вставить("Организация",		ПараметрыОтборов.Организация);
	ПараметрыОпераций.Вставить("ПериодНачисления",	ПараметрыОтборов.ПериодНачисленияТекущий);
	
	Если ПараметрыОтборов.ТекРайон <> Неопределено Тогда
		ПараметрыОпераций.Вставить("Район",	ПараметрыОтборов.ТекРайон);
	Иначе 
		ПараметрыОпераций.Вставить("Район",	ПараметрыОтборов.Район);
	КонецЕсли;
	
	Если ПараметрыОтборов.ОтборПоДому И ЗначениеЗаполнено(ПараметрыОтборов.Дом) Тогда
		ПараметрыОпераций.Вставить("ЧастныйСектор",		Ложь);
	ИначеЕсли ПараметрыОтборов.ОтборПоДому Тогда
		ПараметрыОпераций.Вставить("ЧастныйСектор",		Истина);
	Иначе
		ПараметрыОпераций.Вставить("ЧастныйСектор",		Неопределено);
	КонецЕсли;
	
	//Если ИмяЗадания <> "ВосстановлениеПоследовательностиДокументовНП" тогда
	Если ПараметрыОтборов.ОтборПоДому тогда
		ПараметрыОпераций.Вставить("МКД"	, ПараметрыОтборов.Дом);
		ПараметрыОпераций.Вставить("МКД_НП"	, ?(ПараметрыОтборов.ИсключаяОтдельностоящие, ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка"), ПараметрыОтборов.Дом));
		
	иначе
		ПараметрыОпераций.Вставить("МКД",		Неопределено);
		ПараметрыОпераций.Вставить("МКД_НП",	Неопределено);
	КонецЕсли; 
	//КонецЕсли; 
	
	ПараметрыОпераций.Вставить("Строение",					ПараметрыОтборов.Дом);
	ПараметрыОпераций.Вставить("Помещение",					Неопределено);
	ПараметрыОпераций.Вставить("Абонент",					Неопределено);
	ПараметрыОпераций.Вставить("СписокМКД",					ПараметрыОтборов.СписокМКД);
	ПараметрыОпераций.Вставить("ИсключаяОтдельностоящие",	ПараметрыОтборов.ИсключаяОтдельностоящие);
	
	//Если ИмяЗадания = "ЗаполнениеНачальныхОстатков" тогда
	ПараметрыОпераций.Вставить("СбрасыватьСостояниеПоследовательности", ПараметрыОтборов.СбрасыватьСостояниеПоследовательности);
	//КонецЕсли; 	
	
	ПараметрыОпераций.Вставить("Абонент",					Неопределено);
	ПараметрыОпераций.Вставить("СписокМКД",					ПараметрыОтборов.СписокМКД);
	ПараметрыОпераций.Вставить("ИсключаяОтдельностоящие",	ПараметрыОтборов.ИсключаяОтдельностоящие);
	ПараметрыОпераций.Вставить("МассивКлючейПомещений",		ПараметрыОтборов.МассивКлючейПомещений);
	ПараметрыОпераций.Вставить("МассивАбонентов",			ПараметрыОтборов.МассивАбонентов);
	ПараметрыОпераций.Вставить("ФинальноеНачисление",		ПараметрыОтборов.ФинальноеНачисление);
	
	Если ЗначениеЗаполнено(ПараметрыОтборов.Договор) Тогда
		мОбъектыРасчета = ПолучитьМассивОбъектов(
			ПараметрыОтборов.Организация, 
			ПараметрыОтборов.Район, 
			ПараметрыОтборов.ПериодНачисленияТекущий, 
			ПараметрыОтборов.Договор);
		
		ПараметрыОпераций.Вставить("мОбъектыРасчета",	мОбъектыРасчета);
		ПараметрыОпераций.Вставить("Договор",			ПараметрыОтборов.Договор);
	Иначе
		ПараметрыОпераций.Вставить("мОбъектыРасчета",	Неопределено);
		ПараметрыОпераций.Вставить("Договор",			Неопределено);
	КонецЕсли;
	
	Возврат ПараметрыОпераций;
	
КонецФункции

Функция ПолучитьМассивОбъектов(Организация, Район, Период, Договор)
	
	МассивОбъектов = Неопределено;
	РезультатЗапроса = РегистрыСведений.бестДоговорыТочекУчета.ПолучитьДанныеДоговоров(Организация, Район, Период, Договор);
	ТЗ = РезультатЗапроса.Выгрузить();
	Если ТЗ.Количество() <> 0 Тогда
		ТЗ.Свернуть("ОбъектРасчета");
		МассивОбъектов = ТЗ.ВыгрузитьКолонку("ОбъектРасчета");
	КонецЕсли;
	Возврат МассивОбъектов;
	
КонецФункции

#КонецОбласти 


#Область ПодготовкаВыполняемыхОпераций

Процедура ПолучитьСписокОпераций(ВыполняемыеОперации, ИмяОперации = Неопределено, ВыполнятьПредыдущие = Неопределено, ТолькоОперацииНП = Ложь)
	
	Операции = Операции(ТолькоОперацииНП);
	
	Если ИмяОперации =Неопределено тогда // выполнение всех операций
		для Каждого стр из Операции цикл
			ВыполняемыеОперации.вставить(стр.ключ,стр.Значение);
		КонецЦикла;
		Возврат ;
	иначе
		
	КонецЕсли;
	
	для Каждого стр из Операции цикл
		Если стр.Значение = ИмяОперации тогда
			ИндексОперации  = Число(СтрЗаменить(стр.Ключ,"Операция",""));
		КонецЕсли; 		
	КонецЦикла;
	
	Если ВыполнятьПредыдущие = Неопределено тогда
		// выполняем только одну операцию		
		ВыполняемыеОперации.вставить("Операция" + 0,Операции["Операция" + ИндексОперации]);
		Возврат;
	КонецЕсли;	
	
	Если ВыполнятьПредыдущие тогда
		для Строка = 0 по ИндексОперации-1 цикл
			ВыполняемыеОперации.вставить("Операция" + Строка,Операции["Операция" + Строка]);
		КонецЦикла; 		
	иначе
		Счетчик  = 0;
		для Строка = ИндексОперации по Операции.Количество() - 1 цикл
			ВыполняемыеОперации.вставить("Операция" + Счетчик,Операции["Операция" + Строка]);
			Счетчик = Счетчик + 1;
		КонецЦикла;
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

#Область РезультатВыполненияОперацийНачислений   

Процедура ЗаполнитьСтрокуРезультатаОперации(СтрокаЗаписиРезультата, ПараметрыОтборов, Контекст, ИмяОперации)
	
	СтрокаЗаписиРезультата.Период = ТекущаяДатаСеанса();
	СтрокаЗаписиРезультата.ПериодНачисления = ПараметрыОтборов.ПериодНачисления;
	СтрокаЗаписиРезультата.Организация = ПараметрыОтборов.Организация;
	СтрокаЗаписиРезультата.Район = ПараметрыОтборов.Район; 
	СтрокаЗаписиРезультата.Операция = ИмяОперации;
	СтрокаЗаписиРезультата.ИдентификаторГруппировкиЗаданий = Контекст.ИдентификаторЗадания;
	СтрокаЗаписиРезультата.Пользователь = Контекст.Пользователь;
	СтрокаЗаписиРезультата.ПорядокОперации = Контекст.ПорядокОперации;
	
КонецПроцедуры


Процедура ЗаписатьНачалоОперации(Контекст, СтрокаЗаписиРезультата)
	
	Попытка 	
		Контекст.ФиксаторРезультатаВыполнения.ЗаписатьНачалоОперации(СтрокаЗаписиРезультата);		
	Исключение
	   	Инфо = ИнформацияОбОшибке();
	КонецПопытки;
	                  	
КонецПроцедуры

Процедура ЗаписатьЗавершениеОперации(Контекст, СтрокаЗаписиРезультата)
	
	Попытка	
		Контекст.ФиксаторРезультатаВыполнения.ЗаписатьЗавершениеОперации(СтрокаЗаписиРезультата);	
	Исключение
	   	Инфо = ИнформацияОбОшибке();
	КонецПопытки;
	
КонецПроцедуры   
	
#КонецОбласти

Процедура ОчиститьОчередьНачислений(МенеджерРС, Выборка)
	
	НаборЗаписей = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(МенеджерРС);
	НаборЗаписей.Отбор.Организация.Установить(Выборка.Организация);
	НаборЗаписей.Отбор.Район.Установить(Выборка.Район);
	НаборЗаписей.Отбор.ПериодНачисления.Установить(Выборка.ПериодНачисления);
	НаборЗаписей.Отбор.ИсключаяОтдельностоящие.Установить(Выборка.ИсключаяОтдельностоящие);
	
	Попытка
		
		НаборЗаписей.Записать();	
		
	Исключение
		Инфо = ИнформацияОбОшибке();
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти
