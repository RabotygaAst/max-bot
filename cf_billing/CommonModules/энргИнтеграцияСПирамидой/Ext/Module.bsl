КонецФункции

#КонецОбласти

#Область РаботаСФайлами

// Функция - Префикс загруженного файла
// 
// Возвращаемое значение:
//  Строка- описание параметров функции/процедуры.
//
Функция ПрефиксЗагруженногоФайла() Экспорт 
	Возврат "Загружен_";
КонецФункции

// Функция - Получить файлы для загрузки из каталога
//
// Параметры:
//  КаталогПоиска			 - Строка- описание параметров функции/процедуры. 
//  ПрефиксЗагруженногоФайла - 	Строка- описание параметров функции/процедуры. 
//  Маска					 - Строка- описание параметров функции/процедуры.
// 
// Возвращаемое значение:
//  Строка- описание параметров функции/процедуры. 
//
Функция ПолучитьФайлыДляЗагрузкиИзКаталога(КаталогПоиска, ПрефиксЗагруженногоФайла, Маска = "*.xml") Экспорт 
	Ответ = Новый Массив;

	НайденныеФайлы = НайтиФайлы(КаталогПоиска, Маска);
	Для Каждого ТекФайл Из НайденныеФайлы Цикл
		Если СтрНайти(ТекФайл.ИмяБезРасширения, ПрефиксЗагруженногоФайла) > 0 Тогда
			Продолжить;	
		КонецЕсли; 
		
		Ответ.Добавить(ТекФайл);
	КонецЦикла; 	
	
	Возврат Ответ;
КонецФункции

// Функция - Получить имя файла после загрузки
//
// Параметры:
//  ПолныйПуть	 - Строка- описание параметров функции/процедуры. 
// 
// Возвращаемое значение:
//  Строка- описание параметров функции/процедуры.
//
Функция ПолучитьИмяФайлаПослеЗагрузки(ПолныйПуть) Экспорт 
	Результат	= ПолныйПуть;
	
	Файл 		= Новый Файл(ПолныйПуть);	
	Если НЕ Файл.Существует() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИмяБезРасширения 	= Файл.ИмяБезРасширения;
	Результат			= СтрЗаменить(ПолныйПуть, "\" + ИмяБезРасширения, "\" + ПрефиксЗагруженногоФайла() + ИмяБезРасширения);
	Возврат Результат;	
КонецФункции

// Функция - Установить префикс загруженного файла
//
// Параметры:
//  ТекФайл	 - Строка- описание параметров функции/процедуры. 
// 
// Возвращаемое значение:
//  Строка- описание параметров функции/процедуры.
//
Функция УстановитьПрефиксЗагруженногоФайла(ТекФайл) Экспорт
	НовоеИмяФайла = ПолучитьИмяФайлаПослеЗагрузки(ТекФайл.ПолноеИмя);
	ПереместитьФайл(ТекФайл.ПолноеИмя, НовоеИмяФайла);
	
	Возврат НовоеИмяФайла;
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

