// Строка- описание параметров функции/процедуры. 
//
Функция ИмяЗаданияДляИнтеграцииСПирамидой() Экспорт 
	Возврат Метаданные.РегламентныеЗадания.энргЗагрузитьПоказанияИзПирамида.Синоним;
КонецФункции

// Процедура - Зафиксировать отсутствие файла загрузки из пирамиды
//
// Параметры:
//  ИсточникПоступления	 - Строка- описание параметров функции/процедуры. 
//
Процедура ЗафиксироватьОтсутствиеФайлаЗагрузкиИзПирамиды(ИсточникПоступления) Экспорт
	ИмяЗадания 				= ИмяЗаданияДляИнтеграцииСПирамидой();	
	Комментарий 			= "Не найден файл в каталоге для загрузки";
	ЗаписьЖурналаРегистрации(ИмяЗадания, УровеньЖурналаРегистрации.Ошибка,,, Комментарий);
КонецПроцедуры

// Процедура - Зафиксировать ошибку записи объект регистрации показаний из внешних источников
//
// Параметры:
//  ОписаниеОшибки	 - 	Строка- описание параметров функции/процедуры. 
//  ДопИнформация	 - 	Строка- описание параметров функции/процедуры.
//
Процедура ЗафиксироватьОшибкуЗаписиОбъектРегистрацииПоказанийИзВнешнихИсточников(ОписаниеОшибки, ДопИнформация) Экспорт
	ИмяЗадания 				= ИмяЗаданияДляИнтеграцииСПирамидой();	
	Комментарий 			= "Не удалось загрузить файл с показаниями. " + ДопИнформация + " по причине: " + ПодробноеПредставлениеОшибки(ОписаниеОшибки);
	ЗаписьЖурналаРегистрации(ИмяЗадания, УровеньЖурналаРегистрации.Ошибка,,, Комментарий);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИнициализироватьОбъектРегистрацииПоказанийИзВнешнихИсточников(ФайлДанных)
	ДокументОснование 					= Документы.энргЗагрузкаПоказанийИзВнешнихИсточников.СоздатьДокумент();
	ДокументОснование.Дата 				= ТекущаяДата();
	ДокументОснование.Организация		= Справочники.Организации.НашаОрганизация;
	ДокументОснование.ФайлДляЧтения 	= ФайлДанных.ПолноеИмя;	
	ДокументОснование.ИсточникПоказаний	= Справочники.энргИсточникиПоказаний.ЛичныйКабинет;
	ДокументОснование.ПериодНачисления	= Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ДокументОснование.Дата, ДокументОснование.Организация, Справочники.энргЗоныОтвественности.ПустаяСсылка());	
	
	Возврат ДокументОснование;
КонецФункции 

Функция УпаковатьВоВременноеХранилище(ФайлДляЧтения, УникальныйИдентификатор)
	Файл 	= Новый ДвоичныеДанные(ФайлДляЧтения);
	Адрес 	= ПоместитьВоВременноеХранилище(Файл, УникальныйИдентификатор);
	
	Возврат Адрес;
КонецФункции

#КонецОбласти