
#Область ПрограммныйИнтерфейс

#Область РегламентноеЗадание

// Процедура - Загрузить показания из пирамиды
//
Процедура ЗагрузитьПоказанияИзПирамиды() Экспорт
	ОбработкаЗагрузки 	= ОбъектЗагрузкиПоказанийИзПирамиды();
	КаталогФайлов		= ДанныеНастроек();
	
	Если ПустаяСтрока(КаталогФайлов) Тогда
		Возврат;
	КонецЕсли;	
	
	ФайлыДляЗагрузки	= ПолучитьФайлыДляЗагрузкиИзКаталога(КаталогФайлов, ПрефиксЗагруженногоФайла());
	
	Если ФайлыДляЗагрузки.Количество() = 0 Тогда
		ЗафиксироватьОтсутствиеФайлаЗагрузкиИзПирамиды("");
		Возврат;
	КонецЕсли;
	
	УникальныйИдентификатор = Новый УникальныйИдентификатор;
	Для Каждого ТекФайл Из ФайлыДляЗагрузки Цикл				
		АдресХранилища = УпаковатьВоВременноеХранилище(ТекФайл.ПолноеИмя, УникальныйИдентификатор);
		
		НачатьТранзакцию(); 		
		Попытка
			ОбъектРегистрацииПоказаний = ИнициализироватьОбъектРегистрацииПоказанийИзВнешнихИсточников(ТекФайл);		
			ОбъектРегистрацииПоказаний.Записать(РежимЗаписиДокумента.Запись);			
			ОбработкаЗагрузки.ЗагрузитьПоказанияИзРегламентногоЗадания(ОбъектРегистрацииПоказаний, АдресХранилища);
			
			НовоеИмяФайла 								= УстановитьПрефиксЗагруженногоФайла(ТекФайл);			
			ОбъектРегистрацииПоказаний.ФайлДляЧтения 	= НовоеИмяФайла;
			ОбъектРегистрацииПоказаний.Записать(РежимЗаписиДокумента.Запись);
			
			ЗафиксироватьТранзакцию();		
		Исключение
			ОтменитьТранзакцию();
			
			ОписаниеОшибки 	= ИнформацияОбОшибке();
			ДопИнформация 	= "Путь к файлу: " + ТекФайл.ПолноеИмя;
			ЗафиксироватьОшибкуЗаписиОбъектРегистрацииПоказанийИзВнешнихИсточников(ОписаниеОшибки, ДопИнформация);
		КонецПопытки;
			
	КонецЦикла;
КонецПроцедуры
	
#КонецОбласти


#Область РаботаСНастройкамиОбмена

// Функция - Объект загрузки показаний из пирамиды
// 
// Возвращаемое значение:
//  Строка - описание параметров функции/процедуры.
//
Функция ОбъектЗагрузкиПоказанийИзПирамиды() Экспорт 
	Возврат Обработки.энргЗагрузкаПоказанийПирамида.Создать();
КонецФункции

// Функция - Объект настроек обмена
// 
// Возвращаемое значение:
//  Строка - описание параметров функции/процедуры.
//
Функция ОбъектНастроекОбмена() Экспорт 
	Возврат Константы.энргНастройкаИнтеграцииСПирамидой;
КонецФункции

// Функция - Данные настроек
// 
// Возвращаемое значение:
//  Строка - описание параметров функции/процедуры.
//
Функция ДанныеНастроек() Экспорт 
	ОбъектНастроекОбмена 	= ОбъектНастроекОбмена();
	ДанныеНастроек 			= ОбъектНастроекОбмена.Получить();
	
