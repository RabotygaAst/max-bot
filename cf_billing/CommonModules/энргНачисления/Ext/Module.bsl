Функция ТекстГраницОтчетногоПериода(НачПерНач,КонПерНач,УчитыватьНачалоВеденияУчета = ложь) Экспорт 
	Нач				= НачПерНач; 	
	
	Шаблон 			=
	"ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&Район КАК Район,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ПериодНачисления, СЕКУНДА, -1), МЕСЯЦ), ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеПредыдущего, ВЫБОР
	|				КОГДА энргДатыОтчетногоПериодыОбщиеНастройки.Завершение = 31
	|					ТОГДА ДЕНЬ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ПериодНачисления, МЕСЯЦ), СЕКУНДА, -1))
	|				ИНАЧЕ энргДатыОтчетногоПериодыОбщиеНастройки.Завершение
	|			КОНЕЦ)) КАК НачалоОП,
	|	ДОБАВИТЬКДАТЕ(&ПериодНачисления, ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, ВЫБОР
	|				КОГДА энргДатыОтчетногоПериодыОбщиеНастройки.Завершение = 31
	|					ТОГДА ДЕНЬ(КОНЕЦПЕРИОДА(&ПериодНачисления, МЕСЯЦ))
	|				ИНАЧЕ энргДатыОтчетногоПериодыОбщиеНастройки.Завершение
	|			КОНЕЦ)) КАК ЗавершениеОП,
	|	РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ПериодНачисления, СЕКУНДА, -1), МЕСЯЦ), ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеПредыдущего, ВЫБОР
	|					КОГДА энргДатыОтчетногоПериодыОбщиеНастройки.Завершение = 31
	|						ТОГДА ДЕНЬ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&ПериодНачисления, МЕСЯЦ), СЕКУНДА, -1))
	|					ИНАЧЕ энргДатыОтчетногоПериодыОбщиеНастройки.Завершение
	|				КОНЕЦ)), ДОБАВИТЬКДАТЕ(&ПериодНачисления, ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, ВЫБОР
	|					КОГДА энргДатыОтчетногоПериодыОбщиеНастройки.Завершение = 31
	|						ТОГДА ДЕНЬ(КОНЕЦПЕРИОДА(&ПериодНачисления, МЕСЯЦ))
	|					ИНАЧЕ энргДатыОтчетногоПериодыОбщиеНастройки.Завершение
	|				КОНЕЦ)), ДЕНЬ) КАК ДнейВПериоде
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЗавершениеПредыдущего.Период КАК ЗавершениеПредыдущего,
	|		ЗавершениеТекущего.Период КАК ЗавершениеТекущего
	|	ИЗ
	|		(ВЫБРАТЬ
	|			энргДатыОтчетногоПериоды.Завершение КАК Период
	|		ИЗ
	|			РегистрСведений.энргДатыОтчетногоПериоды КАК энргДатыОтчетногоПериоды
	|		ГДЕ
	|			энргДатыОтчетногоПериоды.ПериодНачисления = &ПериодНачисления
	|			И энргДатыОтчетногоПериоды.Организация = &Организация) КАК ЗавершениеТекущего
	|			ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				энргДатыОтчетногоПериоды.Завершение КАК Период
	|			ИЗ
	|				РегистрСведений.энргДатыОтчетногоПериоды КАК энргДатыОтчетногоПериоды
	|			ГДЕ
	|				энргДатыОтчетногоПериоды.ПериодНачисления = НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ПериодНачисления, СЕКУНДА, -1), МЕСЯЦ)
	|				И энргДатыОтчетногоПериоды.Организация = &Организация) КАК ЗавершениеПредыдущего
	|			ПО (ИСТИНА)) КАК ВложенныйЗапрос
	|		ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			энргДатыОтчетногоПериодыОбщиеНастройки.Завершение КАК Завершение
	|		ИЗ
	|			РегистрСведений.энргДатыОтчетногоПериодыОбщиеНастройки КАК энргДатыОтчетногоПериодыОбщиеНастройки
	|		ГДЕ
	|			энргДатыОтчетногоПериодыОбщиеНастройки.Организация = &Организация) КАК энргДатыОтчетногоПериодыОбщиеНастройки
	|		ПО (ИСТИНА)";
	Текст 				= "";
	Сч					= 0;
	Пока Истина цикл
		Если  Нач >КонПерНач тогда
			Прервать;;
		КонецЕсли;
		СтрокаПериода 		= "ДАТАВРЕМЯ(" +СтрЗаменить(СтрЗаменить(Год(Нач)," ",""),Символы.НПП,"") + "," + СтрЗаменить(СтрЗаменить(МЕСЯЦ(Нач)," ",""),Символы.НПП,"") + "," +  СтрЗаменить(СтрЗаменить(ДЕНЬ(Нач)," ",""),Символы.НПП,"") + ")";
		
		Если Сч> 0 тогда
			Текст 			= Текст + Символы.ПС + "ОБЪЕДИНИТЬ ВСЕ" +Символы.ПС; 						
		КонецЕсли;
		
		Текст 				= Текст + СтрЗаменить(Шаблон,"&ПериодНачисления",СтрокаПериода);
		Если Сч = 0 тогда
			Текст 			= СтрЗаменить(Текст,"%%ФормируемВременную%%","ПОМЕСТИТЬ ГраницыОтчетногоПериода");
		иначе 
			Текст 			= СтрЗаменить(Текст,"%%ФормируемВременную%%",""); 						
		КонецЕсли;		
		Сч 					= Сч + 1;
		Нач 				= ДобавитьМесяц(Нач,1);
	КонецЦикла;
	
	Если УчитыватьНачалоВеденияУчета тогда
		НачалоВеденияУчета 	= энргОбщегоНазначения.ЗначениеКонстанты("энргДатаНачалаВеденияУчета");
		Если ЗначениеЗаполнено(НачалоВеденияУчета) тогда
			Год 			= СтрЗаменить(Год(НачалоВеденияУчета),Символы.НПП,"");
			Месяц 			= СтрЗаменить(Месяц(НачалоВеденияУчета),Символы.НПП,"");
			День 			= СтрЗаменить(День(НачалоВеденияУчета),Символы.НПП,"");
			СтрокаЗапроса  	= "ДАТАВРЕМЯ(" + Год + "," + Месяц + "," + День + ")";
			СтрокаПоиска	= "" +СтрокаЗапроса +" КАК ПериодНачисления,
			|	ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(" + СтрокаЗапроса + ", СЕКУНДА, -1), МЕСЯЦ), ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеПредыдущего, энргДатыОтчетногоПериодыОбщиеНастройки.Завершение)) КАК НачалоОП,
			|	ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, энргДатыОтчетногоПериодыОбщиеНастройки.Завершение)) КАК ЗавершениеОП,
			|	РазностьДат(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", СЕКУНДА, -1), МЕСЯЦ), ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеПредыдущего, энргДатыОтчетногоПериодыОбщиеНастройки.Завершение)),ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, энргДатыОтчетногоПериодыОбщиеНастройки.Завершение)), СЕКУНДА, -1),День)+1  КАК ДнейВПериоде";
			
			СтрокаЗамены 	= "" + СтрокаЗапроса +" КАК ПериодНачисления,
			|	" + СтрокаЗапроса +" КАК НачалоОП,
			|	ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, энргДатыОтчетногоПериодыОбщиеНастройки.Завершение)) как ЗавершениеОП,
			|	РазностьДат(" + СтрокаЗапроса +",ДОБАВИТЬКДАТЕ("+СтрокаЗапроса+", ДЕНЬ, ЕСТЬNULL(ВложенныйЗапрос.ЗавершениеТекущего, энргДатыОтчетногоПериодыОбщиеНастройки.Завершение)),ДЕНЬ)  КАК ДнейВПериоде";
			
			Текст 			= СтрЗаменить(Текст,СтрокаПоиска,СтрокаЗамены);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

Функция ГраницыОтчетногоПериода(Организация,Район,ПериодНачисления) Экспорт 
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.Текст 	= ТекстГраницОтчетногоПериода(ПериодНачисления,ПериодНачисления,Истина);
	результат 		= Запрос.Выполнить();
	Выборка  		= результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка;
КонецФункции

Процедура КорректировкаЗадолженностиПриИзмененииМКД(СтарыйМКД, НовыйМКД, Период, СтруктураРегистров) Экспорт
	
	ВидРН_Остатки = Метаданные.СвойстваОбъектов.ВидРегистраНакопления.Остатки;
	
	ОписаниеТипов_Строение = Новый ОписаниеТипов("СправочникСсылка.энргСтроения");
	Тип_Число = Тип("Число");
	
	Для каждого СтрокаСтруктуры Из СтруктураРегистров Цикл
			
		ТекущийОбъектМетаданных = Метаданные.РегистрыНакопления[СтрокаСтруктуры.Ключ];		
		Если НЕ ТекущийОбъектМетаданных.ВидРегистра = ВидРН_Остатки Тогда
			Продолжить;
		КонецЕсли;
	
		ИзмерениеОтбора = "";		
		Для Каждого ТекущееИзмерение из ТекущийОбъектМетаданных.Измерения Цикл
			Если ТекущееИзмерение.Тип = ОписаниеТипов_Строение Тогда
				ИзмерениеОтбора = ТекущееИзмерение.Имя;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ИзмерениеОтбора = "" Тогда
			Продолжить;
		КонецЕсли;
		
		НаборЗаписей = СтрокаСтруктуры.Значение;
		
		МассивРесурсов = Новый Массив;
		Для Каждого ТекущийРесурс из ТекущийОбъектМетаданных.Ресурсы Цикл
			Если Тип(ТекущийРесурс.Тип) = Тип_Число Тогда
				МассивРесурсов.Добавить(ТекущийРесурс.Имя);
			КонецЕсли;	
		КонецЦикла;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ *
		|ИЗ
		|	РегистрНакопления." + СтрокаСтруктуры.Ключ +  ".Остатки(&Период, &ИзмерениеОтбора = &МКД) КАК НужныйРегистр";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ИзмерениеОтбора", ИзмерениеОтбора);		
		Запрос.УстановитьПараметр("МКД", СтарыйМКД);
		Запрос.УстановитьПараметр("Период", Период);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			НСтр = НаборЗаписей.ДобавитьРасход();
			ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
			НСтр.Период = Период;
			
			НСтр_Обр = НаборЗаписей.ДобавитьПриход();
			ЗаполнитьЗначенияСвойств(НСтр_Обр, ВыборкаДетальныеЗаписи);
			НСтр_Обр[ИзмерениеОтбора] = НовыйМКД;
			НСтр_Обр.Период = Период;
			
			Для каждого ТекущийРесурс Из МассивРесурсов Цикл
				НСтр[ТекущийРесурс] = ВыборкаДетальныеЗаписи[ТекущийРесурс + "Остаток"];
				НСтр_Обр[ТекущийРесурс] = ВыборкаДетальныеЗаписи[ТекущийРесурс + "Остаток"];
			КонецЦикла; 
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ПроверкаОплатыРеструктуризации() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргРеструктуризацияДолгаСрезПоследних.Организация КАК Организация,
		|	энргРеструктуризацияДолгаСрезПоследних.Район КАК Район,
		|	энргРеструктуризацияДолгаСрезПоследних.Строение КАК Строение,
		|	энргРеструктуризацияДолгаСрезПоследних.Абонент КАК Абонент,
		|	энргРеструктуризацияДолгаСрезПоследних.ДатаОплаты КАК ДатаОплаты,
		|	энргРеструктуризацияДолгаСрезПоследних.Документ КАК Документ,
		|	энргРеструктуризацияДолгаСрезПоследних.СуммаНарастающимИтогом КАК СуммаНарастающимИтогом,
		|	энргРеструктуризацияДолгаСрезПоследних.СуммаОбщая КАК СуммаОбщая,
		|	энргРеструктуризацияДолгаСрезПоследних.ДатаНачала КАК ДатаНачала
		|ПОМЕСТИТЬ ДанныеРеструктуризации
		|ИЗ
		|	РегистрСведений.энргРеструктуризацияДолга.СрезПоследних(&ТекущаяДата, ДатаОплаты = &ДатаОплаты) КАК энргРеструктуризацияДолгаСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеРеструктуризации.Организация КАК Организация,
		|	ДанныеРеструктуризации.Район КАК Район,
		|	ДанныеРеструктуризации.Строение КАК Строение,
		|	ДанныеРеструктуризации.Абонент КАК Абонент,
		|	энргДокументыРеструктуризации.Услуга КАК Услуга,
		|	энргДокументыРеструктуризации.ПериодНачисления КАК ПериодНачисления,
		|	энргДокументыРеструктуризации.Поставщик КАК Поставщик,
		|	ДанныеРеструктуризации.ДатаОплаты КАК ДатаОплаты,
		|	ДанныеРеструктуризации.СуммаНарастающимИтогом КАК СуммаНарастающимИтогом,
		|	ДанныеРеструктуризации.СуммаОбщая КАК СуммаОбщая,
		|	ДанныеРеструктуризации.ДатаНачала КАК ДатаНачала,
		|	ДанныеРеструктуризации.Документ КАК Документ,
		|	энргДокументыРеструктуризации.Сумма КАК Сумма
		|ПОМЕСТИТЬ ПериодыРасчета
		|ИЗ
		|	ДанныеРеструктуризации КАК ДанныеРеструктуризации
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргДокументыРеструктуризации КАК энргДокументыРеструктуризации
		|		ПО ДанныеРеструктуризации.Документ = энргДокументыРеструктуризации.ДокументРеструктуризации
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыРасчета.Организация КАК Организация,
		|	ПериодыРасчета.Район КАК Район,
		|	ПериодыРасчета.Строение КАК Строение,
		|	ПериодыРасчета.Абонент КАК Абонент,
		|	ПериодыРасчета.Услуга КАК Услуга,
		|	ПериодыРасчета.ПериодНачисления КАК ПериодНачисления,
		|	ПериодыРасчета.Поставщик КАК Поставщик,
		|	ПериодыРасчета.ДатаОплаты КАК ДатаОплаты,
		|	ПериодыРасчета.СуммаНарастающимИтогом КАК СуммаНарастающимИтогом,
		|	ПериодыРасчета.СуммаОбщая КАК СуммаОбщая,
		|	ПериодыРасчета.ДатаНачала КАК ДатаНачала,
		|	ПериодыРасчета.Документ КАК Документ,
		|	ЕСТЬNULL(энргЗабалансоваяЗадолженностьОбороты.СуммаЗадолженностиРасход, 0) КАК Сумма,
		|	ПериодыРасчета.Сумма - ЕСТЬNULL(энргЗабалансоваяЗадолженностьОбороты.СуммаЗадолженностиРасход, 0) КАК Остаток
		|ПОМЕСТИТЬ ФактическиеСуммы
		|ИЗ
		|	ПериодыРасчета КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.энргЗабалансоваяЗадолженность.Обороты(
		|				,
		|				&ТекущаяДата,
		|				День,
		|				(Организация, Район, МКД, Абонент, Услуга, ПериодНачисления, Поставщик) В
		|						(ВЫБРАТЬ
		|							ПериодыРасчета.Организация КАК Организация,
		|							ПериодыРасчета.Район КАК Район,
		|							ПериодыРасчета.Строение КАК Строение,
		|							ПериодыРасчета.Абонент КАК Абонент,
		|							ПериодыРасчета.Услуга КАК Услуга,
		|							ПериодыРасчета.ПериодНачисления КАК ПериодНачисления,
		|							ПериодыРасчета.Поставщик КАК Поставщик
		|						ИЗ
		|							ПериодыРасчета КАК ПериодыРасчета)
		|					И ВидЗадолженности = &ВидЗадолженности) КАК энргЗабалансоваяЗадолженностьОбороты
		|		ПО ПериодыРасчета.Организация = энргЗабалансоваяЗадолженностьОбороты.Организация
		|			И ПериодыРасчета.Район = энргЗабалансоваяЗадолженностьОбороты.Район
		|			И ПериодыРасчета.Строение = энргЗабалансоваяЗадолженностьОбороты.МКД
		|			И ПериодыРасчета.Абонент = энргЗабалансоваяЗадолженностьОбороты.Абонент
		|			И ПериодыРасчета.Услуга = энргЗабалансоваяЗадолженностьОбороты.Услуга
		|			И ПериодыРасчета.ПериодНачисления = энргЗабалансоваяЗадолженностьОбороты.ПериодНачисления
		|			И ПериодыРасчета.Поставщик = энргЗабалансоваяЗадолженностьОбороты.Поставщик
		|			И ПериодыРасчета.ДатаНачала <= энргЗабалансоваяЗадолженностьОбороты.Период
		|			И ПериодыРасчета.ДатаОплаты >= энргЗабалансоваяЗадолженностьОбороты.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ФактическиеСуммы.Документ КАК Документ,
		|	ФактическиеСуммы.ДатаОплаты КАК ДатаОплаты,
		|	ФактическиеСуммы.СуммаНарастающимИтогом КАК СуммаНарастающимИтогом,
		|	СУММА(ФактическиеСуммы.Сумма) КАК Сумма
		|ПОМЕСТИТЬ ОплатыПоДокументам
		|ИЗ
		|	ФактическиеСуммы КАК ФактическиеСуммы
		|
		|СГРУППИРОВАТЬ ПО
		|	ФактическиеСуммы.Документ,
		|	ФактическиеСуммы.ДатаОплаты,
		|	ФактическиеСуммы.СуммаНарастающимИтогом
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОплатыПоДокументам.Документ КАК Документ,
		|	МИНИМУМ(ОплатыПоДокументам.Сумма >= ОплатыПоДокументам.СуммаНарастающимИтогом) КАК Отметка
		|ПОМЕСТИТЬ ОплаченныеДокументы
		|ИЗ
		|	ОплатыПоДокументам КАК ОплатыПоДокументам
		|
		|СГРУППИРОВАТЬ ПО
		|	ОплатыПоДокументам.Документ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ФактическиеСуммы.Организация КАК Организация,
		|	ФактическиеСуммы.Район КАК Район,
		|	ФактическиеСуммы.ПериодНачисления КАК ПериодНачисления,
		|	ФактическиеСуммы.Строение КАК Строение,
		|	ФактическиеСуммы.Абонент КАК Абонент,
		|	ФактическиеСуммы.Услуга КАК Услуга,
		|	ФактическиеСуммы.Поставщик КАК Поставщик,
		|	ФактическиеСуммы.Остаток КАК Остаток
		|ИЗ
		|	ОплаченныеДокументы КАК ОплаченныеДокументы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ФактическиеСуммы КАК ФактическиеСуммы
		|		ПО ОплаченныеДокументы.Документ = ФактическиеСуммы.Документ
		|			И (НЕ ОплаченныеДокументы.Отметка)
		|ГДЕ
		|	ФактическиеСуммы.Остаток > 0
		|ИТОГИ
		|	МАКСИМУМ(Организация),
		|	МАКСИМУМ(Район),
		|	МАКСИМУМ(Строение)
		|ПО
		|	Абонент";
	
	Ответственный = ПользователиКлиентСервер.АвторизованныйПользователь();
	ТекущаяДата = НачалоДня(ТекущаяДата());	
	ВидОперации = Перечисления.энргВидыОперацийНачисления.ЗакрытиеРеструктуризацииДолга;
	
	Запрос.УстановитьПараметр("ВидЗадолженности", Перечисления.энргВидыЗадолженности.РеструктуризированнаяЗадолженность);
	Запрос.УстановитьПараметр("ДатаОплаты", ТекущаяДата - 1);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаАбонент = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаАбонент.Следующий() Цикл
		
		НДок = Документы.энргСоглашениеПоРассрочке.СоздатьДокумент();
		НДок.Дата = ТекущаяДата;
		НДок.Абонент = ВыборкаАбонент.Абонент;
		НДок.ВидОперации = ВидОперации;
		НДок.Организация = ВыборкаАбонент.Организация;
		НДок.Ответственный = Ответственный;
		НДок.Район = ВыборкаАбонент.Район;
		НДок.Строение = ВыборкаАбонент.Строение;
	
		ВыборкаДетальныеЗаписи = ВыборкаАбонент.Выбрать();	
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НСтр = НДок.ТекущиеЗадолженности.Добавить();
			НСтр.ПериодНачисления = ВыборкаДетальныеЗаписи.ПериодНачисления;
			НСтр.Услуга = ВыборкаДетальныеЗаписи.Услуга;
			НСтр.Сумма = ВыборкаДетальныеЗаписи.Остаток;
			НСтр.Поставщик = ВыборкаДетальныеЗаписи.Поставщик;
		КонецЦикла;
		
		НДок.Записать(РежимЗаписиДокумента.Проведение);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти


