// Процедура - Начислить
//
// Параметры:
//  ПериодНачисления - 	 - 
//  Район			 - 	 - 
//  Дом				 - 	 - 
//  Абонент			 - 	 - 
//  Документ		 - 	 - 
//
Процедура Начислить(Параметры) Экспорт
	                                                                  
	Инструменты 								= энргФабрикаИнструментовНачисления.ИнструментыНачислений();
	Если Инструменты = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект"; 
		Возврат;
	КонецЕсли; 
	
	Делегат 									= энргФабрикаИнструментовНачисления.ДелегатНачислений();
	
	Если Делегат = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект"; 
		Возврат;
	КонецЕсли; 
	
	Делегат.Организация  						= Параметры.Организация;
	Делегат.Район								= Параметры.Район;
	Делегат.ЧастныйСектор 						= Параметры.ЧастныйСектор;
	Делегат.Строение							= Параметры.Строение;
	Делегат.МассивПомещений						= Параметры.Помещение;
	Делегат.МассивКлючейПомещений				= Параметры.МассивКлючейПомещений;
	Делегат.ПериодНачисления					= Параметры.ПериодНачисления;
	Делегат.МенеджерОбъемаНачислений 			= РегистрыНакопления.энргОбъемНачислений;
	Делегат.МенеджерОбъемаНачисленийПомещений 	= РегистрыНакопления.энргОбъемНачисленийПомещенийСРазделеннымиЛС;
	Делегат.МенеджерДокументовНачислений 		= Документы.энргНачисление;
	Делегат.ПроверятьДатуЗапретаИзменения 		= Истина;
	Делегат.ФинальноеНачисление 				= Параметры.ФинальноеНачисление;
	
	Инструменты.Начислить(Делегат);
	
КонецПроцедуры

// Процедура - Восстановить полседовательность
//
// Параметры:
//  ПериодНачисления - 	 - 
//  Район			 - 	 - 
//  Дом				 - 	 - 
//  Абонент			 - 	 - 
//  Документ		 - 	 - 
//
Процедура ВосстановитьПолседовательность(Организация, ПериодНачисления,Район,Строение = Неопределено,Помещение = Неопределено) Экспорт
	
	РаботаСПоследовательностями = энргФабрикаИнструментовНачисления.РаботаСПоследовательностями();
	Если РаботаСПоследовательностями = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект"; 
		Возврат;
	КонецЕсли;
	
	РаботаСПоследовательностями.ОтложенныеДвиженияДокументовНачисления(Организация, ПериодНачисления, Район, Строение);
	РаботаСПоследовательностями.ВосстановитьПоследовательностьСтабильныеПериоды(Организация, ПериодНачисления, Район, Строение, Помещение);
	РаботаСПоследовательностями.ВосстановитьПоследовательностьПоказанияПУ(Организация, ПериодНачисления, Район, Строение, Помещение);
	
КонецПроцедуры

