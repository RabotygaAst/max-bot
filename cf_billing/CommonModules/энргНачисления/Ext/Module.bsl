Процедура ДанныеПерерасчета(Организация,Район,ЧастныйСектор,Строение,Помещения,ПериодНачисленияНачало,ПериодНачисленияЗавершение,Набор,НаборПомещение,КорректировкаПоказаний,ДополнительныеРеквизиты) Экспорт 
		
	Делегат 								= энргФабрикаИнструментовНачисления.ДелегатПерерасчета();
	Если Делегат = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект";
		Возврат;
	КонецЕсли;
	
	Инструмент 								= энргФабрикаИнструментовНачисления.ИнструментыНачислений();
	Если Инструмент = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект";
		Возврат;
	КонецЕсли;
	
	Делегат.Организация  					= Организация;
	Делегат.Район							= Район;
	Делегат.ЧастныйСектор 					= ЧастныйСектор;
	Делегат.Строение						= Строение;
	Делегат.мПомещения						= Помещения;
	Делегат.ПериодНачисленияНачало			= ПериодНачисленияНачало;
	Делегат.ПериодНачисленияЗавершение		= ПериодНачисленияЗавершение;
	Делегат.МенеджерДокументовНачислений	= Документы.энргПерерасчет;
	Делегат.ПроверятьДатуЗапретаИзменения 	= Ложь;

	//НаборПоказаний 							= РегистрыСведений.энргМаксимальныеПоказания.СоздатьНаборЗаписей();
	НаборПоказаний 							= РегистрыСведений.энргПоказанияПриборовУчета.СоздатьНаборЗаписей();

	Для Каждого СтрокаПоказаний Из КорректировкаПоказаний Цикл
		Если СтрокаПоказаний.СостояниеПоказанийПосле = Перечисления.энргСостояниеПоказаний.Отклонены Тогда
			Продолжить;
		КонецЕсли;
		СтрокаНабора 						= НаборПоказаний.Добавить();
		СтрокаНабора.Период		 			= СтрокаПоказаний.Период;
		СтрокаНабора.Регистратор 			= СтрокаПоказаний.Регистратор;
		//СтрокаНабора.ДокРегистратор 		= СтрокаПоказаний.Регистратор; 		
		СтрокаНабора.Организация 			= Организация;
		СтрокаНабора.Район 					= Район;
		СтрокаНабора.КлючПомещения			= СтрокаПоказаний.КлючПомещения;
		СтрокаНабора.ПриборУчета 			= СтрокаПоказаний.ПриборУчета;
		СтрокаНабора.Шкала 					= СтрокаПоказаний.Шкала;
		СтрокаНабора.ТарифнаяЗона 			= СтрокаПоказаний.ТарифнаяЗона;
		СтрокаНабора.Разделитель 			= СтрокаПоказаний.Разделитель;
		СтрокаНабора.Показание 				= СтрокаПоказаний.Показания;
		СтрокаНабора.ПериодНачисления 		= СтрокаПоказаний.ПериодНачисления;
	КонецЦикла;
		
	ИсточникиДанных 						= Новый Структура;
	ИсточникиДанных.Вставить("НаборСтабильныеПериоды",			Неопределено);
	ИсточникиДанных.Вставить("НаборСтабильныеПериодыШкалы",		Неопределено);
	ИсточникиДанных.Вставить("НаборСтабильныеПериодыИзмерители",Неопределено);
	ИсточникиДанных.Вставить("НаборПоказаний",					НаборПоказаний);
		
	энргРаботаСПоследовательностями.ВосстановитьПоследовательностьСтабильныеПериодыПерерасчет(Организация,Район,ЧастныйСектор,Строение,Помещения,ПериодНачисленияНачало,ПериодНачисленияЗавершение,ИсточникиДанных,ДополнительныеРеквизиты);  
	
	Делегат.УстановитьНаборы(ИсточникиДанных);
	
	Инструмент.Начислить(Делегат);
	
	Набор 									= Делегат.НаборОбъемНачислений;
	Для Каждого СтрокаНабора Из Набор Цикл
		РегистрыНакопления.энргОбъемНачислений.РассчитатьСуммы(СтрокаНабора);		
	КонецЦикла;
	
	НаборПомещение 							= Делегат.НаборОбъемНачисленийПомещений;
	
КонецПроцедуры

Процедура ДанныеПерерасчетаМКД(Организация,Район,МКД,НачПерНачисления,ПериодНачисления,Набор,КорректировкаПоказаний) Экспорт 
	
	Инструменты = энргФабрикаИнструментовНачисления.ИнструментыНачислений();
	Если Инструменты = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект";
		Возврат;
	КонецЕсли; 
	Инструменты.ДанныеПерерасчетаМКД(Организация, Район,МКД,НачПерНачисления,ПериодНачисления,Набор,КорректировкаПоказаний);
     	
КонецПроцедуры

Процедура ИзменитьПризнакСостояниеПрибора(Параметры) Экспорт
	
	Инструменты 						= энргФабрикаИнструментовНачисления.ИнструментыПерерасчет();
	Если Инструменты = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект"; 
		Возврат;
	КонецЕсли;	
	
	Делегат 								= энргФабрикаИнструментовНачисления.ДелегатПерерасчета();
	Делегат.Организация  					= Параметры.Организация;
	Делегат.Район							= Параметры.Район;
	Делегат.ЧастныйСектор 					= Параметры.ЧастныйСектор;
	Если Не Параметры.ЧастныйСектор = Неопределено Тогда
		Делегат.Строение					= Параметры.Строение;
	КонецЕсли;
	Делегат.мПомещения						= Параметры.Помещение;
	Делегат.ПериодНачисленияНачало			= НачалоГода(Параметры.ПериодНачисления);
	Делегат.ПериодНачисленияЗавершение		= ДобавитьМесяц(Параметры.ПериодНачисления, -1);
	Делегат.ПериодНачисления				= Параметры.ПериодНачисления;
	Делегат.ВидОперацийНачисления 			= Перечисления.энргВидыОперацийНачисления.ПерерасчетИзменениеПризнакаНаличияПрибораУчетаСНачалаГода;
	Делегат.ПроверятьДатуЗапретаИзменения	= Ложь;

	Инструменты.ИзменитьПризнакСостояниеПрибора(Делегат);
	
КонецПроцедуры

Процедура ПересчитатьРаспредениеОбъемаПотребленногоМКД() Экспорт 
	
	Инструменты = энргФабрикаИнструментовНачисления.ИнструментыНачислений();
