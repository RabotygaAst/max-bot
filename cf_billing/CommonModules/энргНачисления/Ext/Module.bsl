	Возврат энргНачисленияПовтИсп.ИзмеренияТаблицыОбъемов(ИмяРегистра);		
КонецФункции

Функция ОпределитьНачальныйПериодПерерасчета(Организация,Район,ДокументыОснования,Корректировка=Ложь) Экспорт
	
	ИсключаемыеТипы = Новый Массив;
	ИсключаемыеТипы.Добавить(Тип("ДокументСсылка.энргВводНачальныхОстатков"));
	ИсключаемыеТипы.Добавить(Тип("ДокументСсылка.энргПлатежноеПоручениеВходящие"));
	ИсключаемыеТипы.Добавить(Тип("ДокументСсылка.энргОбходнойЛист"));
	ИсключаемыеТипы.Добавить(Тип("ДокументСсылка.энргПриходныйКассовыйОрдер"));
	ИсключаемыеТипы.Добавить(Тип("ДокументСсылка.энргПерерасчет"));
	ИсключаемыеТипы.Добавить(Тип("ДокументСсылка.энргПоступлениеОплатыЧерезКонтроллера"));
	ИсключаемыеТипы.Добавить(Тип("ДокументСсылка.энргРегистрацияПоказанийАбонента"));
	
	
	Текст  							="ВЫБРАТЬ МАКСИМУМ(ВложенныйЗапрос.ДатаФакт)КАК ДатаФакт  ИЗ (Выбрать Минимум(ВложенныйЗапрос.ДатаФактическогоСобытия) КАК ДатаФакт ИЗ (%%ТекстВложенногоЗапроса%%) КАК ВложенныйЗапрос ОБЪЕДИНИТЬ ВСЕ " +Символы.ПС + " ВЫБРАТЬ энргДатаНачалаВеденияУчета.Значение  ИЗ Константа.энргДатаНачалаВеденияУчета КАК энргДатаНачалаВеденияУчета ГДЕ энргДатаНачалаВеденияУчета.Значение > ДАТАВРЕМЯ(1, 1, 1)) КАК ВложенныйЗапрос";
	ТекстВложенногоЗапроса 			="";
	Шаблон 							="ВЫБРАТЬ Док.ДатаФактическогоСобытия ИЗ Документ.%%ИмяДокумента%% КАК Док ГДЕ Док.ссылка  В (&МассивСсылок)";
	ШаблонИсключения 				="ВЫБРАТЬ Док.Дата ИЗ Документ.%%ИмяДокумента%% КАК Док ГДЕ Док.ссылка  В (&МассивСсылок)";
	
	ВозможныеТипы 					= Метаданные.Документы.энргПерерасчет.ТабличныеЧасти.ДокументыОснования.Реквизиты.Документ.Тип.типы();
	ГлавСчетчик 					= 0; 
	для Каждого Тип из ВозможныеТипы цикл
		
		Если не Корректировка и Не ИсключаемыеТипы.Найти(Тип) = Неопределено ТОгда // не корректировка и нет дата факт
			Продолжить;
		КонецЕсли;
		
		МетадДок 					= Метаданные.НайтиПоТипу(Тип);
		ИмяДок  					= МетадДок.имя;
		Если ГлавСчетчик> 0 тогда	
			ТекстВложенногоЗапроса 	= ТекстВложенногоЗапроса + Символы.ПС + "ОБЪЕДИНИТЬ ВСЕ" + Символы.ПС;
		КонецЕсли;
		
		Если Корректировка и Не ИсключаемыеТипы.Найти(Тип) = Неопределено ТОгда   // корректировка и нет дата факт
			
			ТекстВложенногоЗапроса 	= ТекстВложенногоЗапроса + СтрЗаменить(ШаблонИсключения,"%%ИмяДокумента%%",ИмяДок);
			
		Иначе   // есть дата факт
			
			ТекстВложенногоЗапроса 	= ТекстВложенногоЗапроса + СтрЗаменить(Шаблон,"%%ИмяДокумента%%",ИмяДок);
			
		КонецЕсли;
		
		ГлавСчетчик 			= ГлавСчетчик + 1;
	КонецЦикла;
	
	// ТекстВложенногоЗапроса 			= ТекстВложенногоЗапроса + Символы.ПС + "ОБЪЕДИНИТЬ ВСЕ " +Символы.ПС + " ВЫБРАТЬ энргДатаНачалаВеденияУчета.Значение  ИЗ Константа.энргДатаНачалаВеденияУчета КАК энргДатаНачалаВеденияУчета ГДЕ энргДатаНачалаВеденияУчета.Значение > ДАТАВРЕМЯ(1, 1, 1)";
	
	Текст 							= СтрЗаменить(Текст,"%%ТекстВложенногоЗапроса%%",ТекстВложенногоЗапроса);
	Запрос 							= Новый Запрос;
	Запрос.Текст 					=Текст;
	Запрос.УстановитьПараметр("МассивСсылок",ДокументыОснования);
	Результат  						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	Выборка.Следующий();
	
	Возврат Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Выборка.ДатаФакт, Организация, Район);	
	
КонецФункции

