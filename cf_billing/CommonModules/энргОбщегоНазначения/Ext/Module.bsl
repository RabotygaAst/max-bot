// Получает пользователей с отбором по ролям.
//
// Параметры:
//  Организация	-	СправочникСсылка.Организации.
//  Район		-	СправочникСсылка.энргЗоныОтвественности.
//  Роли		-	СправочникСсылка.энргРоли.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ПолучитьПользователейСОтборомПоРолям(Организация, Район, Роли) Экспорт
	Схема							= Неопределено;
	Параметры 						= Новый Структура;
	ПараметрыВТ 					= Новый Массив;
	ПараметрыОтбора					= Новый Массив;
	
	ОтборПоРолям 		= энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("Роль", "Роли"));
	ОтборПоОрганизации 	= энргФормированиеТекстовЗапроса.ПараметрПериодРавно(Новый Структура("Организация", "Организация"));
	ОтборПоРайону 		= энргФормированиеТекстовЗапроса.ПараметрПериодРавно(Новый Структура("Район", "Район"));

	ПараметрыВТ.Добавить(ОтборПоРолям);	
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	РегистрыСведений.энргРолиПользователей.РолиПользователей(Схема, Параметры);
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Роли", 			Роли);
	ПараметрыЗапроса.Вставить("Организация", 	Организация);
	ПараметрыЗапроса.Вставить("Район", 			Район);
		
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);;	
КонецФункции

