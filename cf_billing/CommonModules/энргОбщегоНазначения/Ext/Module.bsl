// Возвращает результат сериализации в JSON.
//
// Параметры:
//  ОбъектСериализации	-	Произвольный.
// 
// Возвращаемое значение:
//   Строка.
//
Функция СериализоватьВJSON(ОбъектСериализации) Экспорт 
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ОбъектСериализации);
	Результат = ЗаписьJSON.Закрыть();;
	
	Возврат Результат;
КонецФункции

// Возвращает результат десериализации JSON.
//
// Параметры:
//  ТекстJSON	-	Строка.
// 
// Возвращаемое значение:
//   Строка.
//
Функция ДесериализоватьJSON(ТекстJSON) Экспорт 
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	Результат = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();
	
	Возврат Результат;
КонецФункции
	
#КонецОбласти

// Возвращает новое уникальное имя файла DBF.
// 
// Возвращаемое значение:
//   Строка.
//
Функция НовоеУникальноеИмяФайлаDBF() Экспорт
	ГСЧ = Новый ГенераторСлучайныхЧисел();
	СлучайноеЧисло 	= Формат(ГСЧ.СлучайноеЧисло(10000, 99999), "ЧГ=0");
	Результат 		= "v8_" + СлучайноеЧисло;
	Возврат Результат;
КонецФункции

#КонецОбласти