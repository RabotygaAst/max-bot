// Возвращает необязательные параметры для регистации ошибки.
// 
// Возвращаемое значение:
//   Структура.
//
Функция НеобязательныеПараметрыРегистацииОшибки() Экспорт 
	Результат = Новый Структура;
	Результат.Вставить("ОбъектМетаданных");
	Результат.Вставить("Данные");
	Результат.Вставить("ВыводитьСообщениеПользователю");
	Результат.Вставить("ТекстПользователю");
	
	Возврат Результат;
