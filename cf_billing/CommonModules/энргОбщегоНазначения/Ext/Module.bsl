// Регистрирует ошибку.
//
// Параметры:
//  ИмяСобытия				-	Строка.
//  Уровень					-	УровеньЖурналаРегистрации.
//  Комментарий				-	Строка.
//  НеобязательныеПараметры	-	Структура	-	см. энргОбщегоНазначения.НеобязательныеПараметрыРегистацииОшибки.
//
Процедура ЗарегистрироватьОшибку(ИмяСобытия, Уровень, Комментарий, НеобязательныеПараметры = Неопределено) Экспорт
	ОбъектМетаданных 				= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(НеобязательныеПараметры, "ОбъектМетаданных", Неопределено);
	Данные 							= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(НеобязательныеПараметры, "Данные", Неопределено);
	ВыводитьСообщениеПользователю 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(НеобязательныеПараметры, "ВыводитьСообщениеПользователю", Истина);
	ТекстПользователю 				= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(НеобязательныеПараметры, "ТекстПользователю", Неопределено);
	
	ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень, ОбъектМетаданных , Данные, Комментарий);
	Если ВыводитьСообщениеПользователю Тогда
		Если ТекстПользователю = Неопределено Тогда 
			ТекстПользователю = Комментарий;
		КонецЕсли;		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Комментарий);
	КонецЕсли;	
КонецПроцедуры
	
