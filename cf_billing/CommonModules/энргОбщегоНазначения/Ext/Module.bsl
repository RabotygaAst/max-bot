// Преобразует JSON в контактную информацию по полям
//
// Параметры:
//  Адрес	-	Строка.
// 
// Возвращаемое значение:
//   Строка.
//
Функция JSONВКонтактнуюИнформациюПоПолям(Адрес) Экспорт
	Попытка
		ЗначенияПолей = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(Адрес,
			Перечисления.ТипыКонтактнойИнформации.Адрес);
		Улица =  УправлениеКонтактнойИнформациейСлужебный.JSONВКонтактнуюИнформациюПоПолям(ЗначенияПолей, Перечисления.ТипыКонтактнойИнформации.Адрес).street;
	Исключение 
		Улица = "";
	КонецПопытки;
	Возврат Улица;
КонецФункции

// Формирует представление адреса по полям.
//
// Параметры:
//  Значение	-	Строка.
//  МассивПолей	-	Массив из Строк.
// 
// Возвращаемое значение:
//   Строка.
//
Функция СформироватьПредставлениеАдресаПоПолям(Значение, МассивПолей) Экспорт
	СтруктуруАдреса = Новый Структура;
	СтруктуруАдреса.Вставить("Area",			"AreaType");  		// Регион
	СтруктуруАдреса.Вставить("District",		"DistrictType");    // Район
	СтруктуруАдреса.Вставить("city",			"cityType");		// Город
	СтруктуруАдреса.Вставить("CityDistrict",	"CityDistrictType");// Внутригородскойрайон
	СтруктуруАдреса.Вставить("Locality",		"LocalityType");	// Населеный пункт	
	СтруктуруАдреса.Вставить("Territory",		"TerritoryType");	// Территория
	СтруктуруАдреса.Вставить("street",			"streetType");      // Улица
	
	КИПоПолям = УправлениеКонтактнойИнформациейСлужебный.JSONВКонтактнуюИнформациюПоПолям(Значение, Перечисления.ТипыКонтактнойИнформации.Адрес);
	Наименование = "";
	
	Для Каждого ТекПоле Из МассивПолей Цикл
		ТекПолеСокр = "";
		Если СтруктуруАдреса.Свойство(ТекПоле, ТекПолеСокр) Тогда
			Наименование = Наименование + ?(ЗначениеЗаполнено(КИПоПолям[ТекПоле]), КИПоПолям[ТекПоле] + " " + КИПоПолям[ТекПолеСокр] + ", ", "");	
		КонецЕсли;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Наименование) Тогда
		Наименование = Лев(Наименование, СтрДлина(Наименование) - 2);
	КонецЕсли;
	
	
	Возврат Наименование;
КонецФункции

// Очищает поля адреса.
//
// Параметры:
//  Значение	-	Строка.
//  МассивПолей	-	Массив из Строк.
// 
// Возвращаемое значение:
//   Структура	-	см. РаботаСАдресамиКлиентСервер.ОписаниеНовойКонтактнойИнформации.
//
Функция ОчиститьПоляАдреса(Значение, МассивПолей) Экспорт
	
	Если ТипЗнч(Значение) <> Тип("Структура") Тогда
		КИПоПолям = УправлениеКонтактнойИнформациейСлужебный.JSONВКонтактнуюИнформациюПоПолям(Значение, Перечисления.ТипыКонтактнойИнформации.Адрес);
	Иначе
		КИПоПолям = Значение;
	КонецЕсли;

	СтруктуруАдреса = Новый Структура;
	СтруктуруАдреса.Вставить("Area",			"AreaType");  		// Регион
	СтруктуруАдреса.Вставить("District",		"DistrictType");    // Район
	СтруктуруАдреса.Вставить("city",			"cityType");		// Город
	СтруктуруАдреса.Вставить("CityDistrict",	"CityDistrictType");// Внутригородскойрайон
	СтруктуруАдреса.Вставить("Locality",		"LocalityType");	// Населеный пункт	
	СтруктуруАдреса.Вставить("Territory",		"TerritoryType");	// Территория
	СтруктуруАдреса.Вставить("street",			"streetType");      // Улица
	СтруктуруАдреса.Вставить("HouseNumber",		"houseType"); 	    // Дом 
	СтруктуруАдреса.Вставить("Apartments",		"");				// Квартира
	СтруктуруАдреса.Вставить("Buildings",		"");				// Корпус
	
	Наименование = "";
	
	Для Каждого ТекПоле Из МассивПолей Цикл
		ТекПолеСокр = "";
		Если СтруктуруАдреса.Свойство(ТекПоле, ТекПолеСокр) Тогда
			Если ЗначениеЗаполнено(ТекПолеСокр) Тогда
				КИПоПолям[ТекПоле]		= ""; 
				КИПоПолям[ТекПолеСокр]	= "";
			Иначе
				КИПоПолям[ТекПоле]		= Новый Массив;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ТипЗнч(Значение) <> Тип("Структура") Тогда
		Возврат УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(КИПоПолям);
	Иначе
		Возврат КИПоПолям;
	КонецЕсли;
	
КонецФункции

// Возвращает новый массив с заполненными данными.
//
// Параметры:
//  ТаблицаСДанными	-	ТаблицаЗначений.
//  ИменаПолей		-	Строка.
// 
// Возвращаемое значение:
//   Массив из СправочникСсылка.энргШкалыПриборовУчета.
//
Функция ВернутьНовыйМассивСЗаполненнымиДанными(ТаблицаСДанными, ИменаПолей) Экспорт
	Массив = новый Массив;
	Если СтрНайти(ИменаПолей, ",") = 0 Тогда
		
		Для Каждого ТекСтрока из ТаблицаСДанными Цикл
			Массив.Добавить(ТекСтрока[ИменаПолей]);
		КонецЦикла;		
		
	Иначе		
		
		Для Каждого ТекСтрока из ТаблицаСДанными Цикл
			НоваяСтрока = Новый Структура(ИменаПолей);
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
			Массив.Добавить(НоваяСтрока);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Массив;	
	
КонецФункции

// Получает количество недопусков для отклонения показаний.
// 
// Возвращаемое значение:
//   Число.
//
Функция ПолучитьКоличествоНедопусковДляОтклоненияПоказаний() Экспорт 	
	КонтантаКолвоНедопусков	= ЗначениеКонстанты("энргКоличествоНедопусковДляОтклоненияПоказаний");
	КолвоНедопусковПодряд	= ?(КонтантаКолвоНедопусков = 0, 99999, КонтантаКолвоНедопусков);
	
	Возврат КолвоНедопусковПодряд;
КонецФункции

// Очищает таблицу по условию.
//
// Параметры:
//  Таблица				-	ДанныеФормыКоллекция.
//  СтруктураУсловия	-	Структура.
//
Процедура ОчиститьТаблицуПоУсловию(Таблица, СтруктураУсловия) Экспорт
	МассивУдаляемыхСтрок = Таблица.НайтиСтроки(СтруктураУсловия);
	УдалитьМассивСтрокИзТаблицы(Таблица, МассивУдаляемыхСтрок);	
КонецПроцедуры

// Удаляет массив строк из таблицы.
//
// Параметры:
//  Таблица					-	ДанныеФормыКоллекция.
//  МассивУдаляемыхСтрок	-	Массив из ДанныеФормыЭлементКоллекции.
//
Процедура УдалитьМассивСтрокИзТаблицы(Таблица, МассивУдаляемыхСтрок) Экспорт
	Для Каждого СтрокаУдаления из МассивУдаляемыхСтрок Цикл
		Таблица.Удалить(СтрокаУдаления);
	КонецЦикла;
КонецПроцедуры

// Очищает данные показаний по точке учета.
//
// Параметры:
//  ИдентификаторСтроки	-	УникальныйИдентификатор.
//  ТаблицаТочек		-	ДанныеФормыКоллекция.
//  ТаблицаШкал			-	ДанныеФормыКоллекция.
//  ТаблицаПоказаний	-	ДанныеФормыКоллекция.
//
Процедура ОчиститьДанныеПоказанийПоТочкеУчета(ИдентификаторСтроки, ТаблицаТочек, ТаблицаШкал, ТаблицаПоказаний) Экспорт
	СтрокаТочкиУчета = ТаблицаТочек.НайтиСтроки(Новый Структура("IDСтроки", ИдентификаторСтроки));
	Для Каждого ТекСтрокаТочки из СтрокаТочкиУчета Цикл 
		СтрокиШкал = ТаблицаШкал.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекСтрокаТочки.IDСтроки));
		Для Каждого ТекСтрокаШкалы из СтрокиШкал Цикл
			ОчиститьТаблицуПоУсловию(ТаблицаПоказаний, Новый Структура("IDСтроки", ТекСтрокаШкалы.IDСтроки));
		КонецЦикла;
		УдалитьМассивСтрокИзТаблицы(ТаблицаШкал, СтрокиШкал);
	КонецЦикла;
	УдалитьМассивСтрокИзТаблицы(ТаблицаТочек, СтрокаТочкиУчета);
КонецПроцедуры

// Удаляет временные файлы
//
// Параметры:
//  ВременныеФайлы	-	Массив из Строк.
//
Процедура УдалитьВременныеФайлы(ВременныеФайлы) Экспорт
	Для Каждого ТекАдресВрменногоХранилища из ВременныеФайлы Цикл
		УдалитьИзВременногоХранилища(ТекАдресВрменногоХранилища);
	КонецЦикла;	
КонецПроцедуры

// Удаляет файлы по указанному пути.
//
// Параметры:
//  ВременныеФайлы	-	Массив из Строк.
//
Процедура УдалитьФайлыПоПути(ВременныеФайлы) Экспорт
	Для Каждого ПутьФайла из ВременныеФайлы Цикл
		УдалитьФайлы(ПутьФайла);
	КонецЦикла;	
КонецПроцедуры

// Дополняет список значений.
//
// Параметры:
//  СписокРезультат	-	СписокЗначений.
//  СписокИсточник	-	СписокЗначений, Массив.
//
Процедура ДополнитьСписокЗначений(СписокРезультат, СписокИсточник) Экспорт  
	
	Если ТипЗнч(СписокИсточник) = Тип("СписокЗначений") Тогда
		 ДополнитьСписокЗначенийИзСпискаЗначений(СписокРезультат, СписокИсточник)
	 ИначеЕсли ТипЗнч(СписокИсточник) = Тип("Массив") Тогда
		 ДополнитьСписокЗначенийИзМассива(СписокРезультат, СписокИсточник)
	 КонецЕсли;
	 
КонецПроцедуры

// Дополняет список значений из списка значений.
//
// Параметры:
//  СписокРезультат	 - 	СписокЗначений.
//  СписокИсточник	 - 	СписокЗначений.
//
Процедура ДополнитьСписокЗначенийИзСпискаЗначений(СписокРезультат, СписокИсточник) Экспорт  
	
	Для Каждого ЭлементСписка Из СписокИсточник Цикл
		СписокРезультат.Добавить(
			ЭлементСписка.Значение, 
			ЭлементСписка.Представление, 
			ЭлементСписка.Пометка, 
			ЭлементСписка.Картинка);
	КонецЦикла;
	
КонецПроцедуры

// Дополняет список значений из массива.
//
// Параметры:
//  СписокРезультат	-	СписокЗначений
//  СписокИсточник	-	Массив.
//
Процедура ДополнитьСписокЗначенийИзМассива(СписокРезультат, СписокИсточник) Экспорт  
	
	Для Каждого ЭлементСписка Из СписокИсточник Цикл
		СписокРезультат.Добавить(ЭлементСписка);
	КонецЦикла;
	
КонецПроцедуры

// Обновляет адрес коллекция.
//
// Параметры:
//  ОбъектыФормы		 - 	ДанныеФормыСтруктура.
//  ИмяКоллекции		 - 	Строка.
//  ТолькоПустыеАдреса	 - 	Булево.
//
Процедура ОбновитьАдресКоллекция(ОбъектыФормы, ИмяКоллекции, ТолькоПустыеАдреса) Экспорт 
	
	ДанныеТабЧасти 					= Новый ТаблицаЗначений;
	ДанныеТабЧасти.Колонки.Добавить("ИдентификаторСтроки",Новый ОписаниеТипов("Число"));
	ДанныеТабЧасти.Колонки.Добавить("Абонент",Новый ОписаниеТипов("СправочникСсылка.энргАбоненты"));
	
	Для Каждого СтрокаТабЧасти Из ОбъектыФормы[ИмяКоллекции] Цикл
		Если ТолькоПустыеАдреса И НЕ ПустаяСтрока(СтрокаТабЧасти.Адрес) Тогда
			Продолжить;
		КонецЕсли; 		
		
		Строка 						= ДанныеТабЧасти.Добавить();
		Строка.Абонент 				= СтрокаТабЧасти.Абонент;
		Строка.ИдентификаторСтроки  = СтрокаТабЧасти.ПолучитьИдентификатор();		
	КонецЦикла;
	
	Текст 							=
	"ВЫБРАТЬ
	|	ДанныеТабЧасти.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	ДанныеТабЧасти.Абонент КАК Абонент
	|ПОМЕСТИТЬ ДанныеТабЧасти
	|ИЗ
	|	&ДанныеТабЧасти КАК ДанныеТабЧасти
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеТабЧасти.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	энргАбонентыКонтактнаяИнформация.Представление КАК Адрес
	|ИЗ
	|	ДанныеТабЧасти КАК ДанныеТабЧасти
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
	|		ПО ДанныеТабЧасти.Абонент = энргАбонентыКонтактнаяИнформация.Ссылка
	|			И (энргАбонентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес))
	|			И (энргАбонентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресОбъекта))";
	
	Запрос  						= Новый Запрос(Текст);
	Запрос.УстановитьПараметр("ДанныеТабЧасти"		, ДанныеТабЧасти);	
	Результат 						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		 Строка  					= ОбъектыФормы[ИмяКоллекции].НайтиПоИдентификатору(Выборка.ИдентификаторСтроки);
		 Строка.Адрес 				= Выборка.Адрес;
	КонецЦикла;
	
КонецПроцедуры

// Получает первые цифры строки.
//
// Параметры:
//  ВходнаяСтрока	-	Строка.
// 
// Возвращаемое значение:
//   Строка.
//
Функция ПолучитьСтрокуТолькоПервыеЦифры(ЗНАЧ ВходнаяСтрока)Экспорт 
	
	РезультатТолькоПервыеЦифры = ""; 
	ИндексЭлемента = 1; 
	ДоступныеСимволы = "0123456789"; 
	
	Пока ИндексЭлемента <= СтрДлина(ВходнаяСтрока) Цикл
		
		ПроверяемыйСимвол = Сред(ВходнаяСтрока, ИндексЭлемента, 1); 
		
		Если СтрНайти(ДоступныеСимволы, ПроверяемыйСимвол) = 0 Тогда 
			Если ЗначениеЗаполнено(РезультатТолькоПервыеЦифры) Тогда Прервать; КонецЕсли; 
			ВходнаяСтрока = СтрЗаменить(ВходнаяСтрока, ПроверяемыйСимвол, ""); 
			Продолжить; 
		Иначе 
			РезультатТолькоПервыеЦифры = РезультатТолькоПервыеЦифры + ПроверяемыйСимвол; 
		КонецЕсли; 
		
		ИндексЭлемента = ИндексЭлемента + 1; 
		
	КонецЦикла; 
	
	Возврат РезультатТолькоПервыеЦифры; 
	
КонецФункции

// Получает склонения объекта.
//
// Параметры:
//  ОбъектСклонения	-	ОпределяемыйТип.ОбъектСклонения.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ПолучитьСклоненияОбъекта(ОбъектСклонения) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СклоненияПредставленийОбъектов.ИменительныйПадеж КАК ИменительныйПадеж,
		|	СклоненияПредставленийОбъектов.РодительныйПадеж КАК РодительныйПадеж,
		|	СклоненияПредставленийОбъектов.ДательныйПадеж КАК ДательныйПадеж,
		|	СклоненияПредставленийОбъектов.ВинительныйПадеж КАК ВинительныйПадеж,
		|	СклоненияПредставленийОбъектов.ТворительныйПадеж КАК ТворительныйПадеж,
		|	СклоненияПредставленийОбъектов.ПредложныйПадеж КАК ПредложныйПадеж
		|ИЗ
		|	РегистрСведений.СклоненияПредставленийОбъектов КАК СклоненияПредставленийОбъектов
		|ГДЕ
		|	СклоненияПредставленийОбъектов.Объект = &Объект";
	
	Запрос.УстановитьПараметр("Объект", ОбъектСклонения);
	
	Возврат Запрос.Выполнить();
	
КонецФункции

#Область Макросы

// Выполняет макрос.
//
// Параметры:
//  Объект				-	СправочникСсылка.макрМакросы.
//  НаименованиеМакроса	-	Строка.
//  ИсполняемыйКод		-	Строка.
//  МакросТаблица		-	Булево.
// 
// Возвращаемое значение:
//   Строка.
//
Функция ВыполнитьМакрос(Объект, НаименованиеМакроса, ИсполняемыйКод, МакросТаблица = Ложь) Экспорт
	
	Результат="";
	
	Попытка 
		Выполнить(ИсполняемыйКод);
	Исключение
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Некорректно настроен макрос: " + НаименованиеМакроса;
		Сообщение.Сообщить();
		Возврат NULL;
	КонецПопытки;
	Если МакросТаблица Тогда
		Возврат Результат;
	Иначе
		Возврат Строка(Результат);
	КонецЕсли;
		
КонецФункции

// Получает печатную форму.
//
// Параметры:
//  Ссылка	-	СправочникСсылка.макрПечатныеФормы.
// 
// Возвращаемое значение:
//   ХранилищеЗначения.
//
Функция ПолучитьПечатнуюФорму(Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	макрПечатныеФормы.ПечатнаяФорма
	|ИЗ
	|	Справочник.макрПечатныеФормы КАК макрПечатныеФормы
	|ГДЕ
	|	макрПечатныеФормы.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ПечатнаяФорма = Выборка.ПечатнаяФорма; 
		Если ТипЗнч(ПечатнаяФорма) = Тип("ХранилищеЗначения") Тогда
			Возврат ПечатнаяФорма.Получить();
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Получает макросы объекта.
//
// Параметры:
//  ОбъектСсылка	-	СправочникСсылка.макрМакросы.
// 
// Возвращаемое значение:
//   Массив из Структура.
//
Функция ПолучитьМакросыОбъекта(ОбъектВладелец=Неопределено) Экспорт
	
	МакросыИКоды = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	макрМакросыВладельцыМакроса.Ссылка КАК МакросСсылка,
	               |	макрМакросыВладельцыМакроса.Ссылка.Наименование КАК МакросНаименование
	               |ПОМЕСТИТЬ ВТ_МакросыВладельца
	               |ИЗ
	               |	Справочник.макрМакросы.ВладельцыМакроса КАК макрМакросыВладельцыМакроса
	               |ГДЕ
	               |	ТИПЗНАЧЕНИЯ(макрМакросыВладельцыМакроса.ОбъектВладелец.СсылкаНаОбъект) = ТИПЗНАЧЕНИЯ(&ОбъектВладелец)
	               |	И НЕ макрМакросыВладельцыМакроса.Ссылка.ПометкаУдаления
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	макрМакросы.Ссылка,
	               |	макрМакросы.Наименование
	               |ИЗ
	               |	Справочник.макрМакросы КАК макрМакросы
	               |ГДЕ
	               |	макрМакросы.ВсеОбъекты
	               |	И НЕ макрМакросы.ПометкаУдаления
	               |;
	               |
	               |
	               |ВЫБРАТЬ
	               |	макрКодыМакросов.ИсполняемыйКод,
	               |	ВТ_МакросыВладельца.МакросСсылка,
	               |	ВТ_МакросыВладельца.МакросНаименование
	               |ИЗ
	               |	РегистрСведений.макрКодыМакросов КАК макрКодыМакросов
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МакросыВладельца КАК ВТ_МакросыВладельца
	               |		ПО макрКодыМакросов.Макрос = ВТ_МакросыВладельца.МакросСсылка";
	Запрос.УстановитьПараметр("ОбъектВладелец", ОбъектВладелец);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл;
		СтруктураЗначений = Новый Структура;
		СтруктураЗначений.Вставить("МакросСсылка",   Выборка.МакросСсылка);
		СтруктураЗначений.Вставить("ИсполняемыйКод", Выборка.ИсполняемыйКод);
		СтруктураЗначений.Вставить("МакросНаименование",   Выборка.МакросНаименование);
		МакросыИКоды.Добавить(СтруктураЗначений);
	КонецЦикла;
	
	Возврат МакросыИКоды;
	
КонецФункции

Процедура ПолучитьЗначенияРеквизитов(Класс = "Справочник", Ссылка, Соответствие) Экспорт 
	
	ИмяОбъектаМетаданных = Ссылка.Метаданные().Имя; 
	
	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ";
	Для Каждого КлючИЗначение Из Соответствие Цикл
		ТекстЗапроса = ТекстЗапроса + Символы.ПС + ИмяОбъектаМетаданных + "." + КлючИЗначение.Ключ + " КАК " + СтрЗаменить(КлючИЗначение.Ключ, ".", "_1_") + ",";
	КонецЦикла;
	ТекстЗапроса = Лев(ТекстЗапроса, СтрДлина(ТекстЗапроса)-1);
	
	ТекстЗапроса = ТекстЗапроса + Символы.ПС + "ИЗ";
	ТекстЗапроса = ТекстЗапроса + Символы.ПС + Класс + "." + ИмяОбъектаМетаданных + " КАК " + ИмяОбъектаМетаданных;
	ТекстЗапроса = ТекстЗапроса + Символы.ПС + " ГДЕ ";
	ТекстЗапроса = ТекстЗапроса + Символы.ПС + ИмяОбъектаМетаданных + ".Ссылка = &Ссылка";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
	Исключение
		Возврат;
	КонецПопытки;

	Если Выборка.Следующий() Тогда
		Для Каждого КлючИЗначение Из Соответствие Цикл
			Соответствие[КлючИЗначение.Ключ] = Выборка[СтрЗаменить(КлючИЗначение.Ключ, ".", "_1_")];
		КонецЦикла;
	КонецЕсли;
		
КонецПроцедуры

// Заменяет макросы печати.
//
// Параметры:
//  ОбъектСсылка	-	СправочникСсылка.макрМакросы.
//  ПутьКФайлу		-	Строка.
//
Процедура ЗаменитьМакросыПечати(ОбъектСсылка, ПутьКФайлу) экспорт
	COMОбъект = ПолучитьCOMОбъект(ПутьКФайлу);	
	COMДокумент = COMОбъект.Application.Documents(1);
	МакросыОбъекта = энргОбщегоНазначения.ПолучитьМакросыОбъекта(ОбъектСсылка);
	МассивЗакладки= Новый Массив;
	Если COMДокумент.Bookmarks.Count >= 1 Тогда   
		Для инд=1 по COMДокумент.Bookmarks.Count Цикл
			МассивЗакладки.Добавить(COMДокумент.Bookmarks(инд).Name);
		КонецЦикла;
	КонецЕсли;
	Для Каждого Стр Из МакросыОбъекта Цикл
		Если энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.МакросСсылка,"ВерхнийКолонтитул") Тогда
			Замена = COMДокумент.Sections(1).Headers(энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.МакросСсылка,"НомерВерхнегоКолонтитула")).Range;
		ИначеЕсли энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.МакросСсылка,"НижнийКолонтитул") Тогда
			Замена = COMДокумент.Sections(1).Footers(энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.МакросСсылка,"НомерНижнегоКолонтитула")).Range;
		Иначе
			Замена = COMДокумент.Content;
		КонецЕсли;
		Если энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.МакросСсылка,"ИскатьВТаблицах") и энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.МакросСсылка,"НомерТаблицы") <> 0 Тогда
			Замена = Замена.Tables(энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.МакросСсылка,"НомерТаблицы")).Range;
		КонецЕсли;
		Замена = Замена.Find;
		Результат = энргОбщегоНазначения.ВыполнитьМакрос(ОбъектСсылка, Стр.МакросНаименование, Стр.ИсполняемыйКод, Ложь);
		
		Если Результат = NULL Тогда Продолжить; КонецЕсли;
		
		МаксДлина = 255;proceed="§§§";
		
		Если СтрДлина(Результат)<МаксДлина Тогда
			Замена.Execute(Стр.МакросНаименование, Ложь, Истина, Ложь, , , Истина, , Ложь, Результат,2);
		Иначе
			МассивСтрок = Новый Массив; Инд=0;
			Пока СтрДлина(Результат)>МаксДлина Цикл
				РазбитаяСтрока = Лев(Результат, МаксДлина-3);
				ПоследнийСимвол = Прав(РазбитаяСтрока, 1);
				Если ПоследнийСимвол = "^" Тогда
					МассивСтрок.Добавить(Лев(Результат, МаксДлина-4));
					Результат = Сред(Результат, СтрДлина(МассивСтрок[Инд]+1));
				Иначе
					МассивСтрок.Добавить(Лев(Результат, МаксДлина-3));
					Результат = Сред(Результат, СтрДлина(МассивСтрок[Инд]+1));
				КонецЕсли;				
				Инд = Инд + 1;
			КонецЦикла;
			Если СтрДлина(Результат)>0 Тогда МассивСтрок.Добавить(Результат); КонецЕсли;
			Для Инд=0 По МассивСтрок.Количество()-2 Цикл 
				МассивСтрок[Инд]=МассивСтрок[Инд]+proceed; 
			КонецЦикла;
			Замена.Execute(Стр.МакросНаименование, Ложь, Истина, Ложь, , , Истина, , Ложь, МассивСтрок[0],2);
			Для Инд=1 По МассивСтрок.Количество()-1 Цикл
				Замена.Execute(proceed, Ложь, Истина, Ложь, , , Истина, , Ложь, МассивСтрок[Инд],2);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ИмяЗакладки из МассивЗакладки Цикл
		СтруктураМакроса =  энргОбщегоНазначения.ПолучитьКодМакросаПоЗакладке(ИмяЗакладки, ОбъектСсылка);
		Результат = энргОбщегоНазначения.ВыполнитьМакрос(ОбъектСсылка, ИмяЗакладки, СтруктураМакроса.ИсполняемыйКод, Истина);
		
		COMДокумент.Bookmarks(ИмяЗакладки).Select();
		
		Табл= COMДокумент.Application.Selection.Range;
		СтрокаТаблицы = "";
		Для каждого стр из Результат Цикл
			Для каждого КолонкаТЗ из стр Цикл
				СтрокаТаблицы = СтрокаТаблицы + КолонкаТЗ + "*";
			КонецЦикла;
			Табл.InsertAfter(Лев(СтрокаТаблицы, СтрДлина(СтрокаТаблицы) - 1));
			Табл.InsertParagraphAfter();
			СтрокаТаблицы = "";
		КонецЦикла;
		
		Табл.ConvertToTable("*");
		НомерФормируемойТаблицы =	COMДокумент.Range(0, Табл.Tables(1).Range.End).Tables.Count;
		COMДокумент.Tables(НомерФормируемойТаблицы).AutoFormat(16);
	КонецЦикла;
КонецПроцедуры

// Получает код макроса по закладке.
//
// Параметры:
//  ИмяЗакладки		-	Строка.
//  ОбъектСсылка	-	СправочникСсылка.макрМакросы.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ПолучитьКодМакросаПоЗакладке(ИмяЗакладки, ОбъектСсылка) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	макрМакросыВладельцыМакроса.Ссылка КАК МакросСсылка
	|ПОМЕСТИТЬ ВТ_МакросыВладельца
	|ИЗ
	|	Справочник.макрМакросы.ВладельцыМакроса КАК макрМакросыВладельцыМакроса
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(макрМакросыВладельцыМакроса.ОбъектВладелец.СсылкаНаОбъект) = ТИПЗНАЧЕНИЯ(&ОбъектВладелец)
	|	И НЕ макрМакросыВладельцыМакроса.Ссылка.ПометкаУдаления
	|	И макрМакросыВладельцыМакроса.Ссылка.Наименование = &Наименование
	|	И макрМакросыВладельцыМакроса.Ссылка.ФормированиеТаблицы
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	макрМакросы.Ссылка
	|ИЗ
	|	Справочник.макрМакросы КАК макрМакросы
	|ГДЕ
	|	макрМакросы.ВсеОбъекты
	|	И НЕ макрМакросы.ПометкаУдаления
	|	И макрМакросы.Наименование = &Наименование
	|	И макрМакросы.ФормированиеТаблицы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	макрКодыМакросов.ИсполняемыйКод КАК ИсполняемыйКод,
	|	макрКодыМакросов.Макрос.НомерФормируемойТаблицы КАК НомерФормируемойТаблицы
	|ИЗ
	|	РегистрСведений.макрКодыМакросов КАК макрКодыМакросов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МакросыВладельца КАК ВТ_МакросыВладельца
	|		ПО макрКодыМакросов.Макрос = ВТ_МакросыВладельца.МакросСсылка";
	
	Запрос.УстановитьПараметр("Наименование", ИмяЗакладки);
	Запрос.УстановитьПараметр("ОбъектВладелец", ОбъектСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ВозвратСтр = Новый Структура;
		ВозвратСтр.Вставить("ИсполняемыйКод", ВыборкаДетальныеЗаписи.ИсполняемыйКод); 
		ВозвратСтр.Вставить("НомерФормируемойТаблицы", ВыборкаДетальныеЗаписи.НомерФормируемойТаблицы);
		Возврат ВозвратСтр;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

// Получает описание свойств регистра.
//
// Параметры:
//  ОбъектМетаданных	-	ОбъектМетаданных: РегистрНакопления, ОбъектМетаданных: РегистрСведений.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ПолучитьОписаниеСвойствРегистра(ОбъектМетаданных) Экспорт 
	ОписаниеОбъекта 	= Новый Структура();
		
	ОписаниеКоллекции(ОписаниеОбъекта, ОбъектМетаданных.Измерения);
	ОписаниеКоллекции(ОписаниеОбъекта, ОбъектМетаданных.Ресурсы);
	ОписаниеКоллекции(ОписаниеОбъекта, ОбъектМетаданных.Реквизиты);
	
	Возврат ОписаниеОбъекта;
КонецФункции

Функция ОписаниеКоллекции(ОписаниеОбъекта, Коллекция)
	Для Каждого ТекСвойство из Коллекция Цикл
		ОписаниеОбъекта.Вставить(ТекСвойство.Имя);
	КонецЦикла;
КонецФункции

