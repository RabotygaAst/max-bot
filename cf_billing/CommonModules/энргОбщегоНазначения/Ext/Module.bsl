//              Если в параметр Ссылка передана ссылка несуществующего объекта (битая ссылка), 
//              то все реквизиты вернутся со значением Неопределено.
//
Функция ЗначенияРеквизитовОбъекта(Ссылка, Реквизиты, ВыбратьРазрешенные = Ложь, КодЯзыка = Неопределено) Экспорт
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, Реквизиты, ВыбратьРазрешенные, КодЯзыка);	
КонецФункции

// Получает дату из строки.
//
// Параметры:
//  Стр	-	Строка.
// 
// Возвращаемое значение:
//   Дата.
//
Функция ПолучитьДатуИзСтроки(Стр) Экспорт
	
	ДатаРезультат = Дата("00010101000000");
	
	Если ПустаяСтрока(Стр) Тогда
		Возврат ДатаРезультат;
	КонецЕсли;
	
	Если Найти(Стр,".") > 0 Тогда
		
		Если Найти(Стр,":") > 0 И Найти(Стр," ") > 0 Тогда 
			МассивЧастей = ОбщегоНазначения.РазложитьСтрокуВМассивПодстрок(Стр," ");
			Возврат ПолучитьДатуИзСтроки(МассивЧастей[0]);
		КонецЕсли;
		
		МассивЧастей = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр,".");
		
	ИначеЕсли Найти(Стр,"/")>0 Тогда
		
		МассивЧастей = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр,"/");
		
	ИначеЕсли Найти(Стр,",")>0 Тогда
		
		МассивЧастей = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр,",");
		
	ИначеЕсли Найти(Стр,"-")>0 Тогда
		
		МассивЧастей = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр,"-");
		
	КонецЕсли; 
	
	Попытка
		
		Если МассивЧастей.Количество() = 3 Тогда //"01.02.13" или "01.02.2013"
			Год = ?(СтрДлина(МассивЧастей[2]) = 2,2000 + МассивЧастей[2],МассивЧастей[2]);
			ДатаРезультат = Дата(Год,МассивЧастей[1],МассивЧастей[0]);
		ИначеЕсли МассивЧастей.Количество() = 2 Тогда //"02.13" или "02.2013";
			Год = ?(СтрДлина(МассивЧастей[1]) = 2,2000 + МассивЧастей[1],МассивЧастей[1]);
			ДатаРезультат = Дата(Год,МассивЧастей[0],1);
		КонецЕсли;
		
	Исключение
	КонецПопытки; 
	
	Возврат ДатаРезультат; 
	
КонецФункции
 
