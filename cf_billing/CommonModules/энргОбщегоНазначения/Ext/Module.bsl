#Область ПрограммныйИнтерфейс

// Устанавливает параметры сеансов.
//
// Параметры:
//  ИмяПараметра			-	Строка.
//  УстановленныеПараметры	-	Массив из Строка.
//
Процедура УстановкаПараметровСеанса(ИмяПараметра, УстановленныеПараметры) Экспорт
	Если ИмяПараметра = "энргДоступныеРайоны" Тогда
		
		УстановленныеПараметры.Добавить("энргДоступныеРайоны");
		
		ПараметрыСеанса.энргДоступныеРайоны = ДоступныеРайоны(Пользователи.ТекущийПользователь());
		
	КонецЕсли;
КонецПроцедуры

// Возвращает контрольную сумму.
//
// Параметры:
//  ОписаниеПараметров	-	Структура.
// 
// Возвращаемое значение:
//   Число.
//
Функция КонтрольнаяСумма(ОписаниеПараметров) Экспорт 
	Хэш = Новый ХешированиеДанных(ХешФункция.CRC32);
	Хэш.Добавить(ЗначениеВСтрокуВнутр(ОписаниеПараметров));
	Возврат Хэш.ХешСумма;
КонецФункции

// Возвращает значение константы.
//
// Параметры:
//  ИмяКонстанты	-	Строка.
// 
// Возвращаемое значение:
//   Произвольный	-	значение константы.
//
Функция ЗначениеКонстанты(ИмяКонстанты) Экспорт 
		
	Результат 						= Константы[ИмяКонстанты].Получить();
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат("ЗначениеКонстанты." + ИмяКонстанты + "", Результат)
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает значение функциональной опции.
//
// Параметры:
//  ИмяОпции	-	Строка.
//  Параметры	-	Структура.
// 
// Возвращаемое значение:
//   Произвольный	-	значения функциональной опции.
//
Функция ЗначениеФункциональнойОпции(ИмяОпции, Параметры = Неопределено) Экспорт 
			
	Если Параметры = Неопределено Тогда
		Результат 					= ПолучитьФункциональнуюОпцию(ИмяОпции); 		
	Иначе
		Результат 					= ПолучитьФункциональнуюОпцию(ИмяОпции, Параметры);
	КонецЕсли;	
	  	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат("ЗначениеФункциональнойОпции." + ИмяОпции + "", Результат)
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Устанавливает управляемую блокировку.
//
// Параметры:
//  СтруктураПараметров			-	Структура.
//  КоллекцияЗначенийБлокировки	-	Структура
//  							-	Соответствие.
//  КоллекцияОписанияИсточника	-	Структура
//  							-	Соответствие.
//  Отказ						-	Булево.
//  Заголовок					-	Строка.
//
Процедура УстановитьУправляемуюБлокировку(СтруктураПараметров, КоллекцияЗначенийБлокировки = Неопределено, КоллекцияОписанияИсточника = Неопределено, Отказ = Ложь, Заголовок = "") Экспорт

	Если НЕ ТипЗнч(СтруктураПараметров) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	ИспользоватьЗначенияБлокировки = КоллекцияЗначенийБлокировки <> Неопределено
		И (ТипЗнч(КоллекцияЗначенийБлокировки) = Тип("Структура")
			ИЛИ ТипЗнч(КоллекцияЗначенийБлокировки) = Тип("Соответствие"))
		И КоллекцияЗначенийБлокировки.Количество() > 0;

	ИспользоватьИсточникДанных     = КоллекцияОписанияИсточника <> Неопределено
		И (ТипЗнч(КоллекцияОписанияИсточника) = Тип("Структура")
			ИЛИ ТипЗнч(КоллекцияОписанияИсточника) = Тип("Соответствие"))
		И КоллекцияОписанияИсточника.Количество() > 0
		И СтруктураПараметров.Свойство("ИсточникДанных");

	Если НЕ ИспользоватьЗначенияБлокировки И НЕ ИспользоватьИсточникДанных Тогда
		Возврат;
	КонецЕсли;

	Блокировка = Новый БлокировкаДанных;

	ТипТаблицы = ?(СтруктураПараметров.Свойство("ТипТаблицы"), СтруктураПараметров.ТипТаблицы, "РегистрНакопления");
	ИмяТаблицы = СтруктураПараметров.ИмяТаблицы;
	ПространствоБлокировки = ТипТаблицы  + ?(ИмяТаблицы ="","",".")  + ИмяТаблицы;
	ЭлементБлокировки = Блокировка.Добавить(ПространствоБлокировки);

	РежимБлокировки = ?(СтруктураПараметров.Свойство("РежимБлокировки"), СтруктураПараметров.РежимБлокировки, РежимБлокировкиДанных.Исключительный);
	ЭлементБлокировки.Режим = РежимБлокировки;

	Если ИспользоватьЗначенияБлокировки Тогда

		Для каждого ЭлементКоллекции Из КоллекцияЗначенийБлокировки Цикл
			Если ЭлементКоллекции.Значение = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ЭлементБлокировки.УстановитьЗначение(ЭлементКоллекции.Ключ, ЭлементКоллекции.Значение);

		КонецЦикла;

	КонецЕсли;

	Если ИспользоватьИсточникДанных Тогда

		ИсточникДанных = СтруктураПараметров.ИсточникДанных;

		Если ТипЗнч(ИсточникДанных) = Тип("МенеджерВременныхТаблиц") Тогда

			Запрос = Новый Запрос;
			Запрос.МенеджерВременныхТаблиц = ИсточникДанных;
			ТекстЗапроса = "";
			Для каждого ЭлементКоллекции Из КоллекцияОписанияИсточника Цикл
				ТекстЗапроса = ТекстЗапроса + ",
				|	Таб." + ЭлементКоллекции.Значение;
			КонецЦикла;
			ТекстЗапроса = Сред(ТекстЗапроса, 2);
			ТекстЗапроса =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ"
			+ ТекстЗапроса + "
			|ИЗ
			|	" + СтруктураПараметров.ИмяВременнойТаблицы + " КАК Таб";
			Запрос.Текст = ТекстЗапроса;
			Результат    = Запрос.Выполнить();

			ЭлементБлокировки.ИсточникДанных = Результат;

		Иначе

			ЭлементБлокировки.ИсточникДанных = ИсточникДанных;

		КонецЕсли;

		Для каждого ЭлементКоллекции Из КоллекцияОписанияИсточника Цикл

			ЭлементБлокировки.ИспользоватьИзИсточникаДанных(ЭлементКоллекции.Ключ, ЭлементКоллекции.Значение);

		КонецЦикла;

	КонецЕсли;

	Попытка

		Блокировка.Заблокировать();

	Исключение

		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		ОписаниеОшибки = ИнформацияОбОшибке();
		ЗаписьЖурналаРегистрации(НСТр("ru = 'Операция не выполнена'"), УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки.Описание);
		ВызватьИсключение НСтр("ru='Операция не выполнена'");

	КонецПопытки;

КонецПроцедуры

// Возвращает банковские реквизиты организации.
// 
// Возвращаемое значение:
//   Структура.
//
Функция БанковскиеРеквизитыОрганизации() Экспорт 
	БанковскиеРеквизиты 	= Новый Структура;
	Запрос  				= Новый Запрос;
	Запрос.Текст 	="ВЫБРАТЬ ПЕРВЫЕ 1
	|	Организации.ОсновнойБанковскийСчет,
	|	Организации.Наименование КАК НаименованиеОрганизации,
	|	Организации.ИНН КАК ИННОрганизации,
	|	Организации.энргНаименованиеОперацииОплаты
	|ПОМЕСТИТЬ ПерваяОрганизация
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	НЕ Организации.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БанковскиеСчета.Банк,
	|	ПерваяОрганизация.НаименованиеОрганизации,
	|	ПерваяОрганизация.ИННОрганизации,
	|	БанковскиеСчета.НомерСчета КАК НомерСчетаОрганизации,
	|	ПерваяОрганизация.энргНаименованиеОперацииОплаты
	|ПОМЕСТИТЬ ОсновнойСчет
	|ИЗ
	|	ПерваяОрганизация КАК ПерваяОрганизация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчета
	|		ПО ПерваяОрганизация.ОсновнойБанковскийСчет = БанковскиеСчета.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Банки.КоррСчет КАК КоррСчетБанка,
	|	Банки.Код КАК БИКБанка,
	|	ОсновнойСчет.НаименованиеОрганизации,
	|	ОсновнойСчет.ИННОрганизации,
	|	ОсновнойСчет.НомерСчетаОрганизации,
	|	Банки.КоррСчет,
	|	ОсновнойСчет.энргНаименованиеОперацииОплаты КАК НазначениеПлатежа
	|ИЗ
	|	ОсновнойСчет КАК ОсновнойСчет
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Банки КАК Банки
	|		ПО ОсновнойСчет.Банк = Банки.Ссылка";
	
	Результат 		= Запрос.Выполнить();
	Выборка  		= Результат.Выбрать();
	Выборка.Следующий();
	
	для Каждого КолонкаРезультат из Результат.Колонки цикл
		 БанковскиеРеквизиты.Вставить(КолонкаРезультат.Имя,Выборка[КолонкаРезультат.Имя]);
	КонецЦикла;
	
	Возврат  БанковскиеРеквизиты;
КонецФункции

// Проверяет наличие присоединенных файлов.
//
// Параметры:
//  ИмяСправочникаХранилищаФайлов	-	Строка.
//  ВладелецФайла					-	СправочникСсылка.
// 
// Возвращаемое значение:
//   Булево.
//
Функция НаличиеПрисоединенныхФайлов(ИмяСправочникаХранилищаФайлов, ВладелецФайла) Экспорт
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Файлы.Ссылка) КАК Ссылка,
	|	Файлы.ВладелецФайла КАК ВладелецФайла
	|ИЗ
	|	&ИмяСправочника КАК Файлы
	|ГДЕ
	|	Файлы.ВладелецФайла = &ВладелецФайлов
	|	И НЕ Файлы.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	Файлы.ВладелецФайла";
	
	ПолноеИмяСправочника = "Справочник." + ИмяСправочникаХранилищаФайлов;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИмяСправочника", ПолноеИмяСправочника);
	
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("ВладелецФайлов", ВладелецФайла);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Если РезультатЗапроса.Количество() > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Устанавливает список маршрутов контролера.
//
// Параметры:
//  Контролер			-	СправочникСсылка.энргСотрудники.
//  МаршрутКонтроллера	-	СправочникСсылка.энргМаршрутыКонтроллеров.
//  Элемент				-	СправочникСсылка.энргМаршрутыКонтроллеров.
//  МКД					-	СправочникСсылка.энргСтроения.
//
Процедура УстановитьСписокМаршрутовКонтролера(Контролер,МаршрутКонтроллера,Элемент, МКД = Неопределено) Экспорт	

	Если ЗначениеЗаполнено(МКД) Тогда
		МаршрутКонтроллера = МКД.МаршрутКонтроллера;
		Если ЗначениеЗаполнено(МаршрутКонтроллера) Тогда
			Контролер = МаршрутКонтроллера.Владелец;
		КонецЕсли;
	КонецЕсли;
	
	ДоступныеМаршруты 	 = ДоступныеМаршруты(Контролер);
	
	Если ДоступныеМаршруты.Количество() = 1 тогда
		МаршрутКонтроллера	= ДоступныеМаршруты[0];		
		Элемент.Вид 		= ВидПоляФормы.ПолеНадписи;
	ИначеЕсли ДоступныеМаршруты.Количество() > 1 тогда
		МаршрутКонтроллера	= Справочники.энргМаршрутыКонтроллеров.ПустаяСсылка();
		Элемент.Вид 		= ВидПоляФормы.ПолеВвода;
		Элемент.РежимВыбораИзСписка = Истина;
		Элемент.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
		Элемент.СписокВыбора.ЗагрузитьЗначения(ДоступныеМаршруты);
	Иначе 
		МаршрутКонтроллера	= Справочники.энргМаршрутыКонтроллеров.ПустаяСсылка();
		Элемент.Вид 		= ВидПоляФормы.ПолеВвода;
		Элемент.РежимВыбораИзСписка = Истина;
		Элемент.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
		Элемент.СписокВыбора.Очистить();
	КонецЕсли;
	
КонецПроцедуры

// Устанавливает доступность элементов по ролям.
//
// Параметры:
//  Форма				-	ФормаКлиентскогоПриложения.
//  СписокЭлементов		-	Структура.
//  ОбъектМетаданных	-	ОбъектМетаданных: Справочник
//						-	ОбъектМетаданных: Документ
//						-	ОбъектМетаданных: Задачи
//						-	ОбъектМетаданных: РегистрыСведений.
//  Право				-	Строка.
//
Процедура УстановитьДоступностьЭлементовПоРолям(Форма, СписокЭлементов, ОбъектМетаданных, Право = "Изменение") Экспорт 

	Если Не ПравоДоступа(Право, ОбъектМетаданных) Тогда
		Для каждого ТекЭлем Из СписокЭлементов Цикл
			Если ТекЭлем.Ключ = "ЭтаФорма" Тогда
				Форма.ТолькоПросмотр = Истина;
				Продолжить;
			КонецЕсли;
			
			Элемент = Форма.Элементы.Найти(ТекЭлем.Ключ);

			Если Элемент <> Неопределено Тогда
				Если ТипЗнч(Элемент) = Тип("КнопкаФормы") Тогда
					Элемент.Доступность    = Ложь;
				Иначе
					Элемент.ТолькоПросмотр = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

// Создает набор записей с дополнительными параметрами.
//
// Параметры:
//  МенеджерРегистраСведений	-	РегистрыСведенийМенеджер.
// 
// Возвращаемое значение:
//   РегистрСведенийЗапись.
//
Функция СоздатьНаборЗаписейСДополнительнымиПараметрами(МенеджерРегистраСведений) Экспорт 
	
	НаборЗаписей = МенеджерРегистраСведений.СоздатьНаборЗаписей();
	НаборЗаписей.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	
	Возврат НаборЗаписей;
	
КонецФункции

// Удаляет повторяющиеся элементы массива.
//
// Параметры:
//  Массив						-	Массив.
//  НеИспользоватьНеопределено	-	Булево.
// 
// Возвращаемое значение:
//   Массив.
//
Функция УдалитьПовторяющиесяЭлементыМассива(Массив, НеИспользоватьНеопределено = Ложь) Экспорт

	ОписаниеТиповСправочники  = Справочники.ТипВсеСсылки();
	ОписаниеТиповДокументы    = Документы.ТипВсеСсылки();
	ОписаниеТиповПВХ          = ПланыВидовХарактеристик.ТипВсеСсылки();
	ОписаниеТиповПланыСчетов  = ПланыСчетов.ТипВсеСсылки();
	ОписаниеТиповПланыРасчета = ПланыВидовРасчета.ТипВсеСсылки();

	Если ТипЗнч(Массив) = Тип("Массив") Тогда

		УжеВМассиве = Новый Соответствие;
		БылоНеопределено = Ложь;

		КолвоЭлементовВМассиве = Массив.Количество();

		Для ОбратныйИндекс = 1 По КолвоЭлементовВМассиве Цикл
			ЭлементМассива = Массив[КолвоЭлементовВМассиве - ОбратныйИндекс];
			ТипЭлемента = ТипЗнч(ЭлементМассива);
			Если ЭлементМассива = Неопределено Тогда
				Если БылоНеопределено или НеИспользоватьНеопределено Тогда
					Массив.Удалить(КолвоЭлементовВМассиве - ОбратныйИндекс);
				Иначе
					БылоНеопределено = Истина;
				КонецЕсли;
				Продолжить;
			ИначеЕсли ОписаниеТиповСправочники.СодержитТип(ТипЭлемента)
				ИЛИ ОписаниеТиповДокументы.СодержитТип(ТипЭлемента)
				ИЛИ ОписаниеТиповПВХ.СодержитТип(ТипЭлемента)
				ИЛИ ОписаниеТиповПланыСчетов.СодержитТип(ТипЭлемента)
				ИЛИ ОписаниеТиповПланыРасчета.СодержитТип(ТипЭлемента) Тогда

				ИДЭлемента = Строка(ЭлементМассива.УникальныйИдентификатор());

			Иначе

				ИДЭлемента = ЭлементМассива;

			КонецЕсли;

			Если УжеВМассиве[ИДЭлемента] = Истина Тогда
				Массив.Удалить(КолвоЭлементовВМассиве - ОбратныйИндекс);
			Иначе
				УжеВМассиве[ИДЭлемента] = Истина;
			КонецЕсли;
		КонецЦикла;

	КонецЕсли;

	Возврат Массив;

КонецФункции

// Возвращает доступные районы.
//
// Параметры:
//  текПользователь	-	СправочникСсылка.Пользователи.
// 
// Возвращаемое значение:
//   ФиксированныйМассив из СправочникСсылка.энргЗоныОтвественности.
//
Функция ДоступныеРайоны(текПользователь)
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Пользователь",текПользователь);
	Запрос.Текст 	="ВЫБРАТЬ
	|	энргДоступныеРайоны.Район
	|ИЗ
	|	РегистрСведений.энргДоступныеРайоны КАК энргДоступныеРайоны
	|ГДЕ
	|	энргДоступныеРайоны.Пользователь = &Пользователь";
	Результат  	= Запрос.Выполнить();
	Районы  	= Новый Массив;	
	Выборка  	= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		 Районы.Добавить(Выборка.Район);
	КонецЦикла;
	Возврат  Новый ФиксированныйМассив(Районы);
КонецФункции

// Возвращает структуру, содержащую значения реквизитов, прочитанные из информационной базы по ссылке на объект.
// Рекомендуется использовать вместо обращения к реквизитам объекта через точку от ссылки на объект
// для быстрого чтения отдельных реквизитов объекта из базы данных.
//
// Если необходимо зачитать реквизит независимо от прав текущего пользователя,
// то следует использовать предварительный переход в привилегированный режим.
//
// Параметры:
//  Ссылка    - ЛюбаяСсылка - объект, значения реквизитов которого необходимо получить.
//            - Строка      - полное имя предопределенного элемента, значения реквизитов которого необходимо получить.
//  Реквизиты - Строка - имена реквизитов, перечисленные через запятую, в формате
//                       требований к свойствам структуры.
//                       Например, "Код, Наименование, Родитель".
//            - Структура
//            - ФиксированнаяСтруктура - в качестве ключа передается
//                       псевдоним поля для возвращаемой структуры с результатом, а в качестве
//                       значения (опционально) фактическое имя поля в таблице.
//                       Если ключ задан, а значение не определено, то имя поля берется из ключа.
//                       Допускается указание имени поля через точку, но при этом параметр КодЯзыка для такого поля
//                       учитываться не будет.
//            - Массив из Строка
//            - ФиксированныйМассив из Строка - имена реквизитов в формате требований к свойствам структуры.
//  ВыбратьРазрешенные - Булево - если Истина, то запрос к объекту выполняется с учетом прав пользователя;
//                                если есть ограничение на уровне записей, то все реквизиты вернутся со 
//                                значением Неопределено; если нет прав для работы с таблицей, то возникнет исключение;
//                                если Ложь, то возникнет исключение при отсутствии прав на таблицу 
//                                или любой из реквизитов.
// Возвращаемое значение:
//  Структура - содержит имена (ключи) и значения затребованных реквизитов.
//              Если в параметр Реквизиты передана пустая строка, то возвращается пустая структура.
//              Если в параметр Ссылка передана пустая ссылка, то возвращается структура, 
//              соответствующая именам реквизитов со значениями Неопределено.
//              Если в параметр Ссылка передана ссылка несуществующего объекта (битая ссылка), 
//              то все реквизиты вернутся со значением Неопределено.
Функция ЗначениеРеквизитаОбъекта(Ссылка, ИмяРеквизита, ВыбратьРазрешенные = Ложь) Экспорт
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, ИмяРеквизита, ВыбратьРазрешенные);	
КонецФункции

