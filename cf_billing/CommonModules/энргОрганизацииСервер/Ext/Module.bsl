Процедура ДополнитьДанныеПоАбоненту(ДанныеЗаполнения)
	
	Если ДанныеЗаполнения.свойство("Абонент") и не ДанныеЗаполнения.свойство("КлючПомещения") Тогда
		ДанныеАбонента = Новый Структура("Абонент,Район,КлючПомещения,Строение,Помещение,ЧастныйСектор,ЛицевойСчет,АдресОбъекта,ПериодНачисления,Организация,ГруппаАбонента,МКД");
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ДанныеЗаполнения, ДанныеАбонента, Ложь);
		энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыАбонента(ДанныеЗаполнения.Абонент,ДанныеЗаполнения);			
	КонецЕсли;
	
КонецПроцедуры
