Процедура ОбработкаЗаполнения(ДокументОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка) Экспорт 
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		ДополнитьДанныеПоАбоненту(ДанныеЗаполнения);
		ЗаполнитьЗначенияСвойств(ДокументОбъект, ДанныеЗаполнения);	
		метТабличныеЧасти 			= ДокументОбъект.Метаданные().ТабличныеЧасти;
		Для Каждого метТабЧасть Из метТабличныеЧасти Цикл
			Если ДанныеЗаполнения.Свойство(метТабЧасть.Имя) Тогда
				Для Каждого Строка Из ДанныеЗаполнения[метТабЧасть.Имя] Цикл
					НоваяСтрока 	= ДокументОбъект[метТабЧасть.Имя].Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
				КонецЦикла;			
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ДанныеЗаполнения.Свойство("Организация") И Не ЗначениеЗаполнено(ДокументОбъект.Организация) Тогда
			ДокументОбъект.Организация  = Справочники.Организации.ОрганизацияПоУмолчанию();
		КонецЕсли;
		
	ИначеЕсли ДанныеЗаполнения = Неопределено Тогда
		ДокументОбъект.Организация  = Справочники.Организации.НашаОрганизация;
	КонецЕсли; 	
		
КонецПроцедуры

Функция ОрганизацияПоУмолчанию() Экспорт  
	
	Если Не УчетПоНесколькимОрганизация() Тогда
		Возврат Справочники.Организации.НашаОрганизация;
	КонецЕсли;
	
	Возврат Справочники.Организации.ПустаяСсылка();
КонецФункции

Функция УчетПоНесколькимОрганизация() Экспорт 
	Возврат энргОрганизацииПовтИсп.УчетПоНесколькимОрганизация();
КонецФункции

