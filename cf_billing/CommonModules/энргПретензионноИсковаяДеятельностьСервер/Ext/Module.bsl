#Область СлужебныйПрограммныйИнтерфейс

#Область РасчетГосПошлины

Функция ГосПошлина(Период,СуммаЗадолженности) Экспорт 
	
	Запрос  			= Новый Запрос;
	Запрос.УстановитьПараметр("Период",				Период);
	Запрос.УстановитьПараметр("СуммаЗадолженности",	СуммаЗадолженности);
	Запрос.Текст 		="ВЫБРАТЬ
	|	энргРазмерыГосПошлиныСрезПоследних.Период,
	|	энргРазмерыГосПошлиныСрезПоследних.СуммаЗадолженность,
	|	энргРазмерыГосПошлиныСрезПоследних.Процент,
	|	энргРазмерыГосПошлиныСрезПоследних.ФиксированнаяСумма,
	|	энргРазмерыГосПошлиныСрезПоследних.СуммаДоПревышения,
	|	энргРазмерыГосПошлиныСрезПоследних.МаксимальнаяСумма,
	|	энргРазмерыГосПошлиныСрезПоследних.МинимальнаяСумма
	|ПОМЕСТИТЬ Набор
	|ИЗ
	|	РегистрСведений.энргРазмерыГосПошлины.СрезПоследних(&Период, ) КАК энргРазмерыГосПошлиныСрезПоследних
	|ГДЕ
	|	энргРазмерыГосПошлиныСрезПоследних.Актуальность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.СуммаЗадолженность,
	|	ВложенныйЗапрос.Процент,
	|	ВложенныйЗапрос.ФиксированнаяСумма,
	|	ВложенныйЗапрос.СуммаДоПревышения,
	|	ВложенныйЗапрос.МаксимальнаяСумма,
	|	ВложенныйЗапрос.СуммаГраница,
	|	ВложенныйЗапрос.МинимальнаяСумма
	|ИЗ
	|	(ВЫБРАТЬ
	|		НаборМинСумма.СуммаЗадолженность КАК СуммаЗадолженность,
	|		НаборМинСумма.Процент КАК Процент,
	|		НаборМинСумма.ФиксированнаяСумма КАК ФиксированнаяСумма,
	|		НаборМинСумма.СуммаДоПревышения КАК СуммаДоПревышения,
	|		НаборМинСумма.МаксимальнаяСумма КАК МаксимальнаяСумма,
	|		МИНИМУМ(ВЫБОР
	|				КОГДА НаборМаксСумма.СуммаЗадолженность ЕСТЬ NULL 
	|					ТОГДА 10000000000000000000000000000000
	|				ИНАЧЕ НаборМаксСумма.СуммаЗадолженность - 1
	|			КОНЕЦ) КАК СуммаГраница,
	|		НаборМинСумма.МинимальнаяСумма КАК МинимальнаяСумма
	|	ИЗ
	|		Набор КАК НаборМинСумма
	|			ЛЕВОЕ СОЕДИНЕНИЕ Набор КАК НаборМаксСумма
	|			ПО НаборМинСумма.СуммаЗадолженность < НаборМаксСумма.СуммаЗадолженность
	|	
	|	СГРУППИРОВАТЬ ПО
	|		НаборМинСумма.СуммаЗадолженность,
	|		НаборМинСумма.Процент,
	|		НаборМинСумма.ФиксированнаяСумма,
	|		НаборМинСумма.СуммаДоПревышения,
	|		НаборМинСумма.МаксимальнаяСумма,
	|		НаборМинСумма.МинимальнаяСумма) КАК ВложенныйЗапрос
	|ГДЕ
	|	&СуммаЗадолженности МЕЖДУ ВложенныйЗапрос.СуммаЗадолженность И ВложенныйЗапрос.СуммаГраница";

	Результат = Запрос.Выполнить();
	Если Результат.Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось определить процентные ставки расчета госпошлины");
	КонецЕсли;
	
	Выборка  = Результат.Выбрать();
	Выборка.Следующий();	
	
	Процент  		= Выборка.Процент;
	Если не ЗначениеЗаполнено(Выборка.СуммаДоПревышения) тогда
		СуммаГоспошлины = СуммаЗадолженности * Выборка.Процент /100;
	иначе
		СуммаГоспошлины = (СуммаЗадолженности-Выборка.СуммаДоПревышения) * Выборка.Процент /100
	КонецЕсли;

	Если ЗначениеЗаполнено(Выборка.МинимальнаяСумма) тогда
		СуммаГоспошлины = Макс(Выборка.МинимальнаяСумма,СуммаГоспошлины);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Выборка.МаксимальнаяСумма) тогда
		СуммаГоспошлины = Мин(Выборка.МаксимальнаяСумма,СуммаГоспошлины);
	КонецЕсли;
	
	Возврат СуммаГоспошлины;
	
КонецФункции

#КонецОбласти

#Область Отправка_писем

