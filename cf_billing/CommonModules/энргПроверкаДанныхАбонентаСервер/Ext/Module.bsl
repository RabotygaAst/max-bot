// Если возвращается ложь то данного ЛС нет или он закрыт! 
// Если возвращается истина то данный ЛС открыт!
#Область ОбработчикиСобытий
Функция СостояниеЛС (Дата,Абонент, Район, Организация) ЭКСПОРТ
	Открыт = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргСостояниеЛССрезПоследних.Абонент КАК Абонент,
	|	энргСостояниеЛССрезПоследних.Состояние КАК Состояние
	|ИЗ
	|	РегистрСведений.энргСостояниеЛС.СрезПоследних(
	|			&Дата,
	|			Район = &Район
	|				И Абонент = &Абонент
	|				И Организация = &Организация) КАК энргСостояниеЛССрезПоследних";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Абонент", Абонент);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("Организация", Организация);

	// Результат  = Запрос.Выполнить();
	// Возврат Не Результат.Пустой(); 
	
		
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Открыт = Выборка.Состояние;
	КонецЦикла;
	
	Возврат Открыт;
КонецФункции

// Возвращает Точку Учета и подключенную к ней услугу.
Функция СостояниеУслугиТочкиУчета(Дата,Район,Абонент,ТочкиУчета) ЭКСПОРТ	
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета
		|ПОМЕСТИТЬ ВТ_ПодключенныеТУ
		|ИЗ
		|	РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(&Дата, ТочкаУчета.Наименование В (&Наименование)) КАК энргАктивностьТочекУчетаСрезПоследних
		|ГДЕ
		|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргУслугиТочекУчетаСрезПоследних.Абонент,
		|	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета,
		|	энргУслугиТочекУчетаСрезПоследних.Услуга
		|ИЗ
		|	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
		|			&Дата,
		|			Абонент = &Абонент
		|				И Район = &Район
		|				И ТочкаУчета В
		|					(ВЫБРАТЬ
		|						ВТ_ПодключенныеТУ.ТочкаУчета
		|					ИЗ
		|						ВТ_ПодключенныеТУ КАК ВТ_ПодключенныеТУ)) КАК энргУслугиТочекУчетаСрезПоследних";
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Район", Район);
	
	НаименованиеТУ = новый ТаблицаЗначений;
	НаименованиеТУ.Колонки.Добавить("Наименование");
	Для Каждого Строка из ТочкиУчета Цикл
		СтрокаНаименованияТУ = НаименованиеТУ.Добавить();		
		СтрокаНаименованияТУ.Наименование = Строка.НаименованиеТочки;
	КонецЦикла;
	
	Запрос.УстановитьПараметр("Наименование", НаименованиеТУ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();	
	
	// Если результат пустой значит услуги не найдены и проверку на услуги ТУ прошла! 
	// Иначе если найдены услуги подключенные к ТУ, то ТУ не прошла проверку! возвращаем ТЗ с данными о услуге и ТУ!
	
	ТУИУслуга = новый СписокЗначений;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		// Стр 		= ТУИУслуга.Добавить();
		// Стр.ТУ 		= ВыборкаДетальныеЗаписи.ТочкаУчета;
		// Стр.Услуга 	= ВыборкаДетальныеЗаписи.Услуга;
		ТУИУслуга.Добавить(ВыборкаДетальныеЗаписи.ТочкаУчета,ВыборкаДетальныеЗаписи.Услуга);
		// ТУИУслуга.Добавить(ВыборкаДетальныеЗаписи.Услуга,"Услуга");		
	КонецЦикла;	
	
	Возврат ТУИУслуга;
КонецФункции

// Если возвращается ложь то ПУ выключен! 
// Если возвращается истина то данный ПУ подключен!
// Если ПроверкаТочек = истина значит  проверяем точку на наличие прибора.  
Функция СостояниеПрибораУчета(Дата,Абонент,ЗаводскойНомер,ТипПУ,ПроверкаТочки = Ложь, ТочкаУчета = Неопределено) ЭКСПОРТ
	
	Подключен = Ложь;	 	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета,
	|	энргАктивностьТочекУчетаСрезПоследних.Абонент
	|ПОМЕСТИТЬ ВТ_ТУ
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(&Дата, Абонент В (&Абонент)) КАК энргАктивностьТочекУчетаСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.ЭнргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета КАК ПУ
	|ИЗ
	|	РегистрСведений.энргПриборыТочекУчета.СрезПоследних(
	|			&Дата,
	|			ТочкаУчета В
	|				(ВЫБРАТЬ
	|					ВТ_ТУ.ТочкаУчета
	|				ИЗ
	|					ВТ_ТУ КАК ВТ_ТУ)) КАК энргПриборыТочекУчетаСрезПоследних
	|ГДЕ
	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета.Наименование = &Наименование
	|	И энргПриборыТочекУчетаСрезПоследних.ПриборУчета.ТипПрибораУчета = &ТипПУ";
	
	Если ПроверкаТочки Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ","");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргПриборыТочекУчетаСрезПоследних.ПриборУчета.Наименование = &Наименование","");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргПриборыТочекУчетаСрезПоследних.ПриборУчета.ТипПрибораУчета = &ТипПУ","");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Абонент В (&Абонент)","Абонент В (&Абонент) И ТочкаУчета В (&ТочкаУчета)");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.ЭнргСостояниеТочекУчета.Включена)","ГДЕ   энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.ЭнргСостояниеТочекУчета.Включена)");
		Запрос.УстановитьПараметр("ТочкаУчета", ТочкаУчета);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Наименование", ЗаводскойНомер);
	Запрос.УстановитьПараметр("ТипПУ", ТипПУ);
	Запрос.УстановитьПараметр("Абонент", Абонент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.ПУ <> Справочники.энргПриборыУчетаАбонента.ПустаяСсылка() Тогда
			Подключен = Истина; 
		КонецЕсли;
	КонецЦикла;
	
	Возврат Подключен;
	
КонецФункции

Функция ПараметрыТочекУчета(ТочкиУчета) ЭКСПОРТ
	Параметры  		= Новый Структура;
	МассивТочек  	= Новый Массив;	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ТочкиУчета",ТочкиУчета);
	Запрос.Текст 	= "ВЫБРАТЬ
	|	ТочкиУчета.НомерСтроки
	|ПОМЕСТИТЬ ДанныеТУ
	|ИЗ
	|	&ТочкиУчета КАК ТочкиУчета
	|ГДЕ
	|	ТочкиУчета.ТочкаУчета = ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеТУ.НомерСтроки
	|ИЗ
	|	ДанныеТУ КАК ДанныеТУ";
	Результат  		= Запрос.Выполнить();
	Параметры.Вставить("НужноСоздаватьТочкиУчета", Не Результат.Пустой());	
	Выборка  		= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		МассивТочек.Добавить(Выборка.НомерСтроки);
	КонецЦикла;	
	Параметры.Вставить("МассивТочек",МассивТочек);
	Возврат Параметры;
КонецФункции

Функция ПараметрыПриборовУчета(ТочкиУчета) ЭКСПОРТ
	Параметры  		= Новый Структура;
	МассивТочек  	= Новый Массив;	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ТочкиУчета",ТочкиУчета);
	Запрос.Текст 	= "ВЫБРАТЬ
	             	  |	ТочкиУчета.НомерСтроки
	             	  |ПОМЕСТИТЬ ДанныеПУ
	             	  |ИЗ
	             	  |	&ТочкиУчета КАК ТочкиУчета
	             	  |ГДЕ
	             	  |	ТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
	             	  |	И ТочкиУчета.ЗаводскойНомер <> """"
	             	  |	И ТочкиУчета.КоэффициентПУ >= 1
	             	  |	И ТочкиУчета.ДатаПоверкиСчетчика <> """"
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ
	             	  |	ДанныеПУ.НомерСтроки
	             	  |ИЗ
	             	  |	ДанныеПУ КАК ДанныеПУ";
	Результат  		= Запрос.Выполнить();
	Параметры.Вставить("НужноСоздаватьПриборыУчета", Не Результат.Пустой());	
	Выборка  		= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		МассивТочек.Добавить(Выборка.НомерСтроки);
	КонецЦикла;	
	Параметры.Вставить("МассивПриборов",МассивТочек);
	Возврат Параметры;
КонецФункции

// Если ПроверкаНаНаличие = истина Тогда проверяется наличие данной точки учета!
// Иначе проверяем состояние ТУ уже имеющейся!
Функция СостояниеТУ(Дата,Абонент,Район,ТочкаУчета)  Экспорт 	
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета,
	|	энргАктивностьТочекУчетаСрезПоследних.Состояние
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
	|			&Дата,
	|			Абонент = &Абонент
	|				И Район = &Район
	|				И ТочкаУчета В (&Точки)) КАК энргАктивностьТочекУчетаСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)";
	
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("Точки", ТочкаУчета);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ТУИСостояние = новый СписокЗначений;	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ТУИСостояние.Добавить(ВыборкаДетальныеЗаписи.ТочкаУчета,ВыборкаДетальныеЗаписи.Состояние);
	КонецЦикла; 
	
	
	Возврат ТУИСостояние;
КонецФункции

Функция СостояниеМКД (Дата,Район,МКД,Организация)Экспорт
	Открыт = Ложь; 	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргСостояниеМКДСрезПоследних.Состояние КАК Состояние
	|ИЗ
	|	РегистрСведений.энргСостояниеМКД.СрезПоследних(
	|			&Дата,
	|			МКД = &МКД
	|				И Район = &Район
	|				И Организация = &Организация) КАК энргСостояниеМКДСрезПоследних";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("МКД", МКД);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Открыт = ВыборкаДетальныеЗаписи.Состояние;
	КонецЦикла;
	
	
	Возврат Открыт;
КонецФункции

Функция ЕстьОткрытыеЛСВМКД(Период,Район,Организация,МКД) Экспорт  
	
	Запрос 			= Новый Запрос;
	Запрос.УстановитьПараметр("Период",			Период);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.УстановитьПараметр("МКД",			МКД);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАбоненты.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВсеАбонентыМКД
	|ИЗ
	|	Справочник.энргАбоненты КАК энргАбоненты
	|ГДЕ
	|	энргАбоненты.Район = &Район
	|	И энргАбоненты.Организация = &Организация
	|	И энргАбоненты.КлючПомещения В
	|			(ВЫБРАТЬ
	|				энргКлючиПомещений.КлючПомещения КАК КлючПомещения
	|			ИЗ
	|				РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|			ГДЕ
	|				энргКлючиПомещений.Строение = &МКД)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеЛССрезПоследних.Абонент КАК Абонент
	|ИЗ
	|	РегистрСведений.энргСостояниеЛС.СрезПоследних(
	|			&Период,
	|			Район = &район
	|				И Организация = &Организация
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						ВсеАбонентыМКД.Ссылка
	|					ИЗ
	|						ВсеАбонентыМКД КАК ВсеАбонентыМКД)) КАК энргСостояниеЛССрезПоследних
	|ГДЕ
	|	энргСостояниеЛССрезПоследних.Состояние";
	
	Результат  = Запрос.Выполнить();
	
	Возврат не Результат.Пустой();
	
КонецФункции

Функция ПроверитьДолгАбонента (Дата,Абонент,Район,МКД) ЭКСПОРТ
	ЕстьДолг = Ложь; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(энргВзаиморасчетыОстатки.СуммаОстаток, 0) КАК Долг
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчеты.Остатки(
		|			&Дата,
		|			Абонент = &Абонент
		|				И МКД = &МКД
		|				И Район = &Район) КАК энргВзаиморасчетыОстатки";
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("МКД", МКД);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ВыборкаДетальныеЗаписи.Долг > 0 Тогда
			ЕстьДолг = Истина;
		КонецЕсли;
		
	КонецЦикла;	
		
	Возврат ЕстьДолг
КонецФункции

Функция ПроверитьОдноразовыйПароль(ЛицевойСчет, Пароль, ДатаЗапроса) Экспорт
	Валидность	= Ложь;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЛицевойСчет", 	ЛицевойСчет);
	Запрос.УстановитьПараметр("Пароль", 		Пароль);
	Запрос.УстановитьПараметр("ДатаЗапроса", 	КонецДня(ДатаЗапроса));
	ЗАпрос.Текст = "ВЫБРАТЬ
	|	бестОдноразовыеПаролиДляЛК.ЛицевойСчет КАК ЛицевойСчет,
	|	бестОдноразовыеПаролиДляЛК.Пароль КАК Пароль
	|ПОМЕСТИТЬ ВрТ0
	|ИЗ
	|	РегистрСведений.бестОдноразовыеПаролиДляЛК КАК бестОдноразовыеПаролиДляЛК
	|ГДЕ
	|	бестОдноразовыеПаролиДляЛК.ЛицевойСчет = &ЛицевойСчет
	|	И бестОдноразовыеПаролиДляЛК.Пароль = &Пароль
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВрТ0.ЛицевойСчет КАК ЛицевойСчет,
	|	ВрТ0.Пароль КАК Пароль,
	|	бестВалидностьОдноразовыхПаролейДляЛКСрезПоследних.СтатусПароля КАК СтатусПароля,
	|	бестВалидностьОдноразовыхПаролейДляЛКСрезПоследних.СрокОкончания КАК СрокОкончания
	|ИЗ
	|	ВрТ0 КАК ВрТ0
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестВалидностьОдноразовыхПаролейДляЛК.СрезПоследних(&Дата, ) КАК бестВалидностьОдноразовыхПаролейДляЛКСрезПоследних
	|		ПО ВрТ0.ЛицевойСчет = бестВалидностьОдноразовыхПаролейДляЛКСрезПоследних.ЛицевойСчет
	|			И ВрТ0.Пароль = бестВалидностьОдноразовыхПаролейДляЛКСрезПоследних.Пароль";
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Если Выборка.СтатусПароля = Перечисления.бестСтатусыПаролей.Активен и КонецДня(Выборка.СрокОкончания) >= КонецДня(ДатаЗапроса) Тогда
			Валидность = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Валидность;
КонецФункции

Функция ГенерацияОдноразовогоПароляДляЛК() Экспорт
	ПараметрыПароля = ПользователиСлужебный.ПараметрыПароля(10, Истина);
	
	НовыйПароль = ПользователиСлужебный.СоздатьПароль(ПараметрыПароля);
	
	Возврат НовыйПароль;
КонецФункции

#КонецОбласти
