#Область СлужебныйПрограммныйИнтерфейс

Функция ПараметрыВидаОперции() Экспорт
	
	ПараметрыВида = Новый Структура;
	ПараметрыВида.Вставить("Вид");
	ПараметрыВида.Вставить("ИмяДокумента");	
	Возврат ПараметрыВида;
	
КонецФункции

Функция ПрефиксФормыПоОснованию(ИмяДокумента,ТипОснования) Экспорт
	
	Если ИмяДокумента = "энргПерерасчет" тогда				
		Возврат "ИзменениеПараметраРассчета"; 				
	КонецЕсли;   
	
КонецФункции

Процедура УстановитьСвойстваВидаОперации(Параметры)  Экспорт
	
	Если ТипЗнч(Параметры.Вид) = Тип("Строка") Тогда
		Объект 				= Справочники.энргВидыОпераций[Параметры.Вид].ПолучитьОбъект();
	Иначе
		Объект 				= Параметры.Вид.ПолучитьОбъект();
	КонецЕсли;
	
	Объект.ИмяДокумента   	= Параметры.ИмяДокумента;
	
	ОбновлениеИнформационнойБазы.ЗаписатьДанные(Объект);
КонецПроцедуры

#КонецОбласти