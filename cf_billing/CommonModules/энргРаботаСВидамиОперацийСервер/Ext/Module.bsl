		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргИзменитьНомерПломбыПрибораУчетаМКД_ЗаменаПломбы, 	"ЗаменаПломбы");
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргИзменитьНомерПломбыПрибораУчетаМКД_Распломбировка, 	"Распломбировка");
		
	ИначеЕсли  ИмяДокумента = "энргОперацияСТочкамиПоставки" тогда
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргОперацияСТочкамиПоставки_ВключениеТочкиПоставки, 	"ВключениеТочкиПоставки");
