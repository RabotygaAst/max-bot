	ИначеЕсли  ИмяДокумента = "энргУстановитьТочкиПоставкиНаТочкиУчета" тогда
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргУстановитьТочкиПоставкиНаТочкиУчета_УстановитьНаТочкиУчетаМКД, 			"УстановитьНаТочкиУчетаМКД");
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргУстановитьТочкиПоставкиНаТочкиУчета_УстановитьНаТочкиУчетаАбонентов, 	"УстановитьНаТочкиУчетаАбонентов");
		
	ИначеЕсли  ИмяДокумента = "энргАктНесанкционированногоПодключенияВмешательства" тогда
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргАктНесанкционированногоПодключенияВмешательства_Вмешательство, "");
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргАктНесанкционированногоПодключенияВмешательства_Подключение	, "");		
		
	ИначеЕсли  ИмяДокумента = "энргКорректировкаПениПоСудебномуРешению" тогда
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргКорректировкаПениПоСудебномуРешению_КорректировкаПениПоСудебномуРешению, "");
