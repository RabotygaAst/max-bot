		врСоотвествие 		= МенеджерОбъекта.СоотвествиеВидовОперацииИПрефиксовФорм();
		ОбщегоНазначенияКлиентСервер.ДополнитьСоответствие(Соотвествие, врСоотвествие, Истина);
		
