#Область ПрограммныйИнтерфейс

Процедура ЗаполнитьСписокВозможныхОперацийФормаСписка(ИмяДокумента,СписокОпераций) Экспорт
	
	Если ИмяДокумента = "энргОперацияСЛицевымСчетом" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС,											"Открытие лицевого счета");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСЛС_ЗакрытиеЛС,											"Закрытие лицевого счета");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСЛС_СменаСобственника,									"Смена собственника лицевого счета");
		
	ИначеЕсли ИмяДокумента = "энргОперацияСПриборомУчета" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВводПУ,									"Акт ввода прибора учета");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВыводПУ,									"Акт вывода прибора учета");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ,									"Акт замены прибора учета");
		
	ИначеЕсли ИмяДокумента = "энргОперацияСУслугами" тогда
		МенеджерОбъекта 	= ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(СтрШаблон("Документ.%1", ИмяДокумента));
		врСписокОпераций 	= МенеджерОбъекта.ЗаполнитьСписокВозможныхОперацийФормаСписка();
		Для Каждого врЗначениеСписка Из врСписокОпераций Цикл
			СписокОпераций.Добавить(врЗначениеСписка.Значение, врЗначениеСписка.Представление);
		КонецЦикла;
		
		//СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги,								"Подключение услуги");
		//СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги,								"Отключение услуги");		
		//
		//// ОРП
		//СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОграничениеРежимаПотребления,					Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргОперацияСУслугами_ОграничениеРежимаПотребления.Синоним);
		//СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления,					Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргОперацияСУслугами_ВозобновлениеРежимаПотребления.Синоним);		
		//// ОРП
		
	ИначеЕсли ИмяДокумента = "энргЭтапПретензионноИсковойДеятельности" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.ЭтапПретензионноИсковойДеятельности_Уведомление,						"Уведомление");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.ЭтапПретензионноИсковойДеятельности_Извещение,						"Извещение");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.ЭтапПретензионноИсковойДеятельности_Предупреждение,					"Предупреждение");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.ЭтапПретензионноИсковойДеятельности_ПередачаПакетаДокументовЮристам,	"Передача пакета документов юристам");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.ЭтапПретензионноИсковойДеятельности_РешениеСуда,						"Решение суда");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.ЭтапПретензионноИсковойДеятельности_РегистрацияИсполнительногоЛиста,	"Регистрация исполнительного листа");
		
	ИначеЕсли ИмяДокумента = "энргОперацияСУслугамиМКД" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСУслугамиМКД_ПодключениеУслуги,							"Подключение услуги многоквартирному дому");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСУслугамиМКД_ОтключениеУслуги,							"Отключение услуги многоквартирному дому");
		
	ИначеЕсли ИмяДокумента = "энргОперацияСПриборомУчетаМКД" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСПриборомУчетаМКД_ВводПУ,									"Ввод общедомового прибора учета");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСПриборомУчетаМКД_ВыводПУ,								"Вывод общедомового прибора учета");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСПриборомУчетаМКД_ЗаменаПУ,								"Замена общедомового прибора учета");
		
	ИначеЕсли ИмяДокумента = "энргОткрытиеМКД" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОткрытиеМКД_Открытие,												"Открытие многоквартирного дома");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОткрытиеМКД_Закрытие,												"Закрытие многоквартирного дома");
		
	ИначеЕсли ИмяДокумента = "энргПерерасчет" тогда
		
		МенеджерОбъекта 	= ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(СтрШаблон("Документ.%1",ИмяДокумента));
		врСписокОпераций 	= МенеджерОбъекта.ЗаполнитьСписокВозможныхОперацийФормаСписка();
		Для Каждого врЗначениеСписка Из врСписокОпераций Цикл
			СписокОпераций.Добавить(врЗначениеСписка.Значение, врЗначениеСписка.Представление);
		КонецЦикла;
		
	ИначеЕсли ИмяДокумента = "энргПерерасчетМКД" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчетМКД_ИзменениеПараметраРассчета,							Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргПерерасчетМКД_ИзменениеПараметраРассчета.Синоним);
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчетМКД_СвязанныйПерерасчет,								"Связанный перерасчет");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчетМКД_РучнойПерерасчет,									"Ручной перерасчет");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчетМКД_КорректировкаГодовогоПотребленияСезонныхУслуг,		Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргПерерасчетМКД_КорректировкаГодовогоПотребленияСезонныхУслуг.Синоним);
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчетМКД_КорректировкаПотребленногоОбъема,					Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргПерерасчетМКД_КорректировкаПотребленногоОбъема.Синоним);
		
		
		//ИначеЕсли ИмяДокумента = "энргРеструктуризацияЗадолженности" тогда
		//	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргРеструктуризацияЗадолженности_СписаниеНаЗабаланс,					"Списание задолженности на забалансовые счета");
		//	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргРеструктуризацияЗадолженности_СписаниеЗабалансовойЗадолженности,	"Списание задолженности с забалансовых счетов");	
		
	ИначеЕсли ИмяДокумента = "энргРегистрацияПоказанийАбонента" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргРегистрацияПоказанийАбонента_РегистрацияКонтрольногоСъема,		"Регистрация контрольного съема");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргРегистрацияПоказанийАбонента_РегистрацияПоказанийАбонента,		"Регистрация показаний предоставленных абонентом");	
		
	ИначеЕсли ИмяДокумента = "энргОперацияСРазделеннымиЛС" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСРазделеннымиЛС_ПодключениеАбонента,						"Подключение абонента к помещению с разделенными ЛС ");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСРазделеннымиЛС_ОтключениеАбонента,						"Отключение абонента от помещения с разделенными ЛС ");
		
	ИначеЕсли ИмяДокумента = "энргОперацияСУслугамиТеплоисточника" тогда                                  		
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСУслугамиТеплоисточника_ПодключениеУслуги,				"Подключение услуги теплоисточника");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСУслугамиТеплоисточника_ОтключениеУслуги,					"Отключение услуги теплоисточника");
		
	ИначеЕсли ИмяДокумента = "энргОперацииСПериодамиОспариванияЗадолженности" тогда                                  		
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацииСПериодамиОспариванияЗадолженности_РегистрацияПериодов,		"Регистрация периодов оспаривания задолженности");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацииСПериодамиОспариванияЗадолженности_СнятиеРегистрацииПериодов,	"Снятие регистрации периодов оспаривания задолженности");
		
	ИначеЕсли ИмяДокумента = "энргИзменениеЛьготыЖильцам" тогда
		
		МенеджерОбъекта 	= ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(СтрШаблон("Документ.%1", ИмяДокумента));
		врСписокОпераций 	= МенеджерОбъекта.ЗаполнитьСписокВозможныхОперацийФормаСписка();
		Для Каждого врЗначениеСписка Из врСписокОпераций Цикл
			СписокОпераций.Добавить(врЗначениеСписка.Значение, врЗначениеСписка.Представление);
		КонецЦикла;
		//СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменениеЛьготыЖильцам_РегистрацияЛьготы,							"Регистрация льготы");
		//СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменениеЛьготыЖильцам_ОтменаРегистрации,							"Отмена льготы");
		////СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменениеЛьготыЖильцам_ИзменениеКатегорииЛьготы,					"Изменение категории");	
		//СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменениеЛьготыЖильцам_ЗагрузкаРеестраЕИРЦ,						"Загрузка реестра из ЕИРЦ");
		
		
	ИначеЕсли ИмяДокумента = "энргПереносОплаты" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПереносОплаты_ПереносМеждуЛицевымиСчетами,						"Перенос между лицевыми счетами");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПереносОплаты_НеправильноРаспределеннаяОплата,					"Неправильно распределенная оплата");	
		
	ИначеЕсли  ИмяДокумента = "энргАктированиеНедопускаДопускаВПомещение" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргАктированиеНедопускаДопускаВПомещение_АктированиеДопускаВПомещение,	"Актирование допуска в помещение");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргАктированиеНедопускаДопускаВПомещение_АктированиеНедопускаВПомещение,"Актирование недопуска в помещение");	
		
	ИначеЕсли  ИмяДокумента = "энргОбходнойЛист" тогда
		МенеджерОбъекта 	= ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(СтрШаблон("Документ.%1", ИмяДокумента));
		врСписокОпераций 	= МенеджерОбъекта.ЗаполнитьСписокВозможныхОперацийФормаСписка();
		Для Каждого врЗначениеСписка Из врСписокОпераций Цикл
			СписокОпераций.Добавить(врЗначениеСписка.Значение, врЗначениеСписка.Представление);
		КонецЦикла;
		//СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОбходнойЛист_МассовыйВвод			,			"Массовый ввод");
		//СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОбходнойЛист_РегистрацияПоСтроению, 			"Регистрация по строению");
		
	ИначеЕсли  ИмяДокумента = "энргБанкротство" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргБанкротство_СписаниеНаЗабалансФЛ			, 		"Списание на забаланс ФЛ");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргБанкротство_ВосстановлениеИзЗабалансаФЛ		, 	"Восстановление из забаланса ФЛ");		
		
	ИначеЕсли  ИмяДокумента = "энргИзменитьНомерПломбыПрибораУчетаАбоненты" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменитьНомерПломбыПрибораУчетаАбоненты_Опломбировка, Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргИзменитьНомерПломбыПрибораУчетаАбоненты_Опломбировка.Синоним);
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменитьНомерПломбыПрибораУчетаАбоненты_ЗаменаПломбы, Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргИзменитьНомерПломбыПрибораУчетаАбоненты_ЗаменаПломбы.Синоним);
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменитьНомерПломбыПрибораУчетаАбоненты_Распломбировка, Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргИзменитьНомерПломбыПрибораУчетаАбоненты_Распломбировка.Синоним);
		
	ИначеЕсли  ИмяДокумента = "энргИзменитьНомерПломбыПрибораУчетаМКД" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменитьНомерПломбыПрибораУчетаМКД_Опломбировка	, Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргИзменитьНомерПломбыПрибораУчетаМКД_Опломбировка.Синоним);
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменитьНомерПломбыПрибораУчетаМКД_Распломбировка	, Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргИзменитьНомерПломбыПрибораУчетаМКД_Распломбировка.Синоним);
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргИзменитьНомерПломбыПрибораУчетаМКД_ЗаменаПломбы	, Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления.энргИзменитьНомерПломбыПрибораУчетаМКД_ЗаменаПломбы.Синоним);
		
	ИначеЕсли  ИмяДокумента = "энргОперацияСТочкамиПоставки" тогда
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСТочкамиПоставки_ВключениеТочкиПоставки		, 	"Включение точки поставки");
		СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргОперацияСТочкамиПоставки_ОтключениеТочкиПоставки		, 	"Отключение точки поставки");
		
