		Соотвествие.Вставить(Перечисления.энргВидыОпераций.СоглашениеПоРассрочке_РеструктуризацияЗадолженностиФЛ		, "ФЛ");
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.СоглашениеПоРассрочке_ЗакрытиеЗадолженностиФЛ		, "ФЛ");
		
		
	ИначеЕсли  ИмяДокумента = "энргРегистрацияРасчетаПениАбонента" тогда
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргРегистрацияРасчетаПениАбонента_ИсключениеРасчетаПениАбонента, "");
		Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргРегистрацияРасчетаПениАбонента_ВозобновлениеРасчетаПениАбонента	, "");
		
		
	КонецЕсли;  
	
	Возврат Соотвествие[ВыбранноеЗначение]; 
	
КонецФункции

