Функция ПолучитьОбъектыРасчетаУправляющейКомпании(Период, Организация, Район, УК, Договор) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргФормыУправленияМКДСрезПоследних.МКД КАК МКД
		|ПОМЕСТИТЬ ВТ_МКД
		|ИЗ
		|	РегистрСведений.энргФормыУправленияМКД.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район) КАК энргФормыУправленияМКДСрезПоследних
		|ГДЕ
		|	энргФормыУправленияМКДСрезПоследних.УК = &УК
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргСостояниеМКДСрезПоследних.МКД КАК МКД,
		|	энргСостояниеМКДСрезПоследних.МКД.ГруппаПотребителейПоУмолчанию КАК ГруппаПотребителейПоУмолчанию,
		|	СУММА(энргЗначениеПлощадейМКДСрезПоследних.Площадь) КАК Площадь
		|ИЗ
		|	РегистрСведений.энргСостояниеМКД.СрезПоследних(
		|			&Период,
		|			Район = &Район
		|				И Организация = &Организация
		|				И МКД В
		|					(ВЫБРАТЬ
		|						ВТ_МКД.МКД КАК МКД
		|					ИЗ
		|						ВТ_МКД КАК ВТ_МКД)) КАК энргСостояниеМКДСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргЗначениеПлощадейМКД.СрезПоследних(
		|				&Период,
		|				Район = &Район
		|					И Организация = &Организация
		|					И МКД В
		|						(ВЫБРАТЬ
		|							ВТ_МКД.МКД КАК МКД
		|						ИЗ
		|							ВТ_МКД КАК ВТ_МКД)
		|					И ВидПлощади = &ВидПлощади) КАК энргЗначениеПлощадейМКДСрезПоследних
		|		ПО энргСостояниеМКДСрезПоследних.МКД = энргЗначениеПлощадейМКДСрезПоследних.МКД
		|ГДЕ
		|	энргСостояниеМКДСрезПоследних.Состояние
		|
		|СГРУППИРОВАТЬ ПО
		|	энргСостояниеМКДСрезПоследних.МКД,
		|	энргСостояниеМКДСрезПоследних.МКД.ГруппаПотребителейПоУмолчанию";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период", Новый Граница(Период, ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("УК", УК);
	Запрос.УстановитьПараметр("ВидПлощади", Перечисления.энргВидыПлощадей.ОбщаяПлощадьМКД);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса;
		
