#Область ОбработчикиСобытий

Функция ПолучитьТарифыАбонента(пАбонент) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |	ИспользованиеУслуг.Тариф КАК Тариф
	                     // |	ИспользованиеУслуг.ТО КАК ТочкаОтпуска
	                      |ИЗ
	                      |	РегистрСведений.ИспользованиеУслуг КАК ИспользованиеУслуг
	                      |ГДЕ
	                      |	ИспользованиеУслуг.Абонент = &Абонент
	                      |	И ИспользованиеУслуг.Тариф.ВидУслуги.Выводить = ИСТИНА");
	
	Запрос.УстановитьПараметр("Абонент",пАбонент);
		
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаЗапроса = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаЗапроса;
	
КонецФункции

Функция ПолучитьУслугиАбонента(пАбонент, Период) Экспорт
	// Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ.
	//                      |	ВложенныйЗапрос.Поставщик КАК Поставщик,
	//                      |	ВложенныйЗапрос.Услуга КАК Услуга,
	//                      |	СостояниеУслуг.Состояние КАК Состояние,
	//                      |	ВложенныйЗапрос.Вывод КАК Вывод.
	//                      |ИЗ
	//                      |	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	//                      |		ИспользованиеУслуг.Тариф.ВидУслуги КАК Услуга,
	//                      |		ИспользованиеУслуг.Тариф.Поставщик КАК Поставщик,
	//                      |		ИспользованиеУслуг.Тариф.ВидУслуги.Выводить КАК Вывод,
	//                      |		ИспользованиеУслуг.Тариф КАК Тариф.
	//                      |	ИЗ
	//                      |		РегистрСведений.ИспользованиеУслуг КАК ИспользованиеУслуг
	//                      |	ГДЕ
	//                      |		ИспользованиеУслуг.Абонент = &Абонент
	//                      |	
	//                      |	ОБЪЕДИНИТЬ ВСЕ
	//                      |	
	//                      |	ВЫБРАТЬ РАЗЛИЧНЫЕ
	//                      |		ВзаиморасчетыНовыйОбороты.Услуга,
	//                      |		ВзаиморасчетыНовыйОбороты.Поставщик,
	//                      |		ВзаиморасчетыНовыйОбороты.Услуга.Выводить,
	//                      |		NULL
	//                      |	ИЗ
	//                      |		РегистрНакопления.ВзаиморасчетыНовый.Обороты(
	//                      |			,
	//                      |			,
	//                      |			,
	//                      |			Абонент = &Абонент) КАК ВзаиморасчетыНовыйОбороты) КАК ВложенныйЗапрос
	//                      |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
	//                      |			ИспользованиеУслугСрезПоследних.Состояние КАК Состояние,
	//                      |			ИспользованиеУслугСрезПоследних.Тариф.Поставщик КАК Поставщик,
	//                      |			ИспользованиеУслугСрезПоследних.Тариф.ВидУслуги КАК ТарифВидУслуги.
	//                      |		ИЗ
	//                      |			РегистрСведений.ИспользованиеУслуг.СрезПоследних(&Дата,
											// Абонент = &Абонент) КАК ИспользованиеУслугСрезПоследних) КАК СостояниеУслуг.
	//                      |		ПО ВложенныйЗапрос.Поставщик = СостояниеУслуг.Поставщик.
	//                      |			И ВложенныйЗапрос.Услуга = СостояниеУслуг.ТарифВидУслуги.
	//                      |ГДЕ
	//                      |	ВложенныйЗапрос.Тариф <> &Пустой
	//                      |
	//                      |УПОРЯДОЧИТЬ ПО
	//                      |	ВложенныйЗапрос.Поставщик.Наименование
	//                      |ИТОГИ
	//                      |	МИНИМУМ(Состояние),
	//                      |	МИНИМУМ(Вывод)
	//                      |ПО
	//                      |	Поставщик,
	//                      |	Услуга");
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |	ВложенныйЗапрос.Услуга КАК Услуга,
	                      |	ВложенныйЗапрос.Вывод КАК Вывод
	                      |ИЗ
	                      |	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |		ИспользованиеУслуг.Услуга КАК Услуга,
	                      |		ИспользованиеУслуг.Услуга.УдалитьВыводить КАК Вывод
	                      |	ИЗ
	                      |		РегистрСведений.энргИспользованиеУслуг КАК ИспользованиеУслуг
	                      |	ГДЕ
	                      |		ИспользованиеУслуг.Абонент = &Абонент
	                      |	
	                      |	ОБЪЕДИНИТЬ ВСЕ
	                      |	
	                      |	ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |		ВзаиморасчетыНовыйОбороты.Услуга,
	                      |		ВзаиморасчетыНовыйОбороты.Услуга.УдалитьВыводить
	                      |	ИЗ
	                      |		РегистрНакопления.энргВзаиморасчеты.Обороты(, , , Абонент = &Абонент) КАК ВзаиморасчетыНовыйОбороты) КАК ВложенныйЗапрос
	                      |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |			ИспользованиеУслугСрезПоследних.Услуга КАК ВидУслуги
	                      |		ИЗ
	                      |			РегистрСведений.энргИспользованиеУслуг.СрезПоследних(&Дата, Абонент = &Абонент) КАК ИспользованиеУслугСрезПоследних) КАК СостояниеУслуг
	                      |		ПО ВложенныйЗапрос.Услуга = СостояниеУслуг.ВидУслуги
	                      |ИТОГИ
	                      |	МИНИМУМ(Вывод)
	                      |ПО
	                      |	Услуга");
	

	Запрос.УстановитьПараметр("Абонент",пАбонент); 	
	// Запрос.УстановитьПараметр("Пустой",Справочники.Тарифы.ПустаяСсылка());     ???
	// Запрос.УстановитьПараметр("Сальдо",Перечисления.ВидыОпераций.НачальноеСальдо);  ???
	Запрос.УстановитьПараметр("Дата", Период);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаЗапроса = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Возврат ВыборкаЗапроса;
	
КонецФункции

Функция ПолучитьУслугиАбонентаСТарифом(пАбонент) Экспорт
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |	ВложенныйЗапрос.Услуга,
	                      |	ВложенныйЗапрос.Поставщик,
	                      |	ВложенныйЗапрос.Вывод,
	                      |	ВложенныйЗапрос.Тариф
	                      |ИЗ
	                      |	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |		ИспользованиеУслуг.Тариф.ВидУслуги КАК Услуга,
	                      |		ИспользованиеУслуг.Тариф.Поставщик КАК Поставщик,
	                      |		ИспользованиеУслуг.Тариф.ВидУслуги.Выводить КАК Вывод,
	                      |		ИспользованиеУслуг.Тариф КАК Тариф
	                      |	ИЗ
	                      |		РегистрСведений.ИспользованиеУслуг КАК ИспользованиеУслуг
	                      |	ГДЕ
	                      |		ИспользованиеУслуг.Абонент = &Абонент
	                      |	
	                      |	ОБЪЕДИНИТЬ ВСЕ
	                      |	
	                      |	ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |		ВзаиморасчетыНовыйОбороты.Услуга,
	                      |		ВзаиморасчетыНовыйОбороты.Поставщик,
	                      |		ВзаиморасчетыНовыйОбороты.Услуга.Выводить,
	                      |		NULL
	                      |	ИЗ
	                      |		РегистрНакопления.ВзаиморасчетыНовый.Обороты(
	                      |			,
	                      |			,
	                      |			,
	                      |			Абонент = &Абонент
	                      |			    И ВидОперации = &Сальдо) КАК ВзаиморасчетыНовыйОбороты) КАК ВложенныйЗапрос
	                      |ГДЕ
	                      |	ВложенныйЗапрос.Тариф <> &Пустой");
      	
	Запрос.УстановитьПараметр("Абонент",пАбонент); 	
	Запрос.УстановитьПараметр("Пустой",Справочники.Тарифы.ПустаяСсылка());
	Запрос.УстановитьПараметр("Сальдо",Перечисления.ВидыОпераций.НачальноеСальдо);
		
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаЗапроса = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаЗапроса;
	
КонецФункции
 
Функция ПолучитьУслугиАбонентаСНачислением(пАбонент, нПериод, кПериод) Экспорт
Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
                      |	Услуги.Тариф,
                      |	Объем.СуммаНачислено КАК Начислено,
                      |	Объем.ОбъемУслугиОборот КАК Объем,
                      |	Услуги.Абонент,
                      |	Услуги.Поставщик,
                      |	Услуги.Тариф.ВидУслуги КАК Услуга
                      |ИЗ
                      |	(ВЫБРАТЬ РАЗЛИЧНЫЕ
                      |		ИспользованиеУслуг.Тариф КАК Тариф,
                      |		ИспользованиеУслуг.Абонент КАК Абонент,
                      |		ИспользованиеУслуг.Тариф.Поставщик КАК Поставщик
                      |	ИЗ
                      |		РегистрСведений.ИспользованиеУслуг КАК ИспользованиеУслуг
                      |	ГДЕ
                      |		ИспользованиеУслуг.Абонент В (&Абонент)) КАК Услуги
                      |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
                      |			ОбъемНачисленийОбороты.Абонент КАК Абонент,                      
                      |			ОбъемНачисленийОбороты.Тариф КАК Тариф,
                      |			ВЫБОР
                      |				КОГДА ОбъемНачисленийОбороты.ВидОперации = &Начисление
					  |					ТОГДА ОбъемНачисленийОбороты.СуммаОборот
					  //|					ТОГДА ОбъемНачисленийОбороты.СуммаОборот - ОбъемНачисленийОбороты.СуммаЛьготОборот.
                      |				ИНАЧЕ 0
                      |			КОНЕЦ КАК СуммаНачислено,
                      |			ВЫБОР
                      |				КОГДА ОбъемНачисленийОбороты.ВидОперации = &Начисление
                      |					ТОГДА ОбъемНачисленийОбороты.ОбъемУслугиОборот
                      |				ИНАЧЕ 0
                      |			КОНЕЦ КАК ОбъемУслугиОборот
                      |		ИЗ
                      |			РегистрНакопления.ОбъемНачислений.Обороты(&НачПериода, &КонПериода, , Абонент В (&Абонент)) КАК ОбъемНачисленийОбороты) КАК Объем
                      |		ПО Услуги.Тариф = Объем.Тариф
                      |			И Услуги.Абонент = Объем.Абонент
                      |			И Услуги.Поставщик = Объем.Тариф.Поставщик");
      	
	Запрос.УстановитьПараметр("Абонент", пАбонент);
	Запрос.УстановитьПараметр("НачПериода", нПериод); 
	Запрос.УстановитьПараметр("КонПериода", кПериод); 
	Запрос.УстановитьПараметр("Начисление", Перечисления.ВидыОпераций.Начисление);  	
			                     
	РезультатЗапроса 	= Запрос.Выполнить();
	ВыборкаЗапроса 		= РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаЗапроса;
	
КонецФункции
  
Функция ПолучитьСписокАбонентов(ДанныеСтроки, Абонент, Точка, НачПер,КонПер) Экспорт
	Результат = "";
	РезультатОбъем = "";
	Если Не  Абонент.Пустая() Тогда
		Результат = " И ИспользованиеУслуг.Абонент В ИЕРАРХИИ(&Абонент) "
	КонецЕсли;
	
	Если Не Абонент.Пустая() Тогда
		РезультатОбъем = " И Абонент В ИЕРАРХИИ(&Абонент) ";
	КонецЕсли;
	
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |	Услуги.Тариф,
	                      |	ЕСТЬNULL(Объем.СуммаНачислено, 0) КАК Сумма,
	                      |	ЕСТЬNULL(Объем.ОбъемУслугиОборот, 0) КАК Объем,
	                      |	Услуги.Абонент,
	                      |	Услуги.Поставщик,
	                      |	Услуги.Тариф.ВидУслуги КАК Услуга,
	                      |	Услуги.ТО
	                      |ИЗ
	                      |	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |		ИспользованиеУслуг.Тариф КАК Тариф,
	                      |		ИспользованиеУслуг.Абонент КАК Абонент,
	                      |		ИспользованиеУслуг.Тариф.Поставщик КАК Поставщик,
	                      |		ИспользованиеУслуг.ТО КАК ТО
	                      |	ИЗ
	                      |		РегистрСведений.ИспользованиеУслуг КАК ИспользованиеУслуг
	                      |	ГДЕ
	                      |		ИспользованиеУслуг.ТО = &ТО И ИспользованиеУслуг.Тариф = &Тариф" + Результат + ") КАК Услуги
	                      |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	                      |			ОбъемНачисленийОбороты.Абонент КАК Абонент,
	                      |			ОбъемНачисленийОбороты.Тариф.ВидУслуги КАК Услуга,
	                      |			ОбъемНачисленийОбороты.Тариф КАК Тариф,
	                      |			ВЫБОР
	                      |				КОГДА ОбъемНачисленийОбороты.ВидОперации = &Начисление
	                      |					ТОГДА ОбъемНачисленийОбороты.СуммаОборот - ОбъемНачисленийОбороты.СуммаЛьготОборот
	                      |				ИНАЧЕ 0
	                      |			КОНЕЦ КАК СуммаНачислено,
	                      |			ВЫБОР
	                      |				КОГДА ОбъемНачисленийОбороты.ВидОперации = &Начисление
	                      |					ТОГДА ОбъемНачисленийОбороты.ОбъемУслугиОборот
	                      |				ИНАЧЕ 0
	                      |			КОНЕЦ КАК ОбъемУслугиОборот
	                      |		ИЗ
	                      |			РегистрНакопления.ОбъемНачислений.Обороты(&НачПериода, &КонПериода, , Тариф = &Тариф" + РезультатОбъем + ") КАК ОбъемНачисленийОбороты) КАК Объем
	                      |		ПО Услуги.Тариф = Объем.Тариф
	                      |			И Услуги.Абонент = Объем.Абонент
	                      |			И Услуги.Поставщик = Объем.Тариф.Поставщик");

	
	Запрос.УстановитьПараметр("НачПериода",НачалоДня(НачПер));
	Запрос.УстановитьПараметр("КонПериода",КонецДня(КонПер));						  
 	Запрос.УстановитьПараметр("ТО", Точка);	
	Запрос.УстановитьПараметр("Тариф", ДанныеСтроки.Тариф);
	Запрос.УстановитьПараметр("Абонент", Абонент);
	Запрос.УстановитьПараметр("Начисление", Перечисления.ВидыОпераций.Начисление); 
			
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаЗапроса = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаЗапроса;
	
КонецФункции
 
Функция ПолучитьСписокАбонентовГруппа(ДанныеСтроки, Абонент, НачПер, КонПер) Экспорт
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	ОбъемНачисленийОбороты.Абонент,
	                      |	ВЫБОР
	                      |		КОГДА ОбъемНачисленийОбороты.ВидОперации = &Начисление
	                      |			ТОГДА ОбъемНачисленийОбороты.СуммаОборот - ОбъемНачисленийОбороты.СуммаЛьготОборот
	                      |		ИНАЧЕ 0
	                      |	КОНЕЦ КАК Сумма,
	                      |	ВЫБОР
	                      |		КОГДА ОбъемНачисленийОбороты.ВидОперации = &Начисление
	                      |			ТОГДА ОбъемНачисленийОбороты.ОбъемУслугиОборот
	                      |		ИНАЧЕ 0
	                      |	КОНЕЦ КАК Объем,
	                      |	ОбъемНачисленийОбороты.Тариф.ВидУслуги КАК Услуга,
	                      |	ОбъемНачисленийОбороты.ПриборУчета,
	                      |	ОбъемНачисленийОбороты.Тариф.Поставщик КАК Поставщик,
	                      |	ОбъемНачисленийОбороты.ТочкаОтпуска
	                      |ИЗ
	                      |	РегистрНакопления.ОбъемНачислений.Обороты(
	                      |		&НачПериода,
	                      |		&КонПериода,
	                      |		,
	                      |		Абонент В ИЕРАРХИИ (&Абонент)
	                      |		    И Тариф = &Тариф) КАК ОбъемНачисленийОбороты"); 
	
	Запрос.УстановитьПараметр("НачПериода",НачалоДня(НачПер));
	Запрос.УстановитьПараметр("КонПериода",КонецДня(КонПер));	
	Запрос.УстановитьПараметр("Абонент",Абонент);
	Запрос.УстановитьПараметр("Тариф",ДанныеСтроки.Тариф);	
	Запрос.УстановитьПараметр("Начисление", Перечисления.ВидыОпераций.Начисление); 
		
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаЗапроса = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаЗапроса;
	
КонецФункции
 
Функция ПолучитьУслугиПоТочке(ТочкаОтпуска) Экспорт
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |	ИспользованиеУслуг.Тариф.ВидУслуги КАК Услуга,
	                      |	ИспользованиеУслуг.Тариф.Поставщик,
	                      |	ИспользованиеУслуг.Тариф
	                      |ИЗ
	                      |	РегистрСведений.ИспользованиеУслуг КАК ИспользованиеУслуг
	                      |ГДЕ
	                      |	ИспользованиеУслуг.ТО = &Точка");

	Запрос.УстановитьПараметр("Точка",ТочкаОтпуска);
		
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаЗапроса = РезультатЗапроса.Выбрать();
	
