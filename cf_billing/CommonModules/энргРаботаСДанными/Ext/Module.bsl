Функция ПолучитьАдресАбонента(пАбонент) Экспорт
	
	Если пАбонент.Пустая() ИЛИ пАбонент.ЭтоГруппа Тогда
		Возврат "";	
	КонецЕсли;
	СтруктураОтбора = Новый Структура("Объект");
	СтруктураОтбора.Вставить("Объект", пАбонент.Ссылка); 
	Запрос = Новый Запрос ("ВЫБРАТЬ
	                       |	КонтактнаяИнформация.Представление
	                       |ИЗ
	                       |	РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	                       |ГДЕ
	                       |	КонтактнаяИнформация.Объект = &Объект");
	Запрос.УстановитьПараметр("Объект",пАбонент);
	ТЗ = Запрос.Выполнить().Выбрать();
	ТЗ.Следующий();
	Адрес = ТЗ.Представление;
	Возврат Адрес;
	
