Функция РубКоп(Сумма) Экспорт
	
	Руб = Цел(Сумма);
	Коп = ОКР(100*(Сумма-Руб),0,1);
	СуммаРубКоп = ""+Руб+" руб. "+Цел(Коп/10)+(Коп-10*Цел(Коп/10))+" коп.";
	
	Возврат СуммаРубКоп;
	
КонецФункции

