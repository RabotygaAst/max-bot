Функция ПолучитьКоличествоПрописанных(пАбонент, Период) Экспорт
	Если пАбонент.Пустая() ИЛИ пАбонент.ЭтоГруппа Тогда
		Возврат "";	
	КонецЕсли;  	
	Запрос=Новый Запрос("ВЫБРАТЬ
	                    |	КоличествоПрописанныхСрезПоследних.Количество КАК Количество
	                    |ИЗ
	                    |	РегистрСведений.КоличествоПрописанных.СрезПоследних(&Период, Абонент = &Абонент) КАК КоличествоПрописанныхСрезПоследних");
						
	Запрос.УстановитьПараметр("Период", ТекущаяДата());
	Запрос.УстановитьПараметр("Абонент", пАбонент);
	ТЗ=Запрос.Выполнить().Выбрать();	
	ТЗ.Следующий();
	Количество = ТЗ.Количество;
	Возврат Количество;
	
