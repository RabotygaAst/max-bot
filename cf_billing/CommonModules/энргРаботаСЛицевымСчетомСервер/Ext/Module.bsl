Процедура ПроверитьИСоздатьАбонента(ТекущийОбъект,Отказ) Экспорт 
	
	ДанныеАбонента 							= ДанныеАбонентаИзСтрокиJSON(ТекущийОбъект.ОписаниеАбонента);
	
	стрОписаниеАбонента 							= ТекущийОбъект.ОписаниеАбонента;
	Чтение  										= Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(стрОписаниеАбонента);
	ОписаниеАбонента 								= ПрочитатьJSON(Чтение);
	
	ДанныеАбонента.Вставить("ВидОбъекта",		Справочники.энргВидыОбъектовАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеАбонента["ВидОбъекта"])));
	ДанныеАбонента.Вставить("КлючПомещения",	ТекущийОбъект.КлючПомещения);
	ДанныеАбонента.Вставить("Район", 			ТекущийОбъект.Район);
	ДанныеАбонента.Вставить("Организация", 		ТекущийОбъект.Организация);
	ДанныеАбонента.Вставить("Поставщик", 		ТекущийОбъект.Поставщик);
	

	Абонент 								= Справочники.энргАбоненты.ПустаяСсылка();
	
	// ищем с таким же адресом	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ФизЛицо",			ДанныеАбонента.ФизЛицо);
	Запрос.УстановитьПараметр("КлючПомещения",		ТекущийОбъект.КлючПомещения);
	Запрос.УстановитьПараметр("Район",				ТекущийОбъект.Район);
	Запрос.УстановитьПараметр("Организация",		ТекущийОбъект.Организация);
	Запрос.УстановитьПараметр("Поставщик",			ТекущийОбъект.Поставщик);	
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАбоненты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.энргАбоненты КАК энргАбоненты
	|ГДЕ
	|	энргАбоненты.ФизЛицо = &ФизЛицо
	|	И энргАбоненты.КлючПомещения = &КлючПомещения
	|	И энргАбоненты.Район = &Район
	|	И энргАбоненты.Организация = &Организация
	|	И энргАбоненты.Поставщик = &Поставщик";
	Результат  					= Запрос.Выполнить();
	Выборка 					= Результат.Выбрать(); 
	Если Выборка.Следующий() тогда
		Абонент 				= Выборка.ссылка; 
	КонецЕсли;
	
	ФормироватьЛС 				= истина;
	
	Если ЗначениеЗаполнено(Абонент) И ТекущийОбъект.ДополнительныеСвойства.Свойство("ЭтоНовыйАбонент") И Не ТекущийОбъект.ДополнительныеСвойства.ЭтоНовыйАбонент  тогда
		// обновляем реквизиты мкд
		АбонентОбъект  			= Абонент.получитьОбъект();
		ФормироватьЛС 			= Ложь;
	иначе
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ЭтоНовыйАбонент") и ТекущийОбъект.ДополнительныеСвойства.ЭтоНовыйАбонент тогда
			АбонентОбъект  		= Справочники.энргАбоненты.СоздатьЭлемент();			
			//АбонентОбъект.УстановитьСсылкуНового(ТекущийОбъект.Абонент);
			АбонентОбъект.УстановитьСсылкуНового(?(ТекущийОбъект.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСЛС_СменаСобственника, ТекущийОбъект.АбонентСмена, ТекущийОбъект.Абонент));
		иначе
			//АбонентОбъект 		= ТекущийОбъект.Абонент.получитьОбъект();
			АбонентОбъект 		= ?(ТекущийОбъект.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСЛС_СменаСобственника, ТекущийОбъект.АбонентСмена, ТекущийОбъект.Абонент).получитьОбъект();
			ФормироватьЛС 		= Ложь;
		КонецЕсли;
	КонецЕсли; 	
	
		
	новДанныеАбонента			= ЗаполнитьРеквизитыАбонента(ТекущийОбъект,ДанныеАбонента,АбонентОбъект,ФормироватьЛС, ТекущийОбъект.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСЛС_СменаСобственника);
	
КонецПроцедуры

Процедура ПроверитьИСоздатьАбонентаИзКоллекции(ТекущийОбъект, ИмяКоллекции, Отказ) Экспорт 
	
	МКД 												= ТекущийОбъект.МКД;
	Район 												= ТекущийОбъект.Район;
	Организация 										= ТекущийОбъект.Организация;
	ФормироватьЛС 										= Ложь;
	Сч 													= 0;
	
	НовыеАбоненты 										= ТекущийОбъект.ДополнительныеСвойства.НовыеАбоненты;
	ИзмененныеАбоненты									= ТекущийОбъект.ДополнительныеСвойства.ИзмененныеАбоненты;
	
	Для Каждого СтрокаАбонента Из ТекущийОбъект[ИмяКоллекции] Цикл
		Если Не ЗначениеЗаполнено(СтрокаАбонента.Абонент) Тогда
			// это коммунальная квартира
			Продолжить;
		КонецЕсли;
		
		ЭтоНовыйАбонент 								= НЕ НовыеАбоненты.Найти(СтрокаАбонента.НомерСтроки) = Неопределено;
		
		Если Не ЭтоНовыйАбонент И ИзмененныеАбоненты.Найти(СтрокаАбонента.Абонент) = Неопределено Тогда
			// этого абонента не изменяли, перезаписывать не надо
			Продолжить;
		КонецЕсли;
		
		АбонентОбъект 									= СтрокаАбонента.Абонент.получитьОбъект();
		Если АбонентОбъект = Неопределено и ЗначениеЗаполнено(СтрокаАбонента.Абонент) Тогда
			АбонентОбъект 								= Справочники.энргАбоненты.СоздатьЭлемент();
			АбонентОбъект.УстановитьСсылкуНового(СтрокаАбонента.Абонент);
		КонецЕсли;
		
		стрОписаниеАбонента 							= СтрокаАбонента.ОписаниеАбонента;
		
		Чтение  										= Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(стрОписаниеАбонента);
		ОписаниеАбонента 								= ПрочитатьJSON(Чтение);
		
		ДанныеАбонента 									= Новый Структура("Дата,Филиал,ГруппаАбонента,Район,Организация,МКД,ФизЛицо,ВидОбъекта,ЛицевойСчет,СтарыйЛС,АдресОбъектаЗначение,КлючПомещения,Филиал,СлужебныеОтметки");
		
		Для Каждого КлючЗначение Из ОписаниеАбонента Цикл
			Если КлючЗначение.Ключ = "ФизическоеЛицо" Тогда
				ДанныеАбонента.ФизЛицо					= Справочники.энргКонтрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "ВидОбъекта" Тогда
				ДанныеАбонента.ВидОбъекта			 	= Справочники.энргВидыОбъектовАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "Филиал" Тогда
				ДанныеАбонента.Филиал 					= Справочники.энргФилиалы.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));	
			Иначе
				ДанныеАбонента[КлючЗначение.Ключ] 		= КлючЗначение.Значение;
			КонецЕсли;
		КонецЦикла;	
		ДанныеАбонента.КлючПомещения					= СтрокаАбонента.КлючПомещения;		
		ДанныеАбонента.ГруппаАбонента					= СтрокаАбонента.ГруппаАбонентов;
		ДанныеАбонента.Район							= Район;
		ДанныеАбонента.Организация						= Организация;
		ДанныеАбонента.МКД								= МКД;
										
		ДанныеАбонента.Дата                             = ТекущийОбъект.Дата;
		ДанныеАбонента 									= ЗаполнитьРеквизитыАбонента(ДанныеАбонента, ДанныеАбонента,АбонентОбъект,ФормироватьЛС);
	КонецЦикла;
	
КонецПроцедуры

Процедура ПараметрыРасчетаПомещения(Организация,Район,КлючПомещения,Период,ПолучаемыеСвойства) Экспорт 
	
	
	Если ТипЗнч(КлючПомещения) = Тип("Структура")  Тогда
		ЕстьРазделитель 	= НЕ Метаданные.ОбщиеРеквизиты.Найти("слжРазделительДляТестов") = Неопределено;
		Если ЕстьРазделитель Тогда
			КлючПомещения.Вставить("слжРазделительДляТестов", ПараметрыСеанса["слжРазделительДляТестовЗначение"]); 			
		КонецЕсли;		
		яКлючПомещения 		= РегистрыСведений.энргКлючиПомещений.Получить(КлючПомещения).КлючПомещения;
		яСтроение 			= КлючПомещения.Строение;
	Иначе
		яКлючПомещения 		= КлючПомещения;
		яСтроение 			= КлючПомещения.Строение;
	КонецЕсли;
		
	ТекстыЗапросов			= Новый Структура;
	
	Если ПолучаемыеСвойства.Свойство("КлючПомещения") Тогда
		ПолучаемыеСвойства.КлючПомещения = яКлючПомещения;	
	КонецЕсли;
	 	
	#Область КоличествоКомнат
	Если ПолучаемыеСвойства.свойство("КоличествоКомнат") тогда 				
		ТекстыЗапросов.Вставить("КоличествоКомнат",Новый Структура("ОбработчикЗаполнения,Текст","энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоКоличествоКомнат", 
		"ВЫБРАТЬ
		|	энргКоличествоКомнатСрезПоследних.Количество КАК Количество
		|ИЗ
		|	РегистрСведений.энргКоличествоКомнат.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения
		|				И Организация = &Организация) КАК энргКоличествоКомнатСрезПоследних"));				
	КонецЕсли;
	#КонецОбласти
	
	#Область КоличествоПрописанных
	Если ПолучаемыеСвойства.свойство("КоличествоПрописанных") тогда 		
		ТекстыЗапросов.Вставить("КоличествоПрописанных",Новый Структура("ОбработчикЗаполнения,Текст","энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоКоличествоПрописанных",
		"ВЫБРАТЬ
		|	энргКоличествоПрописанныхСрезПоследних.Количество КАК Количество
		|ИЗ
		|	РегистрСведений.энргКоличествоПрописанных.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргКоличествоПрописанныхСрезПоследних"));		 		
	КонецЕсли;
	#КонецОбласти
	
	#Область КоличествоПроживающих
	Если ПолучаемыеСвойства.свойство("КоличествоПроживающих") тогда		
		ТекстыЗапросов.Вставить("КоличествоПроживающих",Новый Структура("ОбработчикЗаполнения,Текст","энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоКоличествоПроживающих",
		"ВЫБРАТЬ
		|	энргКоличествоПроживающихСрезПоследних.Количество КАК Количество
		|ИЗ
		|	РегистрСведений.энргКоличествоПроживающих.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргКоличествоПроживающихСрезПоследних"));		 		
	КонецЕсли;
	#КонецОбласти
	
	#Область КоличествоСобственников
