Процедура ЗаполнитьВидБлагоустройстваАбонента(ТекущийОбъект) Экспорт
	
	ТекущийОбъект.Объект.ВидыБлагоустройств.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргАктивностьТочекУчетаСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
		|ПОМЕСТИТЬ АктивныеТУ
		|ИЗ
		|	РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргАктивностьТочекУчетаСрезПоследних
		|ГДЕ
		|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
		|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга
		|ПОМЕСТИТЬ ВТ_Услуги
		|ИЗ
		|	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения
		|				И ТочкаУчета В
		|					(ВЫБРАТЬ
		|						АктивныеТУ.ТочкаУчета
		|					ИЗ
		|						АктивныеТУ КАК АктивныеТУ)) КАК энргУслугиТочекУчетаСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Услуги.ТочкаУчета КАК ТочкаУчета,
		|	ЕСТЬNULL(энргВидыУслугСоставляющиеУслуг.Услуга, ВТ_Услуги.Услуга) КАК Услуга
		|ПОМЕСТИТЬ СоставныеУслуги
		|ИЗ
		|	ВТ_Услуги КАК ВТ_Услуги
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
		|		ПО ВТ_Услуги.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргВидБлагоустройствАбонентаСрезПоследних.Услуга КАК Услуга,
		|	энргВидБлагоустройствАбонентаСрезПоследних.ВидБлагоустройства КАК ВидБлагоустройства
		|ПОМЕСТИТЬ ВТ_ВидыБлагоустройств
		|ИЗ
		|	РегистрСведений.энргВидБлагоустройствАбонента.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения
		|				И Услуга В
		|					(ВЫБРАТЬ
		|						СоставныеУслуги.Услуга
		|					ИЗ
		|						СоставныеУслуги КАК СоставныеУслуги)) КАК энргВидБлагоустройствАбонентаСрезПоследних
		|
		|СГРУППИРОВАТЬ ПО
		|	энргВидБлагоустройствАбонентаСрезПоследних.Услуга,
		|	энргВидБлагоустройствАбонентаСрезПоследних.ВидБлагоустройства
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_ВидыБлагоустройств.ВидБлагоустройства КАК ВидБлагоустройства,
		|	СоставныеУслуги.Услуга КАК Услуга
		|ИЗ
		|	АктивныеТУ КАК АктивныеТУ
		|		ЛЕВОЕ СОЕДИНЕНИЕ СоставныеУслуги КАК СоставныеУслуги
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ВидыБлагоустройств КАК ВТ_ВидыБлагоустройств
		|			ПО СоставныеУслуги.Услуга = ВТ_ВидыБлагоустройств.Услуга
		|		ПО АктивныеТУ.ТочкаУчета = СоставныеУслуги.ТочкаУчета";
	
	Запрос.УстановитьПараметр("КлючПомещения"	, ТекущийОбъект.Объект.КлючПомещения);
	Запрос.УстановитьПараметр("Организация"		, ТекущийОбъект.Объект.Организация);
	Запрос.УстановитьПараметр("Период"			, новый Граница(ТекущийОбъект.Объект.Дата,ВидГраницы.Исключая));//ТекущийОбъект.Объект.ПериодНачисления);
	Запрос.УстановитьПараметр("Район"			, ТекущийОбъект.Объект.Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НовСтр = ТекущийОбъект.Объект.ВидыБлагоустройств.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр,ВыборкаДетальныеЗаписи);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьВидБлагоустройстваМКД(ТекущийОбъект) Экспорт
	
	ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргВидБлагоустройствМКДСрезПоследних.Услуга КАК Услуга,
		|	энргВидБлагоустройствМКДСрезПоследних.ВидБлагоустройства КАК ВидБлагоустройстваОбщедомовой
		|ИЗ
		|	РегистрСведений.энргВидБлагоустройствМКД.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И МКД = &МКД) КАК энргВидБлагоустройствМКДСрезПоследних
		|
		|СГРУППИРОВАТЬ ПО
		|	энргВидБлагоустройствМКДСрезПоследних.Услуга,
		|	энргВидБлагоустройствМКДСрезПоследних.ВидБлагоустройства";
	
	Запрос.УстановитьПараметр("МКД"			, ТекущийОбъект.Объект.МКД);
	Запрос.УстановитьПараметр("Организация"	, ТекущийОбъект.Объект.Организация);
	Запрос.УстановитьПараметр("Период"		, новый Граница(ТекущийОбъект.Объект.Дата,ВидГраницы.Исключая));//Запрос.УстановитьПараметр("Период", ТекущийОбъект.Объект.ПериодНачисления);
	Запрос.УстановитьПараметр("Район"		, ТекущийОбъект.Объект.Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НовСтр = ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр,ВыборкаДетальныеЗаписи);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьГруппуПотребителейАбонентов(ТекущийОбъект) Экспорт
	
	ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргАктивностьТочекУчетаСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
		|ПОМЕСТИТЬ АктивныеТУ
		|ИЗ
		|	РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргАктивностьТочекУчетаСрезПоследних
		|ГДЕ
		|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
		|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга
		|ПОМЕСТИТЬ ВТ_Услуги
		|ИЗ
		|	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения
		|				И ТочкаУчета В
		|					(ВЫБРАТЬ
		|						АктивныеТУ.ТочкаУчета
		|					ИЗ
		|						АктивныеТУ КАК АктивныеТУ)) КАК энргУслугиТочекУчетаСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Услуги.ТочкаУчета КАК ТочкаУчета,
		|	ЕСТЬNULL(энргВидыУслугСоставляющиеУслуг.Услуга, ВТ_Услуги.Услуга) КАК Услуга
		|ПОМЕСТИТЬ СоставныеУслуги
		|ИЗ
		|	ВТ_Услуги КАК ВТ_Услуги
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
		|		ПО ВТ_Услуги.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргГруппыПотребителейАбонентовСрезПоследних.Услуга КАК Услуга,
		|	энргГруппыПотребителейАбонентовСрезПоследних.ГруппаПотребителей КАК ТарифнаяКатегория
		|ПОМЕСТИТЬ ВТ_ТарифныеКатегории
		|ИЗ
		|	РегистрСведений.энргГруппыПотребителейАбонентов.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения
		|				И Услуга В
		|					(ВЫБРАТЬ
		|						СоставныеУслуги.Услуга
		|					ИЗ
		|						СоставныеУслуги КАК СоставныеУслуги)) КАК энргГруппыПотребителейАбонентовСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СоставныеУслуги.Услуга КАК Услуга,
		|	ВТ_ТарифныеКатегории.ТарифнаяКатегория КАК ТарифнаяКатегория
		|ИЗ
		|	АктивныеТУ КАК АктивныеТУ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СоставныеУслуги КАК СоставныеУслуги
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ТарифныеКатегории КАК ВТ_ТарифныеКатегории
		|			ПО СоставныеУслуги.Услуга = ВТ_ТарифныеКатегории.Услуга
		|		ПО АктивныеТУ.ТочкаУчета = СоставныеУслуги.ТочкаУчета";
	
	Запрос.УстановитьПараметр("КлючПомещения"	, ТекущийОбъект.Объект.КлючПомещения);
	Запрос.УстановитьПараметр("Организация"		, ТекущийОбъект.Объект.Организация);
	Запрос.УстановитьПараметр("Период"			, новый Граница(ТекущийОбъект.Объект.Дата,ВидГраницы.Исключая));//ТекущийОбъект.Объект.ПериодНачисления);
	Запрос.УстановитьПараметр("Район"			, ТекущийОбъект.Объект.Район);
	                                 	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НовСтр = ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр,ВыборкаДетальныеЗаписи);
	КонецЦикла;

	
КонецПроцедуры
 
Функция ТочкиУчетаРазделенныхЛС(Период,Организация,Район,КлючПомещения,Услуга = Неопределено) Экспорт 
			
	Запрос = Новый Запрос;
	Текст = 
		"ВЫБРАТЬ
		|	энргКлючиПомещений.Строение КАК Строение,
		|	энргКлючиПомещений.Помещение КАК Помещение,
		|	энргПомещения.Ссылка КАК Комната
		|ПОМЕСТИТЬ КомнатыПомещения
		|ИЗ
		|	Справочник.энргКлючиПомещений КАК энргКлючиПомещений
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПомещения КАК энргПомещения
		|		ПО энргКлючиПомещений.Помещение = энргПомещения.Родитель
		|			И энргКлючиПомещений.Строение = энргПомещения.Строение
		|ГДЕ
		|	энргКлючиПомещений.Ссылка = &КлючПомещения
		|	И энргПомещения.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.Комната)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КомнатыПомещения.Строение КАК Строение,
		|	КомнатыПомещения.Помещение КАК Помещение,
		|	энргКлючиПомещений.КлючПомещения КАК КлючПомещения,
		|	КомнатыПомещения.Комната КАК Комната
		|ПОМЕСТИТЬ КлючиРазделенныхЛС
		|ИЗ
		|	КомнатыПомещения КАК КомнатыПомещения
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
			|		ПО КомнатыПомещения.Строение = энргКлючиПомещений.Строение
		|			И КомнатыПомещения.Комната = энргКлючиПомещений.Помещение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КлючиРазделенныхЛС.Строение КАК Строение,
		|	КлючиРазделенныхЛС.Помещение КАК Помещение,
		|	КлючиРазделенныхЛС.КлючПомещения КАК КлючПомещения,
		|	КлючиРазделенныхЛС.Комната КАК Комната,
		|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
		|	энргАктивностьТочекУчетаСрезПоследних.Организация КАК Организация,
		|	энргАктивностьТочекУчетаСрезПоследних.Район КАК Район
		|ПОМЕСТИТЬ АктивныеТочкиУчетаАбонента
		|ИЗ
		|	КлючиРазделенныхЛС КАК КлючиРазделенныхЛС
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
		|				&Период,
		|				Организация = &Организация
		|					И Район = &Район
		|					И КлючПомещения В
		|						(ВЫБРАТЬ
		|							КлючиРазделенныхЛС.КлючПомещения
		|						ИЗ
		|							КлючиРазделенныхЛС)) КАК энргАктивностьТочекУчетаСрезПоследних
		|		ПО КлючиРазделенныхЛС.КлючПомещения = энргАктивностьТочекУчетаСрезПоследних.КлючПомещения
		|ГДЕ
		|	энргАктивностьТочекУчетаСрезПоследних.Состояние в (ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена),ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.ОРП))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргВладельцыТочекУчетаСрезПоследних.Организация КАК Организация,
		|	энргВладельцыТочекУчетаСрезПоследних.Район КАК Район,
		|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
		|ПОМЕСТИТЬ ТочкиУчетаАбонента
		|ИЗ
		|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ТочкаУчета В
		|					(ВЫБРАТЬ
		|						АктивныеТочкиУчетаАбонента.ТочкаУчета
		|					ИЗ
		|						АктивныеТочкиУчетаАбонента)) КАК энргВладельцыТочекУчетаСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	АктивныеТочкиУчетаАбонента.Строение КАК Строение,
		|	АктивныеТочкиУчетаАбонента.Помещение КАК Помещение,
		|	АктивныеТочкиУчетаАбонента.Комната КАК Комната,
		|	ТочкиУчетаАбонента.ТочкаУчета КАК ТочкаУчета,
		|	АктивныеТочкиУчетаАбонента.КлючПомещения КАК КлючПомещения,
		|	АктивныеТочкиУчетаАбонента.Организация КАК Организация,
		|	АктивныеТочкиУчетаАбонента.Район КАК Район
		|ПОМЕСТИТЬ ДействующиеТочкиУчета
		|ИЗ
		|	АктивныеТочкиУчетаАбонента КАК АктивныеТочкиУчетаАбонента
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТочкиУчетаАбонента КАК ТочкиУчетаАбонента
		|		ПО АктивныеТочкиУчетаАбонента.ТочкаУчета = ТочкиУчетаАбонента.ТочкаУчета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДействующиеТочкиУчета.КлючПомещения КАК КлючПомещения,
		|	ДействующиеТочкиУчета.Строение КАК Строение,
		|	ДействующиеТочкиУчета.Комната КАК Помещение,
		|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга,
		|	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
		|ИЗ
		|	ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
		|				&Период,
		|				Организация = &Организация
		|					И Район = &Район
		|					И КлючПомещения В
		|						(ВЫБРАТЬ
		|							ДействующиеТочкиУчета.КлючПомещения
		|						ИЗ
		|							ДействующиеТочкиУчета)) КАК энргУслугиТочекУчетаСрезПоследних
		|		ПО ДействующиеТочкиУчета.Организация = энргУслугиТочекУчетаСрезПоследних.Организация
		|			И ДействующиеТочкиУчета.Район = энргУслугиТочекУчетаСрезПоследних.Район
		|			И ДействующиеТочкиУчета.КлючПомещения = энргУслугиТочекУчетаСрезПоследних.КлючПомещения
		|			И ДействующиеТочкиУчета.ТочкаУчета = энргУслугиТочекУчетаСрезПоследних.ТочкаУчета
		|ГДЕ
		|	энргУслугиТочекУчетаСрезПоследних.Услуга = &Услуга";
	
	Запрос.УстановитьПараметр("Период",					КонецДня(Период));
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("КлючПомещения",			КлючПомещения);
	Запрос.УстановитьПараметр("Услуга",					Услуга);
	

	
	Если Не ЗначениеЗаполнено(Услуга) Тогда
		Текст 						= СтрЗаменить(Текст,"ГДЕ
		|	энргУслугиТочекУчетаСрезПоследних.Услуга = &Услуга","");
	КонецЕсли;
	
	Запрос.Текст = Текст;
	
	Результат  = Запрос.Выполнить();
	Возврат Результат;

КонецФункции

Функция ЗаполнитьПлощадьМКД(Период, Организация, Район, Строение = Неопределено, ВидПлощади = Неопределено, Услуга = Неопределено) Экспорт
 	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргВладельцыТочекУчетаСрезПоследних.Организация КАК Организация,
		|	энргВладельцыТочекУчетаСрезПоследних.Район КАК Район,
		|	энргВладельцыТочекУчетаСрезПоследних.АбонентВладелец КАК МКД,
		|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
		|ПОМЕСТИТЬ ТочкиУчетаМКД
		|ИЗ
		|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район) КАК энргВладельцыТочекУчетаСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТочкиУчета КАК энргТочкиУчета
		|		ПО энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета = энргТочкиУчета.Ссылка
		|ГДЕ
		|	энргВладельцыТочекУчетаСрезПоследних.АбонентВладелец = &МКД
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	АктивностьТочекУчета.Организация КАК Организация,
		|	АктивностьТочекУчета.Район КАК Район,
		|	АктивностьТочекУчета.МКД КАК МКД,
		|	АктивностьТочекУчета.ТочкаУчета КАК ТочкаУчета
		|ПОМЕСТИТЬ ДействующиеТочкиМКД
		|ИЗ
		|	РегистрСведений.энргАктивностьТочекУчетаМКД.СрезПоследних(
		|			&Период,
		|			(Организация, Район, МКД, ТочкаУчета) В
		|				(ВЫБРАТЬ
		|					ТочкиУчетаМКД.Организация,
		|					ТочкиУчетаМКД.Район,
		|					ТочкиУчетаМКД.МКД,
		|					ТочкиУчетаМКД.ТочкаУчета
		|				ИЗ
		|					ТочкиУчетаМКД КАК ТочкиУчетаМКД)) КАК АктивностьТочекУчета
		|ГДЕ
		|	АктивностьТочекУчета.Состояние = ЗНАЧЕНИЕ(ПЕречисление.энргСостояниеТочекУчета.Включена)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	УслугиТочекУчетаМКДСрезПоследних.Организация КАК Организация,
		|	УслугиТочекУчетаМКДСрезПоследних.Район КАК Район,
		|	УслугиТочекУчетаМКДСрезПоследних.МКД КАК МКД,
		|	УслугиТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
		|	ВЫБОР
		|		КОГДА энргВидыУслугСоставляющиеУслуг.Услуга ЕСТЬ NULL
		|			ТОГДА УслугиТочекУчетаМКДСрезПоследних.Услуга
		|		ИНАЧЕ энргВидыУслугСоставляющиеУслуг.Услуга
		|	КОНЕЦ КАК Услуга
		|ПОМЕСТИТЬ УслугиДействующихТочек
		|ИЗ
		|	РегистрСведений.энргУслугиТочекУчетаМКД.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И (Организация, Район, МКД, ТочкаУчета) В
		|					(ВЫБРАТЬ
		|						ДействующиеТочкиМКД.Организация,
		|						ДействующиеТочкиМКД.Район,
		|						ДействующиеТочкиМКД.МКД,
		|						ДействующиеТочкиМКД.ТочкаУчета
		|					ИЗ
		|						ДействующиеТочкиМКД КАК ДействующиеТочкиМКД)) КАК УслугиТочекУчетаМКДСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
		|		ПО УслугиТочекУчетаМКДСрезПоследних.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗначениеПлощадейМКДСрезПоследних.Организация КАК Организация,
		|	энргЗначениеПлощадейМКДСрезПоследних.Район КАК Район,
		|	энргЗначениеПлощадейМКДСрезПоследних.МКД КАК МКД,
		|	энргЗначениеПлощадейМКДСрезПоследних.ВидПлощади КАК ВидПлощади,
		|	энргЗначениеПлощадейМКДСрезПоследних.Услуга КАК Услуга,
		|	энргЗначениеПлощадейМКДСрезПоследних.Площадь КАК Площадь
		|ИЗ
		|	РегистрСведений.энргЗначениеПлощадейМКД.СрезПоследних(
		|			&Период,
		|			(Организация, Район, Услуга) В
		|					(ВЫБРАТЬ
		|						УслугиДействующихТочек.Организация КАК Организация,
		|						УслугиДействующихТочек.Район КАК Район,
		|						УслугиДействующихТочек.Услуга КАК Услуга
		|					ИЗ
		|						УслугиДействующихТочек КАК УслугиДействующихТочек)
		|				И Организация = &Организация
		|				И Район = &Район
		|				И МКД = &Строение) КАК энргЗначениеПлощадейМКДСрезПоследних
		|ГДЕ
		|	энргЗначениеПлощадейМКДСрезПоследних.ВидПлощади = ЗНАЧЕНИЕ(перечисление.энргВидыПлощадей.ПлощадьМОП)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	энргЗначениеПлощадейМКДСрезПоследних.Организация,
		|	энргЗначениеПлощадейМКДСрезПоследних.Район,
		|	энргЗначениеПлощадейМКДСрезПоследних.МКД,
		|	энргЗначениеПлощадейМКДСрезПоследних.ВидПлощади,
		|	энргЗначениеПлощадейМКДСрезПоследних.Услуга,
		|	энргЗначениеПлощадейМКДСрезПоследних.Площадь
		|ИЗ
		|	РегистрСведений.энргЗначениеПлощадейМКД.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И МКД = &Строение) КАК энргЗначениеПлощадейМКДСрезПоследних
		|ГДЕ
		|	энргЗначениеПлощадейМКДСрезПоследних.ВидПлощади = ЗНАЧЕНИЕ(перечисление.энргВидыПлощадей.ОбщаяПлощадьМКД)";
	
	Запрос.УстановитьПараметр("МКД", Строение);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("Строение", Строение);
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса;
		
	
КонецФункции

Процедура ИзменитьТипСтроения(Строение, ТипСтроения, НеПроверятьНаличиеФайла = Неопределено) Экспорт
	СтроениеОбъект = Строение.ПолучитьОбъект();
	Если не НеПроверятьНаличиеФайла = Неопределено  Тогда
		СтроениеОбъект.ДополнительныеСвойства.Вставить("НеПроверятьНаличиеФайла", НеПроверятьНаличиеФайла);
	КонецЕсли;
	СтроениеОбъект.ТипСтроения = ТипСтроения; 	
	СтроениеОбъект.Записать();		
КонецПроцедуры


Процедура ЗаполнитьСхемуДанныхНаГраницуВремени(Схема, ПараметрыОтбора) Экспорт 
	
	#Область ДатаСостоянияЛицевогоСчета
	РегистрыСведений.энргСостояниеЛС.СостояниеЛицевогоСчета(Схема, ПараметрыОтбора, "СостояниеЛицевогоСчета");  
	#КонецОбласти
	
	#Область ВидБлагоустройства
	// ВТ - УслугиДействующихТочек
	РегистрыСведений.энргВидБлагоустройствАбонента.ВидБлагоустройстваДействующихТочек(Схема, ПараметрыОтбора, "ВидБлагоустройствАбонента");  
