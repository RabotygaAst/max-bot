Функция ПолучитьДлинуЛС(Дата, Организация) Экспорт
	ДлинаЛС	= 14;
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация",Организация); 
	Запрос.УстановитьПараметр("Дата",Дата);
	ЗАпрос.Текст = 
	"ВЫБРАТЬ
	|	ДлинаЛицевогоСчетаСрезПоследних.ДлинаЛС КАК ДлинаЛС
	|ИЗ
	|	РегистрСведений.энргДлинаЛицевогоСчета.СрезПоследних(&Дата, Организация = &Организация) КАК ДлинаЛицевогоСчетаСрезПоследних";
	Результат 	= Запрос.Выполнить();
	Выборка		= Результат.Выбрать();
	Выборка.Следующий();
	
	ДлинаЛС = Выборка.ДлинаЛС;
	
	Возврат ДлинаЛС;
КонецФункции

Функция ПолучитьСписокАбонентовМКДСПостановлениями(ДанныеШапки) Экспорт
	Запрос 			= Новый Запрос;
	Запрос.УстановитьПараметр("Организация", 			ДанныеШапки.Организация);
	Запрос.УстановитьПараметр("Район", 					ДанныеШапки.Район);
	Запрос.УстановитьПараметр("МКД", 					ДанныеШапки.МКД);
	Запрос.УстановитьПараметр("Дата", 					ДанныеШапки.Дата);
	Запрос.Текст 	= 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ЕСТЬNULL(бестРабочиеПостановленияАбонентовСрезПоследних.Постановление, ЗНАЧЕНИЕ(Перечисление.бестРабочиеПостановления.ПустаяСсылка)) КАК Постановление
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргАбоненты.Ссылка КАК Абонент
	|	ИЗ
	|		Справочник.энргАбоненты КАК энргАбоненты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|			ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.КлючПомещения
	|				И (энргКлючиПомещений.Строение = &МКД)) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестРабочиеПостановленияАбонентов.СрезПоследних(
	|				&Дата,
	|				Организация = &Организация
	|					И Район = &Район) КАК бестРабочиеПостановленияАбонентовСрезПоследних
	|		ПО ВложенныйЗапрос.Абонент = бестРабочиеПостановленияАбонентовСрезПоследних.Абонент";
	Результат 		= Запрос.Выполнить();
	Выгрузка		= Результат.Выбрать();
	
	Возврат Выгрузка;
КонецФункции

Процедура ПолучитьДанныеОДокументеФизЛица(ДатаЗапроса, ФизЛицо, ВидДокумента, Свойство, ПолучаемыеСвойства) Экспорт 
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Дата",			ДатаЗапроса);
	Запрос.УстановитьПараметр("Контрагент",		ФизЛицо);
	Запрос.УстановитьПараметр("ВидДокумента",	ВидДокумента);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	бестДокументыФизическихЛицСрезПоследних.Период КАК Период,
	|	бестДокументыФизическихЛицСрезПоследних.Серия КАК Серия,
	|	бестДокументыФизическихЛицСрезПоследних.Номер КАК Номер,
	|	бестДокументыФизическихЛицСрезПоследних.ДатаВыдачи КАК ДатаВыдачи,
	|	бестДокументыФизическихЛицСрезПоследних.СрокДействия КАК СрокДействия,
	|	бестДокументыФизическихЛицСрезПоследних.КемВыдан КАК КемВыдан,
	|	бестДокументыФизическихЛицСрезПоследних.КодПодразделения КАК КодПодразделения,
	|	бестДокументыФизическихЛицСрезПоследних.ЯвляетсяДокументомУдостоверяющимЛичность КАК ЯвляетсяДокументомУдостоверяющимЛичность,
	|	бестДокументыФизическихЛицСрезПоследних.Представление КАК Представление
	|ИЗ
	|	РегистрСведений.энргДокументыФизическихЛиц.СрезПоследних(
	|			&Дата,
	|			Контрагент = &Контрагент
	|				И ВидДокумента = &ВидДокумента) КАК бестДокументыФизическихЛицСрезПоследних";
	Результат  	= Запрос.Выполнить();
	Выборка  	= Результат.Выбрать();
	
	СтруктураДанных	= Новый Структура;
	для Каждого КолонкаРезультата из Результат.Колонки цикл
		СтруктураДанных.Вставить(КолонкаРезультата.Имя, "");	
	КонецЦикла;	
		
	Если Выборка.Следующий() тогда
		ЗаполнитьЗначенияСвойств(СтруктураДанных,Выборка);
	КонецЕсли;
	
	ПолучаемыеСвойства[Свойство] = СтруктураДанных;
КонецПроцедуры

Функция ДанныеДляОплатыАбонента(Период, Организация, Район, МКД, Абонент, ДополнительныеПараметры = Неопределено) Экспорт 
	ПериодОплатыНачало 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ПериодОплатыНачало", Дата(1,1,1));
	ПериодОплатыКонец 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ПериодОплатыКонец", Дата(1,1,1));		 
	
	Запрос   			= Новый Запрос;
	Запрос.УстановитьПараметр("Период" ,			Период);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("МКД",				МКД);
	Запрос.УстановитьПараметр("Абонент",			Абонент);
	Запрос.УстановитьПараметр("ДатаНачала",			ПериодОплатыНачало);
	Запрос.УстановитьПараметр("ДатаКонца",			ПериодОплатыКонец);	
	Запрос.УстановитьПараметр("ТекДата",			ТекущаяДатаСеанса());
	
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления КАК ПериодНачисления,
	|	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
	|	ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.ОсновнойДолг) КАК ВидЗадолженности,
	|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток КАК Задолженность,
	|	энргВзаиморасчетыПоМесяцамОстатки.Поставщик КАК Поставщик
	|ПОМЕСТИТЬ ТекущиеОстатки
	|ИЗ
	|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И Абонент = &Абонент
	|				И (ПериодНачисления МЕЖДУ &ДатаНачала И &ДатаКонца)) КАК энргВзаиморасчетыПоМесяцамОстатки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргВзаиморасчетыПоПениОстатки.ПериодНачисления,
	|	энргВзаиморасчетыПоПениОстатки.Услуга,
	|	ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.Пеня),
	|	энргВзаиморасчетыПоПениОстатки.СуммаОстаток,
	|	ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка)
	|ИЗ
	|	РегистрНакопления.энргВзаиморасчетыПоПени.Остатки(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И Абонент = &Абонент
	|				И (ПериодНачисления МЕЖДУ &ДатаНачала И &ДатаКонца)) КАК энргВзаиморасчетыПоПениОстатки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргЗабалансоваяЗадолженностьОстатки.ПериодНачисления,
	|	энргЗабалансоваяЗадолженностьОстатки.Услуга,
	|	энргЗабалансоваяЗадолженностьОстатки.ВидЗадолженности,
	|	энргЗабалансоваяЗадолженностьОстатки.СуммаЗадолженностиОстаток,
	|	энргЗабалансоваяЗадолженностьОстатки.Поставщик
	|ИЗ
	|	РегистрНакопления.энргЗабалансоваяЗадолженность.Остатки(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И Абонент = &Абонент
	|				И ВидЗадолженности В (ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.МораторнаяЗадолженность), ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.РеструктуризированнаяЗадолженность))
	|				И (ПериодНачисления МЕЖДУ &ДатаНачала И &ДатаКонца)) КАК энргЗабалансоваяЗадолженностьОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргРеструктуризацияДолгаСрезПоследних.Организация КАК Организация,
	|	энргРеструктуризацияДолгаСрезПоследних.Район КАК Район,
	|	энргРеструктуризацияДолгаСрезПоследних.Строение КАК Строение,
	|	энргРеструктуризацияДолгаСрезПоследних.Абонент КАК Абонент,
	|	энргРеструктуризацияДолгаСрезПоследних.ДатаОплаты КАК ДатаОплаты,
	|	энргРеструктуризацияДолгаСрезПоследних.Документ КАК Документ,
	|	СУММА(ВЫБОР
	|			КОГДА энргВзаиморасчеты.ВидДвижения ЕСТЬ NULL
	|				ТОГДА 0
	|			КОГДА энргВзаиморасчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|				ТОГДА энргВзаиморасчеты.Сумма
	|			КОГДА энргВзаиморасчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|					И энргВзаиморасчеты.Сумма < 0
	|				ТОГДА -энргВзаиморасчеты.Сумма
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК Сумма,
	|	энргРеструктуризацияДолгаСрезПоследних.СуммаНарастающимИтогом КАК СуммаНарастающимИтогом,
	|	энргРеструктуризацияДолгаСрезПоследних.СуммаОбщая КАК СуммаОбщая
	|ПОМЕСТИТЬ Реструктуризация
	|ИЗ
	|	РегистрСведений.энргРеструктуризацияДолга.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Строение = &МКД
	|				И Абонент = &Абонент) КАК энргРеструктуризацияДолгаСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.энргВзаиморасчеты КАК энргВзаиморасчеты
	|		ПО энргРеструктуризацияДолгаСрезПоследних.Организация = энргВзаиморасчеты.Организация
	|			И энргРеструктуризацияДолгаСрезПоследних.Район = энргВзаиморасчеты.Район
	|			И энргРеструктуризацияДолгаСрезПоследних.Строение = энргВзаиморасчеты.МКД
	|			И энргРеструктуризацияДолгаСрезПоследних.Абонент = энргВзаиморасчеты.Абонент
	|			И энргРеструктуризацияДолгаСрезПоследних.ДатаНачала <= энргВзаиморасчеты.Период
	|			И энргРеструктуризацияДолгаСрезПоследних.ДатаОплаты >= энргВзаиморасчеты.Период
	|ГДЕ
	|	энргРеструктуризацияДолгаСрезПоследних.ДатаПредыдущегоЭтапа <= &ТекДата
	|
	|СГРУППИРОВАТЬ ПО
	|	энргРеструктуризацияДолгаСрезПоследних.Организация,
	|	энргРеструктуризацияДолгаСрезПоследних.Район,
	|	энргРеструктуризацияДолгаСрезПоследних.Строение,
	|	энргРеструктуризацияДолгаСрезПоследних.Абонент,
	|	энргРеструктуризацияДолгаСрезПоследних.ДатаОплаты,
	|	энргРеструктуризацияДолгаСрезПоследних.Документ,
	|	энргРеструктуризацияДолгаСрезПоследних.СуммаНарастающимИтогом,
	|	энргРеструктуризацияДолгаСрезПоследних.СуммаОбщая
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Реструктуризация.Документ КАК Документ,
	|	Реструктуризация.СуммаОбщая КАК СуммаОбщая,
	|	МИНИМУМ(Реструктуризация.Сумма >= Реструктуризация.СуммаНарастающимИтогом) КАК ОтметкаВыполненного
	|ПОМЕСТИТЬ ВыполненныеРеструктуризации
	|ИЗ
	|	Реструктуризация КАК Реструктуризация
	|
	|СГРУППИРОВАТЬ ПО
	|	Реструктуризация.Документ,
	|	Реструктуризация.СуммаОбщая
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗабалансоваяЗадолженностьОстаткиИОбороты.ПериодНачисления КАК ПериодНачисления,
	|	энргЗабалансоваяЗадолженностьОстаткиИОбороты.Услуга КАК Услуга,
	|	энргЗабалансоваяЗадолженностьОстаткиИОбороты.Поставщик КАК Поставщик,
	|	энргЗабалансоваяЗадолженностьОстаткиИОбороты.СуммаЗадолженностиКонечныйОстаток КАК Задолженность
	|ПОМЕСТИТЬ СуммыЗабаланса
	|ИЗ
	|	РегистрНакопления.энргЗабалансоваяЗадолженность.ОстаткиИОбороты(
	|			,
	|			&Период,
	|			Регистратор,
	|			,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И Абонент = &Абонент
	|				И ВидЗадолженности В (ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.РеструктуризированнаяЗадолженность))
	|				И (ПериодНачисления МЕЖДУ &ДатаНачала И &ДатаКонца)) КАК энргЗабалансоваяЗадолженностьОстаткиИОбороты
	|ГДЕ
	|	энргЗабалансоваяЗадолженностьОстаткиИОбороты.Регистратор В
	|			(ВЫБРАТЬ
	|				ВыполненныеРеструктуризации.Документ
	|			ИЗ
	|				ВыполненныеРеструктуризации КАК ВыполненныеРеструктуризации)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТекущиеОстатки.ПериодНачисления КАК ПериодНачисления,
	|	ТекущиеОстатки.Услуга КАК Услуга,
	|	ТекущиеОстатки.ВидЗадолженности КАК ВидЗадолженности,
	|	ТекущиеОстатки.Задолженность - ЕСТЬNULL(СуммыЗабаланса.Задолженность, 0) КАК Задолженность,
	|	ТекущиеОстатки.Поставщик КАК Поставщик
	|ИЗ
	|	ТекущиеОстатки КАК ТекущиеОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ СуммыЗабаланса КАК СуммыЗабаланса
	|		ПО ТекущиеОстатки.ПериодНачисления = СуммыЗабаланса.ПериодНачисления
	|			И ТекущиеОстатки.Услуга = СуммыЗабаланса.Услуга
	|			И ТекущиеОстатки.Поставщик = СуммыЗабаланса.Поставщик
	|			И (ТекущиеОстатки.ВидЗадолженности = ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.ОсновнойДолг))
	|ГДЕ
	|	ТекущиеОстатки.Задолженность - ЕСТЬNULL(СуммыЗабаланса.Задолженность, 0) > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПериодНачисления"; 
	
	Если НЕ ЗначениеЗаполнено(ПериодОплатыНачало) и НЕ ЗначениеЗаполнено(ПериодОплатыКонец) Тогда
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "И (ПериодНачисления МЕЖДУ &ДатаНачала И &ДатаКонца)", "");
	КонецЕсли;
	
	Результат  		= Запрос.Выполнить();
	Возврат Результат;
	
КонецФункции

Функция ПолучитьАктуальныйСпособДоставкиКвитанции(Период, Организация, Район, КлючПомещения, Абонент) Экспорт	
	Схема 			= Новый СхемаЗапроса;  	
	ПараметрыВТ 	= Новый Массив;
	
	ПараметрТипРавно = энргФормированиеТекстовЗапроса.ПараметрТипРавно(	
		Новый Структура("Организация, Район, КлючПомещения, Абонент", 	
		"Организация", "Район", "КлючПомещения", "Абонент"));
	ПараметрыВТ.Добавить(ПараметрТипРавно); 
	
	Параметры 		= Новый Структура;	
	Параметры.Вставить("ПараметрыВТ", 	ПараметрыВТ);
	Параметры.Вставить("Период",  		Новый Структура("ИмяПараметра", "Период"));
	
	РегистрыСведений.энргСпособыДоставкиКвитанции.ПолучитьАктуальныйСпособДоставкиКвитанции(Схема, Параметры);
	
	Запрос 			= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("Период"	      	, Период);
	Запрос.УстановитьПараметр("Организация"		, Организация);
