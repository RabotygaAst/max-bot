Функция ПолучитьСтрокиСоединенияЗапроса(ОсновнаяТаблица, СоединяемаяТаблица, СтруктураСоединения, ТипСоединения = "ЛЕВОЕ")
	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить(СтрШаблон(ТипСоединения + " СОЕДИНЕНИЕ %1 КАК %1", СоединяемаяТаблица));
	
	Союз 				= "ПО ";
	ШаблонСоединения 	= "%1.%2 = %3.%4";
	Для Каждого ТекКлючЗначение из СтруктураСоединения Цикл
		СтрокаСоединения = СтрШаблон(ШаблонСоединения, ОсновнаяТаблица, ТекКлючЗначение.Ключ, СоединяемаяТаблица, ТекКлючЗначение.Значение);
		МассивСтрок.Добавить(Союз + СтрокаСоединения);
		
		Союз = "И ";
	КонецЦикла;
	
	Возврат СтрСоединить(МассивСтрок, Символы.ПС);
КонецФункции

