#Область ОсновныеПроцедуры

Процедура ПриЧтенииНаСервере(Форма, ИмяКоллекции) Экспорт 
		
	Коллекция 				= Форма.Объект[ИмяКоллекции];
	Запрос 					= Новый Запрос;
	Запрос.УстановитьПараметр("ДанныеТабЧасти",Коллекция.Выгрузить()); 
	Запрос.Текст 			= 
	"ВЫБРАТЬ
	|	ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|	ДанныеТабЧасти.Абонент КАК Абонент
	|ПОМЕСТИТЬ ДанныеТабЧасти
	|ИЗ
	|	&ДанныеТабЧасти КАК ДанныеТабЧасти
	|ГДЕ
	|	НЕ ДанныеТабЧасти.Абонент = ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
	|	ВложенныйЗапрос.ФизЛицо КАК ФизическоеЛицо,
	|	ВложенныйЗапрос.ЛицевойСчет КАК ЛицевойСчет,
	|	энргАбонентыКонтактнаяИнформация.Представление КАК АдресОбъекта,
	|	энргАбонентыКонтактнаяИнформация.ЗначенияПолей КАК АдресОбъектаПредставлениеПолей,
	|	ВложенныйЗапрос.ВидОбъекта КАК ВидОбъекта,
	|	энргАбонентыКонтактнаяИнформация.Значение КАК АдресОбъектаЗначение,
	|	ЕСТЬNULL(энргФилиалыАбонентов.Филиал, ЗНАЧЕНИЕ(Справочник.энргФилиалы.ПустаяСсылка)) КАК Филиал,
	|	ВложенныйЗапрос.СлужебныеОтметки КАК СлужебныеОтметки
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|		ДанныеТабЧасти.Абонент КАК Абонент,
	|		энргАбоненты.ФизЛицо КАК ФизЛицо,
	|		энргАбоненты.ЛицевойСчет КАК ЛицевойСчет,
	|		энргАбоненты.ВидОбъекта КАК ВидОбъекта,
	|		энргАбоненты.СлужебныеОтметки КАК СлужебныеОтметки
	|	ИЗ
	|		ДанныеТабЧасти КАК ДанныеТабЧасти
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ПО ДанныеТабЧасти.Абонент = энргАбоненты.Ссылка) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
	|		ПО ВложенныйЗапрос.Абонент = энргАбонентыКонтактнаяИнформация.Ссылка
	|			И (энргАбонентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес))
	|			И (энргАбонентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресОбъекта))
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргФилиалыАбонентов.СрезПоследних(
	|				,
	|				Абонент В
	|					(ВЫБРАТЬ
	|						ВТ.Абонент
	|					ИЗ
	|						ДанныеТабЧасти КАК ВТ)) КАК энргФилиалыАбонентов
	|		ПО ВложенныйЗапрос.Абонент = энргФилиалыАбонентов.Абонент";
	
	Результат  									= Запрос.Выполнить();
	Выборка 									= Результат.Выбрать();
	                       	
	Пока Выборка.Следующий() Цикл
		СтрокаДляЗаполнения 					= Коллекция[Выборка.НомерСтроки - 1];
		ЗаполнитьЗначенияСвойств(СтрокаДляЗаполнения, Выборка,,"НомерСтроки");
	КонецЦикла;
	
	Для Каждого СтрокаТочки Из Коллекция Цикл
		Если ЗначениеЗаполнено(СтрокаТочки.Абонент) Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТочки.ОписаниеАбонента) Тогда
			Продолжить;
		КонецЕсли;
		
		Чтение 									= Новый ЧтениеJSON();
		Чтение.УстановитьСтроку(СтрокаТочки.ОписаниеАбонента);
		ОписаниеАбонента						= ПрочитатьJSON(Чтение);
		Для Каждого КлючЗначение Из ОписаниеАбонента Цикл
			Если КлючЗначение.Ключ = "ФизическоеЛицо" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргКонтрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "ВидОбъекта" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргВидыОбъектовАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "Филиал" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргФилиалы.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "КлючПомещения" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргКлючиПомещений.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			Иначе
				СтрокаТочки[КлючЗначение.Ключ] 	= КлючЗначение.Значение;
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла;	
	
КонецПроцедуры

Процедура ПриЧтенииНаСервереМКД(Форма, ИмяКоллекции) Экспорт 
		
	Коллекция 				= Форма.Объект[ИмяКоллекции];
	Запрос 					= Новый Запрос;
	Запрос.УстановитьПараметр("ДанныеТабЧасти",Коллекция.Выгрузить()); 
	Запрос.Текст 			= 
	"ВЫБРАТЬ
	|	ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|	ДанныеТабЧасти.МКД КАК МКД
	|ПОМЕСТИТЬ ДанныеТабЧасти
	|ИЗ
	|	&ДанныеТабЧасти КАК ДанныеТабЧасти
	|ГДЕ
	|	НЕ ДанныеТабЧасти.МКД = ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
	|	ВложенныйЗапрос.ГодПостройки КАК ГодПостройки,
	|	ВложенныйЗапрос.Бойлер КАК Бойлер,
	|	энргСтроенияКонтактнаяИнформация.Представление КАК АдресОбъекта,
	|	энргСтроенияКонтактнаяИнформация.ЗначенияПолей КАК АдресОбъектаПредставлениеПолей,
	|	ВложенныйЗапрос.ВидОбъектаАбонентов КАК ВидОбъектаАбонентов,
	|	ВложенныйЗапрос.ГруппаПотребителейПоУмолчанию КАК ГруппаПотребителейПоУмолчанию
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|		ДанныеТабЧасти.МКД КАК МКД,
	|		энргСтроения.ГодПостройки КАК ГодПостройки,
	|		энргСтроения.Бойлер КАК Бойлер,
	|		энргСтроения.ВидОбъектаАбонентов КАК ВидОбъектаАбонентов,
	|		энргСтроения.ГруппаПотребителейПоУмолчанию КАК ГруппаПотребителейПоУмолчанию
	|	ИЗ
	|		ДанныеТабЧасти КАК ДанныеТабЧасти
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргСтроения КАК энргСтроения
	|			ПО ДанныеТабЧасти.МКД = энргСтроения.Ссылка) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
	|		ПО ВложенныйЗапрос.МКД = энргСтроенияКонтактнаяИнформация.Ссылка
	|			И (энргСтроенияКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес))
	|			И (энргСтроенияКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресДома))";
	
	Результат  									= Запрос.Выполнить();
	Выборка 									= Результат.Выбрать();
	                       	
	Пока Выборка.Следующий() Цикл
		СтрокаДляЗаполнения 					= Коллекция[Выборка.НомерСтроки - 1];
		ЗаполнитьЗначенияСвойств(СтрокаДляЗаполнения, Выборка,,"НомерСтроки");
	КонецЦикла;
	
	Для Каждого СтрокаТочки Из Коллекция Цикл
		Если ЗначениеЗаполнено(СтрокаТочки.МКД) Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТочки.ОписаниеМКД) Тогда
			Продолжить;
		КонецЕсли;
		
		Чтение 									= Новый ЧтениеJSON();
		Чтение.УстановитьСтроку(СтрокаТочки.ОписаниеМКД);
		ОписаниеМКД						= ПрочитатьJSON(Чтение);
		Для Каждого КлючЗначение Из ОписаниеМКД Цикл
			Если КлючЗначение.Ключ = "ВидОбъектаАбонентов" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргКонтрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "ГруппаПотребителейПоУмолчанию" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргВидыОбъектовАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			Иначе
				СтрокаТочки[КлючЗначение.Ключ] 	= КлючЗначение.Значение;        
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла;	
	
КонецПроцедуры

Процедура ПриЧтенииНаСервереДанныеПомещенияКоллекция(ОбъектыФормы, ИмяКоллекции) Экспорт 
	
	ДанныеТабЧасти 					= Новый ТаблицаЗначений;
	ДанныеТабЧасти.Колонки.Добавить("ИдентификаторСтроки",Новый ОписаниеТипов("Число"));
	ДанныеТабЧасти.Колонки.Добавить("КлючПомещения",Новый ОписаниеТипов("СправочникСсылка.энргКлючиПомещений"));
	
	Для Каждого СтрокаТабЧасти Из ОбъектыФормы[ИмяКоллекции] Цикл
		Строка 						= ДанныеТабЧасти.Добавить();
		Строка.КлючПомещения 		= СтрокаТабЧасти.КлючПомещения;
		Строка.ИдентификаторСтроки  = СтрокаТабЧасти.ПолучитьИдентификатор();		
	КонецЦикла;
	
	Текст 							=
	"ВЫБРАТЬ
	|	ДанныеТабЧасти.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	ДанныеТабЧасти.КлючПомещения КАК КлючПомещения
	|ПОМЕСТИТЬ ДанныеТабЧасти
	|ИЗ
	|	&ДанныеТабЧасти КАК ДанныеТабЧасти
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеТабЧасти.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	энргКлючиПомещений.Строение КАК Строение,
	|	энргКлючиПомещений.Помещение КАК Помещение
	|ИЗ
	|	ДанныеТабЧасти КАК ДанныеТабЧасти
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО ДанныеТабЧасти.КлючПомещения = энргКлючиПомещений.КлючПомещения";
	
	Запрос  						= Новый Запрос(Текст);
	Запрос.УстановитьПараметр("ДанныеТабЧасти",ДанныеТабЧасти);
	Результат 						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		 Строка  					= ОбъектыФормы[ИмяКоллекции].НайтиПоИдентификатору(Выборка.ИдентификаторСтроки);
		 Строка.Строение 			= Выборка.Строение;
		 Строка.Помещение 			= Выборка.Помещение;	
	КонецЦикла;
	
КонецПроцедуры

Процедура ПрочитатьДанныеАбонента(ОбъектыФормы, ТекущийОбъект) Экспорт 
	
	Абонент = ?(ТекущийОбъект.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСЛС_СменаСобственника, ТекущийОбъект.АбонентСмена, ТекущийОбъект.Абонент);
	
	//Если ЗначениеЗаполнено(ТекущийОбъект.Абонент) Тогда
	Если ЗначениеЗаполнено(Абонент) Тогда
		
		Запрос  									= Новый Запрос;
		//Запрос.УстановитьПараметр("Абонент",ТекущийОбъект.Абонент); 
		Запрос.УстановитьПараметр("Абонент",Абонент); 
		Запрос.Текст 								=
		"ВЫБРАТЬ
		|	энргАбоненты.ВидОбъекта КАК ВидОбъекта,
		|	энргАбоненты.МуниципальноеОбразование КАК МуниципальноеОбразование,
		|	энргАбоненты.ФизЛицо КАК ФизЛицо
		|ИЗ
		|	Справочник.энргАбоненты КАК энргАбоненты
		|ГДЕ
		|	энргАбоненты.Ссылка = &Абонент";
		Результат 									= Запрос.Выполнить();
		Если Результат.Пустой() Тогда
			Возврат;
		КонецЕсли;
		
		Выборка  									= Результат.Выбрать();
		Выборка.Следующий();
		
		ОбъектыФормы.ФизЛицо 						= Выборка.ФизЛицо;
		ОбъектыФормы.ВидОбъекта 					= Выборка.ВидОбъекта;
		ОбъектыФормы.МуниципальноеОбразование 		= Выборка.МуниципальноеОбразование;
		
		Запрос.Текст 								=
		"ВЫБРАТЬ
		|	энргАбонентыКонтактнаяИнформация.Представление КАК Представление,
		|	энргАбонентыКонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей,
		|	энргАбонентыКонтактнаяИнформация.Значение КАК Значение
		|ИЗ
		|	Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
		|ГДЕ
		|	энргАбонентыКонтактнаяИнформация.Ссылка = &Абонент";
		Результат 									= Запрос.Выполнить();
		Если НЕ Результат.Пустой() Тогда
			Выборка  								= Результат.Выбрать();
			Выборка.Следующий();
			ОбъектыФормы.АдресОбъекта 				= Выборка.Представление;
			ОбъектыФормы.АдресОбъектаЗначение 		= ?(НЕ ПустаяСтрока(Выборка.Значение),Выборка.Значение,Выборка.ЗначенияПолей);
		КонецЕсли; 	
		
		
		Запрос.Текст 							=
		"ВЫБРАТЬ
		|	энргИдентификаторыАбонентаГИСЖКХ.ОКТМО КАК ОКТМО
		|ИЗ
		|	РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
		|ГДЕ
		|	энргИдентификаторыАбонентаГИСЖКХ.Абонент = &Абонент";
		Результат 									= Запрос.Выполнить();
		Если НЕ Результат.Пустой() Тогда
			Выборка  								= Результат.Выбрать();
			Выборка.Следующий();
			ОбъектыФормы.ОКТМО 						= Выборка.ОКТМО;
		КонецЕсли;
		
	ИначеЕсли Не ПустаяСтрока(ТекущийОбъект.ОписаниеАбонента) Тогда
		
		ДанныеАбонента 							= ДанныеАбонентаИзСтрокиJSON(ТекущийОбъект.ОписаниеАбонента);
		ЗаполнитьЗначенияСвойств(ОбъектыФормы, ДанныеАбонента);   
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПрочитатьДанныеПомещения(ОбъектыФормы, РезультатДанныеПомещения) Экспорт 
	 	
	Если Не РезультатДанныеПомещения.Пустой() ТОгда
		Выборка 						= РезультатДанныеПомещения.Выбрать();
		Выборка.Следующий();
		ОбъектыФормы.Строение 			= Выборка.Строение;
		ОбъектыФормы.Помещение 			= Выборка.Помещение;
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ОбъектыФормы,"ЧастныйСектор") Тогда
			ОбъектыФормы.ЧастныйСектор 	= Выборка.ЧастныйСектор;
		КонецЕсли;			
	КонецЕсли;
			
КонецПроцедуры

Процедура ПроверитьИСоздатьМКД(ТекущийОбъект,Отказ) Экспорт 
	
	ДанныеМКД 			= ДанныеМКДИзСтрокиJSON(ТекущийОбъект.ОписаниеМКД);
	
	//ДанныеМКД.Вставить("ТерриториальныйОрган",ТекущийОбъект.ТерриториальныйОрган);
	//ДанныеМКД.Вставить("Филиал",ТекущийОбъект.ТерриториальныйОрган);
	
	//// проверяем адрес						
	Отказ 					= Истина;
	
	Если ДанныеМКД.Свойство("АдресОбъектаЗначение") И ЗначениеЗаполнено(ДанныеМКД.АдресОбъектаЗначение) Тогда
		Чтение  			= Новый ЧтениеJSON();
		Чтение.УстановитьСтроку(ДанныеМКД.АдресОбъектаЗначение);
		ДанныеАдреса		= ПрочитатьJSON(Чтение);
		Если НЕ ДанныеАдреса.Свойство("apartments") ИЛИ ДанныеАдреса.apartments.Количество() = 0 Тогда 			
			Отказ 			= Ложь; 			
		КонецЕсли;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("АдресОбъектаСтроительныйЗначение") И ЗначениеЗаполнено(ДанныеМКД.АдресОбъектаСтроительныйЗначение) Тогда
		Чтение  			= Новый ЧтениеJSON();
		Чтение.УстановитьСтроку(ДанныеМКД.АдресОбъектаСтроительныйЗначение);
		ДанныеАдреса		= ПрочитатьJSON(Чтение);
		Если НЕ ДанныеАдреса.Свойство("apartments") ИЛИ ДанныеАдреса.apartments.Количество() = 0 Тогда
			Отказ 			= Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ЭтоНовыйМКД") И ТекущийОбъект.ДополнительныеСвойства.ЭтоНовыйМКД Тогда
		МКДОбъект				= Справочники.энргСтроения.СоздатьЭлемент();
		МКДОбъект.УстановитьСсылкуНового(ТекущийОбъект.МКД);
	Иначе
		МКДОбъект 				= ТекущийОбъект.МКД.получитьОбъект();
	КонецЕсли;
	
	МКДОбъект.УлицаНедобавленнаяВФИАС = ТекущийОбъект.УлицаНедобавленнаяВФИАС;	
	ЗаполнитьРеквизитыМКД(ДанныеМКД,МКДОбъект); 	
	
КонецПроцедуры

