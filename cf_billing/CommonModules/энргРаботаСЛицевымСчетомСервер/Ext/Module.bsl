Функция ПолучитьВыбираемыеПоляИСоединенияСОсновнойТаблицейНаГраницу(Схема, Шаблон, ИмяОсновнойТаблицы = "УслугиДействующихТочек") Экспорт 
	ПараметрыОтбора = "";
	
	ПоляСоединения = Новый Структура;
	ПоляСоединения.Вставить("Организация"	, "Организация");
	ПоляСоединения.Вставить("Район"			, "Район");
	ПоляСоединения.Вставить("КлючПомещения"	, "КлючПомещения");
	
	ВыбираемыеПоля 		= Новый Массив;
	МассивСоединений 	= Новый Массив;
	
	#Область ДатаСостоянияЛицевогоСчета
	ВыбираемыеПоля.Добавить("СостояниеЛицевогоСчета.Период КАК ДатаСостоянияЛицевогоСчета");
	ПоляСоединения.Удалить("КлючПомещения");
	ПоляСоединения.Вставить("Абонент"	, "Абонент");	
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "СостояниеЛицевогоСчета", ПоляСоединения);
	ПоляСоединения.Удалить("Абонент");
	ПоляСоединения.Вставить("КлючПомещения"	, "КлючПомещения");
	МассивСоединений.Добавить(Результат);
	#КонецОбласти
	
	#Область ВидБлагоустройства
	ВыбираемыеПоля.Добавить("ВидБлагоустройствАбонента.ВидБлагоустройства КАК ВидБлагоустройства");
	ПоляСоединения.Вставить("Услуга"	, "Услуга");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "ВидБлагоустройствАбонента", ПоляСоединения);
	ПоляСоединения.Удалить("Услуга");
	МассивСоединений.Добавить(Результат);
	#КонецОбласти 	
	
	#Область КоличествоКомнат
	ВыбираемыеПоля.Добавить("КоличествоКомнат.Количество КАК КоличествоКомнат");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "КоличествоКомнат", ПоляСоединения);
	МассивСоединений.Добавить(Результат);
	#КонецОбласти
	
	#Область КоличествоПроживающих
	ВыбираемыеПоля.Добавить("КоличествоПроживающихПомещения.Количество КАК КоличествоПроживающих");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "КоличествоПроживающихПомещения", ПоляСоединения);
	МассивСоединений.Добавить(Результат);
	#КонецОбласти
	
	#Область КоличествоПрописанных
	ВыбираемыеПоля.Добавить("КоличествоПрописанныхПомещения.Количество КАК КоличествоПрописанных");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "КоличествоПрописанныхПомещения", ПоляСоединения);
	МассивСоединений.Добавить(Результат);
	#КонецОбласти 	
	
	#Область КоличествоСобственников
	ВыбираемыеПоля.Добавить("КоличествоСобственниковПомещения.Количество КАК КоличествоСобственников");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "КоличествоСобственниковПомещения", ПоляСоединения);
	МассивСоединений.Добавить(Результат);
	#КонецОбласти	
	
	#Область КоличествоЭтажей
	// Дополнить схемой этажности
	#КонецОбласти
	
	#Область КоэффициентПУ
	ВыбираемыеПоля.Добавить("КоэффциентыПриборовУчета.Коэффициент КАК КоэффициентПУ");
	ПоляСоединения.Вставить("ПриборУчета"	, "ПриборУчета");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "КоэффциентыПриборовУчета", ПоляСоединения);
	ПоляСоединения.Удалить("ПриборУчета");
	МассивСоединений.Добавить(Результат);
	#КонецОбласти
	
	#Область НаправлениеИспользованияТочекУчета
	ВыбираемыеПоля.Добавить("НаправлениеИспользованияДействующихТочек.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ");
	ПоляСоединения.Вставить("ТочкаУчета"	, "ТочкаУчета");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "НаправлениеИспользованияДействующихТочек", ПоляСоединения);
	МассивСоединений.Добавить(Результат);
	#КонецОбласти
	
	#Область энргТехническаяВозможностьУстановкиПУ
	ВыбираемыеПоля.Добавить("ТехническаяВозможностьУстановкиПУТочекУчета.НетВозможностьУстановкиПУ КАК НетВозможностьУстановкиПУ");
	ВыбираемыеПоля.Добавить("ТехническаяВозможностьУстановкиПУТочекУчета.РасчетТолькоПоПоказаниям КАК РасчетТолькоПоПоказаниям");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "ТехническаяВозможностьУстановкиПУТочекУчета", ПоляСоединения);	
	МассивСоединений.Добавить(Результат);
	#КонецОбласти
	
	#Область СвойствоТехническаяТочкиУчета
	ВыбираемыеПоля.Добавить("СвойствоТехническаяТочкиУчета.Техническая КАК Техническая");
	ПоляСоединения.Вставить("Услуга"	, "Услуга");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "СвойствоТехническаяТочкиУчета", ПоляСоединения);
	МассивСоединений.Добавить(Результат);
	#КонецОбласти 	
	
	#Область СпособРаспределенияОбъемаПомещения 
	ВыбираемыеПоля.Добавить("АктуальныеСпособыРаспределенияОбъемаПомещения.СпособРаспределения КАК СпособРаспределения");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "АктуальныеСпособыРаспределенияОбъемаПомещения", ПоляСоединения);
	ПоляСоединения.Удалить("Услуга");	
	МассивСоединений.Добавить(Результат);
	#КонецОбласти
		
	#Область ТочкаУчетаРодитель
	ВыбираемыеПоля.Добавить("АктуальныеРодителиТочекУчета.РодительТочкиУчета КАК РодительТочкиУчета");
	Результат = ПолучитьСтрокиСоединенияЗапроса(ИмяОсновнойТаблицы, "АктуальныеРодителиТочекУчета", ПоляСоединения);
	ПоляСоединения.Удалить("ТочкаУчета");
	МассивСоединений.Добавить(Результат);
