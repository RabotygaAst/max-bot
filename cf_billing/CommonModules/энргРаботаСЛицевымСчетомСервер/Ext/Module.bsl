	КонецЕсли;
	#КонецОбласти

	
	энргРаботаСЛицевымСчетомПереопределяемый.ПараметрыРасчетаПомещения(Организация,Район,КлючПомещения,Период,ПолучаемыеСвойства,ТекстыЗапросов);
	
	
	ИтоговыйТекст 				= ""; 
	ТекстРазделитель 			= "
	|;
	|////////////////////////////////////////
	|";

	Для Каждого КлючЗначение Из ТекстыЗапросов Цикл
		ИтоговыйТекст 			= ИтоговыйТекст + ?(НЕ ПустаяСтрока(ИтоговыйТекст),ТекстРазделитель,"") + КлючЗначение.Значение.Текст;		
	КонецЦикла;
	
	Запрос  					= Новый Запрос(ИтоговыйТекст);
	Запрос.УстановитьПараметр("Период",			Период);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.УстановитьПараметр("КлючПомещения",	яКлючПомещения);
	Запрос.УстановитьПараметр("Строение",		яСтроение);
	Запрос.УстановитьПараметр("Помещение",		КлючПомещения.Помещение); 
	Запрос.УстановитьПараметр("Организация",	Организация); 
	Результат  					= Запрос.ВыполнитьПакет(); 	
	
	Индекс 						= 0;
	Для Каждого КлючЗначение Из ТекстыЗапросов Цикл
		ОбработчикЗаполнения 	= КлючЗначение.Значение.ОбработчикЗаполнения;
		Параметры  				= Новый Массив;
		Параметры.Добавить(ПолучаемыеСвойства);
		Параметры.Добавить(Результат[Индекс]);
		ОбщегоНазначения.ВыполнитьМетодКонфигурации(ОбработчикЗаполнения,Параметры);		
		Индекс 					= Индекс + 1;		
	КонецЦикла;
	
КонецПроцедуры

Процедура ПараметрыРасчетаАбонента(Организация,Район,Абонент,Период,ПолучаемыеСвойства) Экспорт 
	
	ТекстДанныеАбонента	= 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Строение КАК Строение,
	|	ВложенныйЗапрос.Помещение КАК Помещение,
	|	ВложенныйЗапрос.ВидОбъекта КАК ВидОбъекта,
	|	ВложенныйЗапрос.МуниципальноеОбразование КАК МуниципальноеОбразование,
	|	ВложенныйЗапрос.ГруппаАбонента КАК ГруппаАбонента,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.ЛицевойСчет КАК ЛицевойСчет,
	|	ВложенныйЗапрос.СтарыйЛС КАК СтарыйЛС,
	|	ВложенныйЗапрос.ПредставлениеАбонента КАК ПредставлениеАбонента,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.ФизЛицо КАК ФизЛицо,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(энргСтроенияКонтактнаяИнформация.Представление, """") КАК СТРОКА(250)) КАК АдресСтроения,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(энргПомещенияКонтактнаяИнформация.Представление, ЕСТЬNULL(энргСтроенияКонтактнаяИнформация.Представление, """")) КАК СТРОКА(250)) КАК АдресОбъекта,
	|	энргСтроения.ТипПлиты КАК ТипПлиты
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргАбоненты.Ссылка КАК Ссылка,
	|		энргКлючиПомещений.Строение КАК Строение,
	|		энргКлючиПомещений.Помещение КАК Помещение,
	|		энргАбоненты.ВидОбъекта КАК ВидОбъекта,
	|		энргАбоненты.МуниципальноеОбразование КАК МуниципальноеОбразование,
	|		энргАбоненты.Родитель КАК ГруппаАбонента,
	|		энргАбоненты.Район КАК Район,
	|		энргАбоненты.ЛицевойСчет КАК ЛицевойСчет,
	|		энргАбоненты.СтарыйЛС КАК СтарыйЛС,
	|		энргАбоненты.Наименование КАК ПредставлениеАбонента,
	|		энргАбоненты.Организация КАК Организация,
	|		энргАбоненты.КлючПомещения КАК КлючПомещения,
	|		энргАбоненты.ФизЛицо КАК ФизЛицо
	|	ИЗ
	|		Справочник.энргАбоненты КАК энргАбоненты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|			ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.КлючПомещения
	|				И (энргАбоненты.Ссылка = &Абонент)) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения.КонтактнаяИнформация КАК энргПомещенияКонтактнаяИнформация
	|		ПО (энргПомещенияКонтактнаяИнформация.Ссылка = ВложенныйЗапрос.Помещение)
