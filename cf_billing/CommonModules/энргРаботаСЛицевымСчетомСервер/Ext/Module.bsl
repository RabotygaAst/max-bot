	#КонецОбласти
	
	#Область КоличествоЭтажей
	Если ПолучаемыеСвойства.свойство("КоличествоЭтажей") Или ПолучаемыеСвойства.свойство("ГодПостройки") тогда
		ТекстыЗапросов.Вставить("ЭтажностьГодПостройки",Новый Структура("ОбработчикЗаполнения,Текст","энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоЭтажностьГодПостройки",
		"ВЫБРАТЬ
		|	энргСтроения.КоличествоЭтажей КАК КоличествоЭтажей,
		|	энргСтроения.ГодПостройки КАК ГодПостройки
		|ИЗ
		|	Справочник.энргСтроения КАК энргСтроения
		|ГДЕ
		|	энргСтроения.Ссылка = &Строение"));				
	КонецЕсли;
	#КонецОбласти
	
	#Область ДанныеОЛьготниках
	Если ПолучаемыеСвойства.свойство("ДанныеОЛьготниках") тогда
		ТекстыЗапросов.Вставить("ДанныеОЛьготниках",Новый Структура("ОбработчикЗаполнения,Текст","энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоЖильцыЛьготныхКатегорий",
		"ВЫБРАТЬ
		|	энргЖильцыЛьготныхКатегорий.Период КАК ДатаСостояния,
		|	энргЖильцыЛьготныхКатегорий.Состояние КАК Состояние
		|ИЗ
		|	РегистрСведений.энргЖильцыЛьготныхКатегорий.СрезПоследних(
		|			,
		|			Организация = &Организация
		|				И Район = &Район
		|				И Абонент = &Абонент) КАК энргЖильцыЛьготныхКатегорий"));		
	КонецЕсли; 
	#КонецОбласти 	
	
	энргРаботаСЛицевымСчетомПереопределяемый.ПараметрыРасчетаАбонента(Организация,Район,Абонент,Период,ПолучаемыеСвойства,ДанныеАбонента,ТекстыЗапросов);
	
	
	ИтоговыйТекст 		= ""; 
	ТекстРазделитель 	= "
	|;
	|////////////////////////////////////////
	|";

	Для Каждого КлючЗначение Из ТекстыЗапросов Цикл
		ИтоговыйТекст 	= ИтоговыйТекст + ?(НЕ ПустаяСтрока(ИтоговыйТекст),ТекстРазделитель,"") + КлючЗначение.Значение.Текст;		
	КонецЦикла;

	Если ЗначениеЗаполнено(ИтоговыйТекст) Тогда
		Запрос  			= Новый Запрос(ИтоговыйТекст);
		Запрос.УстановитьПараметр("Период",			Период);
		Запрос.УстановитьПараметр("Район",			Район);
		Запрос.УстановитьПараметр("КлючПомещения",	ДанныеАбонента.КлючПомещения);
		Запрос.УстановитьПараметр("Строение",		ДанныеАбонента.Строение);
		Запрос.УстановитьПараметр("Организация",	Организация); 
		Запрос.УстановитьПараметр("Абонент",		Абонент); 
		Результат  			= Запрос.ВыполнитьПакет(); 	
		
		Индекс 				= 0;
		Для Каждого КлючЗначение Из ТекстыЗапросов Цикл
			ОбработчикЗаполнения 	= КлючЗначение.Значение.ОбработчикЗаполнения;
			Параметры  				= Новый Массив;
			Параметры.Добавить(ПолучаемыеСвойства);
			Параметры.Добавить(Результат[Индекс]);
			ОбщегоНазначения.ВыполнитьМетодКонфигурации(ОбработчикЗаполнения,Параметры);		
			Индекс 					= Индекс + 1;		
		КонецЦикла;
	КонецЕсли;
	
	#Область КоличествоЧеловек
	
	Если ПолучаемыеСвойства.Свойство("КоличествоЧеловек") Тогда
		 ПолучаемыеСвойства.КоличествоЧеловек 		= энргРаботаСПараметрамиРасчетаАбонентаСервер.КоличествоЧеловек(ПолучаемыеСвойства);
	КонецЕсли; 	
	
	#КонецОбласти
	
КонецПроцедуры

Процедура ПараметрыРасчетаМКД(Организация,Район,Строение,Период,ПолучаемыеСвойства) Экспорт 
		
	ТекДата				= ТекущаяДата();
		
	#Область ВидБлагоустройства
	Если ПолучаемыеСвойства.свойство("ВидБлагоустройства") тогда
		Запрос  		= Новый Запрос;
		Запрос.УстановитьПараметр("Период",		Период);
		Запрос.УстановитьПараметр("Район",		Район);
		Запрос.УстановитьПараметр("МКД",		Строение);
		Запрос.УстановитьПараметр("Организация",Организация);		
		Запрос.Текст 	=
		"ВЫБРАТЬ
		|	энргВидБлагоустройствМКД.ВидБлагоустройства КАК ВидБлагоустройства
		|ИЗ
		|	РегистрСведений.энргВидБлагоустройствМКД.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И МКД = &МКД) КАК энргВидБлагоустройствМКД";
		Результат  		= Запрос.Выполнить();
		Выборка 		= Результат.Выбрать();
		Если Выборка.Следующий() тогда
			ПолучаемыеСвойства.ВидБлагоустройства = Выборка.ВидБлагоустройства;
		КонецЕсли; 		
	КонецЕсли;  
	#КонецОбласти
	
	#Область ТипСхемыГВС
	Если ПолучаемыеСвойства.свойство("ТипСхемыГВС") тогда
		Запрос  		= Новый Запрос;
		Запрос.УстановитьПараметр("Период",		Период);
		Запрос.УстановитьПараметр("Район",		Район);
		Запрос.УстановитьПараметр("МКД",		Строение);
		Запрос.УстановитьПараметр("Организация",Организация);		
		Запрос.Текст 	=
		"ВЫБРАТЬ
		|	энргТипСхемыГВССрезПоследних.ТипСхемы КАК ТипСхемы
		|ИЗ
		|	РегистрСведений.энргТипСхемыГВС.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И МКД = &МКД
		|				И Район = &Район) КАК энргТипСхемыГВССрезПоследних";
		Результат  		= Запрос.Выполнить();
		Выборка 		= Результат.Выбрать();
		Если Выборка.Следующий() тогда
			ПолучаемыеСвойства.ТипСхемыГВС = Выборка.ТипСхемы;
		КонецЕсли; 		
	КонецЕсли;  
	#КонецОбласти
	
	#Область ВидТепловогоПункта
	Если ПолучаемыеСвойства.свойство("ВидТепловогоПункта") тогда
		Запрос  		= Новый Запрос;
		Запрос.УстановитьПараметр("Период",		Период);
		Запрос.УстановитьПараметр("Район",		Район);
		Запрос.УстановитьПараметр("МКД",		Строение);
		Запрос.УстановитьПараметр("Организация",Организация);		
		Запрос.Текст 	=
		"ВЫБРАТЬ
		|	энргТипПринадлежностиМКДСрезПоследних.ВидТепловогоПункта КАК ВидТепловогоПункта
		|ИЗ
		|	РегистрСведений.энргТипПринадлежностиМКД.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И МКД = &МКД
		|				И Район = &Район) КАК энргТипПринадлежностиМКДСрезПоследних";
		Результат  		= Запрос.Выполнить();
		Выборка 		= Результат.Выбрать();
		Если Выборка.Следующий() тогда
			ПолучаемыеСвойства.ВидТепловогоПункта = Выборка.ВидТепловогоПункта;
		КонецЕсли; 		
	КонецЕсли;  
	#КонецОбласти

	#Область КоличествоЭтажей
	Если ПолучаемыеСвойства.свойство("КоличествоЭтажей") Или ПолучаемыеСвойства.свойство("ГодПостройки") тогда
		Запрос  		= Новый Запрос;
		Запрос.УстановитьПараметр("Строение",Строение);
		Запрос.Текст 	=
		"ВЫБРАТЬ
		|	энргСтроения.КоличествоЭтажей КАК КоличествоЭтажей,
		|	энргСтроения.ГодПостройки КАК ГодПостройки
		|ИЗ
		|	Справочник.энргСтроения КАК энргСтроения
		|ГДЕ
		|	энргСтроения.Ссылка = &Строение";
		Результат  		= Запрос.Выполнить();
		Выборка  		= Результат.Выбрать();
		Если Выборка.Следующий() тогда
			//Если ПолучаемыеСвойства.свойство("Этажность") Тогда
			//	ПолучаемыеСвойства.Этажность = Выборка.Этажность;
			//КонецЕсли;
			//Если ПолучаемыеСвойства.свойство("ГодПостройки") Тогда 
			//	ПолучаемыеСвойства.ГодПостройки = Выборка.ГодПостройки;
			//КонецЕсли;	
			ЗаполнитьЗначенияСвойств(ПолучаемыеСвойства, Выборка);
		Иначе 
			Если ПолучаемыеСвойства.свойство("КоличествоЭтажей") Тогда
				ПолучаемыеСвойства.КоличествоЭтажей = 0;
			КонецЕсли;
			Если ПолучаемыеСвойства.свойство("ГодПостройки") Тогда 
				ПолучаемыеСвойства.ГодПостройки = 0;
			КонецЕсли;
		КонецЕсли; 		
	КонецЕсли;
	#КонецОбласти
	
КонецПроцедуры

Процедура ЗаполнитьРеквизитыМКД(ДанныеМКД,ЭлементМКД)
	
	Если ДанныеМКД.Свойство("Организация") Тогда 
		ЭлементМКД.Организация						= ДанныеМКД.Организация;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("Район") Тогда 
		ЭлементМКД.Район							= ДанныеМКД.Район;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ВидБлагоустройства") Тогда 
		ЭлементМКД.ВидБлагоустройства				= ДанныеМКД.ВидБлагоустройства;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("КоличествоЭтажей") Тогда 
		ЭлементМКД.КоличествоЭтажей					= ДанныеМКД.КоличествоЭтажей;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ГодПостройки") Тогда 
		ЭлементМКД.ГодПостройки						= ДанныеМКД.ГодПостройки;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ТипПлиты") Тогда 
		ЭлементМКД.ТипПлиты							= ДанныеМКД.ТипПлиты;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ВидОбъектаАбонентов") Тогда 
		ЭлементМКД.ВидОбъектаАбонентов				= ДанныеМКД.ВидОбъектаАбонентов;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ГруппаПотребителейПоУмолчанию") Тогда 
		ЭлементМКД.ГруппаПотребителейПоУмолчанию	= ДанныеМКД.ГруппаПотребителейПоУмолчанию;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("Бойлер") Тогда 
		ЭлементМКД.Бойлер							= ДанныеМКД.Бойлер;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("МаршрутКонтроллера") Тогда 
		ЭлементМКД.МаршрутКонтроллера				= ДанныеМКД.МаршрутКонтроллера;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ВидыБлагоустройстваТарифныеКатегории") Тогда 
		ЭлементМКД.ВидыБлагоустройстваТарифныеКатегории.Очистить();
		Для Каждого Строка Из ДанныеМКД.ВидыБлагоустройстваТарифныеКатегории Цикл
			НовСтр = ЭлементМКД.ВидыБлагоустройстваТарифныеКатегории.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтр,Строка);
		КонецЦикла; 
	КонецЕсли;
	
	ЭлементМКД.ТипСтроения 							= Перечисления.энргТипыСтроений.МКД;
	
	СтрокиКИ										= ЭлементМКД.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип,Вид",Перечисления.ТипыКонтактнойИнформации.Адрес,Справочники.ВидыКонтактнойИнформации.АдресДома));
	Для Каждого СтрокаКИ Из СтрокиКИ Цикл
		ЭлементМКД.КонтактнаяИнформация.Удалить(СтрокаКИ); 
	КонецЦикла;
	
	СтрокиКИ 										= ЭлементМКД.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип,Вид",Перечисления.ТипыКонтактнойИнформации.Адрес,Справочники.ВидыКонтактнойИнформации.СтроительныйАдресДома));
	Для Каждого СтрокаКИ Из СтрокиКИ Цикл
		ЭлементМКД.КонтактнаяИнформация.Удалить(СтрокаКИ); 
	КонецЦикла;
	
	Если ДанныеМКД.Свойство("АдресОбъектаЗначение") Тогда
		УправлениеКонтактнойИнформацией.ЗаписатьКонтактнуюИнформацию(ЭлементМКД, ДанныеМКД.АдресОбъектаЗначение,Справочники.ВидыКонтактнойИнформации.АдресДома,Перечисления.ТипыКонтактнойИнформации.Адрес);
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("АдресОбъектаСтроительныйЗначение") Тогда
		УправлениеКонтактнойИнформацией.ЗаписатьКонтактнуюИнформацию(ЭлементМКД, ДанныеМКД.АдресОбъектаСтроительныйЗначение,Справочники.ВидыКонтактнойИнформации.СтроительныйАдресДома,Перечисления.ТипыКонтактнойИнформации.Адрес);
	КонецЕсли;

	Попытка	
		ЭлементМКД.Записать();
	Исключение
		ВызватьИсключение "Не удалось создать мкд";
	КонецПопытки;
	
	Если ДанныеМКД.Свойство("ОКТМО") Тогда
		НоваяЗапись 								= РегистрыСведений.энргИдентификаторыМКДГИСЖКХ.СоздатьМенеджерЗаписи();
		НоваяЗапись.МКД								= ЭлементМКД.Ссылка;	
		НоваяЗапись.ОКТМО							= ДанныеМКД.ОКТМО;
		Если СтрНачинаетсяС(СокрЛ(ДанныеМКД.АдресОбъектаЗначение), "{") Тогда 
			ЧтениеJSON 								= Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ДанныеМКД.АдресОбъектаЗначение);
			КонтактнаяИнформация 					= ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();
			
			Если КонтактнаяИнформация.Свойство("houseId") И ЗначениеЗаполнено(КонтактнаяИнформация.houseId) Тогда 
				НоваяЗапись.ИдентификаторДомаФИАС	= КонтактнаяИнформация.houseId;
			КонецЕсли;
		КонецЕсли;	
		НоваяЗапись.Записать();
	КонецЕсли;

КонецПроцедуры

Функция ЗаполнитьРеквизитыАбонента(ТекущийОбъект,ДанныеАбонента,АбонентОбъект,ФормироватьЛС, ЭтоСменаСобственника = Ложь)
	                                   	
	//АбонентОбъект.VIPабонент                    = ТекущийОбъект.VIPабонент;
	АбонентОбъект.Родитель 						= ТекущийОбъект.ГруппаАбонента;
	АбонентОбъект.Район 						= ТекущийОбъект.Район;
	АбонентОбъект.Организация 					= ТекущийОбъект.Организация;
	
	Если ДанныеАбонента.Свойство("КлючПомещения") Тогда
		АбонентОбъект.КлючПомещения = ДанныеАбонента.КлючПомещения;
	Иначе
		АбонентОбъект.КлючПомещения = ТекущийОбъект.КлючПомещения;
	КонецЕсли;
	
	Если ДанныеАбонента.Свойство("МуниципальноеОбразование") Тогда
		АбонентОбъект.МуниципальноеОбразование = ДанныеАбонента.МуниципальноеОбразование;
	КонецЕсли;
	
	Если ДанныеАбонента.Свойство("Поставщик") Тогда
		АбонентОбъект.Поставщик = ДанныеАбонента.Поставщик;
	КонецЕсли;
	
	АбонентОбъект.ФизЛицо 						= ДанныеАбонента.ФизЛицо; 	
	АбонентОбъект.ВидОбъекта 					= ?(ЭтоСменаСобственника, ТекущийОбъект.Абонент.ВидОбъекта, ДанныеАбонента.ВидОбъекта);
	АбонентОбъект.Наименование 					= СокрЛП(ДанныеАбонента.ФизЛицо);
	Если ЗначениеЗаполнено(ТекущийОбъект.СтарыйЛС) Тогда
		АбонентОбъект.СтарыйЛС 						= ТекущийОбъект.СтарыйЛС;
	КонецЕсли;
	
	Если ФормироватьЛС тогда
		АбонентОбъект.ЛицевойСчет 				= Обработки.энргНомераЛицевыхСчетовМенеджер.СФормироватьЛицевойСчет(ТекущийОбъект.Организация,ТекущийОбъект.Район,ТекущийОбъект.ГруппаАбонента, ?(ДанныеАбонента.Свойство("Филиал"), ДанныеАбонента.Филиал,Неопределено));
	ИначеЕсли ДанныеАбонента.Свойство("ЛицевойСчет") Тогда 
		АбонентОбъект.ЛицевойСчет 				= ДанныеАбонента.ЛицевойСчет;
	КонецЕсли;
	
	Если ДанныеАбонента.Свойство("СлужебныеОтметки") Тогда 
		АбонентОбъект.СлужебныеОтметки 			= ДанныеАбонента.СлужебныеОтметки;
	КонецЕсли;
	
	СтрокаКИ = Неопределено;
	//Помещение =  ДанныеАбонента.КлючПомещения.Помещение;
	Помещение =  АбонентОбъект.КлючПомещения.Помещение;
	Если ЗначениеЗаполнено(Помещение) И Не Помещение.Фиктивное Тогда
		СтрокаКИ = Помещение.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.АдресПомещения, "Вид");	
	Иначе
		Строение =  ДанныеАбонента.КлючПомещения.Строение;
		Если ЗначениеЗаполнено(Строение) Тогда
			СтрокаКИ = Строение.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.АдресДома, "Вид");
		КонецЕсли;
	КонецЕсли;
	
	Если СтрокаКИ <> Неопределено Тогда
		ТипКИ		= Перечисления.ТипыКонтактнойИнформации.Адрес;
		ВидКИ 		= Справочники.ВидыКонтактнойИнформации.АдресОбъекта;
		АбонентОбъект.КонтактнаяИнформация.Очистить();
		
		Если НЕ ПустаяСтрока(СтрокаКИ.Значение) Тогда
			АдресДома 	= СтрокаКИ.Значение;
			УправлениеКонтактнойИнформацией.ЗаписатьКонтактнуюИнформацию(АбонентОбъект, АдресДома, ВидКИ, ТипКИ);
		Иначе 
			АдресДома 	= СтрокаКИ.Представление;
			УправлениеКонтактнойИнформацией.ЗаписатьКонтактнуюИнформацию(АбонентОбъект, УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(АдресДома, ВидКИ), ВидКИ, ТипКИ);
		КонецЕсли;		
	КонецЕсли;
	
	АбонентОбъект.Записать();
	
	Если ДанныеАбонента.Свойство("Филиал") Тогда
		МЗ = РегистрыСведений.энргФилиалыАбонентов.СоздатьМенеджерЗаписи();
		МЗ.Абонент	= АбонентОбъект.Ссылка;
		МЗ.Период	= ТекущийОбъект.Дата;
		МЗ.Филиал	= ДанныеАбонента.Филиал;
		МЗ.Записать(Истина);
		// ЗаполнитьЗначенияСвойств(АбонентОбъект,ДанныеАбонента,"Филиал");
	КонецЕсли;
		
	Возврат Новый Структура("Абонент,ЛицевойСчет",АбонентОбъект.Ссылка,АбонентОбъект.ЛицевойСчет); 
КонецФункции

Функция МаршрутКонтроллераПоАдресу(АдресОбъекта) Экспорт 

	МаршрутКонтроллера = Новый Структура("Маршрут,Контроллер",Справочники.энргМаршрутыКонтроллеров.ПустаяСсылка(),Справочники.энргСотрудники.ПустаяСсылка());
		
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("АдресОбъекта",	АдресОбъекта);
	Запрос.Текст 	="ВЫБРАТЬ ПЕРВЫЕ 1
	|	энргМаршрутыКонтроллеровАдресаМаршрута.Ссылка КАК Маршрут
	|ПОМЕСТИТЬ Маршруты
	|ИЗ
	|	Справочник.энргМаршрутыКонтроллеров.АдресаМаршрута КАК энргМаршрутыКонтроллеровАдресаМаршрута
	|ГДЕ
	|	&АдресОбъекта ПОДОБНО ""%"" + энргМаршрутыКонтроллеровАдресаМаршрута.Представление + ""%""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	энргМаршрутыКонтроллеров.Владелец КАК Контроллер,
	|	Маршруты.Маршрут КАК Маршрут 
	|ИЗ
	|	Маршруты КАК Маршруты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргМаршрутыКонтроллеров КАК энргМаршрутыКонтроллеров
	|		ПО Маршруты.Маршрут = энргМаршрутыКонтроллеров.Ссылка";
	
	Результат  		= Запрос.Выполнить();
	Выборка 		= Результат.Выбрать();
	
	Если Выборка.Следующий() тогда
		ЗаполнитьЗначенияСвойств(МаршрутКонтроллера,Выборка);
	КонецЕсли;
	
	Возврат МаршрутКонтроллера;
	
КонецФункции

Функция ПоляАдресаМКД(ДанныеАдреса) Экспорт 
	
	Корпус  				= "";
	ТипКорпуса 				= "";
	Если ЗначениеЗаполнено(ДанныеАдреса.Корпуса) и ТипЗнч(ДанныеАдреса.Корпуса) = Тип("Массив") тогда
		Корпус 				= ДанныеАдреса.Корпуса[0].Номер;
		ТипКорпуса 			= ДанныеАдреса.Корпуса[0].ТипКорпуса;
	КонецЕсли;
	
	ПоляАдреса  	= Новый Структура();
	ПоляАдреса.Вставить("Индекс",				ДанныеАдреса.Индекс);
	ПоляАдреса.Вставить("Регион",				ДанныеАдреса.Регион);
	ПоляАдреса.Вставить("Город",				ДанныеАдреса.Город);
	ПоляАдреса.Вставить("НаселенныйПункт",		ДанныеАдреса.НаселенныйПункт);
	ПоляАдреса.Вставить("Дом",					ДанныеАдреса.Здание.Номер);
	ПоляАдреса.Вставить("Корпус",				Корпус);
	ПоляАдреса.Вставить("Улица",				ДанныеАдреса.Улица);
	
	Возврат ПоляАдреса;
КонецФункции

Процедура ДобавитьАдресКМашруту(АдресОбъекта,АдресОбъектаПредставлениеПолей,Контроллер=Неопределено,Маршрут) Экспорт  
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("АдресОбъекта",	АдресОбъекта);
	Запрос.УстановитьПараметр("Маршрут",		Маршрут);
	Запрос.УстановитьПараметр("Контроллер",		?(Контроллер=Неопределено,Маршрут.Владелец, Контроллер));
	Запрос.Текст 	="ВЫБРАТЬ РАЗРЕШЕННЫЕ
	             	 |	энргМаршрутыКонтроллеровАдресаМаршрута.Ссылка КАК Маршрут
	             	 |ПОМЕСТИТЬ Маршруты
	             	 |ИЗ
	             	 |	Справочник.энргМаршрутыКонтроллеров.АдресаМаршрута КАК энргМаршрутыКонтроллеровАдресаМаршрута
	             	 |ГДЕ
	             	 |	энргМаршрутыКонтроллеровАдресаМаршрута.Представление ПОДОБНО &АдресОбъекта
	             	 |	И энргМаршрутыКонтроллеровАдресаМаршрута.Ссылка = &Маршрут
	             	 |;
	             	 |
	             	 |////////////////////////////////////////////////////////////////////////////////
	             	 |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	             	 |	энргМаршрутыКонтроллеров.Владелец КАК Контроллер
	             	 |ИЗ
	             	 |	Маршруты КАК Маршруты
	             	 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргМаршрутыКонтроллеров КАК энргМаршрутыКонтроллеров
	             	 |		ПО Маршруты.Маршрут = энргМаршрутыКонтроллеров.Ссылка
	             	 |			И (энргМаршрутыКонтроллеров.Владелец = &Контроллер)";
	
	Результат  				= Запрос.Выполнить();
	
	Если не Результат.Пустой() тогда
		Возврат;
	КонецЕсли;
	
	// Добавляем строку таб части
	МаршрутОбъект 			= Маршрут.получитьОбъект();
	СтрокаТЧ  				= МаршрутОбъект.АдресаМаршрута.добавить();
	СтрокаТЧ.ЗначенияПолей 	= АдресОбъектаПредставлениеПолей;
	СтрокаТЧ.Представление 	= АдресОбъекта;
	
	МаршрутОбъект.записать();
	
КонецПроцедуры

Процедура ПолучитьДанныеУК_МКД(ТекМКД, ТекДата, СтруктураДанных) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", 	ТекДата);
	Запрос.УстановитьПараметр("МКД", 	ТекМКД);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	энргФормыУправленияМКДСрезПоследних.Район КАК Район,
	|	энргФормыУправленияМКДСрезПоследних.МКД КАК МКД,
	|	энргФормыУправленияМКДСрезПоследних.ФормаУправления КАК ФормаУправления,
	|	энргФормыУправленияМКДСрезПоследних.УК КАК УК,
	|	энргФормыУправленияМКДСрезПоследних.Период КАК Период,
	|	энргФормыУправленияМКДСрезПоследних.РасчетОбъемовВыполняетУК КАК РасчетОбъемовВыполняетУК
	|ИЗ
	|	РегистрСведений.энргФормыУправленияМКД.СрезПоследних(&Дата, МКД = &МКД) КАК энргФормыУправленияМКДСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	энргФормыУправленияМКДСрезПоследних.Район,
	|	энргФормыУправленияМКДСрезПоследних.УК,
	|	энргФормыУправленияМКДСрезПоследних.Период,
	|	энргФормыУправленияМКДСрезПоследних.ФормаУправления,
	|	энргФормыУправленияМКДСрезПоследних.МКД,
	|	энргФормыУправленияМКДСрезПоследних.РасчетОбъемовВыполняетУК";
	Результат 	= Запрос.Выполнить();
	Выборка		= Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураДанных, Выборка);
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьАдресМКД(Строение) Экспорт 
	
	АдресМКД = Новый Структура;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	энргСтроенияКонтактнаяИнформация.Представление КАК Представление,
		|	энргСтроенияКонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей
		|ИЗ
		|	Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
		|ГДЕ
		|	энргСтроенияКонтактнаяИнформация.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Строение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		АдресМКД.Вставить("Представление",	ВыборкаДетальныеЗаписи.Представление);  
		АдресМКД.Вставить("ЗначенияПолей",	ВыборкаДетальныеЗаписи.ЗначенияПолей);
	Иначе
		АдресМКД.Вставить("Представление",	"");  
		АдресМКД.Вставить("ЗначенияПолей",	"");
	КонецЕсли;
	
	Возврат АдресМКД;
	
КонецФункции

Функция ДанныеАбонентаИзСтрокиJSON(ОписаниеАбонента)
	
	Чтение  								= Новый ЧтениеJSON;	
	Чтение.УстановитьСтроку(ОписаниеАбонента);
	ДанныеАбонента 							= ПрочитатьJSON(Чтение);
	
	Результат 								= Новый Структура;
	
	Если ДанныеАбонента.Свойство("ФизЛицо") Тогда
		Результат.Вставить("ФизЛицо",Справочники.энргКонтрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеАбонента.ФизЛицо)));
	КонецЕсли;
	Если ДанныеАбонента.Свойство("ВидОбъекта") Тогда
		Результат.Вставить("ВидОбъекта", Справочники.энргВидыОбъектовАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеАбонента.ВидОбъекта)));
	КонецЕсли;
	Если ДанныеАбонента.Свойство("Филиал") Тогда
		Результат.Вставить("Филиал", Справочники.энргФилиалы.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеАбонента.Филиал)));
	КонецЕсли;
	
	Если ДанныеАбонента.Свойство("АдресОбъекта") Тогда
		Результат.Вставить("АдресОбъекта", ДанныеАбонента.АдресОбъекта);
		Результат.Вставить("АдресОбъектаЗначение", ДанныеАбонента.АдресОбъектаЗначение);
	КонецЕсли;
	
	Если ДанныеАбонента.Свойство("ОКТМО") Тогда
		Результат.Вставить("ОКТМО", ДанныеАбонента.ОКТМО);
	КонецЕсли;
	
	Если ДанныеАбонента.Свойство("КлючПомещения") Тогда
		Результат.Вставить("КлючПомещения", ДанныеАбонента.КлючПомещения);
	КонецЕсли;
	
	Если ДанныеАбонента.Свойство("МуниципальноеОбразование") Тогда
		Результат.Вставить("МуниципальноеОбразование", Справочники.энргМуниципальноеОбразование.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеАбонента.МуниципальноеОбразование))); 
	КонецЕсли;


	Возврат Результат;
	
КонецФункции

Функция ДанныеМКДИзСтрокиJSON(ОписаниеАбонента)
			
	Чтение  			= Новый ЧтениеJSON;	
	Чтение.УстановитьСтроку(ОписаниеАбонента);
	ДанныеМКД 			= ПрочитатьJSON(Чтение);
	
	Результат 			= Новый Структура;
	
	Если ДанныеМКД.Свойство("Организация") Тогда
		Результат.Вставить("Организация",						Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.Организация)));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("Район") Тогда
		Результат.Вставить("Район", 							Справочники.энргЗоныОтвественности.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.Район)));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("Бойлер") Тогда
		Результат.Вставить("Бойлер", 							Булево(ДанныеМКД.Бойлер));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ГодПостройки") Тогда
		Результат.Вставить("ГодПостройки", 						Число(ДанныеМКД.ГодПостройки));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ВидОбъектаАбонентов") Тогда
		Результат.Вставить("ВидОбъектаАбонентов", 				Справочники.энргВидыОбъектовАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.ВидОбъектаАбонентов)));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ГруппаПотребителейПоУмолчанию") Тогда
		Результат.Вставить("ГруппаПотребителейПоУмолчанию", 	Справочники.энргГруппыПотребителей.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.ГруппаПотребителейПоУмолчанию)));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("КоличествоЭтажей") Тогда
		Результат.Вставить("КоличествоЭтажей", 					Число(ДанныеМКД.КоличествоЭтажей));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ОКТМО") Тогда
		Результат.Вставить("ОКТМО", 							ДанныеМКД.ОКТМО);
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ТипПлиты") Тогда
		Результат.Вставить("ТипПлиты", 							Перечисления.энргТипыПлит[ДанныеМКД.ТипПлиты]);
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("АдресОбъекта") Тогда
		Результат.Вставить("АдресОбъекта", 						ДанныеМКД.АдресОбъекта);
		Результат.Вставить("АдресОбъектаЗначение", 				ДанныеМКД.АдресОбъектаЗначение);
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("АдресОбъектаСтроительный") Тогда
		Результат.Вставить("АдресОбъектаСтроительный", 			ДанныеМКД.АдресОбъектаСтроительный);
		Результат.Вставить("АдресОбъектаСтроительныйЗначение", 	ДанныеМКД.АдресОбъектаСтроительныйЗначение);
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("Филиал") Тогда
		Результат.Вставить("Филиал", 	Справочники.энргФилиалы.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.Филиал)));
	Иначе
		Результат.Вставить("Филиал", 	Справочники.энргФилиалы.ПустаяСсылка());
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("Дата") Тогда
		Результат.Вставить("Дата", ДанныеМКД.Дата);
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("МаршрутКонтроллера") Тогда
		Результат.Вставить("МаршрутКонтроллера"				,Справочники.энргМаршрутыКонтроллеров.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.МаршрутКонтроллера)));
	КонецЕсли;
	
	
	Если ДанныеМКД.Свойство("ВидыБлагоустройстваТарифныеКатегории") Тогда
		
		МассивВидов = Новый Массив;
		Для Каждого Строка Из ДанныеМКД.ВидыБлагоустройстваТарифныеКатегории Цикл
			Структура = Новый Структура;
			Если Строка.Свойство("Услуга") Тогда
				Структура.Вставить("Услуга", Справочники.энргВидыУслуг.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.Услуга)));
			КонецЕсли;
			Если Строка.Свойство("ВидБлагоустройстваИндивидуальный") Тогда
				Структура.Вставить("ВидБлагоустройстваИндивидуальный", Справочники.энргВидыБлагоустройств.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.ВидБлагоустройстваИндивидуальный)));
			КонецЕсли;
			Если Строка.Свойство("ВидБлагоустройстваОбщедомовой") Тогда
				Структура.Вставить("ВидБлагоустройстваОбщедомовой", Справочники.энргВидыБлагоустройств.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.ВидБлагоустройстваОбщедомовой)));
			КонецЕсли;
			Если Строка.Свойство("ТарифнаяКатегория") Тогда
				Структура.Вставить("ТарифнаяКатегория", Справочники.энргГруппыПотребителей.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.ТарифнаяКатегория)));
			КонецЕсли;
			МассивВидов.Добавить(Структура);
		КонецЦикла; 
		
		Результат.Вставить("ВидыБлагоустройстваТарифныеКатегории", МассивВидов);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ОбновитьВидыБлагоустройстваТарифныеКатегории(ТекущийОбъект,IDСтроки = Неопределено) Экспорт
	
	МассивУслуг			= Новый Массив;
	МассивУслугДобавить = Новый Массив;
	МассивУслугУдалить	= Новый Массив;
	МассивТекУслуг		= Новый Массив;
	Если IDСтроки = Неопределено Тогда
		МассивТекУслуг = ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.Выгрузить().ВыгрузитьКолонку("Услуга");
		КоллекцияТУ = ТекущийОбъект.Объект.ТочкиУчета;
	Иначе 
		СтрокиВБ = ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.НайтиСтроки(Новый Структура("IDСтрокиАбонента",IDСтроки));
		Для Каждого СтрокаВБ Из СтрокиВБ Цикл
			Если МассивТекУслуг.Найти(СтрокаВБ.Услуга) = Неопределено Тогда
				МассивТекУслуг.Добавить(СтрокаВБ.Услуга);	
			КонецЕсли; 	
		КонецЦикла; 
		КоллекцияТУ = ТекущийОбъект.Объект.ТочкиУчета.НайтиСтроки(Новый Структура("IDСтрокиАбонента",IDСтроки));
	КонецЕсли; 
	
	Для Каждого ТекУслуга Из КоллекцияТУ Цикл
		
		Если Не ЗначениеЗаполнено(ТекУслуга.Услуга) Тогда
			Продолжить;
		КонецЕсли; 
		
		Если ТекУслуга.Услуга.СоставнаяУслуга Тогда
			Для Каждого СостУслуга Из ТекУслуга.Услуга.СоставляющиеУслуг Цикл
				Если МассивТекУслуг.Найти(СостУслуга.Услуга) = Неопределено И МассивУслуг.Найти(СостУслуга.Услуга) = Неопределено Тогда
					МассивУслугДобавить.Добавить(СостУслуга.Услуга);
					МассивУслуг.Добавить(СостУслуга.Услуга);
				ИначеЕсли МассивУслуг.Найти(СостУслуга.Услуга) = Неопределено Тогда
					МассивУслуг.Добавить(СостУслуга.Услуга);
				КонецЕсли	
			КонецЦикла;			
		Иначе
			Если МассивТекУслуг.Найти(ТекУслуга.Услуга) = Неопределено И МассивУслуг.Найти(ТекУслуга.Услуга) = Неопределено Тогда
				МассивУслугДобавить.Добавить(ТекУслуга.Услуга);	
				МассивУслуг.Добавить(ТекУслуга.Услуга);
			ИначеЕсли МассивУслуг.Найти(ТекУслуга.Услуга) = Неопределено Тогда
				МассивУслуг.Добавить(ТекУслуга.Услуга);
			КонецЕсли;			
		КонецЕсли;
			
	КонецЦикла; 
	
	Для Каждого ТекУслуга Из МассивТекУслуг Цикл
		Если МассивУслуг.Найти(ТекУслуга) = Неопределено Тогда
			МассивУслугУдалить.Добавить(ТекУслуга);	
		КонецЕсли; 	
	КонецЦикла; 
	
	Для Каждого ТекУслуга Из МассивУслугУдалить Цикл
		Если IDСтроки = Неопределено Тогда
			СтрокиБлагоустройства = ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.НайтиСтроки(Новый Структура("Услуга",ТекУслуга));
		Иначе
			СтрокиБлагоустройства = ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.НайтиСтроки(Новый Структура("Услуга,IDСтрокиАбонента",ТекУслуга,IDСтроки));
		КонецЕсли; 
		
		Для Каждого ТекСтрока Из СтрокиБлагоустройства Цикл
			ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.Удалить(ТекСтрока);	
		КонецЦикла; 
	КонецЦикла; 
	
	Для Каждого ТекУслуга Из МассивУслугДобавить Цикл
		НоваяСтрока = ТекущийОбъект.Объект.ВидыБлагоустройстваТарифныеКатегории.Добавить();
		НоваяСтрока.Услуга				= ТекУслуга;
		Если IDСтроки <> Неопределено Тогда
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(НоваяСтрока, "IDСтроки") Тогда 
				НоваяСтрока.IDСтроки			= Новый УникальныйИдентификатор();
			КонецЕсли;
			НоваяСтрока.IDСтрокиАбонента    = IDСтроки;	
		КонецЕсли;		
	КонецЦикла;
	
КонецПроцедуры

