
#Область СлужебныйПрограммныйИнтерфейс 

#Область ПроцессОтправки

Процедура Отправить(Зависимости, ВходныеНастройки = Неопределено, ВходныеОтправляемыеОбъекты = Неопределено) Экспорт 
	
	ПодготовленныеДанные = Инициализировать(Зависимости, ВходныеНастройки, ВходныеОтправляемыеОбъекты);
	Если ПодготовленныеДанные.ОтправляемыеОбъекты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Зависимости.МенеджерОтправкиПисем.Отправить(Зависимости, ПодготовленныеДанные.Настройки, ПодготовленныеДанные.ОтправляемыеОбъекты);
	
КонецПроцедуры

#КонецОбласти

#Область КонструкторПараметров

Функция НовыеЗависимости() Экспорт 
	
	СоздательПисем = НовыйСоздательПисем();
	РегистраторРезультатаОтправкиПисем = НовыйРегистраторРезультатаОтправкиПисем();
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяСобытия", ИмяСобытия());
	Результат.Вставить("УчетнаяЗапись", РаботаСПочтовымиСообщениями.СистемнаяУчетнаяЗапись());
	Результат.Вставить("РаботаСПочтовымиСообщениями", "РаботаСПочтовымиСообщениями");	
	Результат.Вставить("МенеджерОтправкиПисем", Обработки.энргМенеджерОтправкиПисем);
	Результат.Вставить("СоздательПисем", СоздательПисем);
	Результат.Вставить("РегистраторРезультатаОтправкиПисем", РегистраторРезультатаОтправкиПисем);

	Возврат Результат;
	
КонецФункции

Функция НовыеНастройки() Экспорт 
	
	Результат = Справочники.энргНастройкиОтправкиПисем.АктуальныеДанные(Справочники.энргНастройкиОтправкиПисем.ПоУмолчанию);	
	Возврат Результат;
	
КонецФункции

Функция НовыеОтправляемыеОбъекты() Экспорт 
	
	Результат = Новый Массив;	
	Возврат Результат;
	
КонецФункции

Функция МодульРаботыСПочтовымиСообщениями() Экспорт 
	Возврат "РаботаСПочтовымиСообщениями";
КонецФункции

#КонецОбласти 


Функция ИмяСобытия() Экспорт
	
	Возврат НСтр("ru = 'Отправка писем'"); 
	
КонецФункции

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияПараметров

Функция НовыйСоздательПисем()
	
	Отборы = НовыеОбязательныеОтборы();
	
	Результат = Новый Структура;
	Результат.Вставить("Исполнитель", Неопределено);
	Результат.Вставить("Отборы", Отборы);
	Результат.Вставить("Контекст", Неопределено);

	Возврат Результат;
	
КонецФункции

Функция НовыеОбязательныеОтборы()
	
	Результат = Новый Структура;
	Результат.Вставить("НачалоПериода", Неопределено);
	Результат.Вставить("Организация", Неопределено);
	Результат.Вставить("Район", Неопределено);
	
	Возврат Результат;
	
КонецФункции

Функция НовыйРегистраторРезультатаОтправкиПисем()
	
	Результат = Новый Структура;
	Результат.Вставить("Исполнитель", Неопределено);
	Результат.Вставить("Контекст", Неопределено);

	Возврат Результат;
	
КонецФункции
	
#КонецОбласти

#Область ПроцессОтправки

Функция Инициализировать(Зависимости, ВходныеНастройки, ВходныеОтправляемыеОбъекты)
	
	Результат = Новый Структура;
	Результат.Вставить("Настройки", ВходныеНастройки);
	Результат.Вставить("ОтправляемыеОбъекты", ВходныеОтправляемыеОбъекты);
	
	Если Результат.Настройки = Неопределено Тогда
		Результат.Настройки = НовыеНастройки();
	КонецЕсли;	
	
	Если ВходныеОтправляемыеОбъекты = Неопределено Тогда 
		
		СоздательПисем 	= Зависимости.СоздательПисем.Исполнитель;
		Отборы 			= Зависимости.СоздательПисем.Отборы;
		Контекст 		= Зависимости.СоздательПисем.Контекст;  		
		Результат.ОтправляемыеОбъекты = СоздательПисем.ОтправляемыеОбъекты(Отборы, Контекст);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции 
	
#КонецОбласти

#КонецОбласти
