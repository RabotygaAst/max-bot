Процедура ЗаполнитьВидБлагоустроства(ДанныеШапки,Движения) Экспорт
	
	Если ДанныеШапки.Свойство("ВидыБлагоустройстваТарифныеКатегории") Тогда
		Набор = Движения.энргВидБлагоустройствАбонента;
		Для Каждого СтрокаВида Из ДанныеШапки.ВидыБлагоустройстваТарифныеКатегории Цикл
			Запись  						= Набор.добавить();
			Запись.Период  					= ДанныеШапки.Дата;
			Запись.Район 					= ДанныеШапки.Район;
			Запись.Организация  			= ДанныеШапки.Организация;
			Запись.КлючПомещения			= ДанныеШапки.КлючПомещения;
			Запись.ВидБлагоустройства 		= СтрокаВида.ВидБлагоустройстваИндивидуальный;
			Запись.Услуга			 		= СтрокаВида.Услуга;
			Запись.ПериодРегистрации		= ДанныеШапки.ПериодРегистрации;
			Запись.ПериодНачисления			= ДанныеШапки.ПериодНачисления;
		КонецЦикла;
	ИначеЕсли ДанныеШапки.Свойство("ВидыБлагоустройств") Тогда
		Набор = Движения.энргВидБлагоустройствАбонента;
		Для Каждого СтрокаВида Из ДанныеШапки.ВидыБлагоустройств Цикл
						
			Запись  						= Набор.добавить();
			Запись.Период  					= ДанныеШапки.Дата;
			Запись.Район 					= ДанныеШапки.Район;
			Запись.Организация  			= ДанныеШапки.Организация;
			Запись.КлючПомещения			= ДанныеШапки.КлючПомещения;
			запись.ВидБлагоустройства		= СтрокаВида.ВидБлагоустройства;
			запись.Услуга					= СтрокаВида.Услуга;
			Запись.ПериодРегистрации		= ДанныеШапки.ПериодРегистрации;
			Запись.ПериодНачисления			= ДанныеШапки.ПериодНачисления;
		КонецЦикла;
	Иначе
		Набор  							= Движения.энргВидБлагоустройствАбонента;
		Запись  						= Набор.добавить();
		Запись.Период  					= ДанныеШапки.Дата;
		Запись.Район 					= ДанныеШапки.Район;
		Запись.Организация  			= ДанныеШапки.Организация;
		Запись.КлючПомещения			= ДанныеШапки.КлючПомещения;
		Запись.ВидБлагоустройства 		= ДанныеШапки.ВидБлагоустройства;
		Запись.ПериодРегистрации		= ДанныеШапки.ПериодРегистрации;
		Запись.ПериодНачисления			= ДанныеШапки.ПериодНачисления;
	КонецЕсли;
	

КонецПроцедуры

