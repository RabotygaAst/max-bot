Процедура УстановитьЛьготностьЖильцовИзОткрытияЛС(ДанныеШапки,Движения) Экспорт
	Набор 								= Движения.бестЖильцыЛьготныхКатегорий;
	Запрос 								= Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргОперацияСЛицевымСчетомЖильцы.ФизическоеЛицо КАК ФизическоеЛицо,
	|	энргОперацияСЛицевымСчетомЖильцы.бестЛьготнаяКатегория КАК бестЛьготнаяКатегория
	|ИЗ
	|	Документ.энргОперацияСЛицевымСчетом.Жильцы КАК энргОперацияСЛицевымСчетомЖильцы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестЖильцыЛьготныхКатегорий.СрезПоследних(&Период, ) КАК бестЖильцыЛьготныхКатегорийСрезПоследних
	|		ПО бестЖильцыЛьготныхКатегорийСрезПоследних.Район = энргОперацияСЛицевымСчетомЖильцы.Ссылка.Район
	|			И бестЖильцыЛьготныхКатегорийСрезПоследних.Организация = энргОперацияСЛицевымСчетомЖильцы.Ссылка.Организация
	|			И бестЖильцыЛьготныхКатегорийСрезПоследних.Жилец = энргОперацияСЛицевымСчетомЖильцы.ФизическоеЛицо
	|			И (бестЖильцыЛьготныхКатегорийСрезПоследних.ЛьготнаяКатегория = энргОперацияСЛицевымСчетомЖильцы.бестЛьготнаяКатегория
	|				ИЛИ НЕ бестЖильцыЛьготныхКатегорийСрезПоследних.Состояние)
	|ГДЕ
	|	энргОперацияСЛицевымСчетомЖильцы.Ссылка = &Ссылка
	|	И энргОперацияСЛицевымСчетомЖильцы.бестЛьготнаяКатегория <> ЗНАЧЕНИЕ(Справочник.бестЛьготныеКатегории.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(ДанныеШапки.Дата), ДанныеШапки.Дата, ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("Ссылка", ДанныеШапки.Документ);
	
	РезультатЗапроса 				= Запрос.Выполнить();
	
	Выборка				 			= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Запись						= Набор.Добавить();
		Запись.Период  				= ДанныеШапки.Дата;
		Запись.Организация  		= ДанныеШапки.Организация;
		Запись.Район				= ДанныеШапки.Район;
		Запись.Абонент 				= ДанныеШапки.Абонент;
		Запись.Жилец				= Выборка.ФизическоеЛицо;
		Запись.ЛьготнаяКатегория	= Выборка.бестЛьготнаяКатегория;
		Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
		Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;
		Запись.Состояние		    = Истина;	
	КонецЦикла;
	
КонецПроцедуры

