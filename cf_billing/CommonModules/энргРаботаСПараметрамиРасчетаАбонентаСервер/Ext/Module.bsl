Процедура УстановитьКоличествоПрописанных(ДанныеШапки,Движения)  Экспорт 
	Если ДанныеШапки.свойство("КоличествоПрописанных") тогда
		Набор  							= Движения.энргКоличествоПрописанных;
	//	Если ЗначениеЗаполнено(ДанныеШапки.КоличествоПрописанных) тогда
			Запись  					= Набор.добавить();
			Запись.Период  				= ДанныеШапки.Дата;
			Запись.Район  				= ДанныеШапки.Район;
			Запись.Организация  		= ДанныеШапки.Организация;
			Запись.КлючПомещения		= ДанныеШапки.КлючПомещения;
			Запись.Количество 			= ДанныеШапки.КоличествоПрописанных;
			Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
			Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;   
	//	КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура УстановитьИзменениеПрописанныхЖильцов(ДанныеШапки,Движения)  Экспорт 
	Набор  							= Движения.энргПроживаниеЖильцов;
	
	Запрос 							= Новый Запрос;
	Запрос.УстановитьПараметр("Организация", 	ДанныеШапки.Организация);
	Запрос.УстановитьПараметр("Район", 			ДанныеШапки.Район);
	Запрос.УстановитьПараметр("КлючПомещения", 	ДанныеШапки.КлючПомещения);
	Запрос.УстановитьПараметр("Ссылка",ДанныеШапки.Ссылка);
	Запрос.Текст 					= 
	"ВЫБРАТЬ
	|	энргУстановитьКоличествоПрописанныхЖильцы.ФизическоеЛицо КАК ФизическоеЛицо,
	|	энргУстановитьКоличествоПрописанныхЖильцы.ДоляСобственностиЧислитель КАК ДоляСобственностиЧислитель,
	|	энргУстановитьКоличествоПрописанныхЖильцы.ДоляСобственностиЗнаменатель КАК ДоляСобственностиЗнаменатель,
	|	энргУстановитьКоличествоПрописанныхЖильцы.Состояние КАК Состояние
	|ИЗ
	|	Документ.энргУстановитьКоличествоПрописанных.Жильцы КАК энргУстановитьКоличествоПрописанныхЖильцы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргПроживаниеЖильцов.СрезПоследних(
	|				,
	|				Организация = &Организация
	|					И Район = &Район
	|					И КлючПомещения = &КлючПомещения) КАК энргПроживаниеЖильцовСрезПоследних
	|		ПО энргУстановитьКоличествоПрописанныхЖильцы.ФизическоеЛицо = энргПроживаниеЖильцовСрезПоследних.Жилец
	|			И энргУстановитьКоличествоПрописанныхЖильцы.Состояние <> энргПроживаниеЖильцовСрезПоследних.Состояние
	|ГДЕ
	|	энргУстановитьКоличествоПрописанныхЖильцы.Ссылка = &Ссылка";	
	
	РезультатЗапроса 				= Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи 			= РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Запись  					= Набор.добавить();
		Запись.Период  				= ДанныеШапки.Дата;
		Запись.Район  				= ДанныеШапки.Район;
		Запись.Организация  		= ДанныеШапки.Организация;
		Запись.КлючПомещения		= ДанныеШапки.КлючПомещения;
		Запись.Жилец 				= ВыборкаДетальныеЗаписи.ФизическоеЛицо;
		Запись.Состояние 			= ВыборкаДетальныеЗаписи.Состояние;	
		Запись.ДоляСобственностиЧислитель 	= ВыборкаДетальныеЗаписи.ДоляСобственностиЧислитель;
		Запись.ДоляСобственностиЗнаменатель = ВыборкаДетальныеЗаписи.ДоляСобственностиЗнаменатель;
	КонецЦикла;
КонецПроцедуры

