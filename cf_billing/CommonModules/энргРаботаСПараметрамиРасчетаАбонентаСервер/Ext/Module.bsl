#КонецОбласти

Функция КоличествоЧеловек(ДанныеАбонента) Экспорт 
	КоличествоЖильцов	 			= 0;
	КоличествоПроживающих 			= 0;
	КоличествоПрописанных 			= 0;
	КоличествоСобственников 		= 0;
	
	ЭтоСоотвествие 					= ТипЗнч(ДанныеАбонента) = Тип("Соответствие");
	
	Если ЭтоСоотвествие и НЕ ДанныеАбонента["КоличествоЖильцов"] = Неопределено Тогда
		 КоличествоЖильцов 		= ДанныеАбонента["КоличествоЖильцов"];
	ИначеЕсли НЕ ЭтоСоотвествие И ДанныеАбонента.Свойство("КоличествоЖильцов") И НЕ ДанныеАбонента.КоличествоЖильцов = Неопределено Тогда
		КоличествоЖильцов 		= ДанныеАбонента.КоличествоЖильцов;
	КонецЕсли;  
	
	Если ЭтоСоотвествие и НЕ ДанныеАбонента["КоличествоПроживающих"] = Неопределено Тогда
		 КоличествоПроживающих 		= ДанныеАбонента["КоличествоПроживающих"];
	ИначеЕсли НЕ ЭтоСоотвествие И ДанныеАбонента.Свойство("КоличествоПроживающих") И НЕ ДанныеАбонента.КоличествоПроживающих = Неопределено Тогда
		КоличествоПроживающих 		= ДанныеАбонента.КоличествоПроживающих;
	КонецЕсли;
	
	Если ЭтоСоотвествие и НЕ ДанныеАбонента["КоличествоПрописанных"] = Неопределено Тогда
		КоличествоПрописанных 		= ДанныеАбонента["КоличествоПрописанных"];		
	ИначеЕсли НЕ ЭтоСоотвествие И ДанныеАбонента.Свойство("КоличествоПрописанных") И НЕ ДанныеАбонента.КоличествоПрописанных = Неопределено Тогда
		КоличествоПрописанных 		= ДанныеАбонента.КоличествоПрописанных;
	КонецЕсли;
	
	Если ЭтоСоотвествие и НЕ ДанныеАбонента["КоличествоСобственников"] = Неопределено Тогда
		КоличествоСобственников 	= ДанныеАбонента["КоличествоСобственников"];
	ИначеЕсли НЕ ЭтоСоотвествие И ДанныеАбонента.Свойство("КоличествоСобственников") И НЕ ДанныеАбонента.КоличествоСобственников = Неопределено Тогда
		КоличествоСобственников 	= ДанныеАбонента.КоличествоСобственников;
	КонецЕсли;
	
	Если НЕ КоличествоЖильцов = 0 Тогда
		Возврат КоличествоЖильцов;
	ИначеЕсли НЕ КоличествоПроживающих = 0 Тогда
		Возврат КоличествоПроживающих;
	ИначеЕсли НЕ КоличествоПрописанных = 0 Тогда
		Возврат КоличествоПрописанных;
	Иначе 
		Возврат КоличествоСобственников;
	КонецЕсли;
		
КонецФункции
