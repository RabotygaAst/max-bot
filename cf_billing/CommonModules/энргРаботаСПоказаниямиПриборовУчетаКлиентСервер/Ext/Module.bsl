// Пересчитывает строку с объемом МКД.
//
// Параметры:
//  ТекущиеДанные		-	ДанныеФормыЭлементКоллекции.
//  ПериодНачисления	-	Дата.
//  КонтрольныйСъем		-	Булево.
//
Процедура ПеречитатьСтрокуСОбъемомМКД(ТекущиеДанные,ПериодНачисления,КонтрольныйСъем = ложь) Экспорт 	
	
	МаксимальныйРасходЗаПериод 				= ТекущиеДанные.МаксимальноВозможныйОбъемПотребления ;
	
	Расход 									= ТекущиеДанные.Разница;
	
	Если КонтрольныйСъем  Тогда
		ТекущиеДанные.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
	ИначеЕсли Расход >= 0 И Расход < МаксимальныйРасходЗаПериод тогда	
		ТекущиеДанные.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
	ИначеЕсли Расход >= 0 и МаксимальныйРасходЗаПериод = 0 тогда	
		ТекущиеДанные.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
	иначе
		ТекущиеДанные.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
	КонецЕсли;
	
КонецПроцедуры

// Пересчитывает строку приборов учета теплоисточника.
//
// Параметры:
//  ТекСтрока			-	ДанныеФормыЭлементКоллекции.
//  ПериодНачисления	-	Дата.
//  КонтрольныйСъем		-	Булево.
//
Процедура ПересчитатьСтрокуПриборовУчетаТеплоисточника(ТекСтрока,ПериодНачисления,КонтрольныйСъем = ложь) Экспорт 
	
	ПоказанияЗа 						= ?(НачалоМесяца(ТекСтрока.ДатаПоследнихПоказаний) - ПериодНачисления = 0 ,1,1 + Цел((ПериодНачисления - ТекСтрока.ДатаПоследнихПоказаний) / (30*86400)));
	МаксимальныеВозможныеПоказания 		=  ТекСтрока.МаксимальноВозможныеПоказания;
	Расход 								= ТекСтрока.ТекущиеПоказания - ТекСтрока.ПредыдущиеПоказания;
	РасходСПереворотом 					= ТекСтрока.МаксимальноВозможныеПоказания - ТекСтрока.ПредыдущиеПоказания + ТекСтрока.ТекущиеПоказания;
	РасходПоМодулю 						= ?(ТекСтрока.ТекущиеПоказания>ТекСтрока.ПредыдущиеПоказания,ТекСтрока.ТекущиеПоказания - ТекСтрока.ПредыдущиеПоказания,ТекСтрока.ПредыдущиеПоказания -ТекСтрока.ТекущиеПоказания);
	
	Если ТекСтрока.СтатусИзмененПользователем  тогда
		Если ТекСтрока.СостояниеПоказаний = ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты") тогда
			ТекСтрока.Разница 			= ?(ТекСтрока.переворот,РасходСПереворотом,Расход);			
		иначе
			ТекСтрока.Разница 			= ?(ТекСтрока.переворот,РасходСПереворотом,Расход);			
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если ТекСтрока.ПереворотИзмененПользователем  тогда
		Если ТекСтрока.Переворот тогда
			ТекСтрока.Разница 			= РасходСПереворотом;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ТекСтрока.ПредыдущиеПоказания < 0 тогда
		ТекСтрока.ПредыдущиеПоказания = 0;
	КонецЕсли;
	
	Если ТекСтрока.ПредыдущиеПоказания = 0 тогда
		ПорядокНачальных 				= 1;
	иначе
		ПорядокНачальных 				= СтрДлина(Строка(Цел(ТекСтрока.ПредыдущиеПоказания))) - 1;
	КонецЕсли;
	
	Если ТекСтрока.ТекущиеПоказания = 0 тогда
		ПорядокКонечных 				= 1;
	иначе
		ПорядокКонечных 				= СтрДлина(Строка(Цел(ТекСтрока.ТекущиеПоказания))) - 1;
	КонецЕсли;	 
	
	Если Расход < 0  и ПорядокНачальных = ПорядокКонечных тогда
		ТекСтрока.Разница 				= Расход;
		ТекСтрока.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		Возврат;
	КонецЕсли; 
	
	// определяем расход
	Если ТекСтрока.ТекущиеПоказания = 0 тогда
		ТекСтрока.Разница 				= 0;
		ТекСтрока.Переворот 			= ложь;
		ТекСтрока.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
	ИначеЕсли КонтрольныйСъем и  Расход >=  0 тогда
		ТекСтрока.Разница 				= Расход;
		ТекСтрока.Переворот 			= ложь;
		ТекСтрока.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
	ИначеЕсли КонтрольныйСъем  тогда
		ТекСтрока.Разница 				= Расход;
		ТекСтрока.Переворот 			= Ложь;
		ТекСтрока.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");	
	ИначеЕсли Расход > 0 тогда	
		ТекСтрока.Разница 				= Расход;
		ТекСтрока.Переворот 			= ложь;
		ТекСтрока.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");	
	иначе
		ТекСтрока.Разница 				= -РасходПоМодулю;
		ТекСтрока.Переворот 			= ложь;
		ТекСтрока.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
	КонецЕсли;    	
	
	ТекСтрока.Сумма 					= ТекСтрока.Разница * ТекСтрока.ЗначениеТарифа;
	
	
КонецПроцедуры

