#Область ПрограммныйИнтерфейс

// Перечитывает строку приборов учета.
//
// Параметры:
//  ТекСтрока					-	ДанныеФормыЭлементКоллекции.
//  ПериодНачисления			-	Дата.
//  КонтрольныйСъем				-	Булево.
//  ДополнительныеПараментры	-	Структура
//
Процедура ПересчитатьСтрокуПриборовУчета(ТекСтрока, ПериодНачисления, КонтрольныйСъем = Ложь, ДополнительныеПараментры = Неопределено) Экспорт 
	
	// Причины отклонения показаний
	ОтрицательныйРасход 						= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ОтрицательныйРасход");
	ИстекСрокМПИ 								= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.УПрибораУчетаИстекМПИ");
	ОРП											= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ОРП");
	АбонентОтсутствует							= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.АбонентОтсутствует");
	ЗапретПриемаВПУ 							= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ЗапретПриемаВПУ");
	АктНедопуска 								= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.АктНедопуска");
	РасходПревышаетМаксимальноДопустимыйОбъем 	= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.РасходПревышаетМаксимальноДопустимыйОбъем");
		
	ПоказанияЗа 					= ?(НачалоМесяца(ТекСтрока.ДатаПоследнихПоказаний) - ПериодНачисления = 0 ,1,1 + 
		Цел((ПериодНачисления - ТекСтрока.ДатаПоследнихПоказаний) / (30*86400)));
		
	МаксимальныеВозможныеПоказания 	= pow(10,СтрДлина(СтрЗаменить(СтрЗаменить(ТекСтрока.ПредыдущиеПоказания,Символы.НПП,"")," ","")));
	Расход 							= ТекСтрока.ТекущиеПоказания - ТекСтрока.ПредыдущиеПоказания;
	РасходСПереворотом 				= ТекСтрока.МаксимальноВозможныеПоказания - ТекСтрока.ПредыдущиеПоказания + ТекСтрока.ТекущиеПоказания;
	РасходПоМодулю 					= ?(ТекСтрока.ТекущиеПоказания>ТекСтрока.ПредыдущиеПоказания,ТекСтрока.ТекущиеПоказания - 
		ТекСтрока.ПредыдущиеПоказания,ТекСтрока.ПредыдущиеПоказания -ТекСтрока.ТекущиеПоказания);
	
	Если ТекСтрока.СтатусИзмененПользователем И ТекСтрока.СостояниеПоказаний = ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены") Тогда
		ТекСтрока.Разница 			= ?(ТекСтрока.Переворот, РасходСПереворотом, Расход);	
		ТекСтрока.ПричинаОтклонения	= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ОтклоненыПользователем"); 
		ТекСтрока.Сумма 				= ТекСтрока.Разница * ТекСтрока.ЗначениеТарифа; 				
		Возврат;
	КонецЕсли; 
	
	Если ТекСтрока.ПереворотИзмененПользователем  Тогда 
		Если ТекСтрока.Переворот Тогда			
			ТекСтрока.Разница 				= РасходСПереворотом;
			ТекСтрока.Сумма 				= ТекСтрока.Разница * ТекСтрока.ЗначениеТарифа;			
			ТекСтрока.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
			ТекСтрока.ПричинаОтклонения		= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ПустаяСсылка");
			Возврат;			
		КонецЕсли;
	КонецЕсли;
	
	Если ТекСтрока.ПредыдущиеПоказания < 0 Тогда 
		ТекСтрока.ПредыдущиеПоказания = 0;
	КонецЕсли;
	
	Если ТекСтрока.ПричинаОтклонения = ИстекСрокМПИ Тогда	
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		ТекСтрока.ПричинаОтклонения				= ИстекСрокМПИ;
		ТекСтрока.СтатусИзмененПользователем 	= Ложь;
	ИначеЕсли ТекСтрока.ПричинаОтклонения = ОРП Тогда	
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		ТекСтрока.ПричинаОтклонения				= ОРП;
		ТекСтрока.СтатусИзмененПользователем 	= Ложь;
	ИначеЕсли ТекСтрока.ПричинаОтклонения = АбонентОтсутствует Тогда 	
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		ТекСтрока.ПричинаОтклонения				= АбонентОтсутствует; 
		ТекСтрока.СтатусИзмененПользователем 	= Ложь;
	ИначеЕсли ТекСтрока.ПричинаОтклонения = ЗапретПриемаВПУ И Не ТекСтрока.СтатусИзмененПользователем Тогда	
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		ТекСтрока.ПричинаОтклонения				= ЗапретПриемаВПУ;
		ТекСтрока.СтатусИзмененПользователем 	= Ложь;
	ИначеЕсли ТекСтрока.ПричинаОтклонения = АктНедопуска Тогда
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		ТекСтрока.ПричинаОтклонения				= АктНедопуска;	
		ТекСтрока.СтатусИзмененПользователем 	= Ложь;
	ИначеЕсли Расход >= 0 И КонтрольныйСъем Тогда
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
		ТекСтрока.ПричинаОтклонения				= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ПустаяСсылка");	
	ИначеЕсли КонтрольныйСъем Тогда
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		ТекСтрока.ПричинаОтклонения				= ОтрицательныйРасход;
		ТекСтрока.СтатусИзмененПользователем 	= Ложь;
	ИначеЕсли Расход >= 0 И Расход <= ТекСтрока.МаксимальноВозможныйОбъемПотребления Тогда 	
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
		ТекСтрока.ПричинаОтклонения				= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ПустаяСсылка");
	ИначеЕсли Расход >= 0 И ТекСтрока.МаксимальноВозможныйОбъемПотребления = 0 Тогда 	
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
		ТекСтрока.ПричинаОтклонения				= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ПустаяСсылка");
	ИначеЕсли Расход >= 0 И ТекСтрока.СтатусИзмененПользователем Тогда 	
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
		ТекСтрока.ПричинаОтклонения				= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ПустаяСсылка");
	ИначеЕсли Расход >= 0 Тогда 	
		ТекСтрока.Разница 						= Расход;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		ТекСтрока.ПричинаОтклонения				= РасходПревышаетМаксимальноДопустимыйОбъем;
		ТекСтрока.СтатусИзмененПользователем 	= Ложь;
	Иначе 
		ТекСтрока.Разница 						= РасходПоМодулю;
		ТекСтрока.Переворот 					= Ложь;
		ТекСтрока.СостояниеПоказаний 			= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		ТекСтрока.ПричинаОтклонения				= ОтрицательныйРасход; 
		ТекСтрока.СтатусИзмененПользователем 	= Ложь;
	КонецЕсли;  	
	
	ТекСтрока.Сумма	= ТекСтрока.Разница * ТекСтрока.ЗначениеТарифа;
	
КонецПроцедуры

// Перечитывает строку с объемом.
//
// Параметры:
//  ТекущиеДанные		-	ДанныеФормыЭлементКоллекции.
//  ПериодНачисления	-	Дата.
//  КонтрольныйСъем		-	Булево.
//
Процедура ПеречитатьСтрокуСОбъемом(ТекущиеДанные,ПериодНачисления,КонтрольныйСъем = ложь) Экспорт
	
	МаксимальныйРасходЗаПериод 				= ТекущиеДанные.МаксимальноВозможныйОбъемПотребления ;
	
	Расход 									= ТекущиеДанные.Разница; 
	
	Если ТекущиеДанные.СтатусИзмененПользователем И ТекущиеДанные.СостояниеПоказаний = ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены") Тогда	
		ТекущиеДанные.ПричинаОтклонения	= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ОтклоненыПользователем"); 
		ТекущиеДанные.Сумма 				= ТекущиеДанные.Разница * ТекущиеДанные.ЗначениеТарифа; 				
		Возврат; 
	КонецЕсли;
	
	Если КонтрольныйСъем  Тогда
		ТекущиеДанные.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
	ИначеЕсли Расход >= 0 И Расход < МаксимальныйРасходЗаПериод Тогда	
		ТекущиеДанные.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
	ИначеЕсли Расход >= 0 и МаксимальныйРасходЗаПериод = 0 Тогда	
		ТекущиеДанные.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты");
	ИначеЕсли Расход < 0 Тогда
		ТекущиеДанные.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
		ТекущиеДанные.ПричинаОтклонения		= ПредопределенноеЗначение("Перечисление.энргПричиныОтклоненияПоказаний.ОтрицательныйРасход");
	Иначе 	
		ТекущиеДанные.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены");
	КонецЕсли;  	
	
	ТекущиеДанные.Сумма 					= ТекущиеДанные.Разница * ТекущиеДанные.ЗначениеТарифа;
	
КонецПроцедуры

// Возвращает данные строки показаний.
//
// Возвращаемое значение:
//   Структура.
//
Функция  ДанныеСтрокиПоказаний() Экспорт 	
	ДанныеСтроки  = Новый Структура;
	ДанныеСтроки.Вставить("ПредыдущиеПоказания");
	ДанныеСтроки.Вставить("ДатаПоследнихПоказаний");
	ДанныеСтроки.Вставить("СостояниеПоказаний");
	ДанныеСтроки.Вставить("ТекущиеПоказания");
	ДанныеСтроки.Вставить("СреднийОбъемПотребления");
	ДанныеСтроки.Вставить("МаксимальноВозможныеПоказания");
	ДанныеСтроки.Вставить("МаксимальноВозможныйОбъемПотребления"); 
	ДанныеСтроки.Вставить("КоэффициентПУ"); 
	ДанныеСтроки.Вставить("Разница");
	ДанныеСтроки.Вставить("Переворот");
	ДанныеСтроки.Вставить("СостояниеПоказаний");
	ДанныеСтроки.Вставить("ПричинаОтклонения");
	ДанныеСтроки.Вставить("ПереворотИзмененПользователем");
	ДанныеСтроки.Вставить("СтатусИзмененПользователем");
	ДанныеСтроки.Вставить("ЗначениеТарифа");
	ДанныеСтроки.Вставить("Сумма");
	Возврат ДанныеСтроки;   	
КонецФункции

// Возвращает данные строки показаний МКД.
// 
// Возвращаемое значение:
//   Структура.
//
Функция  ДанныеСтрокиПоказанийМКД() Экспорт 	
	ДанныеСтроки  = Новый Структура;
	ДанныеСтроки.Вставить("ПредыдущиеПоказания");
	ДанныеСтроки.Вставить("ДатаПоследнихПоказаний");
	ДанныеСтроки.Вставить("СостояниеПоказаний");
	ДанныеСтроки.Вставить("ТекущиеПоказания");
	ДанныеСтроки.Вставить("СреднийОбъемПотребления");
	ДанныеСтроки.Вставить("МаксимальноВозможныеПоказания");
	ДанныеСтроки.Вставить("МаксимальноВозможныйОбъемПотребления"); 
	ДанныеСтроки.Вставить("КоэффициентПУ"); 
	ДанныеСтроки.Вставить("Разница");
	ДанныеСтроки.Вставить("Переворот");
	ДанныеСтроки.Вставить("СостояниеПоказаний");
	ДанныеСтроки.Вставить("ПереворотИзмененПользователем");
	ДанныеСтроки.Вставить("СтатусИзмененПользователем");
	Возврат ДанныеСтроки;   	
КонецФункции

 //Пересчитывает строку приборов учета МКД.
//
// Параметры:
//  ТекСтрока					-	ДанныеФормыЭлементКоллекции.
//  ПериодНачисления			-	Дата.
//  КонтрольныйСъем				-	Булево.
//  ДополнительныеПараментры	-	Структура.
//
Процедура ПересчитатьСтрокуПриборовУчетаМКД(ТекСтрока,ПериодНачисления,КонтрольныйСъем = ложь, ДополнительныеПараментры = Неопределено) Экспорт
		
	ПоказанияЗа 						= ?(НачалоМесяца(ТекСтрока.ДатаПоследнихПоказаний) - ПериодНачисления = 0 ,1,1 + Цел((ПериодНачисления - ТекСтрока.ДатаПоследнихПоказаний) / (30*86400)));
	МаксимальныеВозможныеПоказания 		=  ТекСтрока.МаксимальноВозможныеПоказания;
	Расход 								= ТекСтрока.ТекущиеПоказания - ТекСтрока.ПредыдущиеПоказания;
	РасходСПереворотом 					= ТекСтрока.МаксимальноВозможныеПоказания - ТекСтрока.ПредыдущиеПоказания + ТекСтрока.ТекущиеПоказания;
	РасходПоМодулю 						= ?(ТекСтрока.ТекущиеПоказания>ТекСтрока.ПредыдущиеПоказания,ТекСтрока.ТекущиеПоказания - ТекСтрока.ПредыдущиеПоказания,ТекСтрока.ПредыдущиеПоказания -ТекСтрока.ТекущиеПоказания);
	
	Если ТекСтрока.СтатусИзмененПользователем Тогда
		Если ТекСтрока.СостояниеПоказаний = ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Приняты") тогда
			ТекСтрока.Разница 			= ?(ТекСтрока.переворот,РасходСПереворотом,Расход);			
		иначе
			ТекСтрока.Разница 			= ?(ТекСтрока.переворот,РасходСПереворотом,Расход);			
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если ТекСтрока.ПереворотИзмененПользователем  тогда
		Если ТекСтрока.Переворот тогда
			ТекСтрока.Разница 			= РасходСПереворотом;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ТекСтрока.ПредыдущиеПоказания < 0 тогда
		ТекСтрока.ПредыдущиеПоказания = 0;
	КонецЕсли;
	
	Если ТекСтрока.ПредыдущиеПоказания = 0 тогда
		ПорядокНачальных 				= 1;
	иначе
		ПорядокНачальных 				= СтрДлина(Строка(Цел(ТекСтрока.ПредыдущиеПоказания))) - 1;
	КонецЕсли;
	
	Если ТекСтрока.ТекущиеПоказания = 0 тогда
		ПорядокКонечных 				= 1;
	иначе
