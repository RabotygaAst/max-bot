#Область ПрограммныйИнтерфейс

#Область РегламетныеПроцедуры

// Регламентные процедуры Биллинга.
//
Процедура РегламетныеПроцедурыБиллинг() Экспорт 
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.энргРегламентныеПроцедуры);
	
	УстановитьПривилегированныйРежим(Истина);
	
	Инструменты  		= энргФабрикаИнструментовНачисления.РаботаСПоследовательностями();
	Если Инструменты = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект";
		Возврат;
	КонецЕсли; 
	Инструменты.РегламетныеПроцедурыБиллинг();
	
КонецПроцедуры

// Восстанавливает последовательность взаиморасчетов.
//
Процедура ВосстановитьПоследовательностьВзаиморасчетов() Экспорт  
	
	Текст = 
	"ВЫБРАТЬ
	|	энргВзаиморасчетыПоследовательность.Организация КАК Организация,
	|	энргВзаиморасчетыПоследовательность.Район КАК Район,
	|	МИНИМУМ(энргВзаиморасчетыПоследовательность.ПериодНачисления) КАК ПериодНачисления
	|ИЗ
	|	РегистрСведений.энргВзаиморасчетыПоследовательность КАК энргВзаиморасчетыПоследовательность
	|ГДЕ
	|	НЕ энргВзаиморасчетыПоследовательность.СостояниеПроведения = ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности)
	|	И энргВзаиморасчетыПоследовательность.ПериодНачисления = &ПериодНачисления
	|
	|СГРУППИРОВАТЬ ПО
	|	энргВзаиморасчетыПоследовательность.Организация,
	|	энргВзаиморасчетыПоследовательность.Район";
	
	Запрос  						= Новый Запрос(Текст); 	
	Запрос.УстановитьПараметр("ПериодНачисления", НачалоМесяца(ТекущаяДатаСеанса()));
	Результат  						= Запрос.Выполнить();
	Выборка 						= Результат.Выбрать();
	
	ОписаниеПараметров = "Организация, ПериодНачисления, Район, МКД, Абонент, СписокМКД";
	Пока Выборка.Следующий() Цикл
		ПараметрыОперации = Новый Структура(ОписаниеПараметров);
		ПараметрыОперации.Организация = Выборка.Организация;
		ПараметрыОперации.ПериодНачисления = Выборка.ПериодНачисления;
		ПараметрыОперации.Район = Выборка.Район;
		ПараметрыОперации.СписокМКД = Неопределено;
				
		ПараметрыЗадания  			= Новый Массив;
		ПараметрыЗадания.Добавить(ПараметрыОперации);
		ФоновыеЗадания.Выполнить("энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты", ПараметрыЗадания);
	КонецЦикла;
		
КонецПроцедуры

// Процедура регламентного задания "Автоматическая рассылка уведомлений"
Процедура АвтоматическаяРассылкаУведомлений() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	энргСобытиеАбоненты.Ссылка КАК ДокСобытие,
		|	энргСобытияСрезПоследних.Абонент КАК Абонент,
		|	энргСобытиеАбоненты.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	РегистрСведений.энргСобытия.СрезПоследних(
		|			,
		|			ПланируемаяДатаОтправки <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|				И ПланируемаяДатаОтправки <= &ТекДата) КАК энргСобытияСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргСобытие.Абоненты КАК энргСобытиеАбоненты
		|		ПО энргСобытияСрезПоследних.Регистратор = энргСобытиеАбоненты.Ссылка
		|			И энргСобытияСрезПоследних.ТипСобытия = энргСобытиеАбоненты.Ссылка.ТипСобытия
		|			И энргСобытияСрезПоследних.Абонент = энргСобытиеАбоненты.Абонент
		|			И энргСобытияСрезПоследних.Основание = энргСобытиеАбоненты.Основание
		|ИТОГИ ПО
		|	ДокСобытие";
	
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДокСобытие = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаДокСобытие.Следующий() Цикл
		ДокОъект = ВыборкаДокСобытие.ДокСобытие.ПолучитьОбъект();
		
		Если Ложь Тогда
			ДокОъект = Документы.энргСобытие.СоздатьДокумент();
		КонецЕсли;
		
		СписокНомеров = Новый Массив;
		Выборка = ВыборкаДокСобытие.Выбрать();
	
		Пока Выборка.Следующий() Цикл
			СписокНомеров.Добавить(Выборка.НомерСтроки);
		КонецЦикла;
		
		ДокОъект.ВыполнитьСобытия(СписокНомеров);
	КонецЦикла;
КонецПроцедуры

// Процедура регламентного задания "Закрытие задач ПИД по погашению задолженности"
Процедура ЗакрытиеЗадачПИД_ПоПогашениюЗадолженности() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЭтапыПретензионноИсковойДеятельностиЗадачСрезПоследних.Абонент КАК Абонент,
		|	энргЭтапыПретензионноИсковойДеятельностиЗадачСрезПоследних.Этап КАК Этап,
		|	энргЭтапыПретензионноИсковойДеятельностиЗадачСрезПоследних.ДатаСледЭтапа КАК ДатаСледЭтапа,
		|	энргЭтапыПретензионноИсковойДеятельностиЗадачСрезПоследних.Организация КАК Организация,
		|	энргЭтапыПретензионноИсковойДеятельностиЗадачСрезПоследних.ПериодЗадолженностиНачало КАК НачалоПериода,
		|	энргЭтапыПретензионноИсковойДеятельностиЗадачСрезПоследних.Исполнитель КАК Ответственный,
		|	энргЗадачаПИД.Ссылка КАК Задача,
		|	энргЗадачаПИД.Район КАК Район
		|ПОМЕСТИТЬ ВТ_ЭтапыИОтветственные
		|ИЗ
		|	РегистрСведений.энргЭтапыПретензионноИсковойДеятельностиЗадач.СрезПоследних(&ТекДата, ) КАК энргЭтапыПретензионноИсковойДеятельностиЗадачСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД КАК энргЗадачаПИД
		|		ПО энргЭтапыПретензионноИсковойДеятельностиЗадачСрезПоследних.ЗадачаРрегистратор = энргЗадачаПИД.Ссылка
		|ГДЕ
		|	НЕ энргЗадачаПИД.ПометкаУдаления
		|	И НЕ энргЗадачаПИД.Выполнена
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргНастройкиНачисленияПениСрезПоследних.Организация КАК Организация,
		|	КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(&ТекДата, ДЕНЬ, -энргНастройкиНачисленияПениСрезПоследних.КрайнийСрокОплаты), МЕСЯЦ, -1), МЕСЯЦ) КАК ГраницаНачислений,
		|	энргНастройкиНачисленияПениСрезПоследних.КрайнийСрокОплаты КАК КрайнийСрокОплаты,
		|	энргНастройкиНачисленияПениСрезПоследних.Район КАК Район
		|ПОМЕСТИТЬ ВТ_КрайнийСрокОплаты
		|ИЗ
		|	РегистрСведений.энргНастройкиНачисленияПени.СрезПоследних(, ) КАК энргНастройкиНачисленияПениСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргВзаиморасчеты.Организация КАК Организация,
		|	энргВзаиморасчеты.Район КАК Район,
		|	энргВзаиморасчеты.Абонент КАК Абонент,
		|	СУММА(ВЫБОР
		|			КОГДА энргВзаиморасчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|				ТОГДА энргВзаиморасчеты.Сумма
		|			КОГДА энргВзаиморасчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|					И энргВзаиморасчеты.Сумма < 0
		|				ТОГДА -энргВзаиморасчеты.Сумма
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК НеПросроченныеНачисления
		|ПОМЕСТИТЬ ВТ_НеПросроченныеНачисления
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчеты КАК энргВзаиморасчеты
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КрайнийСрокОплаты КАК ВТ_КрайнийСрокОплаты
		|		ПО энргВзаиморасчеты.Организация = ВТ_КрайнийСрокОплаты.Организация
		|			И энргВзаиморасчеты.Район = ВТ_КрайнийСрокОплаты.Район
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		|		ПО энргВзаиморасчеты.Абонент = энргАбоненты.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЭтапыИОтветственные КАК ВТ_ЭтапыИОтветственные
		|		ПО энргВзаиморасчеты.Организация = ВТ_ЭтапыИОтветственные.Организация
		|			И энргВзаиморасчеты.Район = ВТ_ЭтапыИОтветственные.Район
		|			И энргВзаиморасчеты.Абонент = ВТ_ЭтапыИОтветственные.Абонент
		|ГДЕ
		|	ВЫБОР
		|			КОГДА энргАбоненты.КоличествоДнейОтсрочки > 0
		|				ТОГДА энргВзаиморасчеты.Период > КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(&ТекДата, ДЕНЬ, -энргАбоненты.КоличествоДнейОтсрочки), МЕСЯЦ, -1), МЕСЯЦ)
		|			ИНАЧЕ ВТ_КрайнийСрокОплаты.ГраницаНачислений ЕСТЬ NULL
		|						И энргВзаиморасчеты.Период > КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&ТекДата, МЕСЯЦ, -1), МЕСЯЦ)
		|					ИЛИ энргВзаиморасчеты.Период > ВТ_КрайнийСрокОплаты.ГраницаНачислений
		|		КОНЕЦ
		|	И энргВзаиморасчеты.Период <= &ТекДата
		|
		|СГРУППИРОВАТЬ ПО
		|	энргВзаиморасчеты.Организация,
		|	энргВзаиморасчеты.Район,
		|	энргВзаиморасчеты.Абонент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргВзаиморасчетыОстатки.Организация КАК Организация,
		|	энргВзаиморасчетыОстатки.Район КАК Район,
		|	энргВзаиморасчетыОстатки.Абонент КАК Абонент,
		|	энргВзаиморасчетыОстатки.СуммаОстаток - ЕСТЬNULL(ВТ_НеПросроченныеНачисления.НеПросроченныеНачисления, 0) КАК Задолженность,
		|	ВТ_ЭтапыИОтветственные.Этап КАК Этап,
		|	ВТ_ЭтапыИОтветственные.ДатаСледЭтапа КАК ДатаСледЭтапа,
		|	ВТ_ЭтапыИОтветственные.Ответственный КАК Ответственный,
		|	ВТ_ЭтапыИОтветственные.Задача КАК Задача
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчеты.Остатки(
		|			&ТекДата,
		|			(Абонент, Организация, Район) В
		|				(ВЫБРАТЬ
		|					ВТ_ЭтапыИОтветственные.Абонент КАК Абонент,
		|					ВТ_ЭтапыИОтветственные.Организация КАК Организация,
		|					ВТ_ЭтапыИОтветственные.Район КАК Район
		|				ИЗ
		|					ВТ_ЭтапыИОтветственные КАК ВТ_ЭтапыИОтветственные)) КАК энргВзаиморасчетыОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НеПросроченныеНачисления КАК ВТ_НеПросроченныеНачисления
		|		ПО энргВзаиморасчетыОстатки.Организация = ВТ_НеПросроченныеНачисления.Организация
		|			И энргВзаиморасчетыОстатки.Район = ВТ_НеПросроченныеНачисления.Район
		|			И энргВзаиморасчетыОстатки.Абонент = ВТ_НеПросроченныеНачисления.Абонент
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЭтапыИОтветственные КАК ВТ_ЭтапыИОтветственные
		|		ПО энргВзаиморасчетыОстатки.Организация = ВТ_ЭтапыИОтветственные.Организация
		|			И энргВзаиморасчетыОстатки.Абонент = ВТ_ЭтапыИОтветственные.Абонент
		|ГДЕ
		|	энргВзаиморасчетыОстатки.СуммаОстаток - ЕСТЬNULL(ВТ_НеПросроченныеНачисления.НеПросроченныеНачисления, 0) <= 0";
	
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Попытка
			ТекстКомментария = "Деятельность прекращена регламентным заданием";
			
			ОбъектЗадача = Выборка.Задача.ПолучитьОбъект();
			
			ОбъектЗадача.ПрекращенаДеятельность = Истина;
			ОбъектЗадача.Комментарий			= ТекстКомментария;
			
			СтрокаТЧ = ОбъектЗадача.ИсторияПеренаправленийЗадачи.Добавить();
			СтрокаТЧ.ДатаПеренаправления = ТекущаяДатаСеанса();
			СтрокаТЧ.Комментарий		 = ТекстКомментария;
			СтрокаТЧ.Перенаправил		 = ПараметрыСеанса.ТекущийПользователь;
			
			ОбъектЗадача.ВыполнитьЗадачуИнтерактивно();
		Исключение
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

// Процедура регламентного задания "Открытие ПИР"
Процедура ОткрытиеПИР_ПоКритериям() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестНастройкаКритериевДляНачалаПИРСрезПоследних.Организация КАК Организация,
		|	бестНастройкаКритериевДляНачалаПИРСрезПоследних.Район КАК Район,
		|	бестНастройкаКритериевДляНачалаПИРСрезПоследних.СуммаЗадолженности КАК СуммаЗадолженности,
		|	бестНастройкаКритериевДляНачалаПИРСрезПоследних.КоличествоНеоплаченныхПериодов КАК КоличествоНеоплаченныхПериодов
		|ИЗ
		|	РегистрСведений.бестНастройкаКритериевДляНачалаПИР.СрезПоследних(&ТекущаяДата, ) КАК бестНастройкаКритериевДляНачалаПИРСрезПоследних";
	
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ПрименитьКритерий(Выборка.Организация, Выборка.Район, Выборка.СуммаЗадолженности, Выборка.КоличествоНеоплаченныхПериодов);
	КонецЦикла;
КонецПроцедуры

Процедура ПрименитьКритерий(Организация, Район, СуммаЗадолженности, КоличествоНеоплаченныхПериодов)

	Отборы = Новый Структура("Организация, Район, Задолженность, КоличествоНеоплаченныхПериодов, ТекДата",
								Организация, Район, СуммаЗадолженности, КоличествоНеоплаченныхПериодов, ТекущаяДата());

	Запрос = Обработки.энргРаботаСДолжниками.ПолучитьЗапрос(Отборы, Истина);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаАбонент = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаАбонент.Следующий() Цикл
		ПарамЗадачи = Новый Структура("Абонент, Организация, Район, СуммаЗадолженности,ЛицевойСчет, АдресОбъекта,ПериодНачисления");
		ПарамЗадачи.Вставить("МКД", ВыборкаАбонент.Дом);
		
		энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыАбонента(ВыборкаАбонент.Абонент, ПарамЗадачи);
		ЗаполнитьЗначенияСвойств(ПарамЗадачи, ВыборкаАбонент);
		
		Задолженность = Новый ТаблицаЗначений;
		Задолженность.Колонки.Добавить("Услуга", 			Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
		Задолженность.Колонки.Добавить("ПериодНачисления", 	Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Дата)));
		Задолженность.Колонки.Добавить("Задолженность",		Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
		
		ВыборкаПериодНачисления = ВыборкаАбонент.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаПериодНачисления.Следующий() Цикл
			
			Выборка = ВыборкаПериодНачисления.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока Выборка.Следующий() Цикл
				СтрокаТЗ = Задолженность.Добавить();
				
				ЗаполнитьЗначенияСвойств(СтрокаТЗ, Выборка);
			КонецЦикла;
		КонецЦикла;
		
		Попытка
			НачатьТранзакцию();
			
			НовЗадача = Задачи.энргЗадачаПИД.СоздатьЗадачу();
			НовЗадача.Дата = ТекущаяДата();
			ЗаполнитьЗначенияСвойств(НовЗадача, ПарамЗадачи); 
			СуммаДолга = 0;
			Для каждого СтрокаЗадол Из Задолженность Цикл
				СтрокаТЧ = НовЗадача.Задолженность.Добавить();
				
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаЗадол);
				СуммаДолга = СуммаДолга + СтрокаЗадол.Задолженность;
			КонецЦикла;
			
			НовЗадача.СуммаЗадолженности = СуммаДолга;
			
			Задачи.энргЗадачаПИД.ЗаполнитьНаименованиеИЭтап(НовЗадача);
			НовЗадача.Записать();
			
			Если Не ЗначениеЗаполнено(НовЗадача.Схема) Или Не ЗначениеЗаполнено(НовЗадача.Исполнитель) Тогда
				
				ОтменитьТранзакцию();
			Иначе 
				ЗафиксироватьТранзакцию();
			КонецЕсли;
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось создать задачу для абонента " + ВыборкаАбонент.Абонент + " по причине: " + ОписаниеОшибки());
			ОтменитьТранзакцию();
		КонецПопытки;

	КонецЦикла;
КонецПроцедуры

