//
Процедура ВосстановитьПоследовательностьПоказанияПУМКД(Параметры) Экспорт 
	
	Инструменты  		= энргФабрикаИнструментовНачисления.РаботаСПоследовательностями();
	Если Инструменты = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект";
		Возврат;
	КонецЕсли; 
	Инструменты.ВосстановитьПоследовательностьПоказанияПУМКД(Параметры.Организация, Параметры.ПериодНачисления, Параметры.Район, Параметры.МКД);
	
КонецПроцедуры

// Восстанавливает последовательность взаиморасчетов.
// 
// Параметры:
//	 Параметры 			- Параметры.
//	 Многопоточность	- Многопоточность.
//
Процедура ВосстановитьПоследовательностьВзаиморасчеты(Параметры, Многопоточность = Ложь) Экспорт 
	
	Инструменты  		= энргФабрикаИнструментовНачисления.РаботаСПоследовательностями();
	Если Инструменты = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект";
		Возврат;
	КонецЕсли;
	
	Если Многопоточность И Параметры.МКД = Неопределено И Не ЗначениеЗаполнено(Параметры.Абонент) И Не ЗначениеЗаполнено(Параметры.СписокМКД) Тогда
		// многопоточно
		ДлительныеОперацииСписок = Новый Массив;
		// ЧС
		ПараметрыОтбора = НовыеПараметрыОтборов();  
		ЗаполнитьЗначенияСвойств(ПараметрыОтбора, Параметры);
		ПараметрыОтбора.МКД	= Справочники.энргСтроения.ПустаяСсылка();
		
		ДлительнаяОперация = ЗапуститьФоновоеЗаданиеСервер(Неопределено, ПараметрыОтбора);
		ДлительныеОперацииСписок.Добавить(ДлительнаяОперация);
		
		// МКД
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргВзаиморасчетыПоследовательность.МКД КАК МКД,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ энргВзаиморасчетыПоследовательность.Абонент) КАК Абонент
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	РегистрСведений.энргВзаиморасчетыПоследовательность КАК энргВзаиморасчетыПоследовательность
		|ГДЕ
		|	энргВзаиморасчетыПоследовательность.Организация = &Организация
		|	И энргВзаиморасчетыПоследовательность.Район = &Район
		|	И энргВзаиморасчетыПоследовательность.ПериодНачисления = &ПериодНачисления
		|	И энргВзаиморасчетыПоследовательность.МКД <> ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
		|	И энргВзаиморасчетыПоследовательность.СостояниеПроведения = ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности)
		|
		|СГРУППИРОВАТЬ ПО
		|	энргВзаиморасчетыПоследовательность.МКД
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.МКД КАК МКД
		|ИЗ
		|	ВТ КАК ВТ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТ.Абонент УБЫВ";
		
		Запрос.УстановитьПараметр("ПериодНачисления", Параметры.ПериодНачисления);
		Запрос.УстановитьПараметр("Организация", Параметры.Организация);
		Запрос.УстановитьПараметр("Район", Параметры.Район);
		РезультатЗапроса = Запрос.Выполнить(); 	
		Выборка = РезультатЗапроса.Выбрать();
		МаксимальноеКолиествоПотоков = 10;
		ОбщееКоличество = Выборка.Количество();		
		Если ОбщееКоличество <= МаксимальноеКолиествоПотоков Тогда 
			Порция = ОбщееКоличество;
		Иначе 
			Порция = Цел(ОбщееКоличество / МаксимальноеКолиествоПотоков);
			Если (ОбщееКоличество % МаксимальноеКолиествоПотоков) > 0 Тогда			
				Порция = Порция + 1;
			КонецЕсли;
		КонецЕсли;	
		
		Итерация = 0; 
		ПодготовленныеПотоки = Новый Массив;
		Для Сч = 1 По МаксимальноеКолиествоПотоков Цикл
			ПодготовленныеПотоки.Добавить(Новый Массив);		
		КонецЦикла;
		
		Пока Выборка.Следующий() Цикл
			Если Итерация >  МаксимальноеКолиествоПотоков - 1 Тогда
				Итерация = 0;
			КонецЕсли;
			ПодготовленныеПотоки[Итерация].Добавить(Выборка.МКД);
			Итерация = Итерация + 1;
		КонецЦикла;
		
		Для Каждого Поток из ПодготовленныеПотоки Цикл 
			ПараметрыОтбора = НовыеПараметрыОтборов();
			ЗаполнитьЗначенияСвойств(ПараметрыОтбора, Параметры);
			ПараметрыОтбора.СписокМКД		= Поток;
			ДлительнаяОперация = ЗапуститьФоновоеЗаданиеСервер(Неопределено, ПараметрыОтбора);
			ДлительныеОперацииСписок.Добавить(ДлительнаяОперация);
		КонецЦикла;   
		
		ОжидатьЗавершениеВсехПотоков(ДлительныеОперацииСписок);
		
	КонецЕсли;
	
	Инструменты.ВосстановитьПоследовательностьВзаиморасчеты(Параметры.Организация, Параметры.ПериодНачисления, Параметры.Район, Параметры.МКД, Параметры.Абонент, Параметры.СписокМКД);
	
КонецПроцедуры

// Сбрасывает состояние последовательности.
// 
// Параметры:
//	 ИмяПоследовательности - Имя Последовательности.
//	 Организация		   - Организация.
//   ПериодНачисления 	   - Период Начисления.
//   Район				   - Район.
//   МКД				   - МКД.
//   Абонент			   - Абонент.
//
Процедура СброситьСостояниеПоследовательности(ИмяПоследовательности,Организация, ПериодНачисления,Район,МКД,Абонент = Неопределено) Экспорт 
	
	Инструменты  		= энргФабрикаИнструментовНачисления.РаботаСПоследовательностями();
	Если Инструменты = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект";
		Возврат;
	КонецЕсли; 
	Инструменты.СброситьСостояниеПоследовательности(ИмяПоследовательности,Организация,ПериодНачисления,Район,МКД,Абонент);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область Многопоточность

// Восстанавливает последовательность показания ПУ.
// 
// Параметры:
//   ПериодНачисления 	- Период Начисления.
//   Район				- Район.
//   МКД				- МКД.
//   Абонент			- Абонент.
//
Процедура ВосстановитьПоследовательностьПоказанияПУМногопоточно(Параметры) Экспорт 
	
	Инструмент = энргФабрикаИнструментовНачисления.СервисВосстановленияПоследовательностиПоказанийПУ(); 
	Если Инструмент = Неопределено тогда
		ВызватьИсключение "Не удалось создать защищенный объект";
		Возврат;
	КонецЕсли;
	
	Инструмент.Организация  	= Параметры.Организация;
	Инструмент.ПериодНачисления	= Параметры.ПериодНачисления;
	Инструмент.Район			= Параметры.Район;
	Инструмент.ЧастныйСектор 	= Параметры.ЧастныйСектор;
	Инструмент.Строение			= Параметры.Строение;
	Инструмент.Помещение		= Параметры.Помещение;
	Инструмент.Строения			= Параметры.Строения;
	
	Инструмент.ВосстановитьПоследовательность();
	
КонецПроцедуры
	
#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОжидатьЗавершениеВсехПотоков(ДлительныеОперацииСписок)
	
	ЗавершенныеЗадания = Новый Массив;
	Пока Истина Цикл
		
		Если ЗавершенныеЗадания.Количество() = ДлительныеОперацииСписок.Количество() Тогда 
			Прервать;
		КонецЕсли;
		
		
		Для Каждого ДлительнаяОперация из ДлительныеОперацииСписок Цикл 
			
			Если НЕ ЗавершенныеЗадания.Найти(ДлительнаяОперация) = Неопределено Тогда 
				Продолжить;
			КонецЕсли;
			
			
			Выполнено = Ложь;
			Попытка
				
				Выполнено = ДлительныеОперации.ЗаданиеВыполнено(ДлительнаяОперация.ИдентификаторЗадания);	
				
			Исключение
				// Завершенные аварийно задания помещаем как выполненные
				Выполнено = Истина;
			КонецПопытки;
			
			Если Выполнено Тогда 
				ЗавершенныеЗадания.Добавить(ДлительнаяОперация);
			КонецЕсли; 			
			
		КонецЦикла;
		
		ОбменДаннымиСервер.Пауза(5);
		
	КонецЦикла; 	
	
КонецПроцедуры

Функция НовыеПараметрыОтборов()
	
	Результат = Новый Структура;
	Результат.Вставить("ПериодНачисления"		, Дата(1,1,1));
	Результат.Вставить("Организация"			, Справочники.Организации.НашаОрганизация);
	Результат.Вставить("Район"					, Справочники.энргЗоныОтвественности.ПустаяСсылка());
	Результат.Вставить("МКД"					, Неопределено);
	Результат.Вставить("Абонент"				, Неопределено);
	Результат.Вставить("СписокМКД"				, Неопределено);
	
	Возврат Результат;	
	
КонецФункции

Функция ЗапуститьФоновоеЗаданиеСервер(ИдентификаторФормы, ПараметрыОтбора)
	
	НаименованиеФоновогоЗадания = НСтр(
		СтрШаблон(
			"ru = 'Восстановление взаиморасчетов %1 за %2'", 
			ПараметрыОтбора.Район,
			Формат(ПараметрыОтбора.ПериодНачисления, "ДФ='ММММ гггг'")));
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ПараметрыВыполнения.ЗапуститьНеВФоне = Ложь;
	ПараметрыВыполнения.ОжидатьЗавершение = 0; // запускать сразу
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеФоновогоЗадания;
	ПараметрыВыполнения.Вставить("ИдентификаторФормы", ИдентификаторФормы);
	
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения, 
		"энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты",
		
		ПараметрыОтбора);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

#КонецОбласти