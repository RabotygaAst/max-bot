		|ИЗ
		|	ВспомогательныеДанныеУслуг КАК ВспомогательныеДанныеУслуг
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияТарифов КАК ЗначенияТарифов
		|		ПО ВспомогательныеДанныеУслуг.Организация = ЗначенияТарифов.Организация
		|			И ВспомогательныеДанныеУслуг.Район = ЗначенияТарифов.Район
		|			И ВспомогательныеДанныеУслуг.ГруппаПотребителей = ЗначенияТарифов.ГруппаПотребителей
		|			И ВспомогательныеДанныеУслуг.Услуга = ЗначенияТарифов.Услуга
		|			И ВспомогательныеДанныеУслуг.Поставщик = ЗначенияТарифов.Поставщик
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияТекущихНормПотребления КАК ЗначенияТекущихНормПотребления
		|		ПО ВспомогательныеДанныеУслуг.Организация = ЗначенияТекущихНормПотребления.Организация
		|			И ВспомогательныеДанныеУслуг.Район = ЗначенияТекущихНормПотребления.Район
		|			И ВспомогательныеДанныеУслуг.Услуга = ЗначенияТекущихНормПотребления.Услуга
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТочкаУчета,
		|	Услуга");
	
КонецПроцедуры

Процедура ЗаполнитьСхемуЗначениеНормативов(Схема, Параметры) Экспорт 
	
	РегистрыСведений.энргТипСобственностиАбонентов.ТекстСрезПоследних(Схема, Параметры, "АктуальныйТипСобственности");
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	ВспомогательныеДанныеУслуг.Организация КАК Организация,
		|	ВспомогательныеДанныеУслуг.Район КАК Район,
		|	ВспомогательныеДанныеУслуг.КлючПомещения КАК КлючПомещения,
		|	ВспомогательныеДанныеУслуг.ТочкаУчета КАК ТочкаУчета,
		|	ВспомогательныеДанныеУслуг.Услуга КАК Услуга,
		|	НаправлениеИспользованияДействующихТочек.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
		|	ВспомогательныеДанныеУслуг.СоставнаяУслуга КАК СоставнаяУслуга,
		|	ВспомогательныеДанныеУслуг.ГруппаПотребителей КАК ГруппаПотребителей,
		|	ВспомогательныеДанныеУслуг.Поставщик КАК Поставщик,
		|	ВспомогательныеДанныеУслуг.ВидБлагоустройства КАК ВидБлагоустройства,
		|	энргКлючиПомещений.Строение КАК Строение,
		|	энргКлючиПомещений.Помещение КАК Помещение,
		|	АктуальныйТипСобственности.ТипСобственности КАК ВидСобственности,
		|	0 КАК ГодПостройки,
		|	&КоличествоКомнат КАК КоличествоКомнат,
		|	&КоличествоПроживающих КАК КоличествоПроживающих,
		|	&КоличествоПрописанных КАК КоличествоПрописанных,
		|	&КоличествоСобственников КАК КоличествоСобственников,
		|	0 КАК КоличествоЭтажей
		|ПОМЕСТИТЬ ВсеПараметрыРасчета
		|ИЗ
		|	ВспомогательныеДанныеУслуг КАК ВспомогательныеДанныеУслуг
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
		|		ПО ВспомогательныеДанныеУслуг.КлючПомещения = энргКлючиПомещений.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ АктуальныйТипСобственности КАК АктуальныйТипСобственности
		|		ПО ВспомогательныеДанныеУслуг.Организация = АктуальныйТипСобственности.Организация
		|			И ВспомогательныеДанныеУслуг.Район = АктуальныйТипСобственности.Район
		|			И ВспомогательныеДанныеУслуг.КлючПомещения = АктуальныйТипСобственности.КлючПомещения
		|		ЛЕВОЕ СОЕДИНЕНИЕ НаправлениеИспользованияДействующихТочек КАК НаправлениеИспользованияДействующихТочек
		|		ПО ВспомогательныеДанныеУслуг.Организация = НаправлениеИспользованияДействующихТочек.Организация
		|			И ВспомогательныеДанныеУслуг.Район = НаправлениеИспользованияДействующихТочек.Район
		|			И ВспомогательныеДанныеУслуг.КлючПомещения = НаправлениеИспользованияДействующихТочек.КлючПомещения
		|			И ВспомогательныеДанныеУслуг.ТочкаУчета = НаправлениеИспользованияДействующихТочек.ТочкаУчета");
	
	
	
	Текст = Схема.ПолучитьТекстЗапроса();
	Текст = Текст + ОбщегоНазначения.РазделительПакетаЗапросов();	
	Текст = Текст + Справочники.энргКлючиНормативов.ТекстОпределенияКлючейНорматива();	
	Текст = Текст + ОбщегоНазначения.РазделительПакетаЗапросов();
	
	Текст  = Текст +
	"ВЫБРАТЬ
	|	ВсеПараметрыРасчета.*,
	|	КлючиНорматива.КлючНорматива КАК КлючНорматива
	|ПОМЕСТИТЬ ВсеПараметрыРасчетаНорматив
	|ИЗ
	|	ВсеПараметрыРасчета КАК ВсеПараметрыРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ КлючиНорматива КАК КлючиНорматива
	|		ПО (ВсеПараметрыРасчета.Услуга = КлючиНорматива.Услуга)
	|		И КлючиНорматива.НаправлениеИспользованияТУ = ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление)";
	
	Схема = Новый СхемаЗапроса;
	Схема.УстановитьТекстЗапроса(Текст);	
	
	ПараметрыНормПотребления = ОбщегоНазначения.СкопироватьРекурсивно(Параметры);                                          	
	
	ПараметрыНормПотребления.ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("ТипНачисления", "ТипНачисления")));	
	СоответствиеПолей = Новый Структура(
		"НаправлениеИспользованияТУ,КлючНорматива,Услуга",
		"НаправлениеИспользованияТУ", "КлючНорматива", "Услуга");
	ОтборВТ = энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица("ВсеПараметрыРасчетаНорматив", СоответствиеПолей);
	ПараметрыНормПотребления.ПараметрыВТ.Добавить(ОтборВТ);	
	РегистрыСведений.энргЗначенияНормативовПотребления.ЗначенияТекущихНормПотребления(Схема, ПараметрыНормПотребления, "ЗначенияТекущихНормПотребления");
	
КонецПроцедуры

