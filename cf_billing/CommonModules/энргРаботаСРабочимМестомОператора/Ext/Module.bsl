
#Область СлужебныйПрограммныйИнтерфейс

Функция ЗаполнитьДанныеТочекУчета(ПоляАбонента, Знач ДеревоТочек, Знач ДеревоДанныхПоПУ, Знач ДеревоДанныхПоУслугам, Знач ТочкиУчета, Знач ШкалыПриборовУчета, Знач ПоказанияПриборовУчета)	Экспорт 
	Период = ПоляАбонента.ТекущаяДата;		
	РезультатПакеты = ДействующиеТочкиИИхПриборы(Период, ПоляАбонента);
	ОбщееКолво = РезультатПакеты.Количество();
	
	РезультатЗапроса = РезультатПакеты[ОбщееКолво-1];
	ПолучитьПоказанияПриборУчета(ПоляАбонента, РезультатЗапроса, ТочкиУчета, ШкалыПриборовУчета, ПоказанияПриборовУчета);
	
	ТаблицаПломб = РезультатПакеты[ОбщееКолво-2].Выгрузить();	
	
	СписокДеревьев = Новый Структура("ДеревоТочек, ДеревоДанныхПоПУ, ЕстьОРП", ДеревоТочек, ДеревоДанныхПоПУ, Ложь);
	ЗаполнитьДеревьяТочекИПриборовУчета(РезультатЗапроса, ТаблицаПломб, СписокДеревьев, ПоказанияПриборовУчета);
	
	РезультатЗапроса = РезультатПакеты[ОбщееКолво-4];
	ЗаполнитьДеревоДанныхПоУслугам(РезультатЗапроса, ДеревоДанныхПоУслугам);	
		
	Возврат Новый Структура("ДеревоТочек, ДеревоДанныхПоПУ, ДеревоДанныхПоУслугам, ЕстьОРП", ДеревоТочек, ДеревоДанныхПоПУ, ДеревоДанныхПоУслугам, СписокДеревьев.ЕстьОРП);
	
КонецФункции 

Функция РезультатЗапросаДанныеПомещения(Период, Организация, Район, КлючПомещения, Абонент) Экспорт
	
	СхемаЗапроса	= Неопределено;
	ПараметрыОтбора	= Новый Структура;
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Организация", "Организация"))); 
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Район", "Район"))); 
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("КлючПомещения", "КлючПомещения"))); 
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Абонент", "Абонент"))); 
	
	Если ЗначениеЗаполнено(Период) Тогда
		ПараметрыОтбора.Вставить("Период", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("Период"));
	КонецЕсли;
	ПараметрыОтбора.Вставить("ПараметрыВТ", ПараметрыВТ);	
	
	#Область ЗначенияПлощадей
	РегистрыСведений.энргЗначенияПлощадей.ЗначенияПлощадейПомещений(СхемаЗапроса, ПараметрыОтбора, "ЗначенияПлощадейПомещений");
	#КонецОбласти
	
	#Область КоличествоКомнат
	РегистрыСведений.энргКоличествоКомнат.ТекстСрезПоследних(СхемаЗапроса, ПараметрыОтбора, "КоличествоКомнат");
	#КонецОбласти
	
	#Область КоличествоПроживающих
	РегистрыСведений.энргКоличествоПроживающих.КоличествоПроживающихПомещения(СхемаЗапроса, ПараметрыОтбора, "КоличествоПроживающихПомещения");
	#КонецОбласти
	
	#Область КоличествоПрописанных
	РегистрыСведений.энргКоличествоПрописанных.КоличествоПрописанныхПомещения(СхемаЗапроса, ПараметрыОтбора, "КоличествоПрописанныхПомещения");
	#КонецОбласти 	
	
	#Область КоличествоСобственников
	РегистрыСведений.энргКоличествоСобственников.КоличествоСобственниковПомещения(СхемаЗапроса, ПараметрыОтбора, "КоличествоСобственниковПомещения");
	#КонецОбласти
	
	Пакет = СхемаЗапроса.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	КоличествоКомнат.КлючПомещения КАК КлючПомещения,
	|	КоличествоКомнат.Количество КАК КоличествоКомнат,
	|	0 КАК КоличествоПрописанных,
	|	0 КАК КоличествоПроживающих,
	|	0 КАК КоличествоСобственников
	|ПОМЕСТИТЬ ОбъединенныеДанные
	|ИЗ
	|	КоличествоКомнат КАК КоличествоКомнат
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КоличествоПрописанныхПомещения.КлючПомещения,
	|	0,
	|	КоличествоПрописанныхПомещения.Количество,
	|	0,
	|	0
	|ИЗ
	|	КоличествоПрописанныхПомещения КАК КоличествоПрописанныхПомещения
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КоличествоПроживающихПомещения.КлючПомещения,
	|	0,
	|	0,
	|	КоличествоПроживающихПомещения.Количество,
	|	0
	|ИЗ
	|	КоличествоПроживающихПомещения КАК КоличествоПроживающихПомещения
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КоличествоСобственниковПомещения.КлючПомещения,
	|	0,
	|	0,
	|	0,
	|	КоличествоСобственниковПомещения.Количество
	|ИЗ
	|	КоличествоСобственниковПомещения КАК КоличествоСобственниковПомещения");
	
	Пакет = СхемаЗапроса.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ОбъединенныеДанные.КлючПомещения КАК КлючПомещения,
	|	МАКСИМУМ(ОбъединенныеДанные.КоличествоКомнат) КАК КоличествоКомнат,
	|	МАКСИМУМ(ОбъединенныеДанные.КоличествоПрописанных) КАК КоличествоПрописанных,
	|	МАКСИМУМ(ОбъединенныеДанные.КоличествоПроживающих) КАК КоличествоПроживающих,
	|	МАКСИМУМ(ОбъединенныеДанные.КоличествоСобственников) КАК КоличествоСобственников
	|ИЗ
	|	ОбъединенныеДанные КАК ОбъединенныеДанные
	|
	|СГРУППИРОВАТЬ ПО
	|	ОбъединенныеДанные.КлючПомещения");
	
	Пакет = СхемаЗапроса.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ЗначенияПлощадейПомещений.ВидПлощади КАК ВидПлощади,
	|	ЗначенияПлощадейПомещений.Площадь КАК Значение
	|ИЗ
	|	ЗначенияПлощадейПомещений КАК ЗначенияПлощадейПомещений");
			
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Период"			, Период);
	ПараметрыЗапроса.Вставить("Организация"		, Организация);		
	ПараметрыЗапроса.Вставить("Район"			, Район);		
	ПараметрыЗапроса.Вставить("КлючПомещения"	, КлючПомещения);		
	ПараметрыЗапроса.Вставить("Абонент"			, Абонент);		
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьПакет(СхемаЗапроса, ПараметрыЗапроса);
	
	Возврат РезультатЗапроса;
	
КонецФункции

Функция ПолучитьДанныеОЛьготеАбонента(ПоляАбонента) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ДанныеОЛьготниках", Неопределено);
	
	РезультатЗапроса = ДанныеЛьготыАбонента(ПоляАбонента);
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Результат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	ОписаниеСостояния = Новый Структура("СостояниеЛьготника, ДатаСостоянияЛьготника", Выборка.Состояние, Выборка.Период);	
	Результат.ДанныеОЛьготниках = ОписаниеСостояния;
	
	Возврат Результат;
	
КонецФункции  

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РаботаСВкладкойДанныеТочекУчета


#Область РаботаСДеревомТочекУчета

Процедура ЗаполнитьДеревьяТочекИПриборовУчета(РезультатЗапроса, ТаблицаПломб, СписокДеревьев, ПоказанияПриборовУчета)
	
	ТаблицаТочек = РезультатЗапроса.Выгрузить();	
	КоллекцияДанныхТУ = СписокДеревьев.ДеревоТочек.Строки;
	КоллекцияДанныхПУ = СписокДеревьев.ДеревоДанныхПоПУ.Строки;
	
	ПриборЗаполнен 	 = Ложь;
	ТекТочкаУчета 	 = Неопределено;
	ТекШкала 		 = Неопределено;
	СтрокаДереваПУ   = Неопределено; 	
	СтрокаДанныхШкал = Неопределено;
	
	ВспомогательныеПараметрыТУ = Новый Структура("СостояниеОРП, ТекстОРП, ЕстьОРП", Перечисления.энргСостояниеТочекУчета.ОРП, "ВведеноОРП", СписокДеревьев.ЕстьОРП);
	ОтборСтрокПломб		= Новый Структура("ПриборУчета");
	ОтборСтрокПоказаний = Новый Структура("ПриборУчета,Шкала,ТарифнаяЗона");	
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() цикл
	
		
			Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			
			Если НЕ ЗначениеЗаполнено(Выборка.РодительТочкиУчета) Тогда				
				ДобавитьСтрокуТочкиУчета(Выборка, ТаблицаТочек, КоллекцияДанныхТУ, ВспомогательныеПараметрыТУ);
				СписокДеревьев.ЕстьОРП = ВспомогательныеПараметрыТУ.ЕстьОРП;
			КонецЕсли;
			
			ПриборЗаполнен = ЗначениеЗаполнено(Выборка.ПриборУчета);
			
			Если ПриборЗаполнен Тогда				
				СтрокаДереваПУ = КоллекцияДанныхПУ.Добавить();
				ДобавитьСтрокуПрибораУчета(Выборка, СтрокаДереваПУ);
				
				ДополнитьПломбыПрибораУчета(Выборка, СтрокаДереваПУ, ТаблицаПломб, ОтборСтрокПломб);							
				
				УровеньДанныхШкал 				= СтрокаДереваПУ.Строки;
				СтрокаДанныхПоказаний  			= УровеньДанныхШкал.Добавить();
				СтрокаДанныхПоказаний.Значение1 = "Данные показаний";
				
			КонецЕсли;
			
		КонецЕсли; 		
		
		Если ПриборЗаполнен Тогда 
			
			Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета ИЛИ НЕ ТекШкала = Выборка.Шкала Тогда				
				НоваяСтрокаШкалы = ДобавитьСтрокуШкалыПрибораУчета(Выборка, СтрокаДанныхПоказаний);				
			КонецЕсли;
			
			ДобавитьСтрокуТарифнойЗоныПрибораУчета(Выборка, НоваяСтрокаШкалы, ПоказанияПриборовУчета, ОтборСтрокПоказаний);
			
		КонецЕсли;	
		
		ТекТочкаУчета 	= Выборка.ТочкаУчета;
		ТекШкала 		= Выборка.Шкала;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьСтрокуТочкиУчета(Выборка, ТаблицаТочек, КоллекцияЭлементовДерева, ВспомогательныеПараметрыТУ)
	
	ЭлементДерева = КоллекцияЭлементовДерева.Добавить();	
	ЗаполнитьЗначенияСвойств(ЭлементДерева, Выборка);
	
	Если ВспомогательныеПараметрыТУ.СостояниеОРП = Выборка.СостояниеТочкиУчета Тогда 
		ЭлементДерева.СлужебноеПоле = ВспомогательныеПараметрыТУ.ТекстОРП;
		ВспомогательныеПараметрыТУ.ЕстьОРП = Истина; 
	КонецЕсли;
	
	ОтборСтрок = Новый Структура("РодительТочкиУчета", Выборка.ТочкаУчета);
	ПодчиненныеТочки = ТаблицаТочек.НайтиСтроки(ОтборСтрок);
	Для Каждого Строка Из ПодчиненныеТочки Цикл		
		ДобавитьСтрокуТочкиУчета(Строка, ТаблицаТочек, ЭлементДерева.Строки, ВспомогательныеПараметрыТУ);		
	КонецЦикла;
		
КонецПроцедуры

#КонецОбласти

#Область РаботаСДеревомПриборовУчета

Процедура ДобавитьСтрокуПрибораУчета(Выборка, УровеньПрибораУчета) 	
	
	УровеньПрибораУчета.ПриборУчета = Выборка.ПриборУчета;
	
	УровеньОбщихДанных = УровеньПрибораУчета.Строки;
	СтрокаОбщихДанных = УровеньОбщихДанных.Добавить();
	СтрокаОбщихДанных.Значение1 = "Общие данные";
	
	УровеньДанныхПрибора = СтрокаОбщихДанных.Строки;
	ДобавитьОбщиеДанныеПрибораУчета(УровеньДанныхПрибора, Выборка); 		
		
КонецПроцедуры

Процедура ДобавитьОбщиеДанныеПрибораУчета(УровеньДанныхПрибора, Выборка)
	
	ДобавитьЗаводскойНомер(УровеньДанныхПрибора, Выборка);
	ДобавитьТипПрибораУчета(УровеньДанныхПрибора, Выборка);
	ДобавитьДатаПоверки(УровеньДанныхПрибора, Выборка);
	ДобавитьРегистрируетОбъем(УровеньДанныхПрибора, Выборка);  	
	
КонецПроцедуры

Процедура ДобавитьЗаводскойНомер(УровеньДанныхПрибора, Выборка)
	
	НоваяСтрока = УровеньДанныхПрибора.Добавить();
	НоваяСтрока.Значение1 = "Заводской номер";
	НоваяСтрока.Значение2 = Выборка.ЗаводскойНомер;
	
КонецПроцедуры

Процедура ДобавитьТипПрибораУчета(УровеньДанныхПрибора, Выборка)
	
	НоваяСтрока = УровеньДанныхПрибора.Добавить();
	НоваяСтрока.Значение1 = "Тип прибора учета";
	НоваяСтрока.Значение2 = Выборка.ТипПрибораУчета;
	
КонецПроцедуры

Процедура ДобавитьДатаПоверки(УровеньДанныхПрибора, Выборка)
	
	НоваяСтрока = УровеньДанныхПрибора.Добавить();
	НоваяСтрока.Значение1 = "Дата поверки счетчика";
	НоваяСтрока.Значение2 = Формат(Выборка.ДатаПоверки, "ДФ=dd.MM.yyyy");
	НоваяСтрока.Значение3 = ПолучитьСтатусНеобходимостиПоверки(Выборка);
	
КонецПроцедуры

Процедура ДобавитьРегистрируетОбъем(УровеньДанныхПрибора, Выборка)
	
	НоваяСтрока = УровеньДанныхПрибора.Добавить();
	НоваяСтрока.Значение1 = "Регистриует объем";
	НоваяСтрока.Значение2 = Выборка.РегистрируетОбъем;
	
КонецПроцедуры


Функция ДобавитьСтрокуШкалыПрибораУчета(Выборка, НачальныйУровень)
	
	УровеньДеталей = НачальныйУровень.Строки;
	НоваяСтрока = УровеньДеталей.Добавить();
	НоваяСтрока.Значение1 = Выборка.Шкала;
	
	Возврат НоваяСтрока;
	
КонецФункции

#КонецОбласти

#Область РаботаСПоказаниямиПриборовУчета

Процедура ПолучитьПоказанияПриборУчета(ПоляАбонента, Результат, ТочкиУчета, ШкалыПриборовУчета, ПоказанияПриборовУчета)
	
	Период 				= ПоляАбонента.ТекущаяДата;
	Организация 		= ПоляАбонента.Организация;
	Район 				= ПоляАбонента.Район;
	КлючПомещения 		= ПоляАбонента.КлючПомещения;	
	
	Выборка  										= Результат.выбрать();
	ТекТочкаУчета 									= Неопределено;
	ТекШкала 										= Неопределено;
	IDСтрокиТочки 									= Неопределено;
	IDСтрокиШкалы 									= Неопределено;
	НомерСтроки  									= 1;
	НомерСтрокиПоФормуле 							= 0;
	Пока Выборка.Следующий() цикл
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда  			
			СтрокаТочкиУчета  								= ТочкиУчета.Добавить();
			IDСтрокиТочки 									= Новый УникальныйИдентификатор;
			СтрокаТочкиУчета.IDСтроки 						= IDСтрокиТочки;
			СтрокаТочкиУчета.ТочкаУчета 					= Выборка.ТочкаУчета;			
			СтрокаТочкиУчета.Услуга 						= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 					= Выборка.ПриборУчета;
			СтрокаТочкиУчета.НаправлениеИспользованияТУ 	= Выборка.НаправлениеИспользованияТУ;
			СтрокаТочкиУчета.РасчетПоФормуле 				= Выборка.РасчетПоФормуле;			
			СтрокаТочкиУчета.НомерПломбы					= Выборка.НомерПломбы;
			СтрокаТочкиУчета.ДатаПоверки  					= Выборка.ДатаПоверки;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) Тогда
			Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета ИЛИ НЕ ТекШкала = Выборка.Шкала Тогда
				СтрокаШкалы  						= ШкалыПриборовУчета.Добавить();
				IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
				СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
				СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
				СтрокаШкалы.Шкала 					= Выборка.Шкала;
				СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
			КонецЕсли;
			
			СтрокаПоказаний 						= ПоказанияПриборовУчета.Добавить();
			СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
			СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
			СтрокаПоказаний.НомерСтроки 			= НомерСтроки;
			НомерСтроки 							= НомерСтроки + 1;
		КонецЕсли;
		
		ТекТочкаУчета 								= Выборка.ТочкаУчета;
		ТекШкала 									= Выборка.Шкала;
	КонецЦикла; 
	
	ТаблицаПоказанийДляЗаполнения 		= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Организация, ТочкиУчета, ШкалыПриборовУчета, ПоказанияПриборовУчета, Район, КлючПомещения); 
	РезультатДанныеЗаполненияПоказаний 	= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Организация, Район, ТаблицаПоказанийДляЗаполнения, Период);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний, ТаблицаПоказанийДляЗаполнения, ПоказанияПриборовУчета);	
		
КонецПроцедуры

Процедура ДобавитьСтрокуТарифнойЗоныПрибораУчета(Выборка, НачальныйУровень, ПоказанияПриборовУчета, ОтборСтрокПоказаний)
	
	ОтборСтрокПоказаний.ПриборУчета = Выборка.ПриборУчета;
	ОтборСтрокПоказаний.Шкала = Выборка.Шкала;
	ОтборСтрокПоказаний.ТарифнаяЗона = Выборка.ТарифнаяЗона; 			
	ДанныеПоказаний = ПоказанияПриборовУчета.НайтиСтроки(ОтборСтрокПоказаний);
	
	Если ДанныеПоказаний.Количество() > 0 Тогда 
		СтрокаПредыдущихПоказаний = ДанныеПоказаний[0];
	Иначе 
		СтрокаПредыдущихПоказаний = Новый Структура("ПредыдущиеПоказания, ДатаПоследнихПоказаний", 0, "");
	КонецЕсли;
		
	УровеньШкал = НачальныйУровень.Строки;
	НоваяСтрокаТарифнойЗоны = УровеньШкал.Добавить();
	НоваяСтрокаТарифнойЗоны.Значение1 = Выборка.ТарифнаяЗона;
	
	УровеньТарифнойЗоны = НоваяСтрокаТарифнойЗоны.Строки;
	НоваяСтрока = УровеньТарифнойЗоны.Добавить();
	НоваяСтрока.Значение1 = "Последние показания";
	НоваяСтрока.Значение2 = Формат(СтрокаПредыдущихПоказаний.ПредыдущиеПоказания, "ЧДЦ=6"); 
	
	НоваяСтрока = УровеньТарифнойЗоны.Добавить();
	НоваяСтрока.Значение1 = "Дата последних показаний";
	НоваяСтрока.Значение2 = СтрокаПредыдущихПоказаний.ДатаПоследнихПоказаний;	
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСДеревомДанныхПоУслугам

Процедура ЗаполнитьДеревоДанныхПоУслугам(РезультатЗапроса, ДеревоДанныхПоУслугам)
	
	КоллекцияСтрокВерхнегоУровня = ДеревоДанныхПоУслугам.Строки;

	СтрокаТочкиУчета 	= Неопределено;
	ТекТочкаУчета 		= Неопределено;
	ТекУслуга 			= Неопределено;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() цикл
		
		НоваяТочка = НЕ ТекТочкаУчета = Выборка.ТочкаУчета;
		Если НоваяТочка Тогда 
			СтрокаТочкиУчета = КоллекцияСтрокВерхнегоУровня.Добавить();
			СтрокаТочкиУчета.ТочкаУчета = Выборка.ТочкаУчета;
		КонецЕсли;		
		
		Если НоваяТочка или НЕ ТекУслуга = Выборка.Услуга Тогда 
			
			КоллекцияПодчиненныхСтрокТУ = СтрокаТочкиУчета.Строки;
			УровеньУслуги = КоллекцияПодчиненныхСтрокТУ.Добавить();
			УровеньУслуги.Услуга = Выборка.Услуга;
			
			КоллекцияСтрокУслуги = УровеньУслуги.Строки;
			СтрокаДетализации = КоллекцияСтрокУслуги.Добавить();
			СтрокаДетализации.Услуга = "Поставщик";
			СтрокаДетализации.Значение1 = Выборка.Поставщик;
			
			СтрокаДетализации = КоллекцияСтрокУслуги.Добавить();
			СтрокаДетализации.Услуга = "Вид благоустройства";
			СтрокаДетализации.Значение1 = Выборка.ВидБлагоустройства;			
			
			СтрокаДетализации = КоллекцияСтрокУслуги.Добавить();
			СтрокаДетализации.Услуга = "Тарифная категория";
			СтрокаДетализации.Значение1 = Выборка.ГруппаПотребителей;
			
			СтрокаДетализации = КоллекцияСтрокУслуги.Добавить();
			СтрокаДетализации.Услуга = "Норма потребления";
			СтрокаДетализации.Значение1 = Формат(Выборка.ЗначениеНорматива, "ЧДЦ=6");
			
			// Значения тарифов
			СтрокаГруппыЗначениеТарифа = КоллекцияСтрокУслуги.Добавить();
			СтрокаГруппыЗначениеТарифа.Услуга = "Значение тарифа";
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ТарифнаяЗона) Тогда			
			КоллекцияПодчиненныхСтрокЗначениеТарифа = СтрокаГруппыЗначениеТарифа.Строки;
			СтрокаДетализации = КоллекцияПодчиненныхСтрокЗначениеТарифа.Добавить();
			СтрокаДетализации.Услуга 	= Выборка.ТарифнаяЗона;
			СтрокаДетализации.Значение1 = Выборка.ЗначениеТарифа;
		КонецЕсли;		
		
		ТекТочкаУчета = Выборка.ТочкаУчета;
		ТекУслуга = Выборка.Услуга;
		
	КонецЦикла;
	
КонецПроцедуры
	
#КонецОбласти

#Область РаботаСПломбамиПриборвУчета

Процедура ДополнитьПломбыПрибораУчета(Выборка, СтрокаДереваПУ, ТаблицаПломб, ОтборСтрокПломб)
	
	ОтборСтрокПломб.ПриборУчета = Выборка.ПриборУчета; 
	СтрокиПломб 				= ТаблицаПломб.НайтиСтроки(ОтборСтрокПломб);
	
	Если СтрокиПломб.Количество() > 0 Тогда
		
		КоллекцияВложенностиПУ = СтрокаДереваПУ.Строки;
		УровеньДанныхПломб = КоллекцияВложенностиПУ.Добавить();
		УровеньДанныхПломб.Значение1 = "Данные пломб"; 				
		
		Для Каждого Строка Из СтрокиПломб Цикл		
			ДобавитьСтрокуПломбы(Строка, УровеньДанныхПломб);		
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьСтрокуПломбы(Выборка, НачальныйУровень)
	
	УровеньТарифнойЗоны = НачальныйУровень.Строки;
	НоваяСтрока = УровеньТарифнойЗоны.Добавить();
	НоваяСтрока.Значение1 = "Место установки пломбы";
	НоваяСтрока.Значение2 = Выборка.МестоУстановки;
	
	НоваяСтрока = УровеньТарифнойЗоны.Добавить();
	НоваяСтрока.Значение1 = "Дата установки пломбы";
	НоваяСтрока.Значение2 = Формат(Выборка.Период, "ДФ=dd.MM.yyyy");
	
	НоваяСтрока = УровеньТарифнойЗоны.Добавить();
	НоваяСтрока.Значение1 = "Номер пломбы";
	НоваяСтрока.Значение2 = Выборка.НомерПломбы;
	
КонецПроцедуры
	
#КонецОбласти


#Область ПолучениеДанных

Функция ДействующиеТочкиИИхПриборы(Период, ПоляАбонента) 
	
	Схема		= Неопределено;
	Параметры	= Новый Структура;
	ПараметрыВТ = Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация"		, "Организация")	, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район"			, "Район")			, Неопределено));	
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения"	, "КлючПомещения")	, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("АбонентВладелец"	, "КлючПомещения")	, Неопределено));
		
	Параметры.Вставить("Период"		, Новый Структура("ИмяПараметра,ТипПараметра", "Период" ,"ТипПараметраГраницаИсключая"));
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);
	Параметры.Вставить("ВключаяОРП"	, Истина);
	
	ЗаполнитьСхемуДействующиеТочкиИИхПриборы(Схема, Параметры);
	ЗаполнитьСхемуДополнительныеДанныеУслуг(Схема, Параметры);
	
	// Пломбы исключены т.к их может быть несколько на прибор
	РегистрыСведений.энргНомерПломбПриборовУчета.НомераПломбВведенныхПриборовДействующихТочек(Схема, Параметры, "");
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	&Период КАК ТекущаяДата,
		|	ДанныеПоПриборамИтог.Организация КАК Организация,
		|	ДанныеПоПриборамИтог.Район КАК Район,
		|	ДанныеПоПриборамИтог.КлючПомещения КАК КлючПомещения,
		|	ДанныеПоПриборамИтог.ТочкаУчета КАК ТочкаУчета,
		|	ДанныеПоПриборамИтог.СостояниеТочкиУчета КАК СостояниеТочкиУчета,
		|	ДанныеПоПриборамИтог.ПриборУчета КАК ПриборУчета,
		|	ДанныеПоПриборамИтог.ЗаводскойНомер КАК ЗаводскойНомер,
		|	ДанныеПоПриборамИтог.ТипПрибораУчета КАК ТипПрибораУчета,
		|	ДанныеПоПриборамИтог.РодительТочкиУчета КАК РодительТочкиУчета,
		|	ДанныеПоПриборамИтог.Шкала КАК Шкала,
		|	ДанныеПоПриборамИтог.Услуга КАК Услуга,
		|	ДанныеПоПриборамИтог.Техническая КАК Техническая,
		|	ДанныеПоПриборамИтог.РегистрируетОбъем КАК РегистрируетОбъем,
		|	ДанныеПоПриборамИтог.ВидДифференцированности КАК ВидДифференцированности,
		|	ДанныеПоПриборамИтог.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
		|	ДанныеПоПриборамИтог.РасчетПоФормуле КАК РасчетПоФормуле,
		|   ДанныеПоПриборамИтог.ПрименятьФормулуВсегда КАК ПрименятьФормулуВсегда,
		|	ДанныеПоПриборамИтог.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ДанныеПоПриборамИтог.НомерПломбы КАК НомерПломбы,
		|	ДанныеПоПриборамИтог.ДатаПоверки КАК ДатаПоверки,
		|	ДанныеПоПриборамИтог.СоставнаяУслуга КАК СоставнаяУслуга,
		|	ДанныеПоПриборамИтог.НетВозможностьУстановкиПУ КАК НетВозможностьУстановкиПУ,
		|	ДанныеПоПриборамИтог.РасчетТолькоПоПоказаниям КАК РасчетТолькоПоПоказаниям,
		|	ДанныеПоПриборамИтог.СтруктураСети КАК СтруктураСети,
		|	ДанныеПоПриборамИтог.Абонент КАК Абонент,
		|	ВЫБОР
		|		КОГДА ДанныеПоПриборамИтог.СостояниеТочкиУчета = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.ОРП)
		|			ТОГДА ДанныеПоПриборамИтог.ПериодСостоянияТУ
		|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
		|	КОНЕЦ КАК ПериодСостоянияТУ
		|ИЗ
		|	ДанныеПоПриборамИтог КАК ДанныеПоПриборамИтог
		|
		|УПОРЯДОЧИТЬ ПО
		|	Организация,
		|	Район,
		|	КлючПомещения,
		|	РодительТочкиУчета,
		|	ТочкаУчета,
		|	Шкала");	
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Период",					Период);
	ПараметрыЗапроса.Вставить("МоментВремени",			Период);
	ПараметрыЗапроса.Вставить("ТипНачисления",			Перечисления.энргТипыНачислений.ИндивидуальныеНачисления);
	ПараметрыЗапроса.Вставить("Район",					ПоляАбонента.Район);
	ПараметрыЗапроса.Вставить("Организация",			ПоляАбонента.Организация);
	ПараметрыЗапроса.Вставить("КлючПомещения",			ПоляАбонента.КлючПомещения);	
	ПараметрыЗапроса.Вставить("КоличествоКомнат",		ПоляАбонента.КоличествоКомнат);
	ПараметрыЗапроса.Вставить("КоличествоПроживающих",	ПоляАбонента.КоличествоПроживающих);
	ПараметрыЗапроса.Вставить("КоличествоПрописанных",	ПоляАбонента.КоличествоПрописанных);
	ПараметрыЗапроса.Вставить("КоличествоСобственников",ПоляАбонента.КоличествоСобственников);
	
	МВТ = Новый МенеджерВременныхТаблиц;
	Возврат энргСхемаЗапросаСервер.ВыполнитьПакет(Схема, ПараметрыЗапроса, МВТ);
			
КонецФункции

Процедура ЗаполнитьСхемуДействующиеТочкиИИхПриборы(Схема, Параметры) 
	РегистрыСведений.энргСостояниеПриборовУчетаАбонента.ДействующиеПриборыУчетаПомещения(Схема, Параметры, "ДействующиеПриборыУчетаПомещения");
	РегистрыСведений.энргУслугиТочекУчета.УслугиДействующихТочек(Схема, Параметры, "УслугиДействующихТочек");
	РегистрыСведений.энргНаправлениеИспользованияТочекУчета.НаправлениеИспользованияДействующихТочек(Схема, Параметры, "НаправлениеИспользованияДействующихТочек");
	РегистрыСведений.бестТУНаСтруктуреСети.СтруктураСетиТочкиУчета(Схема, Параметры, "АктуальнаяСтруктураСетиТочкиУчета");
	РегистрыСведений.энргВидыДифференцированностиПриборовУчета.ВидДифференцированностиВведенныхПриборов(Схема, Параметры, "ВидДифференцированностиВведенныхПриборов");
	РегистрыСведений.энргРасчетныеСпособыТочекУчета.ДействующиеТочкиТочкиПоФормуле(Схема, Параметры, "ДействующиеТочкиТочкиПоФормуле");	
	РегистрыСведений.энргДатыПоверкиПрибораУчета.ДатыПоверокДействующихПриборовУчета(Схема, Параметры, "ДатыПоверкиВведенныхПриборовДействующихТочек");
	РегистрыСведений.энргРодительТочкиУчета.АктуальныеРодителиТочекУчета(Схема, Параметры, "АктуальныеРодителиТочекУчета");
	РегистрыСведений.энргТехническаяВозможностьУстановкиПУ.ТехническаяВозможностьУстановкиПУТочекУчета(Схема, Параметры, "ТехническаяВозможностьУстановкиПУТочекУчета");
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВложенныйЗапрос.Организация КАК Организация,
		|	ВложенныйЗапрос.Район КАК Район,
		|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
