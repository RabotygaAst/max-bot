	ОтборВТ = энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица("ДетализацияУслуг", СоответствиеПолей);
	ПараметрыУслуг.ПараметрыВТ.Добавить(ОтборВТ);
	
	РегистрыСведений.энргГруппыПотребителейАбонентов.ГруппыПотребителейАбонентов(Схема, ПараметрыУслуг, "ГруппыПотребителейАбонентов");
	РегистрыСведений.энргПоставщикиУслугАбонента.ПоставщикиУслугАбонента(Схема, ПараметрыУслуг, "ПоставщикиУслугАбонента");
	РегистрыСведений.энргВидБлагоустройствАбонента.АктуальныеВидыБлагоустройств(Схема, ПараметрыУслуг, "АктуальныеВидыБлагоустройств");
		
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	ДетализацияУслуг.Организация КАК Организация,
		|	ДетализацияУслуг.Район КАК Район,
		|	ДетализацияУслуг.КлючПомещения КАК КлючПомещения,
		|	ДетализацияУслуг.ТочкаУчета КАК ТочкаУчета,
		|	ДетализацияУслуг.Услуга КАК Услуга,
		|	ДетализацияУслуг.СоставнаяУслуга КАК СоставнаяУслуга,
		|	ГруппыПотребителейАбонентов.ГруппаПотребителей КАК ГруппаПотребителей,
		|	ПоставщикиУслугАбонента.Поставщик КАК Поставщик,
		|	АктуальныеВидыБлагоустройств.ВидБлагоустройства КАК ВидБлагоустройства
		|ПОМЕСТИТЬ ВспомогательныеДанныеУслуг
		|ИЗ
		|	ДетализацияУслуг КАК ДетализацияУслуг
		|		ЛЕВОЕ СОЕДИНЕНИЕ ГруппыПотребителейАбонентов КАК ГруппыПотребителейАбонентов
		|		ПО ДетализацияУслуг.Организация = ГруппыПотребителейАбонентов.Организация
		|			И ДетализацияУслуг.Район = ГруппыПотребителейАбонентов.Район
		|			И ДетализацияУслуг.КлючПомещения = ГруппыПотребителейАбонентов.КлючПомещения
		|			И ДетализацияУслуг.Услуга = ГруппыПотребителейАбонентов.Услуга
		|		ЛЕВОЕ СОЕДИНЕНИЕ ПоставщикиУслугАбонента КАК ПоставщикиУслугАбонента
		|		ПО ДетализацияУслуг.Организация = ПоставщикиУслугАбонента.Организация
		|			И ДетализацияУслуг.Район = ПоставщикиУслугАбонента.Район
		|			И ДетализацияУслуг.КлючПомещения = ПоставщикиУслугАбонента.КлючПомещения
		|			И ДетализацияУслуг.ТочкаУчета = ПоставщикиУслугАбонента.ТочкаУчета
		|			И ДетализацияУслуг.Услуга = ПоставщикиУслугАбонента.Услуга
		|			И ДетализацияУслуг.ЧастьСоставной = ПоставщикиУслугАбонента.ЧастьСоставной
		|		ЛЕВОЕ СОЕДИНЕНИЕ АктуальныеВидыБлагоустройств КАК АктуальныеВидыБлагоустройств
		|		ПО ДетализацияУслуг.Организация = АктуальныеВидыБлагоустройств.Организация
		|			И ДетализацияУслуг.Район = АктуальныеВидыБлагоустройств.Район
		|			И ДетализацияУслуг.КлючПомещения = АктуальныеВидыБлагоустройств.КлючПомещения
		|			И ДетализацияУслуг.Услуга = АктуальныеВидыБлагоустройств.Услуга");
	
	
	ЗаполнитьСхемуЗначениеНормативов(Схема, Параметры);
	
	ПараметрыЗначенияТарифов = ОбщегоНазначения.СкопироватьРекурсивно(Параметры);
	СоответствиеПолей = Новый Структура(
		"Организация,Район,ГруппаПотребителей,Услуга,Поставщик",
		"Организация", "Район", "ГруппаПотребителей", "Услуга", "Поставщик");
	ОтборВТ = энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица("ВспомогательныеДанныеУслуг", СоответствиеПолей);
	ПараметрыЗначенияТарифов.ПараметрыВТ.Добавить(ОтборВТ);
	РегистрыСведений.энргЗначенияТарифов.ЗначенияТарифов(Схема, ПараметрыЗначенияТарифов, "ЗначенияТарифов"); 
	
	
