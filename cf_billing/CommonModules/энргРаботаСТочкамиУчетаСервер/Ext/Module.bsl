&НаСервере
Функция УслугиМКД(Организация, Район, МКД, Период = '0001-01-01') Экспорт 
	
	Текст = 
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаМКД
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И МКД = &МКД
	|				И Район = &Район) КАК энргАктивностьТочекУчетаМКДСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ТочкиУчетаМКД
	|ИЗ
	|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаМКД.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаМКД КАК АктивныеТочкиУчетаМКД)) КАК энргВладельцыТочекУчетаСрезПоследних
	|ГДЕ
	|	энргВладельцыТочекУчетаСрезПоследних.АбонентВладелец = &МКД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктивныеТочкиУчетаМКД.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ДействующиеТочкиУчета
	|ИЗ
	|	АктивныеТочкиУчетаМКД КАК АктивныеТочкиУчетаМКД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТочкиУчетаМКД КАК ТочкиУчетаМКД
	|		ПО АктивныеТочкиУчетаМКД.ТочкаУчета = ТочкиУчетаМКД.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	энргУслугиТочекУчетаМКДСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ УслугиМКД
	|ИЗ
	|	ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргУслугиТочекУчетаМКД.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И МКД = &МКД
	|					И Район = &Район
	|					И ТочкаУчета В
	|						(ВЫБРАТЬ
	|							ДействующиеТочкиУчета.ТочкаУчета КАК ТочкаУчета
	|						ИЗ
	|							ДействующиеТочкиУчета КАК ДействующиеТочкиУчета)) КАК энргУслугиТочекУчетаМКДСрезПоследних
	|		ПО ДействующиеТочкиУчета.ТочкаУчета = энргУслугиТочекУчетаМКДСрезПоследних.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	энргСтроенияВидыБлагоустройстваТарифныеКатегории.ВидБлагоустройстваИндивидуальный КАК ВидБлагоустройства,
	|	энргСтроенияВидыБлагоустройстваТарифныеКатегории.ТарифнаяКатегория КАК ТарифнаяКатегория
	|ИЗ
	|	(ВЫБРАТЬ
	|		УслугиМКД.Услуга КАК Услуга
	|	ИЗ
	|		УслугиМКД КАК УслугиМКД
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|			ПО УслугиМКД.Услуга = энргВидыУслуг.Ссылка
	|				И (НЕ энргВидыУслуг.СоставнаяУслуга)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		энргВидыУслугСоставляющиеУслуг.Услуга
	|	ИЗ
	|		УслугиМКД КАК УслугиМКД
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|			ПО УслугиМКД.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргСтроения.ВидыБлагоустройстваТарифныеКатегории КАК энргСтроенияВидыБлагоустройстваТарифныеКатегории
	|		ПО ВложенныйЗапрос.Услуга = энргСтроенияВидыБлагоустройстваТарифныеКатегории.Услуга
	|			И (энргСтроенияВидыБлагоустройстваТарифныеКатегории.Ссылка = &МКД)";
	
	Запрос 				= Новый Запрос(Текст); 		
	Запрос.УстановитьПараметр("Организация"	,Организация);
	Запрос.УстановитьПараметр("Район"		,Район);
	Запрос.УстановитьПараметр("МКД"			,МКД);
	Запрос.УстановитьПараметр("Период"		,Период);
	
	УслугиМКД  			= Новый Соответствие;
	
	Результат		 	= Запрос.Выполнить();
	Выборка  			= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		УслугиМКД.Вставить(Выборка.Услуга, Новый Структура("ВидБлагоустройства, ТарифнаяКатегория", Выборка.ВидБлагоустройства, Выборка.ТарифнаяКатегория));
	КонецЦикла;
	
	Возврат УслугиМКД;
	
КонецФункции

Процедура УстановитьТУМКДНаСтруктуруСети(ДанныеШапки,Движения,ИмяКоллекции) Экспорт
	Набор  							= Движения.энргТУМКДНаСтруктуреСети;
	для Каждого стр из ДанныеШапки[ИмяКоллекции] цикл
		Запись  					= Набор.добавить();
		Запись.Период  				= ДанныеШапки.Дата;
		Запись.Организация 			= ДанныеШапки.Организация;
		Запись.Район 				= ДанныеШапки.Район;
		Запись.Строение		 		= ДанныеШапки.МКД;
		Запись.ТочкаУчета 			= стр.ТочкаУчета;
		Запись.СтруктураСети		= стр.СтруктураСети;
		Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
		Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления; 
	КонецЦикла; 
КонецПроцедуры

