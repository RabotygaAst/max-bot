Процедура ДополнитьТаблицыВВходныеДанныеСредствИзмерений(Объект, СредстваИзмерений, IDСтроки) Экспорт 
	СредстваИзмерений.Измерители 				= ОбщегоНазначения.ТаблицаЗначенийВМассив(Объект.Измерители.Выгрузить(Новый Структура("IDСтрокиТочкиУчета", IDСтроки)));
	СредстваИзмерений.ШкалыПриборовУчета 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(Объект.ШкалыПриборовУчета.Выгрузить(Новый Структура("IDСтрокиТочкиУчета", IDСтроки)));
	СредстваИзмерений.ПоказанияПриборовУчета 	= ОбщегоНазначения.ТаблицаЗначенийВМассив(Объект.ПоказанияПриборовУчета.Выгрузить(Новый Структура("IDСтрокиТочкиУчета", IDСтроки)));	
	СредстваИзмерений.ШкалыИзмерителей 			= ОбщегоНазначения.ТаблицаЗначенийВМассив(Объект.ШкалыИзмерителей.Выгрузить(Новый Структура("IDСтрокиТочкиУчета", IDСтроки)));
	СредстваИзмерений.НомераПломб 				= ОбщегоНазначения.ТаблицаЗначенийВМассив(Объект.НомераПломб.Выгрузить(Новый Структура("IDСтрокиТочкиУчета", IDСтроки)));
	Если Объект.Свойство("ФормулыРасчетаУслуг") Тогда
		СредстваИзмерений.ФормулыРасчетаУслуг 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(Объект.ФормулыРасчетаУслуг.Выгрузить(Новый Структура("IDСтрокиТочкиУчета", IDСтроки)));
	Иначе
		СредстваИзмерений.ФормулыРасчетаУслуг 		= Новый Массив;
	КонецЕсли;
КонецПроцедуры

// Обработка результата

Процедура ЗаполнитьДанныеТаблицРезультатаСредствИзмерений(Объект, IDСтрокиТочкиУчета, Результат, ДанныеПУ, ДанныеОчистки = Неопределено) Экспорт 
	
	
	ДополнитьТаблицуПоID(Объект.Измерители				, Результат.Измерители				, IDСтрокиТочкиУчета	, ДанныеПУ, ?(ДанныеОчистки <> Неопределено И ДанныеОчистки.Свойство("Измерители"),ДанныеОчистки.Измерители,Неопределено));
	ДополнитьТаблицуПоID(Объект.ШкалыПриборовУчета		, Результат.ШкалыПриборовУчета		, IDСтрокиТочкиУчета,,?(ДанныеОчистки <> Неопределено И ДанныеОчистки.Свойство("ШкалыПриборовУчета"),ДанныеОчистки.ШкалыПриборовУчета,Неопределено));
	ДополнитьТаблицуПоID(Объект.ШкалыИзмерителей		, Результат.ШкалыИзмерителей		, IDСтрокиТочкиУчета,,?(ДанныеОчистки <> Неопределено И ДанныеОчистки.Свойство("ШкалыИзмерителей"),ДанныеОчистки.ШкалыИзмерителей,Неопределено));
	ДополнитьТаблицуПоID(Объект.ПоказанияПриборовУчета	, Результат.ПоказанияПриборовУчета	, IDСтрокиТочкиУчета,,?(ДанныеОчистки <> Неопределено И ДанныеОчистки.Свойство("ПоказанияПриборовУчета"),ДанныеОчистки.ПоказанияПриборовУчета,Неопределено));
	ДополнитьТаблицуПоID(Объект.НомераПломб				, Результат.НомераПломб				, IDСтрокиТочкиУчета,,?(ДанныеОчистки <> Неопределено И ДанныеОчистки.Свойство("НомераПломб"),ДанныеОчистки.НомераПломб,Неопределено));
	Если Объект.Свойство("ФормулыРасчетаУслуг") Тогда
		ДополнитьТаблицуПоID(Объект.ФормулыРасчетаУслуг				, Результат.ФормулыРасчетаУслуг				, IDСтрокиТочкиУчета,,?(ДанныеОчистки <> Неопределено И ДанныеОчистки.Свойство("ФормулыРасчетаУслуг"),ДанныеОчистки.ФормулыРасчетаУслуг,Неопределено));
	КонецЕсли;

КонецПроцедуры

Процедура ДополнитьТаблицуПоID(ТаблицаПриемник, ТаблицаИсточник, IDСтроки, ДанныеПУ = Неопределено, ДанныеОчистки = Неопределено)
	Если ДанныеОчистки = Неопределено Тогда 
		энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(ТаблицаПриемник, Новый Структура("IDСтрокиТочкиУчета", IDСтроки)); 
	Иначе
		энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(ТаблицаПриемник, ДанныеОчистки);
	КонецЕсли;
	
	ДанныеПУЗаполнены = Ложь;
	Для Каждого СтрокаТаблицыИсточник Из ТаблицаИсточник Цикл
		НоваяСтрока 					= ТаблицаПриемник.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицыИсточник);
		
		Если НЕ ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтрокаТаблицыИсточник,"IDСтрокиТочкиУчета") = Неопределено Тогда
			СтрокаТаблицыИсточник.IDСтрокиТочкиУчета = IDСтроки;
		КонецЕсли; 		
		
		НоваяСтрока.IDСтрокиТочкиУчета 	= IDСтроки;
				
		Если НЕ ДанныеПУ = Неопределено И НЕ ДанныеПУЗаполнены И НЕ НоваяСтрока.ВспомогательноеОборудование Тогда
			ЗаполнитьЗначенияСвойств(ДанныеПУ, НоваяСтрока);
		КонецЕсли;
		
	КонецЦикла;	
	
КонецПроцедуры

