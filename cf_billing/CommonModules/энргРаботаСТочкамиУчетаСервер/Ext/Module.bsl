Функция ТочкиУчетаИВозможностьУстановкиПУ(Граница, Организация, Район, КлючПомещения, мТочкиУчета = Неопределено) Экспорт
	Схема							= Неопределено;
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", 	"Организация"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район", 			"Район"), 			Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения", 	"КлючПомещения"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("АбонентВладелец", "КлючПомещения"),	Неопределено));
	
	Если НЕ мТочкиУчета = Неопределено и ТипЗнч(мТочкиУчета) = Тип("Массив") Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраВСписке", Новый Структура("ТочкаУчета", "мТочкиУчета"), 	Неопределено));
	ИначеЕсли НЕ мТочкиУчета = Неопределено и ТипЗнч(мТочкиУчета) = Тип("СправочникСписок.энргТочкиУчета") Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета", 	"мТочкиУчета"), 	Неопределено));
	КонецЕсли;
	
	Параметры 		= Новый Структура;	
	Параметры.Вставить("Период", 			Новый Структура("ТипПараметра,ИмяПараметра", "ТипПараметраГраницаИсключая", "Период"));
	Параметры.Вставить("Граница", 			Новый Структура("ТипПараметра,ИмяПараметра", "ТипПараметраГраницаИсключая", "Граница"));
	Если ТипЗнч(Граница) = Тип("Дата") и НЕ ЗначениеЗаполнено(Граница) Тогда
		 Параметры.Удалить("Период");
	КонецЕсли;
	Параметры.Вставить("ПараметрыВТ", 		ПараметрыВТ);		
		
	РегистрыСведений.энргАктивностьТочекУчета.АктивныеТочкиУчетаПомещенияБезПУ(Схема, Параметры, "ДействующиеТочкиБезПУ");
	РегистрыСведений.энргТехническаяВозможностьУстановкиПУ.ТехническаяВозможностьУстановкиПУТочекУчета(Схема,Параметры,"ТехническаяВозможностьУстановкиПУТочекУчета");
		
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДействующиеТочки.ТочкаУчета КАК ТочкаУчета,
	|	ЕСТЬNULL(ТехническаяВозможностьУстановкиПУТочекУчета.НетВозможностьУстановкиПУ, ЛОЖЬ) КАК НетВозможностьУстановкиПУ	
	|ИЗ
	|	ДействующиеТочкиБезПУ КАК ДействующиеТочки
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТехническаяВозможностьУстановкиПУТочекУчета КАК ТехническаяВозможностьУстановкиПУТочекУчета
	|		ПО ДействующиеТочки.ТочкаУчета = ТехническаяВозможностьУстановкиПУТочекУчета.ТочкаУчета
	|			И ДействующиеТочки.КлючПомещения = ТехническаяВозможностьУстановкиПУТочекУчета.КлючПомещения
	|			И ДействующиеТочки.Район = ТехническаяВозможностьУстановкиПУТочекУчета.Район
	|			И ДействующиеТочки.Организация = ТехническаяВозможностьУстановкиПУТочекУчета.Организация");
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Организация",	Организация);
	ПараметрыЗапроса.Вставить("Район", 			Район);
	ПараметрыЗапроса.Вставить("КлючПомещения", 	КлючПомещения);	
	ПараметрыЗапроса.Вставить("мТочкиУчета"	, 	мТочкиУчета);	
	Если Параметры.Свойство("Период") Тогда
		ПараметрыЗапроса.Вставить("Период",				?(ТипЗнч(Граница) = Тип("Граница"), Граница.Значение.Дата, Граница));
	Иначе
		ПараметрыЗапроса.Вставить("Период",				ТекущаяДата());
	КонецЕсли;
	
	ПараметрыЗапроса.Вставить("Граница",				Граница);
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргРаботаСТочкамиУчетаСервер.ТочкиУчетаИВозможностьУстановкиПУ";
		ПараметрыМетода 			= Новый Структура("Период, Организация, Район, КлючПомещения, мТочкиУчета", Граница, Организация, Район, КлючПомещения, мТочкиУчета);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);
	КонецЕсли;	
	
	Возврат РезультатЗапроса;  	

КонецФункции

Функция НаправлениеИспользованияТочкиУчета(Организация, Район, КлючПомещения, ТочкаУчета, Период = '0001-01-01') Экспорт 
	
	Текст  =
	"ВЫБРАТЬ
	|	энргНаправлениеИспользованияТочекУчетаСрезПоследних.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ
	|ИЗ
	|	РегистрСведений.энргНаправлениеИспользованияТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И КлючПомещения = &КлючПомещения
	|				И ТочкаУчета = &ТочкаУчета) КАК энргНаправлениеИспользованияТочекУчетаСрезПоследних";
	
	Запрос 			= Новый Запрос(Текст);
	Запрос.УстановитьПараметр("Период", 		Период);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("КлючПомещения", 	КлючПомещения);
	Запрос.УстановитьПараметр("ТочкаУчета",		ТочкаУчета);
	Результат  		= Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка  		= Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.НаправлениеИспользованияТУ;
	
КонецФункции

Функция УслугиИТехническаяТочекУчета(Организация, Район, КлючПомещения) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
		|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга,
		|	энргУслугиТочекУчетаСрезПоследних.Техническая КАК Техническая,
		|	энргАктивностьТочекУчетаСрезПоследних.Состояние КАК Состояние
		|ИЗ
		|	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
		|			,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргУслугиТочекУчетаСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
		|				,
		|				Организация = &Организация
		|					И Район = &Район
		|					И КлючПомещения = &КлючПомещения) КАК энргАктивностьТочекУчетаСрезПоследних
		|		ПО энргУслугиТочекУчетаСрезПоследних.ТочкаУчета = энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета
		|ГДЕ
		|	энргАктивностьТочекУчетаСрезПоследних.Состояние = &Включена";
	
	Запрос.УстановитьПараметр("КлючПомещения", КлючПомещения);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("Включена", Перечисления.энргСостояниеТочекУчета.Включена);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

Функция ТочкиУчетаНаСтруктуреСети(Организация, Район, КлючПомещения, Период) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АктивТУ.Организация КАК Организация,
		|	АктивТУ.Район КАК Район,
		|	АктивТУ.КлючПомещения КАК КлючПомещения,
		|	АктивТУ.ТочкаУчета КАК ТочкаУчета,
		|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга
		|ПОМЕСТИТЬ ВТ_ТочкиУчетаАбонента
		|ИЗ
		|	(ВЫБРАТЬ
		|		энргАктивностьТочекУчетаСрезПоследних.Организация КАК Организация,
		|		энргАктивностьТочекУчетаСрезПоследних.Район КАК Район,
		|		энргАктивностьТочекУчетаСрезПоследних.КлючПомещения КАК КлючПомещения,
		|		энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
		|	ИЗ
		|		РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
		|				&Период,
		|				КлючПомещения = &КлючПомещения
		|					И Организация = &Организация
		|					И Район = &Район) КАК энргАктивностьТочекУчетаСрезПоследних
		|	ГДЕ
		|		энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(перечисление.энргСостояниеТочекУчета.включена)) КАК АктивТУ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
		|				&Период,
		|				КлючПомещения = &КлючПомещения
		|					И Организация = &Организация
		|					И Район = &Район) КАК энргУслугиТочекУчетаСрезПоследних
		|		ПО АктивТУ.Организация = энргУслугиТочекУчетаСрезПоследних.Организация
		|			И АктивТУ.Район = энргУслугиТочекУчетаСрезПоследних.Район
		|			И АктивТУ.КлючПомещения = энргУслугиТочекУчетаСрезПоследних.КлючПомещения
		|			И АктивТУ.ТочкаУчета = энргУслугиТочекУчетаСрезПоследних.ТочкаУчета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТочкиУчетаАбонента.Организация КАК Организация,
		|	ВТ_ТочкиУчетаАбонента.Район КАК Район,
		|	ВТ_ТочкиУчетаАбонента.КлючПомещения КАК КлючПомещения,
		|	ВТ_ТочкиУчетаАбонента.ТочкаУчета КАК ТочкаУчета,
		|	ВТ_ТочкиУчетаАбонента.Услуга КАК Услуга,
		|	бестТУНаСтруктуреСетиСрезПоследних.СтруктураСети КАК СтруктураСети
		|ИЗ
		|	ВТ_ТочкиУчетаАбонента КАК ВТ_ТочкиУчетаАбонента
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестТУНаСтруктуреСети.СрезПоследних(
		|				&Период,
		|				КлючПомещения = &КлючПомещения
		|					И Организация = &Организация
		|					И Район = &Район) КАК бестТУНаСтруктуреСетиСрезПоследних
		|		ПО ВТ_ТочкиУчетаАбонента.Организация = бестТУНаСтруктуреСетиСрезПоследних.Организация
		|			И ВТ_ТочкиУчетаАбонента.Район = бестТУНаСтруктуреСетиСрезПоследних.Район
		|			И ВТ_ТочкиУчетаАбонента.КлючПомещения = бестТУНаСтруктуреСетиСрезПоследних.КлючПомещения
		|			И ВТ_ТочкиУчетаАбонента.ТочкаУчета = бестТУНаСтруктуреСетиСрезПоследних.ТочкаУчета";
	
	Запрос.УстановитьПараметр("КлючПомещения", КлючПомещения);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("Период", Период);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

