Процедура ЗаполнитьТекстовыеПоляКоллекцииМКД(Форма) Экспорт   	
	ТочкиУчета	= Форма.Объект["ТочкиУчета"];	
	Измерители 	= Форма.Объект["Измерители"];
	Потери 		= Форма.Объект["Потери"]; 	
	
	Для Каждого ТекСтрока из ТочкиУчета Цикл
		Если ТекСтрока.Услуга.СоставнаяУслуга Тогда
			ПредставлениеПоставщика  								= "";
			СтрокиТЧ 	=  Форма.Объект["ПоставщикиСоставныхУслуг"].НайтиСтроки(Новый Структура("IDСтроки",ТекСтрока.IDСтроки));
			Для Каждого Строка Из СтрокиТЧ Цикл
				Представление = Строка.Поставщик;
				ПредставлениеПоставщика 							= ПредставлениеПоставщика + ?(ЗначениеЗаполнено(ПредставлениеПоставщика),"/","") + Представление;
			КонецЦикла;
			Поставщик = ПредставлениеПоставщика;
			ТекСтрока.ДанныеУслуги 			= ЗаполнитьТекстДанныеУслуги(ТекСтрока, Поставщик);
		Иначе
			ТекСтрока.ДанныеУслуги 			= ЗаполнитьТекстДанныеУслуги(ТекСтрока);
		КонецЕсли;
		
		ТекСтрока.ДанныеРасположения 	= ЗаполнитьТекстДанныеРасположения(ТекСтрока); 		
		ТекСтрока.ТехническиеСвойстваТУ	= ЗаполнитьТекстТехническихСвойств(ТекСтрока, Потери.НайтиСтроки(Новый Структура("IDСтроки", ТекСтрока.IDСтроки)), "МКД");
		
		ДанныеИзмерителей = Новый Структура("Измерители", Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекСтрока.IDСтроки)));
		ЗаполнитьТекстСредствИзмерений(ТекСтрока, ДанныеИзмерителей);
		
		ОбновитьТекстовыеПоляКоллекцииМКДПереопределяемый(ТекСтрока);		 		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьТекстовыеПоляКоллекцииМКДПереопределяемый(ТекСтрока)
	
КонецПроцедуры

Функция ЗаполнитьТекстДанныеУслуги(ТекущиеДанные, Поставщик = Неопределено) Экспорт 	
	Текст = "Услуга = " + ТекущиеДанные.Услуга + Символы.ПС;
	Текст = Текст + "Ед.изм = " + энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущиеДанные.Услуга, "ЕдиницаИзмерения") + Символы.ПС;
	Если Поставщик = Неопределено Тогда
		Текст = Текст + "Поставщик = " + ТекущиеДанные.Поставщик.Наименование;
	Иначе
		Текст = Текст + "Поставщик = " + Поставщик;
	КонецЕсли;
	
	Возврат Текст; 	
КонецФункции

Функция ЗаполнитьТекстДанныеРасположения(ТекущиеДанные) Экспорт
	СтруктураСети = "";
	Если ТекущиеДанные.свойство("СтруктураСети") Тогда
		СтруктураСети = ТекущиеДанные.СтруктураСети;
	ИначеЕсли ТекущиеДанные.свойство("бестСтруктураСети") Тогда
		СтруктураСети = ТекущиеДанные.бестСтруктураСети;
	КонецЕсли; 	
	
	Текст = "Структура сети = " + СтруктураСети + Символы.ПС;
	Текст = Текст + "Расположение = " + ТекущиеДанные.Расположение + Символы.ПС;
	Текст = Текст + "Наименование точки = " + ТекущиеДанные.НаименованиеТочки;	 	
	
	Возврат Текст;
КонецФункции

Функция ПолучитьСхемуРасположения(ТекущиеДанные) Экспорт
	СтруктураСети = "";
	Если ТекущиеДанные.свойство("СтруктураСети") Тогда
		СтруктураСети = ТекущиеДанные.СтруктураСети;
	ИначеЕсли ТекущиеДанные.свойство("бестСтруктураСети") Тогда
		СтруктураСети = ТекущиеДанные.бестСтруктураСети;
	КонецЕсли; 	
	
	Текст = "" + СтруктураСети;
	Возврат Текст;
КонецФункции

Функция ЗаполнитьТекстТехническихСвойств(ТекущиеДанные, Потери, ВызывающаяПодсистема = "") Экспорт 
	
	Если ВызывающаяПодсистема = "МКД" Тогда
		Возврат	ЗаполнитьТекстТехническихСвойствМКД(ТекущиеДанные, Потери);
	КонецЕсли;	
	
	Текст = "Техническая = " + ТекущиеДанные.Техническая + Символы.ПС;
	Текст = Текст + "Нет возможности установки ПУ = " + ТекущиеДанные.НетВозможностьУстановкиПУ + Символы.ПС;
	Текст = Текст + "Диаметр сечения(мм) = " + ТекущиеДанные.ДиаметрСечения + Символы.ПС;
	
	Если ВызывающаяПодсистема <> "ЮЛ" Тогда	
		Текст = Текст + "Расчет только по показаниям = " + ТекущиеДанные.РасчетТолькоПоПоказаниям + Символы.ПС;
		Текст = Текст + "Рассчитывать по диаметру = " + ТекущиеДанные.РассчитыватьПоДиаметруСечения + Символы.ПС;
		Если ТекущиеДанные.Свойство("НазначениеПУ") Тогда
			Текст = Текст + "Назначение ПУ = " + ?(ЗначениеЗаполнено(ТекущиеДанные.НазначениеПУ), ТекущиеДанные.НазначениеПУ, "не заполнено") + Символы.ПС;
		КонецЕсли;
	Иначе
		Текст = Текст + "Длина трубы(м) = " + ТекущиеДанные.ДлинаТрубы + Символы.ПС;
		Текст = Текст + "Расчет по графику ГП = " + ТекущиеДанные.РасчетПоГрафикуГП + Символы.ПС;
	КонецЕсли;
	
	Если Потери.Количество() = 0 Тогда
		Текст = Текст + "Потери не заполнены";		
	иначе
		Текст = Текст + "Потери:" + Символы.ПС;
		Для Каждого ТекСтр из Потери Цикл
			ЧислоПотерь = ?(ТекСтр.ФиксированныйОбъемПотерь > 0 , ТекСтр.ФиксированныйОбъемПотерь, "" + ТекСтр.ПроцентПотерь + "%");
			Текст 		= Текст + ТекСтр.ВидПотерь + " = " + ЧислоПотерь + Символы.ПС;
		КонецЦикла; 		
	КонецЕсли;	
	
	Возврат СокрЛП(Текст);
КонецФункции

Функция ЗаполнитьТекстТехническихСвойствМКД(ТекущиеДанные, Потери) Экспорт 		
	Текст = "Нет возможности установки ОДПУ = " + ТекущиеДанные.НетВозможностьУстановкиОДПУ + Символы.ПС;
	
	Если Потери.Количество() = 0 Тогда
		Текст = Текст + "Потери не заполнены";		
	иначе
		Текст = Текст + "Потери:" + Символы.ПС;
		Для Каждого ТекСтр из Потери Цикл
			ЧислоПотерь = ?(ТекСтр.ФиксированныйОбъемПотерь > 0 , ТекСтр.ФиксированныйОбъемПотерь, "" + ТекСтр.ПроцентПотерь + "%");
			Текст 		= Текст + ТекСтр.ВидПотерь + " = " + ЧислоПотерь + Символы.ПС;
		КонецЦикла; 		
	КонецЕсли;	
	
	Возврат СокрЛП(Текст);
КонецФункции

Функция ЗаполнитьТекстСредствИзмерений(ТекущиеДанные, Результат) Экспорт
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Результат, "Измерители") Тогда
		Текст = ?(Результат.Измерители.Количество() = 0 , "Не заполнены", "Заполнены");
	Иначе
		Текст = "Не заполнены";
	КонецЕсли;
	
	ТекущиеДанные.СредстваИзмерения = Текст;
	//Возврат Текст;
КонецФункции

