Функция ВсеУслугиТочкиУчета(Организация, Район, КлючПомещения, ТочкаУчета) Экспорт 
	
	Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	энргВидыУслуг.СоставнаяУслуга КАК СоставнаяУслуга
	|ПОМЕСТИТЬ УслугиТочек
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		энргУслугиТочекУчета.Услуга КАК Услуга
	|	ИЗ
	|		РегистрСведений.энргУслугиТочекУчета КАК энргУслугиТочекУчета
	|	ГДЕ
	|		энргУслугиТочекУчета.Организация = &Организация
	|		И энргУслугиТочекУчета.Район = &Район
	|		И энргУслугиТочекУчета.КлючПомещения = &КлючПомещения
	|		И энргУслугиТочекУчета.ТочкаУчета = &ТочкаУчета) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО ВложенныйЗапрос.Услуга = энргВидыУслуг.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВидыУслугСоставляющиеУслуг.Услуга КАК Услуга
	|ИЗ
	|	УслугиТочек КАК УслугиТочек
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|		ПО УслугиТочек.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
	|			И (УслугиТочек.СоставнаяУслуга)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	УслугиТочек.Услуга
	|ИЗ
	|	УслугиТочек КАК УслугиТочек";
	
	Запрос  	= Новый Запрос(Текст);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("КлючПомещения", 	КлючПомещения);
	Запрос.УстановитьПараметр("ТочкаУчета", 	ТочкаУчета);
	
	Результат  = Запрос.Выполнить();
	Возврат Результат.Выгрузить().ВыгрузитьКолонку("Услуга");
	
КонецФункции

Функция УслугаТочкиУчета(Организация, Район, КлючПомещения, ТочкаУчета, Период = '0001-01-01') Экспорт 
	
	Текст  =
	"ВЫБРАТЬ
	|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга
	|ИЗ
	|	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И КлючПомещения = &КлючПомещения
	|				И ТочкаУчета = &ТочкаУчета) КАК энргУслугиТочекУчетаСрезПоследних";
	
	Запрос 			= Новый Запрос(Текст);
	Запрос.УстановитьПараметр("Период", 		Период);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("КлючПомещения", 	КлючПомещения);
	Запрос.УстановитьПараметр("ТочкаУчета",		ТочкаУчета);
	Результат  		= Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Справочники.энргВидыУслуг.ПустаяСсылка();
	КонецЕсли;
	
	Выборка  		= Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Услуга;
	
КонецФункции

