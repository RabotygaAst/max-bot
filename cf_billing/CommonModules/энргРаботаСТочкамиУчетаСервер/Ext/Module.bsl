#Область РаботаСЭлементамиСправочков

Процедура СоздатьТочкиУчета(ТекущийОбъект,ИмяКоллекции,Отказ) Экспорт 
	
	НовыеТочкиУчета 						= Новый Массив;
	
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеТочкиУчета") Тогда
		НовыеТочкиУчета 						= ТекущийОбъект.ДополнительныеСвойства.НовыеТочкиУчета; 
	КонецЕсли;
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ИзмененныеТУ") Тогда
		ИзмененныеТУ							= ТекущийОбъект.ДополнительныеСвойства.ИзмененныеТУ;
	КонецЕсли;
	
	ЗаписываемаяКоллекция 					= ТекущийОбъект[ИмяКоллекции];
	для Каждого стр из ТекущийОбъект[ИмяКоллекции] цикл
		
		Если ПустаяСтрока(стр.ОписаниеТочки) Тогда
			Продолжить;
		КонецЕсли;
		
		ЭтоНоваяТУ							= Не НовыеТочкиУчета.Найти(стр.НомерСтроки) = Неопределено;
		
		Если Не ЭтоНоваяТУ И ТекущийОбъект.ДополнительныеСвойства.Свойство("ИзмененныеТУ") И ИзмененныеТУ.Найти(стр.ТочкаУчета) = Неопределено Тогда
			// эту ТУ не изменяли, перезаписывать не надо
			Продолжить;
		КонецЕсли;
		
		//Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ИзмененныеТУ") И ИзмененныеТУ.Найти(стр.ТочкаУчета) = Неопределено  Тогда
		//	Продолжить;
		//КонецЕсли;
		
		Чтение  							= Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(стр.ОписаниеТочки);		
		Описание							= ПрочитатьJSON(Чтение);
		
		ДанныеТочки 						= Новый Структура("Головная,Расположение,Наименование,ДлинаТрубы",Ложь,Справочники.энргМестаРасположенияТочекУчета.ПустаяСсылка(),"",0);
		ЗаполнитьЗначенияСвойств(ДанныеТочки, стр);
		
		Если  Описание.Свойство("Расположение") тогда
			Ключ 							= Новый УникальныйИдентификатор(Описание.Расположение);
			ДанныеТочки.Расположение 		= Справочники.энргМестаРасположенияТочекУчета.ПолучитьСсылку(Ключ);
		КонецЕсли;
		
		Если  Описание.Свойство("НаименованиеТочки") тогда
			ДанныеТочки.Наименование		= Описание.НаименованиеТочки;
		ИначеЕсли  Описание.Свойство("Наименование") тогда	
			ДанныеТочки.Наименование		= Описание.Наименование;
		КонецЕсли;
		
		Если  Описание.Свойство("Головная") тогда
			ДанныеТочки.Головная 			= ДанныеТочки.Головная;
		КонецЕсли;
		
		Если ЭтоНоваяТУ Тогда
			ТочкаОбъект 					= Справочники.энргТочкиУчета.СоздатьЭлемент();
		    ТочкаОбъект.УстановитьСсылкуНового(стр.ТочкаУчета);
		Иначе
			ТочкаОбъект  					= стр.ТочкаУчета.получитьОбъект();
		КонецЕсли;
		
		ЗаполнитьЭлемент(ТочкаОбъект,ДанныеТочки);		
	КонецЦикла;	
КонецПроцедуры

Функция СформироватьИдентификаторТочекУчета(Организация, ВидКонтрагента) Экспорт
	Идентификатор  				= "";
	ДлинаИдентификатора = 16;
	Запрос 		= Новый Запрос;
	Запрос.УстановитьПараметр("Организация",	Организация);
	ЭтоМКД = Ложь;
	
	Если ВидКонтрагента = Перечисления.бестЮрФизЛицо.ЮрЛицо Тогда
		ЮрФизЛицо = Ложь;
	ИначеЕсли ВидКонтрагента = Перечисления.бестЮрФизЛицо.ФизЛицо Тогда
		ЮрФизЛицо = Истина;
	Иначе
		ЭтоМКД = Истина;
		ЮрФизЛицо = Ложь;
	КонецЕсли;

	//Если ВидКонтрагента = Неопределено Тогда
	//	ЭтоМКД = Истина;
	//	ЮрФизЛицо = Ложь;
	//ИначеЕсли ВидКонтрагента = Тип("СправочникСсылка.Организации") Тогда
	//	ЮрФизЛицо = Ложь;
	//Иначе
	//	ЮрФизЛицо = Контрагент.ЮрФизЛицо = Перечисления.бестЮрФизЛицо.ФизЛицо;
	//КонецЕсли;
	Запрос.УстановитьПараметр("ФизЛицо",	ЮрФизЛицо);//Контрагент.ЮрФизЛицо = Перечисления.бестЮрФизЛицо.ФизЛицо);
	Запрос.УстановитьПараметр("ЭтоМКД",		ЭтоМКД);
	Запрос.Текст  ="ВЫБРАТЬ
	               |	ВЫБОР
	               |		КОГДА ЕСТЬNULL(ВложенныйЗапрос.Идентификатор, ""00000000"") = """"
	               |			ТОГДА ""00000000""
	               |		ИНАЧЕ ЕСТЬNULL(ВложенныйЗапрос.Идентификатор, ""00000000"")
	               |	КОНЕЦ КАК МаксНомер
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		МАКСИМУМ(ПОДСТРОКА(энргТочкиУчета.IDТочкиУчета, 9, 16)) КАК Идентификатор
	               |	ИЗ
	               |		(ВЫБРАТЬ
	               |			энргАктивностьТочекУчета.ТочкаУчета КАК ТочкаУчета
	               |		ИЗ
	               |			РегистрСведений.энргАктивностьТочекУчета КАК энргАктивностьТочекУчета
	               |		ГДЕ
	               |			энргАктивностьТочекУчета.Организация = &Организация
	               |			И &ФизЛицо
	               |			И НЕ &ЭтоМКД
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			энргАктивностьТочекУчета.ТочкаУчета
	               |		
	               |		ОБЪЕДИНИТЬ ВСЕ
	               |		
	               |		ВЫБРАТЬ
	               |			бестАктивностьТочекУчетаНП.ТочкаУчета
	               |		ИЗ
	               |			РегистрСведений.бестАктивностьТочекУчетаНП КАК бестАктивностьТочекУчетаНП
	               |		ГДЕ
	               |			бестАктивностьТочекУчетаНП.Организация = &Организация
	               |			И НЕ &ФизЛицо
	               |			И НЕ &ЭтоМКД
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			бестАктивностьТочекУчетаНП.ТочкаУчета
	               |		
	               |		ОБЪЕДИНИТЬ ВСЕ
	               |		
	               |		ВЫБРАТЬ
	               |			энргАктивностьТочекУчетаМКД.ТочкаУчета
	               |		ИЗ
	               |			РегистрСведений.энргАктивностьТочекУчетаМКД КАК энргАктивностьТочекУчетаМКД
	               |		ГДЕ
	               |			энргАктивностьТочекУчетаМКД.Организация = &Организация
	               |			И &ЭтоМКД
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			энргАктивностьТочекУчетаМКД.ТочкаУчета) КАК ВложенныйЗапрос
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТочкиУчета КАК энргТочкиУчета
	               |			ПО ВложенныйЗапрос.ТочкаУчета = энргТочкиУчета.Ссылка) КАК ВложенныйЗапрос";
	//Текст 			= СтрЗаменить(Текст,"%%ДлинаЛС%%",Строка(ДлинаЛС));
	//Запрос.Текст 	= Текст;
	Результат 		= Запрос.Выполнить();
	Выборка  		= Результат.выбрать();
	Выборка.следующий();
	МаксНомер  		= Выборка.МаксНомер;
	
	Сч = 1;
	Пока Сч<=ДлинаИдентификатора цикл
		Если Сред(МаксНомер,ДлинаИдентификатора-(Сч-1),1) = "9" тогда
			Сч = Сч +1;	
		иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ОкончаниеКода  				= СтрЗаменить(Число(Прав(МаксНомер,Сч)) + 1,Символы.НПП,"");
	КодАбонента 				= Формат(Число(МаксНомер)+1,"ЧЦ=8; ЧВН=; ЧГ=0");
	КодТипаПотребителя			= ?(ЮрФизЛицо, "1", "2");
	Идентификатор 				= ?(ЗначениеЗаполнено(Организация.бестКодВнутриРосатом), Организация.бестКодВнутриРосатом, "0000") + ?(ЗначениеЗаполнено(Организация.бестКодОрганизацииВнутриГоловнойОрганизации), Организация.бестКодОрганизацииВнутриГоловнойОрганизации, "00") + КодТипаПотребителя + КодАбонента;
	Возврат Идентификатор;	
КонецФункции		

#КонецОбласти

#Область ФункцииЗаполненияТабличныхЧастей

Функция ДанныеДляОплатыАбонента(Период,Организация, ПериодНачисления,Район,Дом,Абонент, ОтборПоДому = Истина) Экспорт  
	Запрос   		= Новый Запрос;
	Граница = Новый Граница(Период, ВидГраницы.Включая);
	Запрос.УстановитьПараметр("Период" ,			Граница);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("МКД",				Дом);
	Запрос.УстановитьПараметр("Абонент",			Абонент);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления КАК ПериодНачисления,
	|	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
	|	ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.ОсновнойДолг) КАК ВидЗадолженности,
	|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток КАК Задолженность,
	|	энргВзаиморасчетыПоМесяцамОстатки.Поставщик КАК Поставщик,
	|	0 КАК ЗадолженностьПени
	|ПОМЕСТИТЬ ВТ_Задолженности
	|ИЗ
	|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И Абонент = &Абонент) КАК энргВзаиморасчетыПоМесяцамОстатки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргВзаиморасчетыПоПениОстатки.ПериодНачисления,
	|	энргВзаиморасчетыПоПениОстатки.Услуга,
	|	ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.Пеня),
	|	энргВзаиморасчетыПоПениОстатки.СуммаОстаток,
	|	ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка),
	|	энргВзаиморасчетыПоПениОстатки.СуммаОстаток
	|ИЗ
	|	РегистрНакопления.энргВзаиморасчетыПоПени.Остатки(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И Абонент = &Абонент) КАК энргВзаиморасчетыПоПениОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПросуженнаяЗадолженностьАбонентовСрезПоследних.ПериодНачисления КАК ПериодНачисления,
	|	энргПросуженнаяЗадолженностьАбонентовСрезПоследних.Услуга КАК Услуга,
	|	энргПросуженнаяЗадолженностьАбонентовСрезПоследних.Поставщик КАК Поставщик,
	|	энргПросуженнаяЗадолженностьАбонентовСрезПоследних.ПросуженнаяБлокированная КАК ПросуженнаяБлокированная,
	|	энргПросуженнаяЗадолженностьАбонентовСрезПоследних.Период КАК ДатаДокумента
	|ПОМЕСТИТЬ ВТ_Просуженная
	|ИЗ
	|	РегистрСведений.энргПросуженнаяЗадолженностьАбонентов.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И Абонент = &Абонент) КАК энргПросуженнаяЗадолженностьАбонентовСрезПоследних
	|ГДЕ
	|	энргПросуженнаяЗадолженностьАбонентовСрезПоследних.ПросуженнаяБлокированная
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Задолженности.ПериодНачисления КАК ПериодНачисления,
	|	ВТ_Задолженности.Услуга КАК Услуга,
	|	ВТ_Задолженности.ВидЗадолженности КАК ВидЗадолженности,
	|	ВТ_Задолженности.Задолженность КАК Задолженность,
	|	ВТ_Задолженности.Поставщик КАК Поставщик,
	|	ВТ_Задолженности.ЗадолженностьПени КАК ЗадолженностьПени,
	|	ВТ_Просуженная.ПросуженнаяБлокированная КАК ПросуженнаяБлокированная,
	|	ВТ_Просуженная.ДатаДокумента КАК ДатаДокумента
	|ИЗ
	|	ВТ_Задолженности КАК ВТ_Задолженности
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Просуженная КАК ВТ_Просуженная
	|		ПО ВТ_Задолженности.ПериодНачисления = ВТ_Просуженная.ПериодНачисления
	|			И ВТ_Задолженности.Услуга = ВТ_Просуженная.Услуга
	|			И ВТ_Задолженности.Поставщик = ВТ_Просуженная.Поставщик"; 

	Если НЕ ОтборПоДому Тогда
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст,"И МКД = &МКД", "");
	КонецЕсли;
	
	Результат  		= Запрос.Выполнить();
	Возврат Результат;
	
КонецФункции

Функция ДействующиеТочкиУчета(Период, Организация,Район,КлючПомещения,ОбъектРасчета = Неопределено, ТочкиСПриборами = Неопределено, НаименованиеТочки = "", ПараметрыОтбора = Неопределено) Экспорт  
	
	Схема  							= Неопределено;
	ПараметрыОтбор  				= Новый Массив;
	
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", 	"Организация"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район", 			"Район"), 			Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения", 	"КлючПомещения"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("АбонентВладелец", "КлючПомещения"),	Неопределено));
	
	Если ПараметрыОтбора = Неопределено Тогда
		//ПараметрыВыбора	 				= Новый Структура("ПараметрыВТ,ВыбратьВсеСостояния", ПараметрыВТ,ВыбратьВсеСостояния);
		ПараметрыВыбора	 				= Новый Структура("ПараметрыВТ,Отбор", ПараметрыВТ,ПараметрыОтбор);
	Иначе
		ПараметрыВыбора 				= ПараметрыОтбора;
		ПараметрыВыбора.Вставить("ПараметрыВТ", ПараметрыВТ);
		ПараметрыВыбора.Вставить("Отбор", 		ПараметрыОтбор);
		
		Если ПараметрыОтбора.Свойство("ТочкиОРП") Тогда
			ПараметрыВыбора.Вставить("ТочкиОРП", Истина);
		КонецЕсли;	
		Если ПараметрыОтбора.Свойство("ВключаяОРП") Тогда
			ПараметрыВыбора.Вставить("ВключаяОРП", Истина);
		КонецЕсли;	
		
	КонецЕсли;
		
	Если ЗначениеЗаполнено(Период) Тогда
		ПараметрыВыбора.Вставить("Период", Новый Структура("ИмяПараметра","Период"));
	КонецЕсли;
	
	Если Не ПустаяСтрока(НаименованиеТочки) Тогда
		 ПараметрыОтбор.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраПодобно", Новый Структура("ТочкаУчета", НаименованиеТочки), Неопределено)); 
	КонецЕсли;
	   	
	Если ТочкиСПриборами = Неопределено Тогда
		РегистрыСведений.энргАктивностьТочекУчета.АктивныеТочкиУчетаПомещения(Схема,ПараметрыВыбора);
	ИначеЕсли ТочкиСПриборами Тогда
		РегистрыСведений.энргСостояниеПриборовУчетаАбонента.ДействующиеПриборыУчетаПомещения(Схема, ПараметрыВыбора);
	Иначе
		РегистрыСведений.энргАктивностьТочекУчета.АктивныеТочкиУчетаПомещенияБезПУ(Схема,ПараметрыВыбора);		
	КонецЕсли;
	
	ПараметрыЗапроса 				= Новый Структура;
	ПараметрыЗапроса.Вставить("Период",			КонецДня(Период));
	ПараметрыЗапроса.Вставить("Район",			Район);
	ПараметрыЗапроса.Вставить("Организация",	Организация);  
	ПараметрыЗапроса.Вставить("КлючПомещения",	КлючПомещения);
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргРаботаСТочкамиУчетаСервер.ДействующиеТочкиУчета";
		ПараметрыМетода 			= Новый Структура("Период,Организация,Район,КлючПомещения,ОбъектРасчета,ТочкиСПриборами,НаименованиеТочки,ПараметрыОтбора", Период, Организация,Район,КлючПомещения,ОбъектРасчета, ТочкиСПриборами, НаименованиеТочки, ПараметрыОтбора);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);		
	КонецЕсли;
	
	Возврат РезультатЗапроса;
		
КонецФункции

Функция СвойстваДействующихТочекУчета(Период, Организация,Район,КлючПомещения,ПолучаемыеСвойства,ТочкиСПриборами = Неопределено) Экспорт  
	
	Схема  							= Неопределено;
	
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", 	"Организация"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район", 			"Район"), 			Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения", 	"КлючПомещения"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("АбонентВладелец", "КлючПомещения"),	Неопределено));
	
	Параметры 						= Новый Структура;
		
	Если ЗначениеЗаполнено(Период) Тогда
		Параметры.Вставить("Период", Новый Структура("ИмяПараметра","Период"));
	КонецЕсли;
	
	ПараметрыОтбор  				= Новый Массив;
		
	Параметры.Вставить("ПараметрыВТ", 	ПараметрыВТ);
	Параметры.Вставить("Отбор", 		ПараметрыОтбор);
	
	Если ТочкиСПриборами = Неопределено Тогда
		РегистрыСведений.энргАктивностьТочекУчета.АктивныеТочкиУчетаПомещения(Схема,Параметры,"ДействующиеТочки");
	ИначеЕсли ТочкиСПриборами Тогда
		РегистрыСведений.энргСостояниеПриборовУчетаАбонента.ДействующиеПриборыУчетаПомещения(Схема, Параметры,"ДействующиеТочки");
	Иначе
		РегистрыСведений.энргАктивностьТочекУчета.АктивныеТочкиУчетаПомещенияБезПУ(Схема,Параметры,"ДействующиеТочки");		
	КонецЕсли;
	
	мПолучаемыеСвойстваТочекУчета 		= СтрРазделить(ПолучаемыеСвойства,",");
	
	Если НЕ мПолучаемыеСвойстваТочекУчета.Найти("РасчетТолькоПоПоказаниям") = Неопределено Тогда
		РегистрыСведений.энргСвойствоРасчетТолькоПоПоказаниямТочекУчета.ЗначениеСвойстваРасчетТолькоПоПоказаниямТочекУчета(Схема,Параметры,"СвойствоРасчетТолькоПоПоказаниямТочекУчета");
	КонецЕсли;
	
	ТекстЗапроса = 	"ВЫБРАТЬ
	               	|	ДействующиеТочки.Организация КАК Организация,
	               	|	ДействующиеТочки.Район КАК Район,
	               	|	ДействующиеТочки.КлючПомещения КАК КлючПомещения,
	               	|	ДействующиеТочки.ТочкаУчета КАК ТочкаУчета
	               	|ИЗ
	               	|	ДействующиеТочки КАК ДействующиеТочки
	               	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргПриборыТочекУчета.СрезПоследних(&Период, ) КАК энргПриборыТочекУчетаСрезПоследних
	               	|		ПО ДействующиеТочки.Организация = энргПриборыТочекУчетаСрезПоследних.Организация
	               	|			И ДействующиеТочки.Район = энргПриборыТочекУчетаСрезПоследних.Район
	               	|			И ДействующиеТочки.КлючПомещения = энргПриборыТочекУчетаСрезПоследних.КлючПомещения
	               	|			И ДействующиеТочки.ТочкаУчета = энргПриборыТочекУчетаСрезПоследних.ТочкаУчета
	               	|ГДЕ
	               	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета ЕСТЬ НЕ NULL";
	
	Пакет 								= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(ТекстЗапроса);
	ОператорВыбора 						= Пакет.Операторы[0];
	Если НЕ мПолучаемыеСвойстваТочекУчета.Найти("РасчетТолькоПоПоказаниям") = Неопределено Тогда
		Источник 						= ОператорВыбора.Источники.Добавить("СвойствоРасчетТолькоПоПоказаниямТочекУчета");
		
		УсловиеСоединения 				= Новый Массив;
		УсловиеСоединения.Добавить("ДействующиеТочки.Организация = СвойствоРасчетТолькоПоПоказаниямТочекУчета.Организация");
		УсловиеСоединения.Добавить("ДействующиеТочки.Район = СвойствоРасчетТолькоПоПоказаниямТочекУчета.Район");
		УсловиеСоединения.Добавить("ДействующиеТочки.КлючПомещения = СвойствоРасчетТолькоПоПоказаниямТочекУчета.КлючПомещения");
		УсловиеСоединения.Добавить("ДействующиеТочки.ТочкаУчета = СвойствоРасчетТолькоПоПоказаниямТочекУчета.ТочкаУчета");
		
		ОператорВыбора.Источники[0].Соединения.Добавить(Источник, СтрСоединить(УсловиеСоединения, Символы.ПС + " И "));
		
		ОператорВыбора.ВыбираемыеПоля.Добавить("ЕСТЬNULL(СвойствоРасчетТолькоПоПоказаниямТочекУчета.РасчетТолькоПоПоказаниям, ЛОЖЬ)");
		КолонкаЗапроса 					= Пакет.Колонки[Пакет.Колонки.Количество()-1];
		КолонкаЗапроса.Псевдоним 		= "РасчетТолькоПоПоказаниям"; 
	КонецЕсли;  	
	
	ПараметрыЗапроса 					= Новый Структура;
	ПараметрыЗапроса.Вставить("Период",			Период);
	ПараметрыЗапроса.Вставить("Район",			Район);
	ПараметрыЗапроса.Вставить("Организация",	Организация);  
	ПараметрыЗапроса.Вставить("КлючПомещения",	КлючПомещения);	
	
	РезультатЗапроса 					= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 						= "энргРаботаСТочкамиУчетаСервер.СвойстваДействующихТочекУчета";
		ПараметрыМетода 				= Новый Структура("Период, Организация,Район,КлючПомещения,ПолучаемыеСвойства,ТочкиСПриборами", Период, Организация,Район,КлючПомещения,ПолучаемыеСвойства,ТочкиСПриборами);
		слжОбщегоНазначенияМодуль 		= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);
	КонецЕсли;
	
	Возврат РезультатЗапроса
		
КонецФункции

Процедура АвтоПодборТочкиУчета(Период, Организация,Район,КлючПомещения, Текст, ДанныеВыбора, СтандартнаяОбработка) Экспорт 
	СтандартнаяОбработка	= Ложь;
	Результат  				= ДействующиеТочкиУчета(Период, Организация,Район,КлючПомещения,,,Текст);
	ДанныеВыбора 			= Новый СписокЗначений;
	ДанныеВыбора.ЗагрузитьЗначения(Результат.Выгрузить().ВыгрузитьКолонку("ТочкаУчета"));	
КонецПроцедуры

Функция ДействующиеТочкиУчетаМКД(Период, Организация,Район,МКД,ТочкиСПриборами = Неопределено, НаименованиеТочки = "") Экспорт  
	
	Схема  							= Неопределено;
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", 	"Организация"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район", 			"Район"), 			Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("МКД", 			"МКД"), 		Неопределено));
			
	ПараметрыВыбора	 				= Новый Структура("ПараметрыВТ", ПараметрыВТ);
	
	Если ЗначениеЗаполнено(Период) Тогда
		ПараметрыВыбора.Вставить("Период", Новый Структура("ИмяПараметра","Период"));
	КонецЕсли;
	
	Если Не ПустаяСтрока(НаименованиеТочки) Тогда
		 ПараметрыВыбора.Вставить("Отбор", Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраПодобно", Новый Структура("ТочкаУчета", НаименованиеТочки), Неопределено)); 
	КонецЕсли;
	
	Если ТочкиСПриборами = Неопределено Тогда
		РегистрыСведений.энргАктивностьТочекУчетаМКД.АктивныеТочкиУчета(Схема,ПараметрыВыбора);
	ИначеЕсли ТочкиСПриборами Тогда
		РегистрыСведений.энргСостояниеПриборовМКД.ДействующиеПриборыУчетаМКД(Схема, ПараметрыВыбора);
	Иначе
		РегистрыСведений.энргАктивностьТочекУчетаМКД.АктивныеТочкиУчетаБезПУ(Схема,ПараметрыВыбора);
	КонецЕсли;
	
	ПараметрыЗапроса 				= Новый Структура;
	ПараметрыЗапроса.Вставить("Период",			Период);
	ПараметрыЗапроса.Вставить("Район",			Район);
	ПараметрыЗапроса.Вставить("Организация",	Организация);  
	ПараметрыЗапроса.Вставить("МКД",			МКД);
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргРаботаСТочкамиУчетаСервер.ДействующиеТочкиУчетаМКД";
		ПараметрыМетода 			= Новый Структура("Период, Организация,Район,МКД,ТочкиСПриборами, НаименованиеТочки", Период, Организация,Район,МКД,ТочкиСПриборами, НаименованиеТочки);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);	
	КонецЕсли;
	
	Возврат РезультатЗапроса;
		
КонецФункции

Функция ДанныеОбАвансеАбонента(Период, Организация, Район, Абонент) Экспорт 
	Граница = Новый Граница(Период, ВидГраницы.Включая);
	Запрос   		= Новый Запрос;
	Запрос.УстановитьПараметр("Период" ,			Граница);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("Абонент",			Абонент);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАвансыОстатки.СуммаОстаток КАК Аванс
	|ИЗ
	|	РегистрНакопления.энргАвансы.Остатки(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Абонент = &Абонент) КАК энргАвансыОстатки"; 

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Аванс) Тогда
		Возврат Выборка.Аванс; 
	Иначе	
		Возврат 0;
	КонецЕсли;
КонецФункции

Процедура УдалитьНезначащиеСтрокиВТочкахПоставок(ТекущийОбъект) Экспорт
	ТЧТочкиПоставок = ТекущийОбъект.ТочкиПоставок;
	ДанныеоТП 		= ТЧТочкиПоставок.Выгрузить();
	ТЧТочкиПоставок.Очистить();
	
	Для Каждого ТекСтрокаТУ из ТекущийОбъект.ТочкиУчета Цикл
		МассивТП = ДанныеоТП.НайтиСтроки(Новый Структура("IDСтроки", ТекСтрокаТУ.IDСтроки));
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(МассивТП, ТЧТочкиПоставок);		
	КонецЦикла;	
КонецПроцедуры

