#Область ПрограммныйИнтерфейс

Процедура ПриЧтенииНаСервере(Форма, ИмяКоллекции) Экспорт 
		
	Коллекция 				= Форма.Объект[ИмяКоллекции];
	Запрос 					= Новый Запрос;
	Запрос.УстановитьПараметр("ДанныеТабЧасти",Коллекция.Выгрузить()); 
	Запрос.Текст 			= 
	"ВЫБРАТЬ
	|	ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|	ДанныеТабЧасти.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ДанныеТабЧасти
	|ИЗ
	|	&ДанныеТабЧасти КАК ДанныеТабЧасти
	|ГДЕ
	|	НЕ ДанныеТабЧасти.ТочкаУчета = ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|	энргТочкиУчета.Наименование КАК НаименованиеТочки,
	|	энргТочкиУчета.Головная КАК Головная,
	|	энргТочкиУчета.Расположение КАК Расположение
	|ИЗ
	|	ДанныеТабЧасти КАК ДанныеТабЧасти
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТочкиУчета КАК энргТочкиУчета
	|		ПО ДанныеТабЧасти.ТочкаУчета = энргТочкиУчета.Ссылка";
	
	Результат  									= Запрос.Выполнить();
	Выборка 									= Результат.Выбрать();
	                       	
	Пока Выборка.Следующий() Цикл
		СтрокаДляЗаполнения 					= Коллекция[Выборка.НомерСтроки - 1];
		ЗаполнитьЗначенияСвойств(СтрокаДляЗаполнения, Выборка,,"НомерСтроки");
	КонецЦикла;
	
	Для Каждого СтрокаТочки Из Коллекция Цикл
		Если ЗначениеЗаполнено(СтрокаТочки.ТочкаУчета) Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТочки.ОписаниеТочки) Тогда
			Продолжить;
		КонецЕсли;
		
		Чтение 									= Новый ЧтениеJSON();
		Чтение.УстановитьСтроку(СтрокаТочки.ОписаниеТочки);
		ОписаниеТочки 							= ПрочитатьJSON(Чтение);
		Для Каждого КлючЗначение Из ОписаниеТочки Цикл
			Если КлючЗначение.Ключ = "Расположение" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргМестаРасположенияТочекУчета.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "Наименование" Тогда
				СтрокаТочки.НаименованиеТочки 	= КлючЗначение.Значение;
			Иначе
				СтрокаТочки[КлючЗначение.Ключ] 	= КлючЗначение.Значение;
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла;	
	
КонецПроцедуры

#Область РаботаСНаборамиЗаписей

Процедура УстановитьВладельцаТочкиУчета(ДанныеШапки,Движения,ИмяКоллекции) Экспорт 
	
	Набор  							= Движения.энргВладельцыТочекУчета;
	для Каждого стр из ДанныеШапки[ИмяКоллекции] цикл
		Запись  					= Набор.добавить();
		Запись.Период  				= ДанныеШапки.Дата;
		Запись.Район  				= ДанныеШапки.район;
		Запись.Организация  		= ДанныеШапки.Организация;
		Запись.ТочкаУчета 			= стр.ТочкаУчета;
		Запись.АбонентВладелец 		= ДанныеШапки.КлючПомещения;
		Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
		Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;
	КонецЦикла;  
	
КонецПроцедуры

