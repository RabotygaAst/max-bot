Процедура ПолучитьВходныеДанныеТабЧастейУзла(ПараметрыПередачи, ТекущийОбъект, СоответствиеТаблиц) Экспорт	
	ИдентификаторФормы = ПараметрыПередачи.ИдентификаторФормы;	
	
	Для Каждого ТекКлючЗначение из СоответствиеТаблиц Цикл
		Если ТекКлючЗначение.Значение = "" тогда
			ПараметрыПередачи[ТекКлючЗначение.Ключ]	= "";
			Продолжить;
		КонецЕсли;
		
		Если НЕ ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ТекущийОбъект,ТекКлючЗначение.Значение) Тогда
			Продолжить;
		КонецЕсли;
				
		ПараметрыПередачи[ТекКлючЗначение.Ключ]	= ПоместитьВоВременноеХранилище(ТекущийОбъект[ТекКлючЗначение.Значение].Выгрузить(), ИдентификаторФормы);
	КонецЦикла; 	
КонецПроцедуры

Процедура ПолучитьДанныеТабЧастейУзла(ПараметрыПередачи, ТекущийОбъект, ВидОперации) Экспорт	
	ПараметрыПередачи.ТочкиУчета 				= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ТочкиУчета.Выгрузить());
	ПараметрыПередачи.Измерители 				= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.Измерители.Выгрузить());
	ПараметрыПередачи.ШкалыИзмерителей			= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ШкалыИзмерителей.Выгрузить());
	ПараметрыПередачи.ШкалыПриборовУчета 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ШкалыПриборовУчета.Выгрузить());
	ПараметрыПередачи.ПоказанияПриборовУчета 	= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ПоказанияПриборовУчета.Выгрузить());	
	ПараметрыПередачи.НомераПломб 				= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.НомераПломб.Выгрузить());	
	
	ПараметрыПередачи.ЗначенияИзмерителей 		= Новый Массив;	
	ПараметрыПередачи.ПоставщикиСоставныхУслуг 	= Новый Массив;
	ПараметрыПередачи.Потери 					= Новый Массив;
	
	Если НЕ ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВводПУ Тогда
		ПараметрыПередачи.ЗначенияИзмерителей 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ЗначенияИзмерителей.Выгрузить());	
		ПараметрыПередачи.ПоставщикиСоставныхУслуг 	= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ПоставщикиСоставныхУслуг.Выгрузить());
		ПараметрыПередачи.Потери 					= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.Потери.Выгрузить());
	КонецЕсли;
		
КонецПроцедуры

