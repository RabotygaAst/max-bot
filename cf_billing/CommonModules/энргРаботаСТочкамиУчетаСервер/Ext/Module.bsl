#Область ОперацииОтключения

Процедура СнятьАктивностьВсехТочекУчетаМКД(Движения,Период,ДанныеШапки) Экспорт 
	
	Запрос  						= Новый Запрос;
	Если ДанныеШапки.свойство("МВТ") тогда
		Запрос.МенеджерВременныхТаблиц 	= ДанныеШапки.МВТ;
	КонецЕсли;
	Запрос.УстановитьПараметр("Период",Период);
	Запрос.УстановитьПараметр("Район",ДанныеШапки.Район);
	Запрос.УстановитьПараметр("Организация",ДанныеШапки.Организация);
	Запрос.УстановитьПараметр("МКД",ДанныеШапки.МКД);
	Запрос.Текст 	="ВЫБРАТЬ
	             	 |	энргАктивностьТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета
	             	 |ПОМЕСТИТЬ АктивныеТочки
	             	 |ИЗ
	             	 |	РегистрСведений.энргАктивностьТочекУчетаМКД.СрезПоследних(
	             	 |			&Период,
	             	 |			Район = &Район
	             	 |				И МКД = &МКД
	             	 |				И Организация = &Организация) КАК энргАктивностьТочекУчетаМКДСрезПоследних
	             	 |ГДЕ
	             	 |	энргАктивностьТочекУчетаМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	             	 |;
	             	 |
	             	 |////////////////////////////////////////////////////////////////////////////////
	             	 |ВЫБРАТЬ
	             	 |	АктивныеТочки.ТочкаУчета КАК ТочкаУчета
	             	 |ИЗ
	             	 |	АктивныеТочки КАК АктивныеТочки";
	Результат 				= Запрос.Выполнить();
	Выборка  				= Результат.Выбрать();
	
	Набор  					= Движения.энргАктивностьТочекУчетаМКД;
	
	Пока Выборка.Следующий() цикл
		Запись 				= Набор.добавить();
		Запись.Период  		= ДанныеШапки.Дата;
		Запись.Район  		= ДанныеШапки.Район;
		Запись.Организация  = ДанныеШапки.Организация;
		Запись.МКД  		= ДанныеШапки.МКД;
		Запись.ТочкаУчета  	= Выборка.ТочкаУчета;
		Запись.Состояние  	= Перечисления.энргСостояниеТочекУчета.Отключена;		
	КонецЦикла;
	
	
КонецПроцедуры

Процедура СнятьАктивностьВсехТочекУчетаАбонента(Движения,Период,ДанныеШапки) Экспорт 
	
	Запрос  						= Новый Запрос;
	Если ДанныеШапки.свойство("МВТ") тогда
		Запрос.МенеджерВременныхТаблиц 	= ДанныеШапки.МВТ;
	КонецЕсли;
	Запрос.УстановитьПараметр("Период",Период);
	Запрос.УстановитьПараметр("Район",ДанныеШапки.Район);
	Запрос.УстановитьПараметр("Организация",ДанныеШапки.Организация);
	Запрос.УстановитьПараметр("КлючПомещения",ДанныеШапки.КлючПомещения);
		
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ АктивныеТочки
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И КлючПомещения = &КлючПомещения
	|				И Организация = &Организация) КАК энргАктивностьТочекУчетаСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктивныеТочки.ТочкаУчета КАК ТочкаУчета
	|ИЗ
	|	АктивныеТочки КАК АктивныеТочки";
	
	Результат 						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	
	Набор  							= Движения.энргАктивностьТочекУчета;
	
	Пока Выборка.Следующий() цикл
		Запись 						= Набор.добавить();
		Запись.Период  				= ДанныеШапки.Дата;
		Запись.Район  				= ДанныеШапки.район;
		Запись.Организация  		= ДанныеШапки.Организация;
		Запись.КлючПомещения  		= ДанныеШапки.КлючПомещения;
		Запись.ТочкаУчета  			= Выборка.ТочкаУчета;
		Запись.Состояние  			= Перечисления.энргСостояниеТочекУчета.Отключена;
		Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
		Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;		
	КонецЦикла;	
	
КонецПроцедуры

