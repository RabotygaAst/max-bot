Процедура УстановитьНаправлениеИспользованияТочекУчета(Движения,ДанныеШапки,ИмяКоллекции) Экспорт
	
	НаправлениеИспользованияТУ = Неопределено;	
	Если НЕ энргОбщегоНазначения.ЗначениеФункциональнойОпции("энргИспользоватьНаправленияИспользованияТУ") Тогда
		НаправлениеИспользованияТУ 				= Справочники.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление;
	КонецЕсли;
		
	Набор  										= Движения.энргНаправлениеИспользованияТочекУчета;
	для Каждого стр из ДанныеШапки[ИмяКоллекции] цикл
		Если ЗначениеЗаполнено(стр.ТочкаУчета) тогда
			Запись  							= Набор.добавить();
			Запись.Период  						= ДанныеШапки.Дата;
			Запись.Район  						= ДанныеШапки.район;
			Запись.Организация  				= ДанныеШапки.Организация;
			Запись.КлючПомещения				= ДанныеШапки.КлючПомещения;
			Запись.ТочкаУчета 					= стр.ТочкаУчета;
			Запись.НаправлениеИспользованияТУ 	= ?(НаправлениеИспользованияТУ = Неопределено,стр.НаправлениеИспользованияТУ, НаправлениеИспользованияТУ);
			Запись.ПериодРегистрации			= ДанныеШапки.ПериодРегистрации;
			Запись.ПериодНачисления				= ДанныеШапки.ПериодНачисления;
		КонецЕсли;
	КонецЦикла; 
	
