Функция ПриборыВыведены(ПараметрыОперации) Экспорт 
	Запрос  =		Новый Запрос;
	Запрос.установитьПараметр("МоментВремени",			ПараметрыОперации.МоментВремени);
	Запрос.установитьПараметр("Район",					ПараметрыОперации.Район);
	Запрос.установитьПараметр("Организация",			ПараметрыОперации.Организация);
	Запрос.установитьПараметр("КлючПомещения",			ПараметрыОперации.КлючПомещения);
	Запрос.установитьПараметр("МассивТочекУчета",		ПараметрыОперации.МассивТочекУчета);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргПриборыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочек
	|ИЗ
	|	РегистрСведений.энргПриборыТочекУчета.СрезПоследних(
	|			&МоментВремени,
	|			Район = &Район
	|				И КлючПомещения = &КлючПомещения
	|				И Организация = &Организация
	|				И ТочкаУчета В (&МассивТочекУчета)) КАК энргПриборыТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовУчетаАбонента.СрезПоследних(
	|			&МоментВремени,
	|			Район = &Район
	|				И КлючПомещения = &КлючПомещения
	|				И Организация = &Организация
	|				И ТочкаУчета В (&МассивТочекУчета)
	|				И (ТочкаУчета, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						ПриборыТочек.ТочкаУчета,
	|						ПриборыТочек.ПриборУчета
	|					ИЗ
	|						ПриборыТочек КАК ПриборыТочек)) КАК энргСостояниеПриборовУчетаАбонентаСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеприборовУчета.Ввод)";
	Результат = Запрос.Выполнить();
	Возврат Результат.Пустой();
КонецФункции

Функция ФормулыРасчетаТочекУчета(ТочкиПоФормуле,Организация,Район,КлючПомещения,Период) Экспорт 
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",				Период);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("КлючПомещения",		КлючПомещения);
	Запрос.УстановитьПараметр("ТочкиПоФормуле",		ТочкиПоФормуле);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	ТочкиПоФормуле.НомерСтроки КАК НомерСтроки,
	|	ТочкиПоФормуле.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ТочкиПоФормуле
	|ИЗ
	|	&ТочкиПоФормуле КАК ТочкиПоФормуле
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
	|	энргКлючиПомещений.Строение КАК Строение,
	|	энргКлючиПомещений.Помещение КАК Помещение,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.Коэффициент КАК Коэффициент
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТочкиПоФормуле.НомерСтроки КАК НомерСтроки,
	|		энргФормулыРасчетаТочекУчетаСрезПоследних.КлючПомещенияИсточник КАК КлючПомещения,
	|		энргФормулыРасчетаТочекУчетаСрезПоследних.ТочкаИсточник КАК ТочкаУчета,
	|		энргФормулыРасчетаТочекУчетаСрезПоследних.Коэффициент КАК Коэффициент
	|	ИЗ
	|		ТочкиПоФормуле КАК ТочкиПоФормуле
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргФормулыРасчетаТочекУчета.СрезПоследних(
	|					&Период,
	|					Организация = &Организация
	|						И Район = &Район
	|						И КлючПомещения = &КлючПомещения
	|						И РассчитываемаяТочка В
	|							(ВЫБРАТЬ
	|								ТочкиПоФормуле.ТочкаУчета
	|							ИЗ
	|								ТочкиПоФормуле КАК ТочкиПоФормуле)) КАК энргФормулыРасчетаТочекУчетаСрезПоследних
	|			ПО ТочкиПоФормуле.ТочкаУчета = энргФормулыРасчетаТочекУчетаСрезПоследних.РассчитываемаяТочка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО ВложенныйЗапрос.КлючПомещения = энргКлючиПомещений.КлючПомещения";
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Процедура ЗаполнитьДанныеДляФормулРасчета(ДокументОбъект) Экспорт  
		Запрос  										= Новый Запрос;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументОбъект.Ссылка);
	Запрос.Текст 									= 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	энргОперацияСЛицевымСчетомТочкиУчета.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.энргОперацияСЛицевымСчетом.ТочкиУчета КАК энргОперацияСЛицевымСчетомТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТочкиУчета КАК энргТочкиУчета
	|		ПО энргОперацияСЛицевымСчетомТочкиУчета.ТочкаУчета = энргТочкиУчета.Ссылка
	|			И (энргТочкиУчета.Головная)
	|			И (энргОперацияСЛицевымСчетомТочкиУчета.Ссылка = &ДокументСсылка)";
	Результат 										= Запрос.Выполнить();
	
	Если Не Результат.Пустой() тогда
		ДокументыПоОснованию 						= КритерииОтбора.СвязанныеДокументы.Найти(ДокументОбъект.ссылка);		
		
		ФормулаПоОснованию 							= Новый Массив;
		
		Для Каждого документ из  ДокументыПоОснованию цикл
			Если ТипЗнч(документ) = Тип("ДокументСсылка.энргУстановитьФормулуРасчетаТочекУчета") тогда
				ФормулаПоОснованию.Добавить(документ);
			КонецЕсли;		
		КонецЦикла; 	
		
		УстановкаФормулыРасчета 					= Новый Структура;
		ДанныеЗаполнения  							= Новый Структура("Район,МКД,Абонент,АдресОбъекта,ЛицевойСчет,Дата,ДатаФактическогоСобытия,ПериодНачисления");
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, ДокументОбъект);
		ДанныеЗаполнения.Дата 						= ДокументОбъект.Дата + 1;
		ДанныеЗаполнения.Вставить("ДокументОснование",ДокументОбъект.ссылка);		
		Если ФормулаПоОснованию.Количество() > 1 тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Найдено более одного документа установки формулы расчета");
		ИначеЕсли ФормулаПоОснованию.Количество() = 0 тогда
			УстановкаФормулыРасчета.Вставить("ДанныеЗаполнения",	ДанныеЗаполнения);
		иначе
			УстановкаФормулыРасчета.Вставить("Ключ",				ФормулаПоОснованию[0]);
			УстановкаФормулыРасчета.Вставить("ДанныеЗаполнения",	ДанныеЗаполнения);
		КонецЕсли;
		ДокументОбъект.ДополнительныеСвойства.вставить("УстановкаФормулыРасчета",УстановкаФормулыРасчета);		
	КонецЕсли;
КонецПроцедуры

Функция ЗадолженностьАбонента(Период,Организация,Район,Дом,Абонент) Экспорт  
	Запрос   		= Новый Запрос;
	Запрос.УстановитьПараметр("Период" ,Период);
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.УстановитьПараметр("Район",Район);
	Запрос.УстановитьПараметр("МКД",Дом);
	Запрос.УстановитьПараметр("Абонент",Абонент);
	Запрос.Текст 	="ВЫБРАТЬ
	             	 |	энргВзаиморасчетыОстатки.СуммаОстаток КАК Задолженность
	             	 |ИЗ
	             	 |	РегистрНакопления.энргВзаиморасчеты.Остатки(
	             	 |			&Период,
	             	 |			Организация = &Организация
	             	 |				И Район = &Район
	             	 |				И МКД = &МКД
	             	 |				И Абонент = &Абонент) КАК энргВзаиморасчетыОстатки";
	
	Результат  = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Задолженность = Выборка.Задолженность;
	Иначе
		Задолженность = 0;
	КонецЕсли;
	
	Возврат Задолженность;
	
КонецФункции

Функция ФиксированныеОбъемыРазделенныхЛС(ДокументСсылка)
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	ТаблицаАбоненты.ТочкаУчета КАК ТочкаУчета,
	|	ТаблицаФиксОбъемы.ФиксированныйОбъемПотребления КАК ОбъемПотребления,
	|	ТаблицаАбоненты.КлючПомещения КАК КлючПомещения
	|ИЗ
	|	Документ.энргСоглашениеОПотребленииВПомещении.Абоненты КАК ТаблицаАбоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргСоглашениеОПотребленииВПомещении.ФиксированныеОбъемы КАК ТаблицаФиксОбъемы
	|		ПО ТаблицаАбоненты.Ссылка = ТаблицаФиксОбъемы.Ссылка
	|			И (ТаблицаАбоненты.Ссылка = &ДокументСсылка)
	|			И (ТаблицаФиксОбъемы.Ссылка = &ДокументСсылка)
	|			И ТаблицаАбоненты.IDСтроки = ТаблицаФиксОбъемы.IDСтроки";
	
	Возврат Запрос.Выполнить();
	
КонецФункции

