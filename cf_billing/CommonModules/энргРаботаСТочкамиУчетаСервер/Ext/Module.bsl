Процедура ОчиститьДанныеПоПотерям(Потери) Экспорт
	Для Каждого ТекСтрока из Потери Цикл
		ТекСтрока.ДанныеПотерь = "";		
	КонецЦикла; 	
КонецПроцедуры

Процедура ЗаполнитьДанныеПоПотерям(Потери) Экспорт	
	Потери.Сортировать("IDСтроки");
	
	ТекIDСтроки = Неопределено;
	Для Каждого ТекСтрока из Потери Цикл
		Если НЕ ТекIDСтроки = ТекСтрока.IDСтроки тогда
			МассивСтрок 			= Потери.НайтиСтроки(Новый Структура("IDСтроки", ТекСтрока.IDСтроки));
			ТекСтрока.ДанныеПотерь 	= ПреобразоватьПотериВJSON(МассивСтрок);
		КонецЕсли;
		
		ТекIDСтроки = ТекСтрока.IDСтроки;
	КонецЦикла;
КонецПроцедуры

Функция ПреобразоватьПотериВJSON(Потери) Экспорт
	
	ДанныеПотерь 		= Новый Массив;
	ОписаниеСтроки		= "ВидПотерь, СпособРасчетаПотерь, Значение";		
		
	Для Каждого ТекСтрока из Потери Цикл
		НоваяСтрока 					= Новый Структура(ОписаниеСтроки);
		НоваяСтрока.ВидПотерь 			= "" + ТекСтрока.ВидПотерь.УникальныйИдентификатор();
		НоваяСтрока.СпособРасчетаПотерь = ?(ТекСтрока.ПроцентПотерь > 0, "Процент", "ФиксированныйОбъем");
		НоваяСтрока.Значение 			= ?(ТекСтрока.ПроцентПотерь > 0, ТекСтрока.ПроцентПотерь, ТекСтрока.ФиксированныйОбъемПотерь);	
		
		ДанныеПотерь.Добавить(НоваяСтрока);
	КонецЦикла;	
	
	Если НЕ ДанныеПотерь.Количество() = 0 Тогда
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();  
		ЗаписатьJSON(ЗаписьJSON, ДанныеПотерь);            
		Результат = ЗаписьJSON.Закрыть();
	Иначе 
		Результат = "";
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции

Функция ПолучитьПотериИзJSON(СтрокаJSON) Экспорт	
	Чтение 		= Новый ЧтениеJSON();
	Чтение.УстановитьСтроку(СтрокаJSON);
	Описание 	= ПрочитатьJSON(Чтение);
	
	Возврат Описание;
КонецФункции

Функция ПолучитьОбъемПотерь(ОбщийОбъем, Потери, СтруктураОтбора = Неопределено) Экспорт
	ОбъемПотерь 		= 0;
	МенеджерСпособов 	= Перечисления.энргСпособыРасчетаПотерь;
	Процент 			= МенеджерСпособов.Процент;
	
	Если СтруктураОтбора = Неопределено	Тогда
		Для Каждого ТекСтрока из Потери Цикл
			ОбъемПотерь = ОбъемПотерь + РассчитатьОбъемПотерьПоСтроке(ОбщийОбъем, ТекСтрока, МенеджерСпособов);
		КонецЦикла;
	Иначе 
		ТекСтрока = Потери.Выбрать();
		Пока ТекСтрока.НайтиСледующий(СтруктураОтбора) Цикл
			ОбъемПотерь = ОбъемПотерь + РассчитатьОбъемПотерьПоСтроке(ОбщийОбъем, ТекСтрока, МенеджерСпособов);
		КонецЦикла; 		
	КонецЕсли;
	
	Возврат ОбъемПотерь;
КонецФункции

#КонецОбласти

Процедура ЗначенияТарифовУслугАбонентовВоВременную(МВТ, Схема,Параметры,Организация,МоментВремени,мРайоны,мКлючиПомещений) Экспорт 
	
	яСхема 												= Новый СхемаЗапроса;
	
	ЕстьГруппыПотребителейАбонентов	 					= Ложь;
	Если НЕ Схема = Неопределено Тогда
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "ГруппыПотребителейАбонентов" Тогда
				ЕстьУслугиТочекУчета 					= Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
	КонецЕсли;
	
	Если НЕ ЕстьГруппыПотребителейАбонентов Тогда
		РегистрыСведений.энргГруппыПотребителейАбонентов.ГруппыПотребителейАбонентов(яСхема, Параметры,"ГруппыПотребителейАбонентов");
	КонецЕсли;
	
	ЕстьПоставщикиУслугАбонента 						= Ложь;
	Если НЕ Схема = Неопределено Тогда
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "ПоставщикиУслугАбонента" Тогда
				ЕстьУслугиТочекУчета 					= Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
	КонецЕсли;
	
	Если НЕ ЕстьГруппыПотребителейАбонентов Тогда
		РегистрыСведений.энргПоставщикиУслугАбонента.ПоставщикиУслугАбонента(яСхема, Параметры,"ПоставщикиУслугАбонента");
	КонецЕсли;
	 	
	ЕстьЗначенияТарифовНабор	 						= Ложь;
	Если НЕ Схема = Неопределено Тогда
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "ЗначенияТарифовНабор" Тогда
				ЕстьУслугиТочекУчета 					= Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
	КонецЕсли;
	
	Если НЕ ЕстьЗначенияТарифовНабор Тогда
		РегистрыСведений.энргЗначенияТарифов.ЗначенияТарифов(яСхема, Параметры,"ЗначенияТарифовНабор");
	КонецЕсли;
		
	Пакет  												= яСхема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаЗначенияТарифовУслугАбонентов());
	
	Запрос  											= Новый Запрос(яСхема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("Организация", 			Организация);
	Запрос.УстановитьПараметр("Период",					МоментВремени);
	Если мРайоны.Количество() = 1 Тогда
		Запрос.УстановитьПараметр("мРайоны",			мРайоны[0]);
	Иначе
		Запрос.УстановитьПараметр("мРайоны",			мРайоны);
	КонецЕсли;
	
	Если мКлючиПомещений.Количество() = 1 Тогда
		Запрос.УстановитьПараметр("мКлючПомещений",		мКлючиПомещений[0]);
	Иначе
		Запрос.УстановитьПараметр("мКлючПомещений",		мКлючиПомещений);
	КонецЕсли;
	
	ТаблицаЗначенийТарифовТочекУчета  					= Новый ТаблицаЗначений;
	ТаблицаЗначенийТарифовТочекУчета.Колонки.Добавить("Организация", 					Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ТаблицаЗначенийТарифовТочекУчета.Колонки.Добавить("Район", 							Новый ОписаниеТипов("СправочникСсылка.энргЗоныОтвественности"));
	ТаблицаЗначенийТарифовТочекУчета.Колонки.Добавить("КлючПомещения", 					Новый ОписаниеТипов("СправочникСсылка.энргКлючиПомещений"));
	ТаблицаЗначенийТарифовТочекУчета.Колонки.Добавить("ТочкаУчета", 					Новый ОписаниеТипов("СправочникСсылка.энргТочкиУчета"));
	ТаблицаЗначенийТарифовТочекУчета.Колонки.Добавить("ТарифнаяЗона", 					Новый ОписаниеТипов("СправочникСсылка.энргТарифныеЗоны"));
	ТаблицаЗначенийТарифовТочекУчета.Колонки.Добавить("ЗначениеТарифа", 				Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));
	ТаблицаЗначенийТарифовТочекУчета.Колонки.Добавить("ПредставлениеЗначениеТарифа", 	Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(15)));
	 	
	Результат  												= Запрос.Выполнить();
	Выборка 												= Результат.Выбрать();
	ТекОрганизация 											= Неопределено;
	ТекРайон 												= Неопределено;
	ТекКлючПомещения 										= Неопределено;
	ТекТочкаУчета 											= Неопределено;	
	ТекТарифнаяЗона											= Неопределено;
	ЗначениеТарифа 											= 0;
	ПредставлениеЗначениеТарифа 							= "";
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ТекОрганизация = Выборка.Организация
			ИЛИ НЕ ТекРайон = Выборка.Район
			ИЛИ НЕ ТекКлючПомещения = Выборка.КлючПомещения 
			ИЛИ НЕ ТекТочкаУчета = Выборка.ТочкаУчета 
			ИЛИ НЕ ТекТарифнаяЗона = Выборка.ТарифнаяЗона Тогда
				
			Если Не ТекОрганизация = Неопределено Тогда
				СтрокаЗначения 								= ТаблицаЗначенийТарифовТочекУчета.Добавить();
				СтрокаЗначения.Организация 					= ТекОрганизация;
				СтрокаЗначения.Район 						= ТекРайон;
				СтрокаЗначения.КлючПомещения 				= ТекКлючПомещения;
				СтрокаЗначения.ТочкаУчета 					= ТекТочкаУчета;
				СтрокаЗначения.ТарифнаяЗона 				= ТекТарифнаяЗона;
				СтрокаЗначения.ЗначениеТарифа 				= ЗначениеТарифа;
				СтрокаЗначения.ПредставлениеЗначениеТарифа 	= ПредставлениеЗначениеТарифа;				
			КонецЕсли;
						
			ЗначениеТарифа 									= 0;
			ПредставлениеЗначениеТарифа 					= "";			
		КонецЕсли;
		
		ЗначениеТарифа 										= ЗначениеТарифа + Выборка.Значение;
		ПредставлениеЗначениеТарифа 						= ПредставлениеЗначениеТарифа + ?(ПустаяСтрока(ПредставлениеЗначениеТарифа),"","/") + Формат(Выборка.Значение,"ЧРГ=; ЧГ=0");
		
		ТекОрганизация 										= Выборка.Организация;
		ТекРайон 											= Выборка.Район;
		ТекКлючПомещения 									= Выборка.КлючПомещения;
		ТекТочкаУчета	 									= Выборка.ТочкаУчета;
		ТекТарифнаяЗона										= Выборка.ТарифнаяЗона;
	КонецЦикла;
	
	Если Не ТекОрганизация = Неопределено Тогда
		СтрокаЗначения 										= ТаблицаЗначенийТарифовТочекУчета.Добавить();
		СтрокаЗначения.Организация 							= ТекОрганизация;
		СтрокаЗначения.Район 								= ТекРайон;
		СтрокаЗначения.КлючПомещения 						= ТекКлючПомещения;
		СтрокаЗначения.ТочкаУчета 							= ТекТочкаУчета;
		СтрокаЗначения.ТарифнаяЗона 						= ТекТарифнаяЗона;
		СтрокаЗначения.ЗначениеТарифа 						= ЗначениеТарифа;
		СтрокаЗначения.ПредставлениеЗначениеТарифа 			= ПредставлениеЗначениеТарифа;				
	КонецЕсли;
		
	Запрос  												= Новый Запрос();
	Запрос.МенеджерВременныхТаблиц 							= МВТ;
	Запрос.УстановитьПараметр("ТаблицаЗначенийТарифовТочекУчета", ТаблицаЗначенийТарифовТочекУчета);
	Запрос.Текст 											=
	"ВЫБРАТЬ
	|	ТаблицаЗначенийТарифовТочекУчета.Организация КАК Организация,
	|	ТаблицаЗначенийТарифовТочекУчета.Район КАК Район,
	|	ТаблицаЗначенийТарифовТочекУчета.КлючПомещения КАК КлючПомещения,
	|	ТаблицаЗначенийТарифовТочекУчета.ТочкаУчета КАК ТочкаУчета,
	|	ТаблицаЗначенийТарифовТочекУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТаблицаЗначенийТарифовТочекУчета.ЗначениеТарифа КАК ЗначениеТарифа,
	|	ТаблицаЗначенийТарифовТочекУчета.ПредставлениеЗначениеТарифа КАК ПредставлениеЗначениеТарифа
	|ПОМЕСТИТЬ ТаблицаЗначенийТарифовТочекУчета
	|ИЗ
	|	&ТаблицаЗначенийТарифовТочекУчета КАК ТаблицаЗначенийТарифовТочекУчета";
	
	Запрос.Выполнить();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция РассчитатьОбъемПотерьПоСтроке(ОбщийОбъем, ТекСтрока, МенеджерСпособов)
	Возврат ?(ТекСтрока.СпособРасчетаПотерь = МенеджерСпособов.Процент, ОбщийОбъем * (ТекСтрока.Значение / 100), ТекСтрока.Значение);
КонецФункции

Функция ЗаполнитьЭлемент(ТочкаОбъект,ДанныеТочки)
	ЗаполнитьЗначенияСвойств(ТочкаОбъект,ДанныеТочки);
	ТочкаОбъект.Записать();
	Возврат ТочкаОбъект.Ссылка;
КонецФункции

Функция ТекстЗапросаЗначенияТарифовУслугАбонентов() 
	
	Текст  =
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.ЧастьСоставной КАК ЧастьСоставной,
	|	ВложенныйЗапрос.Поставщик КАК Поставщик,
	|	ЗначенияТарифовНабор.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ЗначенияТарифовНабор.Значение КАК Значение
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПоставщикиУслугАбонента.Организация КАК Организация,
	|		ПоставщикиУслугАбонента.Район КАК Район,
	|		ПоставщикиУслугАбонента.КлючПомещения КАК КлючПомещения,
	|		ПоставщикиУслугАбонента.ТочкаУчета КАК ТочкаУчета,
	|		ПоставщикиУслугАбонента.Услуга КАК Услуга,
	|		ПоставщикиУслугАбонента.ЧастьСоставной КАК ЧастьСоставной,
	|		ПоставщикиУслугАбонента.Поставщик КАК Поставщик,
	|		ГруппыПотребителейАбонентов.ГруппаПотребителей КАК ГруппаПотребителей
	|	ИЗ
	|		ПоставщикиУслугАбонента КАК ПоставщикиУслугАбонента
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ГруппыПотребителейАбонентов КАК ГруппыПотребителейАбонентов
	|			ПО ПоставщикиУслугАбонента.Организация = ГруппыПотребителейАбонентов.Организация
	|				И ПоставщикиУслугАбонента.Район = ГруппыПотребителейАбонентов.Район
	|				И ПоставщикиУслугАбонента.КлючПомещения = ГруппыПотребителейАбонентов.КлючПомещения
	|				И ПоставщикиУслугАбонента.Услуга = ГруппыПотребителейАбонентов.Услуга) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗначенияТарифовНабор КАК ЗначенияТарифовНабор
	|		ПО ВложенныйЗапрос.Организация = ЗначенияТарифовНабор.Организация
	|			И ВложенныйЗапрос.Район = ЗначенияТарифовНабор.Район
	|			И ВложенныйЗапрос.ГруппаПотребителей = ЗначенияТарифовНабор.ГруппаПотребителей
	|			И ВложенныйЗапрос.Услуга = ЗначенияТарифовНабор.Услуга
	|			И ВложенныйЗапрос.Поставщик = ЗначенияТарифовНабор.Поставщик
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Район,
	|	КлючПомещения,
	|	ТочкаУчета,
	|	ТарифнаяЗона";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти