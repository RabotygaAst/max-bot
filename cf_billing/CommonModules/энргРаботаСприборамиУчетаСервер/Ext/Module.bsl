	|		ТаблицаДокумента.Теплоисточник КАК Теплоисточник,
	|		ТаблицаДокумента.ПериодНачисления КАК ПериодНачисления,
	|		ТаблицаПриборовУчета.ТочкаУчета КАК ТочкаУчета
	|	ИЗ
	|		Документ.энргНачислениеТеплоисточника.ТочкиУчета КАК ТаблицаПриборовУчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргНачислениеТеплоисточника.ШкалыПриборовУчета КАК ТаблицаШкал
	|			ПО ТаблицаПриборовУчета.Ссылка = ТаблицаШкал.Ссылка
	|				И ТаблицаПриборовУчета.IDСтроки = ТаблицаШкал.IDСтрокиТочкиУчета
	|				И (ТаблицаПриборовУчета.Ссылка = &ДокументСсылка)
	|				И (ТаблицаШкал.Ссылка = &ДокументСсылка)
	|				И (НЕ ТаблицаПриборовУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргНачислениеТеплоисточника КАК ТаблицаДокумента
	|			ПО ТаблицаПриборовУчета.Ссылка = ТаблицаДокумента.Ссылка
	|				И (ТаблицаПриборовУчета.Ссылка = &ДокументСсылка)
	|				И (ТаблицаДокумента.Ссылка = &ДокументСсылка)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ТаблицаПриборовУчета.ПриборУчета,
	|		ТаблицаШкал.Шкала,
	|		ТаблицаШкал.IDСтроки,
	|		ТаблицаПриборовУчета.Ссылка,
	|		ТаблицаДокумента.Теплоисточник,
	|		ТаблицаДокумента.Район,
	|		ТаблицаДокумента.ПериодНачисления,
	|		ТаблицаПриборовУчета.ТочкаУчета,
	|		ТаблицаДокумента.Организация) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргНачислениеТеплоисточника.ПоказанияПриборовУчета КАК ТаблицаПоказанийПриборовУчета
	|		ПО ВложенныйЗапрос.Ссылка = ТаблицаПоказанийПриборовУчета.Ссылка
	|			И ВложенныйЗапрос.IDСтроки = ТаблицаПоказанийПриборовУчета.IDСтроки
	|			И (ТаблицаПоказанийПриборовУчета.Ссылка = &ДокументСсылка)";
	
	Возврат Запрос.Выполнить();  	
КонецФункции 

Процедура ПолучитьДанныеТипаУзлаУчета(ПараметрыПередачи,ТипУзлаУчета,IDСтроки,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",ТипУзлаУчета);
	Запрос.УстановитьПараметр("IDСтроки",IDСтроки);
	Запрос.УстановитьПараметр("НачалоДействияКоммерскогоУчета",НачалоДействияКоммерскогоУчета);
	Запрос.УстановитьПараметр("КонецДействияКоммерскогоУчета",КонецДействияКоммерскогоУчета);
	Запрос.Текст = "ВЫБРАТЬ
	               |	энргТипыУзловУчетаСоставУзла.НомерСтроки КАК НомерСтроки,
	               |	энргТипыУзловУчетаСоставУзла.ТипИзмерителя КАК ВидИзмерителя,
	               |	&IDСтроки КАК IDСтроки,
	               |	энргТипыУзловУчетаСоставУзла.РасположениеИзмерителя КАК РасположениеИзмерителя,
	               |	энргТипыУзловУчетаСоставУзла.РегистрируетОбъем КАК РегистрируетОбъем,
	               |	&НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	               |	&КонецДействияКоммерскогоУчета КАК КонецДействияКоммерскогоУчета,
	               |	энргТипыУзловУчетаСоставУзла.IDСтроки КАК IDСтрокиШкалы,
	               |	энргТипыУзловУчета.ВидКанальности КАК ВидКанальности
	               |ИЗ
	               |	Справочник.энргТипыУзловУчета.СоставУзла КАК энргТипыУзловУчетаСоставУзла
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТипыУзловУчета КАК энргТипыУзловУчета
	               |		ПО энргТипыУзловУчетаСоставУзла.Ссылка = энргТипыУзловУчета.Ссылка
	               |ГДЕ
	               |	энргТипыУзловУчетаСоставУзла.Ссылка = &Ссылка
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	НомерСтроки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	&IDСтроки КАК IDСтрокиТочкиУчета,
	               |	энргТипыУзловУчетаШкалыТипаИзмерителя.Шкала КАК Шкала,
	               |	энргТипыУзловУчетаСоставУзла.IDСтроки КАК IDСтроки
	               |ИЗ
	               |	Справочник.энргТипыУзловУчета.СоставУзла КАК энргТипыУзловУчетаСоставУзла
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТипыУзловУчета.ШкалыТипаИзмерителя КАК энргТипыУзловУчетаШкалыТипаИзмерителя
	               |		ПО энргТипыУзловУчетаСоставУзла.Ссылка = энргТипыУзловУчетаШкалыТипаИзмерителя.Ссылка
	               |			И энргТипыУзловУчетаСоставУзла.IDСтроки = энргТипыУзловУчетаШкалыТипаИзмерителя.IDСтроки
	               |ГДЕ
	               |	энргТипыУзловУчетаСоставУзла.Ссылка = &Ссылка";
	Результат = Запрос.ВыполнитьПакет();
	СоставУзла 		= Результат[0].Выгрузить();
	ШкалыУзловУчета = Результат[1].Выгрузить();
	
	ПараметрыПередачи.Вставить("ПриборыУзловУчета", ОбщегоНазначения.ТаблицаЗначенийВМассив(СоставУзла));
	ПараметрыПередачи.Вставить("ШкалыПриборовУчета", ОбщегоНазначения.ТаблицаЗначенийВМассив(ШкалыУзловУчета));
КонецПроцедуры

#КонецОбласти