	Результат  = Запрос.ВыполнитьПакет();
	ИндексПоследнегоПакета = Результат.ВГраница();
	РезультатТП = Результат.Получить(ИндексПоследнегоПакета - 1);
	Возврат Результат.Получить(ИндексПоследнегоПакета);
	
КонецФункции

// Проверяет запонены ли реквизиты прибора.
//
// Параметры:
//  ОбъектФормы		-	ФормаКлиентскогоПриложения.
//  ИмяКоллекции	-	Строка.
//  ПредставлениеТЧ	-	Строка.
//  Отказ			-	Булево.
//  РеквизитыТЧ		-	Массив из Строк.
//
Процедура РеквизитыПрибораЗаполнены(ОбъектФормы,ИмяКоллекции,ПредставлениеТЧ,Отказ,РеквизитыТЧ) Экспорт
	
	ТабличнаяЧасть 					= ОбъектФормы[ИмяКоллекции];
	ИндексСтроки 					= 0;
	Для Каждого стр из ТабличнаяЧасть Цикл 					
		Для Сч = 0 По РеквизитыТЧ.ВГраница() Цикл
			Если НЕ ЗначениеЗаполнено(стр[РеквизитыТЧ[Сч]]) тогда
				Отказ 				= Истина;				
				ПутьКДанным 		= "Объект." + ИмяКоллекции + "["+ИндексСтроки+"]." + РеквизитыТЧ[Сч] +"";
				ШаблонСооющения 	= НСтр("ru='Поле ""%1"" табличной части %2 обязательно для заполнения'");
				Текст 				= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонСооющения, РеквизитыТЧ[Сч], ПредставлениеТЧ);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,ПутьКДанным);				
			КонецЕсли;  			
		КонецЦикла;		
		ИндексСтроки 				= ИндексСтроки + 1;		 
	КонецЦикла; 
	
КонецПроцедуры

// Возвращает тарифные зоны текущего вида дифференцированности.
//
// Параметры:
//  ВидДифферинцированности		-	СправочникСсылка.энргВидыДифференцированности.
// 
// Возвращаемое значение:
//  ТаблицаЗначений	-	тарифные зоны текущего вида дифференцированности.
//
Функция ПолучитьТарифныеЗоныПоВидуДифференцированности(ВидДифферинцированности) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидДифференцированности", ВидДифферинцированности);
	Запрос.Текст = "ВЫБРАТЬ
	               |	энргВидыДиффиринцированностиПУСписокТарифныхЗон.ТарифнаяЗона КАК ТарифнаяЗона
	               |ИЗ
	               |	Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДиффиринцированностиПУСписокТарифныхЗон
	               |ГДЕ
	               |	энргВидыДиффиринцированностиПУСписокТарифныхЗон.Ссылка = &ВидДифференцированности
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	энргВидыДиффиринцированностиПУСписокТарифныхЗон.ТарифнаяЗона";
	Результат = Запрос.Выполнить();
	Выгрузка  = Результат.Выгрузить();
	Возврат Выгрузка;
КонецФункции

// Удаляет строки в тарифной зоне по ключу.
//
// Параметры:
//  Ключ	-	УникальныйИдентификатор.
//  ТЧ		-	ДанныеФормыКоллекция.
//
Процедура УдалитьСтрокиВТарифныеЗоныПоКлючу(Ключ, ТЧ) Экспорт
	Отбор = Новый Структура("IDСтроки", Ключ);
	ИщемСтроки = ТЧ.НайтиСтроки(Отбор);
	Если ИщемСтроки.Количество() > 0 Тогда
		Для НайденнаяСтрока = 0 по ИщемСтроки.Количество()-1 Цикл
			ТЧ.Удалить(ИщемСтроки[НайденнаяСтрока]);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

// Возвращает корректен ли состав узла МКД.
//
// Параметры:
//  ПараметрыЗапроса	-	 Стуктура.
// 
// Возвращаемое значение:
//   Булево.
//
Функция СоставУзлаКорректенМКД(ПараметрыЗапроса) Экспорт  	
		
	Запрос = Новый Запрос;
	Для Каждого ТекПараметр из ПараметрыЗапроса Цикл
		Запрос.УстановитьПараметр(ТекПараметр.Ключ,ТекПараметр.Значение);
	КонецЦикла;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаТочекУчета.НомерСтроки КАК НомерСтроки,
		|	ТаблицаТочекУчета.ТипУзлаУчета КАК ТипУзлаУчета,
		|	ТаблицаТочекУчета.IDСтроки КАК IDСтроки,
		|	ТаблицаТочекУчета.ТочкаУчета КАК ТочкаУчета,
		|	ТаблицаТочекУчета.ПриборУчета КАК УзелУчета,
		|	ТаблицаТочекУчета.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ТипыУзлов
		|ИЗ
		|	Документ.энргОткрытиеМКД.ТочкиУчета КАК ТаблицаТочекУчета
		|ГДЕ
		|	НЕ ТаблицаТочекУчета.ТипУзлаУчета = ЗНАЧЕНИЕ(Справочник.энргТипыУзловУчета.ПустаяСсылка)
		|	И ТаблицаТочекУчета.Ссылка = &Ссылка
		|	И НЕ ТаблицаТочекУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТаблицаТочекУчета.НомерСтроки,
		|	ТаблицаТочекУчета.ТипУзлаУчета,
		|	ТаблицаТочекУчета.IDСтроки,
		|	ТаблицаТочекУчета.ТочкаУчета,
		|	ТаблицаТочекУчета.ПриборУчета,
		|	ТаблицаТочекУчета.Ссылка
		|ИЗ
		|	Документ.энргОперацияСУслугамиМКД.ТочкиУчета КАК ТаблицаТочекУчета
		|ГДЕ
		|	НЕ ТаблицаТочекУчета.ТипУзлаУчета = ЗНАЧЕНИЕ(Справочник.энргТипыУзловУчета.ПустаяСсылка)
		|	И ТаблицаТочекУчета.Ссылка = &Ссылка
		|	И НЕ ТаблицаТочекУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТаблицаТочекУчета.НомерСтроки,
		|	ТаблицаТочекУчета.ТипУзлаУчета,
		|	ТаблицаТочекУчета.IDСтроки,
		|	ТаблицаТочекУчета.ТочкаУчета,
		|	ТаблицаТочекУчета.ПриборУчета,
		|	ТаблицаТочекУчета.Ссылка
		|ИЗ
		|	Документ.энргОперацияСПриборомУчетаМКД.ТочкиУчета КАК ТаблицаТочекУчета
		|ГДЕ
		|	НЕ ТаблицаТочекУчета.ТипУзлаУчета = ЗНАЧЕНИЕ(Справочник.энргТипыУзловУчета.ПустаяСсылка)
		|	И ТаблицаТочекУчета.Ссылка = &Ссылка
		|	И НЕ ТаблицаТочекУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.ТипУзлаУчета КАК ТипУзлаУчета,
		|	энргТипыУзловУчетаСоставУзла.ТипИзмерителя КАК ТипПрибораУчета
		|ПОМЕСТИТЬ ВТ_ЭталонныйСоставУзла
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТ_ТипыУзлов.ТипУзлаУчета КАК ТипУзлаУчета
		|	ИЗ
		|		ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТ_ТипыУзлов.ТипУзлаУчета) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТипыУзловУчета.СоставУзла КАК энргТипыУзловУчетаСоставУзла
		|		ПО ВложенныйЗапрос.ТипУзлаУчета = энргТипыУзловУчетаСоставУзла.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
		|	ВложенныйЗапрос.ТипУзлаУчета КАК ТипУзлаУчета,
		|	ВложенныйЗапрос.IDСтроки КАК IDСтроки,
		|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
		|	ВложенныйЗапрос.УзелУчета КАК УзелУчета,
		|	ВложенныйЗапрос.ТипПрибораУчета КАК ТипПрибораУчета,
		|	ВложенныйЗапрос.Колво КАК Колво
		|ПОМЕСТИТЬ ВТ_СоставУзлаСТочками
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТ_ТипыУзлов.НомерСтроки КАК НомерСтроки,
		|		ВТ_ТипыУзлов.ТипУзлаУчета КАК ТипУзлаУчета,
		|		ВТ_ТипыУзлов.IDСтроки КАК IDСтроки,
		|		ВТ_ТипыУзлов.ТочкаУчета КАК ТочкаУчета,
		|		ВТ_ТипыУзлов.УзелУчета КАК УзелУчета,
		|		ВТ_ЭталонныйСоставУзла.ТипПрибораУчета КАК ТипПрибораУчета,
		|		СУММА(1) КАК Колво
		|	ИЗ
		|		ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЭталонныйСоставУзла КАК ВТ_ЭталонныйСоставУзла
		|			ПО ВТ_ТипыУзлов.ТипУзлаУчета = ВТ_ЭталонныйСоставУзла.ТипУзлаУчета
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТ_ТипыУзлов.ТипУзлаУчета,
		|		ВТ_ТипыУзлов.УзелУчета,
		|		ВТ_ТипыУзлов.ТочкаУчета,
		|		ВТ_ТипыУзлов.IDСтроки,
		|		ВТ_ЭталонныйСоставУзла.ТипПрибораУчета,
		|		ВТ_ТипыУзлов.НомерСтроки) КАК ВложенныйЗапрос
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
		|	ВложенныйЗапрос.ТипУзлаУчета КАК ТипУзлаУчета,
		|	ВложенныйЗапрос.IDСтроки КАК IDСтроки,
		|	ВложенныйЗапрос.ТипПрибораУчетаРодитель КАК ТипПрибораУчетаРодитель,
		|	СУММА(ВложенныйЗапрос.Колво) КАК Колво
		|ПОМЕСТИТЬ ВТ_СоставУзлаВДокументе
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТ_ТипыУзлов.НомерСтроки КАК НомерСтроки,
		|		ВТ_ТипыУзлов.ТипУзлаУчета КАК ТипУзлаУчета,
		|		ВТ_ТипыУзлов.IDСтроки КАК IDСтроки,
		|		ТаблицаПриборыУзловУчета.ТипПрибораУчета.Родитель КАК ТипПрибораУчетаРодитель,
		|		1 КАК Колво
		|	ИЗ
		|		ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОткрытиеМКД.ПриборыУзловУчета КАК ТаблицаПриборыУзловУчета
		|			ПО ВТ_ТипыУзлов.Ссылка = ТаблицаПриборыУзловУчета.Ссылка
		|				И (ТаблицаПриборыУзловУчета.Ссылка = &Ссылка)
		|				И ВТ_ТипыУзлов.IDСтроки = ТаблицаПриборыУзловУчета.IDСтроки
		|				И (НЕ ТаблицаПриборыУзловУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ВТ_ТипыУзлов.НомерСтроки,
		|		ВТ_ТипыУзлов.ТипУзлаУчета,
		|		ВТ_ТипыУзлов.IDСтроки,
		|		ТаблицаПриборыУзловУчета.ТипПрибораУчета.Родитель,
		|		1
		|	ИЗ
		|		ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугамиМКД.ПриборыУзловУчета КАК ТаблицаПриборыУзловУчета
		|			ПО ВТ_ТипыУзлов.Ссылка = ТаблицаПриборыУзловУчета.Ссылка
		|				И (ТаблицаПриборыУзловУчета.Ссылка = &Ссылка)
		|				И ВТ_ТипыУзлов.IDСтроки = ТаблицаПриборыУзловУчета.IDСтроки
		|				И (НЕ ТаблицаПриборыУзловУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ВложенныйЗапрос.НомерСтроки,
		|		ВложенныйЗапрос.ТипУзлаУчета,
		|		ВложенныйЗапрос.IDСтроки,
		|		ВложенныйЗапрос.ТипПрибораУчетаРодитель,
		|		1
		|	ИЗ
		|		(ВЫБРАТЬ
		|			ВТ_ТипыУзлов.НомерСтроки КАК НомерСтроки,
		|			ВТ_ТипыУзлов.ТипУзлаУчета КАК ТипУзлаУчета,
		|			ВТ_ТипыУзлов.IDСтроки КАК IDСтроки,
		|			ТаблицаПриборыУзловУчета.ТипПрибораУчета.Родитель КАК ТипПрибораУчетаРодитель
		|		ИЗ
		|			ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСПриборомУчетаМКД.ПриборыУзловУчета КАК ТаблицаПриборыУзловУчета
		|				ПО ВТ_ТипыУзлов.Ссылка = ТаблицаПриборыУзловУчета.Ссылка
		|					И (ТаблицаПриборыУзловУчета.Ссылка = &Ссылка)
		|					И ВТ_ТипыУзлов.IDСтроки = ТаблицаПриборыУзловУчета.IDСтроки
		|					И (НЕ ТаблицаПриборыУзловУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|		
		|		ОБЪЕДИНИТЬ ВСЕ
		|		
		|		ВЫБРАТЬ
		|			ВТ_ТипыУзлов.НомерСтроки,
		|			ВТ_ТипыУзлов.ТипУзлаУчета,
		|			ВТ_ТипыУзлов.IDСтроки,
		|			энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ТипИзмерителя
		|		ИЗ
		|			ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСостояниеПриборовУзловУчетаМКД.СрезПоследних(
		|						&Период,
		|						Организация = &Организация
		|							И Район = &Район
		|							И МКД = &МКД
		|							И (ТочкаУчета, УзелУчета) В
		|								(ВЫБРАТЬ
		|									ВТ_ТипыУзлов.ТочкаУчета КАК ТочкаУчета,
		|									ВТ_ТипыУзлов.УзелУчета КАК УзелУчета
		|								ИЗ
		|									ВТ_ТипыУзлов КАК ВТ_ТипыУзлов)) КАК энргСостояниеПриборовУзловУчетаМКДСрезПоследних
		|				ПО ВТ_ТипыУзлов.ТочкаУчета = энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ТочкаУчета
		|					И ВТ_ТипыУзлов.УзелУчета = энргСостояниеПриборовУзловУчетаМКДСрезПоследних.УзелУчета
		|					И (НЕ энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ТипИзмерителя = ЗНАЧЕНИЕ(Справочник.энргТипыПриборовУчета.ПустаяСсылка))
		|		ГДЕ
		|			энргСостояниеПриборовУзловУчетаМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)) КАК ВложенныйЗапрос) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.ТипПрибораУчетаРодитель,
		|	ВложенныйЗапрос.IDСтроки,
		|	ВложенныйЗапрос.ТипУзлаУчета,
		|	ВложенныйЗапрос.НомерСтроки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СоставУзлаСТочками.НомерСтроки КАК НомерСтроки,
		|	ВТ_СоставУзлаСТочками.ТипПрибораУчета.Наименование КАК ТипПрибораУчетаНаименование
		|ИЗ
		|	ВТ_СоставУзлаСТочками КАК ВТ_СоставУзлаСТочками
		|ГДЕ
		|	НЕ (ВТ_СоставУзлаСТочками.НомерСтроки, ВТ_СоставУзлаСТочками.ТипУзлаУчета, ВТ_СоставУзлаСТочками.IDСтроки, ВТ_СоставУзлаСТочками.ТипПрибораУчета, ВТ_СоставУзлаСТочками.Колво) В
		|				(ВЫБРАТЬ
		|					ВТ_СоставУзлаВДокументе.НомерСтроки КАК НомерСтроки,
		|					ВТ_СоставУзлаВДокументе.ТипУзлаУчета КАК ТипУзлаУчета,
		|					ВТ_СоставУзлаВДокументе.IDСтроки КАК IDСтроки,
		|					ВТ_СоставУзлаВДокументе.ТипПрибораУчетаРодитель КАК ТипПрибораУчетаРодитель,
		|					ВТ_СоставУзлаВДокументе.Колво КАК Колво
		|				ИЗ
		|					ВТ_СоставУзлаВДокументе КАК ВТ_СоставУзлаВДокументе)";
	
	РезультатЗапроса 	= Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Истина;
	КонецЕсли;	
	
	Выборка = РезультатЗапроса.Выбрать();
	
	НомерСтроки = Неопределено;
	Пока Выборка.Следующий() Цикл
		Если не НомерСтроки = Выборка.НомерСтроки Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + Выборка.НомерСтроки +  " указан не весь состав узла. Необходимо добавить: " + Символы.ПС);
		КонецЕсли; 		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + Выборка.ТипПрибораУчетаНаименование + Символы.ПС);
		
		НомерСтроки = Выборка.НомерСтроки; 
	КонецЦикла;
	
	Возврат Ложь;
КонецФункции

// Возвращает корректен ли состава узла НП.
//
// Параметры:
//  ПараметрыЗапроса	-	Структура.
// 
// Возвращаемое значение:
//   Булево.
//
Функция СоставУзлаКорректенНП(ПараметрыЗапроса) Экспорт
		
	Запрос = Новый Запрос;
	Для Каждого ТекПараметр из ПараметрыЗапроса Цикл
		Запрос.УстановитьПараметр(ТекПараметр.Ключ,ТекПараметр.Значение);
	КонецЦикла;
	МВТ = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаТочекУчета.НомерСтроки КАК НомерСтроки,
		|	ТаблицаТочекУчета.ТипУзлаУчета КАК ТипУзлаУчета,
		|	ТаблицаТочекУчета.IDСтроки КАК IDСтроки,
		|	ТаблицаТочекУчета.ТочкаУчета КАК ТочкаУчета,
		|	ТаблицаТочекУчета.ПриборУчета КАК УзелУчета,
		|	ТаблицаОбъектыРасчета.ОбъектРасчета КАК ОбъектРасчета,
		|	ТаблицаОбъектыРасчета.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ТипыУзлов
		|ИЗ
		|	Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ОбъектыРасчета КАК ТаблицаОбъектыРасчета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ТочкиУчета КАК ТаблицаТочекУчета
		|		ПО ТаблицаОбъектыРасчета.IDСтроки = ТаблицаТочекУчета.IDСтрокиВладельца
		|			И (НЕ ТаблицаТочекУчета.ТипУзлаУчета = ЗНАЧЕНИЕ(Справочник.энргТипыУзловУчета.ПустаяСсылка))
		|			И (ТаблицаОбъектыРасчета.Ссылка = &Ссылка)
		|			И (ТаблицаТочекУчета.Ссылка = &Ссылка)
		|			И ТаблицаОбъектыРасчета.Ссылка = ТаблицаТочекУчета.Ссылка
		|			И (НЕ ТаблицаТочекУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТаблицаТочекУчета.НомерСтроки,
		|	ТаблицаТочекУчета.ТипУзлаУчета,
		|	ТаблицаТочекУчета.IDСтроки,
		|	ТаблицаТочекУчета.ТочкаУчета,
		|	ТаблицаТочекУчета.ПриборУчета,
		|	ТаблицаТочекУчета.Ссылка.ОбъектРасчета,
		|	ТаблицаТочекУчета.Ссылка
		|ИЗ
		|	Документ.бестОперацияСУслугамиНП.ТочкиУчета КАК ТаблицаТочекУчета
		|ГДЕ
		|	НЕ ТаблицаТочекУчета.ТипУзлаУчета = ЗНАЧЕНИЕ(Справочник.энргТипыУзловУчета.ПустаяСсылка)
		|	И ТаблицаТочекУчета.Ссылка = &Ссылка
		|	И НЕ ТаблицаТочекУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТаблицаТочекУчета.НомерСтроки,
		|	ТаблицаТочекУчета.ТипУзлаУчета,
		|	ТаблицаТочекУчета.IDСтроки,
		|	ТаблицаТочекУчета.ТочкаУчета,
		|	ТаблицаТочекУчета.ПриборУчета,
		|	ТаблицаТочекУчета.Ссылка.ОбъектРасчета,
		|	ТаблицаТочекУчета.Ссылка
		|ИЗ
		|	Документ.бестОперацияСПриборомУчетаНП.ТочкиУчета КАК ТаблицаТочекУчета
		|ГДЕ
		|	НЕ ТаблицаТочекУчета.ТипУзлаУчета = ЗНАЧЕНИЕ(Справочник.энргТипыУзловУчета.ПустаяСсылка)
		|	И ТаблицаТочекУчета.Ссылка = &Ссылка
		|	И НЕ ТаблицаТочекУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.ТипУзлаУчета КАК ТипУзлаУчета,
		|	энргТипыУзловУчетаСоставУзла.ТипИзмерителя КАК ТипПрибораУчета
		|ПОМЕСТИТЬ ВТ_ЭталонныйСоставУзла
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТ_ТипыУзлов.ТипУзлаУчета КАК ТипУзлаУчета
		|	ИЗ
		|		ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТ_ТипыУзлов.ТипУзлаУчета) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТипыУзловУчета.СоставУзла КАК энргТипыУзловУчетаСоставУзла
		|		ПО ВложенныйЗапрос.ТипУзлаУчета = энргТипыУзловУчетаСоставУзла.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
		|	ВложенныйЗапрос.ТипУзлаУчета КАК ТипУзлаУчета,
		|	ВложенныйЗапрос.IDСтроки КАК IDСтроки,
		|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
		|	ВложенныйЗапрос.УзелУчета КАК УзелУчета,
		|	ВложенныйЗапрос.ТипПрибораУчета КАК ТипПрибораУчета,
		|	ВложенныйЗапрос.Колво КАК Колво
		|ПОМЕСТИТЬ ВТ_СоставУзлаСТочками
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТ_ТипыУзлов.НомерСтроки КАК НомерСтроки,
		|		ВТ_ТипыУзлов.ТипУзлаУчета КАК ТипУзлаУчета,
		|		ВТ_ТипыУзлов.IDСтроки КАК IDСтроки,
		|		ВТ_ТипыУзлов.ТочкаУчета КАК ТочкаУчета,
		|		ВТ_ТипыУзлов.УзелУчета КАК УзелУчета,
		|		ВТ_ЭталонныйСоставУзла.ТипПрибораУчета КАК ТипПрибораУчета,
		|		СУММА(1) КАК Колво
		|	ИЗ
		|		ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЭталонныйСоставУзла КАК ВТ_ЭталонныйСоставУзла
		|			ПО ВТ_ТипыУзлов.ТипУзлаУчета = ВТ_ЭталонныйСоставУзла.ТипУзлаУчета
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТ_ТипыУзлов.УзелУчета,
		|		ВТ_ТипыУзлов.IDСтроки,
		|		ВТ_ЭталонныйСоставУзла.ТипПрибораУчета,
		|		ВТ_ТипыУзлов.ТипУзлаУчета,
		|		ВТ_ТипыУзлов.ТочкаУчета,
		|		ВТ_ТипыУзлов.НомерСтроки) КАК ВложенныйЗапрос
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
		|	ВложенныйЗапрос.ТипУзлаУчета КАК ТипУзлаУчета,
		|	ВложенныйЗапрос.IDСтроки КАК IDСтроки,
		|	ВложенныйЗапрос.ТипПрибораУчетаРодитель КАК ТипПрибораУчетаРодитель,
		|	СУММА(ВложенныйЗапрос.Колво) КАК Колво
		|ПОМЕСТИТЬ ВТ_СоставУзлаВДокументе
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТ_ТипыУзлов.НомерСтроки КАК НомерСтроки,
		|		ВТ_ТипыУзлов.ТипУзлаУчета КАК ТипУзлаУчета,
		|		ВТ_ТипыУзлов.IDСтроки КАК IDСтроки,
		|		бестЗаключениеДоговоровСЮридическимиЛицамиИзмерители.ТипПрибораУчета.Родитель КАК ТипПрибораУчетаРодитель,
		|		1 КАК Колво
		|	ИЗ
		|		ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами.Измерители КАК бестЗаключениеДоговоровСЮридическимиЛицамиИзмерители
		|			ПО ВТ_ТипыУзлов.Ссылка = бестЗаключениеДоговоровСЮридическимиЛицамиИзмерители.Ссылка
		|				И (бестЗаключениеДоговоровСЮридическимиЛицамиИзмерители.Ссылка = &Ссылка)
		|				И ВТ_ТипыУзлов.IDСтроки = бестЗаключениеДоговоровСЮридическимиЛицамиИзмерители.IDСтрокиТочкиУчета
		|				И (НЕ бестЗаключениеДоговоровСЮридическимиЛицамиИзмерители.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ВТ_ТипыУзлов.НомерСтроки,
		|		ВТ_ТипыУзлов.ТипУзлаУчета,
		|		ВТ_ТипыУзлов.IDСтроки,
		|		бестОперацияСУслугамиНПИзмерители.ТипПрибораУчета.Родитель,
		|		1
		|	ИЗ
		|		ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСУслугамиНП.Измерители КАК бестОперацияСУслугамиНПИзмерители
		|			ПО ВТ_ТипыУзлов.Ссылка = бестОперацияСУслугамиНПИзмерители.Ссылка
		|				И (бестОперацияСУслугамиНПИзмерители.Ссылка = &Ссылка)
		|				И ВТ_ТипыУзлов.IDСтроки = бестОперацияСУслугамиНПИзмерители.IDСтрокиТочкиУчета
		|				И (НЕ бестОперацияСУслугамиНПИзмерители.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ВложенныйЗапрос.НомерСтроки,
		|		ВложенныйЗапрос.ТипУзлаУчета,
		|		ВложенныйЗапрос.IDСтроки,
		|		ВложенныйЗапрос.ТипПрибораУчетаРодитель,
		|		1
		|	ИЗ
		|		(ВЫБРАТЬ
		|			ВТ_ТипыУзлов.НомерСтроки КАК НомерСтроки,
		|			ВТ_ТипыУзлов.ТипУзлаУчета КАК ТипУзлаУчета,
		|			ВТ_ТипыУзлов.IDСтроки КАК IDСтроки,
		|			бестОперацияСПриборомУчетаНПИзмерители.ТипПрибораУчета.Родитель КАК ТипПрибораУчетаРодитель
		|		ИЗ
		|			ВТ_ТипыУзлов КАК ВТ_ТипыУзлов
		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.Измерители КАК бестОперацияСПриборомУчетаНПИзмерители
		|				ПО (бестОперацияСПриборомУчетаНПИзмерители.Ссылка = &Ссылка)
		|					И ВТ_ТипыУзлов.Ссылка = бестОперацияСПриборомУчетаНПИзмерители.Ссылка
		|					И (НЕ бестОперацияСПриборомУчетаНПИзмерители.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|					И ВТ_ТипыУзлов.IDСтроки = бестОперацияСПриборомУчетаНПИзмерители.IDСтрокиТочкиУчета) КАК ВложенныйЗапрос) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.ТипПрибораУчетаРодитель,
		|	ВложенныйЗапрос.ТипУзлаУчета,
		|	ВложенныйЗапрос.IDСтроки,
		|	ВложенныйЗапрос.НомерСтроки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СоставУзлаСТочками.НомерСтроки КАК НомерСтроки,
		|	ВТ_СоставУзлаСТочками.ТипПрибораУчета.Наименование КАК ТипПрибораУчетаНаименование
		|ИЗ
		|	ВТ_СоставУзлаСТочками КАК ВТ_СоставУзлаСТочками
		|ГДЕ
		|	НЕ (ВТ_СоставУзлаСТочками.НомерСтроки, ВТ_СоставУзлаСТочками.ТипУзлаУчета, ВТ_СоставУзлаСТочками.IDСтроки, ВТ_СоставУзлаСТочками.ТипПрибораУчета, ВТ_СоставУзлаСТочками.Колво) В
		|				(ВЫБРАТЬ
		|					ВТ_СоставУзлаВДокументе.НомерСтроки КАК НомерСтроки,
		|					ВТ_СоставУзлаВДокументе.ТипУзлаУчета КАК ТипУзлаУчета,
		|					ВТ_СоставУзлаВДокументе.IDСтроки КАК IDСтроки,
		|					ВТ_СоставУзлаВДокументе.ТипПрибораУчетаРодитель КАК ТипПрибораУчетаРодитель,
		|					ВТ_СоставУзлаВДокументе.Колво КАК Колво
		|				ИЗ
		|					ВТ_СоставУзлаВДокументе КАК ВТ_СоставУзлаВДокументе)";
	
	РезультатЗапроса 	= Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Истина;
	КонецЕсли;	
	
	Выборка = РезультатЗапроса.Выбрать();
	
	НомерСтроки = Неопределено;
	Пока Выборка.Следующий() Цикл
		Если не НомерСтроки = Выборка.НомерСтроки Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + Выборка.НомерСтроки +  " указан не весь состав узла. Необходимо добавить: " + Символы.ПС);
		КонецЕсли; 		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + Выборка.ТипПрибораУчетаНаименование + Символы.ПС);
		
		НомерСтроки = Выборка.НомерСтроки; 
	КонецЦикла;
	
	Возврат Ложь;
КонецФункции

// Заполняет результат межповерочный интервал по прибору учета.
//
// Параметры:
//  Результат	-	Число.
//  ПриборУчета	-	СправочникСсылка.энргПриборыУчетаАбонента.
//
Процедура ЗаполнитьРезультатМежповерочныйИнтервалПоПриборуУчета(Результат, ПриборУчета) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(энргМаркиПриборовУчета.МежповерочныйИнтервал, 0) КАК МежповерочныйИнтервал
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргПриборыУчетаАбонента.Ссылка КАК Ссылка,
	|		энргПриборыУчетаАбонента.ТипПрибораУчета КАК ТипПрибораУчета
	|	ИЗ
	|		Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|	ГДЕ
	|		энргПриборыУчетаАбонента.Ссылка = &ПриборУчета) КАК ПриборУчетаСТипом
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргТипыПриборовУчета КАК энргТипыПриборовУчета
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргМаркиПриборовУчета КАК энргМаркиПриборовУчета
	|			ПО энргТипыПриборовУчета.МаркаПУ = энргМаркиПриборовУчета.Ссылка
	|		ПО ПриборУчетаСТипом.ТипПрибораУчета = энргТипыПриборовУчета.Ссылка";
	
	Запрос.УстановитьПараметр("ПриборУчета", ПриборУчета);
	
	РезультатЗапроса 	= Запрос.Выполнить();	
	Выборка 			= РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		Результат = Выборка.МежповерочныйИнтервал;
	КонецЕсли;
КонецПроцедуры

// Получает межповерочный интервал по типу ПУ.
//
// Параметры:
//  ТипПрибораУчета	-	СправочникСсылка.энргТипыПриборовУчета.
// 
// Возвращаемое значение:
//   Число.
//
Функция ПолучитьМежповерочныйИнтервалПоТипуПУ(ТипПрибораУчета) Экспорт
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргМаркиПриборовУчета.МежповерочныйИнтервал КАК МежповерочныйИнтервал
		|ИЗ
		|	Справочник.энргТипыПриборовУчета КАК энргТипыПриборовУчета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргМаркиПриборовУчета КАК энргМаркиПриборовУчета
		|		ПО энргТипыПриборовУчета.МаркаПУ = энргМаркиПриборовУчета.Ссылка
		|ГДЕ
		|	энргТипыПриборовУчета.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ТипПрибораУчета);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.МежповерочныйИнтервал;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

#Область ДобавлениеПуКУзлам

// Получает данные ТЧ узла.
//
// Параметры:
//  ПараметрыПередачи				-	Структура:
//   * IDСтроки	-	УникальныйИдентификатор.
//   * Услуга	-	СправочникСсылка.энргВидыУслуг.
//  IDСтроки						-	УникальныйИдентификатор
//  ТекущийОбъект					-	ДокументОбъект.
//  ТипУзлаУчета					-	СправочникСсылка.энргТипыУзловУчета.
//  НачалоДействияКоммерскогоУчета	-	Дата.
//  КонецДействияКоммерскогоУчета	-	Дата.
//
Процедура ПолучитьДанныеТабЧастейУзла(ПараметрыПередачи,IDСтроки, ТекущийОбъект,ТипУзлаУчета,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета) Экспорт 
	ПриборыУзловУчета = ТекущийОбъект.ПриборыУзловУчета.Выгрузить(Новый Структура("IDСтроки",IDСтроки));
	Если ПриборыУзловУчета.Количество() = 0 Тогда
		ПолучитьДанныеТипаУзлаУчета(ПараметрыПередачи,ТипУзлаУчета,IDСтроки,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета);
	Иначе
		ПараметрыПередачи.Вставить("ПриборыУзловУчета"		,ОбщегоНазначения.ТаблицаЗначенийВМассив(ПриборыУзловУчета));
		ПараметрыПередачи.Вставить("ШкалыПриборовУчета"		,ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ШкалыПриборовУчета.Выгрузить(Новый Структура("IDСтрокиТочкиУчета",IDСтроки))));
	КонецЕсли;
	ПараметрыПередачи.Вставить("ПоказанияПриборовУчета"	,ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ПоказанияПриборовУчета.Выгрузить(Новый Структура("IDСтрокиТочкиУчета",IDСтроки))));
	ПараметрыПередачи.Вставить("ФормулыРасчетаУслуг"	,ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ФормулыРасчетаУслуг.Выгрузить(Новый Структура("IDСтрокиТочкиУчета",IDСтроки))));
	ПараметрыПередачи.Вставить("ШкалыУслуг"				,ОбщегоНазначения.ТаблицаЗначенийВМассив(ТекущийОбъект.ШкалыУслуг.Выгрузить(Новый Структура("IDСтроки",IDСтроки))));
КонецПроцедуры

// Записывает параметры точек узлов приборов.
//
// Параметры:
//  КоллекцияТУ		-	ДанныеФормыКоллекция.
//  КоллекцияПУ		-	ДанныеФормыКоллекция.
//  ТекущийОбъект	-	ДокументОбъект.
//  ПриборыИУзлы	-	Булево.
//
Процедура ЗаписатьПараметрыТочек_Узлов_Приборов(КоллекцияТУ, КоллекцияПУ, ТекущийОбъект, ПриборыИУзлы = Ложь) Экспорт
		
	Сч 					= 0;
	СоответствиеУзлов 	= Новый Соответствие;	
	СоответствиеУзловВидКанальности = Новый Соответствие;
	
	Для Каждого СтрокаТочки Из КоллекцияПУ Цикл		
		ЕстьДанные  							= Ложь; 
		
		Запись  								= Новый ЗаписьJSON;
		Запись.УстановитьСтроку();
		Запись.ЗаписатьНачалоОбъекта(); 	
		
		Если ЗначениеЗаполнено(СтрокаТочки.ЗаводскойНомер) Тогда
			Запись.ЗаписатьИмяСвойства("ЗаводскойНомер");
			Запись.ЗаписатьЗначение(СтрокаТочки.ЗаводскойНомер); 		
			
			Запись.ЗаписатьИмяСвойства("РегистрируетОбъем");
			Запись.ЗаписатьЗначение("" + СтрокаТочки.РегистрируетОбъем);
			
			ЕстьДанные 							= Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТочки.ТипПрибораУчета) Тогда
			Запись.ЗаписатьИмяСвойства("ТипПрибораУчета");
			Запись.ЗаписатьЗначение("" + СтрокаТочки.ТипПрибораУчета.УникальныйИдентификатор());
			ЕстьДанные 							= Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТочки.ТипПрибораУчета) И Не ЗначениеЗаполнено(СтрокаТочки.ВидКанальности)  Тогда
			Запись.ЗаписатьИмяСвойства("ВидКанальности");
			Запись.ЗаписатьЗначение("" + Справочники.энргВидыКанальности.Одноканальный.УникальныйИдентификатор());
			ЕстьДанные 							= Истина;
		ИначеЕсли ЗначениеЗаполнено(СтрокаТочки.ВидКанальности)Тогда
			Запись.ЗаписатьИмяСвойства("ВидКанальности");
			Запись.ЗаписатьЗначение("" + СтрокаТочки.ВидКанальности.УникальныйИдентификатор());
			ЕстьДанные 							= Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТочки.РасположениеИзмерителя) Тогда
			Запись.ЗаписатьИмяСвойства("РасположениеИзмерителя");
			Запись.ЗаписатьЗначение("" + СтрокаТочки.РасположениеИзмерителя.УникальныйИдентификатор());
			ЕстьДанные 							= Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТочки.ДатаВыпуска) Тогда
			Запись.ЗаписатьИмяСвойства("ДатаВыпуска");
			Запись.ЗаписатьЗначение("" + СтрокаТочки.ДатаВыпуска);
			ЕстьДанные 							= Истина;
		КонецЕсли;
		
		Запись.ЗаписатьКонецОбъекта(); 
		
		ЗаписываемаяСтрока  					= ТекущийОбъект.ПриборыУзловУчета[Сч];
		ЗаписываемаяСтрока.ОписаниеПрибора 		= "";
		Если ЕстьДанные Тогда
			ЗаписываемаяСтрока.ОписаниеПрибора 	= Запись.Закрыть();
			
			Если СоответствиеУзлов.Получить(СтрокаТочки.IDСтроки) = Неопределено Тогда
				СоответствиеУзлов.Вставить(СтрокаТочки.IDСтроки,СтрокаТочки.ЗаводскойНомер);
				
				Если СтрокаТочки.свойство("ВидКанальности") Тогда
					СоответствиеУзловВидКанальности.Вставить(СтрокаТочки.IDСтроки, СтрокаТочки.ВидКанальности);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		Сч 										= Сч + 1;		
		
	КонецЦикла;
			
	
	Сч 											= 0;
	Для Каждого СтрокаТочки Из КоллекцияТУ Цикл
		
		ЗаписываемаяСтрока  					= ТекущийОбъект.ТочкиУчета[Сч];
		
		ЗаписьДляУзла  							= Новый ЗаписьJSON;
		ЗаписьДляУзла.УстановитьСтроку();
		ЗаписьДляУзла.ЗаписатьНачалоОбъекта();
		
		ЕстьДанныеУзла 							= Ложь;
		
		ЗаводскойНомерДляУзла = СоответствиеУзлов.Получить(СтрокаТочки.IDСтроки);
		ВидКанальности = СоответствиеУзловВидКанальности.Получить(СтрокаТочки.IDСтроки);
		Если не ЗаводскойНомерДляУзла = Неопределено Тогда
			ЗаписьДляУзла.ЗаписатьИмяСвойства("ЗаводскойНомер");
			ЗаписьДляУзла.ЗаписатьЗначение(ЗаводскойНомерДляУзла);
			
			ЗаписьДляУзла.ЗаписатьИмяСвойства("ТипУзлаУчета");
			ЗаписьДляУзла.ЗаписатьЗначение("" + СтрокаТочки.ТипУзлаУчета.УникальныйИдентификатор());
			
			Если не ВидКанальности = Неопределено Тогда 
				ЗаписьДляУзла.ЗаписатьИмяСвойства("ВидКанальности");
				ЗаписьДляУзла.ЗаписатьЗначение("" + ВидКанальности.УникальныйИдентификатор());
			КонецЕсли;
			
			ЕстьДанныеУзла = Истина;
		КонецЕсли;
		ЗаписьДляУзла.ЗаписатьКонецОбъекта();
		
		// Если необходимо создавать точку 
		Если не ПриборыИУзлы Тогда 
			Запись  								= Новый ЗаписьJSON;
			Запись.УстановитьСтроку();
			Запись.ЗаписатьНачалоОбъекта();		
			
			ЕстьДанные  							= Ложь;
			
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТочки,"НаименованиеТочки") И ЗначениеЗаполнено(СтрокаТочки.НаименованиеТочки) Тогда
				Запись.ЗаписатьИмяСвойства("НаименованиеТочки");
				Запись.ЗаписатьЗначение(СтрокаТочки.НаименованиеТочки);
				ЕстьДанные 							= Истина;
			КонецЕсли;
			
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТочки,"Расположение") И ЗначениеЗаполнено(СтрокаТочки.Расположение) Тогда
				Запись.ЗаписатьИмяСвойства("Расположение");
				Запись.ЗаписатьЗначение("" + СтрокаТочки.Расположение.УникальныйИдентификатор());
				ЕстьДанные 							= Истина;
			КонецЕсли;
			
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТочки,"Головная") Тогда
				Запись.ЗаписатьИмяСвойства("Головная");
				Запись.ЗаписатьЗначение(СтрокаТочки.Головная);
				ЕстьДанные 							= Истина;
			КонецЕсли;
			
			Запись.ЗаписатьКонецОбъекта();
			
			ЗаписываемаяСтрока.ОписаниеТочки 		= ""; 		
			Если ЕстьДанные Тогда
				ЗаписываемаяСтрока.ОписаниеТочки 	= Запись.Закрыть();
			КонецЕсли;
			
		КонецЕсли;		
		
		ЗаписываемаяСтрока.ОписаниеПрибора 		= "";
		Если ЕстьДанныеУзла Тогда
			ЗаписываемаяСтрока.ОписаниеПрибора 	= ЗаписьДляУзла.Закрыть();
		КонецЕсли;
		
		Сч 										= Сч + 1;		
	КонецЦикла;
	
	
КонецПроцедуры

// Находит приборы учета узлов по параметрам.
//
// Параметры:
//  ТекущийОбъект	-	ДокументОбъект.
//  ИмяКоллекции	-	Строка.
//  Отказ			-	Булево.
//
Процедура НайтиПриборыУчетаУзловПоПараметрам(ТекущийОбъект,ИмяКоллекции, Отказ) Экспорт 
	
	ДанныеТабличнойЧасти 					= ТекущийОбъект[ИмяКоллекции];
			
	ОписаниеПриборов 						= Новый ТаблицаЗначений;
	ОписаниеПриборов.Колонки.Добавить("ЗаводскойНомер", 	Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(25)));
	ОписаниеПриборов.Колонки.Добавить("ТипПрибораУчета", 	Новый ОписаниеТипов("СправочникСсылка.энргТипыПриборовУчета"));
	ОписаниеПриборов.Колонки.Добавить("ВидКанальности", 	Новый ОписаниеТипов("СправочникСсылка.энргВидыКанальности"));
	ОписаниеПриборов.Колонки.Добавить("НомерСтроки", 		Новый ОписаниеТипов("Число"));
	ОписаниеПриборов.Колонки.Добавить("Индекс",		 		Новый ОписаниеТипов("Число"));
	ОписаниеПриборов.Колонки.Добавить("РегистрируетОбъем",	Новый ОписаниеТипов("Булево"));

	Индекс  								= 0;
	Для Каждого СтрокаТаблицы Из ДанныеТабличнойЧасти Цикл
		
		СтрокаТаблицы.ПриборУчета  			= Справочники.энргПриборыУчетаАбонента.ПустаяСсылка();
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.ОписаниеПрибора) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаОписания  					= ОписаниеПриборов.Добавить();
		СтрокаОписания.Индекс 				= Индекс;
		СтрокаОписания.НомерСтроки 			= СтрокаТаблицы.НомерСтроки;
		Чтение  							= Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(СтрокаТаблицы.ОписаниеПрибора);
		Описание							= ПрочитатьJSON(Чтение);
		
		Если Описание.Свойство("ТипПрибораУчета") Тогда
			Ключ							= Описание.ТипПрибораУчета;
			СтрокаОписания.ТипПрибораУчета	= Справочники.энргТипыПриборовУчета.ПолучитьСсылку(Новый УникальныйИдентификатор(Ключ));
		КонецЕсли;
		
		Если Описание.Свойство("ВидКанальности") Тогда
			Ключ							= Описание.ВидКанальности;
			СтрокаОписания.ВидКанальности	= Справочники.энргВидыКанальности.ПолучитьСсылку(Новый УникальныйИдентификатор(Ключ));
		КонецЕсли;
		
		Если Описание.Свойство("ЗаводскойНомер") Тогда
			СтрокаОписания.ЗаводскойНомер	= Описание.ЗаводскойНомер;
		КонецЕсли;
		
		Если Описание.Свойство("РегистрируетОбъем") Тогда
			СтрокаОписания.РегистрируетОбъем	= Описание.РегистрируетОбъем;
		КонецЕсли;
		
		Индекс 								= Индекс + 1;
		
		Если НЕ ЗначениеЗаполнено(СтрокаОписания.ЗаводскойНомер)
			ИЛИ НЕ ЗначениеЗаполнено(СтрокаОписания.ТипПрибораУчета)
			ИЛИ НЕ ЗначениеЗаполнено(СтрокаОписания.ВидКанальности) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполнены не все ключевые параметры прибора учета, проведение не возможно");
			Отказ 							= Истина;	
		КонецЕсли;
	КонецЦикла;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
		
	Запрос  			= Новый Запрос;
	Запрос.УстановитьПараметр("ТекущиеДанные",ОписаниеПриборов);
	Текст 				=
	"ВЫБРАТЬ
	|	ТекущиеДанные.РегистрируетОбъем КАК РегистрируетОбъем,
	|	ТекущиеДанные.Индекс КАК Индекс,
	|	ТекущиеДанные.НомерСтроки КАК НомерСтроки,
	|	ТекущиеДанные.ЗаводскойНомер КАК ЗаводскойНомер,
	|	ТекущиеДанные.ТипПрибораУчета КАК ТипПрибораУчета,
	|	ВЫБОР
	|		КОГДА ТекущиеДанные.ВидКанальности = ЗНАЧЕНИЕ(Справочник.энргВидыКанальности.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыКанальности.Одноканальный)
	|		ИНАЧЕ ТекущиеДанные.ВидКанальности
	|	КОНЕЦ КАК ВидКанальности
	|ПОМЕСТИТЬ ДанныеТЧ
	|ИЗ
	|	&ТекущиеДанные КАК ТекущиеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Индекс КАК Индекс,
	|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
	|	ВложенныйЗапрос.ПриборУчетаСсылка КАК ПриборУчетаСсылка,
	|	энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности,
	|	энргПриборыУчетаАбонента.РегистрируетОбъем КАК РегистрируетОбъем
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеТЧ.Индекс КАК Индекс,
	|		ДанныеТЧ.НомерСтроки КАК НомерСтроки,
	|		МИНИМУМ(ЕСТЬNULL(энргПриборыУчетаАбонента.Ссылка, ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))) КАК ПриборУчетаСсылка
	|	ИЗ
	|		ДанныеТЧ КАК ДанныеТЧ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|			ПО ДанныеТЧ.ЗаводскойНомер = энргПриборыУчетаАбонента.Код
	|				И ДанныеТЧ.ТипПрибораУчета = энргПриборыУчетаАбонента.ТипПрибораУчета
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ДанныеТЧ.Индекс,
	|		ДанныеТЧ.НомерСтроки) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ВложенныйЗапрос.ПриборУчетаСсылка = энргПриборыУчетаАбонента.Ссылка";
			
	Запрос.Текст 						= Текст;
	Результат  							= Запрос.Выполнить();
	Выборка  							= Результат.Выбрать();
	
	Пока Выборка.Следующий() цикл		
		СтрокаОписания 					= ОписаниеПриборов[Выборка.Индекс];
		СтрокаТабЧасти 					= ДанныеТабличнойЧасти[Выборка.НомерСтроки - 1];		
		Обновлять 						= НЕ СтрокаОписания.ВидКанальности = Выборка.ВидКанальности или НЕ СтрокаОписания.РегистрируетОбъем = Выборка.РегистрируетОбъем;
		СтрокаТабЧасти.ПриборУчета 		= Выборка.ПриборУчетаСсылка;
		Если Обновлять Тогда
			ПриборОбъект 					= Выборка.ПриборУчетаСсылка.ПолучитьОбъект();
			ПриборОбъект.ВидКанальности 	= СтрокаОписания.ВидКанальности;
			ПриборОбъект.РегистрируетОбъем 	= СтрокаОписания.РегистрируетОбъем;
			ПриборОбъект.Записать();
		КонецЕсли;		
	КонецЦикла; 
	
КонецПроцедуры

// Создает узлы учета.
//
// Параметры:
//  ТекущийОбъект	-	ДокументОбъект.
//  ИмяКоллекции	-	Строка.
//  Отказ			-	Булево.
//
Процедура СоздатьУзлыУчета(ТекущийОбъект,ИмяКоллекции,Отказ) Экспорт  
	
	ДанныеТабличнойЧасти 					= ТекущийОбъект[ИмяКоллекции];
	
	НовыеУзлыУчета 							= Новый Массив;
	
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеУзлыУчета") Тогда
		НовыеУзлыУчета 						= ТекущийОбъект.ДополнительныеСвойства.НовыеУзлыУчета; 
	КонецЕсли;
	
	ЗаписываемаяКоллекция 					= ТекущийОбъект[ИмяКоллекции];
	для Каждого стр из ТекущийОбъект[ИмяКоллекции] цикл
		Если НЕ ЗначениеЗаполнено(стр.ОписаниеПрибора) Тогда //ИЛИ НовыеУзлыУчета.Найти(стр.НомерСтроки) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Чтение  							= Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(стр.ОписаниеПрибора);		
		Описание							= ПрочитатьJSON(Чтение);
		
		ДанныеУзлыУчета						= Новый Структура("ЗаводскойНомер,ТипПрибораУчета,ВидКанальности,ТипУзлаУчета",
		"",Справочники.энргТипыПриборовУчета.ПустаяСсылка(),Справочники.энргВидыКанальности.ПустаяСсылка(), Справочники.энргТипыУзловУчета.ПустаяСсылка());
		
		Если Описание.Свойство("ЗаводскойНомер") тогда
			ДанныеУзлыУчета.ЗаводскойНомер 	= Описание.ЗаводскойНомер;
		КонецЕсли;
		Если Описание.Свойство("ТипУзлаУчета") тогда
			Ключ							= Описание.ТипУзлаУчета;
			ДанныеУзлыУчета.ТипУзлаУчета	= Справочники.энргТипыУзловУчета.ПолучитьСсылку(Новый УникальныйИдентификатор(Ключ));			 	
		КонецЕсли;   		
		
		Если Описание.Свойство("ВидКанальности") тогда
			Ключ							= Описание.ВидКанальности;
			ДанныеУзлыУчета.ВидКанальности	= Справочники.энргВидыКанальности.ПолучитьСсылку(Новый УникальныйИдентификатор(Ключ));			 	
		КонецЕсли;   		
		

		Если НЕ НовыеУзлыУчета.Найти(стр.НомерСтроки) = Неопределено Тогда
			УзелУчета		 					= Справочники.энргПриборыУчетаАбонента.СоздатьЭлемент();
		    УзелУчета.УстановитьСсылкуНового(стр.ПриборУчета);
		Иначе
			УзелУчета  							= стр.ПриборУчета.получитьОбъект();
		КонецЕсли; 	
		
		УзелУчета.Код 					= "УУ" + ДанныеУзлыУчета.ЗаводскойНомер; 		
		УзелУчета.ТипУзлаУчета			= ДанныеУзлыУчета.ТипУзлаУчета;
		Если ДанныеУзлыУчета.Свойство("ВидКанальности") ТОгда 
			УзелУчета.ВидКанальности			= ДанныеУзлыУчета.ВидКанальности;
		КонецЕсли;
		
		УзелУчета.Записать();
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Создает точку учета.
//
// Параметры:
//  ДанныеПрибора	-	Структура.
// 
// Возвращаемое значение:
//   СправочникСсылка.энргПриборыУчетаАбонента.
//
Функция СоздатьТочкуУчета(ДанныеПрибора) Экспорт 
	
	ПриборОбъект			= Справочники.энргПриборыУчетаАбонента.СоздатьЭлемент();
	ЗаполнитьЗначенияСвойств(ПриборОбъект,ДанныеПрибора);
	ПриборОбъект.Записать();
	Возврат ПриборОбъект.Ссылка;
КонецФункции

// Заполняет схему запроса действующих приборов учета абонента.
//
// Параметры:
//  Схема		-	СхемаКомпоновкиДанных.
//  Параметры	-	Структура.
//
Процедура ЗаполнитьСхемуЗапросаДействующихПриборовУчетаАбонента(Схема, Параметры) Экспорт
	
	РегистрыСведений.энргСостояниеПриборовУчетаАбонента.ДействующиеПриборыУчетаПомещения(Схема,Параметры,"ВведенныеПриборыДействующихТочек");
	РегистрыСведений.энргУслугиТочекУчета.УслугиДействующихТочек(Схема,Параметры,"УслугиДействующихТочек");
	РегистрыСведений.энргВидыДифференцированностиПриборовУчета.ВидДифференцированностиВведенныхПриборов(Схема,Параметры,"ВидДифференцированностиВведенныхПриборов");
		
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
	|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ТипПрибораУчета КАК ТипПрибораУчета,
	|	ВложенныйЗапрос.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	ВложенныйЗапрос.ТипИзмерителя КАК ТипИзмерителя,
	|	ВложенныйЗапрос.ТипУзлаУчета КАК ТипУзлаУчета,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.Показание КАК Показание,
	|	ВложенныйЗапрос.Период КАК Период
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВведенныеПриборыДействующихТочек.Организация КАК Организация,
	|		ВведенныеПриборыДействующихТочек.Район КАК Район,
	|		ВведенныеПриборыДействующихТочек.ТочкаУчета КАК ТочкаУчета,
	|		ВведенныеПриборыДействующихТочек.ПриборУчета КАК ПриборУчета,
	|		энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности,
	|		энргПриборыУчетаАбонента.РегистрируетОбъем КАК РегистрируетОбъем,
	|		энргПриборыУчетаАбонента.ТипПрибораУчета КАК ТипПрибораУчета,
	|		энргПриборыУчетаАбонента.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|		энргТипыПриборовУчета.Родитель КАК ТипИзмерителя,
	|		энргПриборыУчетаАбонента.ТипУзлаУчета КАК ТипУзлаУчета,
	|		ВведенныеПриборыДействующихТочек.КлючПомещения КАК КлючПомещения,
	|		энргПоказанияПриборовУчетаСрезПоследних.Показание КАК Показание,
	|		энргПоказанияПриборовУчетаСрезПоследних.Период КАК Период
	|	ИЗ
	|		ВведенныеПриборыДействующихТочек КАК ВведенныеПриборыДействующихТочек
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргТипыПриборовУчета КАК энргТипыПриборовУчета
	|				ПО энргПриборыУчетаАбонента.ТипПрибораУчета = энргТипыПриборовУчета.Ссылка
	|			ПО ВведенныеПриборыДействующихТочек.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргПоказанияПриборовУчета.СрезПоследних(&Период, ) КАК энргПоказанияПриборовУчетаСрезПоследних
	|			ПО ВведенныеПриборыДействующихТочек.ПриборУчета = энргПоказанияПриборовУчетаСрезПоследних.ПриборУчета
	|				И ВведенныеПриборыДействующихТочек.КлючПомещения = энргПоказанияПриборовУчетаСрезПоследних.КлючПомещения
	|				И ВведенныеПриборыДействующихТочек.Организация = энргПоказанияПриборовУчетаСрезПоследних.Организация
	|				И ВведенныеПриборыДействующихТочек.Район = энргПоказанияПриборовУчетаСрезПоследних.Район) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВложенныйЗапрос.ВидКанальности = энргВидыКанальностиШкалы.Ссылка");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	Вложенныйзапрос.Организация КАК Организация,
	|	Вложенныйзапрос.Район КАК Район,
	|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
	|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
	|	Вложенныйзапрос.Шкала КАК Шкала,
	|	Вложенныйзапрос.Услуга КАК Услуга,
	|	Вложенныйзапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона,
	|	Вложенныйзапрос.ТипПрибораУчета КАК ТипПрибораУчета,
	|	Вложенныйзапрос.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	Вложенныйзапрос.ТипИзмерителя КАК ТипИзмерителя,
	|	Вложенныйзапрос.ТипУзлаУчета КАК ТипУзлаУчета,
	|	Вложенныйзапрос.КлючПомещения КАК КлючПомещения,
	|	энргПоставщикиУслугАбонентаСрезПоследних.Поставщик КАК Поставщик,
	|	Вложенныйзапрос.Показание КАК ПредыдущиеПоказания,
	|	Вложенныйзапрос.Период КАК ДатаПоследнихПоказаний
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеПоПриборам.Организация КАК Организация,
	|		ДанныеПоПриборам.Район КАК Район,
	|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|		ДанныеПоПриборам.Шкала КАК Шкала,
	|		ДанныеПоПриборам.РегистрируетОбъем КАК РегистрируетОбъем,
	|		ДанныеПоПриборам.ТипПрибораУчета КАК ТипПрибораУчета,
	|		ДанныеПоПриборам.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|		ДанныеПоПриборам.ТипИзмерителя КАК ТипИзмерителя,
	|		ДанныеПоПриборам.ТипУзлаУчета КАК ТипУзлаУчета,
	|		ЕСТЬNULL(УслугиДействующихТочек.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|		ЕСТЬNULL(ВидДифференцированностиВведенныхПриборов.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности,
	|		ДанныеПоПриборам.КлючПомещения КАК КлючПомещения,
	|		ДанныеПоПриборам.Показание КАК Показание,
	|		ДанныеПоПриборам.Период КАК Период
	|	ИЗ
	|		ДанныеПоПриборам КАК ДанныеПоПриборам
	|			ЛЕВОЕ СОЕДИНЕНИЕ УслугиДействующихТочек КАК УслугиДействующихТочек
	|			ПО ДанныеПоПриборам.Организация = УслугиДействующихТочек.Организация
	|				И ДанныеПоПриборам.Район = УслугиДействующихТочек.Район
	|				И ДанныеПоПриборам.ТочкаУчета = УслугиДействующихТочек.ТочкаУчета
	|				И ДанныеПоПриборам.КлючПомещения = УслугиДействующихТочек.КлючПомещения
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВидДифференцированностиВведенныхПриборов КАК ВидДифференцированностиВведенныхПриборов
	|			ПО ДанныеПоПриборам.Организация = ВидДифференцированностиВведенныхПриборов.Организация
	|				И ДанныеПоПриборам.Район = ВидДифференцированностиВведенныхПриборов.Район
	|				И ДанныеПоПриборам.ПриборУчета = ВидДифференцированностиВведенныхПриборов.ПриборУчета
	|				И ДанныеПоПриборам.Шкала = ВидДифференцированностиВведенныхПриборов.Шкала) КАК Вложенныйзапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
	|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргПоставщикиУслугАбонента.СрезПоследних(&Период, НЕ ЧастьСоставной) КАК энргПоставщикиУслугАбонентаСрезПоследних
	|		ПО Вложенныйзапрос.Организация = энргПоставщикиУслугАбонентаСрезПоследних.Организация
	|			И Вложенныйзапрос.Район = энргПоставщикиУслугАбонентаСрезПоследних.Район
	|			И Вложенныйзапрос.КлючПомещения = энргПоставщикиУслугАбонентаСрезПоследних.КлючПомещения
	|			И Вложенныйзапрос.ТочкаУчета = энргПоставщикиУслугАбонентаСрезПоследних.ТочкаУчета
	|			И Вложенныйзапрос.Услуга = энргПоставщикиУслугАбонентаСрезПоследних.Услуга
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Район,
	|	Вложенныйзапрос.ТочкаУчета,
	|	Вложенныйзапрос.Шкала");
	
КонецПроцедуры

// Заполняет схему запроса действующих приборов учета МКД.
//
// Параметры:
//  Схема		-	СхемаКомпоновкиДанных.
//  Параметры	-	Структура.
//
Процедура ЗаполнитьСхемуЗапросаДействующихПриборовУчетаМКД(Схема, Параметры) Экспорт
	
	РегистрыСведений.энргСостояниеПриборовМКД.АктивныеПриборыУчетаМКД(Схема,Параметры,"ВведенныеПриборыДействующихТочек");
	РегистрыСведений.энргУслугиТочекУчетаМКД.УслугиДействующихТочек(Схема,Параметры,"УслугиДействующихТочек");
	РегистрыСведений.энргВидыДифференцированностиПриборовУчетаМКД.ВидДифференцированностиВведенныхПриборов(Схема,Параметры,"ВидДифференцированностиВведенныхПриборов");
		
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
	|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ТипПрибораУчета КАК ТипПрибораУчета,
	|	ВложенныйЗапрос.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	ВложенныйЗапрос.ТипИзмерителя КАК ТипИзмерителя,
	|	ВложенныйЗапрос.ТипУзлаУчета КАК ТипУзлаУчета
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВведенныеПриборыДействующихТочек.Организация КАК Организация,
	|		ВведенныеПриборыДействующихТочек.Район КАК Район,
	|		ВведенныеПриборыДействующихТочек.МКД КАК МКД,
	|		ВведенныеПриборыДействующихТочек.ТочкаУчета КАК ТочкаУчета,
	|		ВведенныеПриборыДействующихТочек.ПриборУчета КАК ПриборУчета,
	|		энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности,
	|		энргПриборыУчетаАбонента.РегистрируетОбъем КАК РегистрируетОбъем,
	|		энргПриборыУчетаАбонента.ТипПрибораУчета КАК ТипПрибораУчета,
	|		энргПриборыУчетаАбонента.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|		энргТипыПриборовУчета.Родитель КАК ТипИзмерителя,
	|		энргПриборыУчетаАбонента.ТипУзлаУчета КАК ТипУзлаУчета
	|	ИЗ
	|		ВведенныеПриборыДействующихТочек КАК ВведенныеПриборыДействующихТочек
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргТипыПриборовУчета КАК энргТипыПриборовУчета
	|				ПО энргПриборыУчетаАбонента.ТипПрибораУчета = энргТипыПриборовУчета.Ссылка
	|			ПО ВведенныеПриборыДействующихТочек.ПриборУчета = энргПриборыУчетаАбонента.Ссылка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВложенныйЗапрос.ВидКанальности = энргВидыКанальностиШкалы.Ссылка");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	Вложенныйзапрос.Организация КАК Организация,
	|	Вложенныйзапрос.Район КАК Район,
	|	Вложенныйзапрос.МКД КАК МКД,
	|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
	|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
	|	Вложенныйзапрос.Шкала КАК Шкала,
	|	Вложенныйзапрос.Услуга КАК Услуга,
	|	Вложенныйзапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргПоставщикиУслугМКДСрезПоследних.Поставщик КАК Поставщик,
	|	Вложенныйзапрос.ТипПрибораУчета КАК ТипПрибораУчета,
	|	Вложенныйзапрос.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	Вложенныйзапрос.ТипИзмерителя КАК ТипИзмерителя,
	|	Вложенныйзапрос.ТипУзлаУчета КАК ТипУзлаУчета
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеПоПриборам.Организация КАК Организация,
	|		ДанныеПоПриборам.Район КАК Район,
	|		ДанныеПоПриборам.МКД КАК МКД,
	|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|		ДанныеПоПриборам.Шкала КАК Шкала,
	|		ДанныеПоПриборам.РегистрируетОбъем КАК РегистрируетОбъем,
	|		ДанныеПоПриборам.ТипПрибораУчета КАК ТипПрибораУчета,
	|		ДанныеПоПриборам.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|		ДанныеПоПриборам.ТипИзмерителя КАК ТипИзмерителя,
	|		ДанныеПоПриборам.ТипУзлаУчета КАК ТипУзлаУчета,
	|		ЕСТЬNULL(УслугиДействующихТочек.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|		ЕСТЬNULL(ВидДифференцированностиВведенныхПриборов.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности
	|	ИЗ
	|		ДанныеПоПриборам КАК ДанныеПоПриборам
	|			ЛЕВОЕ СОЕДИНЕНИЕ УслугиДействующихТочек КАК УслугиДействующихТочек
	|			ПО ДанныеПоПриборам.Организация = УслугиДействующихТочек.Организация
	|				И ДанныеПоПриборам.Район = УслугиДействующихТочек.Район
	|				И ДанныеПоПриборам.МКД = УслугиДействующихТочек.МКД
	|				И ДанныеПоПриборам.ТочкаУчета = УслугиДействующихТочек.ТочкаУчета
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВидДифференцированностиВведенныхПриборов КАК ВидДифференцированностиВведенныхПриборов
	|			ПО ДанныеПоПриборам.Организация = ВидДифференцированностиВведенныхПриборов.Организация
	|				И ДанныеПоПриборам.Район = ВидДифференцированностиВведенныхПриборов.Район
	|				И ДанныеПоПриборам.МКД = ВидДифференцированностиВведенныхПриборов.МКД
	|				И ДанныеПоПриборам.ПриборУчета = ВидДифференцированностиВведенныхПриборов.ПриборУчета
	|				И ДанныеПоПриборам.Шкала = ВидДифференцированностиВведенныхПриборов.Шкала) КАК Вложенныйзапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
	|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргПоставщикиУслугМКД.СрезПоследних(&Период, НЕ ЧастьСоставной) КАК энргПоставщикиУслугМКДСрезПоследних
	|		ПО Вложенныйзапрос.Организация = энргПоставщикиУслугМКДСрезПоследних.Организация
	|			И Вложенныйзапрос.Район = энргПоставщикиУслугМКДСрезПоследних.Район
	|			И Вложенныйзапрос.МКД = энргПоставщикиУслугМКДСрезПоследних.МКД
	|			И Вложенныйзапрос.ТочкаУчета = энргПоставщикиУслугМКДСрезПоследних.ТочкаУчета
	|			И Вложенныйзапрос.Услуга = энргПоставщикиУслугМКДСрезПоследних.Услуга
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Район,
	|	МКД,
	|	Вложенныйзапрос.ТочкаУчета,
	|	Вложенныйзапрос.Шкала");
	
КонецПроцедуры

// Возвращает действующие приборы учета группы МКД.
//
// Параметры:
//  Период		-	Дата.
//  Организация	-	СправочникСсылка.Организации.
//  Район		-	СправочникСсылка.энргЗоныОтвественности.
//  МВТ			-	МенеджерВременныхТаблиц.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ДействующиеПриборыУчетаГруппыМКД(Период,Организация, Район,МВТ) Экспорт
			
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Период",		Период);
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.УстановитьПараметр("Район",		Район);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргАктивностьТочекУчетаМКДСрезПоследних.МКД КАК МКД
	|ПОМЕСТИТЬ АктивныеТочкиУчетаМКД
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД В
	|					(ВЫБРАТЬ
	|						втМКД.МКД
	|					ИЗ
	|						втМКД КАК втМКД)) КАК энргАктивностьТочекУчетаМКДСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ТочкиУчетаМКД
	|ИЗ
	|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаМКД.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаМКД КАК АктивныеТочкиУчетаМКД)) КАК энргВладельцыТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктивныеТочкиУчетаМКД.ТочкаУчета КАК ТочкаУчета,
	|	АктивныеТочкиУчетаМКД.МКД КАК МКД
	|ПОМЕСТИТЬ ДействующиеТочкиУчета
	|ИЗ
	|	АктивныеТочкиУчетаМКД КАК АктивныеТочкиУчетаМКД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТочкиУчетаМКД КАК ТочкиУчетаМКД
	|		ПО АктивныеТочкиУчетаМКД.ТочкаУчета = ТочкиУчетаМКД.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПриборыТочекМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыТочекМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргПриборыТочекМКДСрезПоследних.МКД КАК МКД
	|ПОМЕСТИТЬ ПриборыТочекМКД
	|ИЗ
	|	РегистрСведений.энргПриборыТочекМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД В
	|					(ВЫБРАТЬ
	|						втМКД.МКД
	|					ИЗ
	|						втМКД КАК втМКД)) КАК энргПриборыТочекМКДСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДействующиеТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	ПриборыТочекМКД.ПриборУчета КАК ПриборУчета,
	|	ДействующиеТочкиУчета.МКД КАК МКД
	|ПОМЕСТИТЬ ПриборыДействующихТочекМКД
	|ИЗ
	|	ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПриборыТочекМКД КАК ПриборыТочекМКД
	|		ПО ДействующиеТочкиУчета.ТочкаУчета = ПриборыТочекМКД.ТочкаУчета
	|			И ДействующиеТочкиУчета.МКД = ПриборыТочекМКД.МКД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеПриборовМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргСостояниеПриборовМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргСостояниеПриборовМКДСрезПоследних.МКД КАК МКД
	|ПОМЕСТИТЬ ВведенныеПриборыМКД
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД В
	|					(ВЫБРАТЬ
	|						втМКД.МКД
	|					ИЗ
	|						втМКД КАК втМКД)) КАК энргСостояниеПриборовМКДСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргУслугиТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргУслугиТочекУчетаМКДСрезПоследних.Услуга КАК Услуга,
	|	энргУслугиТочекУчетаМКДСрезПоследних.МКД КАК МКД
	|ПОМЕСТИТЬ УслугиТочекУчетаМКД
	|ИЗ
	|	РегистрСведений.энргУслугиТочекУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД В
	|					(ВЫБРАТЬ
	|						втМКД.МКД
	|					ИЗ
	|						втМКД КАК втМКД)) КАК энргУслугиТочекУчетаМКДСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВидыДифференцированностиПриборовУчетаМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргВидыДифференцированностиПриборовУчетаМКДСрезПоследних.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВидыДифференцированностиПриборовУчетаМКДСрезПоследних.МКД КАК МКД
	|ПОМЕСТИТЬ ВидыДифференцированностиТочекУчетаМКД
	|ИЗ
	|	РегистрСведений.энргВидыДифференцированностиПриборовУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД В
	|					(ВЫБРАТЬ
	|						втМКД.МКД
	|					ИЗ
	|						втМКД КАК втМКД)) КАК энргВидыДифференцированностиПриборовУчетаМКДСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриборыДействующихТочекМКД.ТочкаУчета КАК ТочкаУчета,
	|	ПриборыДействующихТочекМКД.ПриборУчета КАК ПриборУчета,
	|	ПриборыДействующихТочекМКД.МКД КАК МКД
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	ПриборыДействующихТочекМКД КАК ПриборыДействующихТочекМКД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВведенныеПриборыМКД КАК ВведенныеПриборыМКД
	|		ПО ПриборыДействующихТочекМКД.ПриборУчета = ВведенныеПриборыМКД.ПриборУчета
	|			И ПриборыДействующихТочекМКД.ТочкаУчета = ВведенныеПриборыМКД.ТочкаУчета
	|			И ПриборыДействующихТочекМКД.МКД = ВведенныеПриборыМКД.МКД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|	ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|	ЕСТЬNULL(УслугиТочекУчетаМКД.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|	ЕСТЬNULL(ВидыДифференцированностиТочекУчетаМКД.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности,
	|	ДанныеПоПриборам.МКД КАК МКД
	|ИЗ
	|	ДанныеПоПриборам КАК ДанныеПоПриборам
	|		ЛЕВОЕ СОЕДИНЕНИЕ УслугиТочекУчетаМКД КАК УслугиТочекУчетаМКД
	|		ПО ДанныеПоПриборам.ТочкаУчета = УслугиТочекУчетаМКД.ТочкаУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВидыДифференцированностиТочекУчетаМКД КАК ВидыДифференцированностиТочекУчетаМКД
	|		ПО ДанныеПоПриборам.ПриборУчета = ВидыДифференцированностиТочекУчетаМКД.ПриборУчета";	
	Результат  = Запрос.Выполнить();
	Возврат Результат;
КонецФункции

// Возвращает приборы всех точек учета теплоисточников.
//
// Параметры:
//  Период			-	Дата.
//  Организация		-	СправочникСсылка.Организации.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  Теплоисточник	-	Произвольный.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ПриборыВсехТочекУчетаТеплоисточников(Период,Организация,Район,Теплоисточник) Экспорт
			
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("Теплоисточник",			Теплоисточник);
	
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаАбонента
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчетаТеплоисточников.СрезПоследних(
	|			&Период,
	|			Теплоисточник = &Теплоисточник
	|				И Район = &Район
	|				И Организация = &Организация) КАК энргАктивностьТочекУчетаСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ТочкиУчетаАбонента
	|ИЗ
	|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И Организация = &Организация
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаАбонента.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаАбонента КАК АктивныеТочкиУчетаАбонента)) КАК энргВладельцыТочекУчетаСрезПоследних
	|ГДЕ
	|	энргВладельцыТочекУчетаСрезПоследних.АбонентВладелец = &Теплоисточник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТочкиУчетаАбонента.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ДействующиеТочкиУчета
	|ИЗ
	|	ТочкиУчетаАбонента КАК ТочкиУчетаАбонента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АктивныеТочкиУчетаАбонента КАК АктивныеТочкиУчетаАбонента
	|		ПО ТочкиУчетаАбонента.ТочкаУчета = АктивныеТочкиУчетаАбонента.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПриборыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочекУчета
	|ИЗ
	|	РегистрСведений.энргПриборыТочекТеплоисточников.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И Организация = &Организация
	|				И Теплоисточник = &Теплоисточник) КАК энргПриборыТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВведенныеПриборы
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовТеплоисточников.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И Организация = &Организация
	|				И Теплоисточник = &Теплоисточник) КАК энргСостояниеПриборовУчетаАбонентаСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	ЕСТЬNULL(энргВидыУслугСоставляющиеУслуг.Услуга, энргУслугиТочекУчетаСрезПоследних.Услуга) КАК Услуга
	|ПОМЕСТИТЬ УслугиТочекУчета
	|ИЗ
	|	РегистрСведений.энргУслугиТочекУчетаТеплоисточников.СрезПоследних(
	|			&Период,
	|			Теплоисточник = &Теплоисточник
	|				И Район = &Район
	|				И Организация = &Организация) КАК энргУслугиТочекУчетаСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|		ПО энргУслугиТочекУчетаСрезПоследних.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
	|			И (энргУслугиТочекУчетаСрезПоследних.Услуга.СоставнаяУслуга)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргУслугиТочекУчетаСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргУслугиТочекУчетаСрезПоследних.Шкала КАК Шкала,
	|	энргУслугиТочекУчетаСрезПоследних.ВидДифференцированности КАК ВидДифференцированности
	|ПОМЕСТИТЬ ВидыДифференцированностиТочекУчета
	|ИЗ
	|	РегистрСведений.энргВидыДифференцированностиПриборовУчетаТеплоисточников.СрезПоследних(
	|			&Период,
	|			Теплоисточник = &Теплоисточник
	|				И Район = &Район
	|				И Организация = &Организация) КАК энргУслугиТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
	|	ЕСТЬNULL(энргВидыКанальностиШкалы.Шкала, ЗНАЧЕНИЕ(Справочник.энргШкалыПриборовУчета.ПустаяСсылка)) КАК Шкала
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		ЕСТЬNULL(энргПриборыУчетаАбонента.ВидКанальности, ЗНАЧЕНИЕ(Справочник.энргВидыКанальности.ПустаяСсылка)) КАК ВидКанальности
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ДействующиеТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|			ЕСТЬNULL(ВведенныеПриборы.ПриборУчета, ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)) КАК ПриборУчета
	|		ИЗ
	|			ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
	|				ЛЕВОЕ СОЕДИНЕНИЕ ВведенныеПриборы КАК ВведенныеПриборы
	|				ПО ДействующиеТочкиУчета.ТочкаУчета = ВведенныеПриборы.ТочкаУчета) КАК ВложенныйЗапрос
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|			ПО ВложенныйЗапрос.ПриборУчета = энргПриборыУчетаАбонента.Ссылка) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВложенныйЗапрос.ВидКанальности = энргВидыКанальностиШкалы.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
	|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
	|	Вложенныйзапрос.Шкала КАК Шкала,
	|	Вложенныйзапрос.Услуга КАК Услуга,
	|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	ЕСТЬNULL(энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона, ЗНАЧЕНИЕ(Справочник.энргТарифныеЗоны.ПустаяСсылка)) КАК ТарифнаяЗона
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|		ДанныеПоПриборам.Шкала КАК Шкала,
	|		ЕСТЬNULL(УслугиТочекУчета.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|		ЕСТЬNULL(ВидыДифференцированностиТочекУчета.ВидДифференцированности, ВЫБОР
	|				КОГДА НЕ ДанныеПоПриборам.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПУстаяСсылка)
	|					ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)
	|				ИНАЧЕ ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка)
	|			КОНЕЦ) КАК ВидДифференцированности
	|	ИЗ
	|		ДанныеПоПриборам КАК ДанныеПоПриборам
	|			ЛЕВОЕ СОЕДИНЕНИЕ УслугиТочекУчета КАК УслугиТочекУчета
	|			ПО ДанныеПоПриборам.ТочкаУчета = УслугиТочекУчета.ТочкаУчета
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВидыДифференцированностиТочекУчета КАК ВидыДифференцированностиТочекУчета
	|			ПО ДанныеПоПриборам.ПриборУчета = ВидыДифференцированностиТочекУчета.ПриборУчета
	|				И ДанныеПоПриборам.Шкала = ВидыДифференцированностиТочекУчета.Шкала) КАК Вложенныйзапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
	|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Вложенныйзапрос.ТочкаУчета,
	|	Услуга,
	|	Вложенныйзапрос.Шкала";	
	Результат  = Запрос.Выполнить();
	Возврат Результат;
	
КонецФункции

// Проверяет ТЧ на заполненность.
//
// Параметры:
//  ТекущийОбъект	-	ДокументОбъект.<Имя документа>.
//  ИмяКоллекции	-	Строка.
//  Отказ			-	Булево.
//
Процедура ПроверитьТЧНаЗаполненность(ТекущийОбъект,ИмяКоллекции,Отказ) Экспорт
	
КонецПроцедуры

// Заполняет схему запроса активных приборов учета МКД.
//
// Параметры:
//  Схема		-	СхемаКомпоновкиДанных.
//  Параметры	-	Структура.
//
Процедура ЗаполнитьСхемуЗапросаАктивныхПриборовУчетаМКД(Схема, Параметры) Экспорт
	
	РегистрыСведений.энргСостояниеПриборовМКД.АктивныеПриборыУчетаМКД(Схема,Параметры,"ВведенныеПриборыДействующихТочек");
	РегистрыСведений.энргУслугиТочекУчетаМКД.УслугиДействующихТочек(Схема,Параметры,"УслугиДействующихТочек");
	РегистрыСведений.энргВидыДифференцированностиПриборовУчетаМКД.ВидДифференцированностиВведенныхПриборов(Схема,Параметры,"ВидДифференцированностиВведенныхПриборов");
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
	|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВведенныеПриборыДействующихТочек.Организация КАК Организация,
	|		ВведенныеПриборыДействующихТочек.Район КАК Район,
	|		ВведенныеПриборыДействующихТочек.МКД КАК МКД,
	|		ВведенныеПриборыДействующихТочек.ТочкаУчета КАК ТочкаУчета,	
	|		ВведенныеПриборыДействующихТочек.ПриборУчета КАК ПриборУчета,
	|		энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности,
	|		энргПриборыУчетаАбонента.РегистрируетОбъем КАК РегистрируетОбъем
	|	ИЗ
	|		ВведенныеПриборыДействующихТочек КАК ВведенныеПриборыДействующихТочек
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|			ПО ВведенныеПриборыДействующихТочек.ПриборУчета = энргПриборыУчетаАбонента.Ссылка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВложенныйЗапрос.ВидКанальности = энргВидыКанальностиШкалы.Ссылка");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	Вложенныйзапрос.Организация КАК Организация,
	|	Вложенныйзапрос.Район КАК Район,
	|	Вложенныйзапрос.МКД КАК МКД,
	|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
	|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
	|	Вложенныйзапрос.Шкала КАК Шкала,
	|	Вложенныйзапрос.Услуга КАК Услуга,
	|	Вложенныйзапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргПоставщикиУслугМКДСрезПоследних.Поставщик КАК Поставщик
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеПоПриборам.Организация КАК Организация,
	|		ДанныеПоПриборам.Район КАК Район,
	|		ДанныеПоПриборам.МКД КАК МКД,
	|		ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|		ДанныеПоПриборам.Шкала КАК Шкала,
	|		ДанныеПоПриборам.РегистрируетОбъем КАК РегистрируетОбъем,
	|		ЕСТЬNULL(УслугиДействующихТочек.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|		ЕСТЬNULL(ВидДифференцированностиВведенныхПриборов.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности
	|	ИЗ
	|		ДанныеПоПриборам КАК ДанныеПоПриборам
	|			ЛЕВОЕ СОЕДИНЕНИЕ УслугиДействующихТочек КАК УслугиДействующихТочек
	|			ПО ДанныеПоПриборам.Организация = УслугиДействующихТочек.Организация
	|				И ДанныеПоПриборам.Район = УслугиДействующихТочек.Район
	|				И ДанныеПоПриборам.МКД = УслугиДействующихТочек.МКД
	|				И ДанныеПоПриборам.ТочкаУчета = УслугиДействующихТочек.ТочкаУчета
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВидДифференцированностиВведенныхПриборов КАК ВидДифференцированностиВведенныхПриборов
	|			ПО ДанныеПоПриборам.Организация = ВидДифференцированностиВведенныхПриборов.Организация
	|				И ДанныеПоПриборам.Район = ВидДифференцированностиВведенныхПриборов.Район
	|				И ДанныеПоПриборам.МКД = ВидДифференцированностиВведенныхПриборов.МКД
	|				И ДанныеПоПриборам.ПриборУчета = ВидДифференцированностиВведенныхПриборов.ПриборУчета
	|				И ДанныеПоПриборам.Шкала = ВидДифференцированностиВведенныхПриборов.Шкала) КАК Вложенныйзапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
	|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргПоставщикиУслугМКД.СрезПоследних(&Период, НЕ ЧастьСоставной) КАК энргПоставщикиУслугМКДСрезПоследних
	|		ПО Вложенныйзапрос.Организация = энргПоставщикиУслугМКДСрезПоследних.Организация
	|			И Вложенныйзапрос.Район = энргПоставщикиУслугМКДСрезПоследних.Район
	|			И Вложенныйзапрос.МКД = энргПоставщикиУслугМКДСрезПоследних.МКД
	|			И Вложенныйзапрос.ТочкаУчета = энргПоставщикиУслугМКДСрезПоследних.ТочкаУчета
	|			И Вложенныйзапрос.Услуга = энргПоставщикиУслугМКДСрезПоследних.Услуга
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Район,
	|	МКД,
	|	Вложенныйзапрос.ТочкаУчета,
	|	Вложенныйзапрос.Шкала");
	
КонецПроцедуры

// Заполняет схему запроса активных ТУ и их приборов учета МКД.
//
// Параметры:
//  Схема		-	СхемаКомпоновкиДанных.
//  Параметры	-	Структура.
//
Процедура ЗаполнитьСхемуЗапросаАктивныхТУиИхПриборовУчетаМКД(Схема, Параметры) Экспорт
	
	РегистрыСведений.энргСостояниеПриборовМКД.АктивныеПриборыУчетаМКД(Схема,Параметры,"ВведенныеПриборыДействующихТочек");
	РегистрыСведений.энргУслугиТочекУчетаМКД.УслугиДействующихТочек(Схема,Параметры,"УслугиДействующихТочек");
	РегистрыСведений.энргВидыДифференцированностиПриборовУчетаМКД.ВидДифференцированностиВведенныхПриборов(Схема,Параметры,"ВидДифференцированностиВведенныхПриборов");
		
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
	|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВведенныеПриборыДействующихТочек.Организация КАК Организация,
	|		ВведенныеПриборыДействующихТочек.Район КАК Район,
	|		ВведенныеПриборыДействующихТочек.МКД КАК МКД,
	|		ВведенныеПриборыДействующихТочек.ТочкаУчета КАК ТочкаУчета,	
	|		ВведенныеПриборыДействующихТочек.ПриборУчета КАК ПриборУчета,
	|		энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности,
	|		энргПриборыУчетаАбонента.РегистрируетОбъем КАК РегистрируетОбъем
	|	ИЗ
	|		ВведенныеПриборыДействующихТочек КАК ВведенныеПриборыДействующихТочек
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|			ПО ВведенныеПриборыДействующихТочек.ПриборУчета = энргПриборыУчетаАбонента.Ссылка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВложенныйЗапрос.ВидКанальности = энргВидыКанальностиШкалы.Ссылка");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	Вложенныйзапрос.Организация КАК Организация,
	|	Вложенныйзапрос.Район КАК Район,
	|	Вложенныйзапрос.МКД КАК МКД,
	|	Вложенныйзапрос.ТочкаУчета КАК ТочкаУчета,
	|	Вложенныйзапрос.ПриборУчета КАК ПриборУчета,
	|	Вложенныйзапрос.Шкала КАК Шкала,
	|	Вложенныйзапрос.Услуга КАК Услуга,
	|	Вложенныйзапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	Вложенныйзапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргПоставщикиУслугМКДСрезПоследних.Поставщик КАК Поставщик
	|ИЗ
	|	(ВЫБРАТЬ
	|		УслугиДействующихТочек.Организация КАК Организация,
	|		УслугиДействующихТочек.Район КАК Район,
	|		УслугиДействующихТочек.МКД КАК МКД,
	|		УслугиДействующихТочек.ТочкаУчета КАК ТочкаУчета,
	|		ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|		ДанныеПоПриборам.Шкала КАК Шкала,
	|		ДанныеПоПриборам.РегистрируетОбъем КАК РегистрируетОбъем,
	|		ЕСТЬNULL(УслугиДействующихТочек.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|		ЕСТЬNULL(ВидДифференцированностиВведенныхПриборов.ВидДифференцированности, ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)) КАК ВидДифференцированности
	|	ИЗ
	|		УслугиДействующихТочек КАК УслугиДействующихТочек
	|			ЛЕВОЕ СОЕДИНЕНИЕ ДанныеПоПриборам КАК ДанныеПоПриборам
	|				ЛЕВОЕ СОЕДИНЕНИЕ ВидДифференцированностиВведенныхПриборов КАК ВидДифференцированностиВведенныхПриборов
	|				ПО ДанныеПоПриборам.Организация = ВидДифференцированностиВведенныхПриборов.Организация
	|					И ДанныеПоПриборам.Район = ВидДифференцированностиВведенныхПриборов.Район
	|					И ДанныеПоПриборам.МКД = ВидДифференцированностиВведенныхПриборов.МКД
	|					И ДанныеПоПриборам.ПриборУчета = ВидДифференцированностиВведенныхПриборов.ПриборУчета
	|					И ДанныеПоПриборам.Шкала = ВидДифференцированностиВведенныхПриборов.Шкала
	|			ПО УслугиДействующихТочек.Организация = ДанныеПоПриборам.Организация
	|				И УслугиДействующихТочек.Район = ДанныеПоПриборам.Район
	|				И УслугиДействующихТочек.МКД = ДанныеПоПриборам.МКД
	|				И УслугиДействующихТочек.ТочкаУчета = ДанныеПоПриборам.ТочкаУчета) КАК Вложенныйзапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыДифференцированности.ТарифныеЗоны КАК энргВидыДифференцированностиТарифныеЗоны
	|		ПО Вложенныйзапрос.ВидДифференцированности = энргВидыДифференцированностиТарифныеЗоны.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргПоставщикиУслугМКД.СрезПоследних(&Период, НЕ ЧастьСоставной) КАК энргПоставщикиУслугМКДСрезПоследних
	|		ПО Вложенныйзапрос.Организация = энргПоставщикиУслугМКДСрезПоследних.Организация
	|			И Вложенныйзапрос.Район = энргПоставщикиУслугМКДСрезПоследних.Район
	|			И Вложенныйзапрос.МКД = энргПоставщикиУслугМКДСрезПоследних.МКД
	|			И Вложенныйзапрос.ТочкаУчета = энргПоставщикиУслугМКДСрезПоследних.ТочкаУчета
	|			И Вложенныйзапрос.Услуга = энргПоставщикиУслугМКДСрезПоследних.Услуга
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Район,
	|	МКД,
	|	Вложенныйзапрос.ТочкаУчета,
	|	Вложенныйзапрос.Шкала");
	
КонецПроцедуры

#КонецОбласти

