// Записывает данные вывода.
//
// Параметры:
//  ДанныеШапки			-	Структура.
//  Движения			-	КоллекцияДвижений.
//  ИмяСвойства			-	Строка.
//  СоотвествиеКолонок	-	Соответствие.
//
Процедура ЗаписатьДанныеВывода(ДанныеШапки,Движения,ИмяСвойства,СоотвествиеКолонок) Экспорт 
	
	Набор  									= Движения["энргВыводПриборовУчета"];
	
	АбонентУказанВШапке  					= ДанныеШапки.свойство("Абонент");
	ДатаУказанаВШапке	  					= ДанныеШапки.свойство("Дата");	
	
	ТЗ = ДанныеШапки[ИмяСвойства].Выгрузить();
	ТЗ.Свернуть("" + СоотвествиеКолонок.ТочкаУчета + "," + СоотвествиеКолонок.ПриборУчета + ?(ДатаУказанаВШапке,"",СоотвествиеКолонок.Дата));
	для Каждого стр из ТЗ цикл
		Если ЗначениеЗаполнено(Стр[СоотвествиеКолонок.ПриборУчета]) Тогда
			Запись  					= Набор.добавить();
			Запись.Период  				= ?(ДатаУказанаВШапке,ДанныеШапки.Дата,Стр[СоотвествиеКолонок.Дата]);
			Запись.Район  				= ДанныеШапки.Район;
			Запись.Организация	 		= ДанныеШапки.Организация;
			Запись.КлючПомещения  		= ДанныеШапки.КлючПомещения;
			Запись.ТочкаУчета 			= Стр[СоотвествиеКолонок.ТочкаУчета];
			Запись.ПриборУчета 			= Стр[СоотвествиеКолонок.ПриборУчета];
			Запись.ПериодНачисления 	= ДанныеШапки.ПериодНачисления;
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры  

