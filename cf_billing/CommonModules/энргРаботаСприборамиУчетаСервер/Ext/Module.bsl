Процедура ДополнитьПолучаемыеСвойстваПриборовУчета(ПолучаемыеСвойстваПриборовУчета)
	СтруктураСвойств 	= Новый Структура;
	НаборПолей			= Новый Массив;
	
	Обработки.энргПриборыУчетаАбонентаМенеджер.СтандартныеРеквизитыПрибораУчета(СтруктураСвойств);
	Для Каждого ТекКлючЗначение из СтруктураСвойств Цикл 
		НаборПолей.Добавить(ТекКлючЗначение.Ключ);
	КонецЦикла;
	
	ПолучаемыеСвойстваПриборовУчета = ПолучаемыеСвойстваПриборовУчета + СтрСоединить(НаборПолей, ",");
КонецПроцедуры

Процедура ОписатьСтруктуруДанныхПрибораУчета(ДанныеПрибораУчета)	
	ДанныеПрибораУчета.Вставить("ЗаводскойНомер"				, "");
	ДанныеПрибораУчета.Вставить("ТипПрибораУчета"				, Справочники.энргТипыПриборовУчета.ПустаяСсылка());
	ДанныеПрибораУчета.Вставить("ВидКанальности"				, Справочники.энргВидыКанальности.ПустаяСсылка());
	ДанныеПрибораУчета.Вставить("РегистрируетОбъем"				, Ложь);
	ДанныеПрибораУчета.Вставить("КодАСКУЭ"						, "");
	ДанныеПрибораУчета.Вставить("СобственникАСКУЭ"				, Справочники.энргКонтрагенты.ПустаяСсылка());
	ДанныеПрибораУчета.Вставить("СобственникСИ"					, Перечисления.энргБалансоваяПринадлежность.ПустаяСсылка());
	ДанныеПрибораУчета.Вставить("ДатаВыпуска"					, Дата(1,1,1));
	ДанныеПрибораУчета.Вставить("РасположениеИзмерителя"		, Справочники.энргРасположениеИзмерителей.ПустаяСсылка());
	ДанныеПрибораУчета.Вставить("СистемаУчетаЭлектроэнергии"	, Справочники.энргСистемыУчетаЭлектроэнергии.ПустаяСсылка());
	ДанныеПрибораУчета.Вставить("ДатаИнтеграцииССистемой"		, Дата(1,1,1));
	ДанныеПрибораУчета.Вставить("ТипУзлаУчета"					, Справочники.энргТипыУзловУчета.ПустаяСсылка());
	ДанныеПрибораУчета.Вставить("Фаза"							, Перечисления.энргФазыТрансформатора.ПустаяСсылка());
	ДанныеПрибораУчета.Вставить("БалансоваяПринадлежность"		, Перечисления.энргБалансоваяПринадлежность.ПустаяСсылка());
	ДанныеПрибораУчета.Вставить("ДатаУстановки"					, Дата(1,1,1));
КонецПроцедуры

Процедура ЗаполнитьСтруктуруДанныхПрибораУчета(Описание, ДанныеПрибораУчета)	
	
	Если Описание.Свойство("ЗаводскойНомер") тогда
		ДанныеПрибораУчета.ЗаводскойНомер 				= Описание.ЗаводскойНомер;
	ИначеЕсли Описание.Свойство("Код") тогда
		ДанныеПрибораУчета.ЗаводскойНомер 				= Описание.Код;
	КонецЕсли;
	
	Если Описание.Свойство("РегистрируетОбъем") тогда
		ДанныеПрибораУчета.РегистрируетОбъем 			= Описание.РегистрируетОбъем;
	КонецЕсли;
	
	Если Описание.Свойство("ТипПрибораУчета") тогда
		Ключ  											= Новый УникальныйИдентификатор(Описание.ТипПрибораУчета);
		ДанныеПрибораУчета.ТипПрибораУчета				= Справочники.энргТипыПриборовУчета.ПолучитьСсылку(Ключ);
	КонецЕсли;
	
	Если Описание.Свойство("ВидКанальности") тогда
		Ключ  											= Новый УникальныйИдентификатор(Описание.ВидКанальности);
		ДанныеПрибораУчета.ВидКанальности				= Справочники.энргВидыКанальности.ПолучитьСсылку(Ключ);
	КонецЕсли;
	
	Если Описание.Свойство("КодАСКУЭ") Тогда 
		ДанныеПрибораУчета.КодАСКУЭ						= Описание.КодАСКУЭ;
	КонецЕсли;
	Если Описание.Свойство("СобственникАСКУЭ") Тогда 
		Ключ  											= Новый УникальныйИдентификатор(Описание.СобственникАСКУЭ);
		ДанныеПрибораУчета.СобственникАСКУЭ				= Справочники.энргКонтрагенты.ПолучитьСсылку(Ключ);
	КонецЕсли;
	Если Описание.Свойство("СистемаУчетаЭлектроэнергии") Тогда 
		Ключ  											= Новый УникальныйИдентификатор(Описание.СистемаУчетаЭлектроэнергии);
		ДанныеПрибораУчета.СистемаУчетаЭлектроэнергии	= Справочники.энргСистемыУчетаЭлектроэнергии.ПолучитьСсылку(Ключ);
	КонецЕсли;
	Если Описание.Свойство("ДатаИнтеграцииССистемой") Тогда 
		ДанныеПрибораУчета.ДатаИнтеграцииССистемой		= Описание.ДатаИнтеграцииССистемой;
	КонецЕсли;
	Если Описание.Свойство("СобственникСИ") Тогда
		ДанныеПрибораУчета.СобственникСИ 				= Перечисления.энргБалансоваяПринадлежность[Описание.СобственникСИ];
		//Ключ  											= Новый УникальныйИдентификатор(Описание.СобственникСИ);
		//ДанныеПрибораУчета.СобственникСИ				= Справочники.энргКонтрагенты.ПолучитьСсылку(Ключ);
	КонецЕсли;
	Если Описание.Свойство("РасположениеИзмерителя") Тогда 
		Ключ  											= Новый УникальныйИдентификатор(Описание.РасположениеИзмерителя);
		ДанныеПрибораУчета.РасположениеИзмерителя		= Справочники.энргРасположениеИзмерителей.ПолучитьСсылку(Ключ);
	КонецЕсли;
	Если Описание.Свойство("ДатаВыпуска") тогда
		ДанныеПрибораУчета.ДатаВыпуска 					= Описание.ДатаВыпуска;
	КонецЕсли;
	Если Описание.Свойство("БалансоваяПринадлежность") Тогда
		ДанныеПрибораУчета.БалансоваяПринадлежность 	= Перечисления.энргБалансоваяПринадлежность[Описание.БалансоваяПринадлежность];
	КонецЕсли;
	Если Описание.Свойство("Фаза") тогда
		ДанныеПрибораУчета.Фаза 						= Описание.Фаза;
	КонецЕсли;
	Если Описание.Свойство("ДатаУстановки") тогда
		ДанныеПрибораУчета.ДатаУстановки 				= Описание.ДатаУстановки;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьПриборУчета(ПриборОбъект, ДанныеПрибораУчета)
	ПриборОбъект.Код 								= ДанныеПрибораУчета.ЗаводскойНомер;
	ПриборОбъект.ТипПрибораУчета 					= ДанныеПрибораУчета.ТипПрибораУчета;
	ПриборОбъект.ВидКанальности 					= ДанныеПрибораУчета.ВидКанальности;
	ПриборОбъект.РегистрируетОбъем 					= ДанныеПрибораУчета.РегистрируетОбъем;
	ПриборОбъект.КодАСКУЭ 							= ДанныеПрибораУчета.КодАСКУЭ;
	ПриборОбъект.СобственникАСКУЭ 					= ДанныеПрибораУчета.СобственникАСКУЭ;
	ПриборОбъект.СистемаУчетаЭлектроэнергии 		= ДанныеПрибораУчета.СистемаУчетаЭлектроэнергии;
	ПриборОбъект.ДатаИнтеграцииССистемой 			= ДанныеПрибораУчета.ДатаИнтеграцииССистемой;
	ПриборОбъект.СобственникСИ 						= ДанныеПрибораУчета.СобственникСИ;
	ПриборОбъект.ДатаВыпуска 						= ДанныеПрибораУчета.ДатаВыпуска;
	ПриборОбъект.РасположениеИзмерителя 			= ДанныеПрибораУчета.РасположениеИзмерителя;
	ПриборОбъект.Фаза 								= ДанныеПрибораУчета.Фаза;
	ПриборОбъект.БалансоваяПринадлежность 			= ДанныеПрибораУчета.БалансоваяПринадлежность;
	ПриборОбъект.ДатаУстановки 						= ДанныеПрибораУчета.ДатаУстановки;
	ПриборОбъект.Записать();
КонецПроцедуры

Функция ВидыДифференцированностиПриборов(ДокументСсылка)
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	ТаблицаТочкиУчета.ТочкаУчета,
	|	ТаблицаТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	ТаблицаШкалыПриборов.Шкала КАК Шкала,
	|	ВЫБОР
	|		КОГДА ТаблицаШкалыПриборов.ВидДифференцированности = ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)
	|		ИНАЧЕ ТаблицаШкалыПриборов.ВидДифференцированности
	|	КОНЕЦ КАК ВидДифференцированности
	|ИЗ
	|	Документ.энргОперацияСЛицевымСчетом.ТочкиУчета КАК ТаблицаТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом.ШкалыПриборовУчета КАК ТаблицаШкалыПриборов
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаШкалыПриборов.Ссылка
	|			И ТаблицаТочкиУчета.IDСтроки = ТаблицаШкалыПриборов.IDСтрокиТочкиУчета
	|			И (НЕ ТаблицаТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|			И (ТаблицаТочкиУчета.Ссылка = &ДокументСсылка)
	|			И (ТаблицаШкалыПриборов.Ссылка = &ДокументСсылка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом КАК ТаблицаДокумента
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаДокумента.Ссылка
	|			И (ТаблицаДокумента.Ссылка = &ДокументСсылка)
	|			И (ТаблицаДокумента.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТаблицаТочкиУчета.ТочкаУчета,
	|	ТаблицаТочкиУчета.ПриборУчета,
	|	ТаблицаШкалыПриборов.Шкала,
	|	ВЫБОР
	|		КОГДА ТаблицаШкалыПриборов.ВидДифференцированности = ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)
	|		ИНАЧЕ ТаблицаШкалыПриборов.ВидДифференцированности
	|	КОНЕЦ
	|ИЗ
	|	Документ.энргОперацияСУслугами.ТочкиУчета КАК ТаблицаТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ШкалыПриборовУчета КАК ТаблицаШкалыПриборов
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаШкалыПриборов.Ссылка
	|			И ТаблицаТочкиУчета.IDСтроки = ТаблицаШкалыПриборов.IDСтрокиТочкиУчета
	|			И (НЕ ТаблицаТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|			И (ТаблицаТочкиУчета.Ссылка = &ДокументСсылка)
	|			И (ТаблицаШкалыПриборов.Ссылка = &ДокументСсылка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами КАК ТаблицаДокумента
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаДокумента.Ссылка
	|			И (ТаблицаДокумента.Ссылка = &ДокументСсылка)
	|			И (ТаблицаДокумента.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТаблицаТочкиУчета.ТочкаУчета,
	|	ТаблицаТочкиУчета.ПриборУчета,
	|	ТаблицаШкалыПриборов.Шкала,
	|	ВЫБОР
	|		КОГДА ТаблицаШкалыПриборов.ВидДифференцированности = ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)
	|		ИНАЧЕ ТаблицаШкалыПриборов.ВидДифференцированности
	|	КОНЕЦ
	|ИЗ
	|	Документ.энргОперацияСПриборомУчета.ТочкиУчета КАК ТаблицаТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСПриборомУчета.ШкалыПриборовУчета КАК ТаблицаШкалыПриборов
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаШкалыПриборов.Ссылка
	|			И (НЕ ТаблицаТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|			И ТаблицаТочкиУчета.IDСтроки = ТаблицаШкалыПриборов.IDСтрокиТочкиУчета
	|			И (ТаблицаТочкиУчета.Ссылка = &ДокументСсылка)
	|			И (ТаблицаШкалыПриборов.Ссылка = &ДокументСсылка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСПриборомУчета КАК ТаблицаДокумента
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаДокумента.Ссылка
	|			И (ТаблицаДокумента.Ссылка = &ДокументСсылка)
	|			И (ТаблицаДокумента.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСПриборомУчета_ВводПУ), ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ)))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТаблицаТочкиУчета.ТочкаУчета,
	|	ТаблицаТочкиУчета.ПриборУчета,
	|	ТаблицаШкалыПриборов.Шкала,
	|	ВЫБОР
	|		КОГДА ТаблицаШкалыПриборов.ВидДифференцированности = ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)
	|		ИНАЧЕ ТаблицаШкалыПриборов.ВидДифференцированности
	|	КОНЕЦ
	|ИЗ
	|	Документ.энргУстановитьВидДифференцированностиПриборУчета.ТочкиУчета КАК ТаблицаТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргУстановитьВидДифференцированностиПриборУчета.ШкалыПриборовУчета КАК ТаблицаШкалыПриборов
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаШкалыПриборов.Ссылка
	|			И ТаблицаТочкиУчета.IDСтроки = ТаблицаШкалыПриборов.IDСтрокиТочкиУчета
	|			И (НЕ ТаблицаТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|			И (ТаблицаТочкиУчета.Ссылка = &ДокументСсылка)
	|			И (ТаблицаШкалыПриборов.Ссылка = &ДокументСсылка)
	|			И (ТаблицаШкалыПриборов.ВидДифференцированности <> ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка))
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргУстановитьВидДифференцированностиПриборУчета КАК ТаблицаДокумента
	|		ПО ТаблицаТочкиУчета.Ссылка = ТаблицаДокумента.Ссылка
	|			И (ТаблицаДокумента.Ссылка = &ДокументСсылка)";
	
	Возврат Запрос.Выполнить();
	
КонецФункции

