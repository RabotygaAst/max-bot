#КонецОбласти

// Создает приборы учета.
//
// Параметры:
//  ТекущийОбъект					-	ДокументОбъект.
//  ИмяКоллекции					-	Строка.
//  Отказ							-	Булево.
//  ИмяСвойстваНовыйПриборыУчета	-	Строка.
//
Процедура СоздатьПриборыУчета(ТекущийОбъект,ИмяКоллекции,Отказ,ИмяСвойстваНовыйПриборыУчета = "НовыеПриборыУчета") Экспорт  
	
	ДанныеТабличнойЧасти 					= ТекущийОбъект[ИмяКоллекции];
	
	НовыеТочкиУчета 						= Новый Массив;
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеТочкиУчета") Тогда
		НовыеТочкиУчета 						= ТекущийОбъект.ДополнительныеСвойства.НовыеТочкиУчета; 
	КонецЕсли;
	
	НовыеПриборыУчета 						= Новый Массив;
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство(ИмяСвойстваНовыйПриборыУчета) Тогда
		НовыеПриборыУчета 					= ТекущийОбъект.ДополнительныеСвойства[ИмяСвойстваНовыйПриборыУчета]; 
	КонецЕсли;
	
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ИзмененныеТУ") Тогда
		ИзмененныеТУ							= ТекущийОбъект.ДополнительныеСвойства.ИзмененныеТУ;
	КонецЕсли;
	
	Для Каждого СтрокаТочки Из ДанныеТабличнойЧасти Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТочки.ОписаниеПрибора) Тогда//ИЛИ НовыеПриборыУчета.Найти(СтрокаТочки.НомерСтроки) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭтоНоваяТУ							= НЕ НовыеТочкиУчета.Найти(СтрокаТочки.НомерСтроки) = Неопределено;
		
		Если Не ЭтоНоваяТУ И ТекущийОбъект.ДополнительныеСвойства.Свойство("ИзмененныеТУ") И ИзмененныеТУ.Найти(СтрокаТочки.ТочкаУчета) = Неопределено Тогда
			// эту ТУ не изменяли, перезаписывать не надо
			Продолжить;
		КонецЕсли;
		
		//Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ИзмененныеТУ") И ИзмененныеТУ.Найти(СтрокаТочки.ТочкаУчета) = Неопределено  Тогда
		//	Продолжить;
		//КонецЕсли;
		
		Чтение  							= Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(СтрокаТочки.ОписаниеПрибора);		
		Описание							= ПрочитатьJSON(Чтение);
		
		
		//ДанныеПрибораУчета					= Новый Структура("ЗаводскойНомер,ТипПрибораУчета,ВидКанальности,РегистрируетОбъем,КодАСКУЭ,СобственникАСКУЭ,СобственникСИ,ДатаВыпуска,РасположениеИзмерителя,СистемаУчетаЭлектроэнергии,ДатаИнтеграцииССистемой,ТипУзлаУчета,Фаза",
		//"",Справочники.энргТипыПриборовУчета.ПустаяСсылка(),Справочники.энргВидыКанальности.ПустаяСсылка(), ЛОЖЬ,"", Справочники.энргКонтрагенты.ПустаяСсылка(), Справочники.энргКонтрагенты.ПустаяСсылка(), Дата(1,1,1), Справочники.энргРасположениеИзмерителей.ПустаяСсылка(), Справочники.энргСистемыУчетаЭлектроэнергии.ПустаяСсылка(), Дата(1,1,1), Справочники.энргТипыУзловУчета.ПустаяСсылка(), Перечисления.энргФазыТрансформатора.ПустаяСсылка());
		
		ДанныеПрибораУчета					= Новый Структура;
		ОписатьСтруктуруДанныхПрибораУчета(ДанныеПрибораУчета);
		
		ЗаполнитьСтруктуруДанныхПрибораУчета(Описание, ДанныеПрибораУчета);
		
		Если НЕ НовыеПриборыУчета.Найти(СтрокаТочки.НомерСтроки) = Неопределено Тогда
			ПриборОбъект		 			= Справочники.энргПриборыУчетаАбонента.СоздатьЭлемент();
		    ПриборОбъект.УстановитьСсылкуНового(СтрокаТочки.ПриборУчета);
		Иначе
			ПриборОбъект  					= СтрокаТочки.ПриборУчета.получитьОбъект();
		КонецЕсли;
		
		ЗаписатьПриборУчета(ПриборОбъект, ДанныеПрибораУчета);		
		
	КонецЦикла;	
	
КонецПроцедуры

// Возвращает действующие точки и их приборы учета МКД.
//
// Параметры:
//  Период		-	Дата.
//  Организация	-	СправочникСсылка.Организации.
//  Район		-	СправочникСсылка.энргЗоныОтвественности.
//  МКД			-	СправочникСсылка.энргСтроения.
//  ТочкаУчета	-	СправочникСсылка.энргТочкиУчета
// 
// Возвращаемое значение:
//   РезультатЗапроса
//
Функция ДействующиеТочкиИИхПриборыУчетаМКД(Период, Организация, Район, МКД, ТочкаУчета = Неопределено) Экспорт 
	
	Схема 			= Неопределено;  	
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", 	"Организация"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район", 			"Район"), 			Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("МКД", 			"МКД"), 	Неопределено));
		
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыВТ.Вставить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета", 	"ТочкаУчета"), 		Неопределено));
	КонецЕсли;
	
	Параметры 		= Новый Структура;	
	Параметры.Вставить("ПараметрыВТ", 		ПараметрыВТ);
	Если ЗначениеЗаполнено(Период) Тогда
		Параметры.Вставить("Период",  Новый Структура("ИмяПараметра", "Период"));
	КонецЕсли;

	ЗаполнитьСхемуЗапросаАктивныхТУиИхПриборовУчетаМКД(Схема, Параметры);
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	ПараметрыЗапроса.Вставить("Район",					Район);
	ПараметрыЗапроса.Вставить("Организация",			Организация);
	ПараметрыЗапроса.Вставить("МКД",					МКД);
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ТочкаУчета",			ТочкаУчета);
	КонецЕсли;                                   
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргРаботаСприборамиУчетаСервер.ДействующиеТочкиИИхПриборыУчетаМКД";
		ПараметрыМетода 			= Новый Структура("Период,Организация,Район,МКД,ТочкаУчета", Период, Организация, Район, МКД, ТочкаУчета);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);
	КонецЕсли;
	
	Возврат РезультатЗапроса; 
	 	
КонецФункции

// Возвращает действующие приборы учета МКД.
//
// Параметры:
//  Период		-	Дата.
//  Организация	-	СправочникСсылка.Организации.
//  Район		-	СправочникСсылка.энргЗоныОтвественности.
//  МКД			-	СправочникСсылка.энргСтроения.
//  ТочкаУчета	-	СправочникСсылка.энргТочкиУчета.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ДействующиеПриборыУчетаМКД(Период,Организация,Район,МКД,ТочкаУчета = Неопределено) Экспорт 
	
	Схема 			= Неопределено;  	
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", 	"Организация"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район", 			"Район"), 			Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("МКД", 			"МКД"), 	Неопределено));
		
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета", 	"ТочкаУчета"), 		Неопределено));
	КонецЕсли;
	
	Параметры 	= Новый Структура;	
	Параметры.Вставить("ПараметрыВТ", 		ПараметрыВТ);
	Если ЗначениеЗаполнено(Период) Тогда
		Параметры.Вставить("Период",  Новый Структура("ИмяПараметра", "Период"));
	КонецЕсли;
	
	ЗаполнитьСхемуЗапросаДействующихПриборовУчетаМКД(Схема, Параметры);
	   	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Период",			Новый Граница(Период,ВидГраницы.Исключая));
	ПараметрыЗапроса.Вставить("Район",			Район);
	ПараметрыЗапроса.Вставить("Организация",	Организация);
	ПараметрыЗапроса.Вставить("МКД",			МКД);
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ТочкаУчета",	ТочкаУчета);
	КонецЕсли; 	
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргРаботаСприборамиУчетаСервер.ДействующиеПриборыУчетаМКД";
		ПараметрыМетода 			= Новый Структура("Период,Организация,Район,МКД,ТочкаУчета", Период,Организация,Район,МКД,ТочкаУчета);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);
	КонецЕсли;
	
	Возврат РезультатЗапроса
	 	
КонецФункции

// Возвращает действующие приборы учета абонента.
//
// Параметры:
//  Период			-	Дата.
//  Организация		-	СправочникСсылка.Организации.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  КлючПомещения	-	СправочникСсылка.энргКлючиПомещений.
//  ТочкаУчета		-	Произвольный.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ДействующиеПриборыУчетаАбонента(Период,Организация,Район,КлючПомещения,ТочкаУчета = Неопределено) Экспорт 
	
	Схема 			= Неопределено;  	
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", 	"Организация"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район", 			"Район"), 			Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения", 	"КлючПомещения"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("АбонентВладелец", "КлючПомещения"), 	Неопределено));
		
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета", 	"ТочкаУчета"), 		Неопределено));
	КонецЕсли;
	
	Параметры 	= Новый Структура;	
	Параметры.Вставить("ПараметрыВТ", 		ПараметрыВТ);
	Если ЗначениеЗаполнено(Период) Тогда
		Параметры.Вставить("Период",  Новый Структура("ИмяПараметра", "Период"));
	КонецЕсли;
	
	ЗаполнитьСхемуЗапросаДействующихПриборовУчетаАбонента(Схема, Параметры);
	   	
	ПараметрыЗапроса = Новый Структура;
	//ПараметрыЗапроса.Вставить("Период",			Новый Граница(Период,ВидГраницы.Исключая));
	ПараметрыЗапроса.Вставить("Период",			Период);

	ПараметрыЗапроса.Вставить("Район",			Район);
	ПараметрыЗапроса.Вставить("Организация",	Организация);
	ПараметрыЗапроса.Вставить("КлючПомещения",	КлючПомещения);
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ТочкаУчета",	ТочкаУчета);
	КонецЕсли; 	
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);

	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргРаботаСприборамиУчетаСервер.ДействующиеПриборыУчетаАбонента";
		ПараметрыМетода 			= Новый Структура("Период,Организация,Район,КлючПомещения,ТочкаУчета", Период,Организация,Район,КлючПомещения,ТочкаУчета);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);
	КонецЕсли;
	
	Возврат РезультатЗапроса
	 	
КонецФункции

// Возвращает показания приборов учета.
//
// Параметры:
//  Период			-	Дата.
//  Организация		-	СправочникСсылка.Организации.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  КлючПомещения	-	СправочникСсылка.энргКлючиПомещений.
// 
// Возвращаемое значение:
//    РезультатЗапроса.
//
Функция ПоказанияПриборовУчета(Период,Организация,Район,КлючПомещения) Экспорт 
	
	МВТ  				= Новый МенеджерВременныхТаблиц;
	
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("КлючПомещения",			КлючПомещения);
	
	Схема	= Неопределено;  
	
	врСоотвествиеПолей	= Новый Структура("Организация,Район,КлючПомещения","Организация","Район","КлючПомещения");		
	врПараметрыВТ 							= Новый Массив;
	врПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", врСоотвествиеПолей));
	Если Период <> Неопределено тогда
		врПараметрыВТ.Добавить("Период", Новый Структура("ИмяПараметра","Период"));
		Запрос.УстановитьПараметр("Период",	Период);
	КонецЕсли;
	врПараметры  							= Новый Структура("ПараметрыВТ", врПараметрыВТ);
	
	РегистрыСведений.энргМаксимальныеПоказания.МаксимальныеПоказанияСрез(Схема, врПараметры, "энргМаксимальныеПоказанияСрезПоследних");
	
	Запрос.Текст	= Схема.ПолучитьТекстЗапроса();
	Запрос.Выполнить();

	Текст 	=
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаАбонента
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
	|			&Период,
	|			КлючПомещения = &КлючПомещения
	|				И Район = &Район) КАК энргАктивностьТочекУчетаСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ТочкиУчетаАбонента
	|ИЗ
	|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаАбонента.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаАбонента КАК АктивныеТочкиУчетаАбонента)) КАК энргВладельцыТочекУчетаСрезПоследних
	|ГДЕ
	|	энргВладельцыТочекУчетаСрезПоследних.АбонентВладелец = &КлючПомещения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТочкиУчетаАбонента.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ДействующиеТочкиУчета
	|ИЗ
	|	ТочкиУчетаАбонента КАК ТочкиУчетаАбонента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АктивныеТочкиУчетаАбонента КАК АктивныеТочкиУчетаАбонента
	|		ПО ТочкиУчетаАбонента.ТочкаУчета = АктивныеТочкиУчетаАбонента.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПриборыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочекУчета
	|ИЗ
	|	РегистрСведений.энргПриборыТочекУчета.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И КлючПомещения = &КлючПомещения) КАК энргПриборыТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВведенныеПриборы
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовУчетаАбонента.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И КлючПомещения = &КлючПомещения) КАК энргСостояниеПриборовУчетаАбонентаСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДействующиеТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	ПриборыТочекУчета.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПриборыТочекУчета КАК ПриборыТочекУчета
	|		ПО ДействующиеТочкиУчета.ТочкаУчета = ПриборыТочекУчета.ТочкаУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВведенныеПриборы КАК ВведенныеПриборы
	|		ПО ПриборыТочекУчета.ПриборУчета = ВведенныеПриборы.ПриборУчета
	|			И ПриборыТочекУчета.ТочкаУчета = ВведенныеПриборы.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ УслугиТочекУчета
	|ИЗ
	|	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
	|			&Период,
	|			КлючПомещения = &КлючПомещения
	|				И Район = &Район) КАК энргУслугиТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргДатыПоверкиПрибораУчетаСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргДатыПоверкиПрибораУчетаСрезПоследних.ДатаПоверки КАК ДатаПоверки
	|ПОМЕСТИТЬ ДатыПоверкиПУ
	|ИЗ
	|	РегистрСведений.энргДатыПоверкиПрибораУчета.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И КлючПомещения = &КлючПомещения
	|				И ПриборУчета В
	|					(ВЫБРАТЬ
	|						ВведенныеПриборы.ПриборУчета
	|					ИЗ
	|						ВведенныеПриборы КАК ВведенныеПриборы)) КАК энргДатыПоверкиПрибораУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеПоПриборам.ТочкаУчета КАК ТочкаУчета,
	|	УслугиТочекУчета.Услуга КАК Услуга,
	|	УслугиТочекУчета.Услуга.ПредставлениеДляПечати КАК УслугаПредставлениеДляПечати,
	|	ДанныеПоПриборам.ПриборУчета КАК ПриборУчета,
	|	ЕСТЬNULL(энргПриборыУчетаАбонента.Код, """") КАК НомерПУ,
	|	ЕСТЬNULL(МаксимальныеПоказания.Показание, 0) КАК ТекущиеПоказания,
	|	ЕСТЬNULL(МаксимальныеПоказания.Период, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаТекущихПоказаний,
	|	ЕСТЬNULL(МаксимальныеПоказания.ТарифнаяЗона, """") КАК ТарифнаяЗона,
	|	ЕСТЬNULL(МаксимальныеПоказания.Шкала, """") КАК Шкала,
	|	ЕСТЬNULL(ДатыПоверкиПУ.ДатаПоверки, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПоверки
	|ИЗ
	|	ДанныеПоПриборам КАК ДанныеПоПриборам
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ДанныеПоПриборам.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ УслугиТочекУчета КАК УслугиТочекУчета
	|		ПО ДанныеПоПриборам.ТочкаУчета = УслугиТочекУчета.ТочкаУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ энргМаксимальныеПоказанияСрезПоследних КАК МаксимальныеПоказания
	|		ПО ДанныеПоПриборам.ПриборУчета = МаксимальныеПоказания.ПриборУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДатыПоверкиПУ КАК ДатыПоверкиПУ
	|		ПО ДанныеПоПриборам.ПриборУчета = ДатыПоверкиПУ.ПриборУчета";
	
	
	Если Период = Неопределено тогда
		Текст 			= СтрЗаменить(Текст,"&Период","");
	КонецЕсли; 	
	Запрос.Текст 		= Текст;
	Результат 		 	= Запрос.Выполнить();
	Возврат Результат;
	
КонецФункции

// Возвращает приборы всех точек учета МКД.
//
// Параметры:
//  Период		-	Дата.
//  Организация	-	СправочникСсылка.Организации.
//  Район		-	СправочникСсылка.энргЗоныОтвественности.
//  МКД			-	СправочникСсылка.энргСтроения.
//  РезультатТП	-	Произвольный.
//
// Возвращаемое значение:
//    РезультатЗапроса.
//
Функция ПриборыВсехТочекУчетаМКД(Период, Организация, Район, МКД, РезультатТП = Неопределено) Экспорт
			
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период, ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("МКД",					МКД);
	Запрос.УстановитьПараметр("Дата", 					Период);
	
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаАбонента
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчетаМКД.СрезПоследних(
	|			&Период,
	|			МКД = &МКД
	|				И Район = &Район
	|				И Организация = &Организация) КАК энргАктивностьТочекУчетаСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ТочкиУчетаАбонента
	|ИЗ
	|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И Организация = &Организация
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаАбонента.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаАбонента КАК АктивныеТочкиУчетаАбонента)) КАК энргВладельцыТочекУчетаСрезПоследних
	|ГДЕ
	|	энргВладельцыТочекУчетаСрезПоследних.АбонентВладелец = &МКД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТочкиУчетаАбонента.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ДействующиеТочкиУчета
	|ИЗ
	|	ТочкиУчетаАбонента КАК ТочкиУчетаАбонента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АктивныеТочкиУчетаАбонента КАК АктивныеТочкиУчетаАбонента
	|		ПО ТочкиУчетаАбонента.ТочкаУчета = АктивныеТочкиУчетаАбонента.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПриборыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочекУчета
	|ИЗ
	|	РегистрСведений.энргПриборыТочекМКД.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И Организация = &Организация
