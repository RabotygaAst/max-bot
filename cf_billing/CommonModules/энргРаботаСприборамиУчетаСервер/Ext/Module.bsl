			Запись						= Набор.Добавить();
			Запись.Период				= ДанныеШапки.Дата;
			Запись.Район  				= ДанныеШапки.Район;
			Запись.Организация			= ДанныеШапки.Организация;
			Запись.МКД  				= ДанныеШапки.МКД;
			Запись.ПриборУчета			= стр[СоотвествиеКолонок.ПриборУчета];
			Запись.НомерПломбы			= стр[СоотвествиеКолонок.НомерПломбы];
			Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;			
			Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;   
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры

// Установлеваетить номер пломбы прибора учета.
//
// Параметры:
//  Движения			-	КоллекцияДвижений.
//  ДанныеШапки			-	Структура.
//  ИмяКоллекции		-	Строка.
//  СоотвествиеКолонок	-	Соответствие.
//
Процедура УстановитьНомерПломбыПрибораУчета(Движения,ДанныеШапки, ИмяКоллекции,СоотвествиеКолонок) Экспорт
	Набор 				= Движения.энргНомерПломбПриборовУчета;
	Для каждого стр из ДанныеШапки[ИмяКоллекции] Цикл
		если ЗначениеЗаполнено(стр[СоотвествиеКолонок.ПриборУчета]) и ЗначениеЗаполнено(стр[СоотвествиеКолонок.НомерПломбы]) тогда
			Запись						= Набор.Добавить();
			Запись.Период				= ДанныеШапки.Дата;
			Запись.Район  				= ДанныеШапки.Район;
			Запись.Организация			= ДанныеШапки.Организация;
			Запись.КлючПомещения  		= ДанныеШапки.КлючПомещения;
			Запись.ПриборУчета			= стр[СоотвествиеКолонок.ПриборУчета];
			Запись.НомерПломбы			= стр[СоотвествиеКолонок.НомерПломбы];
			Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;			
			Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;   
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры

// Устанавливает номер пломбы прибора учета по результатам запроса.
//
// Параметры:
//  Результат	-	РезультатЗапроса.
//  Движения	-	КоллекцияДвижений.
//
Процедура УстановитьНомерПломбыПрибораУчетаРезультатЗапроса(Результат,Движения) Экспорт
	Набор 							= Движения.энргНомерПломбПриборовУчета;
	Выборка 						= Результат.выбрать();
	Пока Выборка.следующий() цикл 		
		Запись						= Набор.Добавить();
		Запись.Период				= Выборка.Период;
		Запись.Район  				= Выборка.Район;
		Запись.Организация			= Выборка.Организация;
		Запись.Абонент  			= Выборка.Абонент;
		Запись.ПриборУчета			= Выборка.ПриборУчета;
		Запись.НомерПломбы			= Выборка.НомерПломбы;
		Запись.ПериодРегистрации	= Выборка.ПериодРегистрации;
		Запись.ПериодНачисления		= Выборка.ПериодНачисления;   
	КонецЦикла;	
КонецПроцедуры

// Записывает показания приборов учета МКД.
//
// Параметры:
//  Движения			-	КоллекцияДвижений.
//  ДанныеШапки			-	Структура.
//  ИмяКоллекции		-	Строка.
//  СоотвествиеКолонок	-	Соответствие.
//
Процедура ЗаписатьПоказанияПриборовУчетаМКД(Движения, ДанныеШапки,ИмяКоллекции,СоотвествиеКолонок) Экспорт
	Набор 						= Движения.энргПоказанияПриборовУчетаМКД;
	Для каждого стр из ДанныеШапки[ИмяКоллекции] Цикл
		Если ЗначениеЗаполнено(стр[СоотвествиеКолонок.ПриборУчета]) тогда
			Запись				= Набор.Добавить();
			Запись.период		= ДанныеШапки.Дата;
			Запись.Район		= ДанныеШапки.Район;
			Запись.Организация	= ДанныеШапки.Организация;
			Запись.МКД			= ДанныеШапки.МКД;
			Запись.ПриборУчета	= стр[СоотвествиеКолонок.ПриборУчета];
			Запись.Показание	= стр[СоотвествиеКолонок.ТекущиеПоказания];			
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры

// Записывает состояние прибора учета.
//
// Параметры:
//  ДанныеШапки			-	Структура.
//  Движения			-	КоллекцияДвижений.
//  ИмяСвойства			-	Строка.
//  СоотвествиеКолонок	-	Соответствие.
//  Состояние			-	Булево.
//
Процедура ЗаписатьСостояниеПрибораУчета(ДанныеШапки,Движения,ИмяСвойства,СоотвествиеКолонок, Состояние) Экспорт
	Набор 								= Движения["энргСостояниеПриборовУчетаАбонента"]; 	
	
	ЕстьВывод 							= ДанныеШапки.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ
	ИЛИ ДанныеШапки.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВыводПУ; 
	
	для Каждого стр из ДанныеШапки[ИмяСвойства] цикл
		Если ЗначениеЗаполнено(Стр[СоотвествиеКолонок.ПриборУчета])Тогда
			Запись  					= Набор.добавить();
			Запись.Период  				= ДанныеШапки.Дата;
			Запись.Район 				= ДанныеШапки.Район;
			Запись.Организация			= ДанныеШапки.Организация;
			Запись.КлючПомещения 		= ДанныеШапки.КлючПомещения;
			Запись.ТочкаУчета			= Стр[СоотвествиеКолонок.ТочкаУчета];
			Запись.ПриборУчета 			= Стр[СоотвествиеКолонок.ПриборУчета];  
			Запись.Состояние 			= Состояние;
			Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
			Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;
		КонецЕсли;		
	КонецЦикла;
КонецПроцедуры

// Записывает состояние прибора учета результата запроса.
