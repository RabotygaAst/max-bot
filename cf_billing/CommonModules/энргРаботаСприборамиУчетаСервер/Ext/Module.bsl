// Записывает дату поверки.
//
// Параметры:
//  ДанныеШапки			-	Структура.
//  Движения			-	КоллекцияДвижений.
//  ИмяКоллекции		-	Строка.
//  СоотвествиеКолонок	-	Соответствие.
//
Процедура ЗаписатьДатуПоверки(ДанныеШапки,Движения,ИмяКоллекции,СоотвествиеКолонок) Экспорт
	Набор  = Движения["энргДатыПоверкиПрибораУчета"];
	для Каждого стр из ДанныеШапки[ИмяКоллекции] цикл
		Если ЗначениеЗаполнено(стр[СоотвествиеКолонок.ПриборУчета]) Тогда
			Запись  			= Набор.добавить();
			Запись.Период  				= ДанныеШапки.Дата;
			Запись.Район  				= ДанныеШапки.Район;
			Запись.Организация	 		= ДанныеШапки.Организация;
			Запись.КлючПомещения  		= ДанныеШапки.КлючПомещения;
			Запись.ПриборУчета 			= стр[СоотвествиеКолонок.ПриборУчета];
			Запись.ДатаПоверки 			= стр[СоотвествиеКолонок.ДатаПоверкиСчетчика];
			Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
			Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;
			Запись.ТочкаУчета 			= стр[СоотвествиеКолонок.ТочкаУчета]
		КонецЕсли;
	КонецЦикла; 		
КонецПроцедуры

// Записывает дату поверки результат запроса.
//
// Параметры:
//  Результат	-	РезультатЗапроса.
//  Движения	-	КоллекцияДвижений.
//
Процедура ЗаписатьДатуПоверкиРезультатЗапроса(Результат,Движения) Экспорт
	Набор  							= Движения["энргДатыПоверкиПрибораУчета"];
	Выборка 						= Результат.выбрать();
	Пока Выборка.следующий() Цикл
		Запись  					= Набор.добавить();
		Запись.Период  				= Выборка.Период;
		Запись.Район  				= Выборка.Район;
		Запись.Организация	 		= Выборка.Организация;
		Запись.КлючПомещения  		= Выборка.КлючПомещения;
		Запись.ПриборУчета 			= Выборка.ПриборУчета;
		Запись.ДатаПоверки 			= Выборка.ДатаПоверкиСчетчика;
		Запись.ПериодРегистрации	= Выборка.ПериодРегистрации;
		Запись.ПериодНачисления		= Выборка.ПериодНачисления;
	КонецЦикла;
КонецПроцедуры

// Устанавливает состояние приборов учета МКД.
//
// Параметры:
//  ДанныеШапки			-	Структура.
//  Движения			-	КоллекцияДвижений.
//  ИмяКоллекции		-	Строка.
//  СоотвествиеКолонок	-	Соответствие.
//  Состояние			-	Булево.
//
Процедура УстановитьСостояниеПриборовУчетаМКД(ДанныеШапки,Движения,ИмяКоллекции,СоотвествиеКолонок,Состояние) Экспорт
	Набор 						= Движения.энргСостояниеПриборовМКД;
	Для каждого стр из ДанныеШапки[ИмяКоллекции] Цикл
		Если ЗначениеЗаполнено(стр[СоотвествиеКолонок.ПриборУчета]) тогда
			Запись				= Набор.Добавить();
			Запись.Период 		= ДанныеШапки.Дата;
			Запись.Район 		= ДанныеШапки.Район;
			Запись.Организация	= ДанныеШапки.Организация;
			Запись.МКД 			= ДанныеШапки.МКД;
			Запись.ТочкаУчета 	= стр[СоотвествиеКолонок.ТочкаУчета];
			Запись.ПриборУчета 	= стр[СоотвествиеКолонок.ПриборУчета];		
			Запись.Состояние 	= Состояние;
			Запись.ПериодРегистрации	= ДанныеШапки.ПериодРегистрации;
			Запись.ПериодНачисления		= ДанныеШапки.ПериодНачисления;
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры

