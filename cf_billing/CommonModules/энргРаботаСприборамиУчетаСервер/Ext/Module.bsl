// Выведет все приборы абонента.
//
// Параметры:
//  Движения	-	КоллекцияДвижений.
//  Период		-	Дата.
//  ДанныеШапки	-	Структура.
//
Процедура ВывестиВсеПриборыАбонента(Движения,Период,ДанныеШапки) Экспорт 
	
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= ДанныеШапки.МВТ;
	Запрос.УстановитьПараметр("Период",			Период);
	Запрос.УстановитьПараметр("Район",			ДанныеШапки.Район);
	Запрос.УстановитьПараметр("Организация",	ДанныеШапки.Организация);	
	Запрос.УстановитьПараметр("КлючПомещения",	ДанныеШапки.КлючПомещения);
	Запрос.Текст 					=
	"ВЫБРАТЬ
	|	энргПриборыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ АктивныеПриборы
	|ИЗ
	|	РегистрСведений.энргПриборыТочекУчета.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И Организация = &Организация
	|				И КлючПомещения = &КлючПомещения
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочки.ТочкаУчета
	|					ИЗ
	|						АктивныеТочки КАК АктивныеТочки)) КАК энргПриборыТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовУчетаАбонента.СрезПоследних(
	|			&Период,
	|			Район = &Район
	|				И Организация = &Организация
	|				И КлючПомещения = &КлючПомещения
	|				И (ТочкаУчета, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						АктивныеПриборы.ТочкаУчета,
	|						АктивныеПриборы.ПриборУчета
	|					ИЗ
	|						АктивныеПриборы КАК АктивныеПриборы)) КАК энргСостояниеПриборовУчетаАбонентаСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)";
	
	Результат 					= Запрос.Выполнить();
	Выборка 					= Результат.Выбрать();
	Набор 						= Движения.энргСостояниеПриборовУчетаАбонента;
	
	Пока Выборка.Следующий() цикл
		Запись  				= Набор.добавить();
		Запись.Период  			= ДанныеШапки.Дата;
		Запись.Район  			= ДанныеШапки.Район;
		Запись.Организация		= ДанныеШапки.Организация;
		Запись.КлючПомещения	= ДанныеШапки.КлючПомещения;
		Запись.ТочкаУчета  		= Выборка.ТочкаУчета;
		Запись.ПриборУчета 		= Выборка.ПриборУчета;
		Запись.Состояние 		= Перечисления.энргСостояниеПриборовУчета.Вывод;
	КонецЦикла;
	
КонецПроцедуры

// Выведет все приборы МКД.
//
// Параметры:
//  Движения	-	КоллекцияДвижений.
//  Период		-	Дата.
//  ДанныеШапки	-	Структура.
//
Процедура ВывестиВсеПриборыМКД(Движения,Период,ДанныеШапки) Экспорт 
	
	Запрос  = Новый Запрос;
	Если ДанныеШапки.свойство("МКД") тогда
		Запрос.МенеджерВременныхТаблиц = ДанныеШапки.МВТ;
	КонецЕсли;	
	Запрос.УстановитьПараметр("Период",Период);
	Запрос.УстановитьПараметр("Район",ДанныеШапки.Район);
	Запрос.УстановитьПараметр("Организация",ДанныеШапки.Организация);	
	Запрос.УстановитьПараметр("МКД",ДанныеШапки.МКД);
	Запрос.Текст ="ВЫБРАТЬ
	|	энргПриборыТочекМКДСрезПоследних.ТочкаУчета,
	|	энргПриборыТочекМКДСрезПоследних.ПриборУчета
	|ПОМЕСТИТЬ АктивныеПриборы
	|ИЗ
	|	РегистрСведений.энргПриборыТочекМКД.СрезПоследних(
	|			&Период,
	|			Район = &Район
    |				И Организация = &Организация
	|				И МКД = &МКД
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочки.ТочкаУчета
	|					ИЗ
	|						АктивныеТочки КАК АктивныеТочки)) КАК энргПриборыТочекМКДСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеПриборовМКДСрезПоследних.ТочкаУчета,
	|	энргСостояниеПриборовМКДСрезПоследних.ПриборУчета
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовМКД.СрезПоследних(
	|			&Период,
	|			Район = &Район
    |				И Организация = &Организация
	|				И МКД = &МКД
	|				И (ТочкаУчета, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						АктивныеПриборы.ТочкаУчета,
	|						АктивныеПриборы.ПриборУчета
	|					ИЗ
	|						АктивныеПриборы КАК АктивныеПриборы)) КАК энргСостояниеПриборовМКДСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)";
	Результат 		= Запрос.Выполнить();
	Выборка 		= Результат.Выбрать();
	Набор 			= Движения.энргСостояниеПриборовМКД;
	
	Пока Выборка.Следующий() цикл
		Запись  			= Набор.добавить();
		Запись.Период  		= ДанныеШапки.Дата;
		Запись.Район  		= ДанныеШапки.Район;
		Запись.Организация	= ДанныеШапки.Организация;
		Запись.МКД  		= ДанныеШапки.МКД;
		Запись.ТочкаУчета  	= Выборка.ТочкаУчета;
		Запись.ПриборУчета 	= Выборка.ПриборУчета;
		Запись.Состояние 	= Перечисления.энргСостояниеПриборовУчета.Вывод;
	КонецЦикла;
	
КонецПроцедуры

// Сбросывает расчет по формуле.
//
// Параметры:
//  Движения	-	КоллекцияДвижений.
//  ДанныеШапки	-	Структура.
//
Процедура СброситьРасчетПоФормуле(Движения,ДанныеШапки) Экспорт  
	Набор 							= Движения.энргРасчетныеСпособыТочекУчета;
	
	Запрос  						= Новый Запрос;
	Запрос.УстановитьПараметр("Район", 			ДанныеШапки.Район);
	Запрос.УстановитьПараметр("КлючПомещения", 	ДанныеШапки.КлючПомещения);
	Запрос.УстановитьПараметр("Период", 		ДанныеШапки.Дата);
	Запрос.УстановитьПараметр("Организация",	ДанныеШапки.Организация);
	Запрос.Текст 					="
	|ВЫБРАТЬ
	|	энргРасчетныеСпособыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ИЗ
	|	РегистрСведений.энргРасчетныеСпособыТочекУчета.СрезПоследних(
	|			&Период,
	|			Район = &Район
    |				И Организация = &Организация
	|				И КлючПомещения = &КлючПомещения) КАК энргРасчетныеСпособыТочекУчетаСрезПоследних
	|ГДЕ
	|	энргРасчетныеСпособыТочекУчетаСрезПоследних.РасчетныйСпособ";
	Результат  							= Запрос.Выполнить();
	Выборка  							= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		СтрокаНабора  					= Набор.добавить();
		СтрокаНабора.Период 			= ДанныеШапки.Дата;
		СтрокаНабора.Район 				= ДанныеШапки.Район;
		СтрокаНабора.Организация		= ДанныеШапки.Организация;
		СтрокаНабора.КлючПомещения 		= ДанныеШапки.КлючПомещения;
		СтрокаНабора.ТочкаУчета 		= Выборка.ТочкаУчета;
		СтрокаНабора.РасчетныйСпособ 	= Ложь;
		СтрокаНабора.ПериодНачисления 	= ДанныеШапки.ПериодНачисления;
		СтрокаНабора.ПериодРегистрации 	= ДанныеШапки.ПериодРегистрации;;
	КонецЦикла;  	
КонецПроцедуры

// Устанавливает вид дифференцированности приборов учета.
//
// Параметры:
//  ДанныеШапки	-	Сутруктура			-	см. Документ.энргУстановитьВидДифференцированностиПриборУчета.ДанныеШапки.
//  Движения	-	КоллекцияДвижений.
//
Процедура УстановитьВидДифференцированностиПриборовУчета(ДанныеШапки,Движения) Экспорт
	Набор  								= Движения["энргВидыДифференцированностиПриборовУчета"];
	Результат 							= ВидыДифференцированностиПриборов(ДанныеШапки.Документ);
	Выборка  							= Результат.Выбрать();
	Пока Выборка.Следующий() цикл		
		Запись  						= Набор.Добавить();
		Запись.Период  					= ДанныеШапки.Дата;
		Запись.Район  					= ДанныеШапки.Район;
		Запись.Организация				= ДанныеШапки.Организация;
		Запись.КлючПомещения  			= ДанныеШапки.КлючПомещения;
		Запись.ПриборУчета 				= Выборка.ПриборУчета;
		Запись.Шкала 					= Выборка.Шкала;
		Запись.ВидДифференцированности	= Выборка.ВидДифференцированности;
		Запись.ПериодРегистрации		= ДанныеШапки.ПериодРегистрации;
		Запись.ПериодНачисления			= ДанныеШапки.ПериодНачисления;
		Запись.ТочкаУчета				= Выборка.ТочкаУчета;
	КонецЦикла;
КонецПроцедуры

