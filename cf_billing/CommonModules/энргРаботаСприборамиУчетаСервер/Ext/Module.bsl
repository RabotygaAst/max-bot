Процедура ДополнитьСоотвествиеРеквизитовСвойствамПрибораУчета(СтруктураСоотвествия)	
	СтруктураСвойств = Новый Структура; 	
	Обработки.энргПриборыУчетаАбонентаМенеджер.СтандартныеРеквизитыПрибораУчета(СтруктураСвойств);
	Для Каждого ТекКлючЗначение из СтруктураСвойств Цикл
		Если ТекКлючЗначение.Ключ = "Код" Тогда 
			СтруктураСоотвествия.Вставить("ЗаводскойНомер", "Код");
			Продолжить;
		КонецЕсли;
		
		СтруктураСоотвествия.Вставить(ТекКлючЗначение.Ключ, ТекКлючЗначение.Ключ);
