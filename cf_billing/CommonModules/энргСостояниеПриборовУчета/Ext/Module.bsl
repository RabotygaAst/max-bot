#Область ПрограмныйИнтерфейс

Функция ДействующиеПриборыУчетаПомещения(Период, Организация, Район, КлючПомещения, ТочкаУчета = Неопределено, ВключаяОРП = Ложь, ПараметрыОтбора = Неопределено) Экспорт 
	
	Схема 			= Неопределено;  	
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация"	, "Организация"), Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район"		, "Район")		, Неопределено));
	
	Если ТипЗнч(КлючПомещения) = Тип("Массив") Тогда
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("КлючПомещения", "КлючПомещения")));
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("АбонентВладелец", "КлючПомещения")));
	Иначе
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("КлючПомещения", "КлючПомещения")));
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("АбонентВладелец", "КлючПомещения")));
	КонецЕсли;
		
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета", 	"ТочкаУчета"), 		Неопределено));
	КонецЕсли;
		
	Если ПараметрыОтбора = Неопределено Тогда
		Параметры 		= Новый Структура;	
	Иначе
		Параметры		= ПараметрыОтбора;
	КонецЕсли;	
	Параметры.Вставить("ПараметрыВТ", 		ПараметрыВТ);
	Если ЗначениеЗаполнено(Период) Тогда
		Параметры.Вставить("Период",  Новый Структура("ИмяПараметра,ТипПараметра", "Период", "ГраницаИсключая"));
	КонецЕсли;

	Если ВключаяОРП Тогда 
		Параметры.Вставить("ВключаяОРП", Истина);
	КонецЕсли;
	
	ЗаполнитьСхемуЗапросаДействующихПриборовУчетаПомещения(Схема, Параметры);
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация",		Организация);
	ПараметрыЗапроса.Вставить("Район",				Район); 	
	ПараметрыЗапроса.Вставить("КлючПомещения",		КлючПомещения);
	Если ТипЗнч(Период) = Тип("Граница") Тогда
		ПараметрыЗапроса.Вставить("Период",			Период);
	Иначе
		ПараметрыЗапроса.Вставить("Период",			Период);
	КонецЕсли;
	
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ТочкаУчета",		ТочкаУчета);
	КонецЕсли;	
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса); 
			
КонецФункции

Функция ДействующийСоставУзлаПомещения(Период,Организация,Район,КлючПомещения, ТочкаУчета = Неопределено, ВключаяОРП = Ложь) Экспорт 
	
	Схема 								= Неопределено;  	
	ПараметрыВТ 						= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", 	"Организация"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район", 			"Район"), 			Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения", 	"КлючПомещения"), 	Неопределено));
		
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета", 	"ТочкаУчета"), 		Неопределено));
	КонецЕсли;
	
	Параметры 	= Новый Структура;	
	Параметры.Вставить("ПараметрыВТ", 		ПараметрыВТ);
	Если ЗначениеЗаполнено(Период) Тогда
		Параметры.Вставить("Период",  Новый Структура("ИмяПараметра,ТипПараметра", "Период", "ГраницаИсключая"));
	КонецЕсли;
	
	Если ВключаяОРП Тогда 
		Параметры.Вставить("ВключаяОРП", Истина);
	КонецЕсли;
	
	ЗаполнитьСхемуДействующийСоставУзлаПомещения(Схема, Параметры);
	
	ПараметрыЗапроса 					= Новый Структура;
	ПараметрыЗапроса.Вставить("Период",					Период);
	ПараметрыЗапроса.Вставить("Организация",			Организация);
	ПараметрыЗапроса.Вставить("Район",					Район); 	
	ПараметрыЗапроса.Вставить("КлючПомещения",			КлючПомещения);
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ТочкаУчета",			ТочкаУчета);
	КонецЕсли;
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьПакет(Схема, ПараметрыЗапроса);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргСостояниеПриборовУчета.ДействующийСоставУзлаПомещения";
		ПараметрыМетода 			= Новый Структура("Период,Организация,Район,КлючПомещения,ТочкаУчета",Период,Организация,Район,КлючПомещения,ТочкаУчета); 
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);
	КонецЕсли;
	
	Возврат РезультатЗапроса;	
КонецФункции

Функция ДействующиеПриборыУчетаПоМаршруту(Период, Организация, Район, МаршрутКонтроллера, Строение = Неопределено, ВключаяОРП = Ложь) Экспорт 
	
	Схема 							= Новый СхемаЗапроса;
	
	Если Строение = Неопределено Тогда
		Справочники.энргМаршрутыКонтроллеров.СоставМаршрута(Схема,"Адреса");	
		Справочники.энргКлючиПомещений.КлючиПомещенийПоПредставлениюАдресов(Схема,"КлючиПомещений");
	Иначе 
		ОтборКлючейПомещений 		= Новый Массив;
		ОтборКлючейПомещений.Добавить(Новый Структура("ИмяПараметра,ТипПараметра,СоотвествиеПолей","","ТипПараметраРавно",Новый Структура("Строение","Строение")));
		
		ПараметрыКлючПомещений 		= Новый Структура("ПараметрыВТ", ОтборКлючейПомещений);
		РегистрыСведений.энргКлючиПомещений.ДанныеПомещения(Схема, ПараметрыКлючПомещений, "КлючиПомещений");
	КонецЕсли;
	
	Параметры 						= Новый Структура;	
	Параметры.Вставить("Период", Новый Структура("ИмяПараметра","Период"));
	Если ВключаяОРП Тогда 
		Параметры.Вставить("ВключаяОРП", Истина);
	КонецЕсли;
	
	
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ИмяПараметра,ТипПараметра,СоотвествиеПолей", 					"", 			"ТипПараметраРавно",			Новый Структура("Организация,Район","Организация","Район")));
	ПараметрыВТ.Добавить(Новый Структура("ИмяПараметра,ТаблицаИсточник,ТипПараметра,СоотвествиеПолей", "КлючиПомещений", "КлючиПомещений", "ТипПараметраВременнаяТаблица",	Новый Структура("КлючПомещения","КлючПомещения")));
		
	Параметры.Вставить("ПараметрыВТ",	ПараметрыВТ);
	ЗаполнитьСхемуЗапросаДействующихПриборовУчетаПомещения(Схема, Параметры);
	
	ПараметрыЗапроса  				= Новый Структура;
	ПараметрыЗапроса.Вставить("Период",					Период);//Новый Граница(Период,ВидГраницы.Исключая));
	ПараметрыЗапроса.Вставить("Район",					Район);
	ПараметрыЗапроса.Вставить("Организация",			Организация);
	ПараметрыЗапроса.Вставить("МаршрутКонтроллера",		МаршрутКонтроллера);
	Если НЕ Строение = Неопределено Тогда
		ПараметрыЗапроса.Вставить("Строение",			Строение);
	КонецЕсли; 	
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргСостояниеПриборовУчета.ДействующиеПриборыУчетаПоМаршруту";
		ПараметрыМетода 			= Новый Структура("Период, Организация, Район, МаршрутКонтроллера,Строение",Период, Организация, Район, МаршрутКонтроллера,Строение); 
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);
	КонецЕсли;
	
	Возврат РезультатЗапроса
	
КонецФункции

Функция АктивныеПриборыУчета(Период, Организация, Район, КлючПомещения, ТочкаУчета = Неопределено, ВключаяОРП = Ложь, ПараметрыОтбора = Неопределено) Экспорт
	
	Схема 			= Неопределено;  	
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация"	, "Организация"), Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район"		, "Район")		, Неопределено));
	
	Если ТипЗнч(КлючПомещения) = Тип("Массив") Тогда
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("КлючПомещения", "КлючПомещения")));
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("АбонентВладелец", "КлючПомещения")));
	Иначе
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("КлючПомещения", "КлючПомещения")));
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("АбонентВладелец", "КлючПомещения")));
	КонецЕсли;
		
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета", 	"ТочкаУчета"), 		Неопределено));
	КонецЕсли;
		
	Если ПараметрыОтбора = Неопределено Тогда
		Параметры = Новый Структура;	
	Иначе
		Параметры = ПараметрыОтбора;
	КонецЕсли;	
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);
	Если ЗначениеЗаполнено(Период) Тогда
		Параметры.Вставить("Период",  Новый Структура("ИмяПараметра,ТипПараметра", "Период", "ГраницаИсключая"));
	КонецЕсли;

	Если ВключаяОРП Тогда 
		Параметры.Вставить("ВключаяОРП", Истина);
	КонецЕсли;
	
	РегистрыСведений.энргСостояниеПриборовУчетаАбонента.ДействующиеПриборыУчетаПомещения(Схема, Параметры);
	
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация",		Организация);
	ПараметрыЗапроса.Вставить("Район",				Район); 	
	ПараметрыЗапроса.Вставить("КлючПомещения",		КлючПомещения);
	Если ТипЗнч(Период) = Тип("Граница") Тогда
		ПараметрыЗапроса.Вставить("Период",			Период);
	Иначе
		ПараметрыЗапроса.Вставить("Период",			Период);
	КонецЕсли;
	
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ТочкаУчета",		ТочкаУчета);
	КонецЕсли;	
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);
	
КонецФункции 

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗаполнитьСхемуЗапросаДействующихПриборовУчетаПомещения(Схема, Параметры) Экспорт 
	
	ЗаполнитьСхемуЗапросаДействующегоОсновногоОборудованияПомещения(Схема, Параметры);
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ВидКанальности КАК ВидКанальности,
	|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	энргВидыКанальностиШкалы.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ЗаводскойНомерПриборУчета КАК ЗаводскойНомерПриборУчета
	|ПОМЕСТИТЬ ДанныеПоПриборам
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДействующиеПриборыУчетаПомещения.Организация КАК Организация,
	|		ДействующиеПриборыУчетаПомещения.Район КАК Район,
	|		ДействующиеПриборыУчетаПомещения.КлючПомещения КАК КлючПомещения,
	|		ДействующиеПриборыУчетаПомещения.ТочкаУчета КАК ТочкаУчета,
	|		ДействующиеПриборыУчетаПомещения.ПриборУчета КАК ПриборУчета,
	|		энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности,
	|		энргПриборыУчетаАбонента.РегистрируетОбъем КАК РегистрируетОбъем,
	|		энргПриборыУчетаАбонента.Код КАК ЗаводскойНомерПриборУчета
	|	ИЗ
	|		ДействующиеПриборыУчетаПомещения КАК ДействующиеПриборыУчетаПомещения
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|			ПО ДействующиеПриборыУчетаПомещения.ПриборУчета = энргПриборыУчетаАбонента.Ссылка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыКанальности.Шкалы КАК энргВидыКанальностиШкалы
	|		ПО ВложенныйЗапрос.ВидКанальности = энргВидыКанальностиШкалы.Ссылка");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.Шкала КАК Шкала,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	ВложенныйЗапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	ВложенныйЗапрос.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	ВложенныйЗапрос.РасчетПоФормуле КАК РасчетПоФормуле,
	|	ВложенныйЗапрос.СоставнаяУслуга КАК СоставнаяУслуга,
	|	энргВидыДифференцированностиТарифныеЗоны.ТарифнаяЗона КАК ТарифнаяЗона,
