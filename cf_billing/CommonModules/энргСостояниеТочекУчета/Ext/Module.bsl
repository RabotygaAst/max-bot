#Область ПрограмныйИнтерфейс

Функция ДействующиеТочкиИИхПриборы(Период, Организация, Район, КлючПомещения, ТочкаУчета = Неопределено, ПараметрыОтбора = Неопределено) Экспорт 
	
	Схема							= Неопределено;
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация"		, "Организация")	, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район"			, "Район")			, Неопределено));	
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения"	, "КлючПомещения")	, Неопределено));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("АбонентВладелец", "КлючПомещения")));
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета"	, "ТочкаУчета")		, Неопределено));
	КонецЕсли;
	
	Если ПараметрыОтбора = Неопределено Тогда
		Параметры 		= Новый Структура;	
	Иначе
		Параметры		= ПараметрыОтбора;
	КонецЕсли;
	
	Параметры.Вставить("Период", 			Новый Структура("ИмяПараметра,ТипПараметра", "Период" ,"ТипПараметраГраницаИсключая"));
	Если ТипЗнч(Период) = Тип("Дата") и НЕ ЗначениеЗаполнено(Период) Тогда
		 Параметры.Удалить("Период");
	КонецЕсли;
	Параметры.Вставить("ПараметрыВТ", 		ПараметрыВТ);
	
	ЗаполнитьСхемуДействующиеТочкиИИхПриборы(Схема, Параметры);
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДанныеПоПриборамИтог.Организация КАК Организация,
		|	ДанныеПоПриборамИтог.Район КАК Район,
		|	ДанныеПоПриборамИтог.КлючПомещения КАК КлючПомещения,
		|	ДанныеПоПриборамИтог.ТочкаУчета КАК ТочкаУчета,
		|	ДанныеПоПриборамИтог.ПриборУчета КАК ПриборУчета,
		|	ДанныеПоПриборамИтог.РодительТочкиУчета КАК РодительТочкиУчета,
		|	ДанныеПоПриборамИтог.Шкала КАК Шкала,
		|	ДанныеПоПриборамИтог.Услуга КАК Услуга,
		|	ДанныеПоПриборамИтог.РегистрируетОбъем КАК РегистрируетОбъем,
		|	ДанныеПоПриборамИтог.ВидДифференцированности КАК ВидДифференцированности,
		|	ДанныеПоПриборамИтог.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
		|	ДанныеПоПриборамИтог.РасчетПоФормуле КАК РасчетПоФормуле,
		|	ДанныеПоПриборамИтог.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ДанныеПоПриборамИтог.Поставщик КАК Поставщик,
		|	ДанныеПоПриборамИтог.НомерПломбы КАК НомерПломбы,
		|	ДанныеПоПриборамИтог.ДатаПоверки КАК ДатаПоверки,
		|	ДанныеПоПриборамИтог.СоставнаяУслуга КАК СоставнаяУслуга
		|ИЗ
		|	ДанныеПоПриборамИтог КАК ДанныеПоПриборамИтог
		|
		|УПОРЯДОЧИТЬ ПО
		|	Организация,
		|	Район,
		|	КлючПомещения,
		|	РодительТочкиУчета,
		|	ТочкаУчета,
		|	Шкала"); 
			
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Район",			Район);
	ПараметрыЗапроса.Вставить("Организация",	Организация);
	ПараметрыЗапроса.Вставить("КлючПомещения",	КлючПомещения);	
	
	Если Параметры.Свойство("Период") Тогда
		ПараметрыЗапроса.Вставить("Период",		Период);
	Иначе
		ПараметрыЗапроса.Вставить("Период",		ТекущаяДата());
	КонецЕсли;
	
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ТочкаУчета",	ТочкаУчета);
	КонецЕсли;
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);
			
КонецФункции

Функция ДействующиеТочкиБезПрибораУчета(Период, Организация, Район, КлючПомещения, ТочкаУчета = Неопределено, ПараметрыОтбора = Неопределено) Экспорт 
	
	Схема							= Неопределено;
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация"		, "Организация")	, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район"			, "Район")			, Неопределено));	
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения"	, "КлючПомещения")	, Неопределено));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("АбонентВладелец", "КлючПомещения")));
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета"	, "ТочкаУчета")		, Неопределено));
	КонецЕсли;
	
	Если ПараметрыОтбора = Неопределено Тогда
		Параметры 		= Новый Структура;	
	Иначе
		Параметры		= ПараметрыОтбора;
	КонецЕсли;
	
	Параметры.Вставить("Период", 			Новый Структура("ИмяПараметра,ТипПараметра", "Период" ,"ТипПараметраГраницаИсключая"));
	Если ТипЗнч(Период) = Тип("Дата") и НЕ ЗначениеЗаполнено(Период) Тогда
		 Параметры.Удалить("Период");
	КонецЕсли;
	Параметры.Вставить("ПараметрыВТ", 		ПараметрыВТ);
	
	РегистрыСведений.энргАктивностьТочекУчета.АктивныеТочкиУчетаПомещенияБезПУ(Схема, Параметры, "АктивныеТочкиУчетаПомещенияБезПУ");
	РегистрыСведений.энргУслугиТочекУчета.УслугиДействующихТочек(Схема, Параметры, "УслугиДействующихТочек");
	РегистрыСведений.энргНаправлениеИспользованияТочекУчета.НаправлениеИспользованияДействующихТочек(Схема, Параметры, "НаправлениеИспользованияДействующихТочек"); 
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	АктивныеТочкиУчетаПомещенияБезПУ.Организация КАК Организация,
		|	АктивныеТочкиУчетаПомещенияБезПУ.Район КАК Район,
		|	АктивныеТочкиУчетаПомещенияБезПУ.КлючПомещения КАК КлючПомещения,
		|	АктивныеТочкиУчетаПомещенияБезПУ.ТочкаУчета КАК ТочкаУчета,
		|	ЕСТЬNULL(УслугиДействующихТочек.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
		|	ЕСТЬNULL(НаправлениеИспользованияДействующихТочек.НаправлениеИспользованияТУ, ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление)) КАК НаправлениеИспользованияТУ
		|ИЗ
		|	АктивныеТочкиУчетаПомещенияБезПУ КАК АктивныеТочкиУчетаПомещенияБезПУ
		|		ЛЕВОЕ СОЕДИНЕНИЕ УслугиДействующихТочек КАК УслугиДействующихТочек
		|		ПО АктивныеТочкиУчетаПомещенияБезПУ.Организация = УслугиДействующихТочек.Организация
		|			И АктивныеТочкиУчетаПомещенияБезПУ.Район = УслугиДействующихТочек.Район
		|			И АктивныеТочкиУчетаПомещенияБезПУ.КлючПомещения = УслугиДействующихТочек.КлючПомещения
		|			И АктивныеТочкиУчетаПомещенияБезПУ.ТочкаУчета = УслугиДействующихТочек.ТочкаУчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ НаправлениеИспользованияДействующихТочек КАК НаправлениеИспользованияДействующихТочек
		|		ПО АктивныеТочкиУчетаПомещенияБезПУ.Организация = НаправлениеИспользованияДействующихТочек.Организация
		|			И АктивныеТочкиУчетаПомещенияБезПУ.Район = НаправлениеИспользованияДействующихТочек.Район
		|			И АктивныеТочкиУчетаПомещенияБезПУ.КлючПомещения = НаправлениеИспользованияДействующихТочек.КлючПомещения
		|			И АктивныеТочкиУчетаПомещенияБезПУ.ТочкаУчета = НаправлениеИспользованияДействующихТочек.ТочкаУчета
		|
		|УПОРЯДОЧИТЬ ПО
		|	Организация,
		|	Район,
		|	КлючПомещения,
		|	ТочкаУчета"); 
			
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Район",			Район);
	ПараметрыЗапроса.Вставить("Организация",	Организация);
	ПараметрыЗапроса.Вставить("КлючПомещения",	КлючПомещения);	
	
	Если Параметры.Свойство("Период") Тогда
		ПараметрыЗапроса.Вставить("Период",		Период);
	Иначе
		ПараметрыЗапроса.Вставить("Период",		ТекущаяДатаСеанса());
	КонецЕсли;
	
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ТочкаУчета",	ТочкаУчета);
	КонецЕсли;
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);
			
КонецФункции

Функция УслугиДействующихТочек(Период, Организация, Район, КлючПомещения, ТочкаУчета = Неопределено, ПараметрыОтбора = Неопределено) Экспорт 
	
	Схема							= Неопределено;
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация"		, "Организация")	, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район"			, "Район")			, Неопределено));	
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения"	, "КлючПомещения")	, Неопределено));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("АбонентВладелец", "КлючПомещения")));
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("ТочкаУчета"	, "ТочкаУчета")		, Неопределено));
	КонецЕсли;
	
	Если ПараметрыОтбора = Неопределено Тогда
		Параметры 		= Новый Структура;	
	Иначе
		Параметры		= ПараметрыОтбора;
	КонецЕсли;
	
	Параметры.Вставить("Период", 			Новый Структура("ИмяПараметра,ТипПараметра", "Период" ,"ТипПараметраГраницаИсключая"));
	Если ТипЗнч(Период) = Тип("Дата") и НЕ ЗначениеЗаполнено(Период) Тогда
		 Параметры.Удалить("Период");
	КонецЕсли;
	Параметры.Вставить("ПараметрыВТ", 		ПараметрыВТ);
	
	РегистрыСведений.энргУслугиТочекУчета.УслугиДействующихТочек(Схема,Параметры,"УслугиДействующихТочек");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	УслугиДействующихТочек.Организация КАК Организация,
		|	УслугиДействующихТочек.Район КАК Район,
		|	УслугиДействующихТочек.КлючПомещения КАК КлючПомещения,
		|	УслугиДействующихТочек.ТочкаУчета КАК ТочкаУчета,
		|	ЕСТЬNULL(энргВидыУслугСоставляющиеУслуг.Услуга, УслугиДействующихТочек.Услуга) КАК Услуга,
		|	УслугиДействующихТочек.Техническая КАК Техническая
		|ИЗ
		|	УслугиДействующихТочек КАК УслугиДействующихТочек
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
		|		ПО УслугиДействующихТочек.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	УслугиДействующихТочек.Организация,
		|	УслугиДействующихТочек.Район,
		|	УслугиДействующихТочек.Техническая,
		|	УслугиДействующихТочек.КлючПомещения,
		|	ЕСТЬNULL(энргВидыУслугСоставляющиеУслуг.Услуга, УслугиДействующихТочек.Услуга),
		|	УслугиДействующихТочек.ТочкаУчета"); 
			
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Район",			Район);
	ПараметрыЗапроса.Вставить("Организация",	Организация);
	ПараметрыЗапроса.Вставить("КлючПомещения",	КлючПомещения);	
	
	Если Параметры.Свойство("Период") Тогда
		ПараметрыЗапроса.Вставить("Период",		Период);
	Иначе
		ПараметрыЗапроса.Вставить("Период",		ТекущаяДата());
	КонецЕсли;
	
	Если НЕ ТочкаУчета = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ТочкаУчета",	ТочкаУчета);
	КонецЕсли;
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);
			
КонецФункции

Процедура ЗаполнитьСхемуДействующиеТочкиИИхПриборы(Схема, Параметры) Экспорт 
	РегистрыСведений.энргСостояниеПриборовУчетаАбонента.ДействующиеПриборыУчетаПомещения(Схема,Параметры,"ДействующиеПриборыУчетаПомещения");
	РегистрыСведений.энргУслугиТочекУчета.УслугиДействующихТочек(Схема,Параметры,"УслугиДействующихТочек");
	РегистрыСведений.энргНаправлениеИспользованияТочекУчета.НаправлениеИспользованияДействующихТочек(Схема,Параметры,"НаправлениеИспользованияДействующихТочек");
	РегистрыСведений.энргПоставщикиУслугАбонента.ПоставщикиУслугДействующихТочек(Схема,Параметры,"ПоставщикиУслугДействующихТочек");
	РегистрыСведений.энргВидыДифференцированностиПриборовУчета.ВидДифференцированностиВведенныхПриборов(Схема,Параметры,"ВидДифференцированностиВведенныхПриборов");
	РегистрыСведений.энргРасчетныеСпособыТочекУчета.ДействующиеТочкиТочкиПоФормуле(Схема,Параметры,"ДействующиеТочкиТочкиПоФормуле");
	
	// Пломбы исключены т.к их может быть несколько на прибор
	//РегистрыСведений.энргНомерПломбПриборовУчета.НомераПломбВведенныхПриборовДействующихТочек(Схема,Параметры,"НомераПломбВведенныхПриборовДействующихТочек");
	РегистрыСведений.энргДатыПоверкиПрибораУчета.ДатыПоверокДействующихПриборовУчета(Схема,Параметры,"ДатыПоверкиВведенныхПриборовДействующихТочек");
