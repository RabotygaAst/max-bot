#Область ПрограммныйИнтерфейс

// Формирует печатные формы.
//
// Параметры:
//  МассивОбъектов			-	см. УправлениеПечатьюПереопределяемый.ПриПечати.МассивОбъектов.
//  ПараметрыПечати			-	см. УправлениеПечатьюПереопределяемый.ПриПечати.ПараметрыПечати.
//  КоллекцияПечатныхФорм	-	см. УправлениеПечатьюПереопределяемый.ПриПечати.КоллекцияПечатныхФорм.
//  ОбъектыПечати			-	см. УправлениеПечатьюПереопределяемый.ПриПечати.ОбъектыПечати.
//  ПараметрыВывода			-	см. УправлениеПечатьюПереопределяемый.ПриПечати.ПараметрыВывода.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ИмяМакета 				= КоллекцияПечатныхФорм[0].ИмяМакета;
	СинонимМакета 			= КоллекцияПечатныхФорм[0].СинонимМакета;
	
	
	Если ИмяМакета = "ШаблонПоказаний" Тогда
		ТабличныйДокумент 		= СформироватьШаблонПоказаний(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ШаблонПочасовогоПотребления" Тогда
		ТабличныйДокумент 		= СформироватьШаблонПочасовогоПотребления(ИмяМакета, ПараметрыПечати);
	КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, ИмяМакета) Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		ИмяМакета, "Шаблон для выгрузки показаний",
		ТабличныйДокумент, ,
		"Обработка.бестЗагрузитьДанныеИзВнешнихИсточников." + ИмяМакета);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Функция - Загрузить данные почасовой ведомости
//
// Параметры:
//  Дата		 - 	Дата.
//  Организация	 - 	 - 
//  Район		 - 	 - 
//  Услуга		 - 	 - 
//  Файл		 - 	 - 
//  ТЗПоказания	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗагрузитьДанныеПочасовойВедомости(Дата, Организация, Район, Услуга, Файл, ТЗПоказания) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗПоказания.ОбъектРасчетаКод КАК ОбъектРасчетаКод,
	|	ТЗПоказания.ПриборУчетаИзФайла КАК ПриборУчетаИзФайла,
	|	ТЗПоказания.ОбъектРасчетаИзФайла КАК ОбъектРасчетаИзФайла,
	|	ТЗПоказания.ТарифнаяЗонаИзФайла КАК ТарифнаяЗонаИзФайла,
	|	ТЗПоказания.ШкалаИзФайла КАК ШкалаИзФайла,
	|	ТЗПоказания.Показания КАК Показания,
	|	ТЗПоказания.ТочкаУчетаИзФайла КАК ТочкаУчетаИзФайла,
	|	ТЗПоказания.ТарифнаяЗонаКод КАК ТарифнаяЗонаКод,
	|	ТЗПоказания.ШкалаКод КАК ШкалаКод
	|ПОМЕСТИТЬ ВТ_Показания
	|ИЗ
	|	&ТЗПоказания КАК ТЗПоказания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестОбъектыРасчета.Ссылка КАК ОбъектРасчета,
	|	энргПриборыУчетаАбонента.Ссылка КАК ПУ,
	|	энргТарифныеЗоны.Ссылка КАК ТарифнаяЗона,
	|	энргШкалыПриборовУчета.Ссылка КАК Шкала,
	|	ВТ_Показания.ПриборУчетаИзФайла КАК ПриборУчетаИзФайла,
	|	ВТ_Показания.ОбъектРасчетаИзФайла КАК ОбъектРасчетаИзФайла,
	|	ВТ_Показания.ТарифнаяЗонаИзФайла КАК ТарифнаяЗонаИзФайла,
	|	ВТ_Показания.ШкалаИзФайла КАК ШкалаИзФайла,
	|	ВТ_Показания.Показания КАК Показания,
	|	ВТ_Показания.ТочкаУчетаИзФайла КАК ТочкаУчетаИзФайла,
	|	энргТочкиУчета.Ссылка КАК ТочкаУчета,
	|	&Организация КАК Организация,
	|	&Район КАК Район,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	&Услуга КАК Услуга
	|ПОМЕСТИТЬ Итог
	|ИЗ
	|	ВТ_Показания КАК ВТ_Показания
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ПО ((ВЫРАЗИТЬ(ВТ_Показания.ОбъектРасчетаКод КАК СТРОКА(9))) = бестОбъектыРасчета.Код)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ((ВЫРАЗИТЬ(ВТ_Показания.ПриборУчетаИзФайла КАК СТРОКА(25))) = энргПриборыУчетаАбонента.Код)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргТарифныеЗоны КАК энргТарифныеЗоны
	|		ПО ((ВЫРАЗИТЬ(ВТ_Показания.ТарифнаяЗонаКод КАК СТРОКА(9))) = энргТарифныеЗоны.Код)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргШкалыПриборовУчета КАК энргШкалыПриборовУчета
	|		ПО ((ВЫРАЗИТЬ(ВТ_Показания.ШкалаКод КАК СТРОКА(9))) = энргШкалыПриборовУчета.Код)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргТочкиУчета КАК энргТочкиУчета
	|		ПО ((ВЫРАЗИТЬ(ВТ_Показания.ТочкаУчетаИзФайла КАК СТРОКА(9))) = энргТочкиУчета.Код)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	бестЗагруженныеДанныеИзВнешнихИсточников.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ УжеСозданныйДокумент
	|ИЗ
	|	Документ.бестЗагруженныеДанныеИзВнешнихИсточников КАК бестЗагруженныеДанныеИзВнешнихИсточников
	|ГДЕ
	|	НЕ бестЗагруженныеДанныеИзВнешнихИсточников.ПометкаУдаления
	|	И бестЗагруженныеДанныеИзВнешнихИсточников.ФайлДляЧтения = &ФайлДляЧтения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.ОбъектРасчета КАК ОбъектРасчета,
	|	Итог.ПУ КАК ПриборУчета,
	|	Итог.ТарифнаяЗона КАК ТарифнаяЗона,
	|	Итог.Шкала КАК Шкала,
	|	Итог.Показания КАК Показания,
	|	Итог.ТочкаУчета КАК ТочкаУчета,
	|	Итог.Организация КАК Организация,
	|	Итог.Район КАК Район,
	|	Итог.ПериодНачисления КАК ПериодНачисления,
	|	Итог.Услуга КАК Услуга,
	|	ИСТИНА КАК ГотовКОбработке
	|ПОМЕСТИТЬ ЗагруженныеДанные
	|ИЗ
	|	Итог КАК Итог
	|ГДЕ
	|	НЕ Итог.ОбъектРасчета ЕСТЬ NULL
	|	И НЕ Итог.ПУ ЕСТЬ NULL
	|	И НЕ Итог.ТарифнаяЗона ЕСТЬ NULL
	|	И НЕ Итог.Шкала ЕСТЬ NULL
	|	И НЕ Итог.ТочкаУчета ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.ОбъектРасчета КАК ОбъектРасчета,
	|	Итог.ПУ КАК ПУ,
	|	Итог.ТарифнаяЗона КАК ТарифнаяЗона,
	|	Итог.Шкала КАК Шкала,
	|	Итог.ПриборУчетаИзФайла КАК ПриборУчетаИзФайла,
	|	Итог.ОбъектРасчетаИзФайла КАК ОбъектРасчетаИзФайла,
	|	Итог.ТарифнаяЗонаИзФайла КАК ТарифнаяЗонаИзФайла,
	|	Итог.ШкалаИзФайла КАК ШкалаИзФайла,
	|	Итог.Показания КАК Показания,
	|	Итог.ТочкаУчетаИзФайла КАК ТочкаУчетаИзФайла,
	|	Итог.ТочкаУчета КАК ТочкаУчета,
	|	Итог.Организация КАК Организация,
	|	Итог.Район КАК Район,
	|	Итог.ПериодНачисления КАК ПериодНачисления,
	|	Итог.Услуга КАК Услуга,
	|	ЛОЖЬ КАК ГотовКОбработке
	|ПОМЕСТИТЬ НезагруженныеДанные
	|ИЗ
	|	Итог КАК Итог
	|ГДЕ
	|	(Итог.ОбъектРасчета ЕСТЬ NULL
	|			ИЛИ Итог.ПУ ЕСТЬ NULL
	|			ИЛИ Итог.ТарифнаяЗона ЕСТЬ NULL
	|			ИЛИ Итог.Шкала ЕСТЬ NULL
	|			ИЛИ Итог.ТочкаУчета ЕСТЬ NULL)";
	
	Запрос.УстановитьПараметр("ФайлДляЧтения", 		Файл);
	Запрос.УстановитьПараметр("ТЗПоказания", 		ТЗПоказания);
	Запрос.УстановитьПараметр("ПериодНачисления", 	Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Дата, Организация,Район));
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("Услуга", 			Услуга);
	
	Пакеты = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	ВыборкаДокумент 			= Пакеты[2].Выбрать();
	ВыборкаЗагруженные 			= Пакеты[3].Выбрать();
	ВыборкаНезагруженные 		= Пакеты[4].Выбрать();
	
	Если ВыборкаДокумент.Следующий() Тогда
		ДокументОб = ВыборкаДокумент.Ссылка.ПолучитьОбъект();
		ДокументОб.Показания.Очистить();
	Иначе
		ДокументОб = Документы.бестЗагруженныеДанныеИзВнешнихИсточников.СоздатьДокумент();
	КонецЕсли;
	
	
	ДокументОб.Дата 			= Дата;
	ДокументОб.ФайлДляЧтения 	= Файл;
	
	Пока ВыборкаЗагруженные.Следующий() Цикл
		НовСтр = ДокументОб.Показания.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, ВыборкаЗагруженные);
	КонецЦикла;
	
	Пока ВыборкаНезагруженные.Следующий() Цикл
		НовСтр = ДокументОб.Показания.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, ВыборкаНезагруженные);
	КонецЦикла;
	
	Попытка
		ДокументОб.Записать();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("При создании документа произошла ошибка");
		Возврат Неопределено;
	КонецПопытки;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ создан");
	Возврат ДокументОб.Ссылка;
КонецФункции

Функция ЗагрузитьДанныеПоказанийПирамидыЧерезExcel(Дата, Организация, Файл, ТЗПоказания) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗПоказания.IDСтроки КАК IDСтроки,
	|	ТЗПоказания.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТЗПоказания.ЗаводскойНомер КАК ЗаводскойНомер,
	|	ТЗПоказания.Адрес КАК Адрес,
	|	ТЗПоказания.ТипУстройства КАК ТипУстройства,
	|	ТЗПоказания.Показания КАК Показания,
	|	ТЗПоказания.ДатаПоказаний КАК ДатаПоказаний,
	|	ТЗПоказания.СтрокаЗаписана КАК СтрокаЗаписана
	|ПОМЕСТИТЬ ВТ_Показания
	|ИЗ
	|	&ТЗПоказания КАК ТЗПоказания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДанных.IDСтроки КАК IDСтроки,
	|	ТаблицаДанных.ЗаводскойНомер КАК ЗаводскойНомер,
	|	ТаблицаДанных.ДатаПоказаний КАК ДатаПоказаний,
	|	ТаблицаДанных.Адрес КАК Адрес,
	|	ТаблицаДанных.Показания КАК Показания,
	|	энргПриборыУчетаАбонента.Ссылка КАК ПриборУчета,
	|	ВЫБОР
	|		КОГДА энргПриборыУчетаАбонента.Ссылка ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ПУНайден,
	|	энргПриборыУчетаАбонента.ВидКанальности КАК ВидКанальности,
	|	ЗНАЧЕНИЕ(Справочник.энргШкалыПриборовУчета.Основная) КАК Шкала
	|ПОМЕСТИТЬ ДанныеНайденныхПУ
	|ИЗ
	|	ВТ_Показания КАК ТаблицаДанных
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ТаблицаДанных.ЗаводскойНомер = энргПриборыУчетаАбонента.Код
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестПриборыТочекУчетаНПСрезПоследних.Организация КАК Организация,
	|	бестПриборыТочекУчетаНПСрезПоследних.Район КАК Район,
	|	бестПриборыТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВТ_ТочкиУчетаПриборов
	|ИЗ
	|	РегистрСведений.бестПриборыТочекУчетаНП.СрезПоследних(&Период, ) КАК бестПриборыТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеНайденныхПУ.IDСтроки КАК IDСтроки,
	|	ДанныеНайденныхПУ.ЗаводскойНомер КАК ЗаводскойНомер,
	|	ДанныеНайденныхПУ.ДатаПоказаний КАК ДатаПоказаний,
	|	ДанныеНайденныхПУ.Адрес КАК Адрес,
	|	ДанныеНайденныхПУ.Показания КАК Показания,
	|	ДанныеНайденныхПУ.ПриборУчета КАК ПриборУчета,
	|	ДанныеНайденныхПУ.ПУНайден КАК ПУНайден,
	|	ДанныеНайденныхПУ.ВидКанальности КАК ВидКанальности,
	|	ДанныеНайденныхПУ.Шкала КАК Шкала,
	|	ВТ_ТочкиУчетаПриборов.Организация КАК Организация,
	|	ВТ_ТочкиУчетаПриборов.Район КАК Район,
	|	ВТ_ТочкиУчетаПриборов.ОбъектРасчета КАК ОбъектРасчета,
	|	ВТ_ТочкиУчетаПриборов.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ВТ_ПромежуточныйИтог
	|ИЗ
	|	ДанныеНайденныхПУ КАК ДанныеНайденныхПУ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТочкиУчетаПриборов КАК ВТ_ТочкиУчетаПриборов
	|		ПО ДанныеНайденныхПУ.ПриборУчета = ВТ_ТочкиУчетаПриборов.ПриборУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестУслугиТочекУчетаНПСрезПоследних.Организация КАК Организация,
	|	бестУслугиТочекУчетаНПСрезПоследних.Район КАК Район,
	|	бестУслугиТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ ВТ_Услуги
	|ИЗ
	|	РегистрСведений.бестУслугиТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			(Организация, Район, ОбъектРасчета, ТочкаУчета) В
	|				(ВЫБРАТЬ
	|					ВТ.Организация,
	|					ВТ.Район,
	|					ВТ.ОбъектРасчета,
	|					ВТ.ТочкаУчета
	|				ИЗ
	|					ВТ_ПромежуточныйИтог КАК ВТ)) КАК бестУслугиТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.Организация КАК Организация,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.Район КАК Район,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
