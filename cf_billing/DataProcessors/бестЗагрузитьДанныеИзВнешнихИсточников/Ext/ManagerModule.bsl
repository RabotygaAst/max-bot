	|	Итог.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ОтборПоУслуге
	|ИЗ
	|	Итог КАК Итог
	|ГДЕ
	|	Итог.Услуга = &Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтборПоУслуге.ОбъектРасчета КАК НаименованиеОбъекта,
	|	ОтборПоУслуге.Шкала КАК Шкала,
	|	ОтборПоУслуге.Услуга КАК Услуга,
	|	ОтборПоУслуге.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ОтборПоУслуге.ПриборУчета КАК ПУ,
	|	ЕСТЬNULL(бестКоэффциентыПриборовУчетаНПСрезПоследних.Коэффициент, 0) КАК КоэфТрансформации,
	|	бестОбъектыРасчета.Код КАК КодОбъекта,
	|	энргШкалыПриборовУчета.Код КАК ШкалаКод,
	|	энргТарифныеЗоны.Код КАК ТарифнаяЗонаКод,
	|	энргТочкиУчета.Код КАК КодТУ
	|ИЗ
	|	ОтборПоУслуге КАК ОтборПоУслуге
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестКоэффциентыПриборовУчетаНП.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район) КАК бестКоэффциентыПриборовУчетаНПСрезПоследних
	|		ПО ОтборПоУслуге.ТочкаУчета = бестКоэффциентыПриборовУчетаНПСрезПоследних.ТочкаУчета
	|			И (бестКоэффциентыПриборовУчетаНПСрезПоследних.ПриборУчета = ОтборПоУслуге.ПриборУчета)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ПО ОтборПоУслуге.ОбъектРасчета = бестОбъектыРасчета.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргШкалыПриборовУчета КАК энргШкалыПриборовУчета
	|		ПО ОтборПоУслуге.Шкала = энргШкалыПриборовУчета.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргТарифныеЗоны КАК энргТарифныеЗоны
	|		ПО ОтборПоУслуге.ТарифнаяЗона = энргТарифныеЗоны.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТочкиУчета КАК энргТочкиУчета
	|		ПО ОтборПоУслуге.ТочкаУчета = энргТочкиУчета.Ссылка";
	
	Запрос.УстановитьПараметр("Организация",ПараметрыПечати.Организация);
	Запрос.УстановитьПараметр("Период", 	ПараметрыПечати.Дата);
	Запрос.УстановитьПараметр("Район", 		ПараметрыПечати.Район);
	Запрос.УстановитьПараметр("Услуга",		ПараметрыПечати.Услуга);
	Запрос.УстановитьПараметр("Договор",	ПараметрыПечати.Договор);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаШапкаПодвал 	= РезультатЗапроса[0].Выбрать();
	ВыборкаДанные 		= РезультатЗапроса[2].Выбрать();
	
	Если ВыборкаШапкаПодвал.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ВыборкаШапкаПодвал);
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапкаПодвал);
		ОбластьШапка.Параметры.ДатаДоговора = Формат(ВыборкаШапкаПодвал.ДатаДоговора, "ДЛФ=D");
		
		
		ПодписантКонтрагента = ПараметрыПечати.ПодписантКонтрагента;
		ОбластьПодвал.Параметры.ДатаДоговора = Формат(ВыборкаШапкаПодвал.ДатаДоговора, "ДЛФ=D");
		ОбластьПодвал.Параметры.ПодписантКонтрагента = ПодписантКонтрагента;
		ОбластьПодвал.Параметры.ДолжностьПодписантаКонтрагента = ПодписантКонтрагента.Должность;
	КонецЕсли;
	
	ТабДок.Вывести(ОбластьШапка);
	
	Пока ВыборкаДанные.Следующий() Цикл
		ОбластьСтрокаПоказаний = Макет.ПолучитьОбласть("СтрокаПоказаний");
		ЗаполнитьЗначенияСвойств(ОбластьСтрокаПоказаний.Параметры,ВыборкаДанные);
		ТабДок.Вывести(ОбластьСтрокаПоказаний);
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьПодвал);
	Возврат ТабДок;
КонецФункции

Функция СформироватьШаблонПочасовогоПотребления(ИмяМакета, ПараметрыПечати)
	
	Макет 									= УправлениеПечатью.МакетПечатнойФормы("Обработка.бестЗагрузитьДанныеИзВнешнихИсточников." +ИмяМакета);
	
	ТабДок 									= Новый ТабличныйДокумент;
	
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	Результат = РегистрыСведений.бестПриборыТочекУчетаНП.ПолучитьДанныеПрибораУчета(ПараметрыПечати.Организация, ПараметрыПечати.Район, ПараметрыПечати.Дата,,,ПараметрыПечати.ТочкаУчета);
	
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ОбластьШапка.Параметры.ПУ 		= Выборка.ПриборУчета;
	КонецЕсли;
	
	Если ПараметрыПечати.ВидОперации = Перечисления.бестВидыОпераций.ПочасоваяВедомость_ПлановоеПотребление Тогда
		ОбластьШапка.Параметры.Заголовок 		= "Отчет о плановом почасовом объеме потребления электрической энергии (форма) для потребителей, рассчитывающихся с 5-6 ценовым категориям";
		ОбластьШапка.Параметры.НомерПриложения 	= "ПРИЛОЖЕНИЕ 2.3.";
		ОбластьПодвал.Параметры.Примечение 		= "Примечание:" + Символы.ПС + "1. Плановое почасовое потребление электроэнергии (ППП) ""Потребителя"" формируется отдельно по каждому объекту электроснабжения, в объемы ППП включаются объемы потребления субабонентов." + Символы.ПС +  "2. В объемы данного Приложения не включаются: объемы транзита электроэнергии в сети Сетевой организации.";
	Иначе
		ОбластьШапка.Параметры.Заголовок 		= "Отчет о почасовом потреблении электрической энергии (форма) для объектов потребителей, рассчитывающихся с 3-6 ценовым категориям";
		ОбластьШапка.Параметры.НомерПриложения 	= "ПРИЛОЖЕНИЕ 4.1.";
		ОбластьПодвал.Параметры.Примечение 		= "Примечание: В случае если на энергоснабжаемом объекте установлены несколько приборов учета электрической энергии, то потребитель обязуется предоставлять отчет о расходе электрической энергии и мощности с расшифровкой почасовых объемов потребления, в том числе в целом по объекту.";
	КонецЕсли;
	
	
	ОбластьШапка.Параметры.ТочкаУчета 				= ПараметрыПечати.ТочкаУчета;
	ОбластьШапка.Параметры.КодТУ 					= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыПечати.ТочкаУчета, "Код");
	ОбластьШапка.Параметры.Период 					= Формат(ПараметрыПечати.Дата, "ДЛФ=D");
	ОбластьШапка.Параметры.Контрагент 				= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыПечати.Договор, "Контрагент");
	ОбластьШапка.Параметры.НомерДоговора 			= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыПечати.Договор, "Номер");
	ОбластьШапка.Параметры.ДатаДоговора 			= Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыПечати.Договор, "Дата"), "ДЛФ=D");
	
	ОбластьПодвал.Параметры.Контрагент 				= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыПечати.Договор, "Контрагент");
	ОбластьПодвал.Параметры.Организация 			= ПараметрыПечати.Организация;
	
	ТабДок.Вывести(ОбластьШапка);
	
	пДень = НачалоМесяца(ПараметрыПечати.Дата);
	
	Пока Месяц(ПараметрыПечати.Дата) = Месяц(пДень) Цикл
		ОбластьДанные = Макет.ПолучитьОбласть("Данные");
		ОбластьДанные.Параметры.День 			= Формат(пДень,"ДЛФ=D");
		ТабДок.Вывести(ОбластьДанные);
		пДень = пДень + 86400;
	КонецЦикла;
	
	
	ПодписантКонтрагента = ПараметрыПечати.ПодписантКонтрагента;
	ОбластьПодвал.Параметры.ПодписантКонтрагента = ПодписантКонтрагента;
	ОбластьПодвал.Параметры.ДолжностьПодписантаКонтрагента = ПодписантКонтрагента.Должность;
	ТабДок.Вывести(ОбластьПодвал);
	Возврат ТабДок;
КонецФункции

#КонецОбласти

#КонецЕсли