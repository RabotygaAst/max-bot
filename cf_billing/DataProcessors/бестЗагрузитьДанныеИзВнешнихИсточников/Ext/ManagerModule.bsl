	|			И ВТ_ПромежуточныйИтог.Район = ВТ_Услуги.Район
	|			И ВТ_ПромежуточныйИтог.ОбъектРасчета = ВТ_Услуги.ОбъектРасчета
	|			И ВТ_ПромежуточныйИтог.ТочкаУчета = ВТ_Услуги.ТочкаУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ВидДифференцированности КАК ВТ_ВидДифференцированности
