	Запрос.УстановитьПараметр("ТЗПоказания", 		ТЗПоказания);
	Запрос.УстановитьПараметр("ПериодНачисления", 	Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Дата, Организация, Справочники.энргЗоныОтвественности.ПустаяСсылка()));
	Запрос.УстановитьПараметр("Организация", 		Организация); 
	Запрос.УстановитьПараметр("Период", 			Дата);
	
	Пакеты = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	ВыборкаДокумент 			= Пакеты[Пакеты.Количество() - 3].Выбрать();
	ВыборкаЗагруженные 			= Пакеты[Пакеты.Количество() - 2].Выбрать();
	ВыборкаНезагруженные 		= Пакеты[Пакеты.Количество() - 1].Выбрать();
	
	Если ВыборкаДокумент.Следующий() Тогда
		ДокументОб = ВыборкаДокумент.Ссылка.ПолучитьОбъект();
		ДокументОб.Показания.Очистить();
	Иначе
		ДокументОб = Документы.бестЗагруженныеДанныеИзВнешнихИсточников.СоздатьДокумент();
	КонецЕсли;
	
	
	ДокументОб.Дата 			= Дата;
	ДокументОб.ФайлДляЧтения 	= Файл;
	
	Пока ВыборкаЗагруженные.Следующий() Цикл
		НовСтр = ДокументОб.Показания.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, ВыборкаЗагруженные);
	КонецЦикла;
	
	Пока ВыборкаНезагруженные.Следующий() Цикл
		НовСтр = ДокументОб.Показания.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, ВыборкаНезагруженные);
	КонецЦикла;
	
	Попытка
		ДокументОб.Записать();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("При создании документа произошла ошибка");
		Возврат Неопределено;
	КонецПопытки;
	Возврат ДокументОб.Ссылка;
КонецФункции

Функция ЗагрузитьДанныеГП(Дата, Организация, Услуга, Поставщик, ПутьКФайлу, ТЗУсредненныеОбъемы) Экспорт
	ПрофильГП 					= Документы.бестПрофильГарантирующегоПоставщика.СоздатьДокумент();
	ПрофильГП.Дата 				= ТекущаяДата();
	ПрофильГП.Организация 		= Организация;
	ПрофильГП.ПериодНачисления 	= Дата;
	ПрофильГП.Услуга 			= Услуга;
	ПрофильГП.ФайлДляЧтения 	= ПутьКФайлу;
	ПрофильГП.Поставщик 		= Поставщик;
	
	Для каждого стр из ТЗУсредненныеОбъемы Цикл
		НовСтр = ПрофильГП.УсредненныеОбъемы.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, стр);
	КонецЦикла;
	
	Попытка
		ПрофильГП.Записать(РежимЗаписиДокумента.Проведение);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ создан");
		Возврат ПрофильГП.Ссылка;
	Исключение 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("При создании документа произошла ошибка");
		Возврат Неопределено;
	КонецПопытки;
КонецФункции	

