#Область ОбработчикиКомандФормы 

&НаКлиенте
Процедура ЗагрузитьФайл(Команда)
	СозданныеДокументы.Очистить();
	НезагруженныеДанные = ПредопределенноеЗначение("Документ.бестЗагруженныеДанныеИзВнешнихИсточников.ПустаяСсылка");
	Если ОбщегоНазначенияКлиентСервер.ЭтоВебКлиент() Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузкаПУВеб", ЭтотОбъект);
		НачатьПомещениеФайла(ОписаниеОповещения, , , ОбщегоНазначенияКлиентСервер.ЭтоВебКлиент(), УникальныйИдентификатор);
	Иначе
		МассивФайлов = ПолучитьФайлыДляЗагрузкиИзКаталога(Папка,"Загружен_");
		ExcelApp = Новый COMОбъект("Excel.Application");
		Для каждого Файл из МассивФайлов Цикл
			Попытка
				Книга = ExcelApp.Workbooks.Open(Файл.ПолноеИмя);
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Не удалось открыть файл. Возможно, он открыт в другом приложении.'"));
				Возврат;
			КонецПопытки; 	
			Попытка
				Страница = Книга.Worksheets(1);
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Загрузка: Не удалось найти лист в файле.'"));
				ExcelApp.Quit();
				Возврат;
			КонецПопытки;
			
			ПрочитатьЛистExcel(Страница);
			ExcelApp.Quit();
			Если ЗагрузитьДанныеПочасовойВедомости(Файл.ПолноеИмя) Тогда
				УстановитьПрефиксЗагруженногоФайла(Файл);
			КонецЕсли;
			ТЗПредоставленныеОбъемы.Очистить();
		КонецЦикла;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка завершена!");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьШаблонПоказаний(Команда)
	Результат = Новый Структура("Дата, Организация, Район, Услуга, Договор, ПодписантКонтрагента");
	ЗаполнитьЗначенияСвойств(Результат, ЭтаФорма);
	
	ИмяМакета  			= "ШаблонПоказаний";
	ТаблицаМакета 		= "Обработка.бестЗагрузитьДанныеИзВнешнихИсточников";
	
	МассивОбъектов = Договор;
	
	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(ТаблицаМакета,ИмяМакета,МассивОбъектов,ЭтотОбъект,Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьПоказания(Команда)
	СозданныеДокументыПоказаний.Очистить();
	Если ОбщегоНазначенияКлиентСервер.ЭтоВебКлиент() Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузкаПУВеб", ЭтотОбъект);
		НачатьПомещениеФайла(ОписаниеОповещения, , , ОбщегоНазначенияКлиентСервер.ЭтоВебКлиент(), УникальныйИдентификатор);
	Иначе
		МассивФайлов = ПолучитьФайлыДляЗагрузкиИзКаталога(Папка,"Загружен_");
		ExcelApp = Новый COMОбъект("Excel.Application");
		Для каждого Файл из МассивФайлов Цикл
			Попытка
				Книга = ExcelApp.Workbooks.Open(Файл.ПолноеИмя);
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Не удалось открыть файл. Возможно, он открыт в другом приложении.'"));
				Возврат;
			КонецПопытки; 	
			Попытка
				Страница = Книга.Worksheets(1);
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Загрузка: Не удалось найти лист в файле.'"));
				ExcelApp.Quit();
				Возврат;
			КонецПопытки;
			
			ПрочитатьЛистExcelПоказания(Страница);
			ExcelApp.Quit();
			ЗагрузитьДанныеПоказаний(Файл.ПолноеИмя);
			УстановитьПрефиксЗагруженногоФайла(Файл);
			ТЗПоказания.Очистить();
		КонецЦикла;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка завершена!");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзExcel(Команда) 
