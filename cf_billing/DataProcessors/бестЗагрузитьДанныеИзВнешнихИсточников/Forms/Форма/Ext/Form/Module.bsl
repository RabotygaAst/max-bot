#Область События_РаботаСФайлом 

&НаКлиенте
Процедура ПрочитатьЛистExcel(ЛистЭксель) 
	НомерПервойКолонки 	= 2;
	НомерПервойСтроки 	= 16;
	ВсегоСтрок 			= День(КонецМесяца(?(ЗначениеЗаполнено(ДатаФактическогоСобытия),ДатаФактическогоСобытия,Дата))) + НомерПервойСтроки - 1;
	ВсегоКолонок 		= 25;
	
	Для Строка = НомерПервойСтроки По ВсегоСтрок Цикл
		День = Дата(СокрЛП(ЛистЭксель.Cells(Строка,1).Text) + " 00:00:00");
		Для Колонка = НомерПервойКолонки По ВсегоКолонок Цикл
			НоваяСтрока = ТЗПредоставленныеОбъемы.Добавить();
			НоваяСтрока.День = День;
			Если ЗначениеЗаполнено(ЛистЭксель.Cells(Строка,Колонка).Text) Тогда
				НоваяСтрока.Объем = Число(СтрЗаменить(СокрЛП(ЛистЭксель.Cells(Строка,Колонка).Text)," ",""));
			Иначе
				НоваяСтрока.Объем = -1;
			КонецЕсли;
			НоваяСтрока.Час = Колонка - 2;	      				
		КонецЦикла;
		
	КонецЦикла;
	
	ЗаводскойНомер 	= СокрЛП(ЛистЭксель.Cells(6, 16).Text);
	КодТУ 			= СокрЛП(ЛистЭксель.Cells(4, 23).Text);
КонецПроцедуры

&НаКлиенте
Функция ПолучитьФайлыДляЗагрузкиИзКаталога(КаталогПоиска, ПрефиксЗагруженногоФайла, Маска = "*.xlsx") 
	Ответ = Новый Массив;
	
	НайденныеФайлы = НайтиФайлы(КаталогПоиска, Маска);
	Для Каждого ТекФайл Из НайденныеФайлы Цикл
		Если СтрНайти(ТекФайл.ИмяБезРасширения, ПрефиксЗагруженногоФайла) > 0 Тогда
			Продолжить;	
		КонецЕсли; 
		
		Ответ.Добавить(ТекФайл);
	КонецЦикла; 	
	
	Возврат Ответ;
КонецФункции

#КонецОбласти

#Область ЗагрузкаПочасовыхВедомостей 

&НаСервере
Функция ЗагрузитьДанныеПочасовойВедомости(Файл) 
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("Дата", НачалоМесяца(Дата));   
	ПараметрыДокумента.Вставить("ФайлДляЧтения", Файл);
	ПараметрыДокумента.Вставить("ВидОперации", ВидОперации);
	ПараметрыДокумента.Вставить("ДатаФактическогоСобытия", ДатаФактическогоСобытия);
	ПараметрыДокумента.Вставить("УчитыватьКоэффициентПУ", УчитыватьКоэффициентПУ);
	
	НовыйДок = бестИнтеграции.ЗагрузитьДанныеПочасовойВедомости(ПараметрыДокумента, ЗаводскойНомер, КодТУ, ТЗПредоставленныеОбъемы.Выгрузить());
	Если НовыйДок <> Неопределено Тогда
		СозданныеДокументы.Добавить(НовыйДок);
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

&НаКлиенте
Функция ПолучитьИмяФайлаПослеЗагрузки(ПолныйПуть)
	Результат	= ПолныйПуть;
	
	Файл 		= Новый Файл(ПолныйПуть);	
	Если НЕ Файл.Существует() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИмяБезРасширения 	= Файл.ИмяБезРасширения;
	Результат			= СтрЗаменить(ПолныйПуть, "\" + ИмяБезРасширения, "\" + "Загружен_" + ИмяБезРасширения);
	Возврат Результат;	
КонецФункции

&НаКлиенте
Функция УстановитьПрефиксЗагруженногоФайла(ТекФайл)
	НовоеИмяФайла = ПолучитьИмяФайлаПослеЗагрузки(ТекФайл.ПолноеИмя);
	ПереместитьФайл(ТекФайл.ПолноеИмя, НовоеИмяФайла);
	
	Возврат НовоеИмяФайла;
КонецФункции

&НаСервере
Функция  ПолучитьМассивДоступныхТУ()
	Результат = РегистрыСведений.бестДоговорыТочекУчета.ПолучитьДанныеДоговоров(Организация,Район,Дата,Договор,,,Услуга);
	Возврат Результат.Выгрузить().ВыгрузитьКолонку("ТочкаУчета");
КонецФункции

#КонецОбласти

#Область ЗагрузкаПоказаний 

&НаСервере
Процедура ЗагрузитьДанныеПоказаний(Файл)
	НовыйДок = Обработки.бестЗагрузитьДанныеИзВнешнихИсточников.ЗагрузитьДанныеПочасовойВедомости(Дата, Организация, Район, Услуга, Файл, ТЗПоказания.Выгрузить());
	СозданныеДокументыПоказаний.Добавить(НовыйДок);
КонецПроцедуры

&НаКлиенте
Процедура ПрочитатьЛистExcelПоказания(ЛистЭксель) 
	НомерПервойСтроки 	= 16;
	ВсегоСтрок			= ЛистЭксель.Cells.SpecialCells(11).Row;	
	Для Строка = НомерПервойСтроки По ВсегоСтрок Цикл
		Если НЕ ЗначениеЗаполнено(ЛистЭксель.Cells(Строка,2).Text) Тогда
			Прервать;
		КонецЕсли;
		НовСтр = ТЗПоказания.Добавить();
		НовСтр.ОбъектРасчетаКод 	= СокрЛП(ЛистЭксель.Cells(Строка,2).Text);
		НовСтр.ОбъектРасчетаИзФайла = СокрЛП(ЛистЭксель.Cells(Строка,3).Text) + "(" + СокрЛП(ЛистЭксель.Cells(Строка,2).Text) + ")";
		
		НовСтр.ТочкаУчетаИзФайла 	= СокрЛП(ЛистЭксель.Cells(Строка,6).Text);
		
		НовСтр.ПриборУчетаИзФайла 	= СокрЛП(ЛистЭксель.Cells(Строка,7).Text);
		
		НовСтр.ТарифнаяЗонаКод 		= СокрЛП(ЛистЭксель.Cells(Строка,11).Text);
		НовСтр.ТарифнаяЗонаИзФайла 	= СокрЛП(ЛистЭксель.Cells(Строка,10).Text) + "(" + СокрЛП(ЛистЭксель.Cells(Строка,11).Text) + ")";
		
		НовСтр.ШкалаКод 			= СокрЛП(ЛистЭксель.Cells(Строка,9).Text);
		НовСтр.ШкалаИзФайла 		= СокрЛП(ЛистЭксель.Cells(Строка,8).Text) + "(" + СокрЛП(ЛистЭксель.Cells(Строка,9).Text) + ")";
		Показание 					= СтрЗаменить(СокрЛП(ЛистЭксель.Cells(Строка,13).Text)," ","");
		Если ЗначениеЗаполнено(Показание) Тогда
			НовСтр.Показания = Число(Показание);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаПоказанийИзExcel  

&НаКлиенте
Процедура ОбработатьФайлЗавершениеЗагрузкаИзExcel(ПомещенныйФайл, ДополнительныеПараметры) Экспорт

   ЗагрузитьИзExcelНаСервере(ПомещенныйФайл.Хранение);

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИзExcelНаСервере(АдресВХ)
	
	ТаблицаДанных 		= ДесериализоватьФайл(АдресВХ);
		
	НовыйДок = Обработки.бестЗагрузитьДанныеИзВнешнихИсточников.ЗагрузитьДанныеПоказанийПирамидыЧерезExcel(Дата, Организация, ПутьКФайлу, ТаблицаДанных);
	СозданныеДокументыПоказаний.Добавить(НовыйДок);
	
 	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка завершена");
КонецПроцедуры

&НаСервере
Процедура ПрочитатьФайлДанных(ФайлДанных, ТаблицаДанных)
	
	ТабДок = Новый ТабличныйДокумент; 
	ТабДок.Прочитать(ФайлДанных);
	ПЗ 						= Новый ПостроительЗапроса;
	ПЗ.ИсточникДанных 		= Новый ОписаниеИсточникаДанных(ТабДок.Область(2,1,ТабДок.ВысотаТаблицы+1,6));
	
	ПЗ.ДобавлениеПредставлений 	= ТипДобавленияПредставлений.НеДобавлять;
	ПЗ.ЗаполнитьНастройки();
	ПЗ.Выполнить();
	ТЗ = ПЗ.Результат.Выгрузить();
		
	Для Каждого ТекСтрока Из ТЗ Цикл
		
		Если Не ЗначениеЗаполнено(Формат(ТекСтрока[1], "ЧГ=0")) Тогда
			Продолжить;
		КонецЕсли;
		
		НСтрока = ТаблицаДанных.Добавить();
		НСтрока.IDСтроки		= "" + Новый УникальныйИдентификатор;
		НСтрока.ЗаводскойНомер 	= Формат(ТекСтрока[1], "ЧГ=0");
		НСтрока.ДатаПоказаний 	= СтроковыеФункцииКлиентСервер.СтрокаВДату(СокрЛП(ТекСтрока[2]));
		НСтрока.Адрес		 	= СокрЛП(ТекСтрока[3]);
		НСтрока.ТипУстройства 	= СокрЛП(ТекСтрока[4]);
		НСтрока.Показания	 	= Формат(ТекСтрока[5], "ЧГ=0");
			
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
Функция ДесериализоватьФайл(АдресВХ)
	ДвоичныеДанные 	= ПолучитьИзВременногоХранилища(АдресВХ); 	
	тПуть 			= ПолучитьИмяВременногоФайла("xls"); 
	ДвоичныеДанные.Записать(тПуть);	
	
	ТаблицаДанных 	= НоваяТаблицаДесериализированныхДанных();
	Попытка
		ПрочитатьФайлДанных(тПуть, ТаблицаДанных);	
	Исключение
		ТаблицаДанных.Очистить();
		
		ИнфоОбОшибки 	= ИнформацияОбОшибке();
		Комментарий 	= "Ошибка чтения файла по причине: " + Символы.ПС + ПодробноеПредставлениеОшибки(ИнфоОбОшибки);
		пКомментарий 	= "Ошибка чтения файла по причине: " + Символы.ПС + КраткоеПредставлениеОшибки(ИнфоОбОшибки);
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(пКомментарий);
		ЗаписьЖурналаРегистрации(
		"Загрузка показаний Пирамида", 
		УровеньЖурналаРегистрации.Ошибка,,,
		Комментарий);
	КонецПопытки;	
	
	Попытка
		УдалитьФайлы(тПуть);	
	Исключение
		ИнфоОбОшибки = ИнформацияОбОшибке();
		Комментарий = "Ошибка удаления временного файла. Путь к временному файлу: " + тПуть + Символы.ПС + ПодробноеПредставлениеОшибки(ИнфоОбОшибки);
		
		ЗаписьЖурналаРегистрации(
		"Загрузка показаний Пирамида", 
		УровеньЖурналаРегистрации.Ошибка,,,
		Комментарий);
	КонецПопытки; 	
	
	Возврат ТаблицаДанных;	 	
КонецФункции

Функция НоваяТаблицаДесериализированныхДанных()
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("IDСтроки"			, ОбщегоНазначения.ОписаниеТипаСтрока(36));
	Таблица.Колонки.Добавить("ТарифнаяЗона"		, Новый ОписаниеТипов("СправочникСсылка.энргТарифныеЗоны"));
	Таблица.Колонки.Добавить("ЗаводскойНомер"	, ОбщегоНазначения.ОписаниеТипаСтрока(50));
	Таблица.Колонки.Добавить("Адрес"			, ОбщегоНазначения.ОписаниеТипаСтрока(1000));
	Таблица.Колонки.Добавить("ТипУстройства"	, ОбщегоНазначения.ОписаниеТипаСтрока(50));
	Таблица.Колонки.Добавить("Показания"		, ОбщегоНазначения.ОписаниеТипаЧисло(15, 6));
	Таблица.Колонки.Добавить("ДатаПоказаний"	, ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	Таблица.Колонки.Добавить("СтрокаЗаписана"	, Новый ОписаниеТипов("Булево"));
	
	Возврат Таблица;
КонецФункции
#КонецОбласти

#Область ЗагрузкаГП

&НаКлиенте
Процедура ПрочитатьЛистExcelГП(ЛистЭксель) 
	НомерПервойКолонки 	= 2;
	НомерПервойСтроки 	= 6;
	ВсегоСтрок 			= 29;
	ВсегоКолонок 		= 15;
	Час = 0;
	Для Строка = НомерПервойСтроки По ВсегоСтрок Цикл
		Для Колонка = НомерПервойКолонки По ВсегоКолонок Цикл
			НоваяСтрока = ТЗПредоставленныеОбъемы.Добавить();
			НоваяСтрока.День = Дата(СокрЛП(ЛистЭксель.Cells(5,Колонка).Text) + " 00:00:00");
			НоваяСтрока.Объем = Число(СтрЗаменить(СокрЛП(ЛистЭксель.Cells(Строка,Колонка).Text)," ",""));
			НоваяСтрока.Час = Час;	
		КонецЦикла;
		Час = Час + 1;
	КонецЦикла;
	
	НомерПервойКолонки 	= 2;
	НомерПервойСтроки 	= 33;
	ВсегоСтрок 			= 56;
	ВсегоКолонок 		= День(КонецМесяца(Дата)) - 14;
	Час = 0;
	Для Строка = НомерПервойСтроки По ВсегоСтрок Цикл
		Для Колонка = НомерПервойКолонки По ВсегоКолонок Цикл
			НоваяСтрока = ТЗПредоставленныеОбъемы.Добавить();
			НоваяСтрока.День = Дата(СокрЛП(ЛистЭксель.Cells(32,Колонка).Text) + " 00:00:00");
			НоваяСтрока.Объем = Число(СтрЗаменить(СокрЛП(ЛистЭксель.Cells(Строка,Колонка).Text)," ",""));
			НоваяСтрока.Час = Час;	  	
		КонецЦикла;
		Час = Час + 1;
	КонецЦикла;
КонецПроцедуры

