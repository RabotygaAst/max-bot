#Область ОбработчикиСобытийФормы 

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Услуга 		= Константы.бестУслугаДляЗагрузкиПочасовыхВедомостей.Получить();
	Дата 		= НачалоМесяца(ТекущаяДатаСеанса()); 
	Организация = Справочники.Организации.НашаОрганизация;
	
	Если Параметры.Свойство("Договор") Тогда
		Договор = Параметры.Договор;
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "Контрагент");
		Параметры.Свойство("Организация", Организация);
		Параметры.Свойство("Район", Район);
		Параметры.Свойство("ТочкаУчета", ТочкаУчета);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы 

&НаКлиенте
Процедура ДоговорПриИзменении(Элемент)
	Контрагент = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "Контрагент");
КонецПроцедуры

&НаКлиенте
Процедура ФайлНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ДиалогВыбораФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	
	Если ДиалогВыбораФайла.Выбрать() Тогда
		Папка = ДиалогВыбораФайла.Каталог;		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ПутьКФайлу = бестПользовательскийВводКлиент.РаботаСДиалогомВыбора(РежимДиалогаВыбораФайла.Открытие,"Выберите файл","xls файл (*.xls)|*.xls",Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура Дата3ПриИзменении(Элемент)
	Дата = НачалоМесяца(Дата);
КонецПроцедуры

&НаКлиенте
Процедура ТочкаУчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка 	= Ложь;
	ФормаВыбора 			= ПолучитьФорму("Справочник.энргТочкиУчета.ФормаВыбора",,Элемент);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ФормаВыбора.Список,"Ссылка", ПолучитьМассивДоступныхТУ(), ВидСравненияКомпоновкиДанных.ВСписке);
	ФормаВыбора.Открыть();
КонецПроцедуры

#КонецОбласти

