		|	И бестУстановитьДанныеДляРасчетаНерегулируемойЦеныПервойЦК.Организация = &Организация
		|	И бестУстановитьДанныеДляРасчетаНерегулируемойЦеныПервойЦК.Район = &Район";
	
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ДокументОб = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
	КонецЦикла;
	
	Если ДокументОб = Неопределено Тогда
		ДокументОб 					= Документы.бестУстановитьДанныеДляРасчетаНерегулируемойЦеныПервойЦК.СоздатьДокумент();
		ДокументОб.Организация 		= Организация; 
		ДокументОб.Район 			= Район;
		ДокументОб.ПериодНачисления = ПериодНачисления;
		ДокументОб.Дата				= ТекущаяДатаСеанса();
	КонецЕсли;
		
	ДокументОб.ФайлЗагрузки 		= Файл; 
	ДокументОб.Поставщик 			= Поставщик; 
	ДокументОб.Услуга 				= Электроэнергия;
	ДокументОб.ТарифнаяЗона 		= Справочники.энргТарифныеЗоны.БезРазбивки;  
