
#Область События_Шапки 

&НаКлиенте
Процедура ПериодНачисленияПриИзменении(Элемент)
	ПериодНачисления = НачалоМесяца(ПериодНачисления);
КонецПроцедуры

&НаКлиенте
Процедура ФайлНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ДиалогВыбораФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	
	Если ДиалогВыбораФайла.Выбрать() Тогда
		Файл = ДиалогВыбораФайла.ПолноеИмяФайла;		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Если НЕ МобильныйКлиент Тогда

#Область События_Команды 
&НаКлиенте
Процедура Загрузить(Команда)
	ExcelApp = Новый COMОбъект("Excel.Application"); 
	Попытка
		Книга = ExcelApp.Workbooks.Open(Файл);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Не удалось открыть файл. Возможно, он открыт в другом приложении.'"));
		Возврат;
	КонецПопытки; 	
	Попытка
		Страница = Книга.Worksheets(1);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Загрузка: Не удалось найти лист в файле.'"));
		ExcelApp.Quit();
		Возврат;                                                                
	КонецПопытки;
	
	ПрочитатьЛистExcel(Страница);
	ExcelApp.Quit();
	ЗагрузитьЧасы();
	ПиковыеЧасы.Очистить();
 
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка завершена!");
КонецПроцедуры

#КонецОбласти

#КонецЕсли

#Область События_РаботаСФайлом 

&НаКлиенте
Процедура ПрочитатьЛистExcel(ЛистЭксель) 
	
	НомерПервойСтроки 	= 9;
	ВсегоСтрок 			= ЛистЭксель.Cells.SpecialCells(11).Row;
		
	Для Строка = НомерПервойСтроки По ВсегоСтрок Цикл		
		СтрокаДень = СокрЛП(ЛистЭксель.Cells(Строка,1).Text);
		Если ЗначениеЗаполнено(СтрокаДень) Тогда
			НоваяСтрока = ПиковыеЧасы.Добавить();
			НоваяСтрока.День = Дата(СтрокаДень + " 00:00:00");
			НоваяСтрока.Час  = Число(СтрЗаменить(СокрЛП(ЛистЭксель.Cells(Строка,2).Text)," ",""));
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область События_ВспомогательныеПроцедурыИФункции 

&НаСервере
Процедура ЗагрузитьЧасы() 
	
	ДокументОб = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестИзменитьЧасыПиковойНагрузки.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.бестИзменитьЧасыПиковойНагрузки КАК бестИзменитьЧасыПиковойНагрузки
		|ГДЕ
		|	НЕ бестИзменитьЧасыПиковойНагрузки.ПометкаУдаления
		|	И бестИзменитьЧасыПиковойНагрузки.ПериодНачисления = &ПериодНачисления
		|	И бестИзменитьЧасыПиковойНагрузки.Организация = &Организация";
	
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ДокументОб = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
	КонецЦикла;
	
	Если ДокументОб = Неопределено Тогда
		ДокументОб 					= Документы.бестИзменитьЧасыПиковойНагрузки.СоздатьДокумент();
		ДокументОб.Организация 		= Организация;
		ДокументОб.ПериодНачисления = ПериодНачисления;
		ДокументОб.Дата				= ТекущаяДатаСеанса();
	Иначе
		ДокументОб.РазрезыПиковыхЧасов.Очистить();
		ДокументОб.ПиковыеЧасы.Очистить();
	КонецЕсли;
	
	Для каждого СтрокаУслуга из Услуги Цикл
		НовСтрРазрез 			= ДокументОб.РазрезыПиковыхЧасов.Добавить();
		НовСтрРазрез.Поставщик 	= СтрокаУслуга.Поставщик;
		НовСтрРазрез.Услуга 	= СтрокаУслуга.Услуга;
		НовСтрРазрез.IDСтроки 	= Новый УникальныйИдентификатор;
		
		Для каждого стр из ПиковыеЧасы Цикл
			НовСтрЧасы = ДокументОб.ПиковыеЧасы.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрЧасы, стр);
			НовСтрЧасы.IDСтроки = НовСтрРазрез.IDСтроки;
		КонецЦикла;
	КонецЦикла;
	
	ДокументОб.ФайлЗагрузки = Файл;
	Попытка
		ДокументОб.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ДокументОб.Записать(РежимЗаписиДокумента.Запись);
	КонецПопытки;
	
	СозданныйДокумент = ДокументОб.Ссылка;
КонецПроцедуры

#КонецОбласти
