// Добавляет строки начисления НП по формуле.
//
// Параметры:
//  ТЗДанныеСуточнойВедомости	-	ТаблицаЗначений.
//  ОписаниеУслуг				-	Массив.
//  Набор						-	РегистрНакопленияНаборЗаписей.бестОбъемНачисленийНП.
//  ПараметрыРасчета			-	Структура	-	см. бестНачисленияПовтИспНП.ТипыКоэффициентовВФормулахРасчета.
//
Процедура ДобавитьСтрокиНачисленияНППоФормуле(ТЗДанныеСуточнойВедомости, ОписаниеУслуг, Набор, ПараметрыРасчета)
	
	ТипыРасходов 									= энргНачисления.ТипыРасходовВФормулахРасчета();
	
	Для Каждого СтрокаФормулы Из ОписаниеУслуг Цикл			
		ТекФормулаОбъемУслуги	 					= СтрокаФормулы.ФормулаРасчета;
		
		Если Не ЗначениеЗаполнено(ТекФормулаОбъемУслуги) Тогда
			Продолжить;
		КонецЕсли;
		
		Отбор = Новый Структура();
		Отбор.Вставить("ОбъектРасчета",		СтрокаФормулы.ОбъектРасчета);
		Отбор.Вставить("УзелУчета",			СтрокаФормулы.ПриборУчета);
		Отбор.Вставить("ПериодНачисления",	СтрокаФормулы.ПериодНачисления);
		мТекСтрокДанныеСуточнойВедомости = ТЗДанныеСуточнойВедомости.НайтиСтроки(Отбор);
		
		Отбор.ПериодНачисления	= ДобавитьМесяц(СтрокаФормулы.ПериодНачисления, -1);
		мПредСтрокДанныеСуточнойВедомости = ТЗДанныеСуточнойВедомости.НайтиСтроки(Отбор);
		
		
		ТекФормулаОбъемУслугиПотребленный			= СтрокаФормулы.ФормулаРасчета;
		ПараметрыФормулы 							= СтрокаФормулы.ПараметрыФормулы;		
		ПараметрыРасчетаФормулы                     = СтрокаФормулы.ПараметрыРасчетаФормулы;
		
		Для Каждого стр Из мПредСтрокДанныеСуточнойВедомости Цикл
			КлючВидПараметра 					= XMLСтрока(стр.ВидПараметра); 
			КлючШкалы 							= XMLСтрока(стр.Шкала);
			Ключ 								= Новый Структура("ТипРасхода, Шкала, ВидПараметра", ТипыРасходов.РасходПоШкалеЗаПредПериод,КлючШкалы, КлючВидПараметра); 
			ТекФормулаОбъемУслуги 				= СтрЗаменить(ТекФормулаОбъемУслуги,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ОтформатироватьЧисловойПараметр(стр.ЗначениеПараметра));
			ТекФормулаОбъемУслугиПотребленный 	= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ОтформатироватьЧисловойПараметр(стр.ЗначениеПараметра));
			
			ПараметрыРасчетаФормулы.КолвоЧасовШтатнойРаботыПУПред = стр.ВНР;
		КонецЦикла;
		
		
		Для Каждого стр Из мТекСтрокДанныеСуточнойВедомости Цикл
			КлючВидПараметра 					= XMLСтрока(стр.ВидПараметра); 
			КлючШкалы 							= XMLСтрока(стр.Шкала);
			Ключ 								= Новый Структура("ТипРасхода, Шкала, ВидПараметра", ТипыРасходов.РасходИзмерителяПоШкале,КлючШкалы, КлючВидПараметра); 
			ТекФормулаОбъемУслуги 				= СтрЗаменить(ТекФормулаОбъемУслуги,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ОтформатироватьЧисловойПараметр(стр.ЗначениеПараметра));
			ТекФормулаОбъемУслугиПотребленный 	= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ОтформатироватьЧисловойПараметр(стр.ЗначениеПараметра));
			
			// Если не было данных за предыдущий период
			Ключ 								= Новый Структура("ТипРасхода, Шкала, ВидПараметра", ТипыРасходов.РасходПоШкалеЗаПредПериод,КлючШкалы, КлючВидПараметра); 
			ТекФормулаОбъемУслуги 				= СтрЗаменить(ТекФормулаОбъемУслуги,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",0);
			ТекФормулаОбъемУслугиПотребленный 	= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",0);
			// Если не было данных за предыдущий период
			
			Если ЗначениеЗаполнено(стр.ПлотностьПодающейСетевойВоды) Тогда
				ПараметрыРасчетаФормулы.ПлотностьПодающейСетевойВоды = стр.ПлотностьПодающейСетевойВоды;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(стр.ПлотностьОбратнойСетевойВоды) Тогда
				ПараметрыРасчетаФормулы.ПлотностьОбратнойСетевойВоды = стр.ПлотностьОбратнойСетевойВоды;
			КонецЕсли;
			
			ПараметрыРасчетаФормулы.КоличествоЧасовШтатнойРаботыПУ = стр.ВНР;
		КонецЦикла;
		
		
		
		//Для Каждого ПараметрФормулы Из НормативыПоУслугам Цикл			
		//	Ключ 									= Новый Структура("ТипРасхода, Услуга", ТипРасходаНорматив, XMLСтрока(ПараметрФормулы.Ключ));			
		//	ТекФормулаОбъемУслуги 					= СтрЗаменить(ТекФормулаОбъемУслуги,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ПараметрФормулы.Значение);
		//	ТекФормулаОбъемУслугиПотребленный 		= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ПараметрФормулы.Значение);
		//КонецЦикла;
		//
		//Ключ 									= ТипРасходаНормативНаПодогрев;	
		//ТекФормулаОбъемУслуги 					= СтрЗаменить(ТекФормулаОбъемУслуги,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ПараметрыРасчетаФормулы.НормативНаПодогрев);
		//ТекФормулаОбъемУслугиПотребленный 		= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ПараметрыРасчетаФормулы.НормативНаПодогрев);
		//
		//Ключ 									= ТипРасходаТемпературныйКоэффициентПоВоздуху;	
		//ТекФормулаОбъемУслуги 					= СтрЗаменить(ТекФормулаОбъемУслуги,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ПараметрыРасчетаФормулы.ТемпературныйКоэффициентПоВоздуху);
		//ТекФормулаОбъемУслугиПотребленный 		= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,"[" + ЗначениеВСтрокуВнутр(Ключ) + "]",ПараметрыРасчетаФормулы.ТемпературныйКоэффициентПоВоздуху);
		//
		//
		
		Для каждого КлючЗначение из ПараметрыРасчета Цикл
			ТекФормулаОбъемУслуги 					= СтрЗаменить(ТекФормулаОбъемУслуги,"[" + ЗначениеВСтрокуВнутр(КлючЗначение.Ключ) + "]",ОтформатироватьЧисловойПараметр(ПараметрыРасчетаФормулы[КлючЗначение.Ключ]));
			ТекФормулаОбъемУслугиПотребленный 		= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,"[" + ЗначениеВСтрокуВнутр(КлючЗначение.Ключ) + "]",ОтформатироватьЧисловойПараметр(ПараметрыРасчетаФормулы[КлючЗначение.Ключ]));	
		КонецЦикла;	
		
		Для каждого значениеПеречисления из Метаданные.Перечисления.энргСпособНачислений.ЗначенияПеречисления Цикл
			ТекФормулаОбъемУслуги 					= СтрЗаменить(ТекФормулаОбъемУслуги,"[" + ЗначениеВСтрокуВнутр(значениеПеречисления.Имя) + "]","Перечисления.энргСпособНачислений." + значениеПеречисления.Имя);
			ТекФормулаОбъемУслугиПотребленный 		= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,"[" + ЗначениеВСтрокуВнутр(значениеПеречисления.Имя) + "]","Перечисления.энргСпособНачислений." + значениеПеречисления.Имя);
		КонецЦикла;
		
		//ТекФормулаОбъемУслуги						= СтрЗаменить(ТекФормулаОбъемУслуги," ","");
		ТекФормулаОбъемУслуги						= СтрЗаменить(ТекФормулаОбъемУслуги,Символы.НПП,"");
		РезультатПоФормуламОбъемУслуги				= 0;
		ТекФормулаОбъемУслуги 						= СтрЗаменить(ТекФормулаОбъемУслуги,"[Результат] =","РезультатПоФормуламОбъемУслуги=");
		СпособНачисления = Неопределено;
		Выполнить ТекФормулаОбъемУслуги;
		
		//ТекФормулаОбъемУслугиПотребленный			= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный," ","");
		ТекФормулаОбъемУслугиПотребленный			= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,Символы.НПП,"");
		РезультатПоФормуламОбъемУслугиПотребленный	= 0;
		ТекФормулаОбъемУслугиПотребленный			= СтрЗаменить(ТекФормулаОбъемУслугиПотребленный,"[Результат] =","РезультатПоФормуламОбъемУслугиПотребленный=");
		Выполнить ТекФормулаОбъемУслугиПотребленный;
		
		//Если РезультатПоФормуламОбъемУслуги = 0 И РезультатПоФормуламОбъемУслугиПотребленный = 0 Тогда
		//	Продолжить;
		//КонецЕсли;
		
		СтрокаНабора 								= Набор.добавить();
		СтрокаНабора.Период 						= СтрокаФормулы.КонецПериода-1;
		СтрокаНабора.Организация 					= СтрокаФормулы.Организация;
		СтрокаНабора.Район 							= СтрокаФормулы.Район;
		СтрокаНабора.МКД 							= СтрокаФормулы.МКД;
		СтрокаНабора.ОбъектРасчета 					= СтрокаФормулы.ОбъектРасчета;
		СтрокаНабора.Услуга 						= СтрокаФормулы.Услуга;
		СтрокаНабора.ТочкаУчета 					= СтрокаФормулы.ТочкаУчета;
		СтрокаНабора.ВидНачисления 					= Перечисления.энргВидыНачислений.Начисление;
		СтрокаНабора.СпособНачисления 				= СпособНачисления;
		СтрокаНабора.ПриборУчета 					= СтрокаФормулы.ПриборУчета;
		СтрокаНабора.ТарифнаяЗона 					= Справочники.энргТарифныеЗоны.ПустаяСсылка();
		СтрокаНабора.Поставщик 						= СтрокаФормулы.Поставщик;
		СтрокаНабора.ПериодРасчета 					= СтрокаФормулы.ПериодНачисления;
		СтрокаНабора.ПериодНачисления 				= СтрокаФормулы.ПериодНачисления;
		СтрокаНабора.ОбъемУслуги 					= РезультатПоФормуламОбъемУслуги;		
		СтрокаНабора.ОбъемУслугиПотребленный 		= РезультатПоФормуламОбъемУслугиПотребленный;		
		СтрокаНабора.НачалоПериода 					= СтрокаФормулы.НачалоПериода;
		СтрокаНабора.КонецПериода 					= СтрокаФормулы.КонецПериода;
		СтрокаНабора.Регистратор 					= СтрокаФормулы.ДокументСсылка;
		СтрокаНабора.Договор						= СтрокаФормулы.Договор;
		ЗаполнитьЗначенияСвойств(СтрокаНабора, СтрокаФормулы);
	КонецЦикла;
	
КонецПроцедуры

// Снимает средние начисления НП.
//
// Параметры:
//  Организация				-	СправочникСсылка.Организации.
//  ПериодНачисления		-	Дата.
//  Район					-	СправочникСсылка.энргЗоныОтвественности.
//  МКД						-	СправочникСсылка.энргСтроения.
//  ИсключаяОтдельностоящие	-	Булево.
//  Договор					-	СправочникСсылка.энргДоговорыКонтрагентов.
//  Документ	-	ДокументСсылка.бестПерерасчетНП, ДокументСсылка.бестПерерасчетНПЭЭ.
//
Процедура СнятьСредниеНачисленияНП(Организация, ПериодНачисления,Район,МКД,ИсключаяОтдельностоящие,Договор,Документ) Экспорт
	
	перем ТекМКД,ДокументОбъект; 
	
	Если не ЗначениеЗаполнено(ПериодНачисления) или не ЗначениеЗаполнено(Район) тогда 
		Возврат;
	КонецЕсли;
	
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления);
	
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП;
	
	
	МВТ  											= Новый МенеджерВременныхТаблиц;
	ПрочитатьНеСписанныйСреднийНП(МВТ,ПериодНачисления,Организация,Район,МКД,ИсключаяОтдельностоящие,НачалоПериодаРасчета,КонецПериодаРасчета);	
	результатЗапроса 								= РезультатЗапросаПерерасчетСреднего(МВТ,Организация, ПериодНачисления, КонецПериодаРасчета-1,Район,МКД); 	
	
	
	УправлящаяВыборка								= РезультатЗапроса[0].выбрать(); 	
	Выборка 										= результатЗапроса[1].Выбрать();
	ВыборкаДокументыОтменить                        = РезультатЗапроса[2].выбрать();
	ЕстьСледующийВыборка 							= Выборка.Следующий();
	
	ВидОперации 									= Перечисления.бестВидыОпераций.Перерасчет_СвязанныйПерерасчет;
	Сч 												= 0;
	
	Набор 											= Неопределено;
	НаборНачисленныйСредний 						= Неопределено;
	НаборВыполненные 								= Неопределено;
	
	ВидНачисленияПерерасчет 						= Перечисления.энргВидыНачислений.Перерасчет;
	
	Пока ВыборкаДокументыОтменить.Следующий() Цикл
		ДокументОбъектОтменить					= ВыборкаДокументыОтменить.ДокументПерерасчета.ПолучитьОбъект();
		ДокументОбъектОтменить.УстановитьПометкуУдаления(Истина);
	КонецЦикла;
	
	Ошибки 											= "";
	
	Пока УправлящаяВыборка.следующий() цикл
		Если ТипЗнч(Документ) = Тип("Структура") И  Документ.Свойство("ОбъемНачислений") Тогда
			НаборНачисленныйСредний 				= Неопределено;
			НаборВыполненные 						= Неопределено;
			Набор 									= Документ.ОбъемНачислений;
		ИначеЕсли Документ = Неопределено тогда
			Если Не ТекМКД = УправлящаяВыборка.МКД тогда 				
				Если Не ТекМКД = Неопределено Тогда					
					Попытка
						Если ДокументОбъект<>Неопределено тогда
							ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьНаличиеПрисоединенныхФайлов", 	Истина);
							ДокументОбъект.ДополнительныеСвойства.Вставить("НеРегестрироватьВзаиморасчеты", 			Истина);
							ДокументОбъект.ДополнительныеСвойства.Вставить("ПроведениеРазрешено",						Истина);
							ДокументОбъект.ДополнительныеСвойства.Вставить("РегистрироватьПоказанияПУ", 				Ложь);
							ДокументОбъект.ДополнительныеСвойства.Вставить("РегистрироватьСтабильныеПериоды", 			Ложь);
							ДокументОбъект.записать(РежимЗаписиДокумента.Запись);										
						КонецЕсли;
						
						Набор.ДополнительныеСвойства.Вставить("Организация",				Организация);
						Набор.ДополнительныеСвойства.Вставить("Район",						Район);
						Набор.ДополнительныеСвойства.Вставить("ПериодНачисления",			ПериодНачисления);
						Набор.ДополнительныеСвойства.Вставить("МКД",						ТекМКД);
						Набор.ДополнительныеСвойства.Вставить("ДатаРегистратора",			КонецПериодаРасчета-1);
						Набор.ДополнительныеСвойства.Вставить("НаборНачисленныйСредний",	НаборНачисленныйСредний);
						Набор.Записать(Ложь);
						НаборНачисленныйСредний.Записать(Ложь);
						
						Если НЕ НаборВыполненные = Неопределено Тогда
							НаборВыполненные.Записать(НаборВыполненные.ДополнительныеСвойства.Замещать);
						КонецЕсли;
						
						ЗафиксироватьТранзакцию();
					Исключение
						ОтменитьТранзакцию();      		
						ИнформацияОбОшибке  					= ИнформацияОбОшибке();
						Ошибки 									= Ошибки +
						Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
					КонецПопытки;
				КонецЕсли;
				НачатьТранзакцию();
				ДокументСсылка 									= УправлящаяВыборка.ДокументПерерасчета;
				ПометкаУдаления 								= УправлящаяВыборка.ДокументПерерасчетаПометкаУдаления;
				ДокументОбъект  								= Неопределено;
				
				Если НЕ ЗначениеЗаполнено(ДокументСсылка)  Тогда
					ДокументСсылка 								= Документы.бестПерерасчетНП.ПолучитьСсылку(Новый УникальныйИдентификатор());
					ДокументОбъект  							= Документы.бестПерерасчетНП.СоздатьДокумент();
					ДокументОбъект.УстановитьСсылкуНового(ДокументСсылка);
					ДокументОбъект.район  						= Район;
					ДокументОбъект.МКД							= УправлящаяВыборка.МКД;
					ДокументОбъект.Дата							= КонецПериодаРасчета-1;
					ДокументОбъект.Организация 					= Организация;
					ДокументОбъект.ВидОперации 					= Перечисления.бестВидыОпераций.Перерасчет_СвязанныйПерерасчет;
					ДокументОбъект.ПериодНачисления 			= ПериодНачисления;
					ДокументОбъект.ПричинаПерерасчета 			= Справочники.бестПричиныПерерасчета.ПерерасчетСредних;					
				ИначеЕсли ПометкаУдаления Тогда
					ДокументОбъект  							= ДокументСсылка.ПолучитьОбъект();
					ДокументОбъект.ПометкаУдаления 				= Ложь;
				КонецЕсли;
				
				НаборНачисленныйСредний 								= РегистрыНакопления.бестНачисленныйСреднийОбъемНП.СоздатьНаборЗаписей();
				НаборНачисленныйСредний.Отбор.Регистратор.Установить(ДокументСсылка);
				Если ДокументОбъект = Неопределено Тогда
					НаборНачисленныйСредний.Прочитать();
					НаборНачисленныйСредний.Очистить();
				КонецЕсли;					
				
				Если ДокументОбъект = Неопределено Тогда
					НаборНачисленныйСредний.Записать();
				КонецЕсли;
				
				Набор											= РегистрыНакопления.бестОбъемНачисленийНП.СоздатьНаборЗаписей();
				Набор.Отбор.Регистратор.Установить(ДокументСсылка);				
				
				Набор.Прочитать();
				Набор.Очистить();
				
				Если ДокументОбъект = Неопределено Тогда
					Набор.Записать();
				КонецЕсли;
				
			КонецЕсли;
		иначе
			Если ДокументОбъект = Неопределено Тогда
				НачатьТранзакцию();
				ДокументСсылка									= Документ.Ссылка;
				ДокументОбъект 									= ДокументСсылка.ПолучитьОбъект();
				
				НаборНачисленныйСредний 						= РегистрыНакопления.бестНачисленныйСреднийОбъемНП.СоздатьНаборЗаписей();
				НаборНачисленныйСредний.Отбор.Регистратор.Установить(ДокументСсылка);
				НаборНачисленныйСредний.Очистить();
				
				Набор											= РегистрыНакопления.бестОбъемНачисленийНП.СоздатьНаборЗаписей();
				Набор.Отбор.Регистратор.Установить(ДокументСсылка);
				Набор.Очистить();
				
			КонецЕсли;
		КонецЕсли;	
		
		ОсталосьСписатьОбъем 									= УправлящаяВыборка.ОбъемНадоСписать;
		ОсталосьСписатьОбъемПотребленный						= УправлящаяВыборка.ОбъемПотребленныйНадоСписать;
		
		Пока УправлящаяВыборка.Район = Выборка.Район
			И УправлящаяВыборка.МКД = Выборка.МКД
			И УправлящаяВыборка.ТочкаУчета = Выборка.ТочкаУчета
			И УправлящаяВыборка.Услуга = Выборка.Услуга
			И УправлящаяВыборка.ОбъектРасчета = Выборка.ОбъектРасчета
			И УправлящаяВыборка.ПриборУчета = Выборка.ПриборУчета
			И УправлящаяВыборка.Шкала = Выборка.Шкала
			И УправлящаяВыборка.ТарифнаяЗона = Выборка.ТарифнаяЗона
			И УправлящаяВыборка.Поставщик = Выборка.Поставщик
			И ЕстьСледующийВыборка Цикл
			
			Если НЕ Выборка.ОбъемНадоСписать = 0 ИЛИ НЕ Выборка.ОбъемПотребленныйНадоСписать = 0 Тогда
				ЗначениеТарифа 									= Выборка.ЗначениеТарифа;			
				СтрокаНабора 									= НаборНачисленныйСредний.добавитьРасход();
				ЗаполнитьЗначенияСвойств(СтрокаНабора,Выборка);
				СтрокаНабора.Период 							= ГраницыПериода.ЗавершениеОП - 1;
				СтрокаНабора.Организация 						= Организация;
				СтрокаНабора.МКД								= МКД;
			КонецЕсли;
			
			//СписываемОбъем 									= Мин(ОсталосьСписатьОбъем, Выборка.ОбъемУслуги);
			//СписываемОбъемПотребленный						= Мин(ОсталосьСписатьОбъемПотребленный, Выборка.ОбъемУслугиПотребленный);
			//Если НЕ СписываемОбъем = 0 ИЛИ НЕ СписываемОбъемПотребленный = 0 Тогда
			
			СтрокаНабора 							= Набор.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаНабора,Выборка);
			СтрокаНабора.Период 						= ГраницыПериода.ЗавершениеОП - 1;
			СтрокаНабора.Организация 					= Организация;
			СтрокаНабора.ВидНачисления 					= ВидНачисленияПерерасчет;
			//СтрокаНабора.ОбъемУслуги 					= -СписываемОбъем;
			//СтрокаНабора.ОбъемУслугиПотребленный 		= -СписываемОбъемПотребленный;
			СтрокаНабора.Договор 						= Выборка.Договор;
			СтрокаНабора.ОбъемУслуги 					= -Выборка.ОбъемУслуги;
			СтрокаНабора.ОбъемУслугиПотребленный 		= -Выборка.ОбъемУслугиПотребленный;
			СтрокаНабора.ПериодРасчета					= ПериодНачисления;
			СтрокаНабора.ПериодНачисления				= Выборка.ПериодНачисления;
			СтрокаНабора.МКД							= МКД;
			
			СтрокаНабора.Сумма		 					= Выборка.ЗначениеТарифа*СтрокаНабора.ОбъемУслуги;				
			
			//ОсталосьСписатьОбъем 						= ОсталосьСписатьОбъем - СписываемОбъем;
			//ОсталосьСписатьОбъемПотребленный 			= ОсталосьСписатьОбъемПотребленный - СписываемОбъемПотребленный;	
			//КонецЕсли;			
			
			ЕстьСледующийВыборка  							= Выборка.Следующий();
		КонецЦикла; 		
		
		ТекМКД												= УправлящаяВыборка.МКД;
		Сч 													= Сч + 1;
	КонецЦикла;	
	
	Если Не ТекМКД = Неопределено И ТипЗнч(Документ) <> Тип("Структура") Тогда					
		Попытка
			Если ДокументОбъект<>Неопределено тогда
				ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьНаличиеПрисоединенныхФайлов", 	Истина);
				ДокументОбъект.ДополнительныеСвойства.Вставить("НеРегестрироватьВзаиморасчеты", 			Истина);
				ДокументОбъект.ДополнительныеСвойства.Вставить("ПроведениеРазрешено",						Истина);
				ДокументОбъект.ДополнительныеСвойства.Вставить("РегистрироватьПоказанияПУ", 				Ложь);
				ДокументОбъект.ДополнительныеСвойства.Вставить("РегистрироватьСтабильныеПериоды", 			Ложь);
				ДокументОбъект.записать(РежимЗаписиДокумента.Запись);										
			КонецЕсли;
			
			Если Набор.Количество() > 0 Тогда
				Набор.ДополнительныеСвойства.Вставить("Организация",		Организация);
				Набор.ДополнительныеСвойства.Вставить("Район",				Район);
				Набор.ДополнительныеСвойства.Вставить("ПериодНачисления",	ПериодНачисления);
				Набор.ДополнительныеСвойства.Вставить("МКД",				ТекМКД);
				Набор.ДополнительныеСвойства.Вставить("ДатаРегистратора",	КонецПериодаРасчета-1);
				НаборНачисленныйСредний.Записать(Ложь);
				
			КонецЕсли;			
			Набор.Записать(Ложь);
			Если НЕ НаборВыполненные = Неопределено Тогда
				НаборВыполненные.Записать(НаборВыполненные.ДополнительныеСвойства.Замещать);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ИнформацияОбОшибке  					= ИнформацияОбОшибке();
			Ошибки 									= Ошибки +
			Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		КонецПопытки;
	КонецЕсли;  
	
	Если Не ПустаяСтрока(Ошибки) Тогда
		ВызватьИсключение Ошибки;
	КонецЕсли;
	
КонецПроцедуры

// Снимает средние начисления НПЭЭ.
//
// Параметры:
//  Организация				-	СправочникСсылка.Организации.
//  ПериодНачисления		-	Дата.
//  Район					-	СправочникСсылка.энргЗоныОтвественности.
//  МКД						-	СправочникСсылка.энргСтроения.
//  ИсключаяОтдельностоящие	-	Булево.
//  Документ				-	ДокументСсылка.бестПерерасчетНП, ДокументСсылка.бестПерерасчетНПЭЭ.
//
Процедура СнятьСредниеНачисленияНПЭЭ(Организация, ПериодНачисления,Район,МКД,ИсключаяОтдельностоящие,Документ) Экспорт
	
	перем ТекМКД,ДокументОбъект; 
	
	Если не ЗначениеЗаполнено(ПериодНачисления) или не ЗначениеЗаполнено(Район) тогда 
		Возврат;
	КонецЕсли;
	
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления);
	
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП;
	
	
	МВТ  											= Новый МенеджерВременныхТаблиц;
	РезультатЗапроса 								= ПрочитатьНеСписанныйСреднийЭЭ(МВТ,ПериодНачисления,Организация,Район,МКД,ИсключаяОтдельностоящие,НачалоПериодаРасчета,КонецПериодаРасчета);		
	
		
	Выборка 										= результатЗапроса[РезультатЗапроса.Количество() - 2].Выбрать();
	ВыборкаДокументыОтменить                        = РезультатЗапроса[РезультатЗапроса.Количество() - 1].выбрать();
	
	Набор 											= Неопределено;
	НаборНачисленныйСредний 						= Неопределено;
	
	Пока ВыборкаДокументыОтменить.Следующий() Цикл
		ДокументОбъектОтменить					= ВыборкаДокументыОтменить.ДокументПерерасчета.ПолучитьОбъект();
		ДокументОбъектОтменить.УстановитьПометкуУдаления(Истина);
	КонецЦикла;
	
	Ошибки 											= "";
	
	Пока Выборка.следующий() цикл
		Если Документ = Неопределено тогда
			Если Не ТекМКД = Выборка.МКД тогда 				
				Если Не ТекМКД = Неопределено Тогда					
					Попытка
						Если ДокументОбъект<>Неопределено тогда
							ДокументОбъект.записать(РежимЗаписиДокумента.Запись);										
						КонецЕсли;
						
						Набор.Записать(Ложь);
						НаборНачисленныйСредний.Записать(Ложь);
						
						ЗафиксироватьТранзакцию();
					Исключение
						ОтменитьТранзакцию();      		
						ИнформацияОбОшибке  					= ИнформацияОбОшибке();
						Ошибки 									= Ошибки +
						Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
					КонецПопытки;
				КонецЕсли;
				НачатьТранзакцию();
				ДокументСсылка 									= Выборка.ДокументПерерасчета;
				ПометкаУдаления 								= Выборка.ДокументПерерасчетаПометкаУдаления;
				ДокументОбъект  								= Неопределено;
				
				Если НЕ ЗначениеЗаполнено(ДокументСсылка)  Тогда
					ДокументСсылка 								= Документы.бестПерерасчетЭЭ.ПолучитьСсылку(Новый УникальныйИдентификатор());
					ДокументОбъект  							= Документы.бестПерерасчетЭЭ.СоздатьДокумент();
					ДокументОбъект.УстановитьСсылкуНового(ДокументСсылка);
					ДокументОбъект.район  						= Район;
					ДокументОбъект.МКД							= Выборка.МКД;
					ДокументОбъект.Дата							= КонецПериодаРасчета-1;
					ДокументОбъект.Организация 					= Организация;
					ДокументОбъект.ВидОперации 					= Перечисления.бестВидыОпераций.ПерерасчетЭЭ_СвязанныйПерерасчет;
					ДокументОбъект.ПериодНачисления 			= ПериодНачисления;					
				ИначеЕсли ПометкаУдаления Тогда
					ДокументОбъект  							= ДокументСсылка.ПолучитьОбъект();
					ДокументОбъект.ПометкаУдаления 				= Ложь;
				КонецЕсли;
				
				НаборНачисленныйСредний 								= РегистрыНакопления.бестНачисленныйСреднийОбъемЭЭ.СоздатьНаборЗаписей();
				НаборНачисленныйСредний.Отбор.Регистратор.Установить(ДокументСсылка);
				Если ДокументОбъект = Неопределено Тогда
					НаборНачисленныйСредний.Прочитать();
					НаборНачисленныйСредний.Очистить();
				КонецЕсли;					
				
				Если ДокументОбъект = Неопределено Тогда
					НаборНачисленныйСредний.Записать();
				КонецЕсли;
				
				Набор											= РегистрыНакопления.бестОбъемНачисленийЭлектроэнергии.СоздатьНаборЗаписей();
				Набор.Отбор.Регистратор.Установить(ДокументСсылка);				
				
				Набор.Прочитать();
				Набор.Очистить();
				
				Если ДокументОбъект = Неопределено Тогда
					Набор.Записать();
				КонецЕсли;
				
			КонецЕсли;
		Иначе
			Если ДокументОбъект = Неопределено Тогда
				НачатьТранзакцию();
				ДокументСсылка									= Документ.Ссылка;
				ДокументОбъект 									= ДокументСсылка.ПолучитьОбъект();
				
				НаборНачисленныйСредний 						= РегистрыНакопления.бестНачисленныйСреднийОбъемЭЭ.СоздатьНаборЗаписей();
				НаборНачисленныйСредний.Отбор.Регистратор.Установить(ДокументСсылка);
				НаборНачисленныйСредний.Очистить();
				
				Набор											= РегистрыНакопления.бестОбъемНачисленийЭлектроэнергии.СоздатьНаборЗаписей();
				Набор.Отбор.Регистратор.Установить(ДокументСсылка);
				Набор.Очистить();
				
			КонецЕсли;
		КонецЕсли;	
		
				
		СтрокаНабора 									= НаборНачисленныйСредний.добавитьРасход();
		ЗаполнитьЗначенияСвойств(СтрокаНабора,Выборка);
		СтрокаНабора.Период 							= ГраницыПериода.ЗавершениеОП - 1;
		
		
		СтрокаНабора 								= Набор.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНабора,Выборка);
		СтрокаНабора.Период 						= ГраницыПериода.ЗавершениеОП - 1;
		СтрокаНабора.ВидНачисления 					= Перечисления.энргВидыНачислений.Перерасчет;
		СтрокаНабора.ПериодРасчета					= ПериодНачисления;
		СтрокаНабора.ОбъемУслуги 					= -Выборка.ОбъемУслуги;
		СтрокаНабора.СуммаСредневзвешенная 			= -Выборка.СуммаСредневзвешенная;
		СтрокаНабора.СуммаЗаСбытовуюНадбавку 		= -Выборка.СуммаЗаСбытовуюНадбавку;
		СтрокаНабора.СуммаЗаУслугиПоПередачи 		= -Выборка.СуммаЗаУслугиПоПередачи;
		СтрокаНабора.СуммаЗаИныеУслуги 				= -Выборка.СуммаЗаИныеУслуги;
		СтрокаНабора.Сумма				 			= -Выборка.Сумма;
		СтрокаНабора.СуммаСредневзвешеннаяНДС 		= -Выборка.СуммаСредневзвешеннаяНДС;
		СтрокаНабора.СуммаЗаСбытовуюНадбавкуНДС 	= -Выборка.СуммаЗаСбытовуюНадбавкуНДС;
		СтрокаНабора.СуммаЗаУслугиПоПередачиНДС 	= -Выборка.СуммаЗаУслугиПоПередачиНДС;
		СтрокаНабора.СуммаЗаИныеУслугиНДС 			= -Выборка.СуммаЗаИныеУслугиНДС;
		СтрокаНабора.СуммаНДС 						= -Выборка.СуммаНДС;
			
		ТекМКД										= Выборка.МКД;
	КонецЦикла;	
	
	Если Не ТекМКД = Неопределено И ТипЗнч(Документ) <> Тип("Структура") Тогда					
		Попытка
			Если ДокументОбъект<>Неопределено тогда
				ДокументОбъект.записать(РежимЗаписиДокумента.Запись);										
			КонецЕсли;
			
			Если Набор.Количество() > 0 Тогда
				НаборНачисленныйСредний.Записать(Ложь);	
			КонецЕсли;			
			Набор.Записать(Ложь);
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ИнформацияОбОшибке  					= ИнформацияОбОшибке();
			Ошибки 									= Ошибки +
			Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		КонецПопытки;
	КонецЕсли;  
	
	Если Не ПустаяСтрока(Ошибки) Тогда
		ВызватьИсключение Ошибки;
	КонецЕсли;
	
КонецПроцедуры

// Отменяет закрытие периода.
//
// Параметры:
//  Организация			-	СправочникСсылка.Организации.
//  ПериодНачисления	-	Дата.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  МКД					-	СправочникСсылка.энргСтроения.
//
Процедура ОтменитьЗакрытьПериода(Организация, ПериодНачисления,Район,МКД) Экспорт 
	
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления);
	
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП-1;
	ДнейВПериоде  									= ГраницыПериода.ДнейВПериоде; 
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("НачалоПериода",		НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("КонецПериода",		КонецПериодаРасчета);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Текст 	="ВЫБРАТЬ
	|	энргНачисление.Ссылка
	|ИЗ
	|	Документ.энргНачисление КАК энргНачисление
	|ГДЕ
	|	энргНачисление.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И энргНачисление.МКД = &МКД
	|	И энргНачисление.Район = &Район
	|	И энргНачисление.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргНачислениеМКД.Ссылка
	|ИЗ
	|	Документ.энргНачислениеМКД КАК энргНачислениеМКД
	|ГДЕ
	|	энргНачислениеМКД.Район = &Район
	|	И энргНачислениеМКД.Проведен
	|	И энргНачислениеМКД.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргПерерасчет.Ссылка
	|ИЗ
	|	Документ.энргПерерасчет КАК энргПерерасчет
	|ГДЕ
	|	энргПерерасчет.Проведен
	|	И энргПерерасчет.Район = &Район
	|	И энргПерерасчет.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И энргПерерасчет.МКД = &МКД
	|	И энргПерерасчет.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_КорректировкаПоказаний)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргЗакрытиеПериода.Ссылка
	|ИЗ
	|	Документ.энргЗакрытиеПериода КАК энргЗакрытиеПериода
	|ГДЕ
	|	энргЗакрытиеПериода.Проведен
	|	И энргЗакрытиеПериода.Район = &Район
	|	И энргЗакрытиеПериода.ПериодНачисления = &ПериодНачисления";
	
	Если МКД = Неопределено тогда
		Текст 			= СтрЗаменить(Текст,"И энргНачисление.МКД = &МКД","");
		Текст			= СтрЗаменить(Текст,"И энргПерерасчет.МКД = &МКД","");
	иначе
		Запрос.УстановитьПараметр("МКД",МКД);
	КонецЕсли;
	
	Запрос.Текст 		= Текст;
	Результат  			= Запрос.Выполнить();
	Выборка 			= Результат.Выбрать();
	Пока Выборка.Следующий() цикл  		
		ДокОбъект  		= Выборка.ссылка.получитьОбъект();
		ДокОбъект.ДополнительныеСвойства.вставить("ПроведениеРазрешено",истина);
		ДокОбъект.УстановитьПометкуУдаления(Истина);		
	КонецЦикла; 
	
КонецПроцедуры

// Закрывает период для редактирования.
//
// Параметры:
//  ПериодНачисления	-	Дата.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  МКД					-	СправочникСсылка.энргСтроения.
//
Процедура ЗакрытьПериодДляРедактирования(ПериодНачисления,Район,МКД) Экспорт  
	
	Если МКД <> Неопределено тогда
		Возврат;
	КонецЕсли;
	
	ДокуметЗакрытия 				= ДокуметЗакрытияПериода(ПериодНачисления,Район);
	
	Если не ЗначениеЗаполнено(ДокуметЗакрытия) тогда
		ДокументОбъект 				= Документы.энргЗакрытиеПериода.СоздатьДокумент();		
	иначе
		ДокументОбъект 				= ДокуметЗакрытия.ПолучитьОбъект();  
	КонецЕсли;
	
	ДокументОбъект.ДополнительныеСвойства.вставить("ПроведениеРазрешено",Истина);
	ДокументОбъект.Район 			= Район;
	ДокументОбъект.ПериодНачисления = ПериодНачисления;
	ДокументОбъект.записать(РежимЗаписиДокумента.Проведение);	
	
КонецПроцедуры

// Начисления по схемам структуры сети
//
// Параметры:
//  Организация				-	СправочникСсылка.Организации.
//  ПериодНачисления		-	Дата.
//  Район					-	СправочникСсылка.энргЗоныОтвественности.
//  МКД						-	СправочникСсылка.энргСтроения.
//  ИсключаяОтдельностоящие	-	Булево.
//  Договор					-	СправочникСсылка.энргДоговорыКонтрагентов.
//  Документ				-	ДокументСсылка.бестНачислениеПоСхемамСтруктурыСети
//
Процедура НачисленияПоСхемамСтруктурыСети(Организация,ПериодНачисления,Район,МКД,ИсключаяОтдельностоящие, Договор,Документ) Экспорт
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления,Ложь);
	СпособНачисленияПоПриборам						= Перечисления.энргСпособНачислений.ПоПриборам;
	
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП;
	
	РезультатЗапроса 								= ПолучитьРезультатЗапросаСхемыСтруктурыСети(ПериодНачисления,Организация,Район,ИсключаяОтдельностоящие, МКД,НачалоПериодаРасчета,КонецПериодаРасчета);
	
	
	ВыборкаДетальныеЗаписи 							= РезультатЗапроса.Выбрать();
	
	ТекСтруктура 									= Неопределено;
	ТекУслуга                                       = Неопределено;
	ТекМКД 										= Неопределено;
	НаборЗаписей 									= Неопределено;
	ДокументОбъект 									= Неопределено;
	СтрокаНабора 									= Неопределено;
	ТекСтавкаНДС 									= Неопределено;
	ТекНДСВнутри 									= Неопределено;
	ТекЗначениеТарифа 								= Неопределено;
	
	ОбъемыРассчитанныхСтруктур 						= Новый Соответствие;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если (ТекСтруктура <> ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент ИЛИ ТекУслуга <> ВыборкаДетальныеЗаписи.Услуга) и СтрокаНабора <> Неопределено Тогда
			СтрокаНабора.ОбъемУслуги = ОбъемыРассчитанныхСтруктур[ТекСтруктура][ТекУслуга];
			Если ЗначениеЗаполнено(ТекЗначениеТарифа) и ЗначениеЗаполнено(ТекСтавкаНДС) Тогда
				Если ТекНДСВнутри Тогда 
					СтрокаНабора.Сумма 		= СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа - СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа * ТекСтавкаНДС / (100 + ТекСтавкаНДС);
					СтрокаНабора.СуммаНДС 	= СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа * ТекСтавкаНДС / (100 + ТекСтавкаНДС);
				Иначе 
					СтрокаНабора.Сумма 		= СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа;
					СтрокаНабора.СуммаНДС 	= СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа * ТекСтавкаНДС / 100
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ТекМКД = ВыборкаДетальныеЗаписи.МКД Тогда
			
			Если Не НаборЗаписей = Неопределено и НаборЗаписей.Количество() > 0 Тогда
				
				НачатьТранзакцию();
				
				НаборОтложенныхДвижений	= РегистрыСведений.бестОтложенныеДвиженияДокументовНП.СоздатьНаборЗаписей();
				НаборОтложенныхДвижений.Отбор.Организация.Установить(Организация);
				НаборОтложенныхДвижений.Отбор.ПериодНачисления.Установить(ПериодНачисления);
				НаборОтложенныхДвижений.Отбор.Район.Установить(Район);
				НаборОтложенныхДвижений.Отбор.РазделЗаписи.Установить(Перечисления.бестРазделыЗаписиНП.НачисленияПоДолевымСхемам);
				НаборОтложенныхДвижений.Отбор.МКД.Установить(ТекМКД);
				
				НаборОтложенныхДвижений.Записать();					
				
				НаборЗаписей.ДополнительныеСвойства.Вставить("Организация", 		Организация);
				НаборЗаписей.ДополнительныеСвойства.Вставить("Район",  				Район);
				НаборЗаписей.ДополнительныеСвойства.Вставить("МКД",    				ТекМКД);
				НаборЗаписей.ДополнительныеСвойства.Вставить("ДатаРегистратора",	ГраницыПериода.ЗавершениеОП-1);
				НаборЗаписей.Записать();
				
				Если Не ДокументОбъект = Неопределено Тогда
					ДокументОбъект.ДополнительныеСвойства.Вставить("ПроведениеРазрешено",Истина);
					ДокументОбъект.записать(РежимЗаписиДокумента.Запись);
				КонецЕсли; 					
				ЗафиксироватьТранзакцию();
			КонецЕсли;
			
			ДокументСсылка 							= ВыборкаДетальныеЗаписи.ДокументНачисления;			
			
			Если НЕ ЗначениеЗаполнено(ДокументСсылка) Тогда			
				ДокументСсылка 						= Документы.бестНачислениеПоСхемамСтруктурыСети.ПолучитьСсылку(Новый УникальныйИдентификатор());
				ДокументОбъект 						= Документы.бестНачислениеПоСхемамСтруктурыСети.СоздатьДокумент();
				ДокументОбъект.Район 				= Район;
				ДокументОбъект.МКД 					= ВыборкаДетальныеЗаписи.МКД;
				ДокументОбъект.Дата 				= ГраницыПериода.ЗавершениеОП-1;
				ДокументОбъект.Организация			= Организация;
				ДокументОбъект.ПериодНачисления     = ПериодНачисления;
				ДокументОбъект.УстановитьСсылкуНового(ДокументСсылка);	
				
			Иначе
				ДокументОбъект 						= ДокументСсылка.ПолучитьОбъект();
				ДокументОбъект.ПометкаУдаления 		= Ложь;
				
				НаборЗаписей 						= РегистрыНакопления.бестОбъемНачисленийНП.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
				НаборЗаписей.Записать(); // очищаем набор записей				
			КонецЕсли;
			
			НаборЗаписей 							= РегистрыНакопления.бестОбъемНачисленийНП.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
			
		КонецЕсли;
		
		
		Если  ТекСтруктура <> ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент Тогда
			
			
			ОбъемУжеРассчитанныхЭлементов 	= ОбъемыРассчитанныхСтруктур.Получить(ВыборкаДетальныеЗаписи.СтруктураСетиУчаствующаяВСхеме);
			Если ОбъемУжеРассчитанныхЭлементов <> Неопределено Тогда
				ОбъемУжеРассчитанныхЭлементовУслуга = ОбъемУжеРассчитанныхЭлементов.Получить(ВыборкаДетальныеЗаписи.Услуга);
				Если ОбъемУжеРассчитанныхЭлементовУслуга <> Неопределено Тогда
					Объем  						= ?(ВыборкаДетальныеЗаписи.ВычитатьЭлемент, -ОбъемУжеРассчитанныхЭлементовУслуга, ОбъемУжеРассчитанныхЭлементовУслуга);
				Иначе
					Объем = ВыборкаДетальныеЗаписи.ОбъемУслуги;
				КонецЕсли;
			Иначе
				Объем = ВыборкаДетальныеЗаписи.ОбъемУслуги;
			КонецЕсли;
			ОбъемыРассчитанныхСтруктурУслуга = Новый Соответствие;
			ОбъемыРассчитанныхСтруктурУслуга.Вставить(ВыборкаДетальныеЗаписи.Услуга, Объем);
			ОбъемыРассчитанныхСтруктур.Вставить(ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент, ОбъемыРассчитанныхСтруктурУслуга);
			СтрокаНабора 		= НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи);
			СтрокаНабора.Период = КонецПериодаРасчета - 1;
			
		ИначеЕсли ТекУслуга <> ВыборкаДетальныеЗаписи.Услуга Тогда
			
			ОбъемУжеРассчитанныхЭлементов 	= ОбъемыРассчитанныхСтруктур.Получить(ВыборкаДетальныеЗаписи.СтруктураСетиУчаствующаяВСхеме);
			Если ОбъемУжеРассчитанныхЭлементов <> Неопределено Тогда
				ОбъемУжеРассчитанныхЭлементовУслуга = ОбъемУжеРассчитанныхЭлементов.Получить(ВыборкаДетальныеЗаписи.Услуга);
				Если ОбъемУжеРассчитанныхЭлементовУслуга <> Неопределено Тогда
					Объем  						= ?(ВыборкаДетальныеЗаписи.ВычитатьЭлемент, -ОбъемУжеРассчитанныхЭлементовУслуга, ОбъемУжеРассчитанныхЭлементовУслуга);
				Иначе
					Объем = ВыборкаДетальныеЗаписи.ОбъемУслуги;
				КонецЕсли;
			Иначе
				Объем = ВыборкаДетальныеЗаписи.ОбъемУслуги;
			КонецЕсли;
			ОбъемыРассчитанныхСтруктур[ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент].Вставить(ВыборкаДетальныеЗаписи.Услуга, Объем);
			СтрокаНабора 		= НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи);
			СтрокаНабора.Период = КонецПериодаРасчета - 1;
			
		Иначе
			
			ОбъемУжеРассчитанныхЭлементов = ОбъемыРассчитанныхСтруктур.Получить(ВыборкаДетальныеЗаписи.СтруктураСетиУчаствующаяВСхеме);
			Если ОбъемУжеРассчитанныхЭлементов <> Неопределено Тогда
				ОбъемУжеРассчитанныхЭлементовУслуга = ОбъемУжеРассчитанныхЭлементов.Получить(ВыборкаДетальныеЗаписи.Услуга);
				Если ОбъемУжеРассчитанныхЭлементовУслуга <> Неопределено Тогда
					ОбъемыРассчитанныхСтруктур[ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент][ВыборкаДетальныеЗаписи.Услуга]  = ОбъемыРассчитанныхСтруктур[ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент][ВыборкаДетальныеЗаписи.Услуга] + ?(ВыборкаДетальныеЗаписи.ВычитатьЭлемент, -ОбъемУжеРассчитанныхЭлементовУслуга, ОбъемУжеРассчитанныхЭлементовУслуга);
				Иначе
					ОбъемыРассчитанныхСтруктур[ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент][ВыборкаДетальныеЗаписи.Услуга]  = ОбъемыРассчитанныхСтруктур[ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент][ВыборкаДетальныеЗаписи.Услуга] + ВыборкаДетальныеЗаписи.ОбъемУслуги;
				КонецЕсли;	
			Иначе
				ОбъемыРассчитанныхСтруктур[ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент][ВыборкаДетальныеЗаписи.Услуга]  = ОбъемыРассчитанныхСтруктур[ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент][ВыборкаДетальныеЗаписи.Услуга] + ВыборкаДетальныеЗаписи.ОбъемУслуги;
			КонецЕсли;
		КонецЕсли;
		
		ТекМКД 				= ВыборкаДетальныеЗаписи.МКД;
		ТекСтруктура 		= ВыборкаДетальныеЗаписи.РассчитываемыйЭлемент;
		ТекУслуга			= ВыборкаДетальныеЗаписи.Услуга;
		ТекСтавкаНДС 		= ВыборкаДетальныеЗаписи.СтавкаНДС;
		ТекНДСВнутри 		= ВыборкаДетальныеЗаписи.НДСВнутри;
		ТекЗначениеТарифа   = ВыборкаДетальныеЗаписи.ЗначениеТарифа;
	КонецЦикла;
	
	Если Не НаборЗаписей = Неопределено и НаборЗаписей.Количество() > 0 Тогда
		Если СтрокаНабора <> Неопределено Тогда
			СтрокаНабора.ОбъемУслуги = ОбъемыРассчитанныхСтруктур[ТекСтруктура][ТекУслуга];
			Если ЗначениеЗаполнено(ТекЗначениеТарифа) и ЗначениеЗаполнено(ТекСтавкаНДС) Тогда
				Если ТекНДСВнутри Тогда 
					СтрокаНабора.Сумма 		= СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа - СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа * ТекСтавкаНДС / (100 + ТекСтавкаНДС);
					СтрокаНабора.СуммаНДС 	= СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа * ТекСтавкаНДС / (100 + ТекСтавкаНДС);
				Иначе 
					СтрокаНабора.Сумма 		= СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа;
					СтрокаНабора.СуммаНДС 	= СтрокаНабора.ОбъемУслуги * ТекЗначениеТарифа * ТекСтавкаНДС / 100
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		НачатьТранзакцию();
		
		НаборОтложенныхДвижений	= РегистрыСведений.бестОтложенныеДвиженияДокументовНП.СоздатьНаборЗаписей();
		НаборОтложенныхДвижений.Отбор.Организация.Установить(Организация);
		НаборОтложенныхДвижений.Отбор.ПериодНачисления.Установить(ПериодНачисления);
		НаборОтложенныхДвижений.Отбор.Район.Установить(Район);
		НаборОтложенныхДвижений.Отбор.РазделЗаписи.Установить(Перечисления.бестРазделыЗаписиНП.НачисленияПоДолевымСхемам);
		НаборОтложенныхДвижений.Отбор.МКД.Установить(ТекМКД);
		
		НаборОтложенныхДвижений.Записать();					
		
		НаборЗаписей.ДополнительныеСвойства.Вставить("Организация", 		Организация);
		НаборЗаписей.ДополнительныеСвойства.Вставить("Район",  				Район);
		НаборЗаписей.ДополнительныеСвойства.Вставить("МКД", 	   			ТекМКД);
		НаборЗаписей.ДополнительныеСвойства.Вставить("ДатаРегистратора",	ГраницыПериода.ЗавершениеОП-1);
		НаборЗаписей.Записать();
		
		Если Не ДокументОбъект = Неопределено Тогда
			ДокументОбъект.ДополнительныеСвойства.Вставить("ПроведениеРазрешено",Истина);
			ДокументОбъект.записать(РежимЗаписиДокумента.Запись);
		КонецЕсли; 					
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
КонецПроцедуры

// Выполняет дополнительные начисления ЮЛ.
//
// Параметры:
//  Организация				-	СправочникСсылка.Организации.
//  ПериодНачисления		-	Дата.
//  Район					-	СправочникСсылка.энргЗоныОтвественности.
//  МКД						-	СправочникСсылка.энргСтроения.
//  ИсключаяОтдельностоящие	-	Булево.
//  Договор					-	СправочникСсылка.энргДоговорыКонтрагентов.
//  Документ				-	ДокументСсылка.бестДополнительныеНачисления.
//
Процедура ДополнительныеНачисленияЮЛ(Организация,ПериодНачисления,Район,МКД,ИсключаяОтдельностоящие, Договор,Документ) Экспорт
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления,Ложь);
	СпособНачисленияПоПриборам						= Перечисления.энргСпособНачислений.ПоПриборам;
	
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП;
	
	РезультатЗапроса 								= ПолучитьРезультатЗапросаДополнительныеНачисленияЮЛ(ПериодНачисления,Организация,Район,ИсключаяОтдельностоящие, МКД,НачалоПериодаРасчета,КонецПериодаРасчета);
	
	
	ВыборкаДетальныеЗаписи 		= РезультатЗапроса[4].Выбрать();
	ВыборкаПометитьНаУдаление	= РезультатЗапроса[5].Выбрать();
	
	ТекМКД	 										= Неопределено;
	НаборЗаписей 									= Неопределено;
	ДокументОбъект 									= Неопределено;
	
	Пока ВыборкаПометитьНаУдаление.Следующий() Цикл
		ДокументСсылка 						= ВыборкаПометитьНаУдаление.ДокументНачисления;
		ДокументОбъект 						= ДокументСсылка.ПолучитьОбъект();
		ДокументОбъект.ПометкаУдаления 		= Истина;
		ДокументОбъект.Записать();
	КонецЦикла;	
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если НЕ ТекМКД = ВыборкаДетальныеЗаписи.МКД Тогда
			
			Если Не НаборЗаписей = Неопределено и НаборЗаписей.Количество() > 0 Тогда
				
				НачатьТранзакцию();
				
				
				НаборЗаписей.ДополнительныеСвойства.Вставить("Организация", 		Организация);
				НаборЗаписей.ДополнительныеСвойства.Вставить("Район",  				Район);
				НаборЗаписей.ДополнительныеСвойства.Вставить("МКД",    				ТекМКД);
				НаборЗаписей.ДополнительныеСвойства.Вставить("ДатаРегистратора",	ГраницыПериода.ЗавершениеОП-1);
				НаборЗаписей.Записать();
				
				Если Не ДокументОбъект = Неопределено Тогда
					ДокументОбъект.ДополнительныеСвойства.Вставить("ПроведениеРазрешено",Истина);
					ДокументОбъект.записать(РежимЗаписиДокумента.Запись);
				КонецЕсли; 					
				ЗафиксироватьТранзакцию();
			КонецЕсли;
			
			ДокументСсылка 							= ВыборкаДетальныеЗаписи.ДокументНачисления;			
			
			Если НЕ ЗначениеЗаполнено(ДокументСсылка) Тогда			
				ДокументСсылка 						= Документы.бестДополнительныеНачисления.ПолучитьСсылку(Новый УникальныйИдентификатор());
				ДокументОбъект 						= Документы.бестДополнительныеНачисления.СоздатьДокумент();
				ДокументОбъект.Район 				= Район;
				ДокументОбъект.МКД	 				= ВыборкаДетальныеЗаписи.МКД;
				ДокументОбъект.Дата 				= ГраницыПериода.ЗавершениеОП-1;
				ДокументОбъект.Организация			= Организация;
				ДокументОбъект.УстановитьСсылкуНового(ДокументСсылка);	
				
			Иначе
				ДокументОбъект 						= ДокументСсылка.ПолучитьОбъект();
				ДокументОбъект.ПометкаУдаления 		= Ложь;
				
				НаборЗаписей 						= РегистрыНакопления.бестОбъемНачисленийНП.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
				НаборЗаписей.Записать(); // очищаем набор записей				
			КонецЕсли;
			
			НаборЗаписей 							= РегистрыНакопления.бестОбъемНачисленийНП.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
			
		КонецЕсли;
		
		СтрокаНабора 		= НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи);
		СтрокаНабора.Период = ГраницыПериода.ЗавершениеОП-1;
		
		ТекМКД 			= ВыборкаДетальныеЗаписи.МКД;
		
	КонецЦикла;
	
	
	Если Не НаборЗаписей = Неопределено и НаборЗаписей.Количество() > 0 Тогда
		НачатьТранзакцию();					
		
		НаборЗаписей.ДополнительныеСвойства.Вставить("Организация", 		Организация);
		НаборЗаписей.ДополнительныеСвойства.Вставить("Район",  				Район);
		НаборЗаписей.ДополнительныеСвойства.Вставить("МКД",    				ТекМКД);
		НаборЗаписей.ДополнительныеСвойства.Вставить("ДатаРегистратора",	ГраницыПериода.ЗавершениеОП-1);
		НаборЗаписей.Записать();
		
		Если Не ДокументОбъект = Неопределено Тогда
			ДокументОбъект.ДополнительныеСвойства.Вставить("ПроведениеРазрешено",Истина);
			ДокументОбъект.записать(РежимЗаписиДокумента.Запись);
		КонецЕсли; 					
		ЗафиксироватьТранзакцию();
	КонецЕсли;
КонецПроцедуры

// Выполняет начисления по электроэнергии.
//
// Параметры:
//  МВТ				-	МенеджерВременныхТаблиц.
//  ГраницыПериода	-	Дата.
//
Процедура НачисленияПоЭлектроэнергии(МВТ,ГраницыПериода) Экспорт
	
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП;
	ДнейВПериоде  									= ГраницыПериода.ДнейВПериоде;
	ДатаРегистратора 								= КонецПериодаРасчета - 1;
	
	ТекМКД	 										= Неопределено;
	НаборЗаписей 									= Неопределено;
	НаборПочасовыхЗаписей 							= Неопределено;
	ДокументОбъект 									= Неопределено;
	ДокументСсылка									= Неопределено;
	
	РезультатЗапроса 								= РезультатЗапросаНачислениеПоЭлектроэнергии(МВТ, НачалоПериодаРасчета, КонецПериодаРасчета);
	
	
	// Область почасовых объемов 
	РезультатЗапросаПочасовыеЗначения 	= РезультатЗапросаПочасовыеЗначения(МВТ);
	ВыборкаПочасовыеЗначения 	= РезультатЗапросаПочасовыеЗначения.Выбрать();
	ВыборкаПочасовыеЗначения.Следующий();
	// Область почасовых объемов 
	
	ВыборкаДетальныеЗаписи 		= РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если Не ТекМКД = ВыборкаДетальныеЗаписи.МКД Тогда
			
			Если Не НаборЗаписей = Неопределено И НаборЗаписей.Количество() > 0 Тогда
				
				НачатьТранзакцию();
				
				НаборОтложенныхДвижений	= РегистрыСведений.бестОтложенныеДвиженияДокументовНП.СоздатьНаборЗаписей();
				НаборОтложенныхДвижений.Отбор.Организация.Установить(ВыборкаДетальныеЗаписи.Организация);
				НаборОтложенныхДвижений.Отбор.ПериодНачисления.Установить(ДобавитьМесяц(ВыборкаДетальныеЗаписи.ПериодНачисления,1));
				НаборОтложенныхДвижений.Отбор.Район.Установить(ВыборкаДетальныеЗаписи.Район);
				НаборОтложенныхДвижений.Отбор.РазделЗаписи.Установить(Перечисления.бестРазделыЗаписиНП.СтабильныеПериодыНП);
				НаборОтложенныхДвижений.Отбор.МКД.Установить(ТекМКД);
				НаборОтложенныхДвижений.Записать();
				
				СтрокаНабора 					= НаборОтложенныхДвижений.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи);
				СтрокаНабора.ДатаРегистратора 	= ДатаРегистратора;
				СтрокаНабора.ДокРегистратор 	= ДокументСсылка;
				СтрокаНабора.ПериодНачисления	= ДобавитьМесяц(ВыборкаДетальныеЗаписи.ПериодНачисления,1);
				СтрокаНабора.МКД 				= ТекМКД;
				СтрокаНабора.РазделЗаписи 		= Перечисления.бестРазделыЗаписиНП.СтабильныеПериодыНП;
				
				НаборОтложенныхДвижений.Записать();
				
				
				НаборЗаписей.Записать();
				
				// Область почасовых объемов 
				НаборПочасовыхЗаписей 							= РегистрыНакопления.бестПочасовойОбъемНачисленийЭлектроэнергии.СоздатьНаборЗаписей();
				НаборПочасовыхЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
				
				Пока ТекМКД = ВыборкаПочасовыеЗначения.МКД И ВыборкаПочасовыеЗначения.Следующий() Цикл
					СтрокаНабораПочасовыхЗаписей 		= НаборПочасовыхЗаписей.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаНабораПочасовыхЗаписей, ВыборкаДетальныеЗаписи);
					СтрокаНабораПочасовыхЗаписей.Период = ДатаРегистратора;
				КонецЦикла;
				
				НаборПочасовыхЗаписей.Записать();
				// Область почасовых объемов 
				
				Если Не ДокументОбъект = Неопределено Тогда
					ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
				КонецЕсли; 					
				ЗафиксироватьТранзакцию();
			КонецЕсли;
			
			ДокументСсылка 							= ВыборкаДетальныеЗаписи.ДокументНачисления;			
			
			Если НЕ ЗначениеЗаполнено(ДокументСсылка) Тогда			
				ДокументСсылка 						= Документы.бестНачислениеЭлектроэнергии.ПолучитьСсылку(Новый УникальныйИдентификатор());
				ДокументОбъект 						= Документы.бестНачислениеЭлектроэнергии.СоздатьДокумент();
				ДокументОбъект.Район 				= ВыборкаДетальныеЗаписи.Район;
				ДокументОбъект.МКД	 				= ВыборкаДетальныеЗаписи.МКД;
				ДокументОбъект.Дата 				= ДатаРегистратора;
				ДокументОбъект.Организация			= ВыборкаДетальныеЗаписи.Организация;
				ДокументОбъект.УстановитьСсылкуНового(ДокументСсылка);	
				
			Иначе
				ДокументОбъект 						= ДокументСсылка.ПолучитьОбъект();
				ДокументОбъект.ПометкаУдаления 		= Ложь;
				
				НаборЗаписей 						= РегистрыНакопления.бестОбъемНачисленийЭлектроэнергии.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
				НаборЗаписей.Записать(); 
				
				// Область почасовых объемов
				НаборПочасовыхЗаписей 						= РегистрыНакопления.бестПочасовойОбъемНачисленийЭлектроэнергии.СоздатьНаборЗаписей();
				НаборПочасовыхЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
				НаборПочасовыхЗаписей.Записать();
				// Область почасовых объемов
				
			КонецЕсли;
			
			НаборЗаписей 							= РегистрыНакопления.бестОбъемНачисленийЭлектроэнергии.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
			
		КонецЕсли;
		
		СтрокаНабора 		= НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи);
						
		СтрокаНабора.Период 			= ДатаРегистратора;
		СтрокаНабора.ВидНачисления 		= Перечисления.энргВидыНачислений.Начисление; 
		
		Если СтрокаНабора.СуммаСредневзвешенная > 0 Тогда
			 СтрокаНабора.СуммаСредневзвешенная = СтрокаНабора.Сумма - СтрокаНабора.СуммаЗаСбытовуюНадбавку
			 	- СтрокаНабора.СуммаЗаУслугиПоПередачи - СтрокаНабора.СуммаЗаИныеУслуги - СтрокаНабора.СуммаЗаСбытовуюНадбавкуПокупатель;
				
			 СтрокаНабора.СуммаСредневзвешеннаяНДС = СтрокаНабора.СуммаНДС - СтрокаНабора.СуммаЗаСбытовуюНадбавкуНДС
			 	- СтрокаНабора.СуммаЗаУслугиПоПередачиНДС - СтрокаНабора.СуммаЗаИныеУслугиНДС - СтрокаНабора.СуммаЗаСбытовуюНадбавкуНДСПокупатель;
		КонецЕсли;
		
		Если Не ВыборкаДетальныеЗаписи.ОграничениеУслуги И Не ВыборкаДетальныеЗаписи.ИспользоватьРасчетРеактивнойЭнергии И 
				(ВыборкаДетальныеЗаписи.ПроцентПотерь > 0 Или ВыборкаДетальныеЗаписи.ФиксированныйОбъемПотерь > 0) Тогда
			
			СтрокаПотерь 					= НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаПотерь, СтрокаНабора);
			СтрокаПотерь.СпособНачисления 	= Перечисления.энргСпособНачислений.РасчетПотерь;
			СтрокаПотерь.ОбъемУслуги 		= ВыборкаДетальныеЗаписи.ФиксированныйОбъемПотерь * (СтрокаПотерь.КонецПериода - СтрокаПотерь.НачалоПериода) / (ДнейВПериоде * 24 * 60 * 60);
			Если ВыборкаДетальныеЗаписи.ПроцентПотерь > 0 Тогда 
				СтрокаПотерь.ОбъемУслуги 	= СтрокаПотерь.ОбъемУслуги + (СтрокаПотерь.ОбъемУслуги + ВыборкаДетальныеЗаписи.ОбъемУслугиБезОкругления) * ВыборкаДетальныеЗаписи.ПроцентПотерь / 100;
			КонецЕсли;
			ОбщийОбъем	= ВыборкаДетальныеЗаписи.ОбъемУслугиБезОкругления + СтрокаПотерь.ОбъемУслуги;
			СтрокаПотерь.ОбъемУслуги 		= Окр(ОбщийОбъем, ВыборкаДетальныеЗаписи.РазрядностьОбъема) - СтрокаНабора.ОбъемУслуги;
			ПерерасчитатьСуммы(СтрокаПотерь, СтрокаНабора, 1);
			
		КонецЕсли;
		
		Если СтрокаНабора.ОбъемУслуги < 0 Или ВыборкаДетальныеЗаписи.ОграничениеУслуги Тогда
			
			СтрокаНабора.ОбъемУслуги = 0;
			СтрокаНабора.Сумма = 0;
			СтрокаНабора.СуммаНДС = 0;  
			СтрокаНабора.СуммаСредневзвешенная = 0;
			СтрокаНабора.СуммаЗаСбытовуюНадбавку = 0;  
			СтрокаНабора.СуммаЗаСбытовуюНадбавкуПокупатель = 0;
			СтрокаНабора.СуммаЗаУслугиПоПередачи = 0;
			СтрокаНабора.СуммаЗаИныеУслуги = 0;
			СтрокаНабора.СуммаСредневзвешеннаяНДС = 0;
			СтрокаНабора.СуммаЗаСбытовуюНадбавкуНДС = 0;      
			СтрокаНабора.СуммаЗаСбытовуюНадбавкуНДСПокупатель = 0;
            СтрокаНабора.СуммаЗаУслугиПоПередачиНДС = 0;
			СтрокаНабора.СуммаЗаИныеУслугиНДС = 0;

		КонецЕсли;
		
		ТекМКД 			= ВыборкаДетальныеЗаписи.МКД;
		
	КонецЦикла;
		
	Если Не НаборЗаписей = Неопределено И НаборЗаписей.Количество() > 0 Тогда
		НачатьТранзакцию();					
		
		НаборОтложенныхДвижений	= РегистрыСведений.бестОтложенныеДвиженияДокументовНП.СоздатьНаборЗаписей();
		НаборОтложенныхДвижений.Отбор.Организация.Установить(ВыборкаДетальныеЗаписи.Организация);
		НаборОтложенныхДвижений.Отбор.ПериодНачисления.Установить(ДобавитьМесяц(ВыборкаДетальныеЗаписи.ПериодНачисления,1));
		НаборОтложенныхДвижений.Отбор.Район.Установить(ВыборкаДетальныеЗаписи.Район);
		НаборОтложенныхДвижений.Отбор.РазделЗаписи.Установить(Перечисления.бестРазделыЗаписиНП.СтабильныеПериодыНП);
		НаборОтложенныхДвижений.Отбор.МКД.Установить(ТекМКД);
		НаборОтложенныхДвижений.Записать();
		
		СтрокаНабора 					= НаборОтложенныхДвижений.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи);
		СтрокаНабора.ПериодНачисления	= ДобавитьМесяц(ВыборкаДетальныеЗаписи.ПериодНачисления,1);
		СтрокаНабора.ДатаРегистратора 	= ДатаРегистратора;
		СтрокаНабора.ДокРегистратор 	= ДокументСсылка;
		СтрокаНабора.РазделЗаписи 		= Перечисления.бестРазделыЗаписиНП.СтабильныеПериодыНП;
		
		НаборОтложенныхДвижений.Записать();
		
		НаборЗаписей.Записать();
		
		// Область почасовых объемов 
		НаборПочасовыхЗаписей 							= РегистрыНакопления.бестПочасовойОбъемНачисленийЭлектроэнергии.СоздатьНаборЗаписей();
		НаборПочасовыхЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
		
		Пока ТекМКД = ВыборкаПочасовыеЗначения.МКД  и ВыборкаПочасовыеЗначения.Следующий() Цикл
			СтрокаНабораПочасовыхЗаписей 		= НаборПочасовыхЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаНабораПочасовыхЗаписей, ВыборкаПочасовыеЗначения);
			СтрокаНабораПочасовыхЗаписей.Период = ДатаРегистратора;
		КонецЦикла;
		
		НаборПочасовыхЗаписей.Записать();
		// Область почасовых объемов 
		
		Если Не ДокументОбъект = Неопределено Тогда
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли; 					
		ЗафиксироватьТранзакцию();
	КонецЕсли;
КонецПроцедуры

// Начисляет по долевым схемам электроэнергии.
//
// Параметры:
//  Организация				-	СправочникСсылка.Организации.
//  Район					-	СправочникСсылка.энргЗоныОтвественности.
//  МКД						-	СправочникСсылка.энргСтроения.
//  ПериодПерерасчетаКонец	-	Дата.
//  ИсключаяОтдельностоящие	-	Булево.
//  НачалоПериодаРасчета	-	Дата.
//  КонецПериодаРасчета		-	Дата.
//  РазныеРО				-	Булево.
//  ДопПараметры			-	Структура.
//
Процедура НачисленияПоДолевымСхемамЭлектроэнергии(Организация,Район,МКД,ПериодНачисления,ИсключаяОтдельностоящие,НачалоПериодаРасчета,КонецПериодаРасчета,РазныеРО, ДопПараметры) Экспорт
	ТекМКД	 										= Неопределено;
	НаборЗаписей 									= Неопределено;
	НаборЗаписейОтрицательныеОбъемы 				= Неопределено;
	ДокументОбъект 									= Неопределено;
	ДокументСсылка									= Неопределено;
	мОбъектовРасчета								= Неопределено;
	МВТ = Новый МенеджерВременныхТаблиц;
	ПолучитьВспомогательныеДанныеНачисленияЭЭ(Организация,Район, МКД,ИсключаяОтдельностоящие,НачалоПериодаРасчета,КонецПериодаРасчета,ПериодНачисления, МВТ);
	РезультатЗапроса = РезультатЗапросаНачислениеПоДолевымСхемамЭлектроэнергии(Организация,Район, МКД,ИсключаяОтдельностоящие,НачалоПериодаРасчета,КонецПериодаРасчета,РазныеРО,ПериодНачисления, МВТ, ДопПараметры);
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	РезультатЗапросаОтрицательныеОбъемы = ПолучитьОтрицательныеОбъемыПредыдущихПериодов(МВТ, НачалоПериодаРасчета);
	ОтрицательныеОбъемы = РезультатЗапросаОтрицательныеОбъемы.Выгрузить();
	
	РезультатЗапросаНерассчитанныеТранзитныеСхемы = ПолучитьНерассчитанныеТранзитныеСхемы(ПериодНачисления, КонецПериодаРасчета, РазныеРО, МВТ);
	ВыборкаНерассчитанныеТранзитныеСхемы = РезультатЗапросаНерассчитанныеТранзитныеСхемы.Выбрать();
	НаборЗаписейНерассчитанныеТранзитныеСхемы = РегистрыСведений.бестНерассчитанныеТранзитныеСхемы.СоздатьНаборЗаписей();
	НаборЗаписейНерассчитанныеТранзитныеСхемы.Отбор.Организация.Установить(Организация);
	НаборЗаписейНерассчитанныеТранзитныеСхемы.Отбор.Район.Установить(Район);
	НаборЗаписейНерассчитанныеТранзитныеСхемы.Отбор.ПериодНачисления.Установить(ПериодНачисления);
	НаборЗаписейНерассчитанныеТранзитныеСхемы.Отбор.ТранзитИзРазныхРО.Установить(РазныеРО);
	НаборЗаписейНерассчитанныеТранзитныеСхемы.Записать(); 
	
	Пока ВыборкаНерассчитанныеТранзитныеСхемы.Следующий() Цикл
		 ЗаписьНерассчитанныеТранзитныеСхемы = НаборЗаписейНерассчитанныеТранзитныеСхемы.Добавить();
		 ЗаполнитьЗначенияСвойств(ЗаписьНерассчитанныеТранзитныеСхемы, ВыборкаНерассчитанныеТранзитныеСхемы);
	КонецЦикла;
	
	НаборЗаписейНерассчитанныеТранзитныеСхемы.Записать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если НЕ ТекМКД = ВыборкаДетальныеЗаписи.МКД Тогда
			
			Если ДокументОбъект <> Неопределено Тогда
				
				НачатьТранзакцию();				
				
				Если НаборЗаписей <> Неопределено Тогда
					НаборЗаписей.Записать();    
				КонецЕсли;     
				
				Если НаборЗаписейОтрицательныеОбъемы <> Неопределено Тогда
					НаборЗаписейОтрицательныеОбъемы.Записать();
				КонецЕсли;
				
				ДокументОбъект.записать(РежимЗаписиДокумента.Запись);
				
				ЗафиксироватьТранзакцию();
			КонецЕсли;
			
			ДокументСсылка 							= ВыборкаДетальныеЗаписи.ДокументНачисление;			
			
			Если НЕ ЗначениеЗаполнено(ДокументСсылка) Тогда			
				ДокументСсылка 						= Документы.бестНачислениеПоДолевымСхемамЭлектроэнергии.ПолучитьСсылку(Новый УникальныйИдентификатор());
				ДокументОбъект 						= Документы.бестНачислениеПоДолевымСхемамЭлектроэнергии.СоздатьДокумент();
				ДокументОбъект.Район 				= ВыборкаДетальныеЗаписи.Район;
				ДокументОбъект.МКД	 				= ВыборкаДетальныеЗаписи.МКД;
				ДокументОбъект.ТранзитИзРазныхРО	= РазныеРО;
				ДокументОбъект.Дата 				= КонецПериодаРасчета-1;
				ДокументОбъект.Организация			= ВыборкаДетальныеЗаписи.Организация;
				ДокументОбъект.УстановитьСсылкуНового(ДокументСсылка);	
				
			Иначе
				ДокументОбъект 						= ДокументСсылка.ПолучитьОбъект();
				ДокументОбъект.ПометкаУдаления 		= Ложь;
				
				НаборЗаписей 						= РегистрыНакопления.бестОбъемНачисленийЭлектроэнергии.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
				НаборЗаписей.Записать(); 
				
				НаборЗаписейОтрицательныеОбъемы 						= РегистрыНакопления.бестОтрицательныеОбъемыДолевыхСхем.СоздатьНаборЗаписей();
				НаборЗаписейОтрицательныеОбъемы.Отбор.Регистратор.Установить(ДокументСсылка);
				НаборЗаписейОтрицательныеОбъемы.Записать(); 
			КонецЕсли;
			
			НаборЗаписей 							= РегистрыНакопления.бестОбъемНачисленийЭлектроэнергии.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
			
			НаборЗаписейОтрицательныеОбъемы 							= РегистрыНакопления.бестОтрицательныеОбъемыДолевыхСхем.СоздатьНаборЗаписей();
			НаборЗаписейОтрицательныеОбъемы.Отбор.Регистратор.Установить(ДокументСсылка);

		КонецЕсли;
		
		
		Если ВыборкаДетальныеЗаписи.КонтролироватьОтрицательныйОбъем Тогда 
			Если ВыборкаДетальныеЗаписи.ОбъемУслуги < 0 Тогда
				СтрокаНабора 		= НаборЗаписейОтрицательныеОбъемы.ДобавитьПриход();
				ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи,, "ОбъемУслуги");
				СтрокаНабора.ОбъемУслуги = -ВыборкаДетальныеЗаписи.ОбъемУслуги;
				СтрокаНабора.Период = КонецПериодаРасчета-1;
			Иначе
				Отбор = Новый Структура("ТочкаУчета, Услуга, ТарифнаяЗона");
				ЗаполнитьЗначенияСвойств(Отбор, ВыборкаДетальныеЗаписи);
				СтрокиОтрицательногоОбъема = ОтрицательныеОбъемы.НайтиСтроки(Отбор); 
				Если СтрокиОтрицательногоОбъема.Количество() > 0 Тогда
					ОстатокОбъема = СтрокиОтрицательногоОбъема[0].ОбъемУслуги; 
					ВычитаемыйОбъем = Мин(ОстатокОбъема, ВыборкаДетальныеЗаписи.ОбъемУслуги);
					СтрокиОтрицательногоОбъема[0].ОбъемУслуги = ОстатокОбъема - ВычитаемыйОбъем; 
					
					СтрокаНабора 		= НаборЗаписейОтрицательныеОбъемы.ДобавитьРасход();
					ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи,, "ОбъемУслуги");
					СтрокаНабора.ОбъемУслуги = ВычитаемыйОбъем;
					СтрокаНабора.Период = КонецПериодаРасчета-1;
					
					ЗаписываемыйОбъем = ВыборкаДетальныеЗаписи.ОбъемУслуги - ВычитаемыйОбъем;
					Если ЗаписываемыйОбъем <> 0 Тогда
						СтрокаНабора 		= НаборЗаписей.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи,, "ОбъемУслуги"); 
						СтрокаНабора.ОбъемУслуги = ЗаписываемыйОбъем;
						СтрокаНабора.Период = КонецПериодаРасчета-1;
					КонецЕсли;
					
				Иначе
					СтрокаНабора 		= НаборЗаписей.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи);
					СтрокаНабора.Период = КонецПериодаРасчета-1;
					
				КонецЕсли;
			КонецЕсли;	
		Иначе
			СтрокаНабора 		= НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи);
			СтрокаНабора.Период = КонецПериодаРасчета-1;
		КонецЕсли;    
				
		ТекМКД 			= ВыборкаДетальныеЗаписи.МКД;
		
	КонецЦикла;
	
	
	Если ДокументОбъект <> Неопределено Тогда
		НачатьТранзакцию();					
		
		Если НаборЗаписей <> Неопределено Тогда
			НаборЗаписей.Записать();    
		КонецЕсли;     
		
		Если НаборЗаписейОтрицательныеОбъемы <> Неопределено Тогда
			НаборЗаписейОтрицательныеОбъемы.Записать();
		КонецЕсли;
		
		ДокументОбъект.записать(РежимЗаписиДокумента.Запись);
 					
		ЗафиксироватьТранзакцию();
	КонецЕсли;
КонецПроцедуры

// Считает данные перерасчета ЭЭ.
//
// Параметры:
//  Организация				-	СправочникСсылка.Организации.
//  Район					-	СправочникСсылка.энргЗоныОтвественности.
//  ОснованиеПерерасчета	-	ДокументСсылка.бестПочасоваяВедомость, ДокументСсылка.бестИзменитьПараметрыТочкиУчета,
//		ДокументСсылка.бестОперацияСПриборомУчетаНП, ДокументСсылка.бестОперацияСУслугамиНП,
//		ДокументСсылка.бестЗаключениеДоговоровСЮридическимиЛицами, ДокументСсылка.бестРегистрацияПоказанийНП.
//  ПериодПерерасчетаКонец	-	Дата.
//  Набор					-	Движения.бестОбъемНачисленийЭлектроэнергии.
//  КорректируемыеПоказания	-	ДокументСсылка.бестРегистрацияПоказанийНП.
//
Процедура ДанныеПерерасчетаЭЭ(Организация, Район, ОснованиеПерерасчета, ПериодПерерасчетаКонец, Набор, КорректируемыеПоказания) Экспорт
	МВТДанныеДляРасчета = Новый МенеджерВременныхТаблиц;
	
	ДатаФактическогоСобытия = ОснованиеПерерасчета.ДатаФактическогоСобытия;
	ПериодПерерасчетаНачало = Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ДатаФактическогоСобытия, Организация, Район);
	
	
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодПерерасчетаНачало,Ложь);
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодПерерасчетаКонец,Ложь);
	КонецПериодаРасчета  							= ГраницыПериода.НачалоОП-1;
	
	СоответствиеОтборов = Документы.бестПерерасчетЭЭ.ПолучитьОтборыНачисления(ОснованиеПерерасчета, ПериодПерерасчетаНачало, МВТДанныеДляРасчета);
	
	СторнироватьРаннееНачисленныеОбъемы(Организация, Район, НачалоПериодаРасчета, КонецПериодаРасчета, СоответствиеОтборов, Набор);
	
	ТекПериодПерерасчета = ПериодПерерасчетаНачало;
	
	НаОснованииПочасовойВедомости = ТипЗнч(ОснованиеПерерасчета) = Тип("ДокументСсылка.бестПочасоваяВедомость");
	
	Если ЗначениеЗаполнено(КорректируемыеПоказания) Тогда
		НаборПоследовательность = РегистрыСведений.бестПоказанияПУНППоследовательность.СоздатьНаборЗаписей();
		НаборПоследовательность.Отбор.ДокРегистратор.Установить(КорректируемыеПоказания);
		НаборПоследовательность.Прочитать();
		Для Каждого Запись Из НаборПоследовательность Цикл
			Запись.СостояниеПроведения = Перечисления.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности;
		КонецЦикла;
		НаборПоследовательность.Записать();
	КонецЕсли;
	
	Пока ТекПериодПерерасчета <> ПериодПерерасчетаКонец Цикл
		Для каждого эл из СоответствиеОтборов Цикл
			
			мОбъектыРасчета 								= эл.Значение.ОбъектыРасчета;
			ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ТекПериодПерерасчета,Ложь);
			НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
			КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП;
			ДнейВПериоде  									= ГраницыПериода.ДнейВПериоде;
			ИспользоватьПериодыПерерасчета 					= Истина;

			
			Если НаОснованииПочасовойВедомости Тогда
				бестРаботаСПоследовательностямиНП.ЗаполнитьДанныеПочасовойВедомостиСрез(Организация, Район, эл.Ключ, Ложь, ТекПериодПерерасчета, эл.Значение);
				ИспользоватьПериодыПерерасчета = Ложь;
			Иначе
				Параметры	= Новый Структура("Организация,ПериодНачисления,Район,МКД_НП,ИсключаяОтдельностоящие,СбрасыватьСостояниеПоследовательности",Организация,ТекПериодПерерасчета,Район,эл.Ключ,Ложь,Ложь);     
				бестРаботаСПоследовательностямиНП.ОтложенныеДвиженияДокументовНачисленияНП(Параметры, мОбъектыРасчета, Истина, ТекПериодПерерасчета = ПериодПерерасчетаНачало);			
								
				Если ТипЗнч(ОснованиеПерерасчета) = Тип("ДокументСсылка.бестРегистрацияПоказанийНП") Тогда
					бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьПоказанияПУНП(Параметры,мОбъектыРасчета, Истина);
					ИспользоватьПериодыПерерасчета = Ложь;
				Иначе
					бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьСтабильныеПериодыНП(Параметры, мОбъектыРасчета, МВТДанныеДляРасчета, Истина);
					
					Запрос = Новый Запрос; 
					Запрос.МенеджерВременныхТаблиц = МВТДанныеДляРасчета; 
					
					ТекстЗапpoca = "УНИЧТОЖИТЬ МинПериодРегистрации
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|УНИЧТОЖИТЬ МинимальныйПериод
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|УНИЧТОЖИТЬ МинимальныйРегистратор"; 
					
					Запрос.Текст = ТекстЗапpoca; 
					Запрос.Выполнить(); 
				КонецЕсли;				
				
			КонецЕсли;
			
			МВТ = Новый МенеджерВременныхТаблиц;
			ВспомогательныеДанныеНачисленияНП(МВТ,Организация, ТекПериодПерерасчета,Район,Ложь, эл.Ключ, мОбъектыРасчета,НачалоПериодаРасчета,КонецПериодаРасчета,Константы.энргДеньНачалаПримененияНовогоТарифа.Получить(),ДнейВПериоде, ИспользоватьПериодыПерерасчета);
			ПолучитьСтабильныеПериодыНП(МВТ);
			ПолучитьДанныеДляРасчетаНП(МВТ,ЛОЖЬ);
			
			РезультатЗапроса 					= РезультатЗапросаНачислениеПоЭлектроэнергии(МВТ,НачалоПериодаРасчета,КонецПериодаРасчета);
			КоличествоПакетов					= РезультатЗапроса.Количество();
			ВыборкаДетальныеЗаписи 				= РезультатЗапроса[КоличествоПакетов - 1].Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				СтрокаНабора 		= Набор.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаНабора, ВыборкаДетальныеЗаписи);
				СтрокаНабора.ВидНачисления 	= Перечисления.энргВидыНачислений.Перерасчет;
				СтрокаНабора.Активность = Истина;
				Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ОбъемУслуги) Тогда
					СтрокаНабора.ОбъемУслуги = Окр(ВыборкаДетальныеЗаписи.ОбъемУслуги, ВыборкаДетальныеЗаписи.РазрядностьОбъема);
				КонецЕсли;
				
			КонецЦикла;
		КонецЦикла;
		ТекПериодПерерасчета = ДобавитьМесяц(ТекПериодПерерасчета,1);
	КонецЦикла;
КонецПроцедуры

// Начисляет пеню ЭЭ.
//
// Параметры:
//  Организация			-	СправочникСсылка.Организации.
//  ПериодНачисления	-	Дата.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  Договор				-	СправочникСсылка.энргДоговорыКонтрагентов.
// 
// Возвращаемое значение:
//   Структура.
//
Функция НачислитьПенюЭЭ(Организация,ПериодНачисления,Район,Договор) Экспорт
	
	ОсновнойПроизводственныйКалендарь 	= КалендарныеГрафики.ОсновнойПроизводственныйКалендарь();
	ГраницыПериода  					= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления,Ложь);
	НачалоПериодаРасчета				= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  				= ГраницыПериода.ЗавершениеОП;
	СтруктураВозврат = Новый Структура("КоличествоНеПроведенныхПД, СозданныеДокументы", 0, Новый Массив);
	
	Если НЕ ЗначениеЗаполнено(ОсновнойПроизводственныйКалендарь) тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен основной производственный календарь");
		Возврат СтруктураВозврат;
	КонецЕсли;
	
	
	// Ставки рефинансирования
	Запрос  								= Новый Запрос;
	Запрос.Текст 							=
	"ВЫБРАТЬ
	|	энргСтавкиРефинансированияСрезПоследних.Коэффициент КАК Коэффициент
	|ИЗ
	|	РегистрСведений.энргСтавкиРефинансирования.СрезПоследних(&Период, ) КАК энргСтавкиРефинансированияСрезПоследних";
	Запрос.УстановитьПараметр("Период", НачалоПериодаРасчета);
	
	Результат  								= Запрос.Выполнить();
	Если Результат.Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена информация по ставке рефинансирования,
		|	 Начисление пени не может быть выполнено");
		Возврат СтруктураВозврат;
	КонецЕсли;
	Выборка  								= Результат.Выбрать();
	Выборка.Следующий();
	СтавкаРефинансирования  				= Выборка.Коэффициент; 
	
	// Настройка расчет пени
	МВТ = Новый МенеджерВременныхТаблиц;	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестДоговорныеНастройкиРасчетаПениСрезПоследних.Договор КАК Договор,
	|	бестДоговорныеНастройкиРасчетаПениСрезПоследних.Организация КАК Организация,
	|	бестДоговорныеНастройкиРасчетаПениСрезПоследних.Район КАК Район,
	|	бестДоговорныеНастройкиРасчетаПениСрезПоследних.ГруппаПотребителей КАК ГруппаПотребителей,
	|	бестДоговорныеНастройкиРасчетаПениСрезПоследних.ВариантРасчета КАК ВариантРасчета,
	|	бестДоговорныеНастройкиРасчетаПениСрезПоследних.ПроцентПени КАК ПроцентПени
	|ПОМЕСТИТЬ ДоговорыСРасчетомПени
	|ИЗ
	|	РегистрСведений.бестДоговорныеНастройкиРасчетаПени.СрезПоследних(
	|			&КонецПериода,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор) КАК бестДоговорныеНастройкиРасчетаПениСрезПоследних
	|ГДЕ
	|	бестДоговорныеНастройкиРасчетаПениСрезПоследних.РассчитыватьПени
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестНастройкаРасчетаПениСрезПоследних.ГруппаПотребителя КАК ГруппаПотребителя,
	|	бестНастройкаРасчетаПениСрезПоследних.От КАК От,
	|	бестНастройкаРасчетаПениСрезПоследних.До КАК До,
	|	бестНастройкаРасчетаПениСрезПоследних.Числитель КАК Числитель,
	|	бестНастройкаРасчетаПениСрезПоследних.Знаменатель КАК Знаменатель
	|ИЗ
	|	РегистрСведений.бестНастройкаРасчетаПениНП.СрезПоследних(
	|			&Период,
	|			(Организация, ГруппаПотребителя) В
	|				(ВЫБРАТЬ
	|					ДоговорыСРасчетомПени.Организация КАК Организация,
	|					ДоговорыСРасчетомПени.ГруппаПотребителей КАК ГруппаПотребителей
	|				ИЗ
	|					ДоговорыСРасчетомПени КАК ДоговорыСРасчетомПени)) КАК бестНастройкаРасчетаПениСрезПоследних
	|ИТОГИ ПО
	|	ГруппаПотребителя";
	
	Запрос.УстановитьПараметр("Период", НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериодаРасчета);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	
	Если Не ЗначениеЗаполнено(Договор) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Договор = &Договор", "Истина");
	Иначе
		Запрос.УстановитьПараметр("Договор", Договор);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Результат.Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены настройки расчет пени, Начисление пени не может быть выполнено");
		Возврат СтруктураВозврат;
	КонецЕсли;
	
	ВыборкаКатегорияПотребителя = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	СоответствиеИтог = Новый Соответствие;
	СоответствиеМаксЗначений = Новый Соответствие;
	Пока ВыборкаКатегорияПотребителя.Следующий() Цикл
		МаксЗначение = 0;
		СоответствиеКатегория = Новый Соответствие;
		РангКоэффициента = 1;
		
		Строка = ВыборкаКатегорияПотребителя.Выбрать();
		
		Пока Строка.Следующий() Цикл
			Если Строка.До = 0 Тогда
				НСтр = Новый Структура;
				НСтр.Вставить("Числитель", Строка.Числитель);
				НСтр.Вставить("Знаменатель", Строка.Знаменатель);
				НСтр.Вставить("РангКоэффициента", РангКоэффициента);
				
				СоответствиеКатегория.Вставить(Строка.До, НСтр);
			Иначе
				Для Сч = Строка.От По Строка.До Цикл
					НСтр = Новый Структура;
					НСтр.Вставить("Числитель", Строка.Числитель);
					НСтр.Вставить("Знаменатель", Строка.Знаменатель);
					НСтр.Вставить("РангКоэффициента", РангКоэффициента);
					
					СоответствиеКатегория.Вставить(Сч, НСтр);
					
					МаксЗначение = Макс(МаксЗначение, Сч);
				КонецЦикла;
			КонецЕсли;
			
			РангКоэффициента = РангКоэффициента + 1;
			
		КонецЦикла;
		СоответствиеМаксЗначений.Вставить(ВыборкаКатегорияПотребителя.ГруппаПотребителя, МаксЗначение);
		СоответствиеИтог.Вставить(ВыборкаКатегорияПотребителя.ГруппаПотребителя,СоответствиеКатегория);
	КонецЦикла;
	
	// Настройки начисления пени.
	Запрос  									= Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц				= МВТ;
	Запрос.Текст 								= ТекстЗапросаПеняЭЭ();
	
	Запрос.УстановитьПараметр("КонецПериода", КонецПериодаРасчета);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("ПериодНачисления", ПериодНачисления);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	
	Если Не ЗначениеЗаполнено(Договор) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестПлатежныйДокумент.Договор = &Договор", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Договор = &Договор", "Истина");
	Иначе
		Запрос.УстановитьПараметр("Договор", Договор);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Для каждого стр из ТЗ Цикл
		
		мДат = Новый Массив();
		мДат.Добавить(стр.ДатаНачалаНачисленияПени);
		мДат.Добавить(стр.ИзначальнаяДатаНачисленияПени);
		РабочаяДата = Неопределено;
		РабочаяДата = КалендарныеГрафики.ДатыБлижайшихРабочихДней(ОсновнойПроизводственныйКалендарь,мДат,,Ложь);
		
		Если РабочаяДата <> Неопределено Тогда
			Если стр.ИзначальнаяДатаНачисленияПени = стр.ДатаНачалаНачисленияПени Тогда
				стр.ДатаНачалаНачисленияПени 		= РабочаяДата[стр.ДатаНачалаНачисленияПени];
			КонецЕсли;
			стр.ИзначальнаяДатаНачисленияПени 	= РабочаяДата[стр.ИзначальнаяДатаНачисленияПени];
		КонецЕсли;
		
	КонецЦикла;
	
	Запрос  									= Новый Запрос;
	Запрос.Текст 								=
	"ВЫБРАТЬ
	|	ТЗ.ДатаНачалаНачисленияПени КАК ДатаНачалаНачисленияПени,
	|	ВЫБОР
	|		КОГДА ТЗ.Период = &КонецПериода
	|			ТОГДА ДОБАВИТЬКДАТЕ(ТЗ.Период, ДЕНЬ, -1)
	|		ИНАЧЕ ТЗ.Период
	|	КОНЕЦ КАК Период,
	|	ТЗ.ДокументНачисления КАК ДокументНачисления,
	|	ТЗ.Договор КАК Договор,
	|	ТЗ.СуммаНачальныйОстаток КАК СуммаНачальныйОстаток,
	|	ТЗ.НачальныйПериод КАК НачальныйПериод,
	|	ТЗ.ГруппаПотребителей КАК ГруппаПотребителей,
	|	ТЗ.ВариантРасчета КАК ВариантРасчета,
	|	ТЗ.ПроцентПени КАК ПроцентПени,
	|	ТЗ.ПлатежныйДокумент КАК ПлатежныйДокумент,
	|	ТЗ.СтавкаНДС КАК СтавкаНДС,
	|	ТЗ.ПериодНачисления КАК ПериодНачисления,
	|	ТЗ.ЭтоИсправлениеКорректировка КАК ЭтоИсправлениеКорректировка,
	|	ТЗ.ИзначальнаяДатаНачисленияПени КАК ИзначальнаяДатаНачисленияПени,
	|	ТЗ.ЭтоОплата КАК ЭтоОплата
	|ПОМЕСТИТЬ ДатаНачальногоПериода
	|ИЗ
	|	&ТЗ КАК ТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ДатаНачальногоПериода.Период = ДатаНачальногоПериода.НачальныйПериод
	|			ТОГДА ДатаНачальногоПериода.ДатаНачалаНачисленияПени
	|		ИНАЧЕ ВЫБОР
	|				КОГДА МЕСЯЦ(ДатаНачальногоПериода.НачальныйПериод) <> МЕСЯЦ(&НачалоПериода)
	|					ТОГДА &НачалоПериода
	|				ИНАЧЕ ДатаНачальногоПериода.НачальныйПериод
	|			КОНЕЦ
	|	КОНЕЦ КАК ДатаНачалаНачисленияПени,
	|	ДатаНачальногоПериода.Период КАК Период,
	|	ДатаНачальногоПериода.ДокументНачисления КАК ДокументНачисления,
	|	ДатаНачальногоПериода.Договор КАК Договор,
	|	ДатаНачальногоПериода.СуммаНачальныйОстаток КАК СуммаНачальныйОстаток,
	|	ДатаНачальногоПериода.НачальныйПериод КАК НачальныйПериод,
	|	ДатаНачальногоПериода.ГруппаПотребителей КАК ГруппаПотребителей,
	|	ДатаНачальногоПериода.ВариантРасчета КАК ВариантРасчета,
	|	ДатаНачальногоПериода.ПроцентПени КАК ПроцентПени,
	|	ДатаНачальногоПериода.ПлатежныйДокумент КАК ПлатежныйДокумент,
	|	ДатаНачальногоПериода.СтавкаНДС КАК СтавкаНДС,
	|	ДатаНачальногоПериода.ПериодНачисления КАК ПериодНачисления,
	|	ДатаНачальногоПериода.ЭтоИсправлениеКорректировка КАК ЭтоИсправлениеКорректировка,
	|	ДатаНачальногоПериода.ИзначальнаяДатаНачисленияПени КАК ИзначальнаяДатаНачисленияПени,
	|	ДатаНачальногоПериода.ЭтоОплата КАК ЭтоОплата
	|ПОМЕСТИТЬ ДанныеДляРасчета
	|ИЗ
	|	ДатаНачальногоПериода КАК ДатаНачальногоПериода
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДляРасчета.ДокументНачисления КАК ДокументНачисления,
	|	ДанныеДляРасчета.Договор КАК Договор,
	|	ДанныеДляРасчета.ПериодНачисления КАК ПериодНачисления,
	|	ДанныеДляРасчета.Период КАК Период,
	|	ДанныеДляРасчета.СуммаНачальныйОстаток КАК СуммаНачальныйОстаток,
	|	ДанныеДляРасчета.ДатаНачалаНачисленияПени КАК ДатаНачалаНачисленияПени,
	|	ВЫБОР
	|		КОГДА ДанныеДляРасчета.ИзначальнаяДатаНачисленияПени > ДанныеДляРасчета.ДатаНачалаНачисленияПени
	|			ТОГДА 0
	|		ИНАЧЕ РАЗНОСТЬДАТ(ДанныеДляРасчета.ИзначальнаяДатаНачисленияПени, ДанныеДляРасчета.ДатаНачалаНачисленияПени, ДЕНЬ)
	|	КОНЕЦ КАК ДнейНаДеньНачала,
	|	РАЗНОСТЬДАТ(ДанныеДляРасчета.ИзначальнаяДатаНачисленияПени, ДанныеДляРасчета.Период, ДЕНЬ) + 1 КАК ДнейПросрочкиСДатыНачалаНачисленийПени,
	|	ДЕНЬ(ДанныеДляРасчета.Период) КАК ДеньПериода,
	|	ДЕНЬ(ДанныеДляРасчета.ДатаНачалаНачисленияПени) КАК ДеньНачала,
	|	ДанныеДляРасчета.НачальныйПериод КАК НачальныйПериод,
	|	ДанныеДляРасчета.ГруппаПотребителей КАК ГруппаПотребителей,
	|	ДанныеДляРасчета.ИзначальнаяДатаНачисленияПени КАК ИзначальнаяДатаНачисленияПени,
	|	ДанныеДляРасчета.ВариантРасчета КАК ВариантРасчета,
	|	ДанныеДляРасчета.ПроцентПени КАК ПроцентПени,
	|	ДанныеДляРасчета.ПлатежныйДокумент КАК ПлатежныйДокумент,
	|	ДанныеДляРасчета.СтавкаНДС КАК СтавкаНДС,
	|	ДанныеДляРасчета.ЭтоИсправлениеКорректировка КАК ЭтоИсправлениеКорректировка,
	|	ДанныеДляРасчета.ЭтоОплата КАК ЭтоОплата
	|ИЗ
	|	ДанныеДляРасчета КАК ДанныеДляРасчета
	|ГДЕ
	|	ДанныеДляРасчета.ДатаНачалаНачисленияПени < &КонецПериода
	|	И ДанныеДляРасчета.Период >= ДанныеДляРасчета.ДатаНачалаНачисленияПени
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПериодНачисления,
	|	Период
	|ИТОГИ
	|	МАКСИМУМ(ДокументНачисления),
	|	МАКСИМУМ(ДнейНаДеньНачала),
	|	МАКСИМУМ(ДеньНачала)
	|ПО
	|	Договор,
	|	ПлатежныйДокумент";
	
	Запрос.УстановитьПараметр("ТЗ", ТЗ);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериодаРасчета);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	мСозданныеДокументы = Новый Массив;
	КоличествоНепроведенныхПД = 0;
	ВыборкаДоговор = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	Пока ВыборкаДоговор.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаДоговор.ДокументНачисления) Тогда
			ДокументОбъект 							= ВыборкаДоговор.ДокументНачисления.ПолучитьОбъект();
			ДокументОбъект.ПометкаУдаления  		= Ложь;
			ДокументОбъект.Пеня.Очистить();
		Иначе
			ДокументОбъект 							= Документы.бестПлатежныйДокумент.СоздатьДокумент();
			ДокументОбъект.Дата 					= КонецПериодаРасчета - 1;
			ДокументОбъект.Район 					= Район;
			ДокументОбъект.Организация 				= Организация;
			ДокументОбъект.ПериодНачисления 		= ПериодНачисления;
			ДокументОбъект.Договор 					= ВыборкаДоговор.Договор;
			ДокументОбъект.ВидОперации              = Перечисления.бестВидыОпераций.ПлатежныйДокумент_Пеня;
			ДокументОбъект.Ответственный 			= Пользователи.ТекущийПользователь();
			ДокументОбъект.ТипЗадолженности 		= Перечисления.бестВидыРасчета.Пеня;
		КонецЕсли;
		
		ДокументОбъект.Ответственный 			= Пользователи.ТекущийПользователь();
		ДокументОбъект.Дата 					= КонецПериодаРасчета - 1;
		
		ВыборкаПД = ВыборкаДоговор.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);		
		Пока ВыборкаПД.Следующий() Цикл
			
			ВыборкаДетальныеЗаписи = ВыборкаПД.Выбрать();		
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ДеньНачалаДляРасчета = ВыборкаДетальныеЗаписи.ДнейНаДеньНачала + 1;
				
				ДнейПросрочки 				= 0;
				СуммаЗадолженности 			= ВыборкаДетальныеЗаписи.СуммаНачальныйОстаток;
				КоэффициентЧислитель 		= 1;
				КоэффициентЗнаменатель 		= 1;
				ПредКоэффициентЧислитель 	= 1;
				ПредКоэффициентЗнаменатель 	= 1;
				РангКоэффициента 			= 0;
				ПредыдущийРанг 				= Неопределено;
				
				Для Сч = ДеньНачалаДляРасчета По ВыборкаДетальныеЗаписи.ДнейПросрочкиСДатыНачалаНачисленийПени Цикл
					
					ДнейПросрочки = ДнейПросрочки + 1;
					
					Если ВыборкаДетальныеЗаписи.ВариантРасчета = Перечисления.бестВариантыРасчетаПени.ОтСтавкиРефинансирования Тогда
						Соответствие = СоответствиеИтог.Получить(ВыборкаДетальныеЗаписи.ГруппаПотребителей);
						Если Соответствие = Неопределено Тогда
							Продолжить;
						КонецЕсли;
						СтруктураКоэффициента = Соответствие.Получить(
								?(ДеньНачалаДляРасчета <= СоответствиеМаксЗначений.Получить(ВыборкаДетальныеЗаписи.ГруппаПотребителей), ДеньНачалаДляРасчета, 0));
						Если СтруктураКоэффициента = Неопределено Тогда
							КоэффициентЧислитель = 1;
							КоэффициентЗнаменатель = 1;
							РангКоэффициента = 0;
						Иначе
							КоэффициентЧислитель = СтруктураКоэффициента.Числитель;
							КоэффициентЗнаменатель = СтруктураКоэффициента.Знаменатель;
							РангКоэффициента = СтруктураКоэффициента.РангКоэффициента;
						КонецЕсли;
					КонецЕсли;
					
					Если НЕ РангКоэффициента = ПредыдущийРанг И НЕ ПредыдущийРанг = Неопределено Тогда
						НСтр = ДокументОбъект.Пеня.Добавить();
						ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
						НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ВыборкаДетальныеЗаписи.ДнейПросрочкиСДатыНачалаНачисленийПени;
						Если ВыборкаДетальныеЗаписи.ВариантРасчета = Перечисления.бестВариантыРасчетаПени.ОтСтавкиРефинансирования Тогда
							НСтр.КоэффициентЧислитель 		= ПредКоэффициентЧислитель;
							НСтр.КоэффициентЗнаменатель 	= ПредКоэффициентЗнаменатель;
							НСтр.СтавкаРефинансирования 	= СтавкаРефинансирования;
							НСтр.ПроцентПени = 0;
						КонецЕсли;
						НСтр.СуммаЗадолженности 		= СуммаЗадолженности;
						НСтр.ДнейПросрочки 				= ДнейПросрочки;
													
						Если ВыборкаДетальныеЗаписи.ВариантРасчета = Перечисления.бестВариантыРасчетаПени.ОтСтавкиРефинансирования Тогда
							НСтр.СуммаПени 				= НСтр.СуммаЗадолженности * (НСтр.КоэффициентЧислитель / НСтр.КоэффициентЗнаменатель) * НСтр.СтавкаРефинансирования / 100 * НСтр.ДнейПросрочки;
						ИначеЕсли ВыборкаДетальныеЗаписи.ВариантРасчета = Перечисления.бестВариантыРасчетаПени.ОтСуммы Тогда
							НСтр.СуммаПени 				= НСтр.СуммаЗадолженности * ВыборкаДетальныеЗаписи.ПроцентПени / 100 * НСтр.ДнейПросрочки;
						КонецЕсли;
						НСтр.СуммаПениНДС 				= НСтр.СуммаПени - (НСтр.СуммаПени / (1 + ВыборкаДетальныеЗаписи.СтавкаНДС / 100));
						ДнейПросрочки 					= 0;
					КонецЕсли;
					
					ПредыдущийРанг 				= РангКоэффициента;
					ПредКоэффициентЧислитель 	= КоэффициентЧислитель;
					ПредКоэффициентЗнаменатель 	= КоэффициентЗнаменатель;
					ДеньНачалаДляРасчета 		= ДеньНачалаДляРасчета + 1;
					
				КонецЦикла;
				Если ДнейПросрочки > 0 Тогда
					НСтр = ДокументОбъект.Пеня.Добавить();
					ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
					НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ВыборкаДетальныеЗаписи.ДнейПросрочкиСДатыНачалаНачисленийПени;
					Если ВыборкаДетальныеЗаписи.ВариантРасчета = Перечисления.бестВариантыРасчетаПени.ОтСтавкиРефинансирования Тогда
						НСтр.КоэффициентЧислитель 		= ПредКоэффициентЧислитель;
						НСтр.КоэффициентЗнаменатель 	= ПредКоэффициентЗнаменатель;
						НСтр.СтавкаРефинансирования 	= СтавкаРефинансирования;
						НСтр.ПроцентПени = 0;
					КонецЕсли;
					НСтр.СуммаЗадолженности 		= СуммаЗадолженности;
					НСтр.ДнейПросрочки 				= ?(ВыборкаДетальныеЗаписи.ЭтоОплата, ДнейПросрочки - 1, ДнейПросрочки);							
					Если ВыборкаДетальныеЗаписи.ВариантРасчета = Перечисления.бестВариантыРасчетаПени.ОтСтавкиРефинансирования Тогда
						НСтр.СуммаПени 				= НСтр.СуммаЗадолженности * (НСтр.КоэффициентЧислитель / НСтр.КоэффициентЗнаменатель) * НСтр.СтавкаРефинансирования / 100 * НСтр.ДнейПросрочки;
					ИначеЕсли ВыборкаДетальныеЗаписи.ВариантРасчета = Перечисления.бестВариантыРасчетаПени.ОтСуммы Тогда
						НСтр.СуммаПени 				= НСтр.СуммаЗадолженности * ВыборкаДетальныеЗаписи.ПроцентПени / 100 * НСтр.ДнейПросрочки;
					КонецЕсли;
					НСтр.СуммаПениНДС 				= НСтр.СуммаПени - (НСтр.СуммаПени / (1 + ВыборкаДетальныеЗаписи.СтавкаНДС / 100));
					ДеньНачалаДляРасчета 			= ВыборкаДетальныеЗаписи.ДнейНаДеньНачала + 1;
				КонецЕсли;
			КонецЦикла;				
		КонецЦикла;
		НачатьТранзакцию();
		Попытка
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			мСозданныеДокументы.Добавить(ДокументОбъект.Ссылка);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ЗаписьЖурналаРегистрации(НСтр("ru = 'Не удалось провести платежный документ!'"),
									 УровеньЖурналаРегистрации.Ошибка,
									 ,
									 ,
									 ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			КоличествоНепроведенныхПД = КоличествоНепроведенныхПД + 1;
		КонецПопытки;
	КонецЦикла;
	СтруктураВозврат.Вставить("КоличествоНеПроведенныхПД", КоличествоНеПроведенныхПД);
	СтруктураВозврат.Вставить("СозданныеДокументы", мСозданныеДокументы);
	Возврат СтруктураВозврат;
		
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Перерасчитывает сумму.
//
// Параметры:
//  СтрокаПотерь		-	ДанныеФормыЭлементКоллекции.
//  СтрокаНабора		-	ДанныеФормыЭлементКоллекции.
//  КоэффициентПериода	-	Число.
//
Процедура ПерерасчитатьСуммы(СтрокаПотерь, СтрокаНабора, КоэффициентПериода) Экспорт
	
		ОбъемУслуги 				= СтрокаПотерь.ОбъемУслуги * КоэффициентПериода;
				
		СтрокаПотерь.Сумма						= Окр((СтрокаПотерь.ОбъемУслуги + СтрокаНабора.ОбъемУслуги) * СтрокаПотерь.Тариф, 2) - СтрокаНабора.Сумма;
		СтрокаПотерь.СуммаЗаСбытовуюНадбавку  	= Окр(СтрокаПотерь.ОбъемУслуги * СтрокаПотерь.ТарифЗаСбытовуюНадбавку, 2);
		СтрокаПотерь.СуммаЗаУслугиПоПередачи  	= Окр(СтрокаПотерь.ОбъемУслуги * СтрокаПотерь.ТарифЗаУслугиПоПередачи, 2);
		СтрокаПотерь.СуммаЗаИныеУслуги  		= Окр(СтрокаПотерь.ОбъемУслуги * СтрокаПотерь.ТарифНаИныеУслуги, 2);		
		СтрокаПотерь.СуммаЗаСбытовуюНадбавкуПокупатель = Окр(СтрокаПотерь.ОбъемУслуги * СтрокаПотерь.ТарифЗаСбытовуюНадбавкуПокупатель, 2);
		
		СтрокаПотерь.СуммаСредневзвешенная		= СтрокаПотерь.Сумма - СтрокаПотерь.СуммаЗаСбытовуюНадбавку 
			- СтрокаПотерь.СуммаЗаУслугиПоПередачи - СтрокаПотерь.СуммаЗаИныеУслуги - СтрокаПотерь.СуммаЗаСбытовуюНадбавкуПокупатель;
		
		Если СтрокаПотерь.НДСВнутри Тогда
			СтрокаПотерь.СуммаНДС					 	= СтрокаПотерь.Сумма * СтрокаПотерь.СтавкаНДС / (100 + СтрокаПотерь.СтавкаНДС);
		Иначе
			СтрокаПотерь.СуммаНДС					 	= СтрокаПотерь.Сумма * СтрокаПотерь.СтавкаНДС / 100;
		КонецЕсли;
		
		Если СтрокаПотерь.НДСВнутри Тогда
			СтрокаПотерь.СуммаСредневзвешеннаяНДС		= СтрокаПотерь.СуммаСредневзвешенная * СтрокаПотерь.СтавкаНДС / (100 + СтрокаПотерь.СтавкаНДС);
		Иначе
			СтрокаПотерь.СуммаСредневзвешеннаяНДС		= СтрокаПотерь.СуммаСредневзвешенная * СтрокаПотерь.СтавкаНДС / 100;
		КонецЕсли;
	
		Если СтрокаПотерь.НДСВнутриСбытоваяНадбавка Тогда
			СтрокаПотерь.СуммаЗаСбытовуюНадбавкуНДС 	= СтрокаПотерь.СуммаЗаСбытовуюНадбавку * СтрокаПотерь.СтавкаНДС / (100 + СтрокаПотерь.СтавкаНДС);
			СтрокаПотерь.СуммаЗаСбытовуюНадбавкуНДСПокупатель 	= СтрокаПотерь.СуммаЗаСбытовуюНадбавкуПокупатель * СтрокаПотерь.СтавкаНДС / (100 + СтрокаПотерь.СтавкаНДС);
		Иначе
			СтрокаПотерь.СуммаЗаСбытовуюНадбавкуНДС 	= СтрокаПотерь.СуммаЗаСбытовуюНадбавку * СтрокаПотерь.СтавкаНДС / 100;
			СтрокаПотерь.СуммаЗаСбытовуюНадбавкуНДСПокупатель 	= СтрокаПотерь.СуммаЗаСбытовуюНадбавкуПокупатель * СтрокаПотерь.СтавкаНДС / 100;
		КонецЕсли;
		
		Если СтрокаПотерь.НДСВнутриУслугиПоПередачи Тогда
			СтрокаПотерь.СуммаЗаУслугиПоПередачиНДС 	= СтрокаПотерь.СуммаЗаУслугиПоПередачи * СтрокаПотерь.СтавкаНДС / (100 + СтрокаПотерь.СтавкаНДС);
		Иначе
			СтрокаПотерь.СуммаЗаУслугиПоПередачиНДС 	= СтрокаПотерь.СуммаЗаУслугиПоПередачи * СтрокаПотерь.СтавкаНДС / 100;
		КонецЕсли;

		Если СтрокаПотерь.НДСВнутриИныеУслуги Тогда
			СтрокаПотерь.СуммаЗаИныеУслугиНДС 			= СтрокаПотерь.СуммаЗаИныеУслуги * СтрокаПотерь.СтавкаНДС / (100 + СтрокаПотерь.СтавкаНДС);
		Иначе
			СтрокаПотерь.СуммаЗаИныеУслугиНДС 			= СтрокаПотерь.СуммаЗаИныеУслуги * СтрокаПотерь.СтавкаНДС / 100;
		КонецЕсли;
		
КонецПроцедуры

// Формирует МВТ с индивидуальными начислениями НП.
//
// Параметры:
//  МВТ						-	МенеджерВременныхТаблиц.
//  ПериодНачисления		-	Дата.
//  Организация				-	СправочникСсылка.Организации.
//  Район						СправочникСсылка.энргЗоныОтвественности.
//  ИсключаяОтдельностоящие	-	Булево.
//  МКД						-	СправочникСсылка.энргСтроения.
//  мОбъектыРасчета			-	Массив из СправочникСсылка.бестОбъектыРасчета.
//  НачалоПериодаРасчета	-	Дата.
//  КонецПериодаРасчета		-	Дата.
//  ПериодНовогоТарифа		-	Дата.
//  ДнейВПериоде			-	Число.
//  Перерасчет				-	Булево.
//
Процедура СформироватьМВТСДаннымиИндивидуальныеНачисленияНП(МВТ,ПериодНачисления,Организация,Район,ИсключаяОтдельностоящие, МКД, мОбъектыРасчета,НачалоПериодаРасчета,КонецПериодаРасчета,ПериодНовогоТарифа,ДнейВПериоде,Перерасчет) Экспорт
		
	ВспомогательныеДанныеНачисленияНП(МВТ,Организация, ПериодНачисления,Район,ИсключаяОтдельностоящие, МКД, мОбъектыРасчета,НачалоПериодаРасчета,КонецПериодаРасчета,ПериодНовогоТарифа,ДнейВПериоде,Перерасчет);
	ПолучитьСтабильныеПериодыНП(МВТ);
	ПолучитьДанныеДляРасчетаНП(МВТ,ЛОЖЬ);	
	
КонецПроцедуры

// Получает результат запроса по начислению электроэнергии.
//
// Параметры:
//  МВТ						-	МенеджерВременныхТаблиц.
//  НачалоПериодаРасчета	-	Дата.
//  КонецПериодаРасчета		-	Дата.
//  ПереопределяемыеТаблицы	-	Структура.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция РезультатЗапросаНачислениеПоЭлектроэнергии(МВТ, НачалоПериодаРасчета, КонецПериодаРасчета, ПереопределяемыеТаблицы = Неопределено) Экспорт
	СтруктураЦК = бестНачисленияПовтИспНП.ПолучитьЦКДляРасчета();
	ВыполнитьРасчетПоЭлектроэнергии(МВТ, НачалоПериодаРасчета, КонецПериодаРасчета, СтруктураЦК, ПереопределяемыеТаблицы);
	ВыполнитьРасчетПоМощности(МВТ, СтруктураЦК);

	Возврат ВыполнитьДосчетыИРассчитатьИтог(МВТ, СтруктураЦК);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбщиеПроцедурыИФункции

Процедура ВспомогательныеДанныеНачисленияНП(МВТ,Организация,ПериодНачисления,Район,ИсключаяОтдельностоящие, МКД, мОбъектыРасчета,НачалоПериодаРасчета,КонецПериодаРасчета,ПериодНовогоТарифа,ДнейВПериоде,Перерасчет = Ложь)
	
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;	 	
	
	
	Запрос.УстановитьПараметр("НачалоВеденияУчета",							Константы.энргДатаНачалаВеденияУчета.Получить());	
	Запрос.УстановитьПараметр("НачалоПериодаРасчетаМинусСекунда",			НачалоПериодаРасчета - 1);	
	Запрос.УстановитьПараметр("НачалоПериодаРасчета",						НачалоПериодаРасчета);	 
	Запрос.УстановитьПараметр("КонецПериодаРасчета",						КонецПериодаРасчета);
	КонецПериодаРасчетаРегистр = КонецПериодаРасчета - 1;
	Запрос.УстановитьПараметр("КонецПериодаРасчетаРегистр",					КонецПериодаРасчетаРегистр);
	КонецПериодаРасчетаГраница = Новый Граница(КонецПериодаРасчетаРегистр, ВидГраницы.Исключая);
	Запрос.УстановитьПараметр("КонецПериодаРасчетаГраница",					КонецПериодаРасчетаГраница);
	Запрос.УстановитьПараметр("ПериодНачисления",							ПериодНачисления);
	Запрос.УстановитьПараметр("Организация",								Организация);	 
	Запрос.УстановитьПараметр("Район",										Район);	 
	Запрос.УстановитьПараметр("мОбъектыРасчета",							мОбъектыРасчета);
	Запрос.УстановитьПараметр("ДнейВПериоде",								ДнейВПериоде );
	Запрос.УстановитьПараметр("ПериодНовогоТарифа",							ПериодНовогоТарифа);
	Запрос.УстановитьПараметр("НачалоПредПериодаРасчета",					НачалоМесяца(ДобавитьМесяц(ПериодНачисления, -1))); 
	Запрос.УстановитьПараметр("ПроектнаяТемператураПоУмолчанию", 			Константы.бестПроектнаяТемператураНаружногоВоздухаПоУмолчанию.Получить());
	Запрос.УстановитьПараметр("ТемператураВнутриПомещенияПоУмолчанию", 		Константы.бестТемператураВнутриПомещенияПоУмолчанию.Получить());
	Запрос.УстановитьПараметр("МКД",										МКД);
	Запрос.УстановитьПараметр("ИспользоватьДанныеДляРасчетаТепловойЭнергии",Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("бестИспользоватьДанныеДляРасчетаТепловойЭнергииТеплоносителяИХВСЮЛ"));
	ПериодНачисленияПрошлыйГод = ДобавитьМесяц(ПериодНачисления, -12);
	Запрос.УстановитьПараметр("НачалоПериодаРасчетаПрошлыйГод",				НачалоМесяца(ПериодНачисленияПрошлыйГод));	 
	Запрос.УстановитьПараметр("КонецПериодаРасчетаПрошлыйГод",				ДобавитьМесяц(ПериодНачисленияПрошлыйГод, 1));
	
	Запрос.Текст 	= ТекстЗапросаВспомогательныеДанныеНачисления(ИсключаяОтдельностоящие, МКД, мОбъектыРасчета);
	
	Если Перерасчет Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестСтабильныеПериодыНП",				"бестСтабильныеПериодыНППерерасчет");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестСтабильныеПериодыШкалыНП",		"бестСтабильныеПериодыШкалыНППерерасчет");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестНомераСтрокСтабильногоПериодаНП",	"бестНомераСтрокСтабильногоПериодаНППерерасчет");
	КонецЕсли;
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура ПолучитьСтабильныеПериодыНП(МВТ)  
	
	Текст 							= ТекстПолучитьСтабильныеПериоды();
	Запрос  						= Новый Запрос(Текст);
	Запрос.УстановитьПараметр("НачалоВеденияУчета", Константы.энргДатаНачалаВеденияУчета.Получить());
	Запрос.УстановитьПараметр("ТемператураВнутриПомещенияПоУмолчанию", Константы.бестТемператураВнутриПомещенияПоУмолчанию.Получить());
	
	Запрос.МенеджерВременныхТаблиц	= МВТ;
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура ПолучитьДанныеДляРасчетаНП(МВТ,РасчетПоФормуле)
	
	Текст 							= ТекстЗапросаПолучитьДанныеДляРасчетаНП(РасчетПоФормуле);
	Запрос  						= Новый Запрос(Текст); 	
	Запрос.УстановитьПараметр("ПроектнаяТемператураПоУмолчанию", Константы.бестПроектнаяТемператураНаружногоВоздухаПоУмолчанию.Получить());
	
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Запрос.Выполнить();
	
КонецПроцедуры

Функция РассчитатьИндивидуальныйОбъемПотребленияНП(МВТ,РасчетПоФормуле); 
	
	Текст  							= ТекстРассчитатьИндивидуальныйОбъемПотребленияНП();
	Запрос  						= Новый Запрос(Текст);
	Запрос.УстановитьПараметр("РасчетПоФормуле",РасчетПоФормуле);
	
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция ОтформатироватьЧисловойПараметр(Параметр)
	Если ЗначениеЗаполнено(Параметр) Тогда
		Возврат СтрЗаменить(Строка(Параметр),",",".");
	Иначе
		Возврат	"0";
	КонецЕсли;
КонецФункции

Функция ПолучитьОтрицательныеОбъемыПредыдущихПериодов(МВТ, НачалоПериодаРасчета)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестОтрицательныеОбъемыДолевыхСхемОстатки.ТочкаУчета КАК ТочкаУчета,
		|	бестОтрицательныеОбъемыДолевыхСхемОстатки.Услуга КАК Услуга,
		|	бестОтрицательныеОбъемыДолевыхСхемОстатки.ТарифнаяЗона КАК ТарифнаяЗона,
		|	бестОтрицательныеОбъемыДолевыхСхемОстатки.ОбъемУслугиОстаток КАК ОбъемУслуги
		|ИЗ
		|	РегистрНакопления.бестОтрицательныеОбъемыДолевыхСхем.Остатки(
		|			&НачалоПериодаРасчета,
		|			(Организация, Район, МКД, ОбъектРасчета, ТочкаУчета, Услуга, ТарифнаяЗона) В
		|				(ВЫБРАТЬ
		|					ОбщийИтог.Организация КАК Организация,
		|					ОбщийИтог.Район КАК Район,
		|					ОбщийИтог.МКД КАК МКД,
		|					ОбщийИтог.ОбъектРасчета КАК ОбъектРасчета,
		|					ОбщийИтог.ТочкаУчета КАК ТочкаУчета,
		|					ОбщийИтог.Услуга КАК Услуга,
		|					ОбщийИтог.ТарифнаяЗона КАК ТарифнаяЗона
		|				ИЗ
		|					ОбщийИтог КАК ОбщийИтог)) КАК бестОтрицательныеОбъемыДолевыхСхемОстатки";
	
	Запрос.УстановитьПараметр("НачалоПериодаРасчета", НачалоПериодаРасчета);
	
	Возврат Запрос.Выполнить();
		
КонецФункции

#КонецОбласти 

#Область ТекстЗапросов

Функция ТекстЗапросаВспомогательныеДанныеНачисления(ИсключаяОтдельностоящие, МКД, мОбъектыРасчета)
	Текст =  
	"ВЫБРАТЬ
	|	&ПериодНачисления КАК ПериодНачисления,
	|	энгрЗначенияПовышающихКоэффициентовСрезПоследних.Организация КАК Организация,
	|	энгрЗначенияПовышающихКоэффициентовСрезПоследних.Район КАК Район,
	|	энгрЗначенияПовышающихКоэффициентовСрезПоследних.Коэффициент КАК Коэффициент,
	|	энгрЗначенияПовышающихКоэффициентовСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ ЗначенияПовышающихКоэффициентов
	|ИЗ
	|	РегистрСведений.энгрЗначенияПовышающихКоэффициентов.СрезПоследних(
	|			&КонецПериодаРасчетаРегистр,
	|			Организация = &Организация
	|				И Район = &Район
	|				И НаправлениеИспользованияТУ = ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление)) КАК энгрЗначенияПовышающихКоэффициентовСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&ПериодНачисления КАК ПериодНачисления,
	|	энргЗначенияНормативовПотребленияСрезПоследних.Организация КАК Организация,
	|	энргЗначенияНормативовПотребленияСрезПоследних.Район КАК Район,
	|	энргЗначенияНормативовПотребленияСрезПоследних.КлючНорматива КАК КлючНорматива,
	|	энргЗначенияНормативовПотребленияСрезПоследних.Услуга КАК Услуга,
	|	энргЗначенияНормативовПотребленияСрезПоследних.ТипНачисления КАК ТН_Норматива,
	|	энргЗначенияНормативовПотребленияСрезПоследних.ЗначениеНорматива КАК ЗначениеНорматива
	|ПОМЕСТИТЬ ЗначенияТекущихНормПотребления
	|ИЗ
	|	РегистрСведений.энргЗначенияНормативовПотребления.СрезПоследних(
	|			&КонецПериодаРасчетаРегистр,
	|			Организация = &Организация
	|				И Район = &Район
	|				И НаправлениеИспользованияТУ = Значение(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление)
	|				И ТипНачисления В (ЗНАЧЕНИЕ(Перечисление.энргТипыНачислений.ИндивидуальныеНачисления), ЗНАЧЕНИЕ(Перечисление.энргТипыНачислений.ОтдельностояющиеОбъекты))) КАК энргЗначенияНормативовПотребленияСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргНормаСкоростиДвиженияВодыСрезПоследних.Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	энргНормаСкоростиДвиженияВодыСрезПоследних.СкоростьДвижения КАК СкоростьДвижения
	|ПОМЕСТИТЬ НормаСкоростиДвиженияВоды
	|ИЗ
	|	РегистрСведений.энргНормаСкоростиДвиженияВоды.СрезПоследних(&КонецПериодаРасчетаРегистр, Организация = &Организация) КАК энргНормаСкоростиДвиженияВодыСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НастройкаСезонностиУслуг.Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	НастройкаСезонностиУслуг.Район КАК Район,
	|	НастройкаСезонностиУслуг.Услуга КАК Услуга,
	|	НастройкаСезонностиУслуг.НеПрименятьСезонность КАК НеПрименятьСезонность,
	|	НастройкаСезонностиУслуг.Коэффициент КАК КоэффициентНорматива,
	|	НастройкаСезонностиУслуг.ОбъемЗаПрошлыйГод КАК ОбъемЗаПрошлыйГод,
	|	НастройкаСезонностиУслуг.МКД КАК Строение,
	|	НастройкаСезонностиУслуг.КоэффициентНеПрименятьСезонность КАК КоэффициентНеПрименятьСезонность
	|ПОМЕСТИТЬ УслугиНеПрименятьСезонность
	|ИЗ
	|	РегистрСведений.энргНастройкаСезонностиУслуг.СрезПоследних(
	|			&КонецПериодаРасчетаРегистр,
	|			Организация = &Организация
	|				И Район = &Район
	|				И НаправлениеИспользованияТУ = ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление)) КАК НастройкаСезонностиУслуг
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестГарантированныеОбъемыСрезПоследних.Организация КАК Организация,
	|	бестГарантированныеОбъемыСрезПоследних.Район КАК Район,
	|	бестГарантированныеОбъемыСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестГарантированныеОбъемыСрезПоследних.Услуга КАК Услуга,
	|	бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги КАК ОбъемУслуги
	|ПОМЕСТИТЬ ГарантированныеОбъемы
	|ИЗ
	|	РегистрСведений.бестГарантированныеОбъемы.СрезПоследних(
	|			&КонецПериодаРасчетаРегистр,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И ОбъектРасчета В (&мОбъектыРасчета)
	|				И Месяц = МЕСЯЦ(&ПериодНачисления)) КАК бестГарантированныеОбъемыСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргНастройкаНачисленияГВСМКДСрезПоследних.Организация КАК Организация,
	|	энргНастройкаНачисленияГВСМКДСрезПоследних.Район КАК Район,
	|	энргНастройкаНачисленияГВСМКДСрезПоследних.МКД КАК МКД,
	|	энргНастройкаНачисленияГВСМКДСрезПоследних.Услуга КАК Услуга,
	|	энргНастройкаНачисленияГВСМКДСрезПоследних.ТипСхемы КАК ТипСхемы,
	|	энргНастройкаНачисленияГВСМКДСрезПоследних.ПринадлежностьКТепловомуПункту КАК ПринадлежностьКТепловомуПункту,
	|	энргНастройкаНачисленияГВСМКДСрезПоследних.НеНачислять КАК НеНачислять
	|ПОМЕСТИТЬ МКДНеНачислятьТЭ
	|ИЗ
	|	РегистрСведений.энргНастройкаНачисленияГВСМКД.СрезПоследних(&КонецПериодаРасчетаРегистр, НеНачислять И МКД = &МКД) КАК энргНастройкаНачисленияГВСМКДСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестТемператураИсточникаСрезПоследних.Организация КАК Организация,
	|	бестТемператураИсточникаСрезПоследних.Район КАК Район,
	|	бестТемператураИсточникаСрезПоследних.Источник КАК Источник,
	|	бестТемператураИсточникаСрезПоследних.ТемператураПодачиИсточника КАК ТемператураПодачиИсточника,
	|	бестТемператураИсточникаСрезПоследних.ТемператураХолоднойВодыИсточника КАК ТемператураХолоднойВодыИсточника
	|ПОМЕСТИТЬ ТемпературыИсточника
	|ИЗ
	|	РегистрСведений.бестТемператураИсточника.СрезПоследних(
	|			&КонецПериодаРасчетаРегистр,
	|			Организация = &Организация
	|				И Район = &Район) КАК бестТемператураИсточникаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Сезонность КАК Сезонность,
	|	ВложенныйЗапрос.НачалоФактическогоПериода КАК НачалоФактическогоПериода,
	|	ВложенныйЗапрос.КонецФактическогоПериода КАК КонецФактическогоПериода,
	|	энргВидыУслуг.Ссылка КАК Услуга,
	|	энргВидыУслуг.СезонностьНастраивается КАК СезонностьНастраивается
	|ПОМЕСТИТЬ ДлительностьПериодов
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.Сезонность КАК Сезонность,
	|		ВЫБОР
	|			КОГДА &НачалоПериодаРасчета МЕЖДУ ВложенныйЗапрос.НачалоПериодаДействия И ВложенныйЗапрос.КонецПериодаДействия
	|					ИЛИ &КонецПериодаРасчета МЕЖДУ ВложенныйЗапрос.НачалоПериодаДействия И ВложенныйЗапрос.КонецПериодаДействия
	|				ТОГДА ВЫБОР
	|						КОГДА &НачалоПериодаРасчета > ВложенныйЗапрос.НачалоПериодаДействия
	|							ТОГДА &НачалоПериодаРасчета
	|						ИНАЧЕ ВложенныйЗапрос.НачалоПериодаДействия
	|					КОНЕЦ
	|			ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|		КОНЕЦ КАК НачалоФактическогоПериода,
	|		ВЫБОР
	|			КОГДА &НачалоПериодаРасчета МЕЖДУ ВложенныйЗапрос.НачалоПериодаДействия И ВложенныйЗапрос.КонецПериодаДействия
	|					ИЛИ &КонецПериодаРасчета МЕЖДУ ВложенныйЗапрос.НачалоПериодаДействия И ВложенныйЗапрос.КонецПериодаДействия
	|				ТОГДА ВЫБОР
	|						КОГДА &КонецПериодаРасчета > ВложенныйЗапрос.КонецПериодаДействия
	|							ТОГДА ВложенныйЗапрос.КонецПериодаДействия
	|						ИНАЧЕ &КонецПериодаРасчета
	|					КОНЕЦ
	|			ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|		КОНЕЦ КАК КонецФактическогоПериода,
	|		ВложенныйЗапрос.НачалоПериодаДействия КАК НачалоПериодаДействия,
	|		ВложенныйЗапрос.КонецПериодаДействия КАК КонецПериодаДействия
	|	ИЗ
