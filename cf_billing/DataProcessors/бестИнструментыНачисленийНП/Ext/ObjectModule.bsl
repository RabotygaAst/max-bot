	|	УслугиСУчетомСезонности.Услуга
	|ИЗ
	|	УслугиСУчетомСезонности КАК УслугиСУчетомСезонности
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОтопительныйПериод КАК ОтопительныйПериод
	|		ПО УслугиСУчетомСезонности.Услуга = ОтопительныйПериод.Услуга
	|			И (ОтопительныйПериод.НачалоПериодаДействия > &НачалоПериодаРасчета)
	|			И (ОтопительныйПериод.НачалоПериодаДействия < &КонецПериодаРасчета) 
	|ГДЕ ОтопительныйПериод.НачалоПериодаДействия есть NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СобытияТУТекПериод.ТочкаУчета КАК ТочкаУчета,
	|	СобытияТУТекПериод.Период КАК Период,
	|	МИНИМУМ(СобытияТУТекПериод.Состояние) КАК Состояние,
	|	СобытияТУТекПериод.Услуга КАК Услуга
	|ПОМЕСТИТЬ СобытияТУТекПериодГрупп
	|ИЗ
	|	СобытияТУТекПериод КАК СобытияТУТекПериод
	|
	|СГРУППИРОВАТЬ ПО
	|	СобытияТУТекПериод.ТочкаУчета,
	|	СобытияТУТекПериод.Период,
	|	СобытияТУТекПериод.Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СобытияТУТекПериодГрупп.ТочкаУчета КАК ТочкаУчета,
	|	СобытияТУТекПериодГрупп.Период КАК Период,
	|	КОЛИЧЕСТВО(СобытияТУТекПериодГрупп1.Период) КАК ПорядковыйНомер,
	|	СобытияТУТекПериодГрупп.Услуга КАК Услуга
	|ПОМЕСТИТЬ СостояниеТУНомерСтроки
	|ИЗ
	|	СобытияТУТекПериодГрупп КАК СобытияТУТекПериодГрупп
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СобытияТУТекПериодГрупп КАК СобытияТУТекПериодГрупп1
	|		ПО СобытияТУТекПериодГрупп.Период >= СобытияТУТекПериодГрупп1.Период
	|			И СобытияТУТекПериодГрупп.ТочкаУчета = СобытияТУТекПериодГрупп1.ТочкаУчета
	|			И СобытияТУТекПериодГрупп.Услуга = СобытияТУТекПериодГрупп1.Услуга
	|
	|СГРУППИРОВАТЬ ПО
	|	СобытияТУТекПериодГрупп.ТочкаУчета,
	|	СобытияТУТекПериодГрупп.Период,
	|	СобытияТУТекПериодГрупп.Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СобытияТУТекПериодГрупп.ТочкаУчета КАК ТочкаУчета,
	|	СобытияТУТекПериодГрупп.Период КАК Период,
	|	СобытияТУТекПериодГрупп.Состояние КАК Состояние,
	|	СостояниеТУНомерСтроки.ПорядковыйНомер КАК ПорядковыйНомер,
	|	СобытияТУТекПериодГрупп.Услуга КАК Услуга
	|ПОМЕСТИТЬ СостояниеТУПорядок
	|ИЗ
	|	СобытияТУТекПериодГрупп КАК СобытияТУТекПериодГрупп
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СостояниеТУНомерСтроки КАК СостояниеТУНомерСтроки
	|		ПО СобытияТУТекПериодГрупп.ТочкаУчета = СостояниеТУНомерСтроки.ТочкаУчета
	|			И СобытияТУТекПериодГрупп.Период = СостояниеТУНомерСтроки.Период
	|			И СобытияТУТекПериодГрупп.Услуга = СостояниеТУНомерСтроки.Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СостояниеТУНачало.ТочкаУчета КАК ТочкаУчета,
	|	СостояниеТУНачало.Период КАК НачалоПериода,
	|	ВЫБОР
	|		КОГДА СостояниеТУКонец.Период ЕСТЬ NULL
	|			ТОГДА &КонецПериодаРасчета
	|		ИНАЧЕ СостояниеТУКонец.Период
	|	КОНЕЦ КАК КонецПериода,
	|	СостояниеТУНачало.Состояние КАК Состояние,
	|	СостояниеТУНачало.Услуга КАК Услуга
	|ПОМЕСТИТЬ ПериодыСостоянияТУ
	|ИЗ
	|	СостояниеТУПорядок КАК СостояниеТУНачало
	|		ЛЕВОЕ СОЕДИНЕНИЕ СостояниеТУПорядок КАК СостояниеТУКонец
	|		ПО СостояниеТУНачало.ТочкаУчета = СостояниеТУКонец.ТочкаУчета
	|			И (СостояниеТУНачало.ПорядковыйНомер = СостояниеТУКонец.ПорядковыйНомер - 1)
	|			И СостояниеТУНачало.Услуга = СостояниеТУКонец.Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПериодыСостоянияТУ.ТочкаУчета КАК ТочкаУчета,
	|	ПериодыСостоянияТУ.НачалоПериода КАК НачалоПериода,
	|	ПериодыСостоянияТУ.КонецПериода КАК КонецПериода,
	|	СУММА(ВЫБОР
	|			КОГДА НЕ ПериодыСостоянияТУ.Состояние
	|				ТОГДА 0
	|			КОГДА ПериодыСостоянияТУ.КонецПериода <> &КонецПериодаРасчета
	|				ТОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ПериодыСостоянияТУ.НачалоПериода, ЧАС), НАЧАЛОПЕРИОДА(ПериодыСостоянияТУ.КонецПериода, ЧАС), ЧАС)
	|			ИНАЧЕ РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ПериодыСостоянияТУ.НачалоПериода, ЧАС), НАЧАЛОПЕРИОДА(ПериодыСостоянияТУ.КонецПериода, ЧАС), ЧАС)
	|		КОНЕЦ) КАК КоличествоЧасов,
	|	ПериодыСостоянияТУ.Услуга КАК Услуга
	|ПОМЕСТИТЬ КоличествоЧасовРаботыТУТекПериод
	|ИЗ
	|	ПериодыСостоянияТУ КАК ПериодыСостоянияТУ
	|
	|СГРУППИРОВАТЬ ПО
	|	ПериодыСостоянияТУ.ТочкаУчета,
	|	ПериодыСостоянияТУ.Услуга,
	|	ПериодыСостоянияТУ.НачалоПериода,
	|	ПериодыСостоянияТУ.КонецПериода
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";
	
	Текст = Текст + Символы.ПС + ТекстЗапросаВспомогательныеДанныеЭЭ();
	
	Если ИсключаяОтдельностоящие тогда
		Текст 		= СтрЗаменить(Текст,"бестПредоставленныеПоказанияНП.МКД = &МКД","бестПредоставленныеПоказанияНП.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестМаксимальныеПоказанияСрезНП.МКД = &МКД","бестМаксимальныеПоказанияСрезНП.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестСреднийОбъемПотребленияНП.МКД = &МКД","бестСреднийОбъемПотребленияНП.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"энргСтабильныеПериодыМКД.МКД = &МКД","энргСтабильныеПериодыМКД.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестСтабильныеПериодыНП.МКД = &МКД","бестСтабильныеПериодыНП.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"энргСтабильныеПериоды.Строение = &МКД","энргСтабильныеПериоды.Строение <> &МКД");
		Текст 		= СтрЗаменить(Текст,"энргСтабильныеПериоды.Строение = &МКД","энргСтабильныеПериоды.Строение <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестСтабильныеПериодыШкалыНП.МКД = &МКД","бестСтабильныеПериодыШкалыНП.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестВыводПриборовУчетаНП.МКД = &МКД","бестВыводПриборовУчетаНП.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестОбъемНачисленийНП.МКД = &МКД","бестОбъемНачисленийНП.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестНомераСтрокСтабильногоПериодаНП.МКД = &МКД","бестНомераСтрокСтабильногоПериодаНП.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестЗарегистрированныеОбъемыПотребленияНП.МКД = &МКД","бестЗарегистрированныеОбъемыПотребленияНП.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестЗарегистрированноеБезучетноеБездоговорноеПотребление.МКД = &МКД","бестЗарегистрированноеБезучетноеБездоговорноеПотребление.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестДанныеПочасовойВедомости.МКД = &МКД","бестДанныеПочасовойВедомости.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестНедопущенныеТУ.МКД = &МКД","бестНедопущенныеТУ.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"бестОбъемНачисленийЭлектроэнергии.МКД = &МКД","бестОбъемНачисленийЭлектроэнергии.МКД <> &МКД"); 
		Текст 		= СтрЗаменить(Текст,"бестОбъемНачисленийЭлектроэнергии.МКД = &МКД","бестОбъемНачисленийЭлектроэнергии.МКД <> &МКД");
		
		Текст 		= СтрЗаменить(Текст,"МКД = &МКД","МКД <> &МКД");
	Иначе
		Если МКД = Неопределено Тогда 
			Текст 		= СтрЗаменить(Текст,"бестПредоставленныеПоказанияНП.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестМаксимальныеПоказанияСрезНП.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестСреднийОбъемПотребленияНП.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"энргСтабильныеПериодыМКД.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестСтабильныеПериодыНП.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"энргСтабильныеПериоды.Строение = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"энргСтабильныеПериоды.Строение = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестСтабильныеПериодыШкалыНП.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестВыводПриборовУчетаНП.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестОбъемНачисленийНП.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестНомераСтрокСтабильногоПериодаНП.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестЗарегистрированныеОбъемыПотребленияНП.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестЗарегистрированноеБезучетноеБездоговорноеПотребление.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестДанныеПочасовойВедомости.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестНедопущенныеТУ.МКД = &МКД","ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"бестДанныеПочасовойВедомостиСрез.МКД = &МКД","ИСТИНА"); 
			Текст 		= СтрЗаменить(Текст,"бестОбъемНачисленийЭлектроэнергии.МКД = &МКД","ИСТИНА");
			
			Текст 		= СтрЗаменить(Текст,"МКД = &МКД","ИСТИНА");
		КонецЕсли;
	КонецЕсли;
	
	Если мОбъектыРасчета = Неопределено Тогда
		Текст 		= СтрЗаменить(Текст,"бестПредоставленныеПоказанияНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестМаксимальныеПоказанияСрезНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестПредоставленныеПоказанияНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестСреднийОбъемПотребленияНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестСтабильныеПериодыНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестСтабильныеПериодыШкалыНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестВыводПриборовУчетаНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестОбъемНачисленийНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестНомераСтрокСтабильногоПериодаНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестЗарегистрированныеОбъемыПотребленияНП.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестНедопущенныеТУ.ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестДанныеПочасовойВедомости.ОбъектРасчета В(&мОбъектыРасчета)","ИСТИНА");
		Текст 		= СтрЗаменить(Текст,"бестДанныеПочасовойВедомостиСрез.ОбъектРасчета В(&мОбъектыРасчета)","ИСТИНА"); 
		Текст 		= СтрЗаменить(Текст,"бестОбъемНачисленийЭлектроэнергии.ОбъектРасчета В(&мОбъектыРасчета)","ИСТИНА");
		
		Текст 		= СтрЗаменить(Текст,"ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
	КонецЕсли;
	Возврат Текст;	
	
КонецФункции

Функция ТекстПолучитьСтабильныеПериоды()  
	
	Текст 	=
	"ВЫБРАТЬ
	|	НомераСтрокНачалоСезонности.Организация КАК Организация,
	|	НомераСтрокНачалоСезонности.ПериодНачисления КАК ПериодНачисления,
	|	НомераСтрокНачалоСезонности.Район КАК Район,
	|	НомераСтрокНачалоСезонности.ОбъектРасчета КАК ОбъектРасчета,
	|	НомераСтрокНачалоСезонности.МКД КАК МКД,
	|	НомераСтрокНачалоСезонности.Услуга КАК Услуга,
	|	НомераСтрокНачалоСезонности.ТочкаУчета КАК ТочкаУчета,
	|	НомераСтрокНачалоСезонности.НомерПозиции КАК НомерПозиции,
	|	НомераСтрокНачалоСезонности.ПериодСезонности КАК ПериодСезонности
	|ПОМЕСТИТЬ НомераСтрокНачалоСезонностиБезФормулы
	|ИЗ
	|	НомераСтрокНачалоСезонности КАК НомераСтрокНачалоСезонности
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СтабильныеПериодыНачалоШкалы КАК СтабильныеПериодыНачало
	|		ПО НомераСтрокНачалоСезонности.Организация = СтабильныеПериодыНачало.Организация
	|			И НомераСтрокНачалоСезонности.ПериодНачисления = СтабильныеПериодыНачало.ПериодНачисления
	|			И НомераСтрокНачалоСезонности.Район = СтабильныеПериодыНачало.Район
	|			И НомераСтрокНачалоСезонности.МКД = СтабильныеПериодыНачало.МКД
	|			И НомераСтрокНачалоСезонности.ОбъектРасчета = СтабильныеПериодыНачало.ОбъектРасчета
	|			И НомераСтрокНачалоСезонности.Услуга = СтабильныеПериодыНачало.Услуга
	|			И НомераСтрокНачалоСезонности.ТочкаУчета = СтабильныеПериодыНачало.ТочкаУчета
	|			И НомераСтрокНачалоСезонности.НомерПозиции = СтабильныеПериодыНачало.НомерПозиции
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НомераСтрокКонецСезонности.Организация КАК Организация,
	|	НомераСтрокКонецСезонности.ПериодНачисления КАК ПериодНачисления,
	|	НомераСтрокКонецСезонности.Район КАК Район,
	|	НомераСтрокКонецСезонности.МКД КАК МКД,
	|	НомераСтрокКонецСезонности.ОбъектРасчета КАК ОбъектРасчета,
