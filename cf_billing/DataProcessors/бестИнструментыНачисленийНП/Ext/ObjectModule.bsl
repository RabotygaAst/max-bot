	Текст = ТекстЗапросаВспомогательныеДанныеЭЭ(Истина);
	
	Если мОбъектыРасчета = Неопределено Тогда

		Текст 		= СтрЗаменить(Текст,"ОбъектРасчета В (&мОбъектыРасчета)","ИСТИНА");
		
	Иначе
		
		Запрос.УстановитьПараметр("мОбъектыРасчета",  						мОбъектыРасчета);
		
	КонецЕсли;
	
	Если ИсключаяОтдельностоящие тогда
		Текст 		= СтрЗаменить(Текст, "бестДанныеПочасовойВедомостиСрез.МКД = &МКД", 
			"бестДанныеПочасовойВедомостиСрез.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст, "бестДанныеПочасовойВедомости.МКД = &МКД", 
			"бестДанныеПочасовойВедомости.МКД <> &МКД");
		Текст 		= СтрЗаменить(Текст,"МКД = &МКД","МКД <> &МКД");
	Иначе
		Если МКД = Неопределено Тогда 
			Текст 		= СтрЗаменить(Текст, "бестДанныеПочасовойВедомостиСрез.МКД = &МКД", "ИСТИНА");
			Текст 		= СтрЗаменить(Текст, "бестДанныеПочасовойВедомости.МКД = &МКД", "ИСТИНА");
			Текст 		= СтрЗаменить(Текст,"МКД = &МКД","ИСТИНА");
		КонецЕсли;
	КонецЕсли;
	
	Запрос.Текст = Текст;
	
	Запрос.УстановитьПараметр("НачалоПериодаРасчета", 						НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("КонецПериодаРасчета", 						КонецПериодаРасчета); 
	КонецПериодаРасчетаГраница = Новый Граница(КонецПериодаРасчета, ВидГраницы.Исключая);
	Запрос.УстановитьПараметр("КонецПериодаРасчетаГраница",					КонецПериодаРасчетаГраница);
	Запрос.УстановитьПараметр("Организация",  								Организация);
	Запрос.УстановитьПараметр("Район", 										Район);
	Запрос.УстановитьПараметр("МКД",  										МКД);
	Запрос.УстановитьПараметр("ПериодНачисления",  							ПериодНачисления);
	
	Запрос.Выполнить();
КонецПроцедуры

Функция РезультатЗапросаНачислениеПоДолевымСхемамЭлектроэнергии(Организация,Район, МКД,ИсключаяОтдельностоящие,НачалоПериодаРасчета,КонецПериодаРасчета,РазныеРО,ПериодНачисления,МВТ, ДопПараметры)
	СтруктураЦК = бестНачисленияПовтИспНП.ПолучитьЦКДляРасчета(); 
	ПараметрыРасчета = Новый Структура("Организация,Район,МКД,ИсключаяОтдельностоящие,НачалоПериодаРасчета,КонецПериодаРасчета,НачалоПериодаРасчетаФЛ,КонецПериодаРасчетаФЛ,РазныеРО,ПериодНачисления",
		Организация, Район, МКД, ИсключаяОтдельностоящие, НачалоПериодаРасчета, КонецПериодаРасчета, ДопПараметры.ГраницыПериодаФЛ.НачалоОП,ДопПараметры.ГраницыПериодаФЛ.ЗавершениеОП, РазныеРО, ПериодНачисления);
	ВыполнитьРасчетПоЭлектроэнергииДолевыеСхемы(МВТ, ПараметрыРасчета, СтруктураЦК);
	ВыполнитьРасчетПоМощности(МВТ, СтруктураЦК);

	Возврат ВыполнитьРассчитатьИтогДолевыеСхемы(МВТ, РазныеРО, КонецПериодаРасчета - 1);
		
КонецФункции

Процедура ВыполнитьРасчетПоЭлектроэнергииДолевыеСхемы(МВТ, ПараметрыРасчета, СтруктураЦК)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Текст = ТекстЗапросаДолевыеСхемыРасчетЭлектроэнергии(); 
	
	ТЗ_1Уровень = Новый Массив;
	ТЗ_1Уровень.Добавить(Справочники.энргТарифныеЗоны.БезРазбивки);
	ТЗ_2Уровень = Новый Массив;
	ТЗ_2Уровень.Добавить(Справочники.энргТарифныеЗоны.День);
	ТЗ_2Уровень.Добавить(Справочники.энргТарифныеЗоны.Ночь);
	ТЗ_3Уровень = Новый Массив;
	ТЗ_3Уровень.Добавить(Справочники.энргТарифныеЗоны.Пик);
	ТЗ_3Уровень.Добавить(Справочники.энргТарифныеЗоны.Полупик);
	ТЗ_3Уровень.Добавить(Справочники.энргТарифныеЗоны.НочьТрехЗонная);
	ТЗ_Ночь = Новый Массив;
	ТЗ_Ночь.Добавить(Справочники.энргТарифныеЗоны.Ночь);
	ТЗ_Ночь.Добавить(Справочники.энргТарифныеЗоны.НочьТрехЗонная);
	ТЗ_День = Новый Массив;
	ТЗ_День.Добавить(Справочники.энргТарифныеЗоны.Пик);
	ТЗ_День.Добавить(Справочники.энргТарифныеЗоны.Полупик);
		
	Запрос.УстановитьПараметр("НачалоПериодаРасчета", 	ПараметрыРасчета.НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("КонецПериодаРасчета",  	ПараметрыРасчета.КонецПериодаРасчета);
	Запрос.УстановитьПараметр("НачалоПериодаРасчетаФЛ", 	ПараметрыРасчета.НачалоПериодаРасчетаФЛ);
	Запрос.УстановитьПараметр("КонецПериодаРасчетаФЛ",  	ПараметрыРасчета.КонецПериодаРасчетаФЛ-1);
	Запрос.УстановитьПараметр("Организация", 			ПараметрыРасчета.Организация);
	Запрос.УстановитьПараметр("Район",  				ПараметрыРасчета.Район);
	Запрос.УстановитьПараметр("МКД",  					ПараметрыРасчета.МКД);
	Запрос.УстановитьПараметр("ТранзитИзРазныхРО",  	ПараметрыРасчета.РазныеРО);
	Запрос.УстановитьПараметр("ПериодНачисления",   	ПараметрыРасчета.ПериодНачисления);
	Запрос.УстановитьПараметр("ЦКДляРасчетаПоПочасовойВедомости", СтруктураЦК.ЦКДляРасчетаПоПочасовойВедомости);
	Запрос.УстановитьПараметр("ТЗ_1Уровень",  			ТЗ_1Уровень);
	Запрос.УстановитьПараметр("ТЗ_2Уровень",   			ТЗ_2Уровень);
	Запрос.УстановитьПараметр("ТЗ_3Уровень", 			ТЗ_3Уровень);
	Запрос.УстановитьПараметр("ТЗ_Ночь", 				ТЗ_Ночь);
	Запрос.УстановитьПараметр("ТЗ_День", 				ТЗ_День);
	
	Если ПараметрыРасчета.ИсключаяОтдельностоящие тогда
		Текст 		= СтрЗаменить(Текст,"бестОбъемНачисленийЭлектроэнергии.МКД = &МКД","бестОбъемНачисленийЭлектроэнергии.МКД <> &МКД");
		
		Текст 		= СтрЗаменить(Текст,"МКД = &МКД","МКД <> &МКД");
	Иначе
		Если ПараметрыРасчета.МКД = Неопределено Тогда 
			Текст 		= СтрЗаменить(Текст,"бестОбъемНачисленийЭлектроэнергии.МКД = &МКД","ИСТИНА");
			
			Текст 		= СтрЗаменить(Текст,"МКД = &МКД","ИСТИНА");
		КонецЕсли;
	КонецЕсли;
	Запрос.Текст = Текст;
	
	Запрос.Выполнить();
КонецПроцедуры

Функция ВыполнитьРассчитатьИтогДолевыеСхемы(МВТ, ТранзитИзРазныхРО, ДатаДокумента)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = ТекстЗапросаДолевыеСхемыИтог();
	Запрос.УстановитьПараметр("ТранзитИзРазныхРО",  	ТранзитИзРазныхРО);
	Запрос.УстановитьПараметр("ДатаДокумента",  		ДатаДокумента);
	Возврат Запрос.Выполнить();
КонецФункции

Функция ПолучитьНерассчитанныеТранзитныеСхемы(ПериодНачисления, КонецПериодаРасчета, РазныеРО, МВТ)
