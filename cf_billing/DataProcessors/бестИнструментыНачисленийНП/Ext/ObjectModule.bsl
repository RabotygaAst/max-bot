Процедура СторнироватьРаннееНачисленныеОбъемы(Организация, Район, НачалоПериодаРасчета, КонецПериодаРасчета, СоответствиеОтборов, Набор)
	ОбщийМассивОбъектов = Новый Массив;
	ОбщийМассивТУ = Новый Массив;
	Для каждого эл из СоответствиеОтборов Цикл
		Для каждого ОбъектРасчета из эл.Значение.ОбъектыРасчета Цикл
			ОбщийМассивОбъектов.Добавить(ОбъектРасчета);
		КонецЦикла;
		
		Для каждого ТУ из эл.Значение.ТУ Цикл
			ОбщийМассивТУ.Добавить(ТУ);
		КонецЦикла;
	КонецЦикла;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестОбъемНачисленийЭлектроэнергии.Организация КАК Организация,
	|	бестОбъемНачисленийЭлектроэнергии.Район КАК Район,
	|	бестОбъемНачисленийЭлектроэнергии.МКД КАК МКД,
	|	бестОбъемНачисленийЭлектроэнергии.Распределение КАК Распределение,
	|	бестОбъемНачисленийЭлектроэнергии.СпособНачисления КАК СпособНачисления,
	|	бестОбъемНачисленийЭлектроэнергии.ПериодНачисления КАК ПериодНачисления,
	|	бестОбъемНачисленийЭлектроэнергии.ОбъектРасчета КАК ОбъектРасчета,
	|	бестОбъемНачисленийЭлектроэнергии.ТочкаУчета КАК ТочкаУчета,
	|	бестОбъемНачисленийЭлектроэнергии.Услуга КАК Услуга,
	|	бестОбъемНачисленийЭлектроэнергии.Поставщик КАК Поставщик,
	|	бестОбъемНачисленийЭлектроэнергии.Договор КАК Договор,
	|	бестОбъемНачисленийЭлектроэнергии.ПриборУчета КАК ПриборУчета,
	|	бестОбъемНачисленийЭлектроэнергии.Шкала КАК Шкала,
	|	бестОбъемНачисленийЭлектроэнергии.ТарифнаяЗона КАК ТарифнаяЗона,
	|	бестОбъемНачисленийЭлектроэнергии.ОтклонениеОтПлана КАК ОтклонениеОтПлана,
	|	-бестОбъемНачисленийЭлектроэнергии.ОбъемУслуги КАК ОбъемУслуги,
	|	-бестОбъемНачисленийЭлектроэнергии.СуммаСредневзвешенная КАК СуммаСредневзвешенная,
	|	-бестОбъемНачисленийЭлектроэнергии.СуммаЗаСбытовуюНадбавку КАК СуммаЗаСбытовуюНадбавку,
	|	-бестОбъемНачисленийЭлектроэнергии.СуммаЗаУслугиПоПередачи КАК СуммаЗаУслугиПоПередачи,
	|	-бестОбъемНачисленийЭлектроэнергии.СуммаЗаИныеУслуги КАК СуммаЗаИныеУслуги,
	|	-бестОбъемНачисленийЭлектроэнергии.СуммаСредневзвешеннаяНДС КАК СуммаСредневзвешеннаяНДС,
	|	-бестОбъемНачисленийЭлектроэнергии.СуммаЗаСбытовуюНадбавкуНДС КАК СуммаЗаСбытовуюНадбавкуНДС,
	|	-бестОбъемНачисленийЭлектроэнергии.СуммаЗаУслугиПоПередачиНДС КАК СуммаЗаУслугиПоПередачиНДС,
	|	-бестОбъемНачисленийЭлектроэнергии.СуммаЗаИныеУслугиНДС КАК СуммаЗаИныеУслугиНДС,
	|	бестОбъемНачисленийЭлектроэнергии.ЦеноваяКатегория КАК ЦеноваяКатегория,
	|	бестОбъемНачисленийЭлектроэнергии.НачалоПериода КАК НачалоПериода,
	|	бестОбъемНачисленийЭлектроэнергии.КонецПериода КАК КонецПериода,
	|	бестОбъемНачисленийЭлектроэнергии.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный,
	|	бестОбъемНачисленийЭлектроэнергии.ТарифНаИныеУслуги КАК ТарифНаИныеУслуги,
	|	бестОбъемНачисленийЭлектроэнергии.ТарифЗаСбытовуюНадбавку КАК ТарифЗаСбытовуюНадбавку,
	|	бестОбъемНачисленийЭлектроэнергии.ТарифЗаУслугиПоПередачи КАК ТарифЗаУслугиПоПередачи,
	|	бестОбъемНачисленийЭлектроэнергии.УчаствуетВДолевойСхеме КАК УчаствуетВДолевойСхеме,
	|	бестОбъемНачисленийЭлектроэнергии.НДСВнутриИныеУслуги КАК НДСВнутриИныеУслуги,
	|	бестОбъемНачисленийЭлектроэнергии.НДСВнутриСбытоваяНадбавка КАК НДСВнутриСбытоваяНадбавка,
	|	бестОбъемНачисленийЭлектроэнергии.НДСВнутриУслугиПоПередачи КАК НДСВнутриУслугиПоПередачи,
	|	бестОбъемНачисленийЭлектроэнергии.НачальныеПоказания КАК НачальныеПоказания,
	|	бестОбъемНачисленийЭлектроэнергии.КонечныеПоказания КАК КонечныеПоказания,
	|	бестОбъемНачисленийЭлектроэнергии.СтавкаНДС КАК СтавкаНДС,
	|	-бестОбъемНачисленийЭлектроэнергии.Сумма КАК Сумма,
	|	-бестОбъемНачисленийЭлектроэнергии.СуммаНДС КАК СуммаНДС,
	|	бестОбъемНачисленийЭлектроэнергии.Тариф КАК Тариф
	|ИЗ
	|	РегистрНакопления.бестОбъемНачисленийЭлектроэнергии КАК бестОбъемНачисленийЭлектроэнергии
	|ГДЕ
	|	бестОбъемНачисленийЭлектроэнергии.Организация = &Организация
	|	И бестОбъемНачисленийЭлектроэнергии.Район = &Район
	|	И бестОбъемНачисленийЭлектроэнергии.ОбъектРасчета В(&ОбъектыРасчета)
	|	И бестОбъемНачисленийЭлектроэнергии.Период МЕЖДУ &НачалоПериодаРасчета И &КонецПериодаРасчета
	|	И НЕ бестОбъемНачисленийЭлектроэнергии.Регистратор ССЫЛКА Документ.бестПерерасчетЭЭ
	|	И бестОбъемНачисленийЭлектроэнергии.ТочкаУчета В(&ТУ)";
	
	Запрос.УстановитьПараметр("КонецПериодаРасчета", 	КонецПериодаРасчета);
	Запрос.УстановитьПараметр("НачалоПериодаРасчета", 	НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("ОбъектыРасчета", 		ОбщийМассивОбъектов);
	Запрос.УстановитьПараметр("ТУ", 					ОбщийМассивТУ);
	Запрос.УстановитьПараметр("Организация", 			Организация);
	Запрос.УстановитьПараметр("Район", 					Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяЗапись = Набор.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяЗапись,  ВыборкаДетальныеЗаписи);
		НоваяЗапись.Активность = Истина;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти