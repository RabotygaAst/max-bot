	|					КОГДА Финал2.Услуга.Сезонность = ЗНАЧЕНИЕ(Справочник.энргВидыСезонности.пустаяссылка)
	|							ИЛИ ОтопительныйПериод.Сезонность ЕСТЬ NULL
	|						ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Подключена)
	|					КОГДА ОтопительныйПериод.НачалоПериодаДействия <= &МоментВремени
	|							И ОтопительныйПериод.КонецПериодаДействия > &МоментВремени
	|						ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Подключена)
	|					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Отключена)
	|				КОНЕЦ
	|		ИНАЧЕ Финал2.Состояние
	|	КОНЕЦ КАК Состояние
	|ПОМЕСТИТЬ Финал3
	|ИЗ
	|	Финал2 КАК Финал2
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОтопительныйПериод КАК ОтопительныйПериод
	|		ПО Финал2.Услуга = ОтопительныйПериод.Услуга
	|			И Финал2.Услуга.Сезонность = ОтопительныйПериод.Сезонность
	|
	|СГРУППИРОВАТЬ ПО
	|	Финал2.ОбъектРасчета,
	|	Финал2.ТочкаУчета,
	|	Финал2.ПриборУчета,
	|	Финал2.Шкала,
	|	Финал2.Услуга,
	|	Финал2.ВидДифференцированности,
	|	Финал2.ГруппаОбъектовРасчета,
	|	Финал2.Контрагент,
	|	Финал2.Договор,
	|	ВЫБОР
	|		КОГДА Финал2.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.ПустаяСсылка)
	|			ТОГДА ВЫБОР
	|					КОГДА Финал2.Услуга.Сезонность = ЗНАЧЕНИЕ(Справочник.энргВидыСезонности.пустаяссылка)
	|							ИЛИ ОтопительныйПериод.Сезонность ЕСТЬ NULL
	|						ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Подключена)
	|					КОГДА ОтопительныйПериод.НачалоПериодаДействия <= &МоментВремени
	|							И ОтопительныйПериод.КонецПериодаДействия > &МоментВремени
	|						ТОГДА ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Подключена)
	|					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Отключена)
	|				КОНЕЦ
	|		ИНАЧЕ Финал2.Состояние
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Финал3.ОбъектРасчета КАК ОбъектРасчета,
	|	Финал3.ТочкаУчета КАК ТочкаУчета,
	|	Финал3.Услуга КАК Услуга,
	|	Финал3.Контрагент КАК Контрагент,
	|	Финал3.Договор КАК Договор,
	|	&МоментВремени КАК ДатаОперации,
	|	ВЫБОР
	|		КОГДА &СостояниеУслуги = ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Отключена)
	|			ТОГДА Финал3.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Подключена)
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Переподключение
	|ИЗ
	|	Финал3 КАК Финал3
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &СостояниеУслуги = ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Подключена)
	|				ТОГДА Финал3.Состояние = &СостояниеУслуги
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	Финал3.Контрагент,
	|	Финал3.Договор,
	|	Финал3.Услуга,
	|	Финал3.ОбъектРасчета,
	|	Финал3.ТочкаУчета,
	|	ВЫБОР
	|		КОГДА &СостояниеУслуги = ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Отключена)
	|			ТОГДА Финал3.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Подключена)
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ";	
	
	Запрос.УстановитьПараметр("Услуга",					ТекУслуга);
	Если НЕ ЗначениеЗаполнено(ТекУслуга) Тогда
		Текст = СтрЗаменить(Текст, "			И (энргВидыУслуг.Ссылка = &Услуга)", "");
		Текст = СтрЗаменить(Текст, "бестДоговорыТочекУчетаСрезПоследних.Услуга = &Услуга", "Истина");		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ГруппаОбъектовРасчета",	ТекГруппаОбъектов);
	Если НЕ ЗначениеЗаполнено(ТекГруппаОбъектов) Тогда
		Текст = СтрЗаменить(Текст, "	Финал.ГруппаОбъектовРасчета = &ГруппаОбъектовРасчета", "Истина");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОбъектРасчета) Тогда
		Запрос.УстановитьПараметр("ОбъектРасчета",		ОбъектРасчета)
	Иначе
		//Текст = СтрЗаменить(Текст, "И бестОбъектыРасчета.Ссылка = &ОбъектРасчета", "");
		Текст = СтрЗаменить(Текст, "И ОбъектРасчета = &ОбъектРасчета", "");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Договор",				Договор);
	Если НЕ ЗначениеЗаполнено(Договор) Тогда
		Текст = СтрЗаменить(Текст, "бестДоговорыТочекУчетаСрезПоследних.Договор = &Договор", "Истина");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СтруктураСети",			СтруктураСети);
	Если НЕ ЗначениеЗаполнено(СтруктураСети) Тогда
		Текст = СтрЗаменить(Текст, "бестСтруктураСетиТочекУчетаНПСрезПоследних.СтруктураСети = &СтруктураСети", "Истина");
	КонецЕсли;
	
	//Если ЗначениеЗаполнено(Контролер) Тогда
	//	Запрос.УстановитьПараметр("Контролер",	Контролер)
	//Иначе
	//	Текст = СтрЗаменить(Текст, "(бестОбъектыРасчета.Контролер = &Контролер)", "ИСТИНА");
	//КонецЕсли;
	
	//Если ОтборПоУзлам Тогда
	//	Если ВариантыОтбораПоУзлам = 0 Тогда
	//		Текст = СтрЗаменить(Текст, "ЛЕВОЕ СОЕДИНЕНИЕ ДанныеПоПриборам КАК ДанныеПоПриборам", "ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеПоПриборам КАК ДанныеПоПриборам");
	//		Текст = СтрЗаменить(Текст, "ДанныеПоПриборам.УзелУчета ЕСТЬ NULL", "ИСТИНА");
	//	КонецЕсли;
	//Иначе
	//	Текст = СтрЗаменить(Текст, "ДанныеПоПриборам.УзелУчета ЕСТЬ NULL", "ИСТИНА");
	//КонецЕсли;
	
	Запрос.Текст = Текст;
	Пакет = запрос.ВыполнитьПакетСПромежуточнымиДанными();
	Результат = Пакет[Пакет.Количество() - 1];
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ВыполнитьНаСервере()
	Запрос = Новый Запрос;
	Рок = ТЧ.Выгрузить();
	Запрос.УстановитьПараметр("Таблица", 		ТЧ.Выгрузить());
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("Дата", 			Дата);
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица.Договор КАК Договор,
	               |	Таблица.Контрагент КАК Контрагент,
	               |	Таблица.ОбъектРасчета КАК ОбъектРасчета,
	               |	Таблица.ТочкаУчета КАК ТочкаУчета,
	               |	Таблица.ДатаОперации КАК ДатаОперации,
	               |	Таблица.Флаг КАК Флаг,
	               |	Таблица.Услуга КАК Услуга,
	               |	Таблица.СсылкаНаДокумент КАК СсылкаНаДокумент,
	               |	Таблица.НомерСтроки КАК НомерСтроки,
	               |	Таблица.Переподключение КАК Переподключение
	               |ПОМЕСТИТЬ ВрТ0
	               |ИЗ
	               |	&Таблица КАК Таблица
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВрТ0.Договор КАК Договор,
	               |	ВрТ0.Контрагент КАК Контрагент,
	               |	ВрТ0.ОбъектРасчета КАК ОбъектРасчета,
	               |	ВрТ0.ТочкаУчета КАК ТочкаУчета,
	               |	ВЫБОР
	               |		КОГДА ВрТ0.ДатаОперации = ДАТАВРЕМЯ(1, 1, 1)
	               |			ТОГДА &Дата
	               |		ИНАЧЕ ВрТ0.ДатаОперации
	               |	КОНЕЦ КАК ДатаОперации,
	               |	&Организация КАК Организация,
	               |	&Район КАК Район,
	               |	&Дата КАК Дата,
	               |	ВрТ0.Услуга КАК Услуга,
	               |	ВрТ0.СсылкаНаДокумент КАК СсылкаНаДокумент,
	               |	ВрТ0.НомерСтроки КАК НомерСтроки,
	               |	ВрТ0.Переподключение КАК Переподключение
	               |ПОМЕСТИТЬ ВрТ1
	               |ИЗ
	               |	ВрТ0 КАК ВрТ0
	               |ГДЕ
	               |	ВрТ0.Флаг
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВрТ1.Договор КАК Договор,
	               |	ВрТ1.Контрагент КАК Контрагент,
	               |	ВрТ1.ОбъектРасчета КАК ОбъектРасчета,
	               |	ВрТ1.ТочкаУчета КАК ТочкаУчета,
	               |	ВрТ1.ДатаОперации КАК ДатаОперации,
	               |	ВрТ1.Организация КАК Организация,
	               |	ВрТ1.Район КАК Район,
	               |	ВрТ1.Дата КАК Дата,
	               |	ВрТ1.Услуга КАК Услуга,
	               |	ВрТ1.СсылкаНаДокумент КАК СсылкаНаДокумент,
	               |	ВрТ1.НомерСтроки КАК НомерСтроки,
	               |	ВрТ1.Переподключение КАК Переподключение
	               |ИЗ
	               |	ВрТ1 КАК ВрТ1
	               |ИТОГИ ПО
	               |	ДатаОперации";
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Если ВидОперации = "СезонноеОтключениеУслуги" Тогда
			ТекВидОперации = Перечисления.бестВидыОпераций.бестИзменениеИндивидуальныхНастроекСезонности_ОграничениеУслуги;
			ТекстСообщения = "Отключение услуг выполнено. Созданы документы: ";
		ИначеЕсли ВидОперации = "СезонноеПодключениеУслуги" Тогда
			ТекВидОперации = Перечисления.бестВидыОпераций.бестИзменениеИндивидуальныхНастроекСезонности_ВозобновлениеУслуги;
			ТекстСообщения = "Подключение услуг выполнено. Созданы документы: ";
		КонецЕсли;
		ТекПользователь		= Пользователи.ТекущийПользователь();
		Пока Выборка.Следующий() Цикл 
			//ТекДог	= Выборка.Договор;		
			//ВыборкаДата = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			//Пока ВыборкаДата.Следующий() Цикл
			ТекДата				= Выборка.ДатаОперации;
			НовДок				= Документы.бестИзменениеИндивидуальныхНастроекСезонности.СоздатьДокумент();
			НовДок.ВидОперации	= ТекВидОперации;
			НовДок.Дата			= ТекДата;
			НовДок.ПериодНачисления	=  энргРаботаСПериодомДействия.ОпределитьПериодНачисления(ТекДата, Организация, Район);
			
			//НовДок.Договор		= ТекДог;
			НовДок.Организация 	= Организация;	
			НовДок.Район		= Район;
			
			ТЧТочкиУчета		= НовДок.ТочкиУчета;
			ВыборкаДетали		= Выборка.Выбрать();
			Пока ВыборкаДетали.Следующий() Цикл
				НовСтрока		= ТЧТочкиУчета.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрока, ВыборкаДетали);								
			КонецЦикла;
			НовДок.Ответственный= ТекПользователь;
			НовДок.Примечание	= "Создан обработкой";
			НовДок.Записать(РежимЗаписиДокумента.Проведение);
			
			ВыборкаНов = Выборка.Выбрать();
			Пока ВыборкаНов.Следующий() Цикл 
			Для Каждого  СтрТЧ из ТЧ Цикл
				Если  СтрТЧ.Договор = ВыборкаНов.Договор и СтрТЧ.Контрагент = ВыборкаНов.Контрагент 
					и СтрТЧ.ОбъектРасчета= ВыборкаНов.ОбъектРасчета и СтрТЧ.ТочкаУчета = ВыборкаНов.ТочкаУчета и СтрТЧ.Услуга = ВыборкаНов.Услуга Тогда  
					СтрТЧ.СсылкаНАДокумент = НовДок.Ссылка;
				КонецЕсли;
			КонецЦикла; КонецЦикла;
			
			ТекстСообщения = ТекстСообщения + НовДок.Ссылка + "; ";
			//КонецЦикла;
		КонецЦикла;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ТекстСообщения;
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередВыполнениемОбработки(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если  РезультатВопроса = КодВозвратаДиалога.Да тогда
			ВыполнитьНаСервере();
		КонецЕсли; 		
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокУслугДляВыбора()
	
	СписокУслуг = Новый СписокЗначений; 	

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ Услуги
	|ИЗ
	|	РегистрСведений.бестИндивидуальныеНастройкиСезонностиУслуг.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета) КАК бестУслугиТочекУчетаНПСрезПоследних
	|ГДЕ
	|	бестУслугиТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеУслуг.Отключена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(энргВидыУслугСоставляющиеУслуг.Услуга, Услуги.Услуга) КАК Услуга
	|ИЗ
	|	Услуги КАК Услуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|		ПО Услуги.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка";
	
	
	
	Если Не ЗначениеЗаполнено(ОбъектРасчета) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ОбъектРасчета = &ОбъектРасчета", "ИСТИНА");
	Иначе 
		Запрос.УстановитьПараметр("ОбъектРасчета",ОбъектРасчета);
	КонецЕсли;	
	
	
	
	Запрос.УстановитьПараметр("Район",Район);
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.УстановитьПараметр("Период",?(ЗначениеЗаполнено(Дата), Дата, ТекущаяДата()));
	
	
	РезультатЗапроса 		= Запрос.Выполнить();   	
	ВыборкаДетальныеЗаписи 	= РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СписокУслуг.Добавить(ВыборкаДетальныеЗаписи.Услуга);
	КонецЦикла;
	
	Возврат СписокУслуг;
	
КонецФункции

&НаСервере
Процедура РайонПриИзмененииНаСервере()
	Если ЗначениеЗаполнено(Район) Тогда 
		Организация =Район.Организация;
	иначе 
		Организация = Неопределено;
	КонецЕсли;

КонецПроцедуры

