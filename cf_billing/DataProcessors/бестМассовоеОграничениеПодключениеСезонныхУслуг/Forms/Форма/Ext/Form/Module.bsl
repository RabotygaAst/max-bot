#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ОтборПоУзлам Тогда
		ЭтаФорма.Элементы.ВариантыОтбора.Видимость = Истина;
	Иначе
		ЭтаФорма.Элементы.ВариантыОтбора.Видимость = Ложь;
	КонецЕсли;
	Дата = ТекущаяДата();

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	ОбъектРасчета =  ВыбранноеЗначение;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура УслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если ВидОперации = "СезонноеПодключениеУслуги" Тогда 
		СтандартнаяОбработка 	= Ложь;		
		СписокУслуг 			= ПолучитьСписокУслугДляВыбора();
		
		ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", Новый Структура("СписокУслуг", СписокУслуг), Элемент);
	Иначе 
		СтандартнаяОбработка = Ложь;	
		
		СписокУслуг = бестПользовательскийВводСервер.ПолучитьСписокУслугДляВыбора(?(ЗначениеЗаполнено(Дата), Дата, ТекущаяДата()), Организация, Район, ОбъектРасчета, Неопределено);
		ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", Новый Структура("СписокУслуг", СписокУслуг), Элемент);	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	РайонПриИзмененииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	Элементы.ТЧПереподключение.Видимость =	ВидОперации = "СезонноеПодключениеУслуги";
КонецПроцедуры

&НаКлиенте
Процедура ТЧДатаОперацииПриИзменении(Элемент)
	ТекСтрока 						= Элементы.ТЧ.ТекущиеДанные;
	ТекСтрока.Флаг					= Истина;
КонецПроцедуры

&НаКлиенте
Процедура ОтборПоУзламПриИзменении(Элемент)
	Если ОтборПоУзлам Тогда
		ЭтаФорма.Элементы.ВариантыОтбора.Видимость = Истина;
	Иначе
		ЭтаФорма.Элементы.ВариантыОтбора.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

