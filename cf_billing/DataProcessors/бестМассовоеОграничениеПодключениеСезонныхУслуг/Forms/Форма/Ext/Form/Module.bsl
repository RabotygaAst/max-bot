#Область ОбработчикиСобытийЭлементовТаблицыФормыТЧ

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаполнитьТЧ(Команда)
	ЗаполнитьТЧНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ОчиститьТЧ(Команда)
	ТЧ.Очистить();
КонецПроцедуры

&НаКлиенте
Процедура ВыделитьВсе(Команда)
	Для каждого стр из ТЧ Цикл
		стр.Флаг = Истина;		
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)
	Для каждого стр из ТЧ Цикл
		стр.Флаг = Ложь;		
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоВсемТУОбъекта(Команда)
	ТекСтрока 						= Элементы.ТЧ.ТекущиеДанные;
	Если Не ТекСтрока					= Неопределено Тогда
		СтрОтбора						= Новый Структура("ОбъектРасчета", ТекСтрока.ОбъектРасчета);
		ИщемСтроки						= ТЧ.НайтиСтроки(СтрОтбора);
		Для н = 0 по ИщемСтроки.ВГраница() Цикл
			ИщемСтроки[н].ДатаОперации 	= ТекСтрока.ДатаОперации;
			ИщемСтроки[н].Флаг 			= ТекСтрока.Флаг;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СозданиеДоков(Команда)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросПередВыполнениемОбработки",ЭтотОбъект);
	ПоказатьВопрос(ОписаниеОповещения,"Удалить всю строку вместо значения ячейки?",РежимДиалогаВопрос.ДаНет);		
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьТЧНаСервере()
	//ТЧ.Очистить();
	
	ТекСостояние								= Перечисления.энргСостояниеТочекУчета.Включена;
	Если ВидОперации							= "СезонноеОтключениеУслуги" Тогда
		ТекСостояниеУслуги                      = Перечисления.энргСостояниеУслуг.Подключена;
	ИначеЕсли ВидОперации						= "СезонноеПодключениеУслуги" Тогда 
		ТекСостояниеУслуги                      = Перечисления.энргСостояниеУслуг.Отключена;
	КонецЕсли; 
	
	Результат 									= ДействующиеТочкиУчетаПоУслуге(Дата,Организация,Район,Услуга, ГруппаОбъектовРасчета, ТекСостояние, ТекСостояниеУслуги, Договор, СтруктураСети); 
	Выборка  									= Результат.Выбрать();
	ТекТочкаУчета 								= Неопределено;
	
	Пока Выборка.следующий() цикл
		НоваяТочка = Ложь;
		//Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
		//		СтрокаТочкиУчета  					= ТЧ.Добавить();
		//		ЗаполнитьЗначенияСвойств(СтрокаТочкиУчета, Выборка);	
		//КонецЕсли;
		мСтроки  = ТЧ.НайтиСтроки(Новый Структура("Договор, ОбъектРасчета,ТочкаУчета,Услуга",Выборка.Договор,Выборка.ОбъектРасчета,Выборка.ТочкаУчета, Выборка.Услуга));
		Если мСтроки.Количество()  = 0 Тогда
			СтрокаТочкиУчета  					= ТЧ.Добавить();
			СтрокаТочкиУчета.НомерСтроки = Новый УникальныйИдентификатор();
			ЗаполнитьЗначенияСвойств(СтрокаТочкиУчета, Выборка);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ДействующиеТочкиУчетаПоУслуге(ТекПериод,ТекОрганизация,ТекРайон,ТекУслуга, ТекГруппаОбъектов, ТекСостояние, ТекСостояниеУслуги, Договор, СтруктураСети)
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Новый Граница(ТекПериод,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Организация",			ТекОрганизация);
	Запрос.УстановитьПараметр("Район",					ТекРайон);
	Запрос.УстановитьПараметр("ТекСостояние",			ТекСостояние);
	Запрос.УстановитьПараметр("СостояниеУслуги",		ТекСостояниеУслуги);   
	Запрос.УстановитьПараметр("МоментВремени",			ТекПериод);

	Текст =
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Сезонность КАК Сезонность,
	|	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), ГОД, ВложенныйЗапрос.ГодНачало - 1), МЕСЯЦ, ВложенныйЗапрос.МесяцНачала - 1), ДЕНЬ, ВложенныйЗапрос.ДеньНачала - 1) КАК НачалоПериодаДействия,
	|	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), ГОД, ВложенныйЗапрос.ГодОкончания - 1), МЕСЯЦ, ВложенныйЗапрос.МесяцОкончания - 1), ДЕНЬ, ВложенныйЗапрос.ДеньОкончания - 1) КАК КонецПериодаДействия,
	|	энргВидыУслуг.Ссылка КАК Услуга
	|ПОМЕСТИТЬ ОтопительныйПериод
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргДлительностиПериодов.Сезонность КАК Сезонность,
	|		ДЕНЬ(энргДлительностиПериодов.НачалоПериода) КАК ДеньНачала,
	|		МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) КАК МесяцНачала,
	|		ДЕНЬ(энргДлительностиПериодов.КонецПериода) КАК ДеньОкончания,
	|		МЕСЯЦ(энргДлительностиПериодов.КонецПериода) КАК МесяцОкончания,
	|		ВЫБОР
	|			КОГДА МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) > МЕСЯЦ(энргДлительностиПериодов.КонецПериода)
	|					И МЕСЯЦ(энргДлительностиПериодов.КонецПериода) >= МЕСЯЦ(&МоментВремени)
	|				ТОГДА ГОД(&МоментВремени) - 1
	|			ИНАЧЕ ГОД(&МоментВремени)
	|		КОНЕЦ КАК ГодНачало,
	|		ВЫБОР
	|			КОГДА МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) > МЕСЯЦ(энргДлительностиПериодов.КонецПериода)
	|					И МЕСЯЦ(энргДлительностиПериодов.КонецПериода) >= МЕСЯЦ(&МоментВремени)
	|				ТОГДА ГОД(&МоментВремени)
	|			ИНАЧЕ ГОД(&МоментВремени) + 1
	|		КОНЕЦ КАК ГодОкончания
	|	ИЗ
	|		РегистрСведений.энргДлительностиПериодов.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район) КАК энргДлительностиПериодов) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО ВложенныйЗапрос.Сезонность = энргВидыУслуг.Сезонность
	|			И (энргВидыУслуг.Ссылка = &Услуга)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НастройкаСезонностиУслуг.Организация КАК Организация,
	|	НастройкаСезонностиУслуг.Район КАК Район,
	|	НастройкаСезонностиУслуг.Услуга КАК Услуга,
	|	НастройкаСезонностиУслуг.НеПрименятьСезонность КАК НеПрименятьСезонность,
	|	ОтопительныйПериод.Сезонность КАК Сезонность,
	|	ОтопительныйПериод.НачалоПериодаДействия КАК НачалоПериодаДействия,
	|	ОтопительныйПериод.КонецПериодаДействия КАК КонецПериодаДействия
	|ПОМЕСТИТЬ УслугиНеПрименятьСезонность
	|ИЗ
	|	РегистрСведений.энргНастройкаСезонностиУслуг.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район) КАК НастройкаСезонностиУслуг
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОтопительныйПериод КАК ОтопительныйПериод
	|		ПО НастройкаСезонностиУслуг.Услуга = ОтопительныйПериод.Услуга
	|ГДЕ
	|	НастройкаСезонностиУслуг.Организация = &Организация
	|	И НастройкаСезонностиУслуг.Район = &Район
	|	И НЕ НастройкаСезонностиУслуг.НеПрименятьСезонность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаОбъекта
	|ИЗ
	|	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета) КАК бестАктивностьТочекУчетаНПСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ПО бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета = бестОбъектыРасчета.Ссылка
	|ГДЕ
	|	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = &ТекСостояние
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ТочкиУчетаОбъекта
	|ИЗ
	|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаОбъекта.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта)) КАК энргВладельцыТочекУчетаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТочкиУчетаОбъекта.ТочкаУчета КАК ТочкаУчета,
	|	АктивныеТочкиУчетаОбъекта.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ ДействующиеТочкиУчета
	|ИЗ
	|	ТочкиУчетаОбъекта КАК ТочкиУчетаОбъекта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта
	|		ПО ТочкиУчетаОбъекта.ТочкаУчета = АктивныеТочкиУчетаОбъекта.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестПриборыТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестПриборыТочекУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочекУчета
	|ИЗ
	|	РегистрСведений.бестПриборыТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район) КАК бестПриборыТочекУчетаНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДействующиеТочкиУчета.ОбъектРасчета КАК ОбъектРасчета,
	|	ДействующиеТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	ПриборыТочекУчета.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыДействующихТочек
	|ИЗ
	|	ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПриборыТочекУчета КАК ПриборыТочекУчета
	|		ПО ДействующиеТочкиУчета.ТочкаУчета = ПриборыТочекУчета.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВведенныеПриборы
	|ИЗ
	|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район) КАК бестСостояниеПриборовУчетаНПСрезПоследних
	|ГДЕ
	|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестДоговорыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестДоговорыТочекУчетаСрезПоследних.Услуга КАК Услуга,
	|	бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестДоговорыТочекУчетаСрезПоследних.Договор КАК Договор
	|ПОМЕСТИТЬ УслугиТочекУчета
	|ИЗ
	|	РегистрСведений.бестДоговорыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ОбъектРасчета, ТочкаУчета) В
