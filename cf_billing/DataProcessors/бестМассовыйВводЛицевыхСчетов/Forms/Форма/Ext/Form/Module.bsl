#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СформироватьДокумент(Команда)
	//нДок = ПолучитьДокумент();
	Форма = ПолучитьФорму("Документ.энргВводНачальныхОстатков.ФормаОбъекта");
	ДанныеФормы = Форма.Объект;
	Если НЕ ЭтаФорма.ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьДокументНаСервере(ДанныеФормы);
	КопироватьДанныеФормы(ДанныеФормы, Форма.Объект);
	Форма.Открыть();
КонецПроцедуры  

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ЗаполнитьДокументНаСервере(ДанныеФормы)
	Группа 		= Объект.ГруппаАбонента;
	ДлинаЛС 	= энргРаботаСЛицевымСчетомСервер.ПолучитьДлинуЛС(ТекущаяДата(), Объект.Организация);
	МаксНомер 	= ПолучитьМаксНомер(Группа, Объект.Район, Объект.Организация, ДлинаЛС);
			
	// Шапка документа.
	ДанныеФормы.Организация = Объект.Организация;
	ДанныеФормы.МКД 		= Объект.МКД;
	ДанныеФормы.Район 		= Объект.Район;
	ДанныеФормы.Филиал 		= РегистрыСведений.энргФилиалыСтроений.ПолучитьПоследнее(ТекущаяДата(),Новый Структура("Строение",Объект.МКД)).Филиал;
	МассивПомещений 		= ПолучитьПомещения(Объект.МКД);	
	
	Для й=1 По КвартираДо - КвартираОт + 1 Цикл
		
		КодАбонента 	= Формат(Число(МаксНомер) + й,"ЧГ=0");
		Пока Группа.Уровень() > 1 Цикл
			Группа = Группа.Родитель;
		КонецЦикла;
		КодРайона 		= ?(ЗначениеЗаполнено(Группа.КодРайона),Группа.КодРайона, "00");
		Префикс			= Объект.Район.КодРайона + КодРайона;
		ЛС 				= Префикс + Лев("00000000000000", ДлинаЛС - СтрДлина(Префикс) - СтрДлина(КодАбонента)) + КодАбонента;
		
		// Заполнение ТЧ Абоненты в документе.
		нСтрока 						= ДанныеФормы.Абоненты.Добавить();
		нСтрока.Строение 				= Объект.МКД;
		нСтрока.ЛицевойСчет 			= ЛС;
		нСтрока.ГруппаАбонентов 		= Группа;
		нСтрока.АдресОбъекта 			= Объект.МКД.Наименование + ", квартира " + Формат(Число(КвартираОт-1) + й,"ЧГ=0");
		нСтрока.ДатаОткрытияЛС 			= ТекущаяДата();
		нСтрока.ВидОбъекта 				= Объект.ВидОбъекта;
		нСтрока.IDСтроки 				= Новый УникальныйИдентификатор;
		нСтрока.ТипСобственностиЖилья 	= Объект.ТипСобственностиЖилья;
		нСтрока.Помещение 				= МассивПомещений[й-1];
		
		// Заполнение услуг с типами приборов учета.
		Для каждого ТекСтрока Из Объект.ТочкиУчета Цикл
			нСтрокаТУ 					= ДанныеФормы.ТочкиУчета.Добавить();
			нСтрокаТУ.IDСтроки 			= Новый УникальныйИдентификатор;
			нСтрокаТУ.Услуга 			= ТекСтрока.Услуга;
			нСтрокаТУ.IDСтрокиАбонента 	= нСтрока.IDСтроки;
			нСтрокаТУ.Расположение		= ТекСтрока.Расположение;
			Если ЗначениеЗаполнено(ТекСтрока.ТипПрибораУчета) Тогда
				нСтрокаТУ.ТипПрибораУчета 	= ТекСтрока.ТипПрибораУчета;
				нСтрокаТУ.ВидКанальности 	= Справочники.энргВидыКанальности.Одноканальный;
			КонецЕсли;
			нСтрокаТУ.Поставщик 					= Справочники.энргКонтрагенты.НайтиПоКоду("000000010");
			нСтрокаТУ.НаименованиеТочки 			= "" + нСтрокаТУ.Расположение + "_" + нСтрокаТУ.Услуга;
			ТекСтрокаПоказания 						= ДанныеФормы.ШкалыПриборовУчета.Добавить();
			ТекСтрокаПоказания.IDСтроки 			= Новый УникальныйИдентификатор;
			ТекСтрокаПоказания.IDСтрокиТочкиУчета 	= нСтрокаТУ.IDСтроки;
		КонецЦикла;
		
		// Заполнение услуг по благоустройству.
		Для каждого ТекСтрока Из Объект.ВидыБлагоустройстваТарифныеКатегории Цикл
			Если ТекСтрока.Услуга.СоставнаяУслуга Тогда
				Для каждого ТекСтрокаУслуг Из ТекСтрока.Услуга.СоставляющиеУслуг Цикл
					нСтрокаУслуги 						= ДанныеФормы.ВидыБлагоустройстваТарифныеКатегории.Добавить();
					ЗаполнитьЗначенияСвойств(нСтрокаУслуги, ТекСтрока); 
					нСтрокаУслуги.Услуга 				= ТекСтрокаУслуг.Услуга;
					нСтрокаУслуги.IDСтрокиАбонента 		= нСтрока.IDСтроки;
				КонецЦикла;
			Иначе
				нСтрокаУслуги 							= ДанныеФормы.ВидыБлагоустройстваТарифныеКатегории.Добавить();
				ЗаполнитьЗначенияСвойств(нСтрокаУслуги, ТекСтрока); 
				нСтрокаУслуги.IDСтрокиАбонента 			= нСтрока.IDСтроки;
			КонецЕсли;	  
		КонецЦикла;
		
	КонецЦикла;  
		
КонецФункции

// Получение последнего номера лицевого счета по заданным параметрам.
&НаСервере
Функция ПолучитьМаксНомер(Группа,Район,Организация, ДлинаЛС)
	Запрос 		= Новый Запрос;
	Запрос.УстановитьПараметр("Район",Район);
	Запрос.УстановитьПараметр("Организация",Организация);
	Текст  ="ВЫБРАТЬ
		|	ЕСТЬNULL(ВложенныйЗапрос.ЛицевойСчет, ""00000000"") КАК МаксНомер
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(ПОДСТРОКА(энргАбоненты.ЛицевойСчет, 5,%%ДлинаЛС%%)) КАК ЛицевойСчет
		|	ИЗ
		|		Справочник.энргАбоненты КАК энргАбоненты
		|	ГДЕ
		|		энргАбоненты.Район  =&район И энргАбоненты.Организация  = &Организация) КАК ВложенныйЗапрос";
	Текст 			= СтрЗаменить(Текст,"%%ДлинаЛС%%",Строка(ДлинаЛС));
	Запрос.Текст 	= Текст;
	Выборка  		= Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	МаксНомер  		= СокрЛП(Выборка.МаксНомер);
	
	Возврат МаксНомер;	
КонецФункции

&НаСервере
// Получение элементов справочника энргПомещения в массив, по количеству квартир
Функция ПолучитьПомещения(Строение)
	МассивПомещений = Новый Массив;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргПомещения.Ссылка КАК Ссылка,
		|	энргПомещения.Наименование КАК Наименование
		|ИЗ
		|	Справочник.энргПомещения КАК энргПомещения
		|ГДЕ
		|	энргПомещения.Строение = &Строение
		|
		|СГРУППИРОВАТЬ ПО
		|	энргПомещения.Ссылка,
		|	энргПомещения.Наименование";
	
	Запрос.УстановитьПараметр("Строение", Строение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Для й=КвартираОт По КвартираДо Цикл
			Если СтрНайти(ВыборкаДетальныеЗаписи.Наименование, "Квартира " + й) > 0 Тогда
				МассивПомещений.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
				Прервать;
			ИначеЕсли СтрНайти(ВыборкаДетальныеЗаписи.Наименование, "квартира " + й) > 0 Тогда
				МассивПомещений.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
				Прервать;
			КонецЕсли;
		КонецЦикла;	 
	КонецЦикла;
	Возврат МассивПомещений;
КонецФункции // ПолучитьПомещение()
 
#КонецОбласти