#Область События_Формы 

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Период = ТекущаяДата();
	ЗаполнитьЗаголовкиКолонок();
	бестЛокализацияСервер.ПриСозданииНаСервере_бестРаботаСДолжникамиЮЛ(ЭтотОбъект);
	
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ЭтапыПИР,"Договор", Справочники.энргДоговорыАбонентов.ПустаяСсылка());
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ЗадачиМне,"ТекДата", ТекущаяДата());
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ЗадачиМне,"ТекПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	ОбновитьДокументыКСогласованиюНаСервере();
КонецПроцедуры

#КонецОбласти

#Область Команды 

&НаКлиенте
Процедура Заполнить(Команда)
	ЗаполнитьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура НачатьПИР(Команда)
	Если НЕ ЗначениеЗаполнено(СхемаДляНовыхЗадач) ИЛИ НЕ ЗначениеЗаполнено(НачальныйЭтап) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Заполните схемы для новых задач.");
	Иначе
		Для каждого эл из Элементы.Должники.ВыделенныеСтроки Цикл
			ТекСтрока = Элементы.Должники.ДанныеСтроки(эл);
			ДанныеЗадачи = Новый Структура("Организация, Район, Схема, Договор, КатегорияДебитора, ОбщаяСуммаЗадолженности, ПериодЗадолженностиНачало, ПериодЗадолженностиКонец, ЗадачаЮЛ, Этап"
			,ТекСтрока.Организация, ТекСтрока.Район, СхемаДляНовыхЗадач, ТекСтрока.Договор 
			,ТекСтрока.КатегорияДебитора, ТекСтрока.ОбщаяСуммаЗадолженности, ТекСтрока.ДатаВозникновенияЗадолженности
			,Период, Истина, НачальныйЭтап);
			НачатьПИРНаСервере(ДанныеЗадачи);
		КонецЦикла;
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДокументыКСогласованию(Команда)
	ОбновитьДокументыКСогласованиюНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура СогласоватьСобытие(Команда)
	ТекСтрока = Элементы.ДокументыКСогласованию.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда 
		ПоказатьПредупреждение(, "Выберите событие, которое необходимо согласовать");
		Возврат;
	КонецЕсли;
	Если СобытиеСогласовано(ТекСтрока) Тогда 
		ПоказатьПредупреждение(, "Событие уже согласовано");
		Возврат;
	КонецЕсли;
	
	
	ДанныеДляЗаписи = Новый Структура("Организация,Район,ДокРегистратор");
	ЗаполнитьЗначенияСвойств(ДанныеДляЗаписи, ТекСтрока);	
	
	Результат 		= СогласоватьСобытиеНаСервере(ДанныеДляЗаписи);
	ПоказатьПредупреждение(, Результат);

КонецПроцедуры

&НаКлиенте
Процедура ВернутьНаДоработкуСобытие(Команда)
	ТекСтрока = Элементы.ДокументыКСогласованию.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда 
		ПоказатьПредупреждение(, "Выберите событие, которое необходимо согласовать");
		Возврат;
	КонецЕсли; 	
	Если СобытиеСогласовано(ТекСтрока) Тогда 
		ПоказатьПредупреждение(, "Событие уже согласовано");
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьРезультатЗапросаНаДоработку", ЭтотОбъект);
	ОткрытьФорму("РегистрСведений.энргСтатусСогласованияСобытий.Форма.ФормаВернутьНаДоработку",,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

&НаКлиенте
Процедура АктСверки(Команда)
	ТекДанные = Элементы.Должники.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьФорму("Отчет.бестАктСверки.Форма.ФормаОтчета",Новый Структура("Организация, Район, Договор", Организация, ТекДанные.Район, ТекДанные.Договор),ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьПисьмо(Команда)
	ТекДанные = Элементы.Должники.ТекущиеДанные;
	
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Договоры = Новый Массив;
	Для каждого эл из Элементы.Должники.ВыделенныеСтроки Цикл
		Договоры.Добавить(Новый Структура("Абонент", Элементы.Должники.ДанныеСтроки(эл).Договор));
	КонецЦикла;                                                         
	
	ОткрытьФорму("Документ.энргСобытие.ФормаОбъекта",Новый Структура("Организация, Район, Договоры, ТипСобытия", Организация, ТекДанные.Район, Договоры, ПредопределенноеЗначение("Справочник.энргСпособСвязи.ОтправкаПисьмаНаЭлектроннуюПочту")),ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура СвернутьОтборы(Команда)
	СтруктураНастроек = Новый Структура;
	СтруктураНастроек.Вставить("Группа3", Ложь);
	СтруктураНастроек.Вставить("РазвернутьОтборы", Истина);
	СтруктураНастроек.Вставить("СернутьОтборы", Ложь);
	НастроитьВидимостьЭлементов(СтруктураНастроек);
КонецПроцедуры

