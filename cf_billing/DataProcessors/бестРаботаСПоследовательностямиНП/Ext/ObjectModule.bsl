Функция НаборыПоТипам()
	
	Соотвествие  			= Новый Соответствие;	
	МассивРегистров  		= Новый Массив;
	МассивРегистров.Добавить("бестАвансыЭЭ");
	МассивРегистров.Добавить("бестВзаиморасчетыПоМесяцамЭЭ");
	МассивРегистров.Добавить("бестВзаиморасчетыПоАвансовымСчетам");
	МассивРегистров.Добавить("бестАвансыИспользованныеЭЭ");
	МассивРегистров.Добавить("бестВзаиморасчетыПоПениЭЭ");
	
	для Каждого Регистр из  МассивРегистров цикл
		Типы 					= Метаданные.РегистрыНакопления[Регистр].СтандартныеРеквизиты.Регистратор.Тип.типы();		
		Для Каждого ТипРегистратора из Типы цикл			
			Если Соотвествие.Получить(ТипРегистратора) = Неопределено тогда
				Массив 			= Новый Массив;
				Массив.Добавить(Регистр);
				Соотвествие.Вставить(ТипРегистратора,Массив);
			иначе
				Соотвествие[ТипРегистратора].добавить(Регистр);
			КонецЕсли;  			
		КонецЦикла;	
	КонецЦикла;
	
	Возврат Соотвествие;
	
КонецФункции

Функция ИзменитьСостояниеПоследовательности(Организация, ПериодНачисления,Район,ПроведенСНарушением,ПроведенВПоследовательности,Договор)
	Попытка
		НаборПоследовательности  					= РегистрыСведений.бестВзаиморасчетыПоследовательность.СоздатьНаборЗаписей();
		НаборПоследовательности.Отбор.Организация.установить(Организация);
		НаборПоследовательности.Отбор.ПериодНачисления.установить(ПериодНачисления);
		НаборПоследовательности.Отбор.Район.установить(Район);
		НаборПоследовательности.Отбор.СостояниеПроведения.установить(ПроведенСНарушением);
		Если Договор <> Неопределено тогда
			НаборПоследовательности.Отбор.Договор.установить(Договор);
		КонецЕсли;
		НаборПоследовательности.Прочитать();
		ТаблицаНабора  								= НаборПоследовательности.Выгрузить();
		НаборПоследовательности.Очистить();
		НаборПоследовательности.Записать();
		
		ТаблицаНабора.ЗаполнитьЗначения(ПроведенВПоследовательности,"СостояниеПроведения");
		
		НаборПоследовательности  					= РегистрыСведений.бестВзаиморасчетыПоследовательность.СоздатьНаборЗаписей();
		НаборПоследовательности.Загрузить(ТаблицаНабора);
		НаборПоследовательности.Записать(Ложь);
		Возврат Истина;
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

Функция ПровестиВзаиморасчеты(ПараметрыПроведения,МассивДокументовНачисления)
	
	Организация 								= ПараметрыПроведения.Организация;
	ПериодНачисления							= ПараметрыПроведения.ПериодНачисления;
	Район										= ПараметрыПроведения.Район;
	МассивДокументов							= ПараметрыПроведения.МассивДокументов;
	ДанныеЗадолженности							= ПараметрыПроведения.ДанныеЗадолженности;
	Исключен  									= Перечисления.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности;
	ПроведенВПоследоватености  					= Перечисления.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности;
	Начисления									= ПараметрыПроведения.ДанныеНачислений;
	Оплата										= ПараметрыПроведения.ДанныеОплаты;
	текДокРегистратор 							= Неопределено;
	
	Параметры 									= Новый Структура("
	|Организация, ПериодНачисления, Район,
	|Авансы, СуммаАванса, ДанныеЗадолженности, СтавкаНДС, ДанныеКорректировки",
	Организация, ПериодНачисления, Район,
	ПараметрыПроведения.Авансы, ПараметрыПроведения.СуммаАванса, ДанныеЗадолженности, ПараметрыПроведения.СтавкаНДС, ПараметрыПроведения.ДанныеКорректировки);
	
	для Каждого Документ из МассивДокументов цикл  		
		ОчищатьСтроки 							= Истина;
		Если текДокРегистратор = Документ.ДокРегистратор Тогда
			ОчищатьСтроки 						= Ложь;
		КонецЕсли;
		
		Если Документ.состояниепроведения  = Исключен тогда 			
			// Очищаем данные.
			НаборПоследовательности 			= РегистрыСведений.бестВзаиморасчетыПоследовательность.СоздатьНаборЗаписей();
			НаборПоследовательности.Отбор.ДокРегистратор.установить(Документ.ДокРегистратор);
			НаборПоследовательности.Отбор.Организация.установить(Организация);
			НаборПоследовательности.Отбор.ПериодНачисления.установить(ПериодНачисления);
			НаборПоследовательности.Отбор.Район.установить(Район);
			НаборПоследовательности.Отбор.СостояниеПроведения.установить(Документ.СостояниеПроведения);
			НаборПоследовательности.Отбор.Договор.установить(Документ.Договор);
			НаборПоследовательности.Записать();		
			Продолжить;
		КонецЕсли;
		
		текДокРегистратор 						= Документ.ДокРегистратор;
		
		ДанныеДокумента  						= Новый Структура;
		ДанныеДокумента.Вставить("Договор", 				Документ.Договор);				
		ДанныеДокумента.Вставить("Период",					Документ.ДатаРегистратора);
		ДанныеДокумента.Вставить("ИсточникПоступления",		Документ.ИсточникПоступления);		
		ДанныеДокумента.Вставить("Регистратор",				текДокРегистратор);
		ДанныеДокумента.Вставить("ЭтоОплата",				Документ.ЭтоОплата);
		
		
		СтруктураТаблицНаборов 					= СтруктураТаблицНаборов(МассивДокументовНачисления, ОчищатьСтроки, ДанныеДокумента, ПараметрыПроведения, текДокРегистратор);
		
		ДанныеДокумента.Вставить("НаборТаблиц",							СтруктураТаблицНаборов.НаборТаблиц);
		ДанныеДокумента.Вставить("НаборыЗаписей",						СтруктураТаблицНаборов.НаборыЗаписей);
		
		
		Если Не Документ.ЭтоОплата тогда
			ДанныеНачисления					= Начисления[текДокРегистратор];									
			Если ДанныеНачисления <> Неопределено тогда				
				УвеличитьЗадолженность(Параметры, ДанныеДокумента, ДанныеНачисления);
			КонецЕсли;		
		Иначе	
			ДанныеОплаты						= Оплата[текДокРегистратор];
			РасшифровкаОплаты 					= ДанныеОплаты.Расшифровка;
			Для Каждого СтрокаОплаты Из РасшифровкаОплаты Цикл
				Если ЗначениеЗаполнено(СтрокаОплаты.МассивПД) Тогда
					Для каждого СтруктураПД из СтрокаОплаты.МассивПД Цикл
						СписатьЗадолженность(Параметры, ДанныеДокумента, СтрокаОплаты.Сумма, СтрокаОплаты.IDСтрокиОплаты, СтруктураПД.ПД, СтруктураПД.СуммаОплатыРаспределенная);
						Если СтрокаОплаты.Сумма <= 0 Тогда
							Прервать;
						КонецЕсли;
					КонецЦикла;
					
				Иначе
					СписатьЗадолженность(Параметры, ДанныеДокумента, СтрокаОплаты.Сумма, СтрокаОплаты.IDСтрокиОплаты);
				КонецЕсли;
				Если СтрокаОплаты.Сумма > 0 Тогда
					УвеличитьАванс(Параметры,ДанныеДокумента,СтрокаОплаты.Сумма, СтрокаОплаты.IDСтрокиОплаты, Параметры.ПериодНачисления);
				КонецЕсли;				
			КонецЦикла;			 
		КонецЕсли;
		
		// Удаляем не нужные параметры.
		МассивПараметров  						= ПараметрыВзаиморасчетов();
		для Каждого УдаляемыйПараметр из МассивПараметров цикл
			Если Параметры.Свойство(УдаляемыйПараметр) тогда
				Параметры.Удалить(УдаляемыйПараметр);
			КонецЕсли;			
		КонецЦикла;
		
		// Не будем выполнять запись сразу, сначало пройдем все договоры.
		//Если ТипЗнч(текДокРегистратор) = Тип("ДокументСсылка.бестРеализацияЮрЛица")
		//	или ТипЗнч(текДокРегистратор) = Тип("ДокументСсылка.бестПлатежноеПоручениеВходящееЮрЛица") тогда
		//	
		//	НаборыЗаписей 				= Новый Структура("бестВзаиморасчётыПоУслугамЮрЛица,бестАвансы,бестАвансыИспользованные");			
		//	НаборТаблиц 				= Новый Структура("бестАвансы,бестАвансыИспользованные,бестВзаиморасчётыПоУслугамЮрЛица"); 			
		//	 									
		//	Если ТипЗнч(текДокРегистратор) = Тип("ДокументСсылка.бестПлатежноеПоручениеВходящееЮрЛица") Тогда				
		//		НаборыЗаписей.Вставить("бестОплатаУслуг",		 	Неопределено);
		//		НаборыЗаписей.Вставить("бестАвансыПоступившие",	Неопределено);				
		//		НаборТаблиц.Вставить("бестОплатаУслуг",				Неопределено);
		//		НаборТаблиц.Вставить("бестАвансыПоступившие",		Неопределено);
		//	КонецЕсли;  	
		//	ЗаполнитьЗначенияСвойств(НаборыЗаписей,ДанныеДокумента.НаборыЗаписей);
		//	ЗаполнитьЗначенияСвойств(НаборТаблиц,ДанныеДокумента.НаборТаблиц);
		//	
		//	НаборыОтложеннаяЗапись		= Новый Структура("НаборыЗаписей, НаборТаблиц", НаборыЗаписей, НаборТаблиц);
		//				
		//	Если МассивДокументовНачисления.получить(текДокРегистратор) = Неопределено тогда				
		//		МассивДокументовНачисления.вставить(текДокРегистратор,НаборыОтложеннаяЗапись);
		//	иначе
		//		МассивДокументовНачисления[текДокРегистратор] = НаборыОтложеннаяЗапись;
		//	КонецЕсли;
		//	ПараметрыПроведения.вставить("ЕстьДокументыНачисления",Истина); 
		//	Продолжить;
		//иначе
		НаборыЗаписей 				= ДанныеДокумента.НаборыЗаписей;
		НаборТаблиц 				= ДанныеДокумента.НаборТаблиц;
		для Каждого  СтрокаНабора из НаборыЗаписей цикл
			СтрокаНабора.Значение.загрузить(НаборТаблиц[СтрокаНабора.ключ]);
		КонецЦикла;			 			
		//КонецЕсли;   	
		
		Попытка
			для Каждого СтрокаНаборов из НаборыЗаписей цикл
				СтрокаНаборов.Значение.записать();
			КонецЦикла;		
		Исключение                      
			Представление 				= "Не восстановлена последоватеность по договору: " + Документ.Договор;
			Представление  				= Представление +Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Представление);
			Возврат Истина;
		КонецПопытки;
	КонецЦикла; 
	
	Возврат Ложь;
КонецФункции

Функция СтруктураТаблицНаборов(МассивДокументовНачисления, ОчищатьСтроки, ДанныеДокумента, ПараметрыПроведения, ДокРегистратор)
	
	НаборТаблиц  					= Новый Структура;
	НаборыЗаписей 					= Новый Структура;		
	
	МассивИмен  					= ПараметрыПроведения.НаборыПоТипам.получить(ТипЗнч(ДокРегистратор));
	для Каждого ИмяРегистра из МассивИмен цикл
		Набор  						= РегистрыНакопления[ИмяРегистра].СоздатьНаборЗаписей();
		Набор.Отбор.регистратор.установить(ДокРегистратор);
		Набор.Прочитать();
		
		Таблица 					= Набор.выгрузить();
		Набор.Очистить();
		НаборыЗаписей.Вставить(ИмяРегистра,Набор);
		НаборТаблиц.Вставить(ИмяРегистра,Таблица);
	КонецЦикла;							
	//КонецЕсли;
	
	Если ОчищатьСтроки  Тогда
		для Каждого СтрокаТаблиц из НаборТаблиц цикл
			Строки 						= СтрокаТаблиц.Значение.НайтиСтроки(Новый Структура("Договор",ДанныеДокумента.Договор));
			для Каждого Строка из Строки цикл
				СтрокаТаблиц.Значение.Удалить(Строка);
			КонецЦикла;  			
		КонецЦикла; 		
	КонецЕсли;
	
	Возврат Новый Структура("НаборТаблиц,НаборыЗаписей",НаборТаблиц,НаборыЗаписей);
	
КонецФункции

Функция ПараметрыВзаиморасчетов()
	
	МассивКлючей  = Новый Массив;
	МассивКлючей.Добавить("СнятьТекущие");
	МассивКлючей.Добавить("ВозвратАванса");
	МассивКлючей.Добавить("ДанныеНачисления");
	МассивКлючей.Добавить("ИсточникПоступления");
	Возврат МассивКлючей;	
КонецФункции

#Область РаботаСАвансами

Процедура ДобавитьРасходАванса(ПараметрыОперации, ДанныеДокумента, Сумма, ПараметрыИспользованияАванса)
	
	ТаблицаАвансы 										= ДанныеДокумента.НаборТаблиц.бестАвансыЭЭ;
	ТаблицаАвансыИспользованные 						= ДанныеДокумента.НаборТаблиц.бестАвансыИспользованныеЭЭ;
	
	Авансы 												= ПараметрыОперации.Авансы;
	ОсталосьСписать 									= Сумма;
	УдаляемыеСтроки 									= Новый Массив;
	
	Для Сч = 0 По Авансы.ВГраница() Цикл	
		
		Списываем 										= Мин(Авансы[Сч].СуммаАванса,ОсталосьСписать);
		ОсталосьСписать 								= ОсталосьСписать - Списываем;
		Авансы[Сч].СуммаАванса 							= Авансы[Сч].СуммаАванса - Списываем;
		
		Если Авансы[Сч].СуммаАванса = 0 Тогда
			УдаляемыеСтроки.Добавить(Сч);
		КонецЕсли;
		
		ЗаписьАвансы  									= ТаблицаАвансы.добавить();
		ЗаписьАвансы.ВидДвижения 						= ВидДвиженияНакопления.Расход;
		ЗаписьАвансы.Активность  						= истина;
		ЗаписьАвансы.Период  							= ДанныеДокумента.Период;			
		ЗаписьАвансы.Договор  							= ДанныеДокумента.Договор;
		ЗаписьАвансы.Сумма 								= Списываем;
		ЗаписьАвансы.СуммаНДС 							= Списываем - Списываем / (1 + ПараметрыОперации.СтавкаНДС/100);
		ЗаписьАвансы.ПериодНачисления 					= Авансы[Сч].ПериодНачисления;
		ЗаписьАвансы.ПериодРасчета 						= ПараметрыИспользованияАванса.ПериодРасчета;
		ЗаписьАвансы.Организация 						= ПараметрыОперации.Организация;
		ЗаписьАвансы.Район  							= ПараметрыОперации.Район;
		ЗаписьАвансы.ДокументОплаты 					= Авансы[Сч].ДокументОплаты;
		ЗаписьАвансы.IDСтрокиОплаты 					= Авансы[Сч].IDСтрокиОплаты;
		
		
		ЗаписьАвансыИспользованые					= ТаблицаАвансыИспользованные.добавить();
		ЗаписьАвансыИспользованые.Активность		= Истина;
		ЗаписьАвансыИспользованые.Период  			= ДанныеДокумента.Период;		
		ЗаписьАвансыИспользованые.Договор			= ДанныеДокумента.Договор;
		ЗаписьАвансыИспользованые.Сумма 			= Списываем;
		ЗаписьАвансыИспользованые.СуммаНДС 			= Списываем - Списываем / (1 + ПараметрыОперации.СтавкаНДС/100);
		ЗаписьАвансыИспользованые.ПериодНачисления 	= ПараметрыИспользованияАванса.ПериодНачисления;
		ЗаписьАвансыИспользованые.ПериодРасчета 	= ПараметрыИспользованияАванса.ПериодРасчета;
		ЗаписьАвансыИспользованые.Организация		= ПараметрыОперации.Организация;
		ЗаписьАвансыИспользованые.Район  			= ПараметрыОперации.Район;
		ЗаписьАвансыИспользованые.ДокументОплаты	= Авансы[Сч].ДокументОплаты;
		ЗаписьАвансыИспользованые.IDСтрокиОплаты 	= Авансы[Сч].IDСтрокиОплаты; 
		ЗаписьАвансыИспользованые.ПлатежныйДокумент = ДанныеДокумента.Регистратор;
		
		
		
		Если ОсталосьСписать = 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Смещение 											= 0;
	
	Для Индекс = 0 По УдаляемыеСтроки.ВГраница() Цикл
		Авансы.Удалить(УдаляемыеСтроки[Индекс - Смещение]);
		Смещение 										= Смещение + 1;
	КонецЦикла;
	
КонецПроцедуры

Процедура УвеличитьАванс(ПараметрыОперации,ДанныеДокумента,Сумма,IDСтрокиОплаты,ПериодВзаиморасчетов)
	
	ТаблицаАвансы 									= ДанныеДокумента.НаборТаблиц.бестАвансыЭЭ;
	мАвансы 										= ПараметрыОперации.Авансы;
	Если ТипЗнч(ДанныеДокумента.Регистратор) = Тип("ДокументСсылка.бестПлатежныйДокумент") 
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеДокумента.Регистратор, "ВидОперации") = Перечисления.бестВидыОпераций.ПлатежныйДокумент_Корректировка Тогда
		ДанныеКорректировки = ПараметрыОперации.ДанныеКорректировки;
		СуммаОплаты = ДанныеКорректировки.СуммаОплаты;
		Оплаты = ДанныеКорректировки.Оплаты;
		Индекс = 0;
		КоличествоОплат = Оплаты.Количество();
		Пока Сумма > 0 И Не Индекс = КоличествоОплат Цикл
			Оплата 											= Оплаты[Индекс];
			ЗаписьАвансы  									= ТаблицаАвансы.добавить();
			ЗаписьАвансы.ВидДвижения 						= ВидДвиженияНакопления.Приход;
			ЗаписьАвансы.Активность  						= Истина;
			ЗаписьАвансы.Период  							= ДанныеДокумента.Период;	
			ЗаписьАвансы.Договор  							= ДанныеДокумента.Договор;
			ЗаписьАвансы.ДокументОплаты						= Оплата.ДокументОплаты;
			ЗаписьАвансы.Сумма 								= Мин(Сумма, Оплата.Сумма);
			ЗаписьАвансы.СуммаНДС 							= ЗаписьАвансы.Сумма - ЗаписьАвансы.Сумма / (1 + ПараметрыОперации.СтавкаНДС / 100);
			ЗаписьАвансы.Район  							= ПараметрыОперации.Район;
			ЗаписьАвансы.ПериодНачисления					= ПараметрыОперации.ПериодНачисления;
			ЗаписьАвансы.Организация						= ПараметрыОперации.Организация;
			ЗаписьАвансы.IDСтрокиОплаты						= Оплата.IDСтрокиОплаты;
			ЗаписьАвансы.ПериодРасчета						= ПараметрыОперации.ПериодНачисления;	
			
			ОписаниеАванса 									= ОписаниеАванса();
			ОписаниеАванса.СуммаАванса 						= ЗаписьАвансы.Сумма;
			ОписаниеАванса.ДокументОплаты 					= Оплата.ДокументОплаты;
			ОписаниеАванса.IDСтрокиОплаты					= Оплата.IDСтрокиОплаты;
			ПараметрыОперации.СуммаАванса					= ПараметрыОперации.СуммаАванса + ЗаписьАвансы.Сумма;
			мАвансы.Добавить(ОписаниеАванса);
			
			Индекс											= Индекс + 1;
			Сумма											= Сумма - ЗаписьАвансы.Сумма;
		КонецЦикла;
	Иначе
		ЗаписьАвансы  									= ТаблицаАвансы.добавить();
		ЗаписьАвансы.ВидДвижения 						= ВидДвиженияНакопления.Приход;
		ЗаписьАвансы.Активность  						= Истина;
		ЗаписьАвансы.Период  							= ДанныеДокумента.Период;	
		ЗаписьАвансы.Договор  							= ДанныеДокумента.Договор;
		ЗаписьАвансы.ДокументОплаты						= ДанныеДокумента.Регистратор;
		ЗаписьАвансы.Сумма 								= Сумма;
		ЗаписьАвансы.СуммаНДС 							= Сумма - Сумма / (1 + ПараметрыОперации.СтавкаНДС/100);
		ЗаписьАвансы.Район  							= ПараметрыОперации.Район;
		ЗаписьАвансы.ПериодНачисления					= ПериодВзаиморасчетов;
		ЗаписьАвансы.Организация						= ПараметрыОперации.Организация;
		ЗаписьАвансы.IDСтрокиОплаты						= IDСтрокиОплаты;
		ЗаписьАвансы.ПериодРасчета						= ПараметрыОперации.ПериодНачисления;
		
		Если ПериодВзаиморасчетов <= ПараметрыОперации.ПериодНачисления Тогда
			ОписаниеАванса 									= ОписаниеАванса();
			ОписаниеАванса.СуммаАванса 						= Сумма;
			ОписаниеАванса.ДокументОплаты 					= ДанныеДокумента.Регистратор;
			ОписаниеАванса.IDСтрокиОплаты					= IDСтрокиОплаты;
			ОписаниеАванса.ПериодНачисления					= ПериодВзаиморасчетов; 
			
			ПараметрыОперации.СуммаАванса					= ПараметрыОперации.СуммаАванса + Сумма;
			мАвансы.Добавить(ОписаниеАванса);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УменьшитьАванс(ПараметрыОперации, ДанныеДокумента,ДанныеНачислений)	
	
	яДанныеНачислений	 									= ДанныеНачислений.Расшифровка;
	ОсталосьСписать											= ПараметрыОперации.СуммаАванса;
	ПериодыЗадолженности 									= яДанныеНачислений.Скопировать();
	Для Каждого ТекСтрока Из ПериодыЗадолженности Цикл
		ТекСтрока.СуммаНачислений = Макс(0, ТекСтрока.СуммаНачислений);	
	КонецЦикла;
	ПериодыЗадолженности.Свернуть("ПериодРасчета","СуммаНачислений");
	ПериодыЗадолженности.Сортировать("ПериодРасчета");	
	
	ТаблицаАвансыИспользованные								= ДанныеДокумента.НаборТаблиц.бестАвансыИспользованныеЭЭ;
	
	Для Сч = 0 По ПериодыЗадолженности.Количество() - 1 Цикл
		
		СтрокиВПериоде 										= яДанныеНачислений.НайтиСтроки(Новый Структура("ПериодРасчета", ПериодыЗадолженности[Сч].ПериодРасчета));
		
		Для ИндексСтроки = 0 По СтрокиВПериоде.ВГраница() Цикл			
			ОбщаяСуммаЗаПериод								= ПериодыЗадолженности[Сч].СуммаНачислений;
			
			Если ОбщаяСуммаЗаПериод = 0 Тогда 
				Продолжить;
			КонецЕсли;			
			
			Если СтрокиВПериоде[ИндексСтроки].СуммаНачислений < 0 ИЛИ СтрокиВПериоде[ИндексСтроки].ТипЗадолженности = Перечисления.бестВидыРасчета.Авансовый Тогда 
				Продолжить;
			КонецЕсли;
			
			Списываем 										= Мин(ОсталосьСписать, СтрокиВПериоде[ИндексСтроки].СуммаНачислений);
			ОсталосьСписать 								= ОсталосьСписать - Списываем;
			СтрокиВПериоде[ИндексСтроки].СуммаНачислений	= СтрокиВПериоде[ИндексСтроки].СуммаНачислений - Списываем;
			СтрокиВПериоде[ИндексСтроки].СуммаНачисленийНДС	= СтрокиВПериоде[ИндексСтроки].СуммаНачислений * ПараметрыОперации.СтавкаНДС / (100 + ПараметрыОперации.СтавкаНДС);
			ПараметрыИспользованияАванса  					= Новый Структура("ТипЗадолженности,ПериодРасчета,ПериодНачисления", СтрокиВПериоде[ИндексСтроки].ТипЗадолженности,СтрокиВПериоде[ИндексСтроки].ПериодРасчета,СтрокиВПериоде[ИндексСтроки].ПериодНачисления);
			ДобавитьРасходАванса(ПараметрыОперации, ДанныеДокумента, Списываем,ПараметрыИспользованияАванса);
		КонецЦикла;
	КонецЦикла;
	
	ПараметрыОперации.СуммаАванса 							= ОсталосьСписать;
	
КонецПроцедуры

Функция АвансНаГраницу(Договор,ВыборкаАванс)
	
	Авансы  				= Новый Массив;
	СуммаАванса 			= 0;
	Если Договор  = ВыборкаАванс.Договор тогда		
		Пока Договор = ВыборкаАванс.Договор цикл 			
			ОписаниеАванса 	= ОписаниеАванса();
			ЗаполнитьЗначенияСвойств(ОписаниеАванса, ВыборкаАванс);
			Авансы.Добавить(ОписаниеАванса);
			СуммаАванса 	= СуммаАванса + ВыборкаАванс.СуммаАванса;
			Если не ВыборкаАванс.следующий() тогда
				Прервать;
			КонецЕсли;  				
		КонецЦикла;				  
	КонецЕсли; 			
	
	Возврат Новый Структура("Авансы, СуммаАванса", Авансы, СуммаАванса);
	
КонецФункции

Функция КорректировкаОплаченныхНачислений(Договор, ВыборкаКорректировка)
	
	Оплаты  				= Новый Массив;
	СуммаОплаты 			= 0;
	Если Договор  = ВыборкаКорректировка.Договор тогда		
		Пока Договор = ВыборкаКорректировка.Договор цикл 			
			ОписаниеОплаты 	= ОписаниеОплаты();
			ЗаполнитьЗначенияСвойств(ОписаниеОплаты, ВыборкаКорректировка);
			Оплаты.Добавить(ОписаниеОплаты);
			СуммаОплаты 	= СуммаОплаты + ВыборкаКорректировка.Сумма;
			Если не ВыборкаКорректировка.следующий() тогда
				Прервать;
			КонецЕсли;  				
		КонецЦикла;				  
	КонецЕсли; 			
	
	Возврат Новый Структура("Оплаты, СуммаОплаты", Оплаты, СуммаОплаты);
	
КонецФункции

Функция ОписаниеАванса()
	Возврат Новый Структура("IDСтрокиОплаты,ДокументОплаты,ПериодНачисления, СуммаАванса");	
КонецФункции

Функция ОписаниеОплаты()
	Возврат Новый Структура("IDСтрокиОплаты,ДокументОплаты, Сумма");	
КонецФункции

Функция РезультатКорректировкаОплаченныхНачислений(МВТ)
	Текст 	=
	"ВЫБРАТЬ
	|	ДокументыДляПроведения.ПериодНачисления КАК ПериодНачисления,
	|	ДокументыДляПроведения.Район КАК Район,
	|	ДокументыДляПроведения.Договор КАК Договор,
	|	ДокументыДляПроведения.ДокРегистратор КАК ДокРегистратор,
	|	бестВзаиморасчетыПоМесяцамЭЭ.Регистратор КАК ДокументОплаты,
	|	бестВзаиморасчетыПоМесяцамЭЭ.IDСтрокиОплаты КАК IDСтрокиОплаты,
	|	бестВзаиморасчетыПоМесяцамЭЭ.Сумма КАК Сумма,
	|	бестВзаиморасчетыПоМесяцамЭЭ.СуммаНДС КАК СуммаНДС
	|ИЗ
	|	ДокументыДляПроведения КАК ДокументыДляПроведения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокументКорректировка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.бестВзаиморасчетыПоМесяцамЭЭ КАК бестВзаиморасчетыПоМесяцамЭЭ
	|				ПО бестПлатежныйДокумент.Ссылка = бестВзаиморасчетыПоМесяцамЭЭ.ПлатежныйДокумент
	|					И (бестВзаиморасчетыПоМесяцамЭЭ.Регистратор ССЫЛКА Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица)
	|			ПО бестПлатежныйДокументКорректировка.ДокументИсточник = бестПлатежныйДокумент.Ссылка
	|		ПО ДокументыДляПроведения.ДокРегистратор = бестПлатежныйДокументКорректировка.Ссылка
	|			И (бестПлатежныйДокументКорректировка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.ПлатежныйДокумент_Корректировка))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокументыДляПроведения.ПериодНачисления,
	|	ДокументыДляПроведения.Район,
	|	ДокументыДляПроведения.Договор,
	|	ДокументыДляПроведения.ДокРегистратор,
	|	бестАвансыЭЭ.ДокументОплаты,
	|	бестАвансыЭЭ.IDСтрокиОплаты,
	|	бестАвансыЭЭ.Сумма,
	|	бестАвансыЭЭ.СуммаНДС
	|ИЗ
	|	ДокументыДляПроведения КАК ДокументыДляПроведения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокументКорректировка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.бестАвансыЭЭ КАК бестАвансыЭЭ
	|				ПО бестПлатежныйДокумент.Ссылка = бестАвансыЭЭ.Регистратор
	|			ПО бестПлатежныйДокументКорректировка.ДокументИсточник = бестПлатежныйДокумент.Ссылка
	|		ПО ДокументыДляПроведения.ДокРегистратор = бестПлатежныйДокументКорректировка.Ссылка
	|			И (бестПлатежныйДокументКорректировка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.ПлатежныйДокумент_Корректировка))
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПериодНачисления,
	|	Район,
	|	Договор,
	|	ДокРегистратор,
	|	Сумма УБЫВ";
	
	Запрос  						= Новый Запрос(Текст);
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Возврат Запрос.Выполнить();
КонецФункции

#КонецОбласти

#Область РаботаСЗадолженностью

Процедура УвеличитьЗадолженность(ПараметрыОперации, ДанныеДокумента, ДанныеНачислений)
	
	Если ПараметрыОперации.СуммаАванса > 0 тогда
		УменьшитьАванс(ПараметрыОперации, ДанныеДокумента,ДанныеНачислений);
	КонецЕсли;
	
	Район  												= ПараметрыОперации.Район;
	Договор  											= ДанныеДокумента.Договор;	
	ДанныеЗадолженности 								= ПараметрыОперации.ДанныеЗадолженности;
	ТаблицаВзаиморасчетыПоМесяцам 						= ДанныеДокумента.НаборТаблиц.бестВзаиморасчетыПоМесяцамЭЭ;
	//ТаблицаВзаиморасчетыПоАвансовымСчетам 				= ДанныеДокумента.НаборТаблиц.бестВзаиморасчетыПоАвансовымСчетам;
	
	ТаблицаЗадолженности  								= ДанныеЗадолженности.Расшифровка;
	РасшифровкаНачислений 								= ДанныеНачислений.Расшифровка;
	
	РасшифровкаНачислений.Сортировать("СуммаНачислений,ПериодРасчета");
	// сначала отрицательные строки записываем в аванс
	для Каждого СтрокаНачисления из РасшифровкаНачислений цикл
		
		Если СтрокаНачисления.СуммаНачислений = 0 тогда
			Продолжить;
		ИначеЕсли  СтрокаНачисления.СуммаНачислений < 0 тогда
			//ОтрицательнаяСуммаНачислений(ПараметрыОперации,ДанныеДокумента,-СтрокаНачисления.СуммаНачислений,СтрокаНачисления.Услуга,СтрокаНачисления.Поставщик,СтрокаНачисления.ПериодРасчета);
			//СтрокаНачисления.СуммаНачислений = 0;
			Продолжить;
		КонецЕсли;
		
	КонецЦикла;
	
	// Если отрицательные строки дали аванс, то закрываем им положительнве строки из этого же документа
	Если ПараметрыОперации.СуммаАванса > 0 тогда
		УменьшитьАванс(ПараметрыОперации, ДанныеДокумента,ДанныеНачислений);
	КонецЕсли;
	
	РасшифровкаНачислений 								= ДанныеНачислений.Расшифровка;
	БылиИзменения 										= Ложь;
	
	для Каждого СтрокаНачисления из РасшифровкаНачислений цикл
		
		Если СтрокаНачисления.СуммаНачислений = 0 тогда
			Продолжить;
		ИначеЕсли  СтрокаНачисления.СуммаНачислений < 0 тогда
			//ОтрицательнаяСуммаНачислений(ПараметрыОперации,ДанныеДокумента,-СтрокаНачисления.СуммаНачислений,СтрокаНачисления.Услуга,СтрокаНачисления.Поставщик,СтрокаНачисления.ПериодРасчета);
			Продолжить;
		КонецЕсли;
		
		БылиИзменения 									= Истина;
		
		СтрокаЗадолженности  							= ТаблицаЗадолженности.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаЗадолженности, СтрокаНачисления);
		СтрокаЗадолженности.СуммаЗадолженности			= СтрокаНачисления.СуммаНачислений;
		
		//СтрокаВзаиморасчеты 							= ?(СтрокаНачисления.ТипЗадолженности = Перечисления.бестВидыРасчета.Фактический, ТаблицаВзаиморасчетыПоМесяцам.Добавить(), ТаблицаВзаиморасчетыПоАвансовымСчетам.Добавить());
		СтрокаВзаиморасчеты 							= ТаблицаВзаиморасчетыПоМесяцам.Добавить();
		СтрокаВзаиморасчеты.Организация					= ПараметрыОперации.Организация;	
		СтрокаВзаиморасчеты.Район 						= ПараметрыОперации.Район;
		СтрокаВзаиморасчеты.ВидДвижения					= ВидДвиженияНакопления.Приход;
		СтрокаВзаиморасчеты.Активность					= Истина;
		СтрокаВзаиморасчеты.Период 						= ДанныеДокумента.Период;
		СтрокаВзаиморасчеты.Договор 					= ДанныеДокумента.Договор; 		
		СтрокаВзаиморасчеты.Сумма 						= СтрокаНачисления.СуммаНачислений;
		СтрокаВзаиморасчеты.СуммаНДС 					= СтрокаНачисления.СуммаНачисленийНДС;
		СтрокаВзаиморасчеты.ПлатежныйДокумент 			= ?(ТипЗнч(СтрокаНачисления.ПлатежныйДокумент) = Тип("ДокументСсылка.бестПлатежныйДокумент"),СтрокаНачисления.ПлатежныйДокумент,Документы.бестПлатежныйДокумент.ПустаяСсылка());
		СтрокаВзаиморасчеты.ПериодРасчета				= СтрокаНачисления.ПериодРасчета;
		СтрокаВзаиморасчеты.ПериодНачисления			= СтрокаНачисления.ПериодНачисления;
	КонецЦикла; 
	
	Если БылиИзменения Тогда
		ТаблицаЗадолженности.Свернуть("ПериодРасчета,ПериодНачисления,ПлатежныйДокумент,ТипЗадолженности","СуммаЗадолженности");
		ТаблицаЗадолженности.Сортировать("ПериодРасчета");
		ДанныеЗадолженности.СуммаЗадолженности 			= ТаблицаЗадолженности.Итог("СуммаЗадолженности");
	КонецЕсли;
	
КонецПроцедуры

Процедура СписатьЗадолженность(ПараметрыОперации,ДанныеДокумента,Сумма, IDСтрокиОплаты, ПлатежныйДокумент = Неопределено, СуммаОплатыРаспределенная = 0)
	
	Если Сумма <= 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПлатежныйДокумент = Неопределено И ЗначениеЗаполнено(ПлатежныйДокумент) Тогда
		яПлатежныйДокумент 							= ПлатежныйДокумент;
	КонецЕсли;
	
	Если яПлатежныйДокумент <> Неопределено Тогда
		СписатьЗадолженностьПоПД(ПараметрыОперации,ДанныеДокумента,Сумма,IDСтрокиОплаты,яПлатежныйДокумент, СуммаОплатыРаспределенная);
	Иначе
		СписатьСамуюРаннююЗадолженность(ПараметрыОперации, ДанныеДокумента, Сумма, IDСтрокиОплаты);
	КонецЕсли;
	
КонецПроцедуры 

Процедура СписатьСамуюРаннююЗадолженность(ПараметрыОперации,ДанныеДокумента,НадоСписать,IDСтрокиОплаты)
	
	ТаблицаВзаиморасчетыПоМесяцам 						= ДанныеДокумента.НаборТаблиц.бестВзаиморасчетыПоМесяцамЭЭ;
	
	ДанныеЗадолженности 								= ПараметрыОперации.ДанныеЗадолженности;
	Расшифровка 										= ДанныеЗадолженности.Расшифровка;
	
	МассивУдаляемых										= Новый Массив;
	
	для Каждого СтрокаЗадолженности из Расшифровка цикл
		Если СтрокаЗадолженности.ТипЗадолженности = Перечисления.бестВидыРасчета.Фактический Тогда
			Списываем 										= Мин(СтрокаЗадолженности.СуммаЗадолженности,НадоСписать);
			
			СтрокаЗадолженности.СуммаЗадолженности 			= СтрокаЗадолженности.СуммаЗадолженности - Списываем;
			
			Если СтрокаЗадолженности.СуммаЗадолженности = 0 тогда
				МассивУдаляемых.Добавить(СтрокаЗадолженности);
			КонецЕсли;
			
			СтрокаВзаиморасчеты 							= ТаблицаВзаиморасчетыПоМесяцам.Добавить();
			СтрокаВзаиморасчеты.Организация		 			= ПараметрыОперации.Организация;
			СтрокаВзаиморасчеты.Район 						= ПараметрыОперации.Район;
			СтрокаВзаиморасчеты.ПериодНачисления 			= СтрокаЗадолженности.ПериодНачисления;
			СтрокаВзаиморасчеты.ПериодРасчета 				= СтрокаЗадолженности.ПериодРасчета;
			СтрокаВзаиморасчеты.ВидДвижения					= ВидДвиженияНакопления.Расход;
			СтрокаВзаиморасчеты.Активность					= Истина;
			СтрокаВзаиморасчеты.Период 						= ДанныеДокумента.Период;		
			СтрокаВзаиморасчеты.Договор 					= ДанныеДокумента.Договор;
			СтрокаВзаиморасчеты.Сумма 						= Списываем;
			СтрокаВзаиморасчеты.СуммаНДС 					= Списываем - Списываем / (1 + ПараметрыОперации.СтавкаНДС/100);
			СтрокаВзаиморасчеты.ПлатежныйДокумент			= СтрокаЗадолженности.ПлатежныйДокумент;
			СтрокаВзаиморасчеты.IDСтрокиОплаты      		= IDСтрокиОплаты;
			
			
			НадоСписать										= НадоСписать - Списываем;
			Если НадоСписать = 0 Тогда
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 
	
	для Каждого УдаляемаяСтрока из МассивУдаляемых цикл
		Расшифровка.удалить(УдаляемаяСтрока);
	КонецЦикла;
		
КонецПроцедуры

Процедура СписатьЗадолженностьПоПД(ПараметрыОперации,ДанныеДокумента,НадоСписать,IDСтрокиОплаты, ПлатежныйДокумент, СуммаОплатыРаспределенная)
	перем яПлатежныйДокумент;
	ДанныеЗадолженности 						= ПараметрыОперации.ДанныеЗадолженности.Расшифровка;		
	
	ТаблицаВзаиморасчетыПоМесяцам 				= ДанныеДокумента.НаборТаблиц.бестВзаиморасчетыПоМесяцамЭЭ;
	ТаблицаВзаиморасчетыПоАвансовымСчетам 		= ДанныеДокумента.НаборТаблиц.бестВзаиморасчетыПоАвансовымСчетам;
	ТаблицаВзаиморасчетыПоПени 					= ДанныеДокумента.НаборТаблиц.бестВзаиморасчетыПоПениЭЭ;
	ЭтоОплата 									= Истина;
	
	СтруктураПоиска  							= Новый Структура("ПлатежныйДокумент");
	СтруктураПоиска.ПлатежныйДокумент 			= ПлатежныйДокумент;
	
	СтрокиЗадолженности 						= ДанныеЗадолженности.НайтиСтроки(СтруктураПоиска);
	
	МассивУдаляемых 							= Новый Массив;
	
	НадоСписатьВсего 							= НадоСписать;
	для Каждого СтрокаЗадолженности из СтрокиЗадолженности цикл
		Если СуммаОплатыРаспределенная <> 0 Тогда
			Списываем 								= Мин(СуммаОплатыРаспределенная,СтрокаЗадолженности.СуммаЗадолженности);
		Иначе
			Списываем 								= Мин(НадоСписатьВсего,СтрокаЗадолженности.СуммаЗадолженности);
		КонецЕсли;
		
		// Уменьшаем задолженность по месяцам.
		Если СтрокаЗадолженности.ТипЗадолженности = Перечисления.бестВидыРасчета.Фактический Тогда
			СтрокаВзаиморасчеты 					= ТаблицаВзаиморасчетыПоМесяцам.Добавить();
		ИначеЕсли СтрокаЗадолженности.ТипЗадолженности = Перечисления.бестВидыРасчета.Авансовый Тогда
			СтрокаВзаиморасчеты 					= ТаблицаВзаиморасчетыПоАвансовымСчетам.Добавить();
		ИначеЕсли СтрокаЗадолженности.ТипЗадолженности = Перечисления.бестВидыРасчета.Пеня Тогда
			СтрокаВзаиморасчеты 					= ТаблицаВзаиморасчетыПоПени.Добавить();
		КонецЕсли;
				
		СтрокаВзаиморасчеты.Активность	 		= Истина;
		СтрокаВзаиморасчеты.ВидДвижения 		= ВидДвиженияНакопления.Расход;
		СтрокаВзаиморасчеты.Организация 		= ПараметрыОперации.Организация;
		СтрокаВзаиморасчеты.Район		 		= ПараметрыОперации.Район;
		СтрокаВзаиморасчеты.Договор				= ДанныеДокумента.Договор;
		СтрокаВзаиморасчеты.Период	 			= ДанныеДокумента.период;
		СтрокаВзаиморасчеты.Сумма				= Списываем;
		СтрокаВзаиморасчеты.ПлатежныйДокумент   = СтрокаЗадолженности.ПлатежныйДокумент;
		СтрокаВзаиморасчеты.ПериодНачисления    = СтрокаЗадолженности.ПериодНачисления;
		СтрокаВзаиморасчеты.ПериодРасчета    	= СтрокаЗадолженности.ПериодРасчета;
		СтрокаВзаиморасчеты.IDСтрокиОплаты      = IDСтрокиОплаты;
		
		Если СтрокаЗадолженности.ТипЗадолженности <> Перечисления.бестВидыРасчета.Пеня Тогда
			СтрокаВзаиморасчеты.СуммаНДС 			= Списываем - Списываем / (1 + ПараметрыОперации.СтавкаНДС / 100);
		КонецЕсли;
		
		Если СтрокаЗадолженности.ТипЗадолженности = Перечисления.бестВидыРасчета.Авансовый Тогда
			УвеличитьАванс(ПараметрыОперации,ДанныеДокумента,Списываем,IDСтрокиОплаты, СтрокаЗадолженности.ПериодНачисления);
			СтрокаЗадолженности.СуммаЗадолженности = 0;
			//НадоСписать = 0; 
			НадоСписать 							= НадоСписать - Списываем;
		Иначе
			СтрокаЗадолженности.СуммаЗадолженности 	= СтрокаЗадолженности.СуммаЗадолженности - Списываем; 		
			НадоСписать 							= НадоСписать - Списываем;
		КонецЕсли;		
		
		Если СтрокаЗадолженности.СуммаЗадолженности = 0 тогда
			МассивУдаляемых.Добавить(СтрокаЗадолженности);
		КонецЕсли;  		
		
		Если НадоСписать = 0 Тогда
			Прервать;
		КонецЕсли; 		
		
	КонецЦикла;
	
	для Каждого УдаляемаяСтрока из МассивУдаляемых цикл
		ДанныеЗадолженности.Удалить(УдаляемаяСтрока);				
	КонецЦикла;
	
КонецПроцедуры

Функция ОписаниеЗадолженности()
	Возврат Новый ФиксированнаяСтруктура("СуммаЗадолженности,Расшифровка");	
КонецФункции

Функция ЗадолженностьНаГраницу(Договор,ВыборкаЗадолженность)
	перем ТекПериодыЗадолженность,ТекУслуга,ЗадолженностьУслуга;
	
	РасшифровкаЗадолженности						= ТаблицаРасшифровкиЗадолженности();
	
	ОписаниеЗадолженности  							= ОписаниеЗадолженности();
	
	ЗадолженностьВсего  							= 0;
	
	Если Договор  = ВыборкаЗадолженность.Договор тогда		
		Пока Договор = ВыборкаЗадолженность.Договор цикл 			
			Если ЗначениеЗаполнено(ВыборкаЗадолженность.ПериодРасчета) Тогда 				
				СтрокаЗадолженности  					= РасшифровкаЗадолженности.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаЗадолженности, ВыборкаЗадолженность);
				СтрокаЗадолженности.СуммаЗадолженности	= ВыборкаЗадолженность.ЗадолженностьНачалоПериода;
				ЗадолженностьВсего 						= ЗадолженностьВсего + ВыборкаЗадолженность.ЗадолженностьНачалоПериода;
			КонецЕсли;
			Если не ВыборкаЗадолженность.следующий() тогда
				Прервать;
			КонецЕсли;  				
		КонецЦикла;				  
	КонецЕсли; 	
	
	Результат  										= Новый Структура(ОписаниеЗадолженности);
	Результат.СуммаЗадолженности 					= ЗадолженностьВсего;
	Результат.Расшифровка 							= РасшифровкаЗадолженности;
	
	Возврат Результат;
КонецФункции

Функция ТаблицаРасшифровкиЗадолженности()
	
	ПериодыЗадолженности  							= Новый ТаблицаЗначений;
	Колонки  										= ПериодыЗадолженности.Колонки;	
	Колонки.Добавить("ПериодРасчета",				Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	Колонки.Добавить("ПериодНачисления",			Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	Колонки.Добавить("СуммаЗадолженности",			Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));
	Колонки.Добавить("ПлатежныйДокумент",			Новый ОписаниеТипов("ДокументСсылка.бестПлатежныйДокумент"));
	Колонки.Добавить("ТипЗадолженности",			Новый ОписаниеТипов("ПеречислениеСсылка.бестВидыРасчета"));
	
	Возврат ПериодыЗадолженности;
КонецФункции 

Функция РезультатЗадолженностьФактическая(Организация, ПериодНачисления,Район,Договор,МВТ,НачалоПериодаРасчета,КонецПериодаРасчета)
	
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("ПериодНачисления",		ПериодНачисления);
	Запрос.УстановитьПараметр("НачалоПериодаРасчета",	НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("КонецПериодаРасчета",	КонецПериодаРасчета);
	
	Текст 							= ТекстЗадолженностьНаГраницу();
	
	Если Не ЗначениеЗаполнено(Договор) Тогда
		Текст = СтрЗаменить(Текст, "Договор = &Договор", "Истина");
	Иначе
		Запрос.УстановитьПараметр("Договор",				Договор);
	КонецЕсли;
	
	Запрос.Текст 					= Текст;
	Возврат Запрос.Выполнить();	
КонецФункции

Функция РезультатДанныеНачислений(МВТ)
	
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Запрос.Текст 		=
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.Договор КАК Договор,
	|	ВложенныйЗапрос.ДокРегистратор КАК ДокРегистратор,
	|	ВложенныйЗапрос.ПериодРасчета КАК ПериодРасчета,
	|	ВложенныйЗапрос.СуммаНачислений КАК СуммаНачислений,
	|	ВложенныйЗапрос.ТипЗадолженности КАК ТипЗадолженности,
	|	ВложенныйЗапрос.СуммаНачисленийНДС КАК СуммаНачисленийНДС
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДокументыДляПроведения.ПериодНачисления КАК ПериодНачисления,
	|		ДокументыДляПроведения.Район КАК Район,
	|		ДокументыДляПроведения.Договор КАК Договор,
	|		ДокументыДляПроведения.ДокРегистратор КАК ДокРегистратор,
	|		ДокументыДляПроведения.ПериодНачисления КАК ПериодРасчета,
	|		бестПлатежныйДокумент.ИтоговаяСумма - ЕСТЬNULL(ПДДокументИсточник.ИтоговаяСумма, 0) КАК СуммаНачислений,
	|		бестПлатежныйДокумент.ТипЗадолженности КАК ТипЗадолженности,
	|		бестПлатежныйДокумент.ИтоговаяСуммаНДС - ЕСТЬNULL(ПДДокументИсточник.ИтоговаяСуммаНДС, 0) КАК СуммаНачисленийНДС
	|	ИЗ
	|		ДокументыДляПроведения КАК ДокументыДляПроведения
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК ПДДокументИсточник
	|				ПО бестПлатежныйДокумент.ДокументИсточник = ПДДокументИсточник.Ссылка
	|			ПО ДокументыДляПроведения.ДокРегистратор = бестПлатежныйДокумент.Ссылка
	|	ГДЕ
	|		НЕ ДокументыДляПроведения.ЭтоОплата
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ДокументыДляПроведения.ПериодНачисления,
	|		ДокументыДляПроведения.Район,
	|		ДокументыДляПроведения.Договор,
	|		ДокументыДляПроведения.ДокРегистратор,
	|		ДокументыДляПроведения.ПериодНачисления,
	|		СУММА(бестКорректировкаЗадолженностиВозвратОплаты.СуммаВозврата),
	|		ЗНАЧЕНИЕ(Перечисление.бестВидыРасчета.Фактический),
	|		СУММА(бестКорректировкаЗадолженностиВозвратОплаты.СуммаВозвратаНДС)
	|	ИЗ
	|		Документ.бестКорректировкаЗадолженности.ВозвратОплаты КАК бестКорректировкаЗадолженностиВозвратОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестКорректировкаЗадолженности КАК бестКорректировкаЗадолженности
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДокументыДляПроведения КАК ДокументыДляПроведения
	|				ПО (ДокументыДляПроведения.ДокРегистратор = бестКорректировкаЗадолженности.Ссылка)
	|			ПО бестКорректировкаЗадолженностиВозвратОплаты.Ссылка = бестКорректировкаЗадолженности.Ссылка
	|	ГДЕ
	|		бестКорректировкаЗадолженности.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.КорректировкаЗадолженности_ВозвратПлатежа)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ДокументыДляПроведения.ПериодНачисления,
	|		ДокументыДляПроведения.Договор,
	|		ДокументыДляПроведения.Район,
	|		ДокументыДляПроведения.ДокРегистратор,
	|		ДокументыДляПроведения.ПериодНачисления
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ДокументыДляПроведения.ПериодНачисления,
	|		ДокументыДляПроведения.Район,
	|		ДокументыДляПроведения.Договор,
	|		ДокументыДляПроведения.ДокРегистратор,
	|		ДокументыДляПроведения.ПериодНачисления,
	|		СУММА(бестКорректировкаЗадолженностиПереносОплаты.Сумма),
	|		ЗНАЧЕНИЕ(Перечисление.бестВидыРасчета.Фактический),
	|		СУММА(бестКорректировкаЗадолженностиПереносОплаты.СуммаНДС)
	|	ИЗ
	|		Документ.бестКорректировкаЗадолженности КАК бестКорректировкаЗадолженности
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДокументыДляПроведения КАК ДокументыДляПроведения
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестКорректировкаЗадолженности.ПереносОплаты КАК бестКорректировкаЗадолженностиПереносОплаты
	|				ПО ДокументыДляПроведения.ДокРегистратор = бестКорректировкаЗадолженностиПереносОплаты.Ссылка
	|			ПО (ДокументыДляПроведения.ДокРегистратор = бестКорректировкаЗадолженности.Ссылка)
	|	ГДЕ
	|		бестКорректировкаЗадолженности.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.КорректировкаЗадолженности_ПереносПлатежа)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ДокументыДляПроведения.ПериодНачисления,
	|		ДокументыДляПроведения.Договор,
	|		ДокументыДляПроведения.Район,
	|		ДокументыДляПроведения.ДокРегистратор,
	|		ДокументыДляПроведения.ПериодНачисления) КАК ВложенныйЗапрос
	|ГДЕ
	|	ВложенныйЗапрос.СуммаНачислений <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПериодНачисления,
	|	Район,
	|	Договор,
	|	ТипЗадолженности,
	|	ДокРегистратор";	
	
	Возврат Запрос.Выполнить(); 	
КонецФункции

Функция ДанныеНачислений(Договор,ВыборкаДанныеНачислений)
	перем ТекРасшифровкаНачислений;	
	
	РасшифровкаНачислений  									= Новый ТаблицаЗначений;
	РасшифровкаНачислений.Колонки.Добавить("ПериодРасчета",				Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РасшифровкаНачислений.Колонки.Добавить("ПериодНачисления",			Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РасшифровкаНачислений.Колонки.Добавить("СуммаНачислений",			Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));
	РасшифровкаНачислений.Колонки.Добавить("СуммаНачисленийНДС",		Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));
	СписокТипов = Новый Массив;
	СписокТипов.Добавить("ДокументСсылка.бестПлатежныйДокумент");
	СписокТипов.Добавить("ДокументСсылка.бестКорректировкаЗадолженности");
	РасшифровкаНачислений.Колонки.Добавить("ПлатежныйДокумент",			Новый ОписаниеТипов(СписокТипов));
	РасшифровкаНачислений.Колонки.Добавить("ТипЗадолженности",			Новый ОписаниеТипов("ПеречислениеСсылка.бестВидыРасчета"));
	
	
	ОписаниеНачислений  									= Новый ФиксированнаяСтруктура("СуммаНачислений,Расшифровка");
	СуммаНачислений 										= 0;
	ТекДокументНачисления 									= Неопределено;
	
	Результат  												= Новый Соответствие;
	
	Если Договор  = ВыборкаДанныеНачислений.Договор тогда		
		Пока Договор = ВыборкаДанныеНачислений.Договор цикл 			
			
			Если НЕ ТекДокументНачисления = ВыборкаДанныеНачислений.ДокРегистратор Тогда
				Если НЕ ТекДокументНачисления = Неопределено Тогда
					текОписаниеНачислений 					= Новый Структура(ОписаниеНачислений);
					текОписаниеНачислений.СуммаНачислений 	= СуммаНачислений;
					текОписаниеНачислений.Расшифровка 		= ТекРасшифровкаНачислений;
					Результат.Вставить(ТекДокументНачисления, текОписаниеНачислений);
				КонецЕсли;				
				ТекРасшифровкаНачислений 					= РасшифровкаНачислений.Скопировать();
			КонецЕсли;
			
			СтрокаНачисления	  							= ТекРасшифровкаНачислений.Добавить();
			СтрокаНачисления.ПериодРасчета 					= ВыборкаДанныеНачислений.ПериодРасчета;
			СтрокаНачисления.ПериодНачисления 				= ВыборкаДанныеНачислений.ПериодНачисления;
			СтрокаНачисления.СуммаНачислений				= ВыборкаДанныеНачислений.СуммаНачислений;
			СтрокаНачисления.СуммаНачисленийНДС				= ВыборкаДанныеНачислений.СуммаНачисленийНДС;
			СтрокаНачисления.ПлатежныйДокумент				= ВыборкаДанныеНачислений.ДокРегистратор;
			СтрокаНачисления.ТипЗадолженности				= ВыборкаДанныеНачислений.ТипЗадолженности;
			СуммаНачислений 								= СуммаНачислений + ВыборкаДанныеНачислений.СуммаНачислений;
			ТекДокументНачисления 							= ВыборкаДанныеНачислений.ДокРегистратор;
			
			Если не ВыборкаДанныеНачислений.следующий() тогда
				Прервать;
			КонецЕсли;  				
		КонецЦикла;				  
	КонецЕсли; 	
	
	Если НЕ ТекДокументНачисления = Неопределено Тогда
		текОписаниеНачислений 								= Новый Структура(ОписаниеНачислений);
		текОписаниеНачислений.СуммаНачислений 				= СуммаНачислений;
		текОписаниеНачислений.Расшифровка 					= ТекРасшифровкаНачислений;
		Результат.Вставить(ТекДокументНачисления, текОписаниеНачислений);
	КонецЕсли;
	
	Возврат Результат; 
	
КонецФункции

#КонецОбласти

#Область Оплата

Функция РезультатФактическойПереплаты(Организация, ПериодНачисления,район,Договор,МВТ,НачалоПериодаРасчета,КонецПериодаРасчета)
	
	Запрос  						= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("ПериодНачисления",		ПериодНачисления);
	Запрос.УстановитьПараметр("НачалоПериодаРасчета",	НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("КонецПериодаРасчета",	КонецПериодаРасчета);
	Текст 							= ТекстФактическаяПереплатаНаГраницу();
	Если Не ЗначениеЗаполнено(Договор) Тогда
		Текст = СтрЗаменить(Текст, "Договор = &Договор", "Истина");
	Иначе
		Запрос.УстановитьПараметр("Договор",				Договор);
	КонецЕсли;	
	Запрос.Текст 					= Текст;
	Возврат Запрос.Выполнить();	
	
КонецФункции

Функция РезультатОплата(МВТ, НачалоПериодаРасчета)
	
	Текст 	=
	"ВЫБРАТЬ
	|	ДокументыДляПроведения.ПериодНачисления КАК ПериодНачисления,
	|	ДокументыДляПроведения.Район КАК Район,
	|	ДокументыДляПроведения.Договор КАК Договор,
	|	ДокументыДляПроведения.ДокРегистратор КАК ДокРегистратор,
	|	бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата.СуммаОплаты КАК Сумма,
	|	ЕСТЬNULL(бестПлатежноеПоручениеВходящееЭЭЮрЛицаДокументыНачисления.ДокументНачисления, ЗНАЧЕНИЕ(Документ.бестПлатежныйДокумент.пустаяссылка)) КАК ПлатежныйДокумент,
	|	бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата.IDСтроки КАК IDСтрокиОплаты,
	|	бестПлатежноеПоручениеВходящееЭЭЮрЛицаДокументыНачисления.ПериодНачисления КАК ПериодВзаиморасчетов,
	|	бестПлатежныйДокумент.ТипЗадолженности КАК ТипЗадолженности,
	|	бестПлатежныйДокумент.ВидОперации КАК ВидОперации,
	|	ЕСТЬNULL(бестПлатежноеПоручениеВходящееЭЭЮрЛицаДокументыНачисления.СуммаОплаты, 0) КАК СуммаОплатыРаспределенная
	|ПОМЕСТИТЬ ВходящееПоручение
	|ИЗ
	|	ДокументыДляПроведения КАК ДокументыДляПроведения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица.Оплата КАК бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица.ДокументыНачисления КАК бестПлатежноеПоручениеВходящееЭЭЮрЛицаДокументыНачисления
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|				ПО бестПлатежноеПоручениеВходящееЭЭЮрЛицаДокументыНачисления.ДокументНачисления = бестПлатежныйДокумент.Ссылка
	|			ПО бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата.Ссылка = бестПлатежноеПоручениеВходящееЭЭЮрЛицаДокументыНачисления.Ссылка
	|				И бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата.IDСтроки = бестПлатежноеПоручениеВходящееЭЭЮрЛицаДокументыНачисления.IDСтроки
	|		ПО ДокументыДляПроведения.ДокРегистратор = бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата.Ссылка
	|			И ДокументыДляПроведения.Договор = бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата.Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВходящееПоручение.ПериодНачисления КАК ПериодНачисления,
	|	ВходящееПоручение.Район КАК Район,
	|	ВходящееПоручение.Договор КАК Договор,
	|	ВходящееПоручение.ДокРегистратор КАК ДокРегистратор,
	|	ВходящееПоручение.Сумма КАК Сумма,
	|	ВходящееПоручение.ПлатежныйДокумент КАК ПлатежныйДокумент,
	|	ВходящееПоручение.IDСтрокиОплаты КАК IDСтрокиОплаты,
	|	ВходящееПоручение.ПериодВзаиморасчетов КАК ПериодВзаиморасчетов,
	|	ВходящееПоручение.ТипЗадолженности КАК ТипЗадолженности,
	|	ВходящееПоручение.СуммаОплатыРаспределенная КАК СуммаОплатыРаспределенная
	|ПОМЕСТИТЬ ПлатежноеПоручениеСчетаНаОстаток
	|ИЗ
	|	ВходящееПоручение КАК ВходящееПоручение
	|ГДЕ
	|	(ВходящееПоручение.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.ПлатежныйДокумент_Расчетный)
	|			ИЛИ ВходящееПоручение.ПлатежныйДокумент = ЗНАЧЕНИЕ(Документ.бестПлатежныйДокумент.пустаяссылка)
	|			ИЛИ ВходящееПоручение.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.ПлатежныйДокумент_Пеня))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВходящееПоручение.ПериодНачисления,
	|	ВходящееПоручение.Район,
	|	ВходящееПоручение.Договор,
	|	ВходящееПоручение.ДокРегистратор,
	|	ВходящееПоручение.Сумма,
	|	бестПлатежныйДокумент.Ссылка,
	|	ВходящееПоручение.IDСтрокиОплаты,
	|	бестПлатежныйДокумент.ПериодНачисления,
	|	бестПлатежныйДокумент.ТипЗадолженности,
	|	ВходящееПоручение.СуммаОплатыРаспределенная
	|ИЗ
	|	ВходящееПоручение КАК ВходящееПоручение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент.НеоплаченныеСчета КАК бестПлатежныйДокументНеоплаченныеСчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|			ПО бестПлатежныйДокументНеоплаченныеСчета.ПлатежныйДокумент = бестПлатежныйДокумент.Ссылка
	|		ПО ВходящееПоручение.ПлатежныйДокумент = бестПлатежныйДокументНеоплаченныеСчета.Ссылка
	|ГДЕ
	|	ВходящееПоручение.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.ПлатежныйДокумент_СчетНаОстаток)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыДляПроведения.ПериодНачисления КАК ПериодНачисления,
	|	ДокументыДляПроведения.Район КАК Район,
	|	ДокументыДляПроведения.Договор КАК Договор,
	|	ДокументыДляПроведения.ДокРегистратор КАК ДокРегистратор,
	|	бестКорректировкаЗадолженностиПереносОплаты.Сумма КАК Сумма,
	|	ЕСТЬNULL(бестКорректировкаЗадолженностиДокументыНачисления.ДокументНачисления, ЗНАЧЕНИЕ(Документ.бестПлатежныйДокумент.пустаяссылка)) КАК ПлатежныйДокумент,
	|	бестКорректировкаЗадолженностиПереносОплаты.IDСтрокиОплата КАК IDСтрокиОплаты,
	|	бестКорректировкаЗадолженностиДокументыНачисления.ПериодНачисления КАК ПериодВзаиморасчетов,
	|	ЗНАЧЕНИЕ(Перечисление.бестВидыРасчета.Фактический) КАК ТипЗадолженности,
	|	0 КАК СуммаОплатыРаспределенная
	|ИЗ
	|	ДокументыДляПроведения КАК ДокументыДляПроведения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестКорректировкаЗадолженности.ПереносОплаты КАК бестКорректировкаЗадолженностиПереносОплаты
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестКорректировкаЗадолженности.ДокументыНачисления КАК бестКорректировкаЗадолженностиДокументыНачисления
	|			ПО бестКорректировкаЗадолженностиПереносОплаты.Ссылка = бестКорректировкаЗадолженностиДокументыНачисления.Ссылка
	|				И бестКорректировкаЗадолженностиПереносОплаты.IDСтрокиОплата = бестКорректировкаЗадолженностиДокументыНачисления.IDСтрокиОплата
	|		ПО ДокументыДляПроведения.ДокРегистратор = бестКорректировкаЗадолженностиПереносОплаты.Ссылка
	|			И ДокументыДляПроведения.Договор = бестКорректировкаЗадолженностиПереносОплаты.Договор
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестКорректировкаЗадолженности КАК бестКорректировкаЗадолженности
	|		ПО ДокументыДляПроведения.ДокРегистратор = бестКорректировкаЗадолженности.Ссылка
	|ГДЕ
	|	бестКорректировкаЗадолженности.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.КорректировкаЗадолженности_ПереносПлатежа)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПлатежноеПоручениеСчетаНаОстаток.ПериодНачисления,
	|	ПлатежноеПоручениеСчетаНаОстаток.Район,
	|	ПлатежноеПоручениеСчетаНаОстаток.Договор,
	|	ПлатежноеПоручениеСчетаНаОстаток.ДокРегистратор,
	|	ПлатежноеПоручениеСчетаНаОстаток.Сумма,
	|	ПлатежноеПоручениеСчетаНаОстаток.ПлатежныйДокумент,
	|	ПлатежноеПоручениеСчетаНаОстаток.IDСтрокиОплаты,
	|	ПлатежноеПоручениеСчетаНаОстаток.ПериодВзаиморасчетов,
	|	ПлатежноеПоручениеСчетаНаОстаток.ТипЗадолженности,
	|	ПлатежноеПоручениеСчетаНаОстаток.СуммаОплатыРаспределенная
	|ИЗ
	|	ПлатежноеПоручениеСчетаНаОстаток КАК ПлатежноеПоручениеСчетаНаОстаток
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокументыДляПроведения.ПериодНачисления,
	|	ДокументыДляПроведения.Район,
	|	ДокументыДляПроведения.Договор,
	|	ДокументыДляПроведения.ДокРегистратор,
	|	ЕСТЬNULL(ПДДокументИсточник.ИтоговаяСумма, 0) - бестПлатежныйДокумент.ИтоговаяСумма,
	|	ЗНАЧЕНИЕ(Документ.бестПлатежныйДокумент.пустаяссылка),
	|	"""",
	|	ДокументыДляПроведения.ПериодНачисления,
	|	ЗНАЧЕНИЕ(Перечисление.бестВидыРасчета.Фактический),
	|	0
	|ИЗ
	|	ДокументыДляПроведения КАК ДокументыДляПроведения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК ПДДокументИсточник
	|			ПО бестПлатежныйДокумент.ДокументИсточник = ПДДокументИсточник.Ссылка
	|		ПО ДокументыДляПроведения.ДокРегистратор = бестПлатежныйДокумент.Ссылка
	|ГДЕ
	|	ДокументыДляПроведения.ЭтоОплата
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПериодНачисления,
	|	Район,
	|	Договор,
	|	ДокРегистратор";
	
	Запрос  						= Новый Запрос(Текст);
	Запрос.УстановитьПараметр("НачалоПериодаРасчета", НачалоПериодаРасчета);
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция ДанныеОплаты(Договор, ВыборкаОплата)
	перем ТекРасшифровкаОплаты;
	
	Результат  								= Новый Соответствие;
	
	РасшифровкаОплаты  						= Новый ТаблицаЗначений;
	РасшифровкаОплаты.Колонки.Добавить("ПериодВзаиморасчетов",	Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РасшифровкаОплаты.Колонки.Добавить("Сумма",					Новый ОписаниеТипов("Число"));
	РасшифровкаОплаты.Колонки.Добавить("IDСтрокиОплаты",		Новый ОписаниеТипов("Строка"));
	РасшифровкаОплаты.Колонки.Добавить("МассивПД",				Новый ОписаниеТипов("Массив"));
	
	ТекIDСтроки								= Неопределено;
	ТекДокументОплаты 						= Неопределено;
	ОписаниеОплаты  						=	 Новый ФиксированнаяСтруктура("Сумма,Расшифровка");
	Сумма 									= 0;
	Если Договор  = ВыборкаОплата.Договор тогда	
		Пока Договор = ВыборкаОплата.Договор цикл			
			Если НЕ ТекДокументОплаты = ВыборкаОплата.ДокРегистратор Тогда
				Если НЕ ТекДокументОплаты = Неопределено Тогда
					текОписание 			= Новый Структура(ОписаниеОплаты);
					текОписание.Сумма 		= Сумма;
					текОписание.Расшифровка = ТекРасшифровкаОплаты;
					Результат.Вставить(ТекДокументОплаты, текОписание);
				КонецЕсли;				
				ТекРасшифровкаОплаты 		= РасшифровкаОплаты.Скопировать();
			КонецЕсли;
			
			
			Если ТекIDСтроки <> ВыборкаОплата.IDСтрокиОплаты ИЛИ НЕ ЗначениеЗаполнено(ВыборкаОплата.ПлатежныйДокумент) Тогда
				СтрокаНачисления	  			= ТекРасшифровкаОплаты.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаНачисления,ВыборкаОплата);
				
				
				Сумма 							= Сумма + ВыборкаОплата.Сумма;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ВыборкаОплата.ПлатежныйДокумент) Тогда
				СтрокаНачисления.МассивПД.Добавить(
					Новый Структура("ПД, СуммаОплатыРаспределенная", ВыборкаОплата.ПлатежныйДокумент, ВыборкаОплата.СуммаОплатыРаспределенная));
			КонецЕсли;
			
			ТекДокументОплаты 				= ВыборкаОплата.ДокРегистратор;
			ТекIDСтроки						= ВыборкаОплата.IDСтрокиОплаты;
			
			Если не ВыборкаОплата.следующий() тогда
				Прервать;
			КонецЕсли;  				
		КонецЦикла;				  
	КонецЕсли;
	
	Если НЕ ТекДокументОплаты = Неопределено Тогда
		текОписание 						= Новый Структура(ОписаниеОплаты);
		текОписание.Сумма 					= Сумма;
		текОписание.Расшифровка 			= ТекРасшифровкаОплаты;
		Результат.Вставить(ТекДокументОплаты, текОписание);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

#КонецОбласти

