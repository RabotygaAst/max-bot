	Если НЕ ЗначениеЗаполнено(мОбъектыРасчета) Тогда
		Запрос.Текст 		= СтрЗаменить(Запрос.Текст,"бестДанныеПочасовойВедомости.ОбъектРасчета В(&мОбъектыРасчета)","ИСТИНА");
		Запрос.Текст 		= СтрЗаменить(Запрос.Текст,"бестПочасоваяВедомость.ОбъектРасчета В(&мОбъектыРасчета)","ИСТИНА");
	КонецЕсли;
	
	Если ИсключаяОтдельностоящие тогда
		Запрос.Текст 		= СтрЗаменить(Запрос.Текст,"бестДанныеПочасовойВедомости.МКД = &МКД","бестДанныеПочасовойВедомости.МКД <> &МКД");
		Запрос.Текст 		= СтрЗаменить(Запрос.Текст,"бестОбъектыРасчета.МКД = &МКД","бестОбъектыРасчета.МКД <> &МКД")
