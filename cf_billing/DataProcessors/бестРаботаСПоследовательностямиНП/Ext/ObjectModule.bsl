Процедура ОчиститьДанныеПочасовойВедомостиСрез(Организация, ПериодНачисления, Район, МКД, мОбъектыРасчета)
	Если ЗначениеЗаполнено(мОбъектыРасчета) Тогда
		Для каждого ОбъектРасчета из мОбъектыРасчета Цикл
			НаборДанныеПочасовойВедомостиСрез					= РегистрыСведений.бестДанныеПочасовойВедомостиСрез.СоздатьНаборЗаписей();
			НаборДанныеПочасовойВедомостиСрез.Отбор.Организация.установить(Организация);
			НаборДанныеПочасовойВедомостиСрез.Отбор.ПериодНачисления.установить(ПериодНачисления);
			НаборДанныеПочасовойВедомостиСрез.Отбор.Район.установить(Район);
			НаборДанныеПочасовойВедомостиСрез.Отбор.ОбъектРасчета.установить(ОбъектРасчета);
			НаборДанныеПочасовойВедомостиСрез.записать();
		КонецЦикла;
	Иначе
		НаборДанныеПочасовойВедомостиСрез					= РегистрыСведений.бестДанныеПочасовойВедомостиСрез.СоздатьНаборЗаписей();
		НаборДанныеПочасовойВедомостиСрез.Отбор.Организация.установить(Организация);
		НаборДанныеПочасовойВедомостиСрез.Отбор.ПериодНачисления.установить(ПериодНачисления);
		НаборДанныеПочасовойВедомостиСрез.Отбор.Район.установить(Район);
		Если Не МКД = Неопределено  Тогда
			НаборДанныеПочасовойВедомостиСрез.Отбор.МКД.установить(МКД);
		КонецЕсли;
		НаборДанныеПочасовойВедомостиСрез.записать();
	КонецЕсли;	
	
КонецПроцедуры

Функция ПолучитьДанныеПочасовойВедомостиСрез(Организация, ПериодНачисления, Район, МКД, ГраницыПериода, ИсключаяОтдельностоящие, мОбъектыРасчета)
	Запрос = Новый Запрос; 
	Запрос.Текст = ТекстЗапросаЗамещающийПрофиль();	
		
	Запрос.УстановитьПараметр("НачалоПериодаРасчета", 					ГраницыПериода.НачалоОП);
	Запрос.УстановитьПараметр("КонецПериодаРасчета", 					ГраницыПериода.ЗавершениеОП);
	Запрос.УстановитьПараметр("ПериодНачисления", 						ПериодНачисления);
	
	Запрос.УстановитьПараметр("НачалоПериодаРасчетаПредыдущийГод", 		ДобавитьМесяц(ГраницыПериода.НачалоОП, -12));
