Функция СтрокаЗаполненияРаздел1В(НастройкиРазделов, Выборка)
	
	СтрокаЗаполнения = Неопределено;
	Если Выборка.ВидЛица = "ЮЛ" Тогда
		Отбор = Новый Структура("КатегорияПотребителя, ЦеноваяКатегория", Выборка.КатегорияПотребителя, Выборка.ЦеноваяКатегория);
	Иначе
		Отбор = Новый Структура("ТарифнаяКатегория", Выборка.ТарифнаяКатегория);
	КонецЕсли;
	НайденныеНастройки = НастройкиРазделов[Выборка.ВидЛица].НайтиСтроки(Отбор);
	Если Не НайденныеНастройки.Количество() = 0 Тогда
		Если Выборка.СверхНорматива Тогда 
			СтрокаЗаполнения = НайденныеНастройки[0].НомерСтрокиСверхСоцНорматива;
		Иначе 
			СтрокаЗаполнения = НайденныеНастройки[0].НомерСтрокиВПределахСоцНорматива;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтрокаЗаполнения;
	
КонецФункции

