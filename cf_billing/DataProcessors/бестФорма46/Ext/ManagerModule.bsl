#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Функция ПолучитьДанныеРазделов(ПараметрыОтборов, ДополнительныеПараметры = Неопределено) Экспорт
	
	ДлительныеОперации.СообщитьПрогресс(, "Чтение данных");
	
	НастройкиРазделов = НастройкиРазделов();
	НастройкиРаздела1В = НастройкиРаздела1В();
	
	РезультатЗапросаПакет = РезультатЗапросаНачисления(ПараметрыОтборов);
	КолвоПакетов = РезультатЗапросаПакет.Количество();
	
	ДлительныеОперации.СообщитьПрогресс(, "Формирование раздела 1. А");
	РезультатЗапроса = РезультатЗапросаПакет[КолвоПакетов - 3];
	Раздел1А = СфомироватьТаблицуРаздела1А(НастройкиРазделов, РезультатЗапроса);
	
	ДлительныеОперации.СообщитьПрогресс(, "Формирование раздела 1. Б");
	РезультатЗапроса = РезультатЗапросаПакет[КолвоПакетов - 2];
	Раздел1Б = СфомироватьТаблицуРаздела1Б(НастройкиРазделов, РезультатЗапроса);
	
	ДлительныеОперации.СообщитьПрогресс(, "Формирование раздела 1. В");
	РезультатЗапроса = РезультатЗапросаПакет[КолвоПакетов - 1];
	Раздел1В = СфомироватьТаблицуРаздела1В(НастройкиРаздела1В, РезультатЗапроса);
	 
	Результат = Новый Структура("Раздел1А,Раздел1Б,Раздел1В", Раздел1А, Раздел1Б, Раздел1В);
	Возврат Результат;
	
КонецФункции

Функция НовыеПараметрыОтборов() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("НачалоОП", Дата(1,1,1));
	Результат.Вставить("КонецОП", Дата(1,1,1));
	Результат.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
	Результат.Вставить("Район", Справочники.энргЗоныОтвественности.ПустаяСсылка());
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция РезультатЗапросаНачисления(ПараметрыОтборов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСтавкиНДССрезПоследних.Организация КАК Организация,
		|	бестСтавкиНДССрезПоследних.СтавкаНДС КАК СтавкаНДС
		|ПОМЕСТИТЬ ТаблицаСтавкаНДС
		|ИЗ
		|	РегистрСведений.бестСтавкиНДС.СрезПоследних(&КонецОП, Организация = &Организация) КАК бестСтавкиНДССрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестОбъемНачисленийЭлектроэнергии.Период КАК Период,
		|	энргДоговорыКонтрагентов.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.бестВидыДоговоров.ДоговорКуплиПродажи) КАК ДоговорКуплиПродажи,
		|	бестОбъемНачисленийЭлектроэнергии.ЦеноваяКатегория КАК ЦеноваяКатегория,
		|	бестОбъемНачисленийЭлектроэнергии.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный,
		|	бестОбъемНачисленийЭлектроэнергии.МаксимальнаяМощность КАК МаксимальнаяМощность,
		|	энргДоговорыКонтрагентов.КатегорияПотребителя КАК КатегорияПотребителя,
		|	энргВидыУслуг.бестИспользоватьРасчетПоМощности КАК ЭтоМощность,
		|	СУММА(бестОбъемНачисленийЭлектроэнергии.ОбъемУслуги) КАК ОбъемУслуги,
		|	СУММА(ВЫБОР
		|			КОГДА бестОбъемНачисленийЭлектроэнергии.НДСВнутри
		|				ТОГДА бестОбъемНачисленийЭлектроэнергии.Сумма - бестОбъемНачисленийЭлектроэнергии.СуммаНДС
		|			ИНАЧЕ бестОбъемНачисленийЭлектроэнергии.Сумма
		|		КОНЕЦ) КАК Сумма,
		|	ВЫБОР
		|		КОГДА бестОбъемНачисленийЭлектроэнергии.НДСВнутри
		|			ТОГДА бестОбъемНачисленийЭлектроэнергии.Сумма
		|		ИНАЧЕ бестОбъемНачисленийЭлектроэнергии.Сумма + бестОбъемНачисленийЭлектроэнергии.СуммаНДС
		|	КОНЕЦ КАК СуммаСНДС,
		|	бестОбъемНачисленийЭлектроэнергии.Организация КАК Организация,
		|	бестОбъемНачисленийЭлектроэнергии.Район КАК Район,
		|	бестОбъемНачисленийЭлектроэнергии.ОбъектРасчета КАК ОбъектРасчета,
		|	бестОбъемНачисленийЭлектроэнергии.ТочкаУчета КАК ТочкаУчета,
		|	бестОбъемНачисленийЭлектроэнергии.ПриборУчета КАК ПриборУчета,
		|	бестОбъемНачисленийЭлектроэнергии.Шкала КАК Шкала,
		|	бестОбъемНачисленийЭлектроэнергии.ТарифнаяЗона КАК ТарифнаяЗона,
		|	бестОбъемНачисленийЭлектроэнергии.СпособНачисления КАК СпособНачисления
		|ПОМЕСТИТЬ НачисленияЮридическиеЛица
		|ИЗ
		|	РегистрНакопления.бестОбъемНачисленийЭлектроэнергии КАК бестОбъемНачисленийЭлектроэнергии
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
		|		ПО бестОбъемНачисленийЭлектроэнергии.Услуга = энргВидыУслуг.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
		|		ПО бестОбъемНачисленийЭлектроэнергии.Договор = энргДоговорыКонтрагентов.Ссылка
		|ГДЕ
		|	бестОбъемНачисленийЭлектроэнергии.Период МЕЖДУ &НачалоОП И &КонецОП
		|	И бестОбъемНачисленийЭлектроэнергии.Организация = &Организация
		|	И бестОбъемНачисленийЭлектроэнергии.Район = &Район
		|	И бестОбъемНачисленийЭлектроэнергии.Распределение = ЛОЖЬ
		|	И НЕ бестОбъемНачисленийЭлектроэнергии.СпособНачисления = ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.Реактив)
		|
		|СГРУППИРОВАТЬ ПО
		|	бестОбъемНачисленийЭлектроэнергии.УровеньНапряженияРасчетный,
		|	энргДоговорыКонтрагентов.КатегорияПотребителя,
		|	бестОбъемНачисленийЭлектроэнергии.ЦеноваяКатегория,
		|	энргВидыУслуг.бестИспользоватьРасчетПоМощности,
		|	бестОбъемНачисленийЭлектроэнергии.МаксимальнаяМощность,
		|	бестОбъемНачисленийЭлектроэнергии.Организация,
		|	бестОбъемНачисленийЭлектроэнергии.Район,
		|	бестОбъемНачисленийЭлектроэнергии.ОбъектРасчета,
		|	бестОбъемНачисленийЭлектроэнергии.ТочкаУчета,
		|	бестОбъемНачисленийЭлектроэнергии.ПриборУчета,
		|	бестОбъемНачисленийЭлектроэнергии.Шкала,
		|	бестОбъемНачисленийЭлектроэнергии.ТарифнаяЗона,
		|	бестОбъемНачисленийЭлектроэнергии.Период,
		|	бестОбъемНачисленийЭлектроэнергии.СпособНачисления,
		|	ВЫБОР
		|		КОГДА бестОбъемНачисленийЭлектроэнергии.НДСВнутри
		|			ТОГДА бестОбъемНачисленийЭлектроэнергии.Сумма
		|		ИНАЧЕ бестОбъемНачисленийЭлектроэнергии.Сумма + бестОбъемНачисленийЭлектроэнергии.СуммаНДС
		|	КОНЕЦ,
		|	энргДоговорыКонтрагентов.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.бестВидыДоговоров.ДоговорКуплиПродажи)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.Организация КАК Организация,
		|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.Район КАК Район,
		|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
		|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
		|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
		|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.Шкала КАК Шкала,
		|	бестВидыДифференцированностиПриборовУчетаНПСрезПоследних.ВидДифференцированности КАК ВидДифференцированности
		|ПОМЕСТИТЬ ВидыДифференцированности
		|ИЗ
		|	РегистрСведений.бестВидыДифференцированностиПриборовУчетаНП.СрезПоследних(
		|			&КонецОП,
		|			Организация = &Организация
		|				И Район = &Район
		|				И (ОбъектРасчета, ТочкаУчета, ПриборУчета, Шкала) В
		|					(ВЫБРАТЬ
		|						НачисленияЮридическиеЛица.ОбъектРасчета КАК ОбъектРасчета,
		|						НачисленияЮридическиеЛица.ТочкаУчета КАК ТочкаУчета,
		|						НачисленияЮридическиеЛица.ПриборУчета КАК ПриборУчета,
		|						НачисленияЮридическиеЛица.Шкала КАК Шкала
		|					ИЗ
		|						НачисленияЮридическиеЛица КАК НачисленияЮридическиеЛица)) КАК бестВидыДифференцированностиПриборовУчетаНПСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НачисленияЮридическиеЛица.ДоговорКуплиПродажи КАК ДоговорКуплиПродажи,
		|	НачисленияЮридическиеЛица.ЦеноваяКатегория КАК ЦеноваяКатегория,
		|	НачисленияЮридическиеЛица.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный,
		|	НачисленияЮридическиеЛица.МаксимальнаяМощность КАК МаксимальнаяМощность,
		|	НачисленияЮридическиеЛица.КатегорияПотребителя КАК КатегорияПотребителя,
		|	НачисленияЮридическиеЛица.ЭтоМощность КАК ЭтоМощность,
		|	НачисленияЮридическиеЛица.ОбъемУслуги КАК ОбъемУслуги,
		|	НачисленияЮридическиеЛица.Сумма КАК Сумма,
		|	НачисленияЮридическиеЛица.СуммаСНДС КАК СуммаСНДС,
		|	НачисленияЮридическиеЛица.Организация КАК Организация,
		|	НачисленияЮридическиеЛица.Район КАК Район,
		|	НачисленияЮридическиеЛица.ОбъектРасчета КАК ОбъектРасчета,
		|	НачисленияЮридическиеЛица.ТочкаУчета КАК ТочкаУчета,
		|	НачисленияЮридическиеЛица.ПриборУчета КАК ПриборУчета,
		|	НачисленияЮридическиеЛица.Шкала КАК Шкала,
		|	НачисленияЮридическиеЛица.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ВидыДифференцированности.ВидДифференцированности КАК ВидДифференцированности
		|ПОМЕСТИТЬ НачисленияЮридическиеЛицаРазделВ
		|ИЗ
		|	НачисленияЮридическиеЛица КАК НачисленияЮридическиеЛица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВидыДифференцированности КАК ВидыДифференцированности
		|		ПО НачисленияЮридическиеЛица.Организация = ВидыДифференцированности.Организация
		|			И НачисленияЮридическиеЛица.Район = ВидыДифференцированности.Район
		|			И НачисленияЮридическиеЛица.ОбъектРасчета = ВидыДифференцированности.ОбъектРасчета
		|			И НачисленияЮридическиеЛица.ТочкаУчета = ВидыДифференцированности.ТочкаУчета
		|			И НачисленияЮридическиеЛица.ПриборУчета = ВидыДифференцированности.ПриборУчета
		|			И НачисленияЮридическиеЛица.Шкала = ВидыДифференцированности.Шкала
		|			И (НЕ НачисленияЮридическиеЛица.ЭтоМощность)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестТочкиПоставкиТочекУчетаЮЛСрезПоследних.Организация КАК Организация,
		|	бестТочкиПоставкиТочекУчетаЮЛСрезПоследних.Район КАК Район,
		|	бестТочкиПоставкиТочекУчетаЮЛСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
		|	бестТочкиПоставкиТочекУчетаЮЛСрезПоследних.ТочкаУчета КАК ТочкаУчета,
		|	бестТочкиПоставкиТочекУчетаЮЛСрезПоследних.ТочкаПоставки КАК ТочкаПоставки
		|ПОМЕСТИТЬ ВТ_ТочкиПоставки
		|ИЗ
		|	РегистрСведений.бестТочкиПоставкиТочекУчетаЮЛ.СрезПоследних(
		|			,
		|			(Организация, Район, ОбъектРасчета, ТочкаУчета) В
		|				(ВЫБРАТЬ
		|					НачисленияЮридическиеЛица.Организация КАК Организация,
		|					НачисленияЮридическиеЛица.Район КАК Район,
		|					НачисленияЮридическиеЛица.ОбъектРасчета КАК ОбъектРасчета,
		|					НачисленияЮридическиеЛица.ТочкаУчета КАК ТочкаУчета
		|				ИЗ
		|					НачисленияЮридическиеЛица КАК НачисленияЮридическиеЛица)) КАК бестТочкиПоставкиТочекУчетаЮЛСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргПараметрыТочекПоставки.МоментВремени КАК МоментВремени,
		|	энргПараметрыТочекПоставки.Период КАК Период,
		|	энргПараметрыТочекПоставки.Регистратор КАК Регистратор,
		|	ВТ_ТочкиПоставки.Организация КАК Организация,
		|	ВТ_ТочкиПоставки.Район КАК Район,
		|	ВТ_ТочкиПоставки.ОбъектРасчета КАК ОбъектРасчета,
		|	ВТ_ТочкиПоставки.ТочкаУчета КАК ТочкаУчета,
		|	энргПараметрыТочекПоставки.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный,
		|	энргПараметрыТочекПоставки.МаксимальнаяМощность КАК МаксимальнаяМощность
		|ПОМЕСТИТЬ ВТ_УровниНапряженияТУ
		|ИЗ
		|	ВТ_ТочкиПоставки КАК ВТ_ТочкиПоставки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргПараметрыТочекПоставки КАК энргПараметрыТочекПоставки
		|		ПО ВТ_ТочкиПоставки.ТочкаПоставки = энргПараметрыТочекПоставки.ТочкаПоставки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_УровниНапряженияТУ.Период КАК НачалоПериода,
		|	ВТ_УровниНапряженияТУ.Регистратор КАК Регистратор,
		|	ВТ_УровниНапряженияТУ.Организация КАК Организация,
		|	ВТ_УровниНапряженияТУ.Район КАК Район,
		|	ВТ_УровниНапряженияТУ.ОбъектРасчета КАК ОбъектРасчета,
		|	ВТ_УровниНапряженияТУ.ТочкаУчета КАК ТочкаУчета,
		|	ВТ_УровниНапряженияТУ.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный,
		|	ВТ_УровниНапряженияТУ.МаксимальнаяМощность КАК МаксимальнаяМощность,
		|	МИНИМУМ(ЕСТЬNULL(ВТ_УровниНапряженияТУ1.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК МинПериод
		|ПОМЕСТИТЬ ВТ_МинПериод
		|ИЗ
		|	ВТ_УровниНапряженияТУ КАК ВТ_УровниНапряженияТУ
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_УровниНапряженияТУ КАК ВТ_УровниНапряженияТУ1
		|		ПО ВТ_УровниНапряженияТУ.Организация = ВТ_УровниНапряженияТУ1.Организация
		|			И ВТ_УровниНапряженияТУ.Район = ВТ_УровниНапряженияТУ1.Район
		|			И ВТ_УровниНапряженияТУ.ОбъектРасчета = ВТ_УровниНапряженияТУ1.ОбъектРасчета
		|			И ВТ_УровниНапряженияТУ.ТочкаУчета = ВТ_УровниНапряженияТУ1.ТочкаУчета
