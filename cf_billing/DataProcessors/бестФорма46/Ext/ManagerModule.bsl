#Область Раздел_1А

Функция СфомироватьТаблицуРаздела1А(НастройкиРазделов, РезультатЗапроса)
	
	Результат = Новый Массив;
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат Результат;
	КонецЕсли;
	
	ДополнительныйНомерКолонки = Новый Соответствие;
	ДополнительныйНомерКолонки.Вставить(Перечисления.энргУровниНапряжения.ВН, 0);
	ДополнительныйНомерКолонки.Вставить(Перечисления.энргУровниНапряжения.СН1, 1);
	ДополнительныйНомерКолонки.Вставить(Перечисления.энргУровниНапряжения.СН2, 2);
	ДополнительныйНомерКолонки.Вставить(Перечисления.энргУровниНапряжения.НН, 3);
		
	Соответствие = СоответствиеКолонкиФайлаИПоляВВыборкеРаздел1А();
	НачальнаяКолонка = 7;
		
	ОписаниеНовойСтроки = "НомерКолонки,НомерСтроки,Значение";
	Выборка = РезультатЗапроса.Выбрать();
	
	СтруктураОбъемов = Новый Структура;
	
	Пока Выборка.Следующий() Цикл
		
		СтрокаЗаполнения = СтрокаЗаполнения(НастройкиРазделов, Выборка, "НомерСтрокиФайлаРаздел1А");
		Если СтрокаЗаполнения = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ДопНомер = ДополнительныйНомерКолонки[Выборка.УровеньНапряженияРасчетный];
		
		Для Каждого ТекКлючЗначение Из Соответствие Цикл
			
			Значение = Выборка[ТекКлючЗначение.Значение];
			Если Значение = 0 Тогда
				Продолжить;
			КонецЕсли; 			
			
			НомерКолонки 	= НачальнаяКолонка + ДопНомер + ТекКлючЗначение.Ключ;
			НомерСтроки 	= СтрокаЗаполнения;
			КлючСтруктурыОбъемов = СтрШаблон("Строка%1Колонка%2", НомерСтроки, НомерКолонки);
			ИндексМассива = Неопределено;
			Если СтруктураОбъемов.Свойство(КлючСтруктурыОбъемов, ИндексМассива) Тогда
				НоваяСтрока = Результат.Получить(ИндексМассива);
				НоваяСтрока.Значение = НоваяСтрока.Значение + Значение;
			Иначе
				НоваяСтрока = Новый Структура(ОписаниеНовойСтроки, НомерКолонки, НомерСтроки, Значение);
				Результат.Добавить(НоваяСтрока);
				СтруктураОбъемов.Вставить(КлючСтруктурыОбъемов, Результат.ВГраница());
			КонецЕсли;	
		
		КонецЦикла;
				
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СоответствиеКолонкиФайлаИПоляВВыборкеРаздел1А()
	
	Результат = Новый Соответствие;	
