#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Создает ПД и возвращает количество не проведенных ПД и созданные документы.
//
// Параметры:
//  СтруктураОтборов	-	Структура.
// 
// Возвращаемое значение:
//   Структура.
//
Функция СоздатьПД(СтруктураОтборов) Экспорт
	
	ТекДоговор	 									= Неопределено;
	ТекТипЗадолженности	 							= Неопределено;
	ДокументОбъект 									= Неопределено;
	ДокументСсылка									= Неопределено;
	мСозданныеДокументы 							= Новый Массив;
	
	ПериодНачисления 								= Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(СтруктураОтборов.ДатаФакта, СтруктураОтборов.Организация,СтруктураОтборов.Район);
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(СтруктураОтборов.Организация,СтруктураОтборов.Район,ПериодНачисления,Ложь);
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП - 1;	
	ПредыдущийПериодНачисления                      = ДобавитьМесяц(ПериодНачисления, -1);
	ДатаФакта										= ?(СтруктураОтборов.Свойство("ДатаФакта"),СтруктураОтборов.ДатаФакта,ТекущаяДата());
	ЭтоКонецПериода 								= КонецДня(ДатаФакта) = КонецМесяца(КонецПериодаРасчета);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапросаФормированиеПД();
	
	Если СтруктураОтборов.Свойство("Договор") И ЗначениеЗаполнено(СтруктураОтборов.Договор) Тогда
		Запрос.УстановитьПараметр("Договор", СтруктураОтборов.Договор);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Договор = &Договор", "Истина");
	КонецЕсли;
	
	Если СтруктураОтборов.Свойство("Контрагент") И ЗначениеЗаполнено(СтруктураОтборов.Контрагент) Тогда
		Запрос.УстановитьПараметр("Контрагент", СтруктураОтборов.Контрагент);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргДоговорыКонтрагентов.Контрагент = &Контрагент", "Истина");
	КонецЕсли;
	
	Если СтруктураОтборов.Свойство("ТипЗадолженности") И ЗначениеЗаполнено(СтруктураОтборов.ТипЗадолженности) Тогда
		Запрос.УстановитьПараметр("ТипЗадолженности", СтруктураОтборов.ТипЗадолженности);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТипОплаты = &ТипЗадолженности", "Истина");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Организация", 					СтруктураОтборов.Организация);
	Запрос.УстановитьПараметр("Район", 							СтруктураОтборов.Район);
	Запрос.УстановитьПараметр("ДатаФакта", 						ДатаФакта);
	Запрос.УстановитьПараметр("ПериодНачисления", 				ПериодНачисления);
	Запрос.УстановитьПараметр("ПредыдущийПериодНачисления", 	ПредыдущийПериодНачисления);
	Запрос.УстановитьПараметр("НачалоПериодаРасчета", 			НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("ЭтоКонецПериода", 				ЭтоКонецПериода);
	Запрос.УстановитьПараметр("ЦеновыеКатегорииРазделителяМощности"	, ЦеновыеКатегорииРазделителяМощности());
	Запрос.УстановитьПараметр("СпособыНачисленийРазделителяМощности", СпособыНачисленийРазделителяМощности());
		
	Авансовый = Перечисления.бестВидыРасчета.Авансовый;
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	КоличествоНепроведенныхПД = 0;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
			
		Если ТекДоговор <> ВыборкаДетальныеЗаписи.Договор ИЛИ ТекТипЗадолженности <> ВыборкаДетальныеЗаписи.ТипЗадолженности Тогда
			
			Если Не ДокументОбъект = Неопределено Тогда
				Попытка
					ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
					мСозданныеДокументы.Добавить(ДокументОбъект.Ссылка);
					ЗафиксироватьТранзакцию();
				Исключение
					ОтменитьТранзакцию();
					ЗаписьЖурналаРегистрации(НСтр("ru = 'Не удалось провести платежный документ!'"),
											 УровеньЖурналаРегистрации.Ошибка,
											 ,
											 ,
											 ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
					КоличествоНепроведенныхПД = КоличествоНепроведенныхПД + 1;
				КонецПопытки;
			КонецЕсли; 					
			
			ДокументСсылка 							= ВыборкаДетальныеЗаписи.ПД;			
			
			Если НЕ ЗначениеЗаполнено(ДокументСсылка) Тогда			
				ДокументСсылка 						= Документы.бестПлатежныйДокумент.ПолучитьСсылку(Новый УникальныйИдентификатор());
				ДокументОбъект 						= Документы.бестПлатежныйДокумент.СоздатьДокумент();
				ДокументОбъект.Организация			= ВыборкаДетальныеЗаписи.Организация;
				ДокументОбъект.Район 				= ВыборкаДетальныеЗаписи.Район;
				ДокументОбъект.Договор	 			= ВыборкаДетальныеЗаписи.Договор;
				ДокументОбъект.ТипЗадолженности	 	= ВыборкаДетальныеЗаписи.ТипЗадолженности;
				ДокументОбъект.ВидОперации	 		= Перечисления.бестВидыОпераций.ПлатежныйДокумент_Расчетный;
				ДокументОбъект.ПериодНачисления	 	= ?(ВыборкаДетальныеЗаписи.ТипЗадолженности = Авансовый, ПериодНачисления, ПредыдущийПериодНачисления);
				ДокументОбъект.Дата 				= ?(ВыборкаДетальныеЗаписи.ТипЗадолженности = Авансовый, ПериодНачисления + (ВыборкаДетальныеЗаписи.ДеньФормирования - 1) * 86400, КонецМесяца(ПредыдущийПериодНачисления));
				
				ДокументОбъект.УстановитьСсылкуНового(ДокументСсылка);	
				
			Иначе
				ДокументОбъект 						= ДокументСсылка.ПолучитьОбъект();
				ДокументОбъект.ОсновнаяРеализация.Очистить();
				ДокументОбъект.ПометкаУдаления 		= Ложь;
				ДокументОбъект.Процент	 			= ВыборкаДетальныеЗаписи.Процент;
			КонецЕсли;
			
			Если Не ТранзакцияАктивна() Тогда
				НачатьТранзакцию();
			КонецЕсли;
			
		КонецЕсли;
		
		НовСтр 				= ДокументОбъект.ОсновнаяРеализация.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, ВыборкаДетальныеЗаписи);
		ТекДоговор 			= ВыборкаДетальныеЗаписи.Договор;
		ТекТипЗадолженности = ВыборкаДетальныеЗаписи.ТипЗадолженности;
	КонецЦикла;
	
	Если Не ДокументОбъект = Неопределено Тогда
		Попытка
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			мСозданныеДокументы.Добавить(ДокументОбъект.Ссылка);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ЗаписьЖурналаРегистрации(НСтр("ru = 'Не удалось провести платежный документ!'"),
									 УровеньЖурналаРегистрации.Ошибка,
									 ,
									 ,
									 ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			КоличествоНепроведенныхПД = КоличествоНепроведенныхПД + 1;
		КонецПопытки;
	КонецЕсли;
	
	Возврат Новый Структура("КоличествоНеПроведенныхПД, СозданныеДокументы", КоличествоНеПроведенныхПД, мСозданныеДокументы);
	
КонецФункции

// Создает СФ на аванс.
//
// Параметры:
//  СтруктураОтборов	-	Структура.
// 
// Возвращаемое значение:
//   Массив из ДокументСсылка.бестАвансыЭЭ.
//
Функция СоздатьСФНаАванс(СтруктураОтборов) Экспорт
	
	мСозданныеДокументы								= Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапросаФормированиеСФНаАванс();
	
	Если НЕ СтруктураОтборов.Свойство("ВводНачальныхОстатков") Тогда
		ПериодНачисления 								= Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(СтруктураОтборов.ДатаФакта, СтруктураОтборов.Организация,СтруктураОтборов.Район);
		
		Запрос.УстановитьПараметр("Дата", 				СтруктураОтборов.ДатаФакта);
		Запрос.УстановитьПараметр("Организация", 		СтруктураОтборов.Организация);
		Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
		Запрос.УстановитьПараметр("Район", 				СтруктураОтборов.Район);
		
		
		Если СтруктураОтборов.Свойство("Договор") И ЗначениеЗаполнено(СтруктураОтборов.Договор) Тогда
			Запрос.УстановитьПараметр("Договор", СтруктураОтборов.Договор);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестАвансыЭЭ.Договор = &Договор", "Истина");
		КонецЕсли;
		
		Если СтруктураОтборов.Свойство("Контрагент") И ЗначениеЗаполнено(СтруктураОтборов.Контрагент) Тогда
			Запрос.УстановитьПараметр("Контрагент", СтруктураОтборов.Контрагент);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргДоговорыКонтрагентов.Контрагент = &Контрагент", "Истина");
		КонецЕсли;
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестАвансыЭЭ.Регистратор = &ВводНачальныхОстатков", "Истина");
		
	Иначе
		
		Запрос.УстановитьПараметр("ВводНачальныхОстатков", СтруктураОтборов.ВводНачальныхОстатков);
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестАвансыЭЭ.Организация = &Организация", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестАвансыЭЭ.Район = &Район", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестАвансыЭЭ.Договор = &Договор", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргДоговорыКонтрагентов.Контрагент = &Контрагент", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестАвансыЭЭ.ПериодНачисления = &ПериодНачисления", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестАвансыЭЭ.Период <= &Дата", "Истина");
		
	КонецЕсли;

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	
	НачатьТранзакцию();
	Попытка
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ДокументСФ) Тогда
				ДокументОбъект 						= ВыборкаДетальныеЗаписи.ДокументСФ.ПолучитьОбъект();
				ДокументОбъект.СуммаПереплаты 		= ВыборкаДетальныеЗаписи.СуммаПереплаты;
				ДокументОбъект.СуммаПереплатыНДС 	= ВыборкаДетальныеЗаписи.СуммаПереплатыНДС;
			Иначе
				ДокументОбъект 						= Документы.бестСчетФактураНаАванс.СоздатьДокумент();
				ЗаполнитьЗначенияСвойств(ДокументОбъект, ВыборкаДетальныеЗаписи);
			КонецЕсли;
			
			
			ДокументОбъект.записать();
			мСозданныеДокументы.Добавить(ДокументОбъект.Ссылка);	
		КонецЦикла;
		
	Исключение
		
		ОтменитьТранзакцию();
		Возврат Новый Массив;
		
	КонецПопытки;
	
	ЗафиксироватьТранзакцию();
	
	Если НЕ СтруктураОтборов.Свойство("ВводНачальныхОстатков") Тогда
		СоздатьКорректировочныеСФНаАванс(мСозданныеДокументы, СтруктураОтборов);
	КонецЕсли;
	
	Возврат мСозданныеДокументы;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область СозданиеПД

Функция ПолучитьТекстЗапросаФормированиеПД()
	Возврат "ВЫБРАТЬ
	        |	бестСтавкиНДССрезПоследних.СтавкаНДС КАК СтавкаНДС,
	        |	бестСтавкиНДССрезПоследних.Организация КАК Организация
	        |ПОМЕСТИТЬ СтавкиНДС
	        |ИЗ
	        |	РегистрСведений.бестСтавкиНДС.СрезПоследних(&ДатаФакта, Организация = &Организация) КАК бестСтавкиНДССрезПоследних
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Организация КАК Организация,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Район КАК Район,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Договор КАК Договор,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.ТипОплаты КАК ТипОплаты,
	        |	МАКСИМУМ(бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.ДеньФормирования) КАК ДеньФормирования
	        |ПОМЕСТИТЬ НастройкаФормированияПДМаксимумДата
	        |ИЗ
	        |	РегистрСведений.бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорам.СрезПоследних(
	        |			&ДатаФакта,
	        |			Организация = &Организация
	        |				И Район = &Район
	        |				И Договор = &Договор
	        |				И ТипОплаты = &ТипЗадолженности) КАК бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних
	        |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	        |		ПО бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Договор = энргДоговорыКонтрагентов.Ссылка
	        |ГДЕ
	        |	энргДоговорыКонтрагентов.Контрагент = &Контрагент
	        |	И ВЫБОР
	        |			КОГДА &ЭтоКонецПериода
	        |				ТОГДА ИСТИНА
	        |			ИНАЧЕ бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.ДеньФормирования <= ДЕНЬ(&ДатаФакта)
	        |		КОНЕЦ
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Организация,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Район,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Договор,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.ТипОплаты
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Организация КАК Организация,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Район КАК Район,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Договор КАК Договор,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.ТипОплаты КАК ТипОплаты,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Процент КАК Процент,
	        |	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.ДеньФормирования КАК ДеньФормирования,
	        |	бестКоличествоПериодовДляРасчетаАванса.КоличествоПериодов КАК КоличествоПериодовБазаОбъемов,
	        |	бестКоличествоПериодовДляРасчетаАванса1.КоличествоПериодов КАК КоличествоПериодовБазаСуммы
	        |ПОМЕСТИТЬ НастройкаФормированияПД
	        |ИЗ
	        |	НастройкаФормированияПДМаксимумДата КАК НастройкаФормированияПДМаксимумДата
