Функция ЦеновыеКатегорииРазделителяМощности()
	
	Результат = Новый Массив;	
	Результат.Добавить(Перечисления.бестЦеновыеКатегории.ЧетвертаяЦК);
	Результат.Добавить(Перечисления.бестЦеновыеКатегории.ШестаяЦК);
	
	Возврат Результат;
	
КонецФункции

Функция СпособыНачисленийРазделителяМощности()
	
	Результат = Новый Массив;	
	Результат.Добавить(Перечисления.энргСпособНачислений.МощностьНаРозничномРынке);
	Результат.Добавить(Перечисления.энргСпособНачислений.МощностьНаПередачу);
	
	Возврат Результат;	
	
КонецФункции

#КонецОбласти

#Область СозданиеСФНаАванс

Процедура СоздатьКорректировочныеСФНаАванс(мСозданныеДокументы, СтруктураОтборов)
	ПериодНачисления 								= Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(СтруктураОтборов.ДатаФакта, СтруктураОтборов.Организация,СтруктураОтборов.Район);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапросаКорректировочныеСФНаАванс();
	
	
	Запрос.УстановитьПараметр("Организация", 		СтруктураОтборов.Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	Запрос.УстановитьПараметр("Район", 				СтруктураОтборов.Район);
	
	
	Если СтруктураОтборов.Свойство("Договор") И ЗначениеЗаполнено(СтруктураОтборов.Договор) Тогда
		Запрос.УстановитьПараметр("Договор", СтруктураОтборов.Договор);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестСчетФактураНаАванс.Договор = &Договор", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестКорректировкаЗадолженности.Договор = &Договор", "Истина");
	КонецЕсли;
	
	Если СтруктураОтборов.Свойство("Контрагент") И ЗначениеЗаполнено(СтруктураОтборов.Контрагент) Тогда
		Запрос.УстановитьПараметр("Контрагент", СтруктураОтборов.Контрагент);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргДоговорыКонтрагентов.Контрагент = &Контрагент", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргДоговорыКонтрагентов1.Контрагент = &Контрагент", "Истина");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
	НачатьТранзакцию();
	Попытка
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.СозданныйДокумент) Тогда
				ДокументОбъект 						= ВыборкаДетальныеЗаписи.СозданныйДокумент.ПолучитьОбъект();
				ДокументОбъект.СуммаПереплаты 		= ВыборкаДетальныеЗаписи.СуммаПереплаты;
				ДокументОбъект.СуммаПереплатыНДС 	= ВыборкаДетальныеЗаписи.СуммаПереплатыНДС;
			Иначе
				ДокументОбъект 						= Документы.бестСчетФактураНаАванс.СоздатьДокумент();
				ДокументОбъект.Дата					= СтруктураОтборов.ДатаФакта;
				ДокументОбъект.Корректировка		= Истина;
				ЗаполнитьЗначенияСвойств(ДокументОбъект, ВыборкаДетальныеЗаписи);
			КонецЕсли;
			
			
			ДокументОбъект.записать();
			мСозданныеДокументы.Добавить(ДокументОбъект.Ссылка);	
		КонецЦикла;
		
	Исключение
		
		ОтменитьТранзакцию();
		
	КонецПопытки;
	
	ЗафиксироватьТранзакцию();
КонецПроцедуры

Функция ПолучитьТекстЗапросаФормированиеСФНаАванс()
	
	Возврат "ВЫБРАТЬ
	        |	бестАвансыЭЭ.Регистратор КАК Регистратор,
	        |	бестАвансыЭЭ.Организация КАК Организация,
	        |	бестАвансыЭЭ.Район КАК Район,
	        |	бестАвансыЭЭ.Договор КАК Договор,
	        |	бестАвансыЭЭ.ПериодНачисления КАК ПериодНачисления,
	        |	бестАвансыЭЭ.ДокументОплаты КАК ДокументОплаты,
	        |	бестАвансыЭЭ.Сумма КАК Сумма,
	        |	бестАвансыЭЭ.СуммаНДС КАК СуммаНДС,
	        |	бестАвансыЭЭ.IDСтрокиОплаты КАК IDСтрокиОплаты,
	        |	бестПлатежноеПоручениеВходящееЭЭЮрЛица.Дата КАК Дата
	        |ПОМЕСТИТЬ Авансы
	        |ИЗ
	        |	РегистрНакопления.бестАвансыЭЭ КАК бестАвансыЭЭ
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	        |		ПО бестАвансыЭЭ.Договор = энргДоговорыКонтрагентов.Ссылка
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица КАК бестПлатежноеПоручениеВходящееЭЭЮрЛица
	        |		ПО бестАвансыЭЭ.ДокументОплаты = бестПлатежноеПоручениеВходящееЭЭЮрЛица.Ссылка
	        |ГДЕ
	        |	бестАвансыЭЭ.Организация = &Организация
	        |	И бестАвансыЭЭ.Район = &Район
	        |	И бестАвансыЭЭ.Договор = &Договор
	        |	И энргДоговорыКонтрагентов.Контрагент = &Контрагент
	        |	И бестАвансыЭЭ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	        |	И бестАвансыЭЭ.ПериодНачисления = &ПериодНачисления
	        |	И бестАвансыЭЭ.Период <= &Дата
	        |	И бестАвансыЭЭ.Регистратор = &ВводНачальныхОстатков
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	Авансы.Организация КАК Организация,
	        |	Авансы.Район КАК Район,
	        |	Авансы.Договор КАК Договор,
	        |	Авансы.ПериодНачисления КАК ПериодНачисления,
	        |	Авансы.ДокументОплаты КАК ДокументОплаты,
	        |	Авансы.Сумма КАК СуммаПереплаты,
	        |	Авансы.СуммаНДС КАК СуммаПереплатыНДС,
	        |	Авансы.IDСтрокиОплаты КАК IDСтрокиОплаты,
	        |	бестСчетФактураНаАванс.Ссылка КАК ДокументСФ,
	        |	энргЗоныОтвественности.КодРайона КАК КодРайона,
	        |	Авансы.Дата КАК Дата,
	        |	ВЫБОР
	        |		КОГДА Авансы.Регистратор ССЫЛКА Документ.бестВводНачальныхОстатковЮридическихЛиц
	        |			ТОГДА Авансы.Регистратор
	        |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	        |	КОНЕЦ КАК Основание
	        |ИЗ
	        |	Авансы КАК Авансы
	        |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестСчетФактураНаАванс КАК бестСчетФактураНаАванс
	        |		ПО Авансы.Организация = бестСчетФактураНаАванс.Организация
	        |			И Авансы.Район = бестСчетФактураНаАванс.Район
	        |			И Авансы.Договор = бестСчетФактураНаАванс.Договор
	        |			И Авансы.ПериодНачисления = бестСчетФактураНаАванс.ПериодНачисления
	        |			И Авансы.ДокументОплаты = бестСчетФактураНаАванс.ДокументОплаты
	        |			И Авансы.IDСтрокиОплаты = бестСчетФактураНаАванс.IDСтрокиОплаты
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргЗоныОтвественности КАК энргЗоныОтвественности
	        |		ПО Авансы.Район = энргЗоныОтвественности.Ссылка";
	
КонецФункции

Функция ПолучитьТекстЗапросаКорректировочныеСФНаАванс()
	 Возврат "ВЫБРАТЬ
	         |	бестСчетФактураНаАванс.Организация КАК Организация,
	         |	бестСчетФактураНаАванс.Район КАК Район,
	         |	бестСчетФактураНаАванс.Договор КАК Договор,
	         |	&ПериодНачисления КАК ПериодНачисления,
	         |	бестСчетФактураНаАванс.НомерСчетаФактуры КАК НомерСчетаФактуры,
	         |	бестСчетФактураНаАванс.IDСтрокиОплаты КАК IDСтрокиОплаты,
	         |	бестСчетФактураНаАванс.Ссылка КАК Основание,
	         |	СУММА(бестКорректировкаЗадолженностиПереносОплаты.Сумма) КАК СуммаПереплаты,
	         |	СУММА(бестКорректировкаЗадолженностиПереносОплаты.СуммаНДС) КАК СуммаПереплатыНДС,
	         |	бестКорректировкаЗадолженности.Ссылка КАК ДокументОплаты
	         |ПОМЕСТИТЬ ПереносГруппировка
	         |ИЗ
	         |	Документ.бестСчетФактураНаАванс КАК бестСчетФактураНаАванс
	         |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	         |		ПО бестСчетФактураНаАванс.Договор = энргДоговорыКонтрагентов.Ссылка
	         |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестКорректировкаЗадолженности.ПереносОплаты КАК бестКорректировкаЗадолженностиПереносОплаты
	         |		ПО бестСчетФактураНаАванс.IDСтрокиОплаты = бестКорректировкаЗадолженностиПереносОплаты.IDСтроки,
	         |	Документ.бестКорректировкаЗадолженности КАК бестКорректировкаЗадолженности
	         |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов1
	         |		ПО бестКорректировкаЗадолженности.Договор = энргДоговорыКонтрагентов1.Ссылка
	         |ГДЕ
	         |	бестСчетФактураНаАванс.Организация = &Организация
	         |	И бестСчетФактураНаАванс.Район = &Район
	         |	И бестСчетФактураНаАванс.Договор = &Договор
	         |	И бестКорректировкаЗадолженности.Организация = &Организация
	         |	И бестКорректировкаЗадолженности.Район = &Район
	         |	И бестКорректировкаЗадолженности.ПериодНачисления = &ПериодНачисления
	         |	И бестКорректировкаЗадолженности.Договор = &Договор
	         |	И энргДоговорыКонтрагентов.Контрагент = &Контрагент
	         |	И энргДоговорыКонтрагентов1.Контрагент = &Контрагент
	         |	И бестКорректировкаЗадолженности.Проведен
	         |	И НЕ бестКорректировкаЗадолженности.ПометкаУдаления
	         |	И НЕ бестСчетФактураНаАванс.ПометкаУдаления
	         |	И НЕ бестСчетФактураНаАванс.Корректировка
	         |	И бестКорректировкаЗадолженности.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.КорректировкаЗадолженности_ПереносПлатежа)
	         |
	         |СГРУППИРОВАТЬ ПО
	         |	бестСчетФактураНаАванс.Организация,
	         |	бестСчетФактураНаАванс.Район,
	         |	бестСчетФактураНаАванс.Договор,
	         |	бестСчетФактураНаАванс.НомерСчетаФактуры,
	         |	бестСчетФактураНаАванс.IDСтрокиОплаты,
	         |	бестСчетФактураНаАванс.Ссылка,
	         |	бестКорректировкаЗадолженности.Ссылка
	         |;
	         |
	         |////////////////////////////////////////////////////////////////////////////////
	         |ВЫБРАТЬ
	         |	бестСчетФактураНаАванс.Организация КАК Организация,
	         |	бестСчетФактураНаАванс.Район КАК Район,
	         |	бестСчетФактураНаАванс.Договор КАК Договор,
	         |	&ПериодНачисления КАК ПериодНачисления,
	         |	бестСчетФактураНаАванс.НомерСчетаФактуры КАК НомерСчетаФактуры,
	         |	бестСчетФактураНаАванс.IDСтрокиОплаты КАК IDСтрокиОплаты,
	         |	бестСчетФактураНаАванс.Ссылка КАК Основание,
	         |	бестКорректировкаЗадолженностиВозвратОплаты.СуммаВозврата КАК СуммаПереплаты,
	         |	бестКорректировкаЗадолженностиВозвратОплаты.СуммаВозвратаНДС КАК СуммаПереплатыНДС,
	         |	бестКорректировкаЗадолженности.Ссылка КАК ДокументОплаты
	         |ПОМЕСТИТЬ ДанныеДляФормирования
	         |ИЗ
	         |	Документ.бестСчетФактураНаАванс КАК бестСчетФактураНаАванс
	         |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестКорректировкаЗадолженности.ВозвратОплаты КАК бестКорректировкаЗадолженностиВозвратОплаты
	         |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестКорректировкаЗадолженности КАК бестКорректировкаЗадолженности
	         |				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов1
	         |				ПО бестКорректировкаЗадолженности.Договор = энргДоговорыКонтрагентов1.Ссылка
	         |			ПО (бестКорректировкаЗадолженности.Ссылка = бестКорректировкаЗадолженностиВозвратОплаты.Ссылка)
	         |		ПО бестСчетФактураНаАванс.IDСтрокиОплаты = бестКорректировкаЗадолженностиВозвратОплаты.IDСтроки
	         |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	         |		ПО бестСчетФактураНаАванс.Договор = энргДоговорыКонтрагентов.Ссылка
	         |ГДЕ
	         |	бестСчетФактураНаАванс.Организация = &Организация
	         |	И бестСчетФактураНаАванс.Район = &Район
	         |	И бестСчетФактураНаАванс.Договор = &Договор
	         |	И бестКорректировкаЗадолженности.Организация = &Организация
	         |	И бестКорректировкаЗадолженности.Район = &Район
	         |	И бестКорректировкаЗадолженности.ПериодНачисления = &ПериодНачисления
	         |	И бестКорректировкаЗадолженности.Договор = &Договор
	         |	И энргДоговорыКонтрагентов.Контрагент = &Контрагент
	         |	И энргДоговорыКонтрагентов1.Контрагент = &Контрагент
	         |	И бестКорректировкаЗадолженности.Проведен
	         |	И НЕ бестКорректировкаЗадолженности.ПометкаУдаления
	         |	И НЕ бестСчетФактураНаАванс.ПометкаУдаления
	         |	И НЕ бестСчетФактураНаАванс.Корректировка
	         |	И бестКорректировкаЗадолженности.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.КорректировкаЗадолженности_ВозвратПлатежа)
	         |
	         |ОБЪЕДИНИТЬ ВСЕ
	         |
	         |ВЫБРАТЬ
	         |	ПереносГруппировка.Организация,
	         |	ПереносГруппировка.Район,
	         |	ПереносГруппировка.Договор,
	         |	ПереносГруппировка.ПериодНачисления,
	         |	ПереносГруппировка.НомерСчетаФактуры,
	         |	ПереносГруппировка.IDСтрокиОплаты,
	         |	ПереносГруппировка.Основание,
	         |	ПереносГруппировка.СуммаПереплаты,
	         |	ПереносГруппировка.СуммаПереплатыНДС,
	         |	ПереносГруппировка.ДокументОплаты
	         |ИЗ
	         |	ПереносГруппировка КАК ПереносГруппировка
	         |;
	         |
	         |////////////////////////////////////////////////////////////////////////////////
	         |ВЫБРАТЬ
	         |	ДанныеДляФормирования.Организация КАК Организация,
	         |	ДанныеДляФормирования.Район КАК Район,
	         |	ДанныеДляФормирования.Договор КАК Договор,
	         |	ДанныеДляФормирования.ПериодНачисления КАК ПериодНачисления,
	         |	ДанныеДляФормирования.НомерСчетаФактуры КАК НомерСчетаФактуры,
	         |	ДанныеДляФормирования.IDСтрокиОплаты КАК IDСтрокиОплаты,
	         |	ДанныеДляФормирования.Основание КАК Основание,
	         |	ДанныеДляФормирования.СуммаПереплаты КАК СуммаПереплаты,
	         |	ДанныеДляФормирования.СуммаПереплатыНДС КАК СуммаПереплатыНДС,
	         |	ДанныеДляФормирования.ДокументОплаты КАК ДокументОплаты,
	         |	бестСчетФактураНаАванс.Ссылка КАК СозданныйДокумент
	         |ИЗ
	         |	ДанныеДляФормирования КАК ДанныеДляФормирования
	         |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестСчетФактураНаАванс КАК бестСчетФактураНаАванс
	         |		ПО ДанныеДляФормирования.Организация = бестСчетФактураНаАванс.Организация
	         |			И ДанныеДляФормирования.Район = бестСчетФактураНаАванс.Район
	         |			И ДанныеДляФормирования.Договор = бестСчетФактураНаАванс.Договор
	         |			И ДанныеДляФормирования.ПериодНачисления = бестСчетФактураНаАванс.ПериодНачисления
	         |			И ДанныеДляФормирования.НомерСчетаФактуры = бестСчетФактураНаАванс.НомерСчетаФактуры
	         |			И ДанныеДляФормирования.IDСтрокиОплаты = бестСчетФактураНаАванс.IDСтрокиОплаты
	         |			И ДанныеДляФормирования.Основание = бестСчетФактураНаАванс.Основание
	         |			И ДанныеДляФормирования.ДокументОплаты = бестСчетФактураНаАванс.ДокументОплаты
	         |			И (бестСчетФактураНаАванс.Корректировка)
	         |			И (НЕ бестСчетФактураНаАванс.ПометкаУдаления)";
КонецФункции

