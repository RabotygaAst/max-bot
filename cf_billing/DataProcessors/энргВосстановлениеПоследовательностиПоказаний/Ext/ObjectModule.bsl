		НаборМаксПоказанийСрез.Отбор.Строение.Установить(Выборка.Строение);
		НаборМаксПоказанийСрез.Отбор.Помещение.Установить(Выборка.Помещение);
		НаборМаксПоказанийСрез.Отбор.ПриборУчета.Установить(Выборка.ПриборУчета);
		ИсключенныеДокументы.Вставить(МенеджерыРегистров.энргМаксимальныеПоказанияСрез, НаборМаксПоказанийСрез);
		
		//КлючПоказанийСреза = ИсключенныеДокументы[МенеджерыРегистров.энргМаксимальныеПоказанияСрез];
		
	КонецЕсли;
	
	НаборМаксПоказанийСрез.Очистить(); // При тарфиных зонах обновляем записи, чтобы корректно записать при смене документа
