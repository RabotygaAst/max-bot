		Запрос.УстановитьПараметр("Помещение",				Помещение);
		
		Если Не Отбор.ПриборУчета  = Неопределено Тогда
			Запрос.УстановитьПараметр("ПриборУчета",		Отбор.ПриборУчета);
		КонецЕсли; 	
	КонецЕсли;
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция ДанныеМаксимальногоПотребления(НачалоПериодаРасчета)
	
	Результат = Новый Соответствие;
	
	Схема = Неопределено;
	СоотвествиеПолей = Новый Структура("Организация", "Организация");
	ПараметрыЗапроса = Новый Структура("Организация", Организация); 
	ПараметрыЗапроса.Вставить("Период", КонецМесяца(НачалоПериодаРасчета) + 1);
		
	ПараметрыВТ = Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(СоотвествиеПолей));
	ПараметрПериод = энргФормированиеТекстовЗапроса.ПараметрПериодРавно("Период");
	
	ПараметрыСхемы = Новый Структура(
		"ПараметрыВТ, Период", 
		ПараметрыВТ, ПараметрПериод);
	
	РегистрыСведений.энргМаксимальныеПоказателиПотребления.МаксимальныеПоказателиПотребления(Схема, ПараметрыСхемы);
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);	
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаДобавления = Новый Структура("ПовышающийКоэффициент,МаксимальноеПотребления", Выборка.ПовышающийКоэффициент, Выборка.МаксимальноеПотребления);
		Результат.Вставить(Выборка.Услуга, СтрокаДобавления);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область РаботаСоСреднимОбъемомАбонентов

Функция РезультатСреднийОбъемПотребления(МВТ, Отбор)
	
	Текст 	=
	"ВЫБРАТЬ
	|	энргСреднийОбъемПотребленияАбонентов.Организация КАК Организация,
	|	энргСреднийОбъемПотребленияАбонентов.ПериодНачисления КАК ПериодНачисления,
	|	энргСреднийОбъемПотребленияАбонентов.Район КАК Район,
	|	энргСреднийОбъемПотребленияАбонентов.ЧастныйСектор КАК ЧастныйСектор,
	|	энргСреднийОбъемПотребленияАбонентов.Строение КАК Строение,
	|	энргСреднийОбъемПотребленияАбонентов.Помещение КАК Помещение,
	|	энргСреднийОбъемПотребленияАбонентов.ТочкаУчета КАК ТочкаУчета,
	|	энргСреднийОбъемПотребленияАбонентов.Шкала КАК Шкала,
	|	энргСреднийОбъемПотребленияАбонентов.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргСреднийОбъемПотребленияАбонентов.Объем КАК Объем
	|ПОМЕСТИТЬ СреднийОбъем
	|ИЗ
	|	РегистрСведений.энргСреднийОбъемПотребленияАбонентов КАК энргСреднийОбъемПотребленияАбонентов
	|ГДЕ
	|	энргСреднийОбъемПотребленияАбонентов.Организация = &Организация
	|	И энргСреднийОбъемПотребленияАбонентов.ПериодНачисления = &ПериодНачисления
	|	И энргСреднийОбъемПотребленияАбонентов.Район = &Район
	|	И энргСреднийОбъемПотребленияАбонентов.ЧастныйСектор = &ЧастныйСектор
	|	И энргСреднийОбъемПотребленияАбонентов.Строение = &Строение
	|	И энргСреднийОбъемПотребленияАбонентов.Помещение = &Помещение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Граница.Организация КАК Организация,
	|	Граница.ПериодНачисления КАК ПериодНачисления,
	|	Граница.Район КАК Район,
	|	Граница.ЧастныйСектор КАК ЧастныйСектор,
	|	Граница.Строение КАК Строение,
	|	Граница.Помещение КАК Помещение,
	|	ЕСТЬNULL(СреднийОбъем.ТочкаУчета, ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)) КАК ТочкаУчета,
	|	ЕСТЬNULL(СреднийОбъем.Шкала, ЗНАЧЕНИЕ(Справочник.энргШкалыПриборовУчета.ПустаяСсылка)) КАК Шкала,
	|	ЕСТЬNULL(СреднийОбъем.ТарифнаяЗона, ЗНАЧЕНИЕ(Справочник.энргТарифныеЗоны.ПустаяСсылка)) КАК ТарифнаяЗона,
	|	ЕСТЬNULL(СреднийОбъем.Объем, 0) КАК СреднееПотребление
	|ИЗ
	|	Граница КАК Граница
	|		ЛЕВОЕ СОЕДИНЕНИЕ СреднийОбъем КАК СреднийОбъем
	|		ПО Граница.Организация = СреднийОбъем.Организация
	|			И Граница.ПериодНачисления = СреднийОбъем.ПериодНачисления
	|			И Граница.Район = СреднийОбъем.Район
	|			И Граница.ЧастныйСектор = СреднийОбъем.ЧастныйСектор
	|			И Граница.Строение = СреднийОбъем.Строение
	|			И Граница.Помещение = СреднийОбъем.Помещение
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	ПериодНачисления,
	|	Район,
	|	ЧастныйСектор,
	|	Строение,
	|	Помещение,
	|	Шкала,
	|	ТарифнаяЗона"; 
	
	Если НЕ Строения = Неопределено Тогда
		
		Текст 						= СтрЗаменить(Текст,"И энргСреднийОбъемПотребленияАбонентов.ЧастныйСектор = &ЧастныйСектор","");
		Текст 						= СтрЗаменить(Текст,"И энргСреднийОбъемПотребленияАбонентов.Помещение = &Помещение","");
		
		Текст 						= СтрЗаменить(Текст,".Строение = &Строение", ".Строение В(&Строения)");
		
	ИначеЕсли ЧастныйСектор  = Неопределено Тогда
		Текст 						= СтрЗаменить(Текст,"И энргСреднийОбъемПотребленияАбонентов.ЧастныйСектор = &ЧастныйСектор","");
		Текст 						= СтрЗаменить(Текст,"И энргСреднийОбъемПотребленияАбонентов.Строение = &Строение","");
		Текст 						= СтрЗаменить(Текст,"И энргСреднийОбъемПотребленияАбонентов.Помещение = &Помещение","");
	ИначеЕсли Не ЗначениеЗаполнено(Строение) Тогда
		Текст 						= СтрЗаменить(Текст,"И энргСреднийОбъемПотребленияАбонентов.Строение = &Строение","");
		Текст 						= СтрЗаменить(Текст,"И энргСреднийОбъемПотребленияАбонентов.Помещение = &Помещение","");
	ИначеЕсли Не ЗначениеЗаполнено(Помещение) И Не ЧастныйСектор Тогда
		Текст 						= СтрЗаменить(Текст,"И энргСреднийОбъемПотребленияАбонентов.Помещение = &Помещение","");
	КонецЕсли;
	
	Запрос = Новый Запрос(Текст);
	Запрос.МенеджерВременныхТаблиц = МВТ;
	
	Запрос.УстановитьПараметр("ПериодНачисления", ПериодНачисления);
	Запрос.УстановитьПараметр("Организация"		, Организация);	
	Запрос.УстановитьПараметр("Район"			, Район);  	
	Запрос.УстановитьПараметр("ЧастныйСектор"	, ЧастныйСектор);
	Запрос.УстановитьПараметр("Строение"		, Строение);
	
	Если НЕ Строения = Неопределено Тогда 
		Запрос.УстановитьПараметр("Строения", Строения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Помещение) Или ЗначениеЗаполнено(Строение) И ЧастныйСектор Тогда
		Запрос.УстановитьПараметр("Помещение", Помещение);
	КонецЕсли; 
	
	РезультатЗапроса = Запрос.Выполнить(); 
	Возврат РезультатЗапроса
	
КонецФункции

Функция ДанныеСреднегоОбъемаАбонента(ВыборкаСреднийОбъем, Выборка) 
	
	ТекТочкаУчета					= Неопределено;
	ТекШкала 						= Неопределено;
	СоотвествиеТочек 				= Новый Соответствие;
	СоответствиеЗоны 				= Неопределено;
	СоотвествиеШкал 				= Неопределено;
	Пока ВыборкаСреднийОбъем.ЧастныйСектор  = Выборка.ЧастныйСектор и ВыборкаСреднийОбъем.Строение = Выборка.Строение и ВыборкаСреднийОбъем.Помещение = Выборка.Помещение цикл		
		Если ЗначениеЗаполнено(ВыборкаСреднийОбъем.Шкала) и ЗначениеЗаполнено(ВыборкаСреднийОбъем.ТарифнаяЗона) Тогда
			Если ТекШкала <> ВыборкаСреднийОбъем.Шкала Тогда
				Если ТекШкала <> Неопределено тогда
					СоотвествиеШкал.Вставить(ТекШкала,СоответствиеЗоны);
				КонецЕсли;
				СоотвествиеШкал		= Новый Соответствие;
				СоответствиеЗоны	= Новый Соответствие;
			КонецЕсли;
			
			Если ТекТочкаУчета <> ВыборкаСреднийОбъем.ТочкаУчета тогда
				Если ТекТочкаУчета <> Неопределено тогда
					СоотвествиеТочек.Вставить(ТекТочкаУчета,СоотвествиеШкал);
				КонецЕсли;
				СоотвествиеШкал		= Новый Соответствие;
				СоответствиеЗоны	= Новый Соответствие;
			КонецЕсли; 	
			
			СоответствиеЗоны.Вставить(ВыборкаСреднийОбъем.ТарифнаяЗона, ВыборкаСреднийОбъем.СреднееПотребление);
		КонецЕсли;
	
		Если не ВыборкаСреднийОбъем.Следующий() тогда
			Прервать;
		КонецЕсли;
	КонецЦикла; 
	 	
	Если ТекШкала <> Неопределено тогда
		СоотвествиеШкал.Вставить(ТекШкала,СоответствиеЗоны);
	КонецЕсли;		
		
	Если ТекТочкаУчета <> Неопределено тогда
		СоотвествиеТочек.Вставить(ТекТочкаУчета,СоотвествиеШкал);
	КонецЕсли;	  
	
	Возврат СоотвествиеТочек;
	
КонецФункции
	
#КонецОбласти

#Область ПроцессВосстановления

Процедура ОбработатьДанные(Ошибки, РезультатИнициализации)
	
	Выборка = РезультатИнициализации.ВыборкаПоказания;
	ВыборкаСреднийОбъем = РезультатИнициализации.ВыборкаСреднийОбъем;
	
	ДанныеНаГраницуИМоментДокумента = Новый Соответствие;	 	
	
	СоответствиеШкал = Новый Соответствие;
	СоответствиеТЗ = Новый Соответствие;
	
	КонтекстПриСменеКлюча = НовыйКонтекстПриСменеКлюча();
	КонтекстПриСменеКлюча.ДанныеНаГраницуИМоментДокумента = ДанныеНаГраницуИМоментДокумента;	
	
	ПеременныеПриСменеКлюча = НовыеПеременныеПриСменеКлюча();
	
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ПеременныеПриСменеКлюча.ТекПрибор = Выборка.ПриборУчета ИЛИ НЕ ПеременныеПриСменеКлюча.ТекДокумент = Выборка.ДокРегистратор Тогда
					
			Если НЕ ПеременныеПриСменеКлюча.ТекПрибор = Неопределено И НЕ ПеременныеПриСменеКлюча.ТекДокумент = Неопределено Тогда 
				ОперацииПриСменеКлюча(ПеременныеПриСменеКлюча, КонтекстПриСменеКлюча, Ложь);			
			КонецЕсли;			
			
			Если НЕ ПеременныеПриСменеКлюча.ТекПрибор = Выборка.ПриборУчета Тогда  				
				
				Если КонтекстПриСменеКлюча.УспешноОбработан Тогда
					
					Если КонтекстПриСменеКлюча.НаборыПоказанияПУПоследовательностьИсключенные.Количество() > 0 Тогда
						
						НачатьТранзакцию();
						Попытка						
							ЗаписатьНаборыПоследовательности(КонтекстПриСменеКлюча);						
							ЗафиксироватьТранзакцию();
						Исключение
							
							ОтменитьТранзакцию();
							
							Инфо = ИнформацияОбОшибке(); 		
							Комментарий = "Установка состояния последовательности. Прибор:" + ПеременныеПриСменеКлюча.ТекПрибор +
							" причина: " + Символы.ПС + 
							ПодробноеПредставлениеОшибки(Инфо);
							
							Ошибки.Добавить(Комментарий);
							
						КонецПопытки;
						
					КонецЕсли;									
					
				КонецЕсли; 				
				
				КонтекстПриСменеКлюча.УспешноОбработан = Истина;
				КонтекстПриСменеКлюча.НаборыПоказанияПУПоследовательностьИсключенные.Очистить();
				СоответствиеШкал.Очистить();
				СоответствиеТЗ.Очистить();
				ДанныеНаГраницуИМоментДокумента.Очистить();
				ДанныеНаГраницуИМоментДокумента.Вставить(Выборка.ПриборУчета, СоответствиеШкал); 				
				
				Если НЕ ПеременныеПриСменеКлюча.ТекПомещение = Выборка.Помещение Тогда
					ДанныеСреднегоОбъема = ДанныеСреднегоОбъемаАбонента(ВыборкаСреднийОбъем, Выборка);
				КонецЕсли;
				
			КонецЕсли;
			
			ОбновитьКонтекстПриСменеКлюча(КонтекстПриСменеКлюча, Выборка);
			
		КонецЕсли;
		
		Если (НЕ КонтекстПриСменеКлюча.ДокОбъектПолучен = Неопределено И НЕ КонтекстПриСменеКлюча.ДокОбъектПолучен)
			ИЛИ НЕ КонтекстПриСменеКлюча.УспешноОбработан Тогда
			
			ОбновитьЗначенияПеременныхКлюча(ПеременныеПриСменеКлюча, Выборка);		
			Продолжить;
			
		КонецЕсли;  		
		
		ЗаполнитьДанныеНаГраницуИМоментДокумента(ДанныеНаГраницуИМоментДокумента, Выборка, СоответствиеТЗ);		
		
		Если Выборка.СостояниеПроведения = СтатическийКонтекст.Исключен тогда 
			
			КлючПрибора = ДанныеНаГраницуИМоментДокумента[Выборка.ПриборУчета];
			ПодготовитьРегистрыИсключенногоИзПоследовательности(КонтекстПриСменеКлюча, Выборка, КлючПрибора);
			
			ОбновитьЗначенияПеременныхКлюча(ПеременныеПриСменеКлюча, Выборка);			
			Продолжить;
			
		КонецЕсли;
		
		//Если НЕ СтатическийКонтекст.ПричиныОтклоненияИсключая.Найти(Выборка.ПричинаОтклонения) = Неопределено Тогда
		//	
		//	ОбновитьЗначенияПеременныхКлюча(ПеременныеПриСменеКлюча, Выборка);
		//	Продолжить;
		//	
		//КонецЕсли;
		
		ДанныеПрибораПоДокументу = ДанныеНаГраницуИМоментДокумента[Выборка.ПриборУчета][Выборка.Шкала][Выборка.ТарифнаяЗона];
		
		СостояниеПоказаний  = Выборка.СостояниеПоказаний;
		ПричинаОтклонения	= Выборка.ПричинаОтклонения;
		Переворот  			= Выборка.Переворот;
		
		ОбновлятьДанные 		= Истина;
		ЭтоОткрытие 			= Ложь;
		ЭтоДокументнСДатойФакта	= Ложь;
		ЭтоИзменениеПоказаний	= Ложь;
		
		Текущие = Выборка.Показание;
		
		ЭтоМаксимальные = Ложь;			
		Если Выборка.РегистрируетОбъем Тогда
			ЭтоМаксимальные = СостояниеПоказаний = СтатическийКонтекст.ПоказанияПриняты;
		Иначе
			ЭтоМаксимальные = (ДанныеПрибораПоДокументу.ПредыдущиеМакс <= Текущие или Переворот);
		КонецЕсли;
		
		// Обновляем показания в документа.
		ТипДокумента = ТипЗнч(Выборка.ДокРегистратор);
		Если Выборка.ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС") Тогда 
			ОбновлятьДанные = Ложь;
			ЭтоОткрытие 	= Истина;
			ЭтоМаксимальные = Истина;
			Если НачалоДня(Выборка.ДатаРегистратора) = НачалоДня(Выборка.ПериодРегистрации) Тогда
				ЭтоДокументнСДатойФакта	= Истина;
			КонецЕсли;
			
		ИначеЕсли Выборка.ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги") Тогда 
			ОбновлятьДанные = Ложь;
			ЭтоМаксимальные = Истина;
			ЭтоОткрытие 	= Истина;
			Если НачалоДня(Выборка.ДатаРегистратора) <> НачалоДня(Выборка.ПериодРегистрации) Тогда
				ЭтоДокументнСДатойФакта	= Истина;
			КонецЕсли;
		ИначеЕсли ТипДокумента = Тип("ДокументСсылка.энргПерерасчет") Тогда
			ОбновлятьДанные 		= Ложь;
			ЭтоМаксимальные 		= Истина;
			ЭтоИзменениеПоказаний	= Истина;
		ИначеЕсли Выборка.ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСПриборомУчета_ВводПУ") Тогда 
			ОбновлятьДанные = Ложь;
			ЭтоМаксимальные = Истина;
			ЭтоОткрытие 	= Истина;
			Если НачалоДня(Выборка.ДатаРегистратора) <> НачалоДня(Выборка.ПериодРегистрации) Тогда
				ЭтоДокументнСДатойФакта	= Истина;
			КонецЕсли;
		ИначеЕсли Выборка.ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ") Тогда 
			
			ТабЧасть  		= Выборка.ДокРегистратор["ТочкиУчета"];
			СтрокиПрибора	= ТабЧасть.НайтиСтроки(Новый Структура("ПриборУчета", Выборка.ПриборУчета));
			Если НЕ СтрокиПрибора.Количество() = 0 Тогда
				ОбновлятьДанные = Ложь;
				ЭтоМаксимальные = Истина;
				ЭтоОткрытие 	= Истина;
				Если НачалоДня(Выборка.ДатаРегистратора) <> НачалоДня(Выборка.ПериодРегистрации) Тогда
					ЭтоДокументнСДатойФакта	= Истина;
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли Выборка.ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргАктированиеНедопускаДопускаВПомещение_АктированиеДопускаВПомещение") Тогда 
			
			ОбновлятьДанные = Ложь;
			ЭтоМаксимальные = Истина;
			ЭтоОткрытие 	= Истина;
			Если НачалоДня(Выборка.ДатаРегистратора) <> НачалоДня(Выборка.ПериодРегистрации) Тогда
				ЭтоДокументнСДатойФакта	= Истина;
			КонецЕсли;			
			
		КонецЕсли;   			
		
		
		Если Выборка.РегистрируетОбъем Тогда
			ОбновлятьДанные = Ложь;
		КонецЕсли;
		
		ЭтоНовыйВидДифф = Ложь;
		Если ОбновлятьДанные Тогда 
			
			Если КонтекстПриСменеКлюча.ДокОбъектПолучен = Неопределено ИЛИ НЕ КонтекстПриСменеКлюча.ДокОбъектПолучен Тогда 
				Попытка
					
					КонтекстПриСменеКлюча.ДокОбъект = Выборка.ДокРегистратор.ПолучитьОбъект();	
					КонтекстПриСменеКлюча.ДокОбъектПолучен = Истина; 
					
				Исключение
					КонтекстПриСменеКлюча.ДокОбъектПолучен = Ложь;
				КонецПопытки;
			КонецЕсли;
			Если НЕ КонтекстПриСменеКлюча.ДокОбъектПолучен Тогда
				
				ОбновитьЗначенияПеременныхКлюча(ПеременныеПриСменеКлюча, Выборка);		
				Продолжить;
				
			КонецЕсли;
			
			
			ПараметрыОперации = СтатическийКонтекст.ПараметрыОперации;
			ЗаполнитьЗначенияСвойств(ПараметрыОперации, Выборка, СписокСвойствСтрокиТЗ);		
			
			ПараметрыОперации.ДокОбъект 						= КонтекстПриСменеКлюча.ДокОбъект;
			ПараметрыОперации.ПредыдущиеМакс 					= ДанныеПрибораПоДокументу.ПредыдущиеМакс;
			ПараметрыОперации.ПериодПредыдущихМаксПок 			= ДанныеПрибораПоДокументу.ПериодПредыдущихМаксПок;
			ПараметрыОперации.ДанныеМаксимальногоПотребления 	= ДанныеМаксимальногоПотребления;
			ПараметрыОперации.ДанныеСреднегоОбъема 				= ДанныеСреднегоОбъема;
			ПараметрыОперации.ЭтоНовыйВидДифф 					= ЭтоНовыйВидДифф;
			ПараметрыОперации.ТипДокумента 						= ТипДокумента;			
			
			ОбновитьДанныеВДокументе(ПериодНачисления, Выборка.ДокРегистратор, ПараметрыОперации, КонтекстПриСменеКлюча);
			
			СостояниеПоказаний 	= ПараметрыОперации.СостояниеПоказаний;
			Переворот 			= ПараметрыОперации.Переворот;
			ЭтоНовыйВидДифф		= ПараметрыОперации.ЭтоНовыйВидДифф;
			
		КонецЕсли;
		
		///////////
		ВСрок = Истина;
		
		Если ЭтоДокументнСДатойФакта Тогда 
			// показания от документов с датой факта всегда не в срок 
			ВСрок = Ложь;
		КонецЕсли;
		
		Если НЕ ЭтоОткрытие Или ЭтоДокументнСДатойФакта Тогда 
			// Проверять "ВСрок" только документы регистрации показаний 
			ВСрок = Выборка.ПериодРегистрации >= РезультатИнициализации.НачалоПериодаРасчета и День(Выборка.ПериодРегистрации) >= СтатическийКонтекст.ПоказанияС и День(Выборка.ПериодРегистрации) <= СтатическийКонтекст.ПоказанияПО И НЕ Выборка.НедопускПрибора;
		КонецЕсли;			
		
		Если ЭтоИзменениеПоказаний Тогда 
			ВСрок = Ложь;
		КонецЕсли;
		
		ЭтоВвод = НЕ ОбновлятьДанные ИЛИ ЭтоНовыйВидДифф;
		ДанныеПрибораПоДокументу.ЭтоВвод = ЭтоВвод;
		Если СостояниеПоказаний = СтатическийКонтекст.ПоказанияОтклонены Тогда 
			КонтекстПриСменеКлюча.ЕстьОтклонениеЗоны = Истина;
		КонецЕсли;
		
		Если СтатическийКонтекст.РасчетПриОтклоненииПоказанийПоСреднемуИлиНормативу и ВСрок и СостояниеПоказаний = СтатическийКонтекст.ПоказанияОтклонены Тогда
			ОбновитьЗначенияПеременныхКлюча(ПеременныеПриСменеКлюча, Выборка);
			Продолжить;
		КонецЕсли;
		
		Если СтатическийКонтекст.НачПокНеЯвляютсяКонечнымиПриУстПрибора И ЭтоОткрытие и ВСрок Тогда 
			// Показания ввода прибора учета не должны учитываться как конечные при непредоставлении показаний
			ВСрок = Ложь;
		КонецЕсли;
		
		
		Если Выборка.ДатаРегистратора < Выборка.ПериодРегистрации тогда
			// Может быть либо у потерянной квитанции или у контрольного съема который НЕ с 23-26.
			Если Выборка.БылПереворот = 1 тогда
				ЭтоМаксимальные = Ложь;			 
			КонецЕсли; 			 
		КонецЕсли;
		
		Если НЕ СостояниеПоказаний = СтатическийКонтекст.ПоказанияПриняты Тогда 
			ЭтоМаксимальные = Ложь;
		КонецЕсли;
		
		//ЭтоВвод = НЕ ОбновлятьДанные ИЛИ ЭтоНовыйВидДифф;
		
		Если СостояниеПоказаний = СтатическийКонтекст.ПоказанияПриняты И НЕ ЭтоОткрытие И НЕ ЭтоНовыйВидДифф Тогда
			
			Если НЕ СтатическийКонтекст.НаборРасчетСреднего = Неопределено Тогда 
				
				СтрокаНабор = СтатическийКонтекст.НаборРасчетСреднего.Добавить();
				СтрокаНабор.ПериодНачисления = СтатическийКонтекст.НаборРасчетСреднего.Отбор.ПериодНачисления.Значение;
				СтрокаНабор.Организация 	 = Организация;
				СтрокаНабор.Район			 = Район;
				ЗаполнитьЗначенияСвойств(СтрокаНабор, Выборка, "Строение,Помещение,ЧастныйСектор,Шкала,ТарифнаяЗона,ТочкаУчета,ДокРегистратор,Разделитель");
				//ЗаполнитьЗначенияСвойств(СтрокаНабор, Выборка, "ТочкаУчета,ДокРегистратор,Разделитель");
				Если Выборка.РегистрируетОбъем Тогда
					СтрокаНабор.ОбъемУслуги = Текущие;
				Иначе	
					СтрокаНабор.ОбъемУслуги = Текущие - ДанныеПрибораПоДокументу.ПредыдущиеМакс;
				КонецЕсли;
				
				Если НЕ ЭтоВвод Тогда 
					ИндексСтроки = СтатическийКонтекст.НаборРасчетСреднего.Индекс(СтрокаНабор);
					СтатическийКонтекст.СтрокиСменыПоказанийНаборРасчетСреднего.Добавить(ИндексСтроки);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЭтоИзменениеПоказаний Тогда
			ПоказанияТекущегоПериода = Ложь;
		Иначе 
			ПоказанияТекущегоПериода = Выборка.ПериодРегистрации >= РезультатИнициализации.НачалоПериодаРасчета;
		КонецЕсли;
		
		Если ЭтоМаксимальные Тогда 
			
			//ДанныеПрибораПоДокументу.ЭтоВвод 							= НЕ ОбновлятьДанные ИЛИ ЭтоНовыйВидДифф;
			ДанныеПрибораПоДокументу.ПериодПредыдущихМаксПокМомент 		= Выборка.ПериодРегистрации;
			ДанныеПрибораПоДокументу.ПредыдущиеМаксМомент 				= Текущие;				
			ДанныеПрибораПоДокументу.РегистраторМаксимальныхМомент 		= Выборка.ДокРегистратор;
			ДанныеПрибораПоДокументу.ДатаРегистратораМаксимальныхМомент = Выборка.ДатаРегистратора; 			
			
			НаборМаксПоказаний = СтатическийКонтекст.НаборМаксимальныеПоказания;
			СтрокаМаксимальных = НаборМаксПоказаний.Добавить();				
			ЗаполнитьЗначенияСвойств(СтрокаМаксимальных, Выборка, "КлючПомещения,ПриборУчета,Шкала,ТарифнаяЗона,ДокРегистратор,Разделитель,Показание,ДатаРегистратора");
			//ЗаполнитьЗначенияСвойств(СтрокаМаксимальных, Выборка, "ДокРегистратор,Разделитель,Показание,ДатаРегистратора");
			СтрокаМаксимальных.Период 		= Выборка.ПериодРегистрации;
			СтрокаМаксимальных.Организация 	= Организация;
			СтрокаМаксимальных.Район 		= Район;
			
			Если НЕ ЭтоВвод Тогда 
				ИндексСтроки = СтатическийКонтекст.НаборМаксимальныеПоказания.Индекс(СтрокаМаксимальных);
				СтатическийКонтекст.СтрокиСменыПоказанийНаборМаксимальныеПоказания.Добавить(ИндексСтроки);
			КонецЕсли;
			
		КонецЕсли; 			 			
		
		Если СостояниеПоказаний = СтатическийКонтекст.ПоказанияПриняты ИЛИ ВСрок Тогда
			
			ЭтоПерерасчет = ТипЗнч(Выборка.ДокРегистратор) = Тип("ДокументСсылка.энргПерерасчет");
			
			НаборПредоставленных = СтатическийКонтекст.НаборПредоставленных;
			СтрокаНабор = НаборПредоставленных.Добавить();
			СтрокаНабор.Организация 	 	= Организация;
			СтрокаНабор.ПериодНачисления 	= ПериодНачисления;
			СтрокаНабор.Район				= Район;
			СтрокаНабор.ПериодНачисленияКорректировки = Выборка.ПериодНачисленияКорректировки;			
			ЗаполнитьЗначенияСвойств(СтрокаНабор, Выборка, "Строение,Помещение,ЧастныйСектор,ПриборУчета,Шкала,ТарифнаяЗона,ДокРегистратор,Разделитель");
			//ЗаполнитьЗначенияСвойств(СтрокаНабор, Выборка, "ДокРегистратор,Разделитель");
			СтрокаНабор.НомерПозиции  			= ?(ЭтоПерерасчет, -1, ДанныеПрибораПоДокументу.НомерПозицииМомент);
			СтрокаНабор.ДатаРегистратора  		= Выборка.ПериодРегистрации;
			СтрокаНабор.ВСрок  					= ВСрок;
			СтрокаНабор.ПоказанияТекущегоПериода= ПоказанияТекущегоПериода;
			Если Выборка.РегистрируетОбъем Тогда
				СтрокаНабор.Показания  = ?(СостояниеПоказаний = СтатическийКонтекст.ПоказанияПриняты, Текущие, 0);
			Иначе
				СтрокаНабор.Показания  = ?(ДанныеПрибораПоДокументу.ПредыдущиеМаксМомент < 0, 0, ДанныеПрибораПоДокументу.ПредыдущиеМаксМомент);
			КонецЕсли;				
			
			Если ЭтоПерерасчет = Ложь Тогда 
				ДанныеПрибораПоДокументу.НомерПозицииМомент = ДанныеПрибораПоДокументу.НомерПозицииМомент + 1;
			КонецЕсли; 				
			
			Если НЕ ЭтоВвод Тогда
				ИндексСтроки = СтатическийКонтекст.НаборПредоставленных.Индекс(СтрокаНабор);
				СтатическийКонтекст.СтрокиСменыПоказанийНаборПредоставленных.Добавить(ИндексСтроки);
			КонецЕсли;
			
		КонецЕсли;
		
		ОбновитьЗначенияПеременныхКлюча(ПеременныеПриСменеКлюча, Выборка);		
		
	КонецЦикла;
	
	Если НЕ ПеременныеПриСменеКлюча.ТекПрибор = Неопределено Тогда 
		ОперацииПриСменеКлюча(ПеременныеПриСменеКлюча, КонтекстПриСменеКлюча, Истина);
	КонецЕсли;  	
		
КонецПроцедуры

#Область ПеременныеСменыКлюча

Процедура ОбновитьКонтекстПриСменеКлюча(КонтекстПриСменеКлюча, Выборка)
	
	Если НЕ КонтекстПриСменеКлюча.УспешноОбработан Тогда
		Возврат;
	КонецЕсли;
	
	КонтекстПриСменеКлюча.ДокументИсключен = Ложь;
	КонтекстПриСменеКлюча.ЕстьОтклонениеЗоны = Ложь;
	КонтекстПриСменеКлюча.ИтогПроверкиОбновленияДокумента.ОбновлятьДокумент = Ложь;
	КонтекстПриСменеКлюча.ИтогПроверкиОбновленияДокумента.ДанныеПодчиненногоРегистра.Очистить();
	КонтекстПриСменеКлюча.ИтогПроверкиОбновленияДокумента.ВсеСтрокиПоказанийДокумента.Очистить();
	КонтекстПриСменеКлюча.ИтогПроверкиОбновленияДокумента.ВсеОтборыПоказанийДокумента.Очистить();	
	
	//КонтекстПриСменеКлюча.НаборыПоказанияПУПоследовательностьИсключенные.Очистить();
	КонтекстПриСменеКлюча.НаборыИсключенныхДокументов.Очистить();
	КонтекстПриСменеКлюча.НаборыСвязанныхРегистров.Очистить();
	
	СтатическийКонтекст.НаборПредоставленных = Неопределено;
	СтатическийКонтекст.НаборРасчетСреднего = Неопределено;
	СтатическийКонтекст.НаборМаксимальныеПоказания = Неопределено;
	СтатическийКонтекст.НаборМаксимальныеПоказанияСрез = Неопределено;
	
	СтатическийКонтекст.СтрокиСменыПоказанийНаборПредоставленных.Очистить();
	СтатическийКонтекст.СтрокиСменыПоказанийНаборРасчетСреднего.Очистить();
	СтатическийКонтекст.СтрокиСменыПоказанийНаборМаксимальныеПоказания.Очистить();
	//СтатическийКонтекст.СтрокиСменыПоказанийНаборМаксимальныеПоказанияСрез.Очистить();
	
	ДополнитьНаборЗаписейВСоответствиеПредоставленныеПоказания(МенеджерыРегистров.энргПредоставленныеПоказания, Выборка);
	ДополнитьНаборЗаписейВСоответствиеРасчетСреднегоОбъема(МенеджерыРегистров.энргРасчетСреднегоОбъема, Выборка);
	ДополнитьНаборЗаписейВСоответствиеМаксимальныеПоказания(МенеджерыРегистров.энргМаксимальныеПоказания, Выборка);
	ДополнитьНаборЗаписейВСоответствиеМаксимальныеПоказанияСрез(МенеджерыРегистров.энргМаксимальныеПоказанияСрез, Выборка);
	
	КонтекстПриСменеКлюча.ДокОбъектПолучен = Неопределено;
	
	//Попытка
	//	
	//	КонтекстПриСменеКлюча.ДокОбъект = Выборка.ДокРегистратор.ПолучитьОбъект();	
	//	КонтекстПриСменеКлюча.ДокОбъектПолучен = Истина; 
	//	
	//Исключение
	//	КонтекстПриСменеКлюча.ДокОбъектПолучен = Ложь;
	//КонецПопытки;
	
КонецПроцедуры

Функция НовыйКонтекстПриСменеКлюча()
	
	ИтогПроверкиОбновленияДокумента = НовыйИтогПроверкиОбновленияДокумента();
	
	Результат = Новый Структура;
	Результат.Вставить("УспешноОбработан", Истина);
	Результат.Вставить("ДокОбъект", Неопределено);
	Результат.Вставить("ДокОбъектПолучен", Ложь);
	Результат.Вставить("ДокументИсключен", Ложь);	
	Результат.Вставить("ЕстьОтклонениеЗоны", Ложь);	
	Результат.Вставить("НаборыПоказанияПУПоследовательностьИсключенные", Новый Соответствие);
	Результат.Вставить("НаборыИсключенныхДокументов", Новый Соответствие);
	Результат.Вставить("ИтогПроверкиОбновленияДокумента", ИтогПроверкиОбновленияДокумента);
	Результат.Вставить("НаборыСвязанныхРегистров", Новый Соответствие);
	Результат.Вставить("ДанныеНаГраницуИМоментДокумента", Неопределено);
	
	Возврат Результат;
	
КонецФункции

Функция НовыйИтогПроверкиОбновленияДокумента()
	
	Результат = Новый Структура;
	Результат.Вставить("ОбновлятьДокумент", Ложь);
	Результат.Вставить("ДанныеПодчиненногоРегистра", Новый Массив);
	Результат.Вставить("ВсеСтрокиПоказанийДокумента", Новый Массив);
	Результат.Вставить("ВсеОтборыПоказанийДокумента", Новый Массив);
	
	Возврат Результат;
	
КонецФункции

Функция НовыеПеременныеПриСменеКлюча()
	
	Результат = Новый Структура;
	Результат.Вставить("ТекЧастныйСектор", Неопределено);
	Результат.Вставить("ТекСтроение", Неопределено);
	Результат.Вставить("ТекПомещение", Неопределено);
	Результат.Вставить("ТекПрибор", Неопределено);
	Результат.Вставить("ТекДокумент", Неопределено);
	
	Возврат Результат;
	
КонецФункции

Процедура ОбновитьЗначенияПеременныхКлюча(ПеременныеПриСменеКлюча, Выборка)
	
	ПеременныеПриСменеКлюча.ТекЧастныйСектор	= Выборка.ЧастныйСектор;
	ПеременныеПриСменеКлюча.ТекСтроение 		= Выборка.Строение;
	ПеременныеПриСменеКлюча.ТекПомещение 		= Выборка.Помещение;
	ПеременныеПриСменеКлюча.ТекДокумент 		= Выборка.ДокРегистратор;
	ПеременныеПриСменеКлюча.ТекПрибор 			= Выборка.ПриборУчета;
		
КонецПроцедуры

#КонецОбласти

#Область ПриСменеКлючаИтогов

Процедура ОперацииПриСменеКлюча(ПеременныеПриСменеКлюча, КонтекстПриСменеКлюча, ЗаписыватьПоследовательность)
	
	Если НЕ КонтекстПриСменеКлюча.УспешноОбработан Тогда 
		Возврат;
	КонецЕсли; 	
	
	НаборПоказаний = Неопределено;
	Если НЕ КонтекстПриСменеКлюча.ДокументИсключен Тогда 
		ПодготовитьДанныеКЗаписи(ПеременныеПриСменеКлюча, КонтекстПриСменеКлюча, НаборПоказаний);
	КонецЕсли; 
	
	НачатьТранзакцию();
	Попытка
		
		Если КонтекстПриСменеКлюча.ДокументИсключен Тогда 
			ОчиститьИсключенныеДокументы(КонтекстПриСменеКлюча.НаборыИсключенныхДокументов);
		Иначе 
			
			Если КонтекстПриСменеКлюча.ИтогПроверкиОбновленияДокумента.ОбновлятьДокумент Тогда
				
				КонтекстПриСменеКлюча.ДокОбъект.Записать();
				Если НЕ НаборПоказаний = Неопределено Тогда
					НаборПоказаний.Записать();
				КонецЕсли;
				
			КонецЕсли;		
			
			ЗаписатьСвязанныеРегистры();
			
			//Если ЗаписыватьПоследовательность И КонтекстПриСменеКлюча.НаборыПоказанияПУПоследовательностьИсключенные.Количество() > 0 Тогда 
			//	ЗаписатьНаборыПоследовательности(КонтекстПриСменеКлюча);
			//КонецЕсли;
			
		КонецЕсли;
		
		Если ЗаписыватьПоследовательность И КонтекстПриСменеКлюча.НаборыПоказанияПУПоследовательностьИсключенные.Количество() > 0 Тогда 
			ЗаписатьНаборыПоследовательности(КонтекстПриСменеКлюча);
		КонецЕсли;
				
		ЗафиксироватьТранзакцию();
		
		КонтекстПриСменеКлюча.УспешноОбработан = Истина;
	Исключение
		
		ОтменитьТранзакцию();
		
		КонтекстПриСменеКлюча.УспешноОбработан = Ложь;		
		Инфо = ИнформацияОбОшибке();
		Комментарий = "Запись регистров. Документ:" + ПеременныеПриСменеКлюча.ТекДокумент + 
		" Прибор: " + ПеременныеПриСменеКлюча.ТекПрибор + 
		" причина: " + Символы.ПС + 
		ПодробноеПредставлениеОшибки(Инфо);
		
		Ошибки.Добавить(Комментарий);
		
	КонецПопытки;
	               	
КонецПроцедуры

Процедура ОчиститьИсключенныеДокументы(НаборыИсключенныхДокументов)
	
	Для Каждого КлючЗначение из НаборыИсключенныхДокументов Цикл
		
		КлючЗначение.Значение.Записать();	
		
	КонецЦикла;
		
КонецПроцедуры

Процедура ПодготовитьДанныеКЗаписи(ПеременныеПриСменеКлюча, КонтекстПриСменеКлюча, НаборПоказаний)
	
	ЗапомнитьУспешныйСтатусПроведенияВПоследовательности(КонтекстПриСменеКлюча, ПеременныеПриСменеКлюча);
	ИтогПроверкиОбновленияДокумента = КонтекстПриСменеКлюча.ИтогПроверкиОбновленияДокумента;
	ЕстьОтклонениеЗоны = КонтекстПриСменеКлюча.ЕстьОтклонениеЗоны;                                        
	
	Если НЕ ЕстьОтклонениеЗоны Тогда
		
		Если ИтогПроверкиОбновленияДокумента.ОбновлятьДокумент Тогда
			
			ДанныеПодчиненногоРегистра = ИтогПроверкиОбновленияДокумента.ДанныеПодчиненногоРегистра;
			Если ДанныеПодчиненногоРегистра.Количество() > 0 Тогда
				ОбновитьДанныеПодчиненногоРегистра(ПеременныеПриСменеКлюча, ДанныеПодчиненногоРегистра, НаборПоказаний, ЕстьОтклонениеЗоны);
			КонецЕсли;
			
		КонецЕсли;
		
		ДанныеНаГраницуДокумента = КонтекстПриСменеКлюча.ДанныеНаГраницуИМоментДокумента[ПеременныеПриСменеКлюча.ТекПрибор];
		Для Каждого КлючЗначениеШкалы из ДанныеНаГраницуДокумента Цикл 
			Для Каждого КлючЗначениеТарифнойЗоны из КлючЗначениеШкалы.Значение Цикл 
				
				НоваяСтрока = СтатическийКонтекст.НаборМаксимальныеПоказанияСрез.Добавить();
				НоваяСтрока.Организация = Организация;
				НоваяСтрока.ПериодНачисления = ПериодНачисления;
				НоваяСтрока.Район = Район;
				НоваяСтрока.ЧастныйСектор = ПеременныеПриСменеКлюча.ТекЧастныйСектор;
				НоваяСтрока.Строение = ПеременныеПриСменеКлюча.ТекСтроение;
				НоваяСтрока.Помещение = ПеременныеПриСменеКлюча.ТекПомещение;
				НоваяСтрока.ПриборУчета = ПеременныеПриСменеКлюча.ТекПрибор;			
				НоваяСтрока.Шкала = КлючЗначениеШкалы.Ключ;
				НоваяСтрока.ТарифнаяЗона = КлючЗначениеТарифнойЗоны.Ключ;
				НоваяСтрока.Показания = КлючЗначениеТарифнойЗоны.Значение.ПредыдущиеМаксМомент;
				НоваяСтрока.ДокРегистратор = КлючЗначениеТарифнойЗоны.Значение.РегистраторМаксимальныхМомент;
				НоваяСтрока.ДатаРегистратора = КлючЗначениеТарифнойЗоны.Значение.ДатаРегистратораМаксимальныхМомент;
				
				ОбновитьСтрокуДанныхНаГраницуИМоментДокумента(КлючЗначениеТарифнойЗоны.Значение, Истина);
				
			КонецЦикла;		
		КонецЦикла;
		
		Возврат;
				
	КонецЕсли;
	
	ЕстьВвод = Ложь;
	ДанныеНаГраницуДокумента = КонтекстПриСменеКлюча.ДанныеНаГраницуИМоментДокумента[ПеременныеПриСменеКлюча.ТекПрибор];
	Для Каждого КлючЗначениеШкалы из ДанныеНаГраницуДокумента Цикл 
		Для Каждого КлючЗначениеТарифнойЗоны из КлючЗначениеШкалы.Значение Цикл 
			
			НоваяСтрока = СтатическийКонтекст.НаборМаксимальныеПоказанияСрез.Добавить();
			НоваяСтрока.Организация = Организация;
			НоваяСтрока.ПериодНачисления = ПериодНачисления;
			НоваяСтрока.Район = Район;
			НоваяСтрока.ЧастныйСектор = ПеременныеПриСменеКлюча.ТекЧастныйСектор;
			НоваяСтрока.Строение = ПеременныеПриСменеКлюча.ТекСтроение;
			НоваяСтрока.Помещение = ПеременныеПриСменеКлюча.ТекПомещение;
			НоваяСтрока.ПриборУчета = ПеременныеПриСменеКлюча.ТекПрибор;			
			НоваяСтрока.Шкала = КлючЗначениеШкалы.Ключ;
			НоваяСтрока.ТарифнаяЗона = КлючЗначениеТарифнойЗоны.Ключ;
			
			Если НЕ КлючЗначениеТарифнойЗоны.Значение.ЭтоВвод Тогда
				
				
				НоваяСтрока.Показания = КлючЗначениеТарифнойЗоны.Значение.ПредыдущиеМакс;
				НоваяСтрока.ДокРегистратор = КлючЗначениеТарифнойЗоны.Значение.РегистраторМаксимальных;
				НоваяСтрока.ДатаРегистратора = КлючЗначениеТарифнойЗоны.Значение.ДатаРегистратораМаксимальных;
				
				ОбновитьСтрокуДанныхНаГраницуИМоментДокумента(КлючЗначениеТарифнойЗоны.Значение, Ложь);
				Продолжить;
			КонецЕсли;			
			
			НоваяСтрока.Показания = КлючЗначениеТарифнойЗоны.Значение.ПредыдущиеМаксМомент;
			НоваяСтрока.ДокРегистратор = КлючЗначениеТарифнойЗоны.Значение.РегистраторМаксимальныхМомент;
			НоваяСтрока.ДатаРегистратора = КлючЗначениеТарифнойЗоны.Значение.ДатаРегистратораМаксимальныхМомент;
			
			ОбновитьСтрокуДанныхНаГраницуИМоментДокумента(КлючЗначениеТарифнойЗоны.Значение, Истина);
			ЕстьВвод = Истина;
			
		КонецЦикла;		
	КонецЦикла;
	
	
	ОбновлятьДокумент = Ложь;		
	Для Каждого СтрокаПоказаний Из ИтогПроверкиОбновленияДокумента.ВсеСтрокиПоказанийДокумента Цикл
		
		Если СтрокаПоказаний.СостояниеПоказаний = СтатическийКонтекст.ПоказанияОтклонены Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаПоказаний.СостояниеПоказаний = СтатическийКонтекст.ПоказанияОтклонены;
		СтрокаПоказаний.ПричинаОтклонения = СтатическийКонтекст.ОшибкаДругойЗоны;
		ОбновлятьДокумент = Истина;
		
	КонецЦикла;
	
	Если НЕ ИтогПроверкиОбновленияДокумента.ОбновлятьДокумент И ОбновлятьДокумент Тогда
		
		КонтекстПриСменеКлюча.ДокОбъект.ОбменДанными.Загрузка = Истина;
		КонтекстПриСменеКлюча.ДокОбъект.ДополнительныеСвойства.Вставить("ВосстановлениеПоследовательности", Истина);			
		КонтекстПриСменеКлюча.ДокОбъект.ДополнительныеСвойства.Вставить("ПропуститьПроверкуЗапретаИзменения", Истина);
		КонтекстПриСменеКлюча.ДокОбъект.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);	
		ИтогПроверкиОбновленияДокумента.ОбновлятьДокумент = Истина;			
		
	КонецЕсли;
	
	Если ИтогПроверкиОбновленияДокумента.ОбновлятьДокумент Тогда 
		
		ВсеОтборыПоказанийДокумента = ИтогПроверкиОбновленияДокумента.ВсеОтборыПоказанийДокумента;
		Если ВсеОтборыПоказанийДокумента.Количество() > 0 Тогда
			ОбновитьДанныеПодчиненногоРегистра(ПеременныеПриСменеКлюча, ВсеОтборыПоказанийДокумента, НаборПоказаний, ЕстьОтклонениеЗоны);
		КонецЕсли;			
		
	КонецЕсли;
	
	Если НЕ ЕстьВвод Тогда 	
		
		// Не подчиненные
		СтатическийКонтекст.НаборПредоставленных.Очистить();
		СтатическийКонтекст.НаборМаксимальныеПоказания.Очистить();		
		Если НЕ СтатическийКонтекст.НаборРасчетСреднего = Неопределено Тогда 
			СтатическийКонтекст.НаборРасчетСреднего.Очистить();
		КонецЕсли;
		// СтатическийКонтекст.НаборМаксимальныеПоказанияСрез = Неопределено; //надо всегда перезаписывать срез
		
		Возврат;
		
	КонецЕсли;
	
	ОчиститьСтрокиСменыПоказаний(СтатическийКонтекст.НаборПредоставленных, СтатическийКонтекст.СтрокиСменыПоказанийНаборПредоставленных);
	ОчиститьСтрокиСменыПоказаний(СтатическийКонтекст.НаборМаксимальныеПоказания, СтатическийКонтекст.СтрокиСменыПоказанийНаборМаксимальныеПоказания);
	ОчиститьСтрокиСменыПоказаний(СтатическийКонтекст.НаборРасчетСреднего, СтатическийКонтекст.СтрокиСменыПоказанийНаборРасчетСреднего);
	
КонецПроцедуры

Процедура ОчиститьСтрокиСменыПоказаний(НаборЗаписей, СтрокиСменыПоказаний)
	
	Если НаборЗаписей = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокиСменыПоказаний.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокиСменыПоказаний.СортироватьПоЗначению(НаправлениеСортировки.Убыв);
	Для Каждого СтрокаСменыПоказаний Из СтрокиСменыПоказаний Цикл
		
		НаборЗаписей.Удалить(СтрокаСменыПоказаний.Значение);	
		
	КонецЦикла; 	
	
КонецПроцедуры

Процедура ОбновитьДанныеПодчиненногоРегистра(ПеременныеПриСменеКлюча, ДанныеПодчиненногоРегистра, НаборПоказаний, ЕстьОтклонениеЗоны)
	
	ПриборУчета = ПеременныеПриСменеКлюча.ТекПрибор;
	ДокРегистратор = ПеременныеПриСменеКлюча.ТекДокумент;
	
	НаборПоказаний = СоздатьНаборЗаписей(РегистрыСведений.энргПоказанияПриборовУчета);
	НаборПоказаний.Отбор.Регистратор.Установить(ДокРегистратор);
	ТаблицаПоказаний = ПрочитатьНаборПоказанийПриборов(ДокРегистратор);
	
	Для Каждого СтрокаНаборПодчиненного из ДанныеПодчиненногоРегистра Цикл 
		СтрокиПоказаний = ТаблицаПоказаний.НайтиСтроки(СтрокаНаборПодчиненного.ОтборСтрок); 
		Если СтрокиПоказаний.Количество() = 0 тогда 	
			// Движений по данному пу нету.	
			//Если СтрокаПоказаний.ТекущиеПоказания > 0 тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не восстановлена последовательность в документе " + ДокРегистратор + " по прибору " + ПриборУчета);
			//КонецЕсли;				
		иначеЕсли СтрокиПоказаний.Количество() > 1 тогда
			// Исключительная ситуация когда в документе у одного прибора учета показания указаны более одного раза.
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не восстановлена последовательность в документе " + ДокРегистратор + " по прибору " + ПриборУчета);
		иначе
			
			ДанныеСтроки = СтрокаНаборПодчиненного.ДанныеЗаписи;
			
			СтрокаПоказаний  						= СтрокиПоказаний[0];
			СтрокаПоказаний.Показание 				= ДанныеСтроки.ТекущиеПоказания;
			СтрокаПоказаний.Переворот 				= ДанныеСтроки.Переворот;
			СтрокаПоказаний.СостояниеПоказаний 		= ДанныеСтроки.СостояниеПоказаний;
			СтрокаПоказаний.ПричинаОтклонения 		= ДанныеСтроки.ПричинаОтклонения;
			
			Если ЕстьОтклонениеЗоны И НЕ СтрокаПоказаний.СостояниеПоказаний = СтатическийКонтекст.ПоказанияОтклонены Тогда 
				СтрокаПоказаний.СостояниеПоказаний = СтатическийКонтекст.ПоказанияОтклонены;
				СтрокаПоказаний.ПричинаОтклонения = СтатическийКонтекст.ОшибкаДругойЗоны;
			КонецЕсли; 			
			
		КонецЕсли;			
		
	КонецЦикла;
	
	НаборПоказаний.Загрузить(ТаблицаПоказаний); 
	
КонецПроцедуры

