#Область ОписаниеПеременных

Перем ПериодНачисления Экспорт; // Период начисления услуги 
Перем Организация Экспорт; // Организация предоставляющая услуги
Перем Район Экспорт; // Район, в котором оказывается услуга
Перем ЧастныйСектор Экспорт; // Булево - Является ли строение частным сектором
Перем Строение Экспорт; // Адрес, по которому оказавается услуга
Перем Помещение Экспорт; // Помещение, в котором оказывается услуга
Перем Строения Экспорт; // Строения для изменения структуры запроса
Перем МенеджерыРегистров; 
Перем СписокСвойствСтрокиТЗ; 
Перем СтатическийКонтекст;
Перем ДанныеМаксимальногоПотребления;
Перем ОбщееОписаниеДокумента;
Перем ЗапросПоказанийПодчиненногоРегистра;
Перем ЗапросПоследовательности;
Перем Ошибки;

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ВосстановитьПоследовательность() Экспорт 
		
	Если НЕ РазрешеноВыполнятьОперацию() Тогда
		Возврат;
	КонецЕсли;
	
	РезультатИнициализации = ИнициализироватьДанныеВосстановления();		
	
	Выборка = РезультатИнициализации.ВыборкаПоказания;
	Если Выборка.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли; 
	
	ИнициализироватьОбщиеПеременные(РезультатИнициализации);
	ОбработатьДанные(Ошибки, РезультатИнициализации);
	
	Если Ошибки.Количество() > 0 Тогда
		ВызватьИсключение СтрСоединить(Ошибки, Символы.ПС);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИнициализироватьМенеджерыРегистров()

	Результат = Новый Структура;
	Результат.Вставить("энргПоказанияПУПоследовательность", РегистрыСведений.энргПоказанияПУПоследовательность);
	Результат.Вставить("энргПредоставленныеПоказания", РегистрыСведений.энргПредоставленныеПоказания);
	Результат.Вставить("энргРасчетСреднегоОбъема", РегистрыСведений.энргРасчетСреднегоОбъема);
	Результат.Вставить("энргМаксимальныеПоказания", РегистрыСведений.энргМаксимальныеПоказания);
	Результат.Вставить("энргМаксимальныеПоказанияСрез", РегистрыСведений.энргМаксимальныеПоказанияСрез);
	
	Возврат Результат;
	
КонецФункции

Процедура ИнициализироватьОбщиеПеременные(РезультатИнициализации)

	Ошибки = Новый Массив;
	МенеджерыРегистров = ИнициализироватьМенеджерыРегистров();
	ИнициализироватьЗапросПоказанийПодчиненногоРегистра();
	ИнициализироватьЗапросПоследовательности();
	СтатическийКонтекст = СтатичныеДополнительныеПараметрыПоказаний(РезультатИнициализации.ПериодыПриемаПоказаний);
	ДанныеМаксимальногоПотребления = РезультатИнициализации.ДанныеМаксимальногоПотребления;
	ОбщееОписаниеДокумента = ОбщееОписаниеСостоянияДокумента();	
	
	СписокСвойствСтрокиТЗ = "КлючПомещения,ПриборУчета,Шкала,ТарифнаяЗона,НедопускПрибора
	|,СостояниеПоказаний,ПричинаОтклонения,Переворот,НомерСтрокиТЧ,Разделитель
	|,МаксимальноВозможныеПоказания,КоэффициентПУ,ИмяТабЧасти,КС";
	
КонецПроцедуры

#Область Валидация

Функция РазрешеноВыполнятьОперацию()
	
	Если НЕ ЗначениеЗаполнено(ПериодНачисления) ИЛИ НЕ ЗначениеЗаполнено(Район) тогда
		Возврат Ложь;
	КонецЕсли;
	
	ОбъектПроверки = Документы.энргРегистрацияПоказанийАбонента.СоздатьДокумент();
	ОбъектПроверки.Организация	= Организация;
	ОбъектПроверки.Дата			= ПериодНачисления;
	ОбъектПроверки.Район		= Район;
	
	Отказ = энргДатыЗапретаИзмененияПереопределяемый.ЗапрещеноИзменятьДанные(ОбъектПроверки);
		
	Если Отказ Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Для пользователя " + Пользователи.ТекущийПользователь() + 
			" район " + Район + " период " + ПериодНачисления + 
			" закрыт для редактирования");
	КонецЕсли;
		
	
	Возврат НЕ Отказ;
	
КонецФункции

#КонецОбласти

#Область ПолучениеДанных

Функция ИнициализироватьДанныеВосстановления()
		
	ГраницыПериода = Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация, Район, ПериодНачисления); 	
	
	Отбор = Новый Структура;
	Отбор.Вставить("НачалоПериодаРасчета"	, ГраницыПериода.НачалоОП);
	Отбор.Вставить("КонецПериодаРасчета"	, ГраницыПериода.ЗавершениеОП);
	Отбор.Вставить("ПриборУчета"			, Неопределено);
	Отбор.Вставить("КолвоНедопусковПодряд"	, энргРаботаСКонстантами.ЗначениеКонстантыКоличествоНедопусковДляОтклоненияПоказаний());	
	
	МВТ = Новый МенеджерВременныхТаблиц;
	
	РезультатПоказания = РезультатЗапросаПоказанияПУ(МВТ, Отбор);
	ВыборкаПоказания = РезультатПоказания.Выбрать();
	
	ДанныеМаксимальногоПотребления = ДанныеМаксимальногоПотребления(Отбор.НачалоПериодаРасчета);
	
	РезультатСреднийОбъем	= РезультатСреднийОбъемПотребления(МВТ, Отбор);
	ВыборкаСреднийОбъем 	= РезультатСреднийОбъем.Выбрать();
	
	//МВТ.Закрыть();
	
	ПериодыПриемаПоказаний 	= РегистрыСведений.энргПериодыПриемаПоказаний.ПолучитьПоследнее(ПериодНачисления, Новый Структура("Организация", Организация));
	
	Результат = Новый Структура;
	Результат.Вставить("НачалоПериодаРасчета", Отбор.НачалоПериодаРасчета);
	Результат.Вставить("ВыборкаПоказания", ВыборкаПоказания);
	Результат.Вставить("ДанныеМаксимальногоПотребления", ДанныеМаксимальногоПотребления);
	Результат.Вставить("ВыборкаСреднийОбъем", ВыборкаСреднийОбъем);
	Результат.Вставить("ПериодыПриемаПоказаний", ПериодыПриемаПоказаний);
	
	Возврат Результат;
	
КонецФункции

Функция РезультатЗапросаПоказанияПУ(МВТ, Отбор) 
	
	Запрос  = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Текст =
	"ВЫБРАТЬ
	|	энргПоказанияПУПоследовательность.Организация КАК Организация,
