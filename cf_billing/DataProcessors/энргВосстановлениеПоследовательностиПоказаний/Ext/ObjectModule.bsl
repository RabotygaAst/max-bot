#Область ЗаполнениеДанныхНаГраницуДокумента

Процедура ЗаполнитьДанныеНаГраницуИМоментДокумента(ДанныеНаГраницуИМоментДокумента, Выборка, СоответствиеТЗ)
	
	КлючПрибора = ДанныеНаГраницуИМоментДокумента[Выборка.ПриборУчета];		
	
	ЕстьШкалаПрибора = НЕ КлючПрибора[Выборка.Шкала] = Неопределено;
	Если НЕ ЕстьШкалаПрибора Тогда
		
		СтрокаГраницы = ЗаполнитьДанныеТарифнойЗоныНаГраницуИМоментДокумента(Выборка);	
		СоответствиеТЗ.Вставить(Выборка.ТарифнаяЗона, СтрокаГраницы);	
		КлючПрибора.Вставить(Выборка.Шкала, СоответствиеТЗ); 			
		
	КонецЕсли;
	
	КлючПриборШкала = КлючПрибора[Выборка.Шкала]; 	
	ЕстьТарифнаяЗонаПрибора = НЕ КлючПриборШкала[Выборка.ТарифнаяЗона] = Неопределено;
	
	Если НЕ ЕстьТарифнаяЗонаПрибора Тогда
		
		СтрокаГраницы = ЗаполнитьДанныеТарифнойЗоныНаГраницуИМоментДокумента(Выборка);
		КлючПриборШкала.Вставить(Выборка.ТарифнаяЗона, СтрокаГраницы); 
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЗаполнитьДанныеТарифнойЗоныНаГраницуИМоментДокумента(Выборка)
	
	Результат = Новый Структура(ОбщееОписаниеДокумента);
	Результат.НомерПозиции = Выборка.НомерПозици + 1;
	Результат.ПредыдущиеМакс = Выборка.МаксПоказания;
	Результат.ПериодПредыдущихМаксПок = Выборка.ПериодМаксПоказаний;
	Результат.РегистраторМаксимальных = Выборка.РегистраторМаксПоказаний;
	Результат.ДатаРегистратораМаксимальных = Выборка.ДатаРегистратораМаксимальных;
	
	Результат.НомерПозицииМомент = Результат.НомерПозиции;
	Результат.ПредыдущиеМаксМомент = Результат.ПредыдущиеМакс;
	Результат.ПериодПредыдущихМаксПокМомент = Результат.ПериодПредыдущихМаксПок;
	Результат.РегистраторМаксимальныхМомент = Результат.РегистраторМаксимальных;
	Результат.ДатаРегистратораМаксимальныхМомент = Результат.ДатаРегистратораМаксимальных;
	
	Результат.ЭтоВвод = Ложь;
	
	Возврат Результат;
	
КонецФункции

Процедура ОбновитьСтрокуДанныхНаГраницуИМоментДокумента(СтрокаДанных, Обновить)
	
	Если Обновить Тогда
		
		СтрокаДанных.НомерПозиции = СтрокаДанных.НомерПозицииМомент;
		СтрокаДанных.ПредыдущиеМакс = СтрокаДанных.ПредыдущиеМаксМомент;
		СтрокаДанных.ПериодПредыдущихМаксПок = СтрокаДанных.ПериодПредыдущихМаксПокМомент;
		СтрокаДанных.РегистраторМаксимальных = СтрокаДанных.РегистраторМаксимальныхМомент;
		СтрокаДанных.ДатаРегистратораМаксимальных = СтрокаДанных.ДатаРегистратораМаксимальныхМомент;
		
	Иначе 
		
		СтрокаДанных.НомерПозицииМомент = СтрокаДанных.НомерПозиции;
		СтрокаДанных.ПредыдущиеМаксМомент = СтрокаДанных.ПредыдущиеМакс;
		СтрокаДанных.ПериодПредыдущихМаксПокМомент = СтрокаДанных.ПериодПредыдущихМаксПок;
		СтрокаДанных.РегистраторМаксимальныхМомент = СтрокаДанных.РегистраторМаксимальных;
		СтрокаДанных.ДатаРегистратораМаксимальныхМомент = СтрокаДанных.ДатаРегистратораМаксимальных;
		
	КонецЕсли; 	
	
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

Функция ОбщееОписаниеСостоянияДокумента()
	
	ОписаниеДанныхНаГраницуДокумента = "НомерПозиции,ПредыдущиеМакс,ПериодПредыдущихМаксПок,РегистраторМаксимальных,ДатаРегистратораМаксимальных";
	ОписаниеДанныхНаМоментДокумента = "НомерПозицииМомент,ПредыдущиеМаксМомент,ПериодПредыдущихМаксПокМомент,РегистраторМаксимальныхМомент,ДатаРегистратораМаксимальныхМомент,ЭтоВвод";
	ОписанияДанныхДокумента = Новый Массив;
	ОписанияДанныхДокумента.Добавить(ОписаниеДанныхНаГраницуДокумента);
	ОписанияДанныхДокумента.Добавить(ОписаниеДанныхНаМоментДокумента);
	Результат = СтрСоединить(ОписанияДанныхДокумента, ",");
	
	Возврат Результат;
	
КонецФункции

Функция НовыеПараметрыОперации()
	
	Результат = Новый Структура(
		"ДокОбъект,КлючПомещения,ПриборУчета,Шкала,ТарифнаяЗона,ПредыдущиеМакс,
		|ПериодПредыдущихМаксПок,СостояниеПоказаний,ПричинаОтклонения,ДанныеМаксимальногоПотребления,
		|Переворот,НомерСтрокиТЧ,Разделитель,ДанныеСреднегоОбъема,МаксимальноВозможныеПоказания,
		|КоэффициентПУ,ИмяТабЧасти,КС,НедопускПрибора,ЭтоНовыйВидДифф,ТипДокумента");
	
	Возврат Результат;
	
КонецФункции

