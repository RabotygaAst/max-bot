		Пакет 									= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
		Оператор 								= Пакет.Операторы[0];
		ДобавитьПолеПериодНачисления(Пакет, Оператор);
		
	ИначеЕсли ИмяНабора = "УвеличениеСниженияСтоимостиУслуг" Тогда
		Параметры  								= Новый Структура("ПараметрыВТ, Период", ПараметрыВТ, Новый Структура("ИмяПараметра", "ЗавершениеПериодаРасчета"));
		РегистрыСведений.энргУвеличениеСниженияСтоимостиУслуг.УвеличениеСниженияСтоимостиУслуг(Схема, Параметры, ТаблицаДляПомещения);
		Пакет 									= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
		Оператор 								= Пакет.Операторы[0];
		ДобавитьПолеПериодНачисления(Пакет, Оператор);
		
	ИначеЕсли ИмяНабора = "СостояниеВыполненияОбязанностейГарантирующегоПоставщика" Тогда		
		Параметры  								= Новый Структура("ПараметрыВТ, Период, ЕстьОтборПоКлючамПомещений", ПараметрыВТ, Новый Структура("ИмяПараметра", "ЗавершениеПериодаРасчета"), Параметры.ЕстьОтборПоКлючамПомещений);
		РегистрыСведений.энргСостояниеВыполненияОбязанностейГарантирующегоПоставщика.ТочкиСНеВыполненнымиОбязанностямиГарантирующегоПоставщика(Схема, Параметры, ТаблицаДляПомещения);
		Пакет 									= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
		Оператор 								= Пакет.Операторы[0];
		ДобавитьПолеПериодНачисления(Пакет, Оператор);
		
	ИначеЕсли ИмяНабора  = "НазначенияПриборовУчета" Тогда
		
		Параметры  								= Новый Структура("ПараметрыВТ, Период", ПараметрыВТ, Новый Структура("ИмяПараметра", "ЗавершениеПериодаРасчета"));
		РегистрыСведений.энргНазначенияПриборовУчета.НазначенияПУСрез(Схема,Параметры,ТаблицаДляПомещения);
		
	ИначеЕсли ИмяНабора  = "ЗначенияКлючейПомещений" Тогда
		
		РегистрыСведений.энргКлючиПомещений.ДанныеПомещений(Схема,Параметры,ТаблицаДляПомещения);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьПолеПериодНачисления(Пакет, Оператор)
	Оператор.ВыбираемыеПоля.Добавить("&ПериодНачисления");
	КолонкаЗапроса  			= Пакет.Колонки[Пакет.Колонки.Количество()-1];
	КолонкаЗапроса.Псевдоним 	= "ПериодНачисления";
КонецПроцедуры

