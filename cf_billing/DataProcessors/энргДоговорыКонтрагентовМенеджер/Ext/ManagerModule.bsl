#Область СлужебныйПрограммныйИнтерфейс

Функция ЗначенияСвойствОбъекта(Договор, ПолучаемыеСвойства) Экспорт 
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		Если слжОбщегоНазначенияМодуль.ВоспроизводитьРезультатМетодов() Тогда; 
			Если НЕ Метаданные.Обработки.Найти("слжДоговорыКонтрагентовМенеджер") = Неопределено Тогда
				Возврат Обработки["слжДоговорыКонтрагентовМенеджер"].ЗначенияСвойствОбъекта(Договор, ПолучаемыеСвойства);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Результат = Справочники.энргДоговорыКонтрагентов.ЗначенияСвойствОбъекта(Договор, ПолучаемыеСвойства);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "ДоговорыКонтрагентовМенеджер.ЗначенияСвойствОбъекта";
		ПараметрыМетода 			= Новый Структура("Договор, ПолучаемыеСвойства", Договор, ПолучаемыеСвойства);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, Результат, ПараметрыМетода);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НайтиДействующийДоговорПоПараметрам(Организация, Район, Контрагент, ДатаОкончанияДействия) Экспорт 
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		Если слжОбщегоНазначенияМодуль.ВоспроизводитьРезультатМетодов() Тогда; 
			Если НЕ Метаданные.Обработки.Найти("слжДоговорыКонтрагентовМенеджер") = Неопределено Тогда
				Возврат Обработки["слжДоговорыКонтрагентовМенеджер"].НайтиДействующийДоговорПоПараметрам(Организация, Район, Контрагент, ДатаОкончанияДействия);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Результат = Справочники.энргДоговорыКонтрагентов.НайтиДействующийДоговорПоПараметрам(Организация, Район, Контрагент, ДатаОкончанияДействия);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "ДоговорыКонтрагентовМенеджер.НайтиДействующийДоговорПоПараметрам";
		ПараметрыМетода 			= Новый Структура("Организация, Район, Контрагент, ДатаОкончанияДействия", Организация, Район, Контрагент, ДатаОкончанияДействия);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, Результат, ПараметрыМетода);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьДоговорАбонента(Период, Абонент) Экспорт
	
	СхемаЗапроса	= Неопределено;
	ПараметрыОтбора	= Новый Структура;
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Абонент", "Абонент"))); 
	
	Если ЗначениеЗаполнено(Период) Тогда
		ПараметрыОтбора.Вставить("Период", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("Период"));
	КонецЕсли;
	ПараметрыОтбора.Вставить("ПараметрыВТ", ПараметрыВТ);	
	
	РегистрыСведений.энргДоговорыАбонентов.ПолучитьАктуальныйДоговорАбонента(СхемаЗапроса, ПараметрыОтбора);	 
			
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Период"	, Период);
	ПараметрыЗапроса.Вставить("Абонент"	, Абонент);		
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьЗапрос(СхемаЗапроса, ПараметрыЗапроса);
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Справочники.энргДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Результат = Выборка.Договор;
	
	Возврат Результат;
	
КонецФункции

Процедура СменитьСтатусДоговораАбонента(Период, Абонент, Статус) Экспорт
	
	Договор = ПолучитьДоговорАбонента(Период, Абонент);
	СменитьСтатусДоговора(Договор, Статус);
	
КонецПроцедуры

Функция ОписаниеОбъекта() Экспорт 
	
	Результат = Новый Структура;
	ЗаполнитьСтруктуруОписанияОбъекта(Результат);	
	Возврат Результат;
	
КонецФункции

// Функция - Вернуть банковские счета контрагента
//
// Параметры:
//  Контрагент - СправочникСсылка.энргКонтрагенты - Контрагент
// 
// Возвращаемое значение:
//   Массив - массив банковских счетов контрагента 
//
Функция ВернутьБанковскиеСчетаКонтрагента(Контрагент) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	БанковскиеСчета.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|ГДЕ
	|	БанковскиеСчета.Владелец = &Контрагент И НЕ БанковскиеСчета.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	Возврат Запрос.Выполнить();
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура СменитьСтатусДоговора(Договор, Статус)
	
	ДоговорОбъект = Договор.ПолучитьОбъект();
	ДоговорОбъект.Статус = Статус;
	ДоговорОбъект.Записать();
	
КонецПроцедуры

Процедура ЗаполнитьСтруктуруОписанияОбъекта(Результат)
	
	Результат.Вставить("Ссылка", 					Справочники.энргДоговорыКонтрагентов.ПустаяСсылка());
	Результат.Вставить("Организация", 				Справочники.Организации.ПустаяСсылка());
	Результат.Вставить("Район", 					Справочники.энргЗоныОтвественности.ПустаяСсылка());
	Результат.Вставить("Контрагент", 				Справочники.энргКонтрагенты.ПустаяСсылка());
	Результат.Вставить("Номер", 					"");
	Результат.Вставить("Дата", 						Дата(1,1,1));
	Результат.Вставить("СпособЗаключенияДоговора", 	Перечисления.энргСпособыЗаключенияДоговора.ПустаяСсылка());
	Результат.Вставить("Публичный", 				Ложь);
	Результат.Вставить("НачислениеПени",			Ложь);
	Результат.Вставить("Статус",					Перечисления.бестСтатусыДоговоровКонтрагентов.ПустаяСсылка());
	
КонецПроцедуры

#КонецОбласти

