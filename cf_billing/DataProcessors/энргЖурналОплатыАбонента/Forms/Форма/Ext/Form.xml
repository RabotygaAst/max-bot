			</Type>
			<MainAttribute>true</MainAttribute>
		</Attribute>
		<Attribute name="ДокументыОплаты" id="2">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Документы оплаты</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<UseAlways>
				<Field>ДокументыОплаты.Абонент</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	КритерийОтбораэнргДокументыОплатыАбонента.Ссылка КАК Ссылка
ПОМЕСТИТЬ ДокументыОплатыАбонента
ИЗ
	КритерийОтбора.энргДокументыОплатыАбонента(&amp;Абонент) КАК КритерийОтбораэнргДокументыОплатыАбонента
ГДЕ
	КритерийОтбораэнргДокументыОплатыАбонента.Ссылка &lt;&gt; &amp;Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ТаблицаДокумента.ДокументОплаты КАК ДокументОплаты,
	ТаблицаДокумента.Разделитель КАК Разделитель
ПОМЕСТИТЬ СкорректированныеДокументы
ИЗ
	ДокументыОплатыАбонента КАК ДокументыОплатыАбонента
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет.КорректировкаОплаты КАК ТаблицаДокумента
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет КАК энргПерерасчет
			ПО ТаблицаДокумента.Ссылка = энргПерерасчет.Ссылка
				И (НЕ энргПерерасчет.ПометкаУдаления)
		ПО ДокументыОплатыАбонента.Ссылка = ТаблицаДокумента.Ссылка
			И (ТаблицаДокумента.АбонентБыло = &amp;Абонент)
			И (ТаблицаДокумента.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_КорректировкаОплаты))
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДокументыОплатыАбонента.Ссылка КАК ДокументОплаты,
	ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка) КАК Услуга,
	ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка) КАК Поставщик,
	ДАТАВРЕМЯ(1, 1, 1) КАК ПериодОплаты,
	ТаблицаДокумента.СуммаОплаты КАК СуммаОплаты,
	ТаблицаДокумента.Абонент КАК Абонент,
	СУММА(ВЫБОР
			КОГДА ТаблицаДокумента.НомерСтроки = энргПлатежноеПоручениеВходящиеОплата.НомерСтроки
				ТОГДА 0
			ИНАЧЕ 1
		КОНЕЦ) КАК Разделитель,
	ТаблицаДокумента.НомерСтроки КАК НомерСтроки
ПОМЕСТИТЬ ВсеДокументы
ИЗ
	ДокументыОплатыАбонента КАК ДокументыОплатыАбонента
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПлатежноеПоручениеВходящие.Оплата КАК ТаблицаДокумента
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПлатежноеПоручениеВходящие.Оплата КАК энргПлатежноеПоручениеВходящиеОплата
			ПО ТаблицаДокумента.Ссылка = энргПлатежноеПоручениеВходящиеОплата.Ссылка
				И (энргПлатежноеПоручениеВходящиеОплата.Абонент = &amp;Абонент)
				И ТаблицаДокумента.НомерСтроки &gt;= энргПлатежноеПоручениеВходящиеОплата.НомерСтроки
		ПО ДокументыОплатыАбонента.Ссылка = ТаблицаДокумента.Ссылка
			И (ТаблицаДокумента.Абонент = &amp;Абонент)

СГРУППИРОВАТЬ ПО
	ДокументыОплатыАбонента.Ссылка,
	ТаблицаДокумента.ПериодОплаты,
	ТаблицаДокумента.СуммаОплаты,
	ТаблицаДокумента.Абонент,
	ТаблицаДокумента.НомерСтроки

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ДокументыОплатыАбонента.Ссылка,
	ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка),
	ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка),
	ДАТАВРЕМЯ(1, 1, 1),
	ТаблицаДокумента.СуммаОплаты,
	ТаблицаДокумента.Абонент,
	0,
	0
ИЗ
	ДокументыОплатыАбонента КАК ДокументыОплатыАбонента
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПоступлениеОплатыЧерезКонтроллера.Оплата КАК ТаблицаДокумента
		ПО ДокументыОплатыАбонента.Ссылка = ТаблицаДокумента.Ссылка
			И (ТаблицаДокумента.Абонент = &amp;Абонент)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ДокументыОплатыАбонента.Ссылка,
	ТаблицаДокумента.Услуга,
	ТаблицаДокумента.Поставщик,
	ДАТАВРЕМЯ(1, 1, 1),
	ТаблицаДокумента.Оплачено,
	&amp;Абонент,
	0,
	0
ИЗ
	ДокументыОплатыАбонента КАК ДокументыОплатыАбонента
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПриходныйКассовыйОрдер.Услуги КАК ТаблицаДокумента
		ПО ДокументыОплатыАбонента.Ссылка = ТаблицаДокумента.Ссылка
			И (ТаблицаДокумента.Оплачено &gt; 0)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ДокументыОплатыАбонента.Ссылка,
	ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка),
	ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка),
	ДАТАВРЕМЯ(1, 1, 1),
	ТаблицаДокумента.СуммаОплаты,
	ТаблицаДокумента.Абонент,
	0,
	0
ИЗ
	ДокументыОплатыАбонента КАК ДокументыОплатыАбонента
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПриходныйКассовыйОрдер КАК ТаблицаДокумента
		ПО ДокументыОплатыАбонента.Ссылка = ТаблицаДокумента.Ссылка
			И (ТаблицаДокумента.СуммаОплаты &gt; 0)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ДокументыОплатыАбонента.Ссылка,
	ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка),
	ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка),
	ДАТАВРЕМЯ(1, 1, 1),
	ВЫБОР
		КОГДА ТаблицаДокумента.АбонентБыло = ТаблицаДокумента.АбонентСтало
			ТОГДА ТаблицаДокумента.СуммаСтало
		ИНАЧЕ ТаблицаДокумента.СуммаБыло - ТаблицаДокумента.СуммаСтало
