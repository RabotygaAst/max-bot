Функция РезультатЗапросаИндивидуальныеНачисления(МВТ,ДокументНачисленияПустаяСсылка) 			
	ПолучитьСтабильныеПериоды(МВТ,ДокументНачисленияПустаяСсылка);
	ПолучитьДанныеДляРасчета(МВТ,ЛОЖЬ,Ложь,"энргНачисление");
	Возврат РассчитатьИндивидуальныйОбъемПотребления(МВТ);
КонецФункции

Процедура ОбработатьРезультатЗапросаНачислений(РезультатЗапроса, Делегат)
	
	Перем ТекПериодНачисления, ТекОрганизация, ТекРайон, ТекСтроение,ТекМКД,ТекПомещениеРодитель,ТекПомещение,ТекТочкаУчета, ТекНачалоПериода,
	ТекКонецПериода, ГраницыПериодаНачисления, АктуальныеЗначенияПотерь, ТекИндексСтрокиНабора, ТекИндексСтрокиНабораПомещений;
	
	Ошибки 										= "";
	ИнформацияДляОшибки							= "";
	Выборка  									= РезультатЗапроса.выбрать();
	
	ТекЧастныйСектор							= Ложь;
	ТекИндексСтрокиНабора						= -1;
	ТекИндексСтрокиНабораПомещений				= -1;
	НачисленияПоУслугам 						= Новый Соответствие;
	НачисленияПоУслугамПомещения 				= Новый Соответствие;
	ПлощадиПомещенийПоУслугам 					= Новый Соответствие;
		
	ПараметрыРаспределенияОбъемаПомещения 		= Новый Соответствие;
	ПересчитатьСтрокиПоФормуле 					= Новый Соответствие;
	ДеревоТочекУчета 							= Новый Соответствие;
	ОстатокСоциальнойНормы 						= Новый Соответствие;
	ОбъемыПомещенийССоглашением 				= Новый Соответствие;
	ЗаписиСтороннихПоставщиков					= Новый Массив;
		
	Набор 										= Неопределено;
	НаборОбъемПомещений 						= Неопределено;
	КлючиЗаписиРезультатаЗапроса				= КлючиЗаписиРезультатаЗапроса(РезультатЗапроса);
	
	РазделенныеЛицевыеСчета 				= Новый Соответствие;

	НачисленияПоУслугамПомещенияРазделенныеЛС 			= Новый Соответствие;
	ПлощадиПомещенийПоУслугамРазделенныеЛС 				= Новый Соответствие;

	Всего = Выборка.Количество();
	Если Всего = 0 И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Делегат, "МассивПомещений") И ЗначениеЗаполнено(Делегат.МассивПомещений) Тогда
		// только индивидуальные, которые в результате дали нулевое начисление
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(энргОбъемНачислений.Регистратор) КАК Регистратор
		|ИЗ
		|	РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
		|ГДЕ
		|	энргОбъемНачислений.Помещение В(&Помещения)
		|	И энргОбъемНачислений.Строение = &Строение
		|	И энргОбъемНачислений.Организация = &Организация
		|	И энргОбъемНачислений.Район = &Район
		|	И энргОбъемНачислений.ПериодРасчета = &ПериодРасчета
		|	И энргОбъемНачислений.Регистратор ССЫЛКА Документ.энргНачисление";
		
		Запрос.УстановитьПараметр("Организация",	Делегат.Организация);
		Запрос.УстановитьПараметр("Район",			Делегат.Район);
		Запрос.УстановитьПараметр("Помещения",		Делегат.МассивПомещений);
		Запрос.УстановитьПараметр("Строение",		Делегат.Строение);
		Запрос.УстановитьПараметр("ПериодРасчета",	Делегат.ПериодНачисления);
		
		ВыборкаДокументов = Запрос.Выполнить().Выбрать();
		Если ВыборкаДокументов.Следующий() и ЗначениеЗаполнено(ВыборкаДокументов.Регистратор) Тогда 
			НаборОбъемНачислений = РегистрыНакопления.энргОбъемНачислений.СоздатьНаборЗаписейСОтборомПоРегистратору(ВыборкаДокументов.Регистратор);
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("Организация",						Делегат.Организация);
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("Район",							Делегат.Район);
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("ПериодНачисления",				Делегат.ПериодНачисления);
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("ЧастныйСектор",					Делегат.ЧастныйСектор);
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("МКД",								?(Делегат.ЧастныйСектор, Справочники.энргСтроения.ПустаяСсылка(), Делегат.Строение));
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("ДатаРегистратора",				Делегат.ПериодНачисления);
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("ДокРегистратор",					ВыборкаДокументов.Регистратор);
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("Строение",						Делегат.Строение);
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("Помещение",						Делегат.МассивПомещений);
			НаборОбъемНачислений.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых",	Истина);
			
			РегистрыНакопления.энргОбъемНачислений.ПрочитатьЗаписиПоПомещениюДоЗаписи(НаборОбъемНачислений);
			
			НаборОбъемНачислений.Записать(Ложь);
		КонецЕсли;
	КонецЕсли;
	
	ПриоритетыВидовДифференцированности = РегистрыСведений.энргПриоритетыВидовДифференцированности.ПолучитьПриоритетыВидовДифференцированности();
	СоставляющиеТарифныхЗон 			= РегистрыСведений.энргСоставляющиеТарифныхЗон.ПолучитьСоставляющиеТарифныхЗон();
	
	Итерация			= 0;
	КоличествоИтераций 	= Итерация;
	КолвоСообщений		= Цел(Всего / 10);
	Постфикс 			= " из " + Всего;
	РайонПредставление	= Делегат.Район.Наименование;
 	Пока Выборка.следующий() цикл
		// Потомки помещения
		Если НЕ ТекПериодНачисления = Выборка.ПериодНачисления
			ИЛИ НЕ ТекПомещениеРодитель = Выборка.ПомещениеРодитель Тогда
			Если Не ТекПомещениеРодитель = Неопределено Тогда
				ПереопределитьТарифныеЗоныПоПриоритетуДифференцированности(НачисленияПоУслугамПомещения, ПараметрыРаспределенияОбъемаПомещения, ПриоритетыВидовДифференцированности, СоставляющиеТарифныхЗон);
				РассчитатьДельтуРаспределения(НачисленияПоУслугамПомещения, ПараметрыРаспределенияОбъемаПомещения);
				ПересчитатьСтрокиНачисление(Набор, НаборОбъемПомещений, НачисленияПоУслугамПомещения, ПлощадиПомещенийПоУслугам, ПараметрыРаспределенияОбъемаПомещения, ОстатокСоциальнойНормы, Ошибки, ИнформацияДляОшибки, РазделенныеЛицевыеСчета, НачисленияПоУслугамПомещенияРазделенныеЛС, ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора);
			КонецЕсли;
			ПараметрыРаспределенияОбъемаПомещения 	= Новый Соответствие;
			ПлощадиПомещенийПоУслугам 				= Новый Соответствие;
			НачисленияПоУслугамПомещения 			= Новый Соответствие;			
		КонецЕсли;
		
			// Помещение
		Если НЕ ТекПериодНачисления = Выборка.ПериодНачисления
			ИЛИ НЕ ТекЧастныйСектор = Выборка.ЧастныйСектор
			ИЛИ НЕ ТекСтроение = Выборка.Строение
			ИЛИ НЕ ТекПомещение = Выборка.Помещение Тогда
			Если НЕ ТекПериодНачисления = Неопределено Тогда
				РассчитатьДеревоТочекУчета(ДеревоТочекУчета, Набор, НаборОбъемПомещений, ОстатокСоциальнойНормы, Ошибки, ИнформацияДляОшибки);									
			КонецЕсли;			
			ДеревоТочекУчета 					= Новый Соответствие;			
		КонецЕсли;		
		
		// Помещение в рамках периода
		Если НЕ ТекПериодНачисления = Выборка.ПериодНачисления
			ИЛИ НЕ ТекЧастныйСектор = Выборка.ЧастныйСектор
			ИЛИ НЕ ТекСтроение = Выборка.Строение
			ИЛИ НЕ ТекПомещение = Выборка.Помещение
			ИЛИ НЕ ТекНачалоПериода = Выборка.НачалоПериода
			ИЛИ НЕ ТекКонецПериода = Выборка.КонецПериода Тогда			
			НачисленияПоУслугам 				= Новый Соответствие;	
			
		КонецЕсли;		
		 		
		Если НЕ ТекПериодНачисления = Выборка.ПериодНачисления			
			ИЛИ НЕ ТекМКД = Выборка.МКД Тогда			
			Если НЕ ТекМКД = Неопределено Тогда				
				ПересчитатьСтрокиПоФормуле(Набор, НаборОбъемПомещений, ПересчитатьСтрокиПоФормуле);				
				ПересчитатьСоциальнуюНорму(Набор, НаборОбъемПомещений, ОстатокСоциальнойНормы, ТекИндексСтрокиНабора, ТекИндексСтрокиНабораПомещений);				
				//ЗаписатьНаборыЗаписейНачисление(ДокументОбъект, Набор, НаборВыполненные, НаборОбъемПомещений, Ошибки);
				УдалитьЗаписиСторонихПоставщиков(ЗаписиСтороннихПоставщиков, Набор, ТекИндексСтрокиНабора);				
				Делегат.ПослеПроведенияМКД(Ошибки);
			КонецЕсли;
			ЗаписиСтороннихПоставщиков			= Новый Массив;
			ДокументОбъект  					= Неопределено;			
			Делегат.ПередПроведениемМКД(Выборка.МКД,Выборка.ДокументНачисления, Выборка.ДокументНачисленияПометкаУдаления, ТекИндексСтрокиНабора, ТекИндексСтрокиНабораПомещений);
			Набор 								= Делегат.НаборОбъемНачислений;
			НаборОбъемПомещений 				= Делегат.НаборОбъемНачисленийПомещений;
			ТекИндексСтрокиНабора				= Набор.Количество() - 1;
			ТекИндексСтрокиНабораПомещений		= НаборОбъемПомещений.Количество() - 1;
			Набор.ДополнительныеСвойства.Вставить("ТекИндексСтрокиНабора",							ТекИндексСтрокиНабора + 1);
			НаборОбъемПомещений.ДополнительныеСвойства.Вставить("ТекИндексСтрокиНабораПомещений",	ТекИндексСтрокиНабораПомещений + 1);

			
			//ПрочитатьНаборыЗаписейНачисление(Выборка, ДокументОбъект, Помещение, Набор, НаборОбъемПомещений, НаборВыполненные, Перечисления.энргВидыОперацийНачисления.Индивидуальные);
			ПересчитатьТехническиеТочки			= Новый Массив;
			ПересчитатьТехническиеТочкиПомещ	= Новый Массив;
			ПересчитатьСтрокиПоФормуле 			= Новый Соответствие;
			ОстатокСоциальнойНормы 				= Новый Соответствие;
			РазделенныеЛицевыеСчета 			= Новый Соответствие;			

		КонецЕсли; 				
		
		ДанныеВыборки 								= Новый Структура(КлючиЗаписиРезультатаЗапроса);
		ЗаполнитьЗначенияСвойств(ДанныеВыборки, Выборка);
		
		Если ЗначениеЗаполнено(Выборка.ПомещениеРодитель) И Выборка.ПомещениеРодитель <> Выборка.Помещение Тогда
			ЗаполнитьНачисленияПоУслугамПомещенияРазделенныеЛС(ДанныеВыборки, НачисленияПоУслугамПомещенияРазделенныеЛС);
			ЗаполнитьРазделенныеЛицевыеСчетаПомещения(ДанныеВыборки, РазделенныеЛицевыеСчета);
		КонецЕсли;

		ЗаполнитьНачисленияПоУслугамПомещения(ДанныеВыборки, НачисленияПоУслугамПомещения);
		ЗаполнитьНаборыЗаписейНачисление(Выборка, Набор, НаборОбъемПомещений, НачисленияПоУслугам, НачисленияПоУслугамПомещения, ПлощадиПомещенийПоУслугам, ПересчитатьСтрокиПоФормуле, ПересчитатьТехническиеТочки, ПересчитатьТехническиеТочкиПомещ, ДеревоТочекУчета, ОстатокСоциальнойНормы, ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора, ТекИндексСтрокиНабораПомещений);
		ЗаполнитьПараметрыРаспределенияОбъемаПомещения(ДанныеВыборки, ПараметрыРаспределенияОбъемаПомещения, ПриоритетыВидовДифференцированности);
		ИзменитьОстатокОбъемаКРаспределениюВПомещении(ДанныеВыборки, НачисленияПоУслугамПомещения);

		ТекОрганизация 							= Выборка.Организация;
		ТекПериодНачисления 					= Выборка.ПериодНачисления;
		ТекРайон 								= Выборка.Район;
		ТекМКД 									= Выборка.МКД;
		ТекЧастныйСектор						= Выборка.ЧастныйСектор;
		ТекСтроение								= Выборка.Строение;
		ТекПомещениеРодитель 					= Выборка.ПомещениеРодитель;
		ТекПомещение							= Выборка.Помещение;
		ТекТочкаУчета							= Выборка.ТочкаУчета;
		ТекНачалоПериода						= Выборка.НачалоПериода;
		ТекКонецПериода 						= Выборка.КонецПериода;
		ТекЗавершениеОП 						= Выборка.ЗавершениеОП;
		ИнформацияДляОшибки = "Остановились на строении '" + Выборка.СтроениеПредставление + "'" + ?(ЗначениеЗаполнено(Выборка.Помещение)," и помещении '" + Выборка.ПомещениеПредставление + "'", "");		
		
		Если КоличествоИтераций = КолвоСообщений Тогда
			Процент = Цел(Итерация / Всего * 100);
			ДлительныеОперации.СообщитьПрогресс(Процент, "Расчет начислений на физ.лиц по району " + РайонПредставление + " : " + Итерация + Постфикс);			
			КоличествоИтераций = 0;
		КонецЕсли;
		
		Итерация = Итерация + 1;
		КоличествоИтераций = КоличествоИтераций + 1;
		
	КонецЦикла;	
	
	Если НЕ ТекПериодНачисления = Неопределено Тогда 
		РассчитатьДеревоТочекУчета(ДеревоТочекУчета, Набор, НаборОбъемПомещений, ОстатокСоциальнойНормы, Ошибки, ИнформацияДляОшибки);
		ПереопределитьТарифныеЗоныПоПриоритетуДифференцированности(НачисленияПоУслугамПомещения, ПараметрыРаспределенияОбъемаПомещения, ПриоритетыВидовДифференцированности, СоставляющиеТарифныхЗон);
		РассчитатьДельтуРаспределения(НачисленияПоУслугамПомещения, ПараметрыРаспределенияОбъемаПомещения);
		ПересчитатьСтрокиНачисление(Набор, НаборОбъемПомещений, НачисленияПоУслугамПомещения, ПлощадиПомещенийПоУслугам, ПараметрыРаспределенияОбъемаПомещения, ОстатокСоциальнойНормы, Ошибки, ИнформацияДляОшибки, РазделенныеЛицевыеСчета, НачисленияПоУслугамПомещенияРазделенныеЛС, ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора);
		ПересчитатьСтрокиПоФормуле(Набор, НаборОбъемПомещений, ПересчитатьСтрокиПоФормуле);
		ПересчитатьСоциальнуюНорму(Набор, НаборОбъемПомещений, ОстатокСоциальнойНормы, ТекИндексСтрокиНабора, ТекИндексСтрокиНабораПомещений);			
		УдалитьЗаписиСторонихПоставщиков(ЗаписиСтороннихПоставщиков, Набор, ТекИндексСтрокиНабора);
	КонецЕсли; 	

	Если Не ТекМКД = Неопределено Тогда
		Делегат.ПослеПроведенияМКД(Ошибки);
	КонецЕсли;
		
	Если Не ПустаяСтрока(Ошибки) Тогда
		ВызватьИсключение Ошибки;
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьЗаписиСторонихПоставщиков(Знач ЗаписиСтороннихПоставщиков, Набор, ТекИндексСтрокиНабора)
	
	Перем СтрокаНабора, Сч;
	
	Для Сч = 0 По ЗаписиСтороннихПоставщиков.ВГраница() Цикл
		СтрокаНабора 				 	= Набор.Получить(ЗаписиСтороннихПоставщиков[Сч]);
 		Набор.Удалить(СтрокаНабора);
		ТекИндексСтрокиНабора			= ТекИндексСтрокиНабора - 1;
	КонецЦикла;

КонецПроцедуры

Процедура ПересчитатьСтрокиНачисление(Набор, НаборОбъемПомещений, НачисленияПоУслугамПомещения, ПлощадиПомещенийПоУслугам, ПараметрыРаспределенияОбъемаПомещения, ОстатокСоциальнойНормы, Ошибки, ИнформацияДляОшибки, РазделенныеЛицевыеСчета, НачисленияПоУслугамПомещенияРазделенныеЛС, ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора)
	
	Попытка
		Для Каждого КлючЗначениеСоставнаяУслуга Из НачисленияПоУслугамПомещения Цикл			
			Для Каждого КлючЗначениеУслуга Из КлючЗначениеСоставнаяУслуга.Значение Цикл			
				Для Каждого КлючЗначениеНачалоПериода Из КлючЗначениеУслуга.Значение Цикл
					Для Каждого КлючЗначениеТарифнаяЗона Из КлючЗначениеНачалоПериода.Значение Цикл
						ЗначениеСтруктуры 									= КлючЗначениеТарифнаяЗона.Значение;						
						ЗначениеСтруктуры.Вставить("РаспределилиОбъемУслугиОстаток",				ЗначениеСтруктуры.ОбъемУслугиОстаток);
						ЗначениеСтруктуры.Вставить("РаспределилиОбъемУслугиПотребленныйОстаток", 	ЗначениеСтруктуры.ОбъемУслугиПотребленныйОстаток);
						ЗначениеСтруктуры.Вставить("СоставнаяУслуга",								КлючЗначениеСоставнаяУслуга.Ключ);
						ЗначениеСтруктуры.Вставить("Услуга",										КлючЗначениеУслуга.Ключ);
						ЗначениеСтруктуры.Вставить("ТарифнаяЗона",									КлючЗначениеТарифнаяЗона.Ключ);
						ЗначениеСтруктуры.Вставить("НачалоПериода",									КлючЗначениеНачалоПериода.Ключ);
						ЗначениеСтруктуры.Вставить("ПлощадиПомещенийПоУслугам",						ПлощадиПомещенийПоУслугам);
						
						ПомещенияСОстаткомРаспределения 					= Новый Массив;
						
						РаспредеделитьОбъемПомещенияПоУслугеНаПотомков(Набор, ЗначениеСтруктуры, ПараметрыРаспределенияОбъемаПомещения,  ПомещенияСОстаткомРаспределения, ПлощадиПомещенийПоУслугам, РазделенныеЛицевыеСчета, НачисленияПоУслугамПомещенияРазделенныеЛС, ЗаписиСтороннихПоставщиков, Ложь, ТекИндексСтрокиНабора);
						РаспредеделитьОбъемПомещенияПоУслугеНаПотомков(Набор, ЗначениеСтруктуры, ПараметрыРаспределенияОбъемаПомещения,  ПомещенияСОстаткомРаспределения, ПлощадиПомещенийПоУслугам, РазделенныеЛицевыеСчета, НачисленияПоУслугамПомещенияРазделенныеЛС, ЗаписиСтороннихПоставщиков, Истина, ТекИндексСтрокиНабора);
						
						РаспределитьОстатокНаПомещенияСоСпособомРаспределенияОстаток(Набор, ЗначениеСтруктуры,ПомещенияСОстаткомРаспределения,ПараметрыРаспределенияОбъемаПомещения, ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора);
					КонецЦикла;					
				КонецЦикла;
			КонецЦикла;	
		КонецЦикла;
	Исключение
		ИнформацияОбОшибке  													= ИнформацияОбОшибке();
		Ошибки 																	=
		Ошибки + Символы.ПС + ИнформацияДляОшибки + Символы.ПС + КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
	КонецПопытки;
КонецПроцедуры

Процедура ПересчитатьСтрокиПоФормуле(Набор, НаборОбъемПомещений, ПересчитатьСтрокиПоФормуле)
	
	СпособПоФормуле 												= Перечисления.энргСпособНачислений.ПоФормуламРасчета;
	СпособПоПриборам 												= Перечисления.энргСпособНачислений.ПоПриборам;
	СпособПоСреднему 												= Перечисления.энргСпособНачислений.НачислениеПоСреднему;
	СпособПоНормативу	 											= Перечисления.энргСпособНачислений.ПоНормативу;
	
	Для Каждого СтрокаПоФормуле Из ПересчитатьСтрокиПоФормуле Цикл 																			 
		Для Каждого СтрокаПериод Из СтрокаПоФормуле.Значение Цикл
			ОбъемУслуги 											= 0;
			ОбъемУслугиПотребленный 								= 0;
			ПараметрыФормулы 										= СтрокаПериод.Значение.ПараметрыФормулы;
			ПрименятьФормулуВсегда 									= СтрокаПериод.Значение.ПрименятьФормулуВсегда;
			НачисленияПоУслугам 									= Новый Соответствие;			
			ВсеНачисленияПоПрибору 									= Истина;
			ЕстьРасходПоПриборуПоВсемТочкам 						= Истина;
			
			Для Каждого ПараметрФормулы Из ПараметрыФормулы Цикл
				//Если НЕ мТочкиУчета.Найти(ПараметрФормулы.ТочкаУчета) = Неопределено Тогда
				//	Продолжить;
				//КонецЕсли;
				Если Не ПрименятьФормулуВсегда И НЕ ПараметрФормулы.СпособНачисления  = СпособПоПриборам
					И НЕ ПараметрФормулы.СпособНачисления  = СпособПоСреднему Тогда
					ЕстьРасходПоПриборуПоВсемТочкам 				= Ложь;
				КонецЕсли;
				
				Если НЕ ПараметрФормулы.СпособНачисления  = СпособПоПриборам Тогда
					// чтобы снять этот объем когда придут все показания
					ВсеНачисленияПоПрибору 							= Ложь;
					яСтрокаНабора 									= Набор.Получить(ПараметрФормулы.ИндексСтроки);
					яСтрокаНабора.СниматьНачисленныйСредний 		= Истина;
				КонецЕсли;
				
				Если НачисленияПоУслугам[ПараметрФормулы.Услуга] = Неопределено Тогда
					НачисленияПоУслугам.Вставить(ПараметрФормулы.Услуга, Новый Структура("ОбъемУслуги,ОбъемУслугиПотребленный,ВсеНачисленияПоПрибору,ЕстьРасходПоПриборуПоВсемТочкам",0,0,Ложь,Ложь));
				КонецЕсли;  				
				НачисленияПоУслугам[ПараметрФормулы.Услуга].ЕстьРасходПоПриборуПоВсемТочкам = ЕстьРасходПоПриборуПоВсемТочкам;
				НачисленияПоУслугам[ПараметрФормулы.Услуга].ВсеНачисленияПоПрибору 			= ВсеНачисленияПоПрибору;
				НачисленияПоУслугам[ПараметрФормулы.Услуга].ОбъемУслуги 					= НачисленияПоУслугам[ПараметрФормулы.Услуга].ОбъемУслуги + ПараметрФормулы.ОбъемУслуги * ПараметрФормулы.КоэффициентФормула;
				НачисленияПоУслугам[ПараметрФормулы.Услуга].ОбъемУслугиПотребленный			= НачисленияПоУслугам[ПараметрФормулы.Услуга].ОбъемУслугиПотребленный + ПараметрФормулы.ОбъемУслугиПотребленный * ПараметрФормулы.КоэффициентФормула;
				///мТочкиУчета.Добавить(ПараметрФормулы.ТочкаУчета);
			КонецЦикла;
			
			Если НЕ ВсеНачисленияПоПрибору Тогда				
				Для Каждого ПараметрФормулы Из ПараметрыФормулы Цикл					
					яСтрокаНабора 										= Набор.Получить(ПараметрФормулы.ИндексСтроки);
					яСтрокаНабора.СниматьНачисленныйСреднийПоФормулам	= Истина;
				КонецЦикла;				
			КонецЕсли; 			
			
			ИндексыСтрок 											= СтрокаПериод.Значение.ИндексыСтрок;
			
			Для Сч = 0 По ИндексыСтрок.ВГраница() Цикл
				СтрокаНабора 										= Набор.Получить(ИндексыСтрок[Сч]);
				Если НачисленияПоУслугам[СтрокаНабора.Услуга] = Неопределено И НЕ ПрименятьФормулуВсегда Тогда
					Продолжить;
				КонецЕсли;

				ОбъемУслугиБыло 									= СтрокаНабора.ОбъемУслуги;
				ОбъемУслугиПотребленныйБыло 						= СтрокаНабора.ОбъемУслугиПотребленный;
				СтрокаНабора.ОбъемУслуги							= 0;				
				СтрокаНабора.ОбъемУслугиПотребленный				= 0;
				Если НЕ ПрименятьФормулуВсегда И НЕ ЕстьРасходПоПриборуПоВсемТочкам И ЗначениеЗаполнено(СтрокаНабора.ЗависитОтУслуги) Тогда
					СтрокаНабора.СпособНачисления 					= СпособПоФормуле;
					ОбъемУслуги 									= 0;
					ОбъемУслугиПотребленный 						= 0;
				    ВсеНачисленияПоПрибору 							= НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги].ВсеНачисленияПоПрибору;					
				ИначеЕсли НЕ ПрименятьФормулуВсегда И НЕ ЕстьРасходПоПриборуПоВсемТочкам Тогда
					СтрокаНабора.СпособНачисления 					= СпособПоНормативу;
					ОбъемУслуги 									= РассчитатьОбъемУслугиСтроктНабораПоНормативу(СтрокаНабора);
					ОбъемУслугиПотребленный 						= 0;
				    ВсеНачисленияПоПрибору 							= НачисленияПоУслугам[СтрокаНабора.Услуга].ВсеНачисленияПоПрибору;					
				ИначеЕсли ЗначениеЗаполнено(СтрокаНабора.ЗависитОтУслуги) и ЗначениеЗаполнено(НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги]) Тогда
					ОбъемУслуги 									= НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги].ОбъемУслуги;
					ОбъемУслугиПотребленный 						= НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги].ОбъемУслугиПотребленный;
					ВсеНачисленияПоПрибору 							= НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги].ВсеНачисленияПоПрибору;
					СтрокаНабора.СпособНачисления 					= СпособПоФормуле;
				ИначеЕсли ЗначениеЗаполнено(НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги]) Тогда 	
					ОбъемУслуги 									= НачисленияПоУслугам[СтрокаНабора.Услуга].ОбъемУслуги;
					ОбъемУслугиПотребленный 						= НачисленияПоУслугам[СтрокаНабора.Услуга].ОбъемУслугиПотребленный;
					ВсеНачисленияПоПрибору 							= НачисленияПоУслугам[СтрокаНабора.Услуга].ВсеНачисленияПоПрибору;
					СтрокаНабора.СпособНачисления 					= СпособПоФормуле;
				ИначеЕсли ЕстьРасходПоПриборуПоВсемТочкам И НЕ НачисленияПоУслугам[СтрокаНабора.Услуга] = Неопределено Тогда					
					ОбъемУслуги 									= НачисленияПоУслугам[СтрокаНабора.Услуга].ОбъемУслуги;
					ОбъемУслугиПотребленный 						= НачисленияПоУслугам[СтрокаНабора.Услуга].ОбъемУслугиПотребленный;
					ВсеНачисленияПоПрибору 							= НачисленияПоУслугам[СтрокаНабора.Услуга].ВсеНачисленияПоПрибору;
					СтрокаНабора.СпособНачисления 					= СпособПоФормуле;	
				Иначе
					ОбъемУслуги 									= 0;
					ОбъемУслугиПотребленный 						= 0;
					ВсеНачисленияПоПрибору 							= Ложь;
					СтрокаНабора.СпособНачисления 					= СпособПоФормуле;
				КонецЕсли;
				
				Если НЕ ОбъемУслугиБыло = 0 Тогда
					СтрокаНабора.ОбъемУслуги						= ОбъемУслуги;
				КонецЕсли;
				Если Не ОбъемУслугиПотребленныйБыло = 0 Тогда
					СтрокаНабора.ОбъемУслугиПотребленный			= ОбъемУслугиПотребленный;
				КонецЕсли;				
				СтрокаНабора.СуммаПоПовышенномуКоэффициенту			= 0;
				СтрокаНабора.ПовыщающийКоэффициент					= 0;
				СтрокаНабора.СниматьНачисленныйСредний 				= НЕ ВсеНачисленияПоПрибору;
				СтрокаНабора.СниматьНачисленныйСреднийЗависимыхТочек= НЕ ВсеНачисленияПоПрибору;
				СтрокаНабора.КоэффициентФормула 					= 1;
			КонецЦикла;
			
 			ИндексыСтрок 											= СтрокаПериод.Значение.ИндексыСтрокПомещений;
			
			Для Сч = 0 По ИндексыСтрок.ВГраница() Цикл
				СтрокаНабора 										= НаборОбъемПомещений.Получить(ИндексыСтрок[Сч]);
				ОбъемУслугиБыло 									= СтрокаНабора.ОбъемУслуги;
				ОбъемУслугиПотребленныйБыло 						= СтрокаНабора.ОбъемУслугиПотребленный;
				СтрокаНабора.ОбъемУслуги							= 0;				
				СтрокаНабора.ОбъемУслугиПотребленный				= 0;
				Если НЕ ПрименятьФормулуВсегда И НЕ ЕстьРасходПоПриборуПоВсемТочкам И ЗначениеЗаполнено(СтрокаНабора.ЗависитОтУслуги) Тогда
					ОбъемУслуги 									= 0;
					ОбъемУслугиПотребленный 						= 0;
				    ВсеНачисленияПоПрибору 							= НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги].ВсеНачисленияПоПрибору;
				ИначеЕсли НЕ ПрименятьФормулуВсегда И НЕ ЕстьРасходПоПриборуПоВсемТочкам Тогда
					ОбъемУслуги 									= 0;
					ОбъемУслугиПотребленный 						= 0;
				    ВсеНачисленияПоПрибору 							= НачисленияПоУслугам[СтрокаНабора.Услуга].ВсеНачисленияПоПрибору;
				ИначеЕсли ЗначениеЗаполнено(СтрокаНабора.ЗависитОтУслуги) и ЗначениеЗаполнено(НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги]) Тогда
					ОбъемУслуги 									= НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги].ОбъемУслуги;
					ОбъемУслугиПотребленный 						= НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги].ОбъемУслугиПотребленный;
					ВсеНачисленияПоПрибору 							= НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги].ВсеНачисленияПоПрибору;
				ИначеЕсли ЗначениеЗаполнено(НачисленияПоУслугам[СтрокаНабора.ЗависитОтУслуги]) Тогда					
					ОбъемУслуги 									= НачисленияПоУслугам[СтрокаНабора.Услуга].ОбъемУслуги;
					ОбъемУслугиПотребленный 						= НачисленияПоУслугам[СтрокаНабора.Услуга].ОбъемУслугиПотребленный;
					ВсеНачисленияПоПрибору 							= НачисленияПоУслугам[СтрокаНабора.Услуга].ВсеНачисленияПоПрибору;
				Иначе
					ОбъемУслуги 									= 0;
					ОбъемУслугиПотребленный 						= 0;
					ВсеНачисленияПоПрибору 							= Ложь;
				КонецЕсли;
				СтрокаНабора.СпособНачисления 						= СпособПоФормуле;
				Если НЕ ОбъемУслугиБыло = 0 Тогда
					СтрокаНабора.ОбъемУслуги						= ОбъемУслуги;
				КонецЕсли;
				Если Не ОбъемУслугиПотребленныйБыло = 0 Тогда
					СтрокаНабора.ОбъемУслугиПотребленный			= ОбъемУслугиПотребленный;
				КонецЕсли;
				СтрокаНабора.СуммаПоПовышенномуКоэффициенту			= 0;
				СтрокаНабора.ПовыщающийКоэффициент					= 0;			
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьНаборыЗаписейНачисление(Выборка, Набор, НаборОбъемПомещений, НачисленияПоУслугам, НачисленияПоУслугамПомещения, ПлощадиПомещенийПоУслугам, ПересчитатьСтрокиПоФормуле, ПересчитатьТехническиеТочки, ПересчитатьТехническиеТочкиПомещения,ДеревоТочекУчета, ОстатокСоциальнойНормы, ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора, ТекИндексСтрокиНабораПомещений)
	
	ВидНачисления 											= Перечисления.энргВидыНачислений.Начисление;	
	ЕстьСумма 												= Истина;
	ЕстьНачисления 											= Истина;
	КлючФормулы 											= "ИндексыСтрок,ИндексыСтрокПомещений,ПараметрыФормулы, ПрименятьФормулуВсегда";
	КлючиПараметровФормулы 									= "ТочкаУчета,Услуга,КоэффициентФормула,ИндексСтроки,СпособНачисления,ОбъемУслуги,ОбъемУслугиПотребленный";
	ЕстьАбонент 											= Ложь;
	
	Если ЗначениеЗаполнено(Выборка.Абонент) И Выборка.ПомещениеРодитель = Выборка.Помещение Тогда		 
		СтрокНабора 										= Набор.добавить();
		ЗаполнитьЗначенияСвойств(СтрокНабора,Выборка);
		СтрокНабора.Период									= Выборка.ЗавершениеОП-1;
		СтрокНабора.ВидНачисления 							= ВидНачисления;
		СтрокНабора.ПериодРасчета 							= Выборка.ПериодНачисления;
		СтрокНабора.ОбъемУслуги 							= Выборка.ОбъемУслуги;
		ЕстьАбонент 										= Истина;
		ТекИндексСтрокиНабора								= ТекИндексСтрокиНабора + 1;
		ИндексСтрокиНабора									= ТекИндексСтрокиНабора;
	ИначеЕсли  ЗначениеЗаполнено(Выборка.Абонент) Тогда
		СтрокНабора 										= Набор.добавить();
		ЗаполнитьЗначенияСвойств(СтрокНабора,Выборка);
		СтрокНабора.Период									= Выборка.ЗавершениеОП-1;
		СтрокНабора.ВидНачисления 							= ВидНачисления;
		СтрокНабора.ПериодРасчета 							= Выборка.ПериодНачисления;
		ЕстьАбонент 										= Истина;	
		ТекИндексСтрокиНабора								= ТекИндексСтрокиНабора + 1;
		ИндексСтрокиНабора									= ТекИндексСтрокиНабора;
	Иначе
		СтрокНабора 										= НаборОбъемПомещений.добавить();
		ЗаполнитьЗначенияСвойств(СтрокНабора,Выборка);
		СтрокНабора.Период									= Выборка.ЗавершениеОП-1;
		СтрокНабора.ВидНачисления 							= ВидНачисления;
		СтрокНабора.ПериодРасчета 							= Выборка.ПериодНачисления;
		ЕстьСумма 											= Ложь;	
		ТекИндексСтрокиНабораПомещений						= ТекИндексСтрокиНабораПомещений + 1;
		ИндексСтрокиНабора									= ТекИндексСтрокиНабораПомещений;
	КонецЕсли;	
	
	ИзменитьОстатокСоциальнойНормы(Выборка, ОстатокСоциальнойНормы, Набор, НаборОбъемПомещений, СтрокНабора, ИндексСтрокиНабора, ЕстьАбонент, НачисленияПоУслугам);
	
	// Начисления поставщиков из РС "Поставщики не начислять"
	Если ЕстьАбонент И Выборка.УдалитьЗапись Тогда
		ЗаписиСтороннихПоставщиков.Вставить(0, ИндексСтрокиНабора);
		СтрокНабора.ПоставщикиНеНачислять = Выборка.УдалитьЗапись;
	КонецЕсли;
	
	Если Выборка.ЭтоПростаяТочкаУчета Тогда		
		// закрытая схема
		Если Выборка.ЗакрытаяСхемаГВС Тогда
			СтрокНабора.ОбъемУслуги 							= 0;
			СтрокНабора.Сумма 									= 0;
		КонецЕсли;
		
		Возврат;
	КонецЕсли;

			
	Если Выборка.ПомещениеРодитель = Выборка.Помещение И ЗначениеЗаполнено(Выборка.ЗависитОтУслуги) И НЕ Выборка.РасчетПоФормуле И НЕ ЗначениеЗаполнено(Выборка.ЗависимаяТочкаУчета) Тогда
		ОбъемУслуги 										= 0;
		ОбъемУслугиПотребленный								= 0;
		СниматьНачисленныйСредний							= Выборка.СниматьНачисленныйСредний;
		
		Если НЕ НачисленияПоУслугам.Получить(Выборка.ТочкаУчета) = Неопределено 
			И НЕ НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги] = Неопределено
			И НЕ НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала] = Неопределено
			И НЕ НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала][Выборка.ТарифнаяЗона] = Неопределено
			И НЕ НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления] = Неопределено Тогда 
			Если НЕ СтрокНабора.ОбъемУслуги = 0 Тогда
				ОбъемУслуги 								= НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления].ОбъемУслуги;
			КонецЕсли;
			
			Если НЕ СтрокНабора.ОбъемУслугиПотребленный = 0 Тогда
				ОбъемУслугиПотребленный 					= НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления].ОбъемУслугиПотребленный;
			КонецЕсли;
			
			Если Не Выборка.НеПрименятьЗависимостьЕслиБольшеОднойТочки Тогда
				СниматьНачисленныйСредний						= НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления].СниматьНачисленныйСредний;
			КонецЕсли;
		КонецЕсли;	
		    
		ОбъемУслуги 										= ОбъемУслуги * ?(Выборка.УмножатьНаНормуРодительскойУслуги,Выборка.НормаПотребления,1);
		ОбъемУслугиПотребленный 							= ОбъемУслугиПотребленный * ?(Выборка.УмножатьНаНормуРодительскойУслуги,Выборка.НормаПотребления,1);
				
		СтрокНабора.ОбъемУслуги 							= ОбъемУслуги;
		СтрокНабора.ОбъемУслугиПотребленный 				= ОбъемУслугиПотребленный;                 
		СтрокНабора.СниматьНачисленныйСредний 				= СниматьНачисленныйСредний;
						
		ОбъемУслугиПоПриборуПоСтроке 						= 0;
		ОбъемУслугиПотребленныйПоПриборуПоСтроке 			= 0;
		ОбъемУслугиБезПрибораПоСтроке 						= 0;
		ОбъемУслугиПотребленныйБезПрибораПоСтроке 			= 0;
				
		Если СтрокНабора.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам 
			ИЛИ СтрокНабора.СпособНачисления = Перечисления.энргСпособНачислений.НачислениеПоСреднему Тогда
			ОбъемУслугиПоПриборуПоСтроке 					= СтрокНабора.ОбъемУслуги;
			ОбъемУслугиПотребленныйПоПриборуПоСтроке		= СтрокНабора.ОбъемУслугиПотребленный;
		Иначе
			ОбъемУслугиБезПрибораПоСтроке 					= СтрокНабора.ОбъемУслуги;
			ОбъемУслугиПотребленныйБезПрибораПоСтроке 		= СтрокНабора.ОбъемУслугиПотребленный;
		КонецЕсли;
		
		ОбъемУслугиПоПрибору 								= 0;
		ОбъемУслугиПотребленныйПоПрибору 					= 0;
		ОбъемУслугиБезПрибора 								= 0;
		ОбъемУслугиПотребленныйБезПрибора 					= 0;
		
		Если Выборка.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам 
			ИЛИ Выборка.СпособНачисления = Перечисления.энргСпособНачислений.НачислениеПоСреднему Тогда
			ОбъемУслугиПоПрибору 							= Выборка.ОбъемУслуги;
			ОбъемУслугиПотребленныйПоПрибору 				= Выборка.ОбъемУслугиПотребленный;
		Иначе
			ОбъемУслугиБезПрибора 							= Выборка.ОбъемУслуги;
			ОбъемУслугиПотребленныйБезПрибора 				= Выборка.ОбъемУслугиПотребленный;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Выборка.Абонент) Тогда				
			НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслуги 							= НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслуги + СтрокНабора.ОбъемУслуги - Выборка.ОбъемУслуги;
			НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиПотребленный 				= НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиПотребленный + СтрокНабора.ОбъемУслугиПотребленный - Выборка.ОбъемУслугиПотребленный;
			
			НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиПоПрибору 				= НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиПоПрибору + ОбъемУслугиПоПриборуПоСтроке - ОбъемУслугиПоПрибору;
			НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиПотребленныйПоПрибору 	= НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиПотребленныйПоПрибору + ОбъемУслугиПотребленныйПоПриборуПоСтроке - ОбъемУслугиПотребленныйПоПрибору;
			НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиБезПрибора 				= НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиБезПрибора + ОбъемУслугиБезПрибораПоСтроке - ОбъемУслугиБезПрибора;
			НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиПотребленныйБезПрибора 	= НачисленияПоУслугамПомещения[Выборка.СоставнаяУслуга][Выборка.Услуга][Выборка.НачалоПериода][Выборка.ТарифнаяЗона].ОбъемУслугиПотребленныйБезПрибора + ОбъемУслугиПотребленныйБезПрибораПоСтроке - ОбъемУслугиПотребленныйБезПрибора;			
		КонецЕсли;	  
	КонецЕсли; 
			
	Если Выборка.РасчетПоФормуле Тогда
		Если НЕ ПересчитатьСтрокиПоФормуле[Выборка.ТочкаУчета] = Неопределено И НЕ ПересчитатьСтрокиПоФормуле[Выборка.ТочкаУчета][Выборка.НачалоПериода] = Неопределено Тогда
