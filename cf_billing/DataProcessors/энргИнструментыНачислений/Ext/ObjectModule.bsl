		СоотвествиеПоТарифнамЗонам 							= Новый Соответствие;
		СоотвествиеПоСпособам 								= Новый Соответствие;
		СоотвествиеПоСпособам.Вставить(Выборка.СпособНачисления, Новый Структура("ОбъемУслуги,ОбъемУслугиПотребленный,СниматьНачисленныйСредний,ЗначениеСоциальнойНормы", Выборка.ОбъемУслуги, Выборка.ОбъемУслугиПотребленный, Выборка.СниматьНачисленныйСредний, Выборка.ЗначениеСоциальнойНормы));
		СоотвествиеПоТарифнамЗонам.Вставить(Выборка.ТарифнаяЗона, СоотвествиеПоСпособам);
		СоотвествиеПоШкалам.Вставить(Выборка.Шкала, СоотвествиеПоТарифнамЗонам);
		СоотвествиеПоУслугам.Вставить(Выборка.Услуга, СоотвествиеПоШкалам);
		НачисленияПоУслугам.Вставить(Выборка.ТочкаУчета,СоотвествиеПоУслугам)
	ИначеЕсли НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга] = Неопределено Тогда
		СоотвествиеПоШкалам 								= Новый Соответствие;
		СоотвествиеПоТарифнамЗонам 							= Новый Соответствие;
		СоотвествиеПоСпособам 								= Новый Соответствие;
		СоотвествиеПоСпособам.Вставить(Выборка.СпособНачисления, Новый Структура("ОбъемУслуги,ОбъемУслугиПотребленный,СниматьНачисленныйСредний,ЗначениеСоциальнойНормы", Выборка.ОбъемУслуги, Выборка.ОбъемУслугиПотребленный, Выборка.СниматьНачисленныйСредний, Выборка.ЗначениеСоциальнойНормы));
		СоотвествиеПоТарифнамЗонам.Вставить(Выборка.ТарифнаяЗона, СоотвествиеПоСпособам);
		СоотвествиеПоШкалам.Вставить(Выборка.Шкала, СоотвествиеПоТарифнамЗонам);
		НачисленияПоУслугам[Выборка.ТочкаУчета].Вставить(Выборка.Услуга,СоотвествиеПоШкалам)
	ИначеЕсли НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга][Выборка.Шкала] = Неопределено Тогда
		СоотвествиеПоТарифнамЗонам 							= Новый Соответствие;
		СоотвествиеПоСпособам 								= Новый Соответствие;
		СоотвествиеПоСпособам.Вставить(Выборка.СпособНачисления, Новый Структура("ОбъемУслуги,ОбъемУслугиПотребленный,СниматьНачисленныйСредний,ЗначениеСоциальнойНормы", Выборка.ОбъемУслуги, Выборка.ОбъемУслугиПотребленный, Выборка.СниматьНачисленныйСредний, Выборка.ЗначениеСоциальнойНормы));
		СоотвествиеПоТарифнамЗонам.Вставить(Выборка.ТарифнаяЗона, СоотвествиеПоСпособам);
		НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга].Вставить(Выборка.Шкала, СоотвествиеПоТарифнамЗонам);
	ИначеЕсли НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга][Выборка.Шкала][Выборка.ТарифнаяЗона] = Неопределено Тогда
		СоотвествиеПоСпособам 								= Новый Соответствие;
		СоотвествиеПоСпособам.Вставить(Выборка.СпособНачисления, Новый Структура("ОбъемУслуги,ОбъемУслугиПотребленный,СниматьНачисленныйСредний,ЗначениеСоциальнойНормы", Выборка.ОбъемУслуги, Выборка.ОбъемУслугиПотребленный, Выборка.СниматьНачисленныйСредний, Выборка.ЗначениеСоциальнойНормы));
		НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга][Выборка.Шкала].Вставить(Выборка.ТарифнаяЗона, СоотвествиеПоСпособам);
	ИначеЕсли НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления] = Неопределено Тогда
		НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга][Выборка.Шкала][Выборка.ТарифнаяЗона].Вставить(Выборка.СпособНачисления, Новый Структура("ОбъемУслуги,ОбъемУслугиПотребленный,СниматьНачисленныйСредний,ЗначениеСоциальнойНормы", Выборка.ОбъемУслуги, Выборка.ОбъемУслугиПотребленный, Выборка.СниматьНачисленныйСредний, Выборка.ЗначениеСоциальнойНормы));
	Иначе	
		НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления].ОбъемУслуги = НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления].ОбъемУслуги + Выборка.ОбъемУслуги;
		НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления].ОбъемУслугиПотребленный = НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.Услуга][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления].ОбъемУслугиПотребленный + Выборка.ОбъемУслугиПотребленный;
	КонецЕсли; 		   		                                                 
	
	// Запоминаем значения площадей для того чтобы пересчитать объем коммунальных квартир		
	Если Выборка.ПорядокПомещения  = 0 Тогда
		// Если будут возникать ошибки суммарной площади (изменений в один день) исправить соотвествие на хранение площадей для каждого помещения
		НачалоПериода 			= НачалоДня(Выборка.НачалоПериода);
		Если ПлощадиПомещенийПоУслугам[Выборка.Услуга] = Неопределено Тогда
			ПлощадиПоПериодам  = Новый Соответствие;
			ПлощадиПоПериодам.Вставить(НачалоПериода, Новый Структура("Площадь,Помещения",Выборка.ЗначениеПлощади, Новый Массив));
			ПлощадиПоПериодам[НачалоПериода].Помещения.добавить(Выборка.Помещение);
			ПлощадиПомещенийПоУслугам.Вставить(Выборка.Услуга, ПлощадиПоПериодам);
		ИначеЕсли ПлощадиПомещенийПоУслугам[Выборка.Услуга][НачалоПериода] = Неопределено Тогда
			ПлощадиПомещенийПоУслугам[Выборка.Услуга].Вставить(НачалоПериода, Новый Структура("Площадь,Помещения",Выборка.ЗначениеПлощади, Новый Массив));
			ПлощадиПомещенийПоУслугам[Выборка.Услуга][НачалоПериода].Помещения.добавить(Выборка.Помещение);
		ИначеЕсли ПлощадиПомещенийПоУслугам[Выборка.Услуга][НачалоПериода].Помещения.Найти(Выборка.Помещение) = Неопределено Тогда 
			ПлощадиПомещенийПоУслугам[Выборка.Услуга][НачалоПериода].Площадь = ПлощадиПомещенийПоУслугам[Выборка.Услуга][НачалоПериода].Площадь + Выборка.ЗначениеПлощади;
			ПлощадиПомещенийПоУслугам[Выборка.Услуга][НачалоПериода].Помещения.добавить(Выборка.Помещение);
		КонецЕсли;
	КонецЕсли;		
	
	Если Выборка.Техническая и ЕстьАбонент Тогда
		ПересчитатьТехническиеТочки.Добавить(ИндексСтрокиНабора);
	ИначеЕсли Выборка.Техническая Тогда
		//ПересчитатьТехническиеТочкиПомещения.Добавить(НаборОбъемПомещений.Индекс(СтрокНабора));	
		ПересчитатьТехническиеТочкиПомещения.Добавить(ТекИндексСтрокиНабораПомещений);
	КонецЕсли;		
		
	Если ДеревоТочекУчета[Выборка.КонецПериода] = Неопределено Тогда
		СтрокиНабора  									= Новый Массив;
		СтрокиНабора.Добавить(ИндексСтрокиНабора);
		
		СоотвествиеУслуги 								= Новый Соответствие;
		СоотвествиеУслуги.Вставить(Выборка.Услуга, СтрокиНабора);
		
		СоотвествиеТочки 								= Новый Соответствие;
		СоотвествиеТочки.Вставить(Выборка.ТочкаУчета, СоотвествиеУслуги);
		
		ДанныеТочкиУчета 								= Новый Соответствие;
		ДанныеТочкиУчета.Вставить(Выборка.ТочкаУчетаРодитель, СоотвествиеТочки);		
		
		ДеревоТочекУчета.Вставить(Выборка.КонецПериода, ДанныеТочкиУчета);
	ИначеЕсли ДеревоТочекУчета[Выборка.КонецПериода][Выборка.ТочкаУчетаРодитель] = Неопределено Тогда		
		
		СтрокиНабора  									= Новый Массив;
		СтрокиНабора.Добавить(ИндексСтрокиНабора);
		
		СоотвествиеУслуги 								= Новый Соответствие;
		СоотвествиеУслуги.Вставить(Выборка.Услуга, СтрокиНабора);
		
		СоотвествиеТочки 								= Новый Соответствие;
		СоотвествиеТочки.Вставить(Выборка.ТочкаУчета, СоотвествиеУслуги);
				
		ДеревоТочекУчета[Выборка.КонецПериода].Вставить(Выборка.ТочкаУчетаРодитель, СоотвествиеТочки);
		
	ИначеЕсли ДеревоТочекУчета[Выборка.КонецПериода][Выборка.ТочкаУчетаРодитель][Выборка.ТочкаУчета] = Неопределено Тогда
		СтрокиНабора  									= Новый Массив;
		СтрокиНабора.Добавить(ИндексСтрокиНабора);
		
		СоотвествиеУслуги 								= Новый Соответствие;
		СоотвествиеУслуги.Вставить(Выборка.Услуга, СтрокиНабора);
				
		ДеревоТочекУчета[Выборка.КонецПериода][Выборка.ТочкаУчетаРодитель].Вставить(Выборка.ТочкаУчета, СоотвествиеУслуги);
		
	ИначеЕсли ДеревоТочекУчета[Выборка.КонецПериода][Выборка.ТочкаУчетаРодитель][Выборка.ТочкаУчета][Выборка.Услуга] = Неопределено Тогда
		СтрокиНабора  									= Новый Массив;
		СтрокиНабора.Добавить(ИндексСтрокиНабора);		
				
		ДеревоТочекУчета[Выборка.КонецПериода][Выборка.ТочкаУчетаРодитель][Выборка.ТочкаУчета].Вставить(Выборка.Услуга, СтрокиНабора);
	Иначе
		
		ДеревоТочекУчета[Выборка.КонецПериода][Выборка.ТочкаУчетаРодитель][Выборка.ТочкаУчета][Выборка.Услуга].Добавить(ИндексСтрокиНабора); 	
	КонецЕсли;
	
	// закрытая схема
	Если Выборка.ЗакрытаяСхемаГВС Тогда
		СтрокНабора.ОбъемУслуги 							= 0;
		СтрокНабора.Сумма 									= 0;
	КонецЕсли;

КонецПроцедуры

Процедура РассчитатьДеревоТочекУчета(ДеревоТочекУчета,Набор, НаборОбъемПомещений,ОстатокСоциальнойНормы, Ошибки, ИнформацияДляОшибки)
	
	Попытка
		Для Каждого КлючЗначениеПериод Из ДеревоТочекУчета Цикл
			Дерево  								= Новый Массив;
			
			Если КлючЗначениеПериод.Значение.Количество() = 1 Тогда
				Продолжить;
			КонецЕсли;	
			
			Для Каждого Вершины Из КлючЗначениеПериод.Значение Цикл
				Если ЗначениеЗаполнено(Вершины.Ключ) Тогда
					Продолжить;
				КонецЕсли;
				
				Для Каждого КлючЗначение ИЗ Вершины.Значение Цикл 				
					Дерево.Добавить(Новый Структура("ТочкаУчета, Услуги, Потомки", КлючЗначение.Ключ, КлючЗначение.Значение, Новый Массив));					
				КонецЦикла;			
			КонецЦикла;
			
			Для Каждого Вершина Из Дерево Цикл 			
				ЗаполнитьДеревоТочекУчетаРекурсивно(КлючЗначениеПериод.Значение, Вершина.ТочкаУчета, Вершина.Потомки, Вершина.Услуги);		
			КонецЦикла;	
			
			Для Каждого Вершина Из Дерево Цикл
				
				Если Вершина.Потомки.Количество() = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				Для Каждого УслугаВершины из Вершина.Услуги Цикл 
					
					СтрокиНабора 													= УслугаВершины.Значение;
					ДанныеСтрокиНачислений 											= Набор.Получить(СтрокиНабора[0]);
					
					ОбщаяСуммаЗначениеСоциальнойНормы 								= 0; //"ЗначениеСоциальнойНормы" необходимо будет определять если у всей ветки "ОбщаяСуммаЗначениеСоциальнойНормы" больше 0
					ОбщееЗначениеСоциальнойНормыОбъемПотребленный 					= 0;
					ДанныеИспользованияСоцНормы										= ОпределитьОбщуюСуммуЗначениеСоциальнойНормыРекурсия(Набор, Вершина.Потомки, ОбщаяСуммаЗначениеСоциальнойНормы, ОбщееЗначениеСоциальнойНормыОбъемПотребленный, УслугаВершины.Ключ);		
					ПриборУчетаГоловнойТочкиВведен 									= ЗначениеЗаполнено(ДанныеСтрокиНачислений.ПриборУчета);
					Если (ДанныеСтрокиНачислений.СпособНачисления  = Перечисления.энргСпособНачислений.ПоПриборам
						ИЛИ ДанныеСтрокиНачислений.СпособНачисления  = Перечисления.энргСпособНачислений.НачислениеПоСреднему) Тогда
						
						ОчиститьОбъемУслугиТочекУчетаДереревоРекурсия(Набор, Вершина.Потомки, УслугаВершины.Ключ, ДанныеСтрокиНачислений);
						
						Для Сч = 0 По СтрокиНабора.ВГраница() Цикл
							ДанныеСтрокиНачислений 									= Набор.Получить(СтрокиНабора[Сч]);
							
							Если НЕ ДанныеСтрокиНачислений.ОбъемУслуги = 0 И НЕ ДанныеИспользованияСоцНормы.СоциальнаяНормаИспользуется Тогда 
								 ОстатокСоциальнойНормы[ДанныеСтрокиНачислений.КлючПомещения]
								[ДанныеСтрокиНачислений.Услуга]
								[ДанныеСтрокиНачислений.ЗависитОтУслуги]
								[ДанныеСтрокиНачислений.НаправлениеИспользованияТУ]
								.Остаток 											= -1;
							ИначеЕсли НЕ ДанныеСтрокиНачислений.ОбъемУслуги = 0 Тогда 
								ОстатокСоциальнойНормы[ДанныеСтрокиНачислений.КлючПомещения]
								[ДанныеСтрокиНачислений.Услуга]
								[ДанныеСтрокиНачислений.ЗависитОтУслуги]
								[ДанныеСтрокиНачислений.НаправлениеИспользованияТУ]
								.Остаток 											= ОбщаяСуммаЗначениеСоциальнойНормы;
							КонецЕсли;
							
							Если НЕ ДанныеСтрокиНачислений.ОбъемУслугиПотребленный = 0 И НЕ ДанныеИспользованияСоцНормы.СоциальнаяНормаПотребленныйИспользуется Тогда	
								ОстатокСоциальнойНормы[ДанныеСтрокиНачислений.КлючПомещения]
								[ДанныеСтрокиНачислений.Услуга]
								[ДанныеСтрокиНачислений.ЗависитОтУслуги]
								[ДанныеСтрокиНачислений.НаправлениеИспользованияТУ]
								.ОстатокПотребленный 								= -1;
							ИначеЕсли НЕ ДанныеСтрокиНачислений.ОбъемУслугиПотребленный = 0 Тогда
								ОстатокСоциальнойНормы[ДанныеСтрокиНачислений.КлючПомещения]
								[ДанныеСтрокиНачислений.Услуга]
								[ДанныеСтрокиНачислений.ЗависитОтУслуги]
								[ДанныеСтрокиНачислений.НаправлениеИспользованияТУ]
								.ОстатокПотребленный 								= ОбщееЗначениеСоциальнойНормыОбъемПотребленный;
							КонецЕсли; 
							
							Если НЕ ДанныеСтрокиНачислений.ОбъемУслуги  = 0 И НЕ ДанныеИспользованияСоцНормы.СоциальнаяНормаПотребленныйИспользуется Тогда
								ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы 		= 0;
							ИначеЕсли НЕ ДанныеСтрокиНачислений.ОбъемУслуги  = 0  Тогда
								ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы 		= ОбщаяСуммаЗначениеСоциальнойНормы;	
							КонецЕсли;
							
							Если НЕ ДанныеСтрокиНачислений.ОбъемУслугиПотребленный  = 0 И НЕ ДанныеИспользованияСоцНормы.СоциальнаяНормаПотребленныйИспользуется Тогда
								ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы 		= 0;
							ИначеЕсли НЕ ДанныеСтрокиНачислений.ОбъемУслугиПотребленный  = 0 Тогда
								ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы 		= ОбщееЗначениеСоциальнойНормыОбъемПотребленный;	
							КонецЕсли;
							
							Если ДанныеСтрокиНачислений.ОбъемУслуги  = 0 и ДанныеСтрокиНачислений.ОбъемУслугиПотребленный  = 0 Тогда
								ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы 		= 0;
							КонецЕсли;												
						КонецЦикла;
						
					Иначе
						
						Если ЗначениеЗаполнено(ДанныеСтрокиНачислений.ПриборУчета) Тогда
							УстановитьСниматьНачисленныйСреднийПотомковРекурсия(Набор, Вершина.Потомки, УслугаВершины.Ключ, ПриборУчетаГоловнойТочкиВведен);
						КонецЕсли;

						Для Сч  = 0 По СтрокиНабора.ВГраница() Цикл
							ДанныеСтрокиНачислений 									= Набор.Получить(СтрокиНабора[Сч]);
							ДанныеСтрокиНачислений.СпособНачисления 				= Перечисления.энргСпособНачислений.Расчетный; 					
							ДанныеСтрокиНачислений.ОбъемУслуги 						= 0;
							ДанныеСтрокиНачислений.СуммаПоПовышенномуКоэффициенту 	= 0;
							ДанныеСтрокиНачислений.Сумма 							= 0;
							
							ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы 			= 0;
							ДанныеСтрокиНачислений.ОбъемУслугиПотребленный			= 0;										
						КонецЦикла;
					КонецЕсли; 				
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	Исключение
		ИнформацияОбОшибке  					= ИнформацияОбОшибке();
		Ошибки 									= Ошибки +  
		Символы.ПС + ИнформацияДляОшибки + Символы.ПС + КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
	КонецПопытки;
КонецПроцедуры

Процедура ПересчитатьСоциальнуюНорму(Набор, НаборОбъемПомещений, ОстатокСоциальнойНормы, ТекИндексСтрокиНабора, ТекИндексСтрокиНабораПомещений)
	  	
	Для Каждого КлючЗначениеПомещение Из ОстатокСоциальнойНормы Цикл		
		Для Каждого КлючЗначениеУслуга Из КлючЗначениеПомещение.Значение Цикл
			Для Каждого КлючЗначениеЗависитОтУслуги Из КлючЗначениеУслуга.Значение Цикл
				Для Каждого КлючЗначениеНаправление Из КлючЗначениеЗависитОтУслуги.Значение Цикл
					СтруктураСоциальнойНормы 							= КлючЗначениеНаправление.Значение;
					Если СтруктураСоциальнойНормы.Остаток < 0 Тогда
						Продолжить;
					КонецЕсли;			
					
					ИндексыСтрок 															= СтруктураСоциальнойНормы.ИндексыСтрок;
					ИндексыСтрокПомещения													= СтруктураСоциальнойНормы.ИндексыСтрокПомещения; 				
					
					СтрокиНабораОбъемСверхНормы 											= Новый Массив;
					СтрокиНабораОбъемПотребленныйСверхНормы 								= Новый Массив;
					ОписаниеСтрокиСверхНормы 												= "Индекс,ОбъемСверхНормы,НоваяСтрока";
					Для Сч = 0 По ИндексыСтрок.ВГраница() Цикл
						СтрокаНабора  														= Набор.Получить(ИндексыСтрок[Сч]);
						Если СтрокаНабора.ПоставщикиНеНачислять Тогда 
							Продолжить;
						КонецЕсли;
						
						Если СтрокаНабора.СпособНачисления = Перечисления.энргСпособНачислений.СреднееПоНормативу и НЕ СтруктураСоциальнойНормы.РассчитыватьСоцНормуПоСтроке Тогда
							Продолжить;
						КонецЕсли;
						
						Если СтрокаНабора.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам И СтрокаНабора.СниматьНачисленныйСредний Тогда
							Продолжить;
						КонецЕсли;
						
						Если СтруктураСоциальнойНормы.РассчитыватьСоцНормуПоСтроке Тогда
							ИспользуемОбъем 												= Мин(СтрокаНабора.ЗначениеСоциальнойНормы, СтрокаНабора.ОбъемУслуги);
							ИспользуемОбъемПотребленный										= Мин(СтрокаНабора.ЗначениеСоциальнойНормы, СтрокаНабора.ОбъемУслугиПотребленный);
						Иначе
							ИспользуемОбъем 												= Мин(СтруктураСоциальнойНормы.Остаток, СтрокаНабора.ОбъемУслуги);
							ИспользуемОбъемПотребленный										= Мин(СтруктураСоциальнойНормы.ОстатокПотребленный, СтрокаНабора.ОбъемУслугиПотребленный);
						КонецЕсли;
						
						Если ИспользуемОбъем < СтрокаНабора.ОбъемУслуги и СтруктураСоциальнойНормы.Остаток > 0 Тогда						
							ДанныеСтрокиОбъем 												= Новый Структура(ОписаниеСтрокиСверхНормы);
							ДанныеСтрокиОбъем.Индекс 										= ИндексыСтрок[Сч];
							ДанныеСтрокиОбъем.ОбъемСверхНормы 								= СтрокаНабора.ОбъемУслуги - ИспользуемОбъем;
							ДанныеСтрокиОбъем.НоваяСтрока 									= Истина;
							
							СтрокаНабора.ОбъемУслуги 										= ИспользуемОбъем;
							СтрокаНабора.ОбъемУслугиСоцНорма 								= ИспользуемОбъем;
							СтрокиНабораОбъемСверхНормы.Добавить(ДанныеСтрокиОбъем); 						
						ИначеЕсли ИспользуемОбъем < СтрокаНабора.ОбъемУслуги и НЕ СтрокаНабора.ОбъемУслуги = 0 Тогда
							ДанныеСтрокиОбъем 												= Новый Структура(ОписаниеСтрокиСверхНормы);
							ДанныеСтрокиОбъем.Индекс 										= ИндексыСтрок[Сч];
							ДанныеСтрокиОбъем.ОбъемСверхНормы 								= СтрокаНабора.ОбъемУслуги - ИспользуемОбъем;
							ДанныеСтрокиОбъем.НоваяСтрока 									= Ложь;				
							СтрокиНабораОбъемСверхНормы.Добавить(ДанныеСтрокиОбъем);
						КонецЕсли; 
						
						Если ИспользуемОбъемПотребленный < СтрокаНабора.ОбъемУслугиПотребленный и СтруктураСоциальнойНормы.ОстатокПотребленный > 0 Тогда						
							ДанныеСтрокиОбъем 												= Новый Структура(ОписаниеСтрокиСверхНормы);
							ДанныеСтрокиОбъем.Индекс 										= ИндексыСтрок[Сч];
							ДанныеСтрокиОбъем.ОбъемСверхНормы 								= СтрокаНабора.ОбъемУслугиПотребленный - ИспользуемОбъемПотребленный;
							ДанныеСтрокиОбъем.НоваяСтрока 									= Истина;
							
							СтрокаНабора.ОбъемУслугиПотребленный 							= ИспользуемОбъемПотребленный;
							СтрокаНабора.ОбъемУслугиПотребленныйСоцНорма 					= ИспользуемОбъемПотребленный;
							СтрокиНабораОбъемПотребленныйСверхНормы.Добавить(ДанныеСтрокиОбъем); 						
						ИначеЕсли ИспользуемОбъемПотребленный < СтрокаНабора.ОбъемУслугиПотребленный и НЕ СтрокаНабора.ОбъемУслугиПотребленный = 0 Тогда
							ДанныеСтрокиОбъем 												= Новый Структура(ОписаниеСтрокиСверхНормы);
							ДанныеСтрокиОбъем.Индекс 										= ИндексыСтрок[Сч];
							ДанныеСтрокиОбъем.ОбъемСверхНормы 								= СтрокаНабора.ОбъемУслугиПотребленный - ИспользуемОбъемПотребленный;
							ДанныеСтрокиОбъем.НоваяСтрока 									= Ложь;
							СтрокиНабораОбъемПотребленныйСверхНормы.Добавить(ДанныеСтрокиОбъем);
						КонецЕсли;
						
						СтруктураСоциальнойНормы.Остаток 					= СтруктураСоциальнойНормы.Остаток - ИспользуемОбъем;  
						СтруктураСоциальнойНормы.ОстатокПотребленный 		= СтруктураСоциальнойНормы.ОстатокПотребленный - ИспользуемОбъемПотребленный;					
					КонецЦикла;
					
					Для Сч  = 0 По СтрокиНабораОбъемСверхНормы.ВГраница() Цикл
						ДанныеСтроки 										= СтрокиНабораОбъемСверхНормы[Сч];
						Если ДанныеСтроки.НоваяСтрока Тогда
							НоваяСтрока 									= Набор.Добавить();
							ТекИндексСтрокиНабора							= ТекИндексСтрокиНабора + 1;
							СтрокаНабора 									= Набор.Получить(СтрокиНабораОбъемСверхНормы[Сч].Индекс);
							ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаНабора);
						Иначе
							НоваяСтрока 									= Набор.Получить(СтрокиНабораОбъемСверхНормы[Сч].Индекс);
						КонецЕсли;
						
						НоваяСтрока.ОбъемУслуги 							= ДанныеСтроки.ОбъемСверхНормы;
						НоваяСтрока.ОбъемУслугиПотребленный 				= 0;
						НоваяСтрока.ОбъемУслугиСоцНорма 					= 0;
						НоваяСтрока.ОбъемУслугиПотребленныйСоцНорма 		= 0;
						НоваяСтрока.СверхНорматива 							= Истина;
						НоваяСтрока.ЗначениеТарифа 							= НоваяСтрока.ЗначениеТарифаСверхНорматива;
					КонецЦикла;
					
					Для Сч  = 0 По СтрокиНабораОбъемПотребленныйСверхНормы.ВГраница() Цикл
						ДанныеСтроки 										= СтрокиНабораОбъемПотребленныйСверхНормы[Сч];
						Если ДанныеСтроки.НоваяСтрока Тогда
							НоваяСтрока 									= Набор.Добавить();
							ТекИндексСтрокиНабора							= ТекИндексСтрокиНабора + 1;
							СтрокаНабора 									= Набор.Получить(ДанныеСтроки.Индекс);
							ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаНабора); 						
						Иначе
							НоваяСтрока 									= Набор.Получить(ДанныеСтроки.Индекс);						
						КонецЕсли;
						
						НоваяСтрока.ОбъемУслуги 							= 0;
						НоваяСтрока.ОбъемУслугиСоцНорма 					= 0;
						НоваяСтрока.СверхНорматива 							= Истина;
						НоваяСтрока.ЗначениеТарифа 							= НоваяСтрока.ЗначениеТарифаСверхНорматива;					
						НоваяСтрока.ОбъемУслугиПотребленныйСоцНорма 		= 0;
						НоваяСтрока.ОбъемУслугиПотребленный 				= ДанныеСтроки.ОбъемСверхНормы;				
					КонецЦикла;
					
					СтрокиНабораОбъемСверхНормы 											= Новый Массив;
					СтрокиНабораОбъемПотребленныйСверхНормы 								= Новый Массив;
					ОписаниеСтрокиСверхНормы 												= "Индекс,ОбъемСверхНормы,НоваяСтрока";
					
					Для Сч = 0 По ИндексыСтрокПомещения.ВГраница() Цикл
						СтрокаНабора  														= НаборОбъемПомещений.Получить(ИндексыСтрокПомещения[Сч]);
						
						Если СтрокаНабора.СпособНачисления = Перечисления.энргСпособНачислений.СреднееПоНормативу Тогда
							Продолжить;
						КонецЕсли;
						
						ИспользуемОбъем 													= Мин(СтруктураСоциальнойНормы.Остаток, СтрокаНабора.ОбъемУслуги);
						ИспользуемОбъемПотребленный											= Мин(СтруктураСоциальнойНормы.ОстатокПотребленный, СтрокаНабора.ОбъемУслугиПотребленный);
						
						Если ИспользуемОбъем < СтрокаНабора.ОбъемУслуги и СтруктураСоциальнойНормы.Остаток > 0 Тогда						
							ДанныеСтрокиОбъем 												= Новый Структура(ОписаниеСтрокиСверхНормы);
							ДанныеСтрокиОбъем.Индекс 										= ИндексыСтрокПомещения[Сч];
							ДанныеСтрокиОбъем.ОбъемСверхНормы 								= СтрокаНабора.ОбъемУслуги - ИспользуемОбъем;
							ДанныеСтрокиОбъем.НоваяСтрока 									= Истина;
							
							СтрокаНабора.ОбъемУслуги 										= ИспользуемОбъем;
							СтрокаНабора.ОбъемУслугиСоцНорма 								= ИспользуемОбъем;
							СтрокиНабораОбъемСверхНормы.Добавить(ДанныеСтрокиОбъем); 						
						ИначеЕсли ИспользуемОбъем < СтрокаНабора.ОбъемУслуги и НЕ СтрокаНабора.ОбъемУслуги = 0 Тогда
							ДанныеСтрокиОбъем 												= Новый Структура(ОписаниеСтрокиСверхНормы);
							ДанныеСтрокиОбъем.Индекс 										= ИндексыСтрокПомещения[Сч];
							ДанныеСтрокиОбъем.ОбъемСверхНормы 								= СтрокаНабора.ОбъемУслуги - ИспользуемОбъем;
							ДанныеСтрокиОбъем.НоваяСтрока 									= Ложь;				
							СтрокиНабораОбъемСверхНормы.Добавить(ДанныеСтрокиОбъем);
						КонецЕсли; 
						
						Если ИспользуемОбъемПотребленный < СтрокаНабора.ОбъемУслугиПотребленный и СтруктураСоциальнойНормы.ОстатокПотребленный > 0 Тогда						
							ДанныеСтрокиОбъем 												= Новый Структура(ОписаниеСтрокиСверхНормы);
							ДанныеСтрокиОбъем.Индекс 										= ИндексыСтрокПомещения[Сч];
							ДанныеСтрокиОбъем.ОбъемСверхНормы 								= СтрокаНабора.ОбъемУслугиПотребленный - ИспользуемОбъемПотребленный;
							ДанныеСтрокиОбъем.НоваяСтрока 									= Истина;
							
							СтрокаНабора.ОбъемУслугиПотребленный 							= ИспользуемОбъемПотребленный;
							СтрокаНабора.ОбъемУслугиПотребленныйСоцНорма 					= ИспользуемОбъемПотребленный;
							СтрокиНабораОбъемПотребленныйСверхНормы.Добавить(ДанныеСтрокиОбъем); 						
						ИначеЕсли ИспользуемОбъемПотребленный < СтрокаНабора.ОбъемУслугиПотребленный и НЕ СтрокаНабора.ОбъемУслугиПотребленный = 0 Тогда
							ДанныеСтрокиОбъем 												= Новый Структура(ОписаниеСтрокиСверхНормы);
							ДанныеСтрокиОбъем.Индекс 										= ИндексыСтрокПомещения[Сч];
							ДанныеСтрокиОбъем.ОбъемСверхНормы 								= СтрокаНабора.ОбъемУслугиПотребленный - ИспользуемОбъемПотребленный;
							ДанныеСтрокиОбъем.НоваяСтрока 									= Ложь;
							СтрокиНабораОбъемПотребленныйСверхНормы.Добавить(ДанныеСтрокиОбъем);
						КонецЕсли;
						
						СтруктураСоциальнойНормы.Остаток 					= СтруктураСоциальнойНормы.Остаток - ИспользуемОбъем;  
						СтруктураСоциальнойНормы.ОстатокПотребленный 		= СтруктураСоциальнойНормы.ОстатокПотребленный - ИспользуемОбъемПотребленный;					
					КонецЦикла;
					
					Для Сч  = 0 По СтрокиНабораОбъемСверхНормы.ВГраница() Цикл
						ДанныеСтроки 										= СтрокиНабораОбъемСверхНормы[Сч];
						Если ДанныеСтроки.НоваяСтрока Тогда
							НоваяСтрока 									= НаборОбъемПомещений.Добавить();
							ТекИндексСтрокиНабораПомещений					= ТекИндексСтрокиНабораПомещений + 1;
							СтрокаНабора 									= НаборОбъемПомещений.Получить(СтрокиНабораОбъемСверхНормы[Сч].Индекс);
							ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаНабора);
						Иначе
							НоваяСтрока 									= НаборОбъемПомещений.Получить(СтрокиНабораОбъемСверхНормы[Сч].Индекс);
						КонецЕсли;
						
						НоваяСтрока.ОбъемУслуги 							= ДанныеСтроки.ОбъемСверхНормы;
						НоваяСтрока.ОбъемУслугиПотребленный 				= 0;
						НоваяСтрока.ОбъемУслугиСоцНорма 					= 0;
						НоваяСтрока.СверхНорматива 							= Истина;
						НоваяСтрока.ЗначениеТарифа 							= НоваяСтрока.ЗначениеТарифаСверхНорматива;
					КонецЦикла;
					
					Для Сч  = 0 По СтрокиНабораОбъемПотребленныйСверхНормы.ВГраница() Цикл
						ДанныеСтроки 										= СтрокиНабораОбъемПотребленныйСверхНормы[Сч];
						Если ДанныеСтроки.НоваяСтрока Тогда
							НоваяСтрока 									= НаборОбъемПомещений.Добавить();
							ТекИндексСтрокиНабораПомещений					= ТекИндексСтрокиНабораПомещений + 1;
							СтрокаНабора 									= НаборОбъемПомещений.Получить(ДанныеСтроки.Индекс);
							ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаНабора); 						
						Иначе
							НоваяСтрока 									= НаборОбъемПомещений.Получить(ДанныеСтроки.Индекс);						
						КонецЕсли;
						
						НоваяСтрока.ОбъемУслуги 							= 0;
						НоваяСтрока.ОбъемУслугиСоцНорма 					= 0;
						НоваяСтрока.СверхНорматива 							= Истина;
						НоваяСтрока.ЗначениеТарифа 							= НоваяСтрока.ЗначениеТарифаСверхНорматива;					
						
						НоваяСтрока.ОбъемУслугиПотребленный 				= ДанныеСтроки.ОбъемСверхНормы;				
					КонецЦикла;					
				КонецЦикла;		
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьДеревоТочекУчетаРекурсивно(ДеревоТочекУчета,Родитель,Потомки,Услуги)
	Коллекция  			= ДеревоТочекУчета[Родитель];
	
	Если Коллекция = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого КлючЗначение Из Коллекция Цикл
		врПотомки  		= Новый Массив;
		ЗаполнитьДеревоТочекУчетаРекурсивно(ДеревоТочекУчета, КлючЗначение.Ключ, врПотомки, КлючЗначение.Значение);
		Потомки.Добавить(Новый Структура("ТочкаУчета, Потомки, Услуги", КлючЗначение.Ключ, врПотомки, КлючЗначение.Значение)); 		
	КонецЦикла;
КонецПроцедуры

Процедура ОчиститьОбъемУслугиТочекУчетаДереревоРекурсия(Набор, Потомки, Услуга, ДанныеСтрокиРодителя)
	
	Для Каждого СтрокаПотомка Из Потомки Цикл
		СтрокиНабора 										= СтрокаПотомка.Услуги[Услуга];
		Если СтрокиНабора = Неопределено Тогда
			Продолжить;
		КонецЕсли; 	
		
		Для Сч = 0 По СтрокиНабора.ВГраница() Цикл
			ДанныеСтрокиНачислений 							=  Набор.Получить(СтрокиНабора[Сч]);			
			ДанныеСтрокиНачислений.ОбъемУслуги  			= 0;
			ДанныеСтрокиНачислений.ОбъемУслугиПотребленный  = 0;
			ДанныеСтрокиНачислений.Сумма  					= 0;
			ДанныеСтрокиНачислений.СверхНорматива 			= Ложь; 			
		КонецЦикла;
		ОчиститьОбъемУслугиТочекУчетаДереревоРекурсия(Набор, СтрокаПотомка.Потомки, Услуга, ДанныеСтрокиРодителя);
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьСниматьНачисленныйСреднийПотомковРекурсия(Набор, Потомки, Услуга, ПриборУчетаГоловнойТочкиВведен)
	
	Для Каждого СтрокаПотомка Из Потомки Цикл
		СтрокиНабора 											= СтрокаПотомка.Услуги[Услуга];
		Если СтрокиНабора = Неопределено Тогда
			Продолжить;
		КонецЕсли; 	
		
		Для Сч = 0 По СтрокиНабора.ВГраница() Цикл
			ДанныеСтрокиНачислений 								= Набор.Получить(СтрокиНабора[Сч]);			
			ДанныеСтрокиНачислений.СниматьНачисленныйСредний	= Истина;
			ДанныеСтрокиНачислений.СпособНачисления 			= ?(ПриборУчетаГоловнойТочкиВведен, Перечисления.энргСпособНачислений.СреднееПоНормативу, Перечисления.энргСпособНачислений.ПоНормативу); 
			ДанныеСтрокиНачислений.ПовыщающийКоэффициент 		= ?(ПриборУчетаГоловнойТочкиВведен,1,ДанныеСтрокиНачислений.ПовыщающийКоэффициент);  
		КонецЦикла;
		УстановитьСниматьНачисленныйСреднийПотомковРекурсия(Набор, СтрокаПотомка.Потомки, Услуга, ПриборУчетаГоловнойТочкиВведен);
	КонецЦикла;
	
КонецПроцедуры

Функция СуммаНормативовПотомковРекурсия(Набор, Потомки, Услуга, ПриборУчетаГоловнойТочкиВведен) 
	
	врНорматив 												= Новый Структура("ОбъемУслуги,Сумма,СуммаПоПовышенномуКоэффициенту", 0, 0, 0);
	Для Каждого СтрокаПотомка Из Потомки Цикл
		Если СтрокаПотомка.Потомки.Количество()  = 0 Тогда
			СтрокиНабора 									= СтрокаПотомка.Услуги[Услуга];
			Если СтрокиНабора = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Для Сч = 0 По СтрокиНабора.ВГраница() Цикл
				СтрокаНабора 								= Набор.Получить(СтрокиНабора[Сч]);
				Если НЕ Услуга = СтрокаНабора.Услуга Тогда
					Продолжить;
				КонецЕсли;
				СтрокаНабора.ПовыщающийКоэффициент 			= ?(ПриборУчетаГоловнойТочкиВведен,1,СтрокаНабора.ПовыщающийКоэффициент);
				РегистрыНакопления.энргОбъемНачислений.РассчитатьСуммуПоПотребленномуОбъему(СтрокаНабора);
				
				врНорматив.ОбъемУслуги 						= врНорматив.ОбъемУслуги + СтрокаНабора.ОбъемУслугиПотребленный;
				врНорматив.Сумма 							= врНорматив.Сумма + СтрокаНабора.Сумма;
				врНорматив.СуммаПоПовышенномуКоэффициенту 	= врНорматив.СуммаПоПовышенномуКоэффициенту + СтрокаНабора.СуммаПоПовышенномуКоэффициенту;
			КонецЦикла;			
		Иначе
			яНорматив 										= СуммаНормативовПотомковРекурсия(Набор, СтрокаПотомка.Потомки, Услуга, ПриборУчетаГоловнойТочкиВведен);
			врНорматив.ОбъемУслуги 							= врНорматив.ОбъемУслуги + яНорматив.ОбъемУслугиПотребленный;
			врНорматив.Сумма 								= врНорматив.Сумма + яНорматив.Сумма;
			врНорматив.СуммаПоПовышенномуКоэффициенту 		= врНорматив.СуммаПоПовышенномуКоэффициенту + яНорматив.СуммаПоПовышенномуКоэффициенту;
		КонецЕсли;		
	КонецЦикла;
	
	Возврат врНорматив;
	
КонецФункции

Функция ОпределитьОбщуюСуммуЗначениеСоциальнойНормыРекурсия(Набор, Потомки, ОбщаяСуммаЗначениеСоциальнойНормы, ОбщееЗначениеСоциальнойНормыОбъемПотребленный, Услуга);
	
	СоциальнаяНормаИспользуется 								= Ложь;
	СоциальнаяНормаПотребленныйИспользуется 					= Ложь;
	
	Для Каждого СтрокаПотомка Из Потомки Цикл
		
		СтрокиНабора 											= СтрокаПотомка.Услуги[Услуга];
		Если СтрокиНабора = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		
		Для Сч = 0 По СтрокиНабора.ВГраница() Цикл  			
			ДанныеСтрокиНачислений 								= Набор.Получить(СтрокиНабора[Сч]);			 
			Если НЕ ДанныеСтрокиНачислений.ОбъемУслуги = 0 Тогда
				ОбщаяСуммаЗначениеСоциальнойНормы 				= ОбщаяСуммаЗначениеСоциальнойНормы + ?(ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы = -1,ДанныеСтрокиНачислений.ЗначениеСоциальнойНормыРасчетныйСпособ,ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы);
				Если НЕ ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы = -1 Тогда
					СоциальнаяНормаИспользуется 				= Истина;
				КонецЕсли;				
			КонецЕсли;
			Если НЕ ДанныеСтрокиНачислений.ОбъемУслугиПотребленный = 0 Тогда
				ОбщееЗначениеСоциальнойНормыОбъемПотребленный 	= ОбщееЗначениеСоциальнойНормыОбъемПотребленный + ?(ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы = -1,ДанныеСтрокиНачислений.ЗначениеСоциальнойНормыРасчетныйСпособ,ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы);
				Если НЕ ДанныеСтрокиНачислений.ЗначениеСоциальнойНормы = -1 Тогда
					СоциальнаяНормаПотребленныйИспользуется 	= Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		ДанныеИспользования		 								= ОпределитьОбщуюСуммуЗначениеСоциальнойНормыРекурсия(Набор, СтрокаПотомка.Потомки, ОбщаяСуммаЗначениеСоциальнойНормы, ОбщееЗначениеСоциальнойНормыОбъемПотребленный, Услуга);
		
		СоциальнаяНормаИспользуется 							= Макс(СоциальнаяНормаИспользуется, ДанныеИспользования.СоциальнаяНормаИспользуется);
		СоциальнаяНормаПотребленныйИспользуется					= Макс(СоциальнаяНормаПотребленныйИспользуется, ДанныеИспользования.СоциальнаяНормаПотребленныйИспользуется);		
	КонецЦикла;	
	
	Возврат Новый Структура("СоциальнаяНормаИспользуется,СоциальнаяНормаПотребленныйИспользуется", СоциальнаяНормаПотребленныйИспользуется, СоциальнаяНормаПотребленныйИспользуется);
	
КонецФункции

Функция КлючиЗаписиРезультатаЗапроса(РезультатЗапроса)
	
	мКлючЗаписи  = Новый Массив;
	Для Каждого КолонкаРезультат Из РезультатЗапроса.Колонки Цикл
		мКлючЗаписи.Добавить(КолонкаРезультат.Имя);
	КонецЦикла;
	
	Возврат СтрСоединить(мКлючЗаписи,",");	   
		
КонецФункции

Процедура ИзменитьОстатокСоциальнойНормы(Выборка, ОстатокСоциальнойНормы,  Набор, НаборОбъемПомещений, СтрокНабора,  ИндексСтрокиНабора, ЕстьАбонент, НачисленияПоУслугам);
	
	//ТочностьОбъема											= Метаданные.РегистрыНакопления.энргОбъемНачислений.Ресурсы.ОбъемУслуги.Тип.КвалификаторыЧисла.РазрядностьДробнойЧасти;
	СтрокНабораКалендарныхДней = День(КонецМесяца(СтрокНабора.НачалоПериода));
	СтрокНабораДнейВПериоде = (НачалоДня(СтрокНабора.КонецПериода) - НачалоДня(СтрокНабора.НачалоПериода)) / (24 * 3600);
	Если Выборка.ПомещениеРодитель = Выборка.Помещение И ЗначениеЗаполнено(Выборка.ЗависитОтУслуги) И НЕ Выборка.РасчетПоФормуле И НЕ ЗначениеЗаполнено(Выборка.ЗависимаяТочкаУчета) Тогда
		// соцнорма зависимой ТУ
		Если НЕ НачисленияПоУслугам.Получить(Выборка.ТочкаУчета) = Неопределено 
			И НЕ НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги] = Неопределено
			И НЕ НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала] = Неопределено
			И НЕ НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала][Выборка.ТарифнаяЗона] = Неопределено
			И НЕ НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления] = Неопределено
			И Выборка.ЗначениеСоциальнойНормы > 0 Тогда 
			 
			// времЗначениеСоциальнойНормы	= Выборка.НормаПотребления * НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления].ЗначениеСоциальнойНормы;
			времЗначениеСоциальнойНормы	= НачисленияПоУслугам[Выборка.ТочкаУчета][Выборка.ЗависитОтУслуги][Выборка.Шкала][Выборка.ТарифнаяЗона][Выборка.СпособНачисления].ЗначениеСоциальнойНормы;
		Иначе 
			времЗначениеСоциальнойНормы	= Выборка.ЗначениеСоциальнойНормы;
		КонецЕсли;
		
	Иначе
		времЗначениеСоциальнойНормы	= Выборка.ЗначениеСоциальнойНормы;
	КонецЕсли;
	
	Если времЗначениеСоциальнойНормы < 0 Или Выборка.СоциальнаяНормаЗависитОтРасхода Тогда
		// если СоциальнаяНормаЗависитОтРасхода то мы же учли дни в запросе

		окрЗначениеСоциальнойНормы = времЗначениеСоциальнойНормы;
	Иначе
		окрЗначениеСоциальнойНормы = Окр(времЗначениеСоциальнойНормы / СтрокНабораКалендарныхДней * СтрокНабораДнейВПериоде ,8);
	КонецЕсли;
	//ЕстьАбонент 											= ИндексСтрокиНабора >= 0;
	
	КлючиОписанияСоциальнойНормы 							= "КонецПериода,Остаток,ОстатокПотребленный,ИндексыСтрок,ИндексыСтрокПомещения, РассчитыватьСоцНормуПоСтроке";
	яЗначениеСоциальнойНормы 								= 0;
	яЗначениеСоциальнойНормыОбъемПотребленный 				= 0;
	
	Если Выборка.ЗначениеСоциальнойНормы < 0 Тогда
		яЗначениеСоциальнойНормы 					= Выборка.ЗначениеСоциальнойНормы;
		яЗначениеСоциальнойНормыОбъемПотребленный 	= Выборка.ЗначениеСоциальнойНормы;
	КонецЕсли; 
	
	Если НЕ СтрокНабора.ОбъемУслуги = 0 Или (яЗначениеСоциальнойНормы < 0 И времЗначениеСоциальнойНормы >= 0) Тогда
		яЗначениеСоциальнойНормы 							= окрЗначениеСоциальнойНормы;
	КонецЕсли;
	
	Если НЕ СтрокНабора.ОбъемУслугиПотребленный = 0 Или (яЗначениеСоциальнойНормыОбъемПотребленный < 0 И времЗначениеСоциальнойНормы >= 0) Тогда
		яЗначениеСоциальнойНормыОбъемПотребленный 			= окрЗначениеСоциальнойНормы;
	КонецЕсли;
		
	Если ОстатокСоциальнойНормы[Выборка.КлючПомещения] = Неопределено Тогда
		ИндексыСтрок 										= Новый Массив;
		ИндексыСтрокПомещения 								= Новый Массив;
		Если ЕстьАбонент Тогда
			ИндексыСтрок.Добавить(ИндексСтрокиНабора);
		Иначе
			ИндексыСтрокПомещения.Добавить(ИндексСтрокиНабора);
		КонецЕсли;
		ОписаниеСоциальнойНормы  							= Новый Структура(КлючиОписанияСоциальнойНормы, СтрокНабора.КонецПериода,яЗначениеСоциальнойНормы,яЗначениеСоциальнойНормыОбъемПотребленный,ИндексыСтрок,ИндексыСтрокПомещения, Выборка.РассчитыватьСоцНормуПоСтроке);
		
		СоотвествиеНаправление  							= Новый Соответствие;
		СоотвествиеНаправление.Вставить(Выборка.НаправлениеИспользованияТУ, ОписаниеСоциальнойНормы);
		
		СоотвествиеЗависитОтУслуги 							= Новый Соответствие;
		СоотвествиеЗависитОтУслуги.Вставить(Выборка.ЗависитОтУслуги, СоотвествиеНаправление);
		
		СоотвествиеУслуга		  							= Новый Соответствие;
		СоотвествиеУслуга.Вставить(Выборка.Услуга, СоотвествиеЗависитОтУслуги);
		
		ОстатокСоциальнойНормы.Вставить(Выборка.КлючПомещения, СоотвествиеУслуга);
	ИначеЕсли ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга] = Неопределено   Тогда		
		ИндексыСтрок 										= Новый Массив;
		ИндексыСтрокПомещения 								= Новый Массив;
		Если ЕстьАбонент Тогда
			ИндексыСтрок.Добавить(ИндексСтрокиНабора);
		Иначе
			ИндексыСтрокПомещения.Добавить(ИндексСтрокиНабора);
		КонецЕсли;
		ОписаниеСоциальнойНормы  							= Новый Структура(КлючиОписанияСоциальнойНормы, СтрокНабора.КонецПериода,яЗначениеСоциальнойНормы,яЗначениеСоциальнойНормыОбъемПотребленный,ИндексыСтрок,ИндексыСтрокПомещения, Выборка.РассчитыватьСоцНормуПоСтроке);
		
		СоотвествиеНаправление  							= Новый Соответствие;
		СоотвествиеНаправление.Вставить(Выборка.НаправлениеИспользованияТУ, ОписаниеСоциальнойНормы);
		
		СоотвествиеЗависитОтУслуги 							= Новый Соответствие;
		СоотвествиеЗависитОтУслуги.Вставить(Выборка.ЗависитОтУслуги, СоотвествиеНаправление);
		
		ОстатокСоциальнойНормы[Выборка.КлючПомещения].Вставить(Выборка.Услуга, СоотвествиеЗависитОтУслуги);	
		
	ИначеЕсли ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги] = Неопределено   Тогда		
		ИндексыСтрок 										= Новый Массив;
		ИндексыСтрокПомещения 								= Новый Массив;
		Если ЕстьАбонент Тогда
			ИндексыСтрок.Добавить(ИндексСтрокиНабора);
		Иначе
			ИндексыСтрокПомещения.Добавить(ИндексСтрокиНабора);
		КонецЕсли;
		ОписаниеСоциальнойНормы  							= Новый Структура(КлючиОписанияСоциальнойНормы, СтрокНабора.КонецПериода,яЗначениеСоциальнойНормы,яЗначениеСоциальнойНормыОбъемПотребленный,ИндексыСтрок,ИндексыСтрокПомещения, Выборка.РассчитыватьСоцНормуПоСтроке);
		
		СоотвествиеНаправление  							= Новый Соответствие;
		СоотвествиеНаправление.Вставить(Выборка.НаправлениеИспользованияТУ, ОписаниеСоциальнойНормы);
		
		ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга].Вставить(Выборка.ЗависитОтУслуги, СоотвествиеНаправление);	

	ИначеЕсли ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ] = Неопределено Тогда
		ИндексыСтрок 										= Новый Массив;
		ИндексыСтрокПомещения 								= Новый Массив;
		Если ЕстьАбонент Тогда
			ИндексыСтрок.Добавить(ИндексСтрокиНабора);
		Иначе
			ИндексыСтрокПомещения.Добавить(ИндексСтрокиНабора);
		КонецЕсли;
		ОписаниеСоциальнойНормы  							= Новый Структура(КлючиОписанияСоциальнойНормы, СтрокНабора.КонецПериода,яЗначениеСоциальнойНормы,яЗначениеСоциальнойНормыОбъемПотребленный,ИндексыСтрок,ИндексыСтрокПомещения, Выборка.РассчитыватьСоцНормуПоСтроке);
		ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги].Вставить(Выборка.НаправлениеИспользованияТУ, ОписаниеСоциальнойНормы);
		
	//ИначеЕсли ОстатокСоциальнойНормы[КлючПомещения][Услуга][НаправлениеИспользованияТУ].КонецПериода = СтрокНабора.НачалоПериода и НЕ СоциальнаяНормаЗависитОтРасхода   Тогда		
	//	ИндексыСтрок 										= Новый Массив;
	//	ИндексыСтрокПомещения 								= Новый Массив;
	//	Если ЕстьАбонент Тогда
	//		ИндексыСтрок.Добавить(ИндексСтрокиНабора);
	//	Иначе
	//		ИндексыСтрокПомещения.Добавить(НаборОбъемПомещений.Индекс(СтрокНабора));
	//	КонецЕсли;
	//	ОписаниеСоциальнойНормы  							= Новый Структура(КлючиОписанияСоциальнойНормы, СтрокНабора.КонецПериода,яЗначениеСоциальнойНормы,яЗначениеСоциальнойНормыОбъемПотребленный,ИндексыСтрок,ИндексыСтрокПомещения, РассчитыватьСоцНормуПоСтроке);
	//	СоотвествиеНаправление  							= Новый Соответствие;
	//	СоотвествиеНаправление.Вставить(НаправлениеИспользованияТУ, ОписаниеСоциальнойНормы);																																 
	//	ОстатокСоциальнойНормы[КлючПомещения].Вставить(Услуга, СоотвествиеНаправление);		
		
	ИначеЕсли ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].КонецПериода = СтрокНабора.КонецПериода и НЕ Выборка.СоциальнаяНормаЗависитОтРасхода Тогда
		
		Если НЕ СтрокНабора.ОбъемУслуги = 0 Тогда
			ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].Остаток 				= окрЗначениеСоциальнойНормы;
		КонецЕсли;
		
		Если НЕ СтрокНабора.ОбъемУслугиПотребленный = 0 Тогда
			ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ОстатокПотребленный 	= окрЗначениеСоциальнойНормы;
		КонецЕсли;   		
		
		Если ЕстьАбонент Тогда
			ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ИндексыСтрок.Добавить(ИндексСтрокиНабора);
		Иначе
			ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ИндексыСтрокПомещения.Добавить(ИндексСтрокиНабора);
		КонецЕсли;	
	ИначеЕсли ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].КонецПериода < СтрокНабора.КонецПериода и НЕ Выборка.СоциальнаяНормаЗависитОтРасхода Тогда
		ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].Остаток 				= ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].Остаток + яЗначениеСоциальнойНормы;
		ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ОстатокПотребленный 	= ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ОстатокПотребленный + яЗначениеСоциальнойНормыОбъемПотребленный;
		
		Если ЕстьАбонент Тогда
			ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ИндексыСтрок.Добавить(ИндексСтрокиНабора);
		Иначе
			ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ИндексыСтрокПомещения.Добавить(ИндексСтрокиНабора);
		КонецЕсли;
	//ИначеЕсли ОстатокСоциальнойНормы[КлючПомещения][Услуга][НаправлениеИспользованияТУ].КонецПериода < СтрокНабора.КонецПериода и НЕ СоциальнаяНормаЗависитОтРасхода Тогда
	//	ОстатокСоциальнойНормы[КлючПомещения][Услуга][НаправлениеИспользованияТУ].Остаток 				= окрЗначениеСоциальнойНормы;
	//	ОстатокСоциальнойНормы[КлючПомещения][Услуга][НаправлениеИспользованияТУ].ОстатокПотребленный 	= окрЗначениеСоциальнойНормы;
	//	Если ЕстьАбонент Тогда
	//		ОстатокСоциальнойНормы[КлючПомещения][Услуга][НаправлениеИспользованияТУ].ИндексыСтрок.Добавить(ИндексСтрокиНабора);
	//	Иначе
	//		ОстатокСоциальнойНормы[КлючПомещения][Услуга][НаправлениеИспользованияТУ].ИндексыСтрокПомещения.Добавить(ИндексСтрокиНабора);
	//	КонецЕсли;
	ИначеЕсли Выборка.СоциальнаяНормаЗависитОтРасхода Тогда
		ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].Остаток = ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].Остаток + яЗначениеСоциальнойНормы;
		ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ОстатокПотребленный = ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ОстатокПотребленный + яЗначениеСоциальнойНормыОбъемПотребленный;
		Если ЕстьАбонент Тогда
			ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ИндексыСтрок.Добавить(ИндексСтрокиНабора);
		Иначе
			ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ИндексыСтрокПомещения.Добавить(ИндексСтрокиНабора);
		КонецЕсли;		
	ИначеЕсли ЕстьАбонент Тогда		
		ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ИндексыСтрок.Добавить(ИндексСтрокиНабора);
	Иначе		
		ОстатокСоциальнойНормы[Выборка.КлючПомещения][Выборка.Услуга][Выборка.ЗависитОтУслуги][Выборка.НаправлениеИспользованияТУ].ИндексыСтрокПомещения.Добавить(ИндексСтрокиНабора);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьНачисленияПоУслугамПомещения(ДанныеВыборки, НачисленияПоУслугамПомещения)
		
	Если НЕ ДанныеВыборки.Помещение  = ДанныеВыборки.ПомещениеРодитель Тогда
		Возврат;
	КонецЕсли; 
	             	
	ДанныеСтрокиРезультата 							= Новый ФиксированнаяСтруктура(ДанныеВыборки);
	
	ЗначениеСоотвествия 							= Новый Структура("
	|КоличествоЧеловек,ОбъемУслуги,ОбъемУслугиПотребленный,ВидПлощади,
	|ОбъемУслугиОстаток,ОбъемУслугиПотребленныйОстаток,ЗначениеСоциальнойНормы,
	|ОбъемУслугиПоПрибору,ОбъемУслугиПотребленныйПоПрибору,ОбъемУслугиБезПрибора,ОбъемУслугиПотребленныйБезПрибора,
	|ПовыщающийКоэффициент,СниматьНачисленныйСредний,УслугаПолностьюОприборена,СпособНачисления,
	|СтрокиРезультатаЗапроса,ОбъемУслугиСписать,ОбъемУслугиПотребленныйСписать,НазначениеПУ,
	|ВидДифференцированности,ЗначениеТарифа, ЗначениеТарифаСверхНорматива");
	
	ОбъемУслугиПоПрибору 									= 0;
	ОбъемУслугиПотребленныйПоПрибору 						= 0;
	ОбъемУслугиБезПрибора 									= 0;
	ОбъемУслугиПотребленныйБезПрибора 						= 0;
	
	Если ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам 
		ИЛИ ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.НачислениеПоСреднему Тогда
		ОбъемУслугиПоПрибору 								= ДанныеВыборки.ОбъемУслуги;
		ОбъемУслугиПотребленныйПоПрибору 					= ДанныеВыборки.ОбъемУслугиПотребленный;
	Иначе
		ОбъемУслугиБезПрибора 								= ДанныеВыборки.ОбъемУслуги;
		ОбъемУслугиПотребленныйБезПрибора 					= ДанныеВыборки.ОбъемУслугиПотребленный;
	КонецЕсли; 
	
	ЗначениеСоотвествия.КоличествоЧеловек 					= ДанныеВыборки.КоличествоЖильцов;
	ЗначениеСоотвествия.ВидПлощади 							= ДанныеВыборки.ВидПлощади;
	ЗначениеСоотвествия.ОбъемУслугиОстаток 					= ДанныеВыборки.ОбъемУслуги;
	ЗначениеСоотвествия.ОбъемУслугиПотребленныйОстаток 		= ДанныеВыборки.ОбъемУслугиПотребленный;
	ЗначениеСоотвествия.ЗначениеСоциальнойНормы 			= ДанныеВыборки.ЗначениеСоциальнойНормы;
	ЗначениеСоотвествия.ПовыщающийКоэффициент 				= ДанныеВыборки.ПовыщающийКоэффициент;
	ЗначениеСоотвествия.СниматьНачисленныйСредний 			= ДанныеВыборки.СниматьНачисленныйСредний;
	ЗначениеСоотвествия.УслугаПолностьюОприборена 			= ДанныеВыборки.УслугаПолностьюОприборена;
	ЗначениеСоотвествия.СпособНачисления 					= ДанныеВыборки.СпособНачисления;
	ЗначениеСоотвествия.НазначениеПУ 						= ДанныеВыборки.НазначениеПУ;
	ЗначениеСоотвествия.ВидДифференцированности 			= ДанныеВыборки.ВидДифференцированности;
	ЗначениеСоотвествия.ЗначениеТарифа 						= ДанныеВыборки.ЗначениеТарифа;
	ЗначениеСоотвествия.ЗначениеТарифаСверхНорматива 		= ДанныеВыборки.ЗначениеТарифаСверхНорматива;

	Если ДанныеВыборки.СниматьНачисленныйСредний И ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам Тогда
		ЗначениеСоотвествия.ОбъемУслуги 						= 0;
		ЗначениеСоотвествия.ОбъемУслугиПотребленный 			= 0;
		ЗначениеСоотвествия.ОбъемУслугиПоПрибору 				= 0;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйПоПрибору 	= 0;
		ЗначениеСоотвествия.ОбъемУслугиБезПрибора 				= 0;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйБезПрибора 	= 0;
		ЗначениеСоотвествия.ОбъемУслугиСписать 					= ДанныеВыборки.ОбъемУслуги;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйСписать 		= ДанныеВыборки.ОбъемУслугиПотребленный;
	Иначе
		ЗначениеСоотвествия.ОбъемУслуги 						= ДанныеВыборки.ОбъемУслуги;
		ЗначениеСоотвествия.ОбъемУслугиПотребленный 			= ДанныеВыборки.ОбъемУслугиПотребленный;
		ЗначениеСоотвествия.ОбъемУслугиПоПрибору 				= ОбъемУслугиПоПрибору;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйПоПрибору 	= ОбъемУслугиПотребленныйПоПрибору;
		ЗначениеСоотвествия.ОбъемУслугиБезПрибора 				= ОбъемУслугиБезПрибора;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйБезПрибора 	= ОбъемУслугиПотребленныйБезПрибора;
		ЗначениеСоотвествия.ОбъемУслугиСписать 					= 0;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйСписать 		= 0;
	КонецЕсли;
	ЗначениеСоотвествия.СтрокиРезультатаЗапроса				= Новый Массив;
	ЗначениеСоотвествия.СтрокиРезультатаЗапроса.Добавить(ДанныеСтрокиРезультата);
	
	Если НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга] = Неопределено Тогда
		
		СоотвествиеТарифнаяЗона 						= Новый Соответствие;
		СоотвествиеТарифнаяЗона.Вставить(ДанныеВыборки.ТарифнаяЗона, ЗначениеСоотвествия);	
		
		СоотвествиеНачалоПериода 						= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, СоотвествиеТарифнаяЗона);
		
		СоотвествиеУслуга 								= Новый Соответствие;
		СоотвествиеУслуга.Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);
		
		НачисленияПоУслугамПомещения.Вставить(ДанныеВыборки.СоставнаяУслуга,СоотвествиеУслуга);
		
	ИначеЕсли НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга] = Неопределено Тогда
		
		СоотвествиеТарифнаяЗона 						= Новый Соответствие;
		СоотвествиеТарифнаяЗона.Вставить(ДанныеВыборки.ТарифнаяЗона, ЗначениеСоотвествия);	
		
		СоотвествиеНачалоПериода 						= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, СоотвествиеТарифнаяЗона);
				
		НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга].Вставить(ДанныеВыборки.Услуга,СоотвествиеНачалоПериода);			
		
	ИначеЕсли НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода] = Неопределено Тогда
		
		СоотвествиеТарифнаяЗона 						= Новый Соответствие;
		СоотвествиеТарифнаяЗона.Вставить(ДанныеВыборки.ТарифнаяЗона, ЗначениеСоотвествия);
								
		НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга].Вставить(ДанныеВыборки.НачалоПериода, СоотвествиеТарифнаяЗона);
				
	ИначеЕсли НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона] = Неопределено Тогда
		
		НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода].Вставить(ДанныеВыборки.ТарифнаяЗона, ЗначениеСоотвествия);
		
	Иначе		
		НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].КоличествоЧеловек 						= ДанныеВыборки.КоличествоЖильцов;
		НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ЗначениеСоциальнойНормы 					= ДанныеВыборки.ЗначениеСоциальнойНормы;
		НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ВидПлощади 								= ДанныеВыборки.ВидПлощади;
		
		Если ДанныеВыборки.СниматьНачисленныйСредний И ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам Тогда
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиСписать 					= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиСписать + ДанныеВыборки.ОбъемУслуги;
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйСписать 		= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйСписать + ДанныеВыборки.ОбъемУслугиПотребленный;
		Иначе
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслуги 							= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслуги + ДанныеВыборки.ОбъемУслуги;
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиОстаток 					= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиОстаток + ДанныеВыборки.ОбъемУслуги;
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйОстаток 		= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйОстаток + ДанныеВыборки.ОбъемУслугиПотребленный;
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленный				= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленный + ДанныеВыборки.ОбъемУслугиПотребленный;
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПоПрибору					= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПоПрибору + ОбъемУслугиПоПрибору;
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйПоПрибору		= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйПоПрибору + ОбъемУслугиПотребленныйПоПрибору;
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиБезПрибора				= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиБезПрибора + ОбъемУслугиБезПрибора;
			НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйБезПрибора	= НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйБезПрибора + ОбъемУслугиПотребленныйБезПрибора;
		КонецЕсли;
		
		НачисленияПоУслугамПомещения[ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].СтрокиРезультатаЗапроса.Добавить(ДанныеСтрокиРезультата);

	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьНачисленияПоУслугамПомещенияРазделенныеЛС(ДанныеВыборки, НачисленияПоУслугамПомещенияРазделенныеЛС)
		
	ДанныеСтрокиРезультата 							= Новый ФиксированнаяСтруктура(ДанныеВыборки);
	
	ЗначениеСоотвествия 							= Новый Структура("
	|КоличествоЧеловек,ОбъемУслуги,ОбъемУслугиПотребленный,ВидПлощади,
	|ОбъемУслугиОстаток,ОбъемУслугиПотребленныйОстаток,ЗначениеСоциальнойНормы,
	|ОбъемУслугиПоПрибору,ОбъемУслугиПотребленныйПоПрибору,ОбъемУслугиБезПрибора,ОбъемУслугиПотребленныйБезПрибора,
	|ПовыщающийКоэффициент,СниматьНачисленныйСредний,УслугаПолностьюОприборена,СпособНачисления,
	|СтрокиРезультатаЗапроса,ОбъемУслугиСписать,ОбъемУслугиПотребленныйСписать,НазначениеПУ,
	|ВидДифференцированности,ЗначениеТарифа, ЗначениеТарифаСверхНорматива");
	
	ОбъемУслугиПоПрибору 									= 0;
	ОбъемУслугиПотребленныйПоПрибору 						= 0;
	ОбъемУслугиБезПрибора 									= 0;
	ОбъемУслугиПотребленныйБезПрибора 						= 0;
	
	Если ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам 
		ИЛИ ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.НачислениеПоСреднему Тогда
		ОбъемУслугиПоПрибору 								= ДанныеВыборки.ОбъемУслуги;
		ОбъемУслугиПотребленныйПоПрибору 					= ДанныеВыборки.ОбъемУслугиПотребленный;
	Иначе
		ОбъемУслугиБезПрибора 								= ДанныеВыборки.ОбъемУслуги;
		ОбъемУслугиПотребленныйБезПрибора 					= ДанныеВыборки.ОбъемУслугиПотребленный;
	КонецЕсли; 
	
	ЗначениеСоотвествия.КоличествоЧеловек 					= ДанныеВыборки.КоличествоЖильцов;
	ЗначениеСоотвествия.ВидПлощади 							= ДанныеВыборки.ВидПлощади;
	ЗначениеСоотвествия.ОбъемУслугиОстаток 					= ДанныеВыборки.ОбъемУслуги;
	ЗначениеСоотвествия.ОбъемУслугиПотребленныйОстаток 		= ДанныеВыборки.ОбъемУслугиПотребленный;
	ЗначениеСоотвествия.ЗначениеСоциальнойНормы 			= ДанныеВыборки.ЗначениеСоциальнойНормы;
	ЗначениеСоотвествия.ПовыщающийКоэффициент 				= ДанныеВыборки.ПовыщающийКоэффициент;
	ЗначениеСоотвествия.СниматьНачисленныйСредний 			= ДанныеВыборки.СниматьНачисленныйСредний;
	ЗначениеСоотвествия.УслугаПолностьюОприборена 			= ДанныеВыборки.УслугаПолностьюОприборена;
	ЗначениеСоотвествия.СпособНачисления 					= ДанныеВыборки.СпособНачисления;
	ЗначениеСоотвествия.НазначениеПУ 						= ДанныеВыборки.НазначениеПУ;
	ЗначениеСоотвествия.ВидДифференцированности 			= ДанныеВыборки.ВидДифференцированности;
	ЗначениеСоотвествия.ЗначениеТарифа 						= ДанныеВыборки.ЗначениеТарифа;
	ЗначениеСоотвествия.ЗначениеТарифаСверхНорматива 		= ДанныеВыборки.ЗначениеТарифаСверхНорматива;

	Если ДанныеВыборки.СниматьНачисленныйСредний И ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам Тогда
		ЗначениеСоотвествия.ОбъемУслуги 						= 0;
		ЗначениеСоотвествия.ОбъемУслугиПотребленный 			= 0;
		ЗначениеСоотвествия.ОбъемУслугиПоПрибору 				= 0;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйПоПрибору 	= 0;
		ЗначениеСоотвествия.ОбъемУслугиБезПрибора 				= 0;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйБезПрибора 	= 0;
		ЗначениеСоотвествия.ОбъемУслугиСписать 					= ДанныеВыборки.ОбъемУслуги;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйСписать 		= ДанныеВыборки.ОбъемУслугиПотребленный;
	Иначе
		ЗначениеСоотвествия.ОбъемУслуги 						= ДанныеВыборки.ОбъемУслуги;
		ЗначениеСоотвествия.ОбъемУслугиПотребленный 			= ДанныеВыборки.ОбъемУслугиПотребленный;
		ЗначениеСоотвествия.ОбъемУслугиПоПрибору 				= ОбъемУслугиПоПрибору;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйПоПрибору 	= ОбъемУслугиПотребленныйПоПрибору;
		ЗначениеСоотвествия.ОбъемУслугиБезПрибора 				= ОбъемУслугиБезПрибора;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйБезПрибора 	= ОбъемУслугиПотребленныйБезПрибора;
		ЗначениеСоотвествия.ОбъемУслугиСписать 					= 0;
		ЗначениеСоотвествия.ОбъемУслугиПотребленныйСписать 		= 0;
	КонецЕсли;
	ЗначениеСоотвествия.СтрокиРезультатаЗапроса				= Новый Массив;
	ЗначениеСоотвествия.СтрокиРезультатаЗапроса.Добавить(ДанныеСтрокиРезультата);
	
	Если НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение] = Неопределено Тогда
		
		СоотвествиеТарифнаяЗона 						= Новый Соответствие;
		СоотвествиеТарифнаяЗона.Вставить(ДанныеВыборки.ТарифнаяЗона, ЗначениеСоотвествия);	
		
		СоотвествиеНачалоПериода 						= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, СоотвествиеТарифнаяЗона);
		
		СоотвествиеУслуга 								= Новый Соответствие;
		СоотвествиеУслуга.Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);
		
		СоотвествиеСоставнаяУслуга 								= Новый Соответствие;
		СоотвествиеСоставнаяУслуга.Вставить(ДанныеВыборки.СоставнаяУслуга, СоотвествиеУслуга);
				
		НачисленияПоУслугамПомещенияРазделенныеЛС.Вставить(ДанныеВыборки.Помещение,СоотвествиеСоставнаяУслуга);
		
	ИначеЕсли НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга] = Неопределено Тогда

		СоотвествиеТарифнаяЗона 						= Новый Соответствие;
		СоотвествиеТарифнаяЗона.Вставить(ДанныеВыборки.ТарифнаяЗона, ЗначениеСоотвествия);
		
		СоотвествиеНачалоПериода 						= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, СоотвествиеТарифнаяЗона);
		
		СоотвествиеУслуга 								= Новый Соответствие;
		СоотвествиеУслуга.Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);
		
		НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение].Вставить(ДанныеВыборки.СоставнаяУслуга,СоотвествиеУслуга);
		
	ИначеЕсли НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга] = Неопределено Тогда
		
		СоотвествиеТарифнаяЗона 						= Новый Соответствие;
		СоотвествиеТарифнаяЗона.Вставить(ДанныеВыборки.ТарифнаяЗона, ЗначениеСоотвествия);
		
		СоотвествиеНачалоПериода 						= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, СоотвествиеТарифнаяЗона);
				
		НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга].Вставить(ДанныеВыборки.Услуга,СоотвествиеНачалоПериода);			
						
	ИначеЕсли НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода] = Неопределено Тогда
		
		СоотвествиеТарифнаяЗона 						= Новый Соответствие;
		СоотвествиеТарифнаяЗона.Вставить(ДанныеВыборки.ТарифнаяЗона, ЗначениеСоотвествия);
		
		НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга].Вставить(ДанныеВыборки.НачалоПериода, СоотвествиеТарифнаяЗона);
		
	ИначеЕсли НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона] = Неопределено Тогда
		
		НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода].Вставить(ДанныеВыборки.ТарифнаяЗона, ЗначениеСоотвествия);

	Иначе		
		НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].КоличествоЧеловек 						= ДанныеВыборки.КоличествоЖильцов;
		НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ЗначениеСоциальнойНормы 				= ДанныеВыборки.ЗначениеСоциальнойНормы;
		НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ВидПлощади 							= ДанныеВыборки.ВидПлощади;
		
		Если ДанныеВыборки.СниматьНачисленныйСредний И ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам Тогда
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиСписать 				= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиСписать + ДанныеВыборки.ОбъемУслуги;
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйСписать 	= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйСписать + ДанныеВыборки.ОбъемУслугиПотребленный;
		Иначе
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслуги 						= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслуги + ДанныеВыборки.ОбъемУслуги;
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиОстаток 				= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиОстаток + ДанныеВыборки.ОбъемУслуги;
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйОстаток 	= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйОстаток + ДанныеВыборки.ОбъемУслугиПотребленный;
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленный			= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленный + ДанныеВыборки.ОбъемУслугиПотребленный;
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПоПрибору				= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПоПрибору + ОбъемУслугиПоПрибору;
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйПоПрибору	= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйПоПрибору + ОбъемУслугиПотребленныйПоПрибору;
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиБезПрибора				= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиБезПрибора + ОбъемУслугиБезПрибора;
			НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйБезПрибора	= НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].ОбъемУслугиПотребленныйБезПрибора + ОбъемУслугиПотребленныйБезПрибора;
		КонецЕсли;
		
		НачисленияПоУслугамПомещенияРазделенныеЛС[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода][ДанныеВыборки.ТарифнаяЗона].СтрокиРезультатаЗапроса.Добавить(ДанныеСтрокиРезультата);

	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьПараметрыРаспределенияОбъемаПомещения(ДанныеВыборки, ПараметрыРаспределенияОбъемаПомещения, ПриоритетыВидовДифференцированности)
	
	Если ДанныеВыборки.Помещение  = ДанныеВыборки.ПомещениеРодитель Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтрокиОбъема 							= Новый ФиксированнаяСтруктура(ДанныеВыборки);
	
	СоответствиеТЗ 		= Новый Соответствие;
	СтруктураОбъемов 	= Новый Структура("ОбъемУслуги, ОбъемУслугиПотребленный, ЗначениеТарифа,ЗначениеТарифаСверхНорматива", 
	ДанныеВыборки.ОбъемУслуги, ДанныеВыборки.ОбъемУслугиПотребленный, ДанныеВыборки.ЗначениеТарифа, ДанныеВыборки.ЗначениеТарифаСверхНорматива);
	СоответствиеТЗ.Вставить(ДанныеВыборки.ТарифнаяЗона,СтруктураОбъемов);
	
	ЗначениеСоотвествия 						= Новый Структура(
	"ДанныеСтроки, ДоляПотребленияЧислитель,ДоляПотребленияЗнаменатель,КоэффициентРаспределенияОстатка,СпособРаспределенияОстатка, КоличествоЖильцов, 
	|ФиксированныйОбъемПотребления, КомнатыРассчитаныПоПриборам, ВидДифференцированности, СоответствиеТЗ",
	ДанныеСтрокиОбъема, ДанныеВыборки.ДоляПотребленияЧислитель, ДанныеВыборки.ДоляПотребленияЗнаменатель, ДанныеВыборки.КоэффициентРаспределенияОстатка
	, ДанныеВыборки.СпособРаспределенияОбъемаПомещения, ДанныеВыборки.КоличествоЖильцов, ДанныеВыборки.ФиксированныйОбъемПотребления, 
	?(ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам, Истина, Ложь), ДанныеВыборки.ВидДифференцированности, СоответствиеТЗ);
	
	Если ПараметрыРаспределенияОбъемаПомещения[ДанныеВыборки.Помещение] = Неопределено Тогда
	
		СоотвествиеНачалоПериода 				= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, ЗначениеСоотвествия);
				
		СоотвествиеУслуга 						= Новый Соответствие;
		СоотвествиеУслуга.Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);		
		
		СоотвествиеСоставнаяУслуга 						= Новый Соответствие;
		СоотвествиеСоставнаяУслуга.Вставить(ДанныеВыборки.СоставнаяУслуга, СоотвествиеУслуга);
		
		ПараметрыРаспределенияОбъемаПомещения.Вставить(ДанныеВыборки.Помещение, СоотвествиеСоставнаяУслуга);
		
	ИначеЕсли ПараметрыРаспределенияОбъемаПомещения[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга] = Неопределено Тогда
				
		СоотвествиеНачалоПериода 				= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, ЗначениеСоотвествия);
		
		СоотвествиеУслуга 						= Новый Соответствие;
		СоотвествиеУслуга.Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);
		
		ПараметрыРаспределенияОбъемаПомещения[ДанныеВыборки.Помещение].Вставить(ДанныеВыборки.СоставнаяУслуга, СоотвествиеУслуга);

	ИначеЕсли ПараметрыРаспределенияОбъемаПомещения[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга] = Неопределено Тогда
				
		СоотвествиеНачалоПериода 				= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, ЗначениеСоотвествия);
				
		ПараметрыРаспределенияОбъемаПомещения[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга].Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);
		
		
	ИначеЕсли ПараметрыРаспределенияОбъемаПомещения[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода] = Неопределено Тогда
		
		ПараметрыРаспределенияОбъемаПомещения[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга].Вставить(ДанныеВыборки.НачалоПериода, ЗначениеСоотвествия);
		
	Иначе
		
		ЗначениеСоотвествия = ПараметрыРаспределенияОбъемаПомещения[ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода];
		
		Если ЗначениеСоотвествия.КомнатыРассчитаныПоПриборам И ДанныеВыборки.СпособНачисления <> Перечисления.энргСпособНачислений.ПоПриборам Тогда
			ЗначениеСоотвествия.КомнатыРассчитаныПоПриборам = Ложь;
		КонецЕсли;
		
		ЗначениеСоотвествия.КоличествоЖильцов = ДанныеВыборки.КоличествоЖильцов;
		
		Если ПриоритетыВидовДифференцированности[ДанныеВыборки.ВидДифференцированности] <> Неопределено 
			И ПриоритетыВидовДифференцированности[ЗначениеСоотвествия.ВидДифференцированности] <> Неопределено 
			И ПриоритетыВидовДифференцированности[ДанныеВыборки.ВидДифференцированности] < ПриоритетыВидовДифференцированности[ЗначениеСоотвествия.ВидДифференцированности] Тогда
			
			ЗначениеСоотвествия.ВидДифференцированности = ДанныеВыборки.ВидДифференцированности;
		КонецЕсли;
		
		Если ЗначениеСоотвествия.СоответствиеТЗ[ДанныеВыборки.ТарифнаяЗона] = Неопределено Тогда
			ЗначениеСоотвествия.СоответствиеТЗ.Вставить(ДанныеВыборки.ТарифнаяЗона,СтруктураОбъемов);
		Иначе
			СтруктураОбъемов 							= ЗначениеСоотвествия.СоответствиеТЗ[ДанныеВыборки.ТарифнаяЗона];
			СтруктураОбъемов.ОбъемУслуги 				= СтруктураОбъемов.ОбъемУслуги + ДанныеВыборки.ОбъемУслуги;
			СтруктураОбъемов.ОбъемУслугиПотребленный 	= СтруктураОбъемов.ОбъемУслугиПотребленный + ДанныеВыборки.ОбъемУслугиПотребленный;
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьРазделенныеЛицевыеСчетаПомещения(ДанныеВыборки, РазделенныеЛицевыеСчета)
	
	Если ДанныеВыборки.Помещение  = ДанныеВыборки.ПомещениеРодитель Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтрокиОбъема 							= Новый ФиксированнаяСтруктура(ДанныеВыборки);
	
	СоответствиеТЗ 		= Новый Соответствие;
	СтруктураОбъемов 	= Новый Структура("ОбъемУслуги, ОбъемУслугиПотребленный, ЗначениеТарифа,ЗначениеТарифаСверхНорматива", 
	ДанныеВыборки.ОбъемУслуги, ДанныеВыборки.ОбъемУслугиПотребленный, ДанныеВыборки.ЗначениеТарифа, ДанныеВыборки.ЗначениеТарифаСверхНорматива);
	СоответствиеТЗ.Вставить(ДанныеВыборки.ТарифнаяЗона,СтруктураОбъемов);
	
	ЗначениеСоотвествия 						= Новый Структура(
	"ДанныеСтроки, ДоляПотребленияЧислитель,ДоляПотребленияЗнаменатель,КоэффициентРаспределенияОстатка,СпособРаспределенияОстатка, КоличествоЖильцов, 
	|ФиксированныйОбъемПотребления, КомнатыРассчитаныПоПриборам, ВидДифференцированности, СоответствиеТЗ",
	ДанныеСтрокиОбъема, ДанныеВыборки.ДоляПотребленияЧислитель, ДанныеВыборки.ДоляПотребленияЗнаменатель, ДанныеВыборки.КоэффициентРаспределенияОстатка
	, ДанныеВыборки.СпособРаспределенияОбъемаПомещения, ДанныеВыборки.КоличествоЖильцов, ДанныеВыборки.ФиксированныйОбъемПотребления, 
	?(ДанныеВыборки.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам, Истина, Ложь), ДанныеВыборки.ВидДифференцированности, СоответствиеТЗ);
	
	
	Если РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель] = Неопределено Тогда													
			
		СоотвествиеНачалоПериода 				= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, ЗначениеСоотвествия);
				
		СоотвествиеУслуга 						= Новый Соответствие;
		СоотвествиеУслуга.Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);		
		
		СоотвествиеСоставнаяУслуга 						= Новый Соответствие;
		СоотвествиеСоставнаяУслуга.Вставить(ДанныеВыборки.СоставнаяУслуга, СоотвествиеУслуга);
		
		СоотвествиеПомещение 						= Новый Соответствие;
		СоотвествиеПомещение.Вставить(ДанныеВыборки.Помещение,СоотвествиеСоставнаяУслуга);
		
		РазделенныеЛицевыеСчета.Вставить(ДанныеВыборки.ПомещениеРодитель, СоотвествиеПомещение);

	ИначеЕсли РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель][ДанныеВыборки.Помещение] = Неопределено Тогда
	
		СоотвествиеНачалоПериода 				= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, ЗначениеСоотвествия);
				
		СоотвествиеУслуга 						= Новый Соответствие;
		СоотвествиеУслуга.Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);		
		
		СоотвествиеСоставнаяУслуга 						= Новый Соответствие;
		СоотвествиеСоставнаяУслуга.Вставить(ДанныеВыборки.СоставнаяУслуга, СоотвествиеУслуга);
		
		РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель].Вставить(ДанныеВыборки.Помещение, СоотвествиеСоставнаяУслуга);
		
	ИначеЕсли РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель][ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга] = Неопределено Тогда
				
		СоотвествиеНачалоПериода 				= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, ЗначениеСоотвествия);
		
		СоотвествиеУслуга 						= Новый Соответствие;
		СоотвествиеУслуга.Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);
		
		РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель][ДанныеВыборки.Помещение].Вставить(ДанныеВыборки.СоставнаяУслуга, СоотвествиеУслуга);

	ИначеЕсли РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель][ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга] = Неопределено Тогда
				
		СоотвествиеНачалоПериода 				= Новый Соответствие;
		СоотвествиеНачалоПериода.Вставить(ДанныеВыборки.НачалоПериода, ЗначениеСоотвествия);
				
		РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель][ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга].Вставить(ДанныеВыборки.Услуга, СоотвествиеНачалоПериода);
		
		
	ИначеЕсли РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель][ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода] = Неопределено Тогда
		
		РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель][ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга].Вставить(ДанныеВыборки.НачалоПериода, ЗначениеСоотвествия);
		
	Иначе
		
		ЗначениеСоотвествия = РазделенныеЛицевыеСчета[ДанныеВыборки.ПомещениеРодитель][ДанныеВыборки.Помещение][ДанныеВыборки.СоставнаяУслуга][ДанныеВыборки.Услуга][ДанныеВыборки.НачалоПериода];
		
		ЗначениеСоотвествия.КоличествоЖильцов = ДанныеВыборки.КоличествоЖильцов;
		
		Если ЗначениеСоотвествия.КомнатыРассчитаныПоПриборам И ДанныеВыборки.СпособНачисления <> Перечисления.энргСпособНачислений.ПоПриборам Тогда
			ЗначениеСоотвествия.КомнатыРассчитаныПоПриборам = Ложь;
		КонецЕсли;
		
		//Если ПриоритетыВидовДифференцированности[ДанныеВыборки.ВидДифференцированности] <> Неопределено 
		//	И ПриоритетыВидовДифференцированности[ЗначениеСоотвествия.ВидДифференцированности] <> Неопределено 
		//	И ПриоритетыВидовДифференцированности[ДанныеВыборки.ВидДифференцированности] < ПриоритетыВидовДифференцированности[ЗначениеСоотвествия.ВидДифференцированности] Тогда
		//	
		//	ЗначениеСоотвествия.ВидДифференцированности = ДанныеВыборки.ВидДифференцированности;
		//КонецЕсли;
		
		Если ЗначениеСоотвествия.СоответствиеТЗ[ДанныеВыборки.ТарифнаяЗона] = Неопределено Тогда
			ЗначениеСоотвествия.СоответствиеТЗ.Вставить(ДанныеВыборки.ТарифнаяЗона,СтруктураОбъемов);
		Иначе
			СтруктураОбъемов 							= ЗначениеСоотвествия.СоответствиеТЗ[ДанныеВыборки.ТарифнаяЗона];
			СтруктураОбъемов.ОбъемУслуги 				= СтруктураОбъемов.ОбъемУслуги + ДанныеВыборки.ОбъемУслуги;
			СтруктураОбъемов.ОбъемУслугиПотребленный 	= СтруктураОбъемов.ОбъемУслугиПотребленный + ДанныеВыборки.ОбъемУслугиПотребленный;
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

Процедура ИзменитьОстатокОбъемаКРаспределениюВПомещении(ДанныеВыборки, НачисленияПоУслугамПомещения) 
	
	Если ДанныеВыборки.Помещение = ДанныеВыборки.ПомещениеРодитель Тогда
		Возврат;
	КонецЕсли;
	
	Если НачисленияПоУслугамПомещения[ДанныеВыборки.Услуга] = Неопределено
		ИЛИ НачисленияПоУслугамПомещения[ДанныеВыборки.Услуга][ДанныеВыборки.ТарифнаяЗона] = Неопределено
		ИЛИ НачисленияПоУслугамПомещения[ДанныеВыборки.Услуга][ДанныеВыборки.ТарифнаяЗона][ДанныеВыборки.НачалоПериода] = Неопределено
		ИЛИ НачисленияПоУслугамПомещения[ДанныеВыборки.Услуга][ДанныеВыборки.ТарифнаяЗона][ДанныеВыборки.НачалоПериода][ДанныеВыборки.СоставнаяУслуга] = Неопределено Тогда
		Возврат;
	КонецЕсли;

	НачисленияПоУслугамПомещения[ДанныеВыборки.Услуга][ДанныеВыборки.ТарифнаяЗона][ДанныеВыборки.НачалоПериода][ДанныеВыборки.СоставнаяУслуга].ОбъемУслугиОстаток = НачисленияПоУслугамПомещения[ДанныеВыборки.Услуга][ДанныеВыборки.ТарифнаяЗона][ДанныеВыборки.НачалоПериода][ДанныеВыборки.СоставнаяУслуга].ОбъемУслугиОстаток - ДанныеВыборки.ОбъемУслуги;
	НачисленияПоУслугамПомещения[ДанныеВыборки.Услуга][ДанныеВыборки.ТарифнаяЗона][ДанныеВыборки.НачалоПериода][ДанныеВыборки.СоставнаяУслуга].ОбъемУслугиПотребленныйОстаток = НачисленияПоУслугамПомещения[ДанныеВыборки.Услуга][ДанныеВыборки.ТарифнаяЗона][ДанныеВыборки.НачалоПериода][ДанныеВыборки.СоставнаяУслуга].ОбъемУслугиПотребленныйОстаток - ДанныеВыборки.ОбъемУслугиПотребленный;
		
КонецПроцедуры

Процедура РаспредеделитьОбъемПомещенияПоУслугеНаПотомков(Набор, ДанныеДляРаспределения, ПараметрыРаспределенияОбъемаПомещения, ПомещенияСОстаткомРаспределения, ПлощадиПомещенийПоУслугам, ПараметрыВсехПомещенийСРазделеннымиЛС, ДанныеДляРаспределенияВсехПомещенийСРазделеннымиЛС, ЗаписиСтороннихПоставщиков, ЭтоОбъемПотребленный, ТекИндексСтрокиНабора)

	РазрядностьДробнойЧасти 														= Метаданные.РегистрыНакопления.энргОбъемНачислений.Ресурсы.ОбъемУслуги.Тип.КвалификаторыЧисла.РазрядностьДробнойЧасти;
	
	СоставнаяУслуга = ДанныеДляРаспределения.СоставнаяУслуга;
	Услуга 			= ДанныеДляРаспределения.Услуга;
	ТарифнаяЗона 	= ДанныеДляРаспределения.ТарифнаяЗона;
	НачалоПериода 	= ДанныеДляРаспределения.НачалоПериода;
	
	Если ЭтоОбъемПотребленный Тогда
		ОбъемСписать 	= ДанныеДляРаспределения.ОбъемУслугиПотребленныйСписать;
		Объем  			= ДанныеДляРаспределения.ОбъемУслугиПотребленный;
		ОбъемОстаток  	= ДанныеДляРаспределения.ОбъемУслугиПотребленныйОстаток;
	Иначе
		ОбъемСписать 	= ДанныеДляРаспределения.ОбъемУслугиСписать;
		Объем  			= ДанныеДляРаспределения.ОбъемУслуги;
		ОбъемОстаток  	= ДанныеДляРаспределения.ОбъемУслугиОстаток;
	КонецЕсли;
	
	Для Каждого КлючЗначениеПомещение Из ПараметрыРаспределенияОбъемаПомещения Цикл
		
		Если КлючЗначениеПомещение.Значение[СоставнаяУслуга] = Неопределено
			ИЛИ КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга] = Неопределено
			ИЛИ КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга][НачалоПериода] = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыРаспределения 														= КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга][НачалоПериода];
		ПлощадиПомещений	 														= ПлощадиПомещенийПоУслугам[Услуга][НачалоПериода];
				
		Если НЕ ОбъемСписать = 0 Тогда
			Если НЕ ПараметрыРаспределения.СпособРаспределенияОстатка = Перечисления.энргСпособыРаспределенияОбъема.Остаток Тогда
				Если ПараметрыРаспределения.СпособРаспределенияОстатка = Перечисления.энргСпособыРаспределенияОбъема.ФиксированныйОбъем Тогда
					ОбъемУслугиПотомкаСписать = ПараметрыРаспределения.ФиксированныйОбъемПотребления;
				ИначеЕсли НЕ ПараметрыРаспределения.ДоляПотребленияЧислитель = 0 И НЕ ПараметрыРаспределения.ДоляПотребленияЗнаменатель = 0 Тогда
					ОбъемУслугиПотомкаСписать 												= Окр(ОбъемСписать * ПараметрыРаспределения.ДоляПотребленияЧислитель / ПараметрыРаспределения.ДоляПотребленияЗнаменатель, РазрядностьДробнойЧасти);					
				ИначеЕсли ЗначениеЗаполнено(ДанныеДляРаспределения.ВидПлощади) Тогда
					ОбъемУслугиПотомкаСписать 												= Окр(ОбъемСписать * ПараметрыРаспределения.ДанныеСтроки.ЗначениеПлощади / ПлощадиПомещений.Площадь, РазрядностьДробнойЧасти);
				Иначе
					КоличествоЧеловек 														= ?(ПараметрыРаспределения.КоличествоЖильцов = 0, энргРаботаСПараметрамиРасчетаАбонентаСервер.КоличествоЧеловек(ПараметрыРаспределения.ДанныеСтроки), ПараметрыРаспределения.КоличествоЖильцов);
					ОбъемУслугиПотомкаСписать 												= Окр(ОбъемСписать * КоличествоЧеловек / ДанныеДляРаспределения.КоличествоЧеловек, РазрядностьДробнойЧасти);
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ПараметрыРаспределения.ДанныеСтроки.Абонент) Тогда
					ЗаполнитьСтрокуНабораНачисленияПотомка(Набор, ДанныеДляРаспределения, ПараметрыРаспределения,  ?(ЭтоОбъемПотребленный, -1, ОбъемУслугиПотомкаСписать), ?(ЭтоОбъемПотребленный, ОбъемУслугиПотомкаСписать, -1), ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора, Истина);
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
		
		
		Если НЕ ПараметрыРаспределения.СпособРаспределенияОстатка = Перечисления.энргСпособыРаспределенияОбъема.Остаток Тогда
			Если ПараметрыРаспределения.СпособРаспределенияОстатка = Перечисления.энргСпособыРаспределенияОбъема.ФиксированныйОбъем Тогда
				ОбъемУслугиПотомка = ПараметрыРаспределения.ФиксированныйОбъемПотребления;
			ИначеЕсли НЕ ПараметрыРаспределения.ДоляПотребленияЧислитель = 0 И НЕ ПараметрыРаспределения.ДоляПотребленияЗнаменатель = 0 Тогда
				ОбъемУслугиПотомка 												= Окр(Объем * ПараметрыРаспределения.ДоляПотребленияЧислитель / ПараметрыРаспределения.ДоляПотребленияЗнаменатель, РазрядностьДробнойЧасти);					
			ИначеЕсли ЗначениеЗаполнено(ДанныеДляРаспределения.ВидПлощади) Тогда
				ОбъемУслугиПотомка 												= Окр(Объем * ПараметрыРаспределения.ДанныеСтроки.ЗначениеПлощади / ПлощадиПомещений.Площадь, РазрядностьДробнойЧасти);
			Иначе
				КоличествоЧеловек 												= ?(ПараметрыРаспределения.КоличествоЖильцов = 0, энргРаботаСПараметрамиРасчетаАбонентаСервер.КоличествоЧеловек(ПараметрыРаспределения.ДанныеСтроки), ПараметрыРаспределения.КоличествоЖильцов);
				ОбъемУслугиПотомка 												= Окр(Объем * КоличествоЧеловек / ДанныеДляРаспределения.КоличествоЧеловек, РазрядностьДробнойЧасти);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ПараметрыРаспределения.ДанныеСтроки.Абонент) Тогда
				Если НЕ Объем = 0 Тогда
					ЗаполнитьСтрокуНабораНачисленияПотомка(Набор, ДанныеДляРаспределения, ПараметрыРаспределения, ?(ЭтоОбъемПотребленный, -1, ОбъемУслугиПотомка), ?(ЭтоОбъемПотребленный, ОбъемУслугиПотомка, -1), ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора);
				КонецЕсли;
			Иначе
				Если Не ПараметрыВсехПомещенийСРазделеннымиЛС[КлючЗначениеПомещение.Ключ] = Неопределено Тогда 
					ПараметрыРаспределенияОбъемаПомещенияПотомков = ПараметрыВсехПомещенийСРазделеннымиЛС[КлючЗначениеПомещение.Ключ];
					Если Не ДанныеДляРаспределенияВсехПомещенийСРазделеннымиЛС[КлючЗначениеПомещение.Ключ][СоставнаяУслуга][Услуга][НачалоПериода] = Неопределено Тогда
						
						ДанныеДляРаспределенияПотомков = ДанныеДляРаспределенияВсехПомещенийСРазделеннымиЛС[КлючЗначениеПомещение.Ключ][СоставнаяУслуга][Услуга][НачалоПериода][ТарифнаяЗона];
						
						ДанныеДляРаспределенияПотомков.Вставить("СоставнаяУслуга",								СоставнаяУслуга);
						ДанныеДляРаспределенияПотомков.Вставить("Услуга",										Услуга);
						ДанныеДляРаспределенияПотомков.Вставить("ТарифнаяЗона",									ТарифнаяЗона);
						ДанныеДляРаспределенияПотомков.Вставить("НачалоПериода",								НачалоПериода);
						ДанныеДляРаспределенияПотомков.Вставить("ПлощадиПомещенийПоУслугам",					ПлощадиПомещенийПоУслугам);
						ДанныеДляРаспределенияПотомков.Вставить("РаспределилиОбъемУслугиОстаток",				ДанныеДляРаспределенияПотомков.ОбъемУслугиОстаток);
						ДанныеДляРаспределенияПотомков.Вставить("РаспределилиОбъемУслугиПотребленныйОстаток",	ДанныеДляРаспределенияПотомков.ОбъемУслугиПотребленныйОстаток);
						Если ЭтоОбъемПотребленный Тогда
							ДанныеДляРаспределенияПотомков.ОбъемУслугиПотребленный = ДанныеДляРаспределенияПотомков.ОбъемУслугиПотребленный + ОбъемУслугиПотомка;
						Иначе
							ДанныеДляРаспределенияПотомков.ОбъемУслуги = ДанныеДляРаспределенияПотомков.ОбъемУслуги + ОбъемУслугиПотомка;
						КонецЕсли;
						
						РаспредеделитьОбъемПомещенияПоУслугеНаПотомков(Набор, ДанныеДляРаспределенияПотомков, ПараметрыРаспределенияОбъемаПомещенияПотомков, ПомещенияСОстаткомРаспределения, ПлощадиПомещенийПоУслугам, ПараметрыВсехПомещенийСРазделеннымиЛС, ДанныеДляРаспределенияВсехПомещенийСРазделеннымиЛС, ЗаписиСтороннихПоставщиков, ЭтоОбъемПотребленный, ТекИндексСтрокиНабора);
					КонецЕсли;
				Иначе
					Продолжить;
				КонецЕсли;
			КонецЕсли;
		Иначе
			Продолжить;
		КонецЕсли; 
		
					
		
		
		
		Если НЕ ПараметрыРаспределения.СпособРаспределенияОстатка = Перечисления.энргСпособыРаспределенияОбъема.Остаток Тогда
			ОбъемУслугиПотомка 													= ОбъемОстаток * ПараметрыРаспределения.КоэффициентРаспределенияОстатка;
			Если ОбъемУслугиПотомка > 0 Тогда
				ДанныеДляРаспределения.РаспределилиОбъемУслугиОстаток 				= ДанныеДляРаспределения.РаспределилиОбъемУслугиОстаток - ОбъемУслугиПотомка;				
				Если ЗначениеЗаполнено(ПараметрыРаспределения.ДанныеСтроки.Абонент) Тогда
					Если НЕ ОбъемОстаток = 0 Тогда
						ЗаполнитьСтрокуНабораНачисленияПотомка(Набор, ДанныеДляРаспределения, ПараметрыРаспределения, ?(ЭтоОбъемПотребленный, -1, ОбъемУслугиПотомка), ?(ЭтоОбъемПотребленный, ОбъемУслугиПотомка, -1), ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора);
					КонецЕсли;	
				Иначе
					Если Не ПараметрыВсехПомещенийСРазделеннымиЛС[КлючЗначениеПомещение.Ключ] = Неопределено Тогда 
						ПараметрыРаспределенияОбъемаПомещенияПотомков = ПараметрыВсехПомещенийСРазделеннымиЛС[КлючЗначениеПомещение.Ключ];
						Если Не ДанныеДляРаспределенияВсехПомещенийСРазделеннымиЛС[КлючЗначениеПомещение.Ключ][СоставнаяУслуга][Услуга][НачалоПериода] = Неопределено Тогда
							ДанныеДляРаспределенияПотомков = ДанныеДляРаспределенияВсехПомещенийСРазделеннымиЛС[КлючЗначениеПомещение.Ключ][СоставнаяУслуга][Услуга][НачалоПериода];
							
							ДанныеДляРаспределенияПотомков.Вставить("СоставнаяУслуга",								СоставнаяУслуга);
							ДанныеДляРаспределенияПотомков.Вставить("Услуга",										Услуга);
							ДанныеДляРаспределенияПотомков.Вставить("ТарифнаяЗона",									ТарифнаяЗона);
							ДанныеДляРаспределенияПотомков.Вставить("НачалоПериода",								НачалоПериода);
							ДанныеДляРаспределенияПотомков.Вставить("ПлощадиПомещенийПоУслугам",					ПлощадиПомещенийПоУслугам);
							ДанныеДляРаспределенияПотомков.Вставить("РаспределилиОбъемУслугиОстаток",				ДанныеДляРаспределенияПотомков.ОбъемУслугиОстаток);
							ДанныеДляРаспределенияПотомков.Вставить("РаспределилиОбъемУслугиПотребленныйОстаток",	ДанныеДляРаспределенияПотомков.ОбъемУслугиПотребленныйОстаток);
							
							Если ЭтоОбъемПотребленный Тогда
								ДанныеДляРаспределенияПотомков.ОбъемУслугиПотребленный = ОбъемУслугиПотомка;
							Иначе
								ДанныеДляРаспределенияПотомков.ОбъемУслуги = ОбъемУслугиПотомка;
							КонецЕсли;
							
							РаспредеделитьОбъемПомещенияПоУслугеНаПотомков(Набор, ДанныеДляРаспределенияПотомков, ПараметрыРаспределенияОбъемаПомещенияПотомков, ПомещенияСОстаткомРаспределения, ПлощадиПомещенийПоУслугам, ПараметрыВсехПомещенийСРазделеннымиЛС, ДанныеДляРаспределенияВсехПомещенийСРазделеннымиЛС, ЗаписиСтороннихПоставщиков, ЭтоОбъемПотребленный, ТекИндексСтрокиНабора);
						Иначе
							Прервать;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли; 
			
					                              
				
				
		Если ПараметрыРаспределения.СпособРаспределенияОстатка = Перечисления.энргСпособыРаспределенияОбъема.Остаток Тогда
			ПомещенияСОстаткомРаспределения.Добавить(КлючЗначениеПомещение.Ключ);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Процедура РаспределитьОстатокНаПомещенияСоСпособомРаспределенияОстаток(Набор, ДанныеДляРаспределения,ПомещенияСОстаткомРаспределения, ПараметрыРаспределенияОбъемаПомещения, ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора)
	
	Услуга 			= ДанныеДляРаспределения.Услуга;
	ТарифнаяЗона 	= ДанныеДляРаспределения.ТарифнаяЗона;
	НачалоПериода 	= ДанныеДляРаспределения.НачалоПериода;
	
	Для Индекс  = 0 По ПомещенияСОстаткомРаспределения.ВГраница() Цикл
		ПараметрыРаспределения 								= ПараметрыРаспределенияОбъемаПомещения[ПомещенияСОстаткомРаспределения[Индекс]][Услуга][ТарифнаяЗона][НачалоПериода];
		Если Индекс = ПомещенияСОстаткомРаспределения.ВГраница() Тогда
			ОбъемУслугиПотомка 												= ДанныеДляРаспределения.РаспределилиОбъемУслугиОстаток;
			ОбъемУслугиПотребленныйПотомка 									= ДанныеДляРаспределения.РаспределилиОбъемУслугиПотребленныйОстаток;
		Иначе
			ОбъемУслугиПотомка 												= ДанныеДляРаспределения.ОбъемУслугиОстаток * ПараметрыРаспределения.КоэффициентРаспределенияОстатка;
			ОбъемУслугиПотребленныйПотомка 									= ДанныеДляРаспределения.ОбъемУслугиПотребленныйОстаток * ПараметрыРаспределения.КоэффициентРаспределенияОстатка;
		КонецЕсли;
		
		ЗаполнитьСтрокуНабораНачисленияПотомка(Набор, ДанныеДляРаспределения, ПараметрыРаспределения, ОбъемУслугиПотомка, ОбъемУслугиПотребленныйПотомка, ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора);
		
		ДанныеДляРаспределения.РаспределилиОбъемУслугиОстаток 				= ДанныеДляРаспределения.РаспределилиОбъемУслугиОстаток - ОбъемУслугиПотомка;
		ДанныеДляРаспределения.РаспределилиОбъемУслугиПотребленныйОстаток 	= ДанныеДляРаспределения.РаспределилиОбъемУслугиПотребленныйОстаток - ОбъемУслугиПотребленныйПотомка; 							
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСтрокуНабораНачисленияПотомка(Набор, ДанныеДляРаспределения, ПараметрыРаспределения, ОбъемУслуги, ОбъемУслугиПотребленный, ЗаписиСтороннихПоставщиков, ТекИндексСтрокиНабора, СписатьОбъем = Ложь)
	
	СтрокиРезультатаЗапросаРодитель				= ДанныеДляРаспределения.СтрокиРезультатаЗапроса;
	ДанныеСтрокиРезультатаЗапросаПомещения		= ПараметрыРаспределения.ДанныеСтроки;
	СтрокаРезультатаЗапросаПомещения 			= СтрокиРезультатаЗапросаРодитель[0];
	
	Если СписатьОбъем и СтрокаРезультатаЗапросаПомещения.СпособНачисления <> Перечисления.энргСпособНачислений.ПоПриборам Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбъемУслуги >= 0 Тогда
		СтрокаНабора = ДобавитьСтрокуНабораНачисленияПотомка(Набор, СтрокаРезультатаЗапросаПомещения, ДанныеСтрокиРезультатаЗапросаПомещения, ПараметрыРаспределения, ЗаписиСтороннихПоставщиков, СписатьОбъем, ДанныеДляРаспределения, ТекИндексСтрокиНабора);
		СтрокаНабора.ОбъемУслуги 				= ОбъемУслуги;
		СтрокаНабора.ОбъемУслугиПотребленный 	= 0;
	КонецЕсли;
	
	Если ОбъемУслугиПотребленный >= 0 Тогда
		СтрокаНабора = ДобавитьСтрокуНабораНачисленияПотомка(Набор, СтрокаРезультатаЗапросаПомещения, ДанныеСтрокиРезультатаЗапросаПомещения, ПараметрыРаспределения, ЗаписиСтороннихПоставщиков, СписатьОбъем, ДанныеДляРаспределения, ТекИндексСтрокиНабора);
		СтрокаНабора.ОбъемУслуги 				= 0;
		СтрокаНабора.ОбъемУслугиПотребленный 	= ОбъемУслугиПотребленный;
	КонецЕсли;
	
КонецПроцедуры

Функция ДобавитьСтрокуНабораНачисленияПотомка(Набор, СтрокаРезультатаЗапросаПомещения, ДанныеСтрокиРезультатаЗапросаПомещения, ПараметрыРаспределения, ЗаписиСтороннихПоставщиков, СписатьОбъем, ДанныеДляРаспределения, ТекИндексСтрокиНабора)
	СтрокаНабора 							= Набор.Добавить();	
	ТекИндексСтрокиНабора					= ТекИндексСтрокиНабора + 1;
	ЗаполнитьЗначенияСвойств(СтрокаНабора,ДанныеСтрокиРезультатаЗапросаПомещения);		
	СтрокаНабора.Период						= ДанныеСтрокиРезультатаЗапросаПомещения.ЗавершениеОП-1;
	СтрокаНабора.ВидНачисления 				= Перечисления.энргВидыНачислений.Начисление;
	СтрокаНабора.ПериодРасчета 				= ДанныеСтрокиРезультатаЗапросаПомещения.ПериодНачисления;
	ЗаполнитьЗначенияСвойств(СтрокаНабора, СтрокаРезультатаЗапросаПомещения, "СниматьНачисленныйСредний, УслугаПолностьюОприборена, СпособНачисления, ПриборУчета, ТочкаУчета");
	Если Не ДанныеСтрокиРезультатаЗапросаПомещения.ПрименятьТарифВРазрезеКомнат = Неопределено И ДанныеСтрокиРезультатаЗапросаПомещения.ПрименятьТарифВРазрезеКомнат Тогда
		ЗаполнитьЗначенияСвойств(СтрокаНабора, ДанныеДляРаспределения, "ТарифнаяЗона, ЗначениеТарифаСверхНорматива");
	Иначе
		ЗаполнитьЗначенияСвойств(СтрокаНабора, ДанныеДляРаспределения, "ТарифнаяЗона, ЗначениеТарифа, ЗначениеТарифаСверхНорматива");
	КонецЕсли;
	
	Если СтрокаРезультатаЗапросаПомещения.ПриборВведен Тогда
		СтрокаНабора.ПовыщающийКоэффициент = 1;		
	КонецЕсли;
	
	Если ПараметрыРаспределения.СпособРаспределенияОстатка = Перечисления.энргСпособыРаспределенияОбъема.ФиксированныйОбъем Тогда
		СтрокаНабора.СпособНачисления  = Перечисления.энргСпособНачислений.ФиксированныйОбъем;
	КонецЕсли;
		
	Если ДанныеСтрокиРезультатаЗапросаПомещения.УдалитьЗапись Тогда
		ЗаписиСтороннихПоставщиков.Вставить(0, ТекИндексСтрокиНабора);
		СтрокаНабора.ПоставщикиНеНачислять = ДанныеСтрокиРезультатаЗапросаПомещения.УдалитьЗапись;
	КонецЕсли;
	
	Возврат СтрокаНабора;
КонецФункции

Процедура РассчитатьДельтуРаспределения(НачисленияПоУслугамПомещения, ПараметрыРаспределенияОбъемаПомещения)
	Для Каждого КлючЗначениеСоставнаяУслуга Из НачисленияПоУслугамПомещения Цикл
		Для Каждого КлючЗначениеУслуга Из КлючЗначениеСоставнаяУслуга.Значение Цикл			
			Для Каждого КлючЗначениеНачалоПериода Из КлючЗначениеУслуга.Значение Цикл
				Для Каждого КлючЗначениеТарифнаяЗона Из КлючЗначениеНачалоПериода.Значение Цикл
					ЗначениеСтруктуры 								= КлючЗначениеТарифнаяЗона.Значение;
					СоставнаяУслуга									= КлючЗначениеСоставнаяУслуга.Ключ;
					Услуга											= КлючЗначениеУслуга.Ключ;
					ТарифнаяЗона									= КлючЗначениеТарифнаяЗона.Ключ;
					НачалоПериода									= КлючЗначениеНачалоПериода.Ключ;
					Если ЗначениеСтруктуры.СпособНачисления = Перечисления.энргСпособНачислений.ПоПриборам Тогда
						Для Каждого КлючЗначениеПомещение Из ПараметрыРаспределенияОбъемаПомещения Цикл
							Если КлючЗначениеПомещение.Значение[СоставнаяУслуга] = Неопределено
								ИЛИ КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга] = Неопределено
								ИЛИ КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга][НачалоПериода] = Неопределено Тогда
								Продолжить;
							КонецЕсли;
							
							ПараметрыРаспределения 					= КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга][НачалоПериода];
							
							Если ПараметрыРаспределения.КомнатыРассчитаныПоПриборам И ЗначениеСтруктуры.НазначениеПУ = Перечисления.энргНазначениеПУ.ОПУ Тогда
								СоответствиеТЗ = КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга][НачалоПериода].СоответствиеТЗ;
								Если СоответствиеТЗ[ТарифнаяЗона] <> Неопределено Тогда
									ЗначениеСтруктуры.ОбъемУслуги 				= ЗначениеСтруктуры.ОбъемУслуги - ?(СоответствиеТЗ[ТарифнаяЗона].ОбъемУслуги > ЗначениеСтруктуры.ОбъемУслуги, ЗначениеСтруктуры.ОбъемУслуги, СоответствиеТЗ[ТарифнаяЗона].ОбъемУслуги); 
									ЗначениеСтруктуры.ОбъемУслугиПотребленный 	= ЗначениеСтруктуры.ОбъемУслугиПотребленный - ?(СоответствиеТЗ[ТарифнаяЗона].ОбъемУслугиПотребленный > ЗначениеСтруктуры.ОбъемУслугиПотребленный, ЗначениеСтруктуры.ОбъемУслугиПотребленный, СоответствиеТЗ[ТарифнаяЗона].ОбъемУслугиПотребленный);
								КонецЕсли;
							КонецЕсли;
						КонецЦикла;	
					КонецЕсли;
				КонецЦикла;					
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

Процедура ПереопределитьТарифныеЗоныПоПриоритетуДифференцированности(НачисленияПоУслугамПомещения, ПараметрыРаспределенияОбъемаПомещения, ПриоритетыВидовДифференцированности, СоставляющиеТарифныхЗон)
	Для Каждого КлючЗначениеСоставнаяУслуга Из НачисленияПоУслугамПомещения Цикл	
		Для Каждого КлючЗначениеУслуга Из КлючЗначениеСоставнаяУслуга.Значение Цикл			
			Для Каждого КлючЗначениеНачалоПериода Из КлючЗначениеУслуга.Значение Цикл
				
				СоставнаяУслуга									= КлючЗначениеСоставнаяУслуга.Ключ;
				Услуга											= КлючЗначениеУслуга.Ключ;
				НачалоПериода									= КлючЗначениеНачалоПериода.Ключ;
				ВидДифференцированностиПриоритет 				= Неопределено;
				СпособНачисления                                = Неопределено;
				
				Для Каждого КлючЗначениеТарифнаяЗона Из КлючЗначениеНачалоПериода.Значение Цикл
					
					ЗначениеСтруктуры 								= КлючЗначениеТарифнаяЗона.Значение;	
					ТарифнаяЗона									= КлючЗначениеТарифнаяЗона.Ключ;
					СпособНачисления								= ЗначениеСтруктуры.СпособНачисления;
					
					Если ВидДифференцированностиПриоритет = Неопределено Тогда
						
						ВидДифференцированностиПриоритет = ЗначениеСтруктуры.ВидДифференцированности;
					ИначеЕсли ПриоритетыВидовДифференцированности[ЗначениеСтруктуры.ВидДифференцированности] <> Неопределено 
						И ПриоритетыВидовДифференцированности[ВидДифференцированностиПриоритет] <> Неопределено 
						И ПриоритетыВидовДифференцированности[ЗначениеСтруктуры.ВидДифференцированности] < ПриоритетыВидовДифференцированности[ВидДифференцированностиПриоритет] Тогда
						
						ВидДифференцированностиПриоритет = ЗначениеСтруктуры.ВидДифференцированности;
					КонецЕсли;
					
				КонецЦикла;	
				
				Если СпособНачисления <> Перечисления.энргСпособНачислений.ПоПриборам ИЛИ ВидДифференцированностиПриоритет = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				ВсеКомнатыРассчитаныПоПриборам  = Истина;
				СоответствиеТЗПриоритет			= Неопределено;
				
				Для Каждого КлючЗначениеПомещение Из ПараметрыРаспределенияОбъемаПомещения Цикл
					Если КлючЗначениеПомещение.Значение[СоставнаяУслуга] = Неопределено
						ИЛИ КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга] = Неопределено
						ИЛИ КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга][НачалоПериода] = Неопределено Тогда
						Продолжить;
					КонецЕсли;
					
					ПараметрыРаспределения 														= КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга][НачалоПериода];
					
					Если НЕ ПараметрыРаспределения.КомнатыРассчитаныПоПриборам Тогда
						ВсеКомнатыРассчитаныПоПриборам = Ложь;
						Прервать;
					КонецЕсли;
					
					Если ПриоритетыВидовДифференцированности[ПараметрыРаспределения.ВидДифференцированности] <> Неопределено 
						И ПриоритетыВидовДифференцированности[ВидДифференцированностиПриоритет] <> Неопределено 
						И ПриоритетыВидовДифференцированности[ПараметрыРаспределения.ВидДифференцированности] < ПриоритетыВидовДифференцированности[ВидДифференцированностиПриоритет] Тогда
						
						
						ВидДифференцированностиПриоритет 	= ПараметрыРаспределения.ВидДифференцированности;
						СоответствиеТЗПриоритет 			= ПараметрыРаспределения.СоответствиеТЗ;
					КонецЕсли;
					
				КонецЦикла;
				
				Если НЕ ВсеКомнатыРассчитаныПоПриборам Тогда
					Продолжить;
				КонецЕсли;
				
				мТарифныхЗонПриоритет = ВидДифференцированностиПриоритет.ТарифныеЗоны.ВыгрузитьКолонку("ТарифнаяЗона");
				
				Для Каждого КлючЗначениеПомещение Из ПараметрыРаспределенияОбъемаПомещения Цикл
					Если КлючЗначениеПомещение.Значение[СоставнаяУслуга] = Неопределено
						ИЛИ КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга] = Неопределено
						ИЛИ КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга][НачалоПериода] = Неопределено Тогда
						Продолжить;
					КонецЕсли;
					
					ПараметрыРаспределения 														= КлючЗначениеПомещение.Значение[СоставнаяУслуга][Услуга][НачалоПериода];
					
					Если ВидДифференцированностиПриоритет = ПараметрыРаспределения.ВидДифференцированности Тогда
						Продолжить;
					КонецЕсли;
					
					СоответствиеТЗ = ПараметрыРаспределения.СоответствиеТЗ;
					
					Для каждого ТЗ из мТарифныхЗонПриоритет Цикл 
						Если СоответствиеТЗ[ТЗ] = Неопределено И СоставляющиеТарифныхЗон[ТЗ] <> Неопределено Тогда
							Для каждого СоставляющаяТЗ из СоставляющиеТарифныхЗон[ТЗ] Цикл
								Если СоответствиеТЗ[СоставляющаяТЗ] <> Неопределено Тогда
									Если СоответствиеТЗ[ТЗ] = Неопределено Тогда
										СоответствиеТЗ.Вставить(ТЗ, Новый Структура("ОбъемУслуги, ОбъемУслугиПотребленный", СоответствиеТЗ[СоставляющаяТЗ].ОбъемУслуги, СоответствиеТЗ[СоставляющаяТЗ].ОбъемУслугиПотребленный));
									Иначе
										СоответствиеТЗ[ТЗ].ОбъемУслуги 				= СоответствиеТЗ[ТЗ].ОбъемУслуги + СоответствиеТЗ[СоставляющаяТЗ].ОбъемУслуги;
										СоответствиеТЗ[ТЗ].ОбъемУслугиПотребленный 	= СоответствиеТЗ[ТЗ].ОбъемУслугиПотребленный + СоответствиеТЗ[СоставляющаяТЗ].ОбъемУслугиПотребленный;
									КонецЕсли;
									СоответствиеТЗ.Удалить(СоставляющаяТЗ);
								КонецЕсли;
							КонецЦикла;	
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
				
				ЗначениеНачалоПериода = КлючЗначениеНачалоПериода.Значение;
				
				Для каждого ТЗ из мТарифныхЗонПриоритет Цикл 
					Если ЗначениеНачалоПериода[ТЗ] = Неопределено И СоставляющиеТарифныхЗон[ТЗ] <> Неопределено Тогда
						Для каждого СоставляющаяТЗ из СоставляющиеТарифныхЗон[ТЗ] Цикл
							Если ЗначениеНачалоПериода[СоставляющаяТЗ] <> Неопределено Тогда
								Если ЗначениеНачалоПериода[ТЗ] = Неопределено Тогда
									НовоеЗначениеСоотвествия = Новый Структура;
									ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(НовоеЗначениеСоотвествия, ЗначениеНачалоПериода[СоставляющаяТЗ]);
									Если СоответствиеТЗПриоритет <> Неопределено И СоответствиеТЗПриоритет[ТЗ] <> Неопределено Тогда
										НовоеЗначениеСоотвествия.ЗначениеТарифа 				= СоответствиеТЗПриоритет[ТЗ].ЗначениеТарифа;
										НовоеЗначениеСоотвествия.ЗначениеТарифаСверхНорматива 	= СоответствиеТЗПриоритет[ТЗ].ЗначениеТарифаСверхНорматива;
									КонецЕсли;
									ЗначениеНачалоПериода.Вставить(ТЗ, НовоеЗначениеСоотвествия);
								Иначе
									ЗначениеНачалоПериода[ТЗ].ОбъемУслуги 				= ЗначениеНачалоПериода[ТЗ].ОбъемУслуги + ЗначениеНачалоПериода[СоставляющаяТЗ].ОбъемУслуги;
									ЗначениеНачалоПериода[ТЗ].ОбъемУслугиПотребленный 	= ЗначениеНачалоПериода[ТЗ].ОбъемУслугиПотребленный + ЗначениеНачалоПериода[СоставляющаяТЗ].ОбъемУслугиПотребленный;
								КонецЕсли;
								ЗначениеНачалоПериода.Удалить(СоставляющаяТЗ);
							КонецЕсли;
						КонецЦикла;	
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область НачислениеПоРассрочке_ВспомогательныеФункции

// Рассчет процентов происходит на остаток суммы
Процедура ДифференцированныйСпособРасчетаПроцентов(Организация, ПериодНачисления,Район,МКД,Документ,КонецПериодаРасчета)
	
	Запрос  								= Новый Запрос;
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("КонецПериодаРасчета",КонецПериодаРасчета);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("Организация",			Организация);
	Текст  									= ТекстЗапросаДифференцированныйСпособРасчетаПроцентов();
	
	Если МКД = Неопределено тогда
		Текст 								= СтрЗаменить(Текст,"И энргСтабильныеПериоды.МКД = &МКД","");
		Текст 								= СтрЗаменить(Текст,"И (энргСтабильныеПериоды.МКД = &МКД)","");
		Текст 								= СтрЗаменить(Текст,"И МКД = &МКД","");
		Текст 								= СтрЗаменить(Текст,"И (энргНачислениеПоРассрочке.МКД = &МКД)","");
	иначе
		Запрос.УстановитьПараметр("МКД",МКД);
	КонецЕсли;
	
	Запрос.Текст 							= Текст;
	РезЗадолженность						= Запрос.Выполнить();
	
	// читаем ставку рефинансирования
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("КонецПериодаРасчета",КонецПериодаРасчета);
	Запрос.Текст 	="ВЫБРАТЬ
	|	энргСтавкиРефинансированияСрезПоследних.Коэффициент
	|ИЗ
	|	РегистрСведений.энргСтавкиРефинансирования.СрезПоследних(&КонецПериодаРасчета, ) КАК энргСтавкиРефинансированияСрезПоследних";
	Результат 								= Запрос.Выполнить();
	
	Если Результат.Пустой() тогда
		Возврат;
	иначе
		Выборка  							= Результат.Выбрать();
		Выборка.Следующий();
		СтРеф  								= Выборка.Коэффициент;
	КонецЕсли;
	
	Выборка  								= РезЗадолженность.Выбрать();
	ТекДом 									= Неопределено;
	ДокументОбъект 							= Неопределено;
	Пока Выборка.Следующий() цикл
		Если Документ = Неопределено тогда
			ТабЧасть 						= Документ.НачисленияАбонентам;			 
		иначеЕсли ТекДом <>  Выборка.МКД тогда // первая строка выборки
			
			Если ТекДом<>Неопределено тогда
				ДокументОбъект.ДополнительныеСвойства.Вставить("ПроведениеРазрешено",Истина);
				ДокументОбъект.записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли; 		
			
			Если ЗначениеЗаполнено(Выборка.ДокументНачисления) тогда
				ДокументОбъект  			= Выборка.ДокументНачисления.получитьОбъект();
			иначе
				ДокументОбъект  			= Документы.энргНачислениеПоРассрочке.СоздатьДокумент();
				ДокументОбъект.Дата 		= КонецПериодаРасчета;
			КонецЕсли;
			
			ДокументОбъект.ПометкаУдаления = ложь;
			ДокументОбъект.Район 			= Район;
			ДокументОбъект.МКД 			= Выборка.МКД;
			ТабЧасть 						= ДокументОбъект.НачисленияАбонентам
		КонецЕсли; 		
		СтрокаТЧ  							= ТабЧасть.Добавить();
		СтрокаТЧ.Абонент 					= Выборка.Абонент;
		СтрокаТЧ.СуммаНачисленныхПроцентов	= Выборка.Задолженность * СтРеф /(12* 100);
		ТекДом 								= Выборка.МКД;
	КонецЦикла;
	
	Если Документ = Неопределено и ДокументОбъект<>Неопределено тогда
		ДокументОбъект.ДополнительныеСвойства.Вставить("ПроведениеРазрешено",Истина);
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЕсли; 
	
КонецПроцедуры

Функция ТекстЗапросаДифференцированныйСпособРасчетаПроцентов()
	Текст 	=
	"ВЫБРАТЬ
	|	энргСтабильныеПериоды.Организация КАК Организация,
	|	энргСтабильныеПериоды.ПериодНачисления КАК ПериодНачисления,
	|	энргСтабильныеПериоды.Район КАК Район,
	|	энргСтабильныеПериоды.МКД КАК МКД,
	|	энргСтабильныеПериоды.Абонент КАК Абонент,
	|	энргСтабильныеПериоды.Услуга КАК Услуга,
	|	энргСтабильныеПериоды.ТочкаУчета КАК ТочкаУчета,
	|	МАКСИМУМ(энргСтабильныеПериоды.НомерПозиции) КАК НомерПозиции
	|ПОМЕСТИТЬ НомерПозиций
	|ИЗ
	|	РегистрСведений.энргСтабильныеПериоды КАК энргСтабильныеПериоды
	|ГДЕ
	|	энргСтабильныеПериоды.Организация = &Организация
	|	И энргСтабильныеПериоды.ПериодНачисления = &ПериодНачисления
	|	И энргСтабильныеПериоды.Район = &Район
	|	И энргСтабильныеПериоды.МКД = &МКД
	|
	|СГРУППИРОВАТЬ ПО
	|	энргСтабильныеПериоды.Организация,
	|	энргСтабильныеПериоды.ПериодНачисления,
	|	энргСтабильныеПериоды.МКД,
	|	энргСтабильныеПериоды.Район,
	|	энргСтабильныеПериоды.Услуга,
	|	энргСтабильныеПериоды.ТочкаУчета,
	|	энргСтабильныеПериоды.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	энргСтабильныеПериоды.МКД КАК МКД,
	|	энргСтабильныеПериоды.Абонент КАК Абонент
	|ПОМЕСТИТЬ ОткрытыеЛС
	|ИЗ
	|	НомерПозиций КАК НомерПозиций
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСтабильныеПериоды КАК энргСтабильныеПериоды
	|		ПО НомерПозиций.Организация = энргСтабильныеПериоды.Организация
	|			И НомерПозиций.ПериодНачисления = энргСтабильныеПериоды.ПериодНачисления
	|			И НомерПозиций.Район = энргСтабильныеПериоды.Район
	|			И НомерПозиций.МКД = энргСтабильныеПериоды.МКД
	|			И НомерПозиций.Абонент = энргСтабильныеПериоды.Абонент
	|			И НомерПозиций.Услуга = энргСтабильныеПериоды.Услуга
	|			И НомерПозиций.ТочкаУчета = энргСтабильныеПериоды.ТочкаУчета
	|			И НомерПозиций.НомерПозиции = энргСтабильныеПериоды.НомерПозиции
	|			И (энргСтабильныеПериоды.УслугаПодключена)
	|			И (энргСтабильныеПериоды.Организация = &Организация)
	|			И (энргСтабильныеПериоды.ПериодНачисления = &ПериодНачисления)
	|			И (энргСтабильныеПериоды.Район = &Район)
	|			И (энргСтабильныеПериоды.МКД = &МКД)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗадолженностьПоРассрочкеОстатки.МКД КАК МКД,
	|	энргЗадолженностьПоРассрочкеОстатки.Абонент КАК Абонент,
	|	энргЗадолженностьПоРассрочкеОстатки.СуммаЗадолженностиОстаток КАК СуммаЗадолженностиОстаток
	|ПОМЕСТИТЬ ЗадолженностьПоРассрочке
	|ИЗ
	|	РегистрНакопления.энргЗадолженностьПоРассрочке.Остатки(
	|			&ПериодНачисления,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД) КАК энргЗадолженностьПоРассрочкеОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗадолженностьПоРассрочке.МКД КАК МКД,
	|	ЗадолженностьПоРассрочке.Абонент КАК Абонент,
	|	ЗадолженностьПоРассрочке.СуммаЗадолженностиОстаток КАК СуммаЗадолженностиОстаток
	|ПОМЕСТИТЬ ДанныеДляНачислений
	|ИЗ
	|	ОткрытыеЛС КАК ОткрытыеЛС
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗадолженностьПоРассрочке КАК ЗадолженностьПоРассрочке
	|		ПО ОткрытыеЛС.МКД = ЗадолженностьПоРассрочке.МКД
	|			И ОткрытыеЛС.Абонент = ЗадолженностьПоРассрочке.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДляНачислений.МКД КАК МКД,
	|	ДанныеДляНачислений.Абонент КАК Абонент,
	|	ДанныеДляНачислений.СуммаЗадолженностиОстаток КАК Задолженность,
	|	ЕСТЬNULL(энргНачислениеПоРассрочке.Ссылка, ЗНАЧЕНИЕ(Документ.энргНачислениеПоРассрочке.ПустаяСсылка)) КАК ДокументНачисления
	|ИЗ
	|	ДанныеДляНачислений КАК ДанныеДляНачислений
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргНачислениеПоРассрочке КАК энргНачислениеПоРассрочке
	|		ПО ДанныеДляНачислений.МКД = энргНачислениеПоРассрочке.МКД
	|			И (энргНачислениеПоРассрочке.Организация = &Организация)
	|			И (энргНачислениеПоРассрочке.Район = &Район)
	|			И (энргНачислениеПоРассрочке.Дата = &КонецПериодаРасчета)
	|			И (энргНачислениеПоРассрочке.МКД = &МКД)
	|
	|УПОРЯДОЧИТЬ ПО
	|	МКД
	|ИТОГИ
	|	МАКСИМУМ(ДокументНачисления)
	|ПО
	|	МКД";
	Возврат Текст;
КонецФункции

#КонецОбласти

#Область ЗакрытьПериодДляРедактирования_ВспомогательныеФункции

Функция ДокуметЗакрытияПериода(Организация,ПериодНачисления,Район)
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.Текст 	="ВЫБРАТЬ ПЕРВЫЕ 1
	|	энргЗакрытиеПериода.Ссылка
	|ИЗ
	|	Документ.энргЗакрытиеПериода КАК энргЗакрытиеПериода
	|ГДЕ
	|	НЕ энргЗакрытиеПериода.ПометкаУдаления
	|	И энргЗакрытиеПериода.Район = &Район
	|	И энргЗакрытиеПериода.Организация = &Организация
	|	И энргЗакрытиеПериода.ПериодНачисления = &ПериодНачисления";
	Результат  		= Запрос.Выполнить();
	Выборка  		= Результат.Выбрать();
	Если Выборка.Следующий() тогда
		Возврат  Выборка.Ссылка;
	КонецЕсли;
	Возврат Документы.энргЗакрытиеПериода.ПустаяСсылка();	
КонецФункции

#КонецОбласти

#Область РаспредениеОбъемаМКД_ВспомогательныеПроцедуры

#Область ОперацииПоРаспределениюОбъемаУслуги

Процедура РаспределитьОбъемПоУслугеМКД(ПериодНачисления, Организация, Район, МКД, Услуга, ГраницыПериода, ЗначенияТарифов, ДанныеПоУслуге, ДокументОбъект, РаспределениеОбъемаПоУслугам, НаборОтрицательныйОбъемРаспределения, НаборЗаписей, НаборЗаписейПомещение,НаборЗаписейНП, НаборЗаписейНПЭЭ, НаборЗаписейСверхНорма)
			
	РаспределениеПоАбонентам 						= Новый Соответствие;
		
	ОбщийОбъемНачислений 							= ДанныеПоУслуге.ОбщийОбъемНачислений;
	ОбщийОбъемНачисленийПомещений 					= ДанныеПоУслуге.ОбщийОбъемНачисленийПомещений;
	ТочностьОбъемаНачислений 						= Метаданные.РегистрыНакопления.энргОбъемНачислений.Ресурсы.ОбъемУслуги.Тип.КвалификаторыЧисла.РазрядностьДробнойЧасти;
	ДанныеОбъемаКРаспределению 						= ДанныеОбъемаКРаспределению(ДанныеПоУслуге, Услуга, ГраницыПериода, ЗначенияТарифов, НаборЗаписей, НаборЗаписейПомещение, НаборЗаписейНП, НаборЗаписейНПЭЭ, ОбщийОбъемНачислений, ОбщийОбъемНачисленийПомещений);
	
	ВидНачисления 									= Перечисления.энргВидыНачислений.НачислениеОДН;	
	СпособНачисленияОДН 							= ДанныеОбъемаКРаспределению.СпособНачисленияОДН;//Перечисления.энргСпособНачислений.ПустаяСсылка();
		
	Для Каждого КлючЗначениеТарифнаяЗона Из ДанныеОбъемаКРаспределению.ОсталосьРаспределить Цикл 		
		ОсталосьРаспределить 						= КлючЗначениеТарифнаяЗона.Значение; 		
		СписываемИзОтрицательного 					= Мин(Макс(ОсталосьРаспределить,0), ДанныеПоУслуге.ОтрицательныйОбъемРаспределения.ОбъемУслуги); 

		ПроцентОтОбъема 							= ДанныеПоУслуге.ПроцентРаспределенияОтрицательногоОбъема;
		Если СписываемИзОтрицательного > 0 и ПроцентОтОбъема > 0 Тогда 		
			ОбъемПроцентаКРаспределению 			= Макс(ОсталосьРаспределить,0) * (ПроцентОтОбъема / 100);
			ОсталосьРаспределить					= ?(ОбъемПроцентаКРаспределению > СписываемИзОтрицательного, Макс(ОсталосьРаспределить,0) - СписываемИзОтрицательного, ОбъемПроцентаКРаспределению);
			СписываемИзОтрицательного				= ОсталосьРаспределить;  		
		Иначе 
			ОсталосьРаспределить 					= ОсталосьРаспределить - СписываемИзОтрицательного;
		КонецЕсли;
		          	
		ЗаполнитьНаборОтрицательногоОбъемаРаспределения(ОсталосьРаспределить, СписываемИзОтрицательного, НаборОтрицательныйОбъемРаспределения, Организация, ПериодНачисления, Район, МКД, Услуга, КлючЗначениеТарифнаяЗона.Ключ, ГраницыПериода.ЗавершениеОП - 1, ДанныеПоУслуге);
						
		Если ОсталосьРаспределить <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		АбонентыДляРаспределения 					= ДанныеПоУслуге.АбонентыДляРаспределения;
		Распределили 								= 0; 	
		Для Сч = 0 По АбонентыДляРаспределения.ВГраница() Цикл
			ДанныеАбонента 							= АбонентыДляРаспределения[Сч];		
			Если ЗначениеЗаполнено(ДанныеПоУслуге.ЗависитОтУслуги) Тогда
				ОбъемУслуги 						= 0;			
				Если РаспределениеОбъемаПоУслугам[ДанныеПоУслуге.ЗависитОтУслуги] = Неопределено Тогда
					ОбъемУслуги 					= 0; 
				ИначеЕсли РаспределениеОбъемаПоУслугам[ДанныеПоУслуге.ЗависитОтУслуги][ДанныеАбонента.Абонент] = Неопределено Тогда
					ОбъемУслуги 					= 0;
				Иначе
					ОбъемУслуги 					= РаспределениеОбъемаПоУслугам[ДанныеПоУслуге.ЗависитОтУслуги][ДанныеАбонента.Абонент] * ДанныеПоУслуге.ЗначениеНорматива;
				КонецЕсли;  			
				
			ИначеЕсли Сч = АбонентыДляРаспределения.ВГраница() Тогда
				ОбъемУслуги 						= ОсталосьРаспределить - Распределили;
				
			ИначеЕсли ДанныеПоУслуге.ВсегоПлощадьАбонентов = 0 Тогда
				ВызватьИсключение "Для МКД " + СокрЛП(МКД) + " не задана площадь помещений. ЛС " + ДанныеАбонента.Абонент.ЛицевойСчет;	
			Иначе			
				кПлощади 							= ДанныеАбонента.ЗначениеПлощади / ДанныеПоУслуге.ВсегоПлощадьАбонентов;
				ОбъемУслуги 						= ОсталосьРаспределить * кПлощади;				
			КонецЕсли; 				
			ОбъемУслуги 							= Окр(ОбъемУслуги, ТочностьОбъемаНачислений);
			Распределили 							= Распределили + ОбъемУслуги;
			ЗаполнитьСтрокуНачисленийПриРаспределении(КлючЗначениеТарифнаяЗона.Ключ, ОбъемУслуги, СпособНачисленияОДН, ГраницыПериода, Организация, ПериодНачисления, Район, МКД, Услуга, ДанныеПоУслуге, ДанныеАбонента, ЗначенияТарифов, НаборЗаписей, НаборЗаписейПомещение, НаборЗаписейНП, НаборЗаписейНПЭЭ, ОбщийОбъемНачисленийПомещений, ОбщийОбъемНачислений, ТочностьОбъемаНачислений);
			РаспределениеПоАбонентам.Вставить(ДанныеАбонента.Абонент, ОбъемУслуги);
		КонецЦикла;		
	КонецЦикла;
			
	Если РаспределениеОбъемаПоУслугам[Услуга] = Неопределено Тогда
		РаспределениеОбъемаПоУслугам.Вставить(Услуга, РаспределениеПоАбонентам);
	КонецЕсли;	
	
	ДанныеПоУслуге.ОбщийОбъемНачислений				= ОбщийОбъемНачислений;
	ДанныеПоУслуге.ОбщийОбъемНачисленийПомещений 	= ОбщийОбъемНачисленийПомещений;	
КонецПроцедуры

Функция ДанныеОбъемаКРаспределению(ДанныеПоУслуге, Услуга, ГраницыПериода, ЗначенияТарифов, НаборЗаписей, НаборЗаписейПомещение, НаборЗаписейНП, НаборЗаписейНПЭЭ, ОбщийОбъемНачислений, ОбщийОбъемНачисленийПомещений)
	
	Если ДанныеПоУслуге.НеНачислятьУслугуАбонентам Тогда
		НадоРаспределить = ДанныеПоУслуге.ОбъемПотребленныйПоПрибору + ДанныеПоУслуге.ОбъемПотребленныйБезПрибора - ДанныеПоУслуге.ОбъемУслугиПотребленныйПерерасчет;
	Иначе
		
		НадоРаспределить = ДанныеПоУслуге.ОбъемПоПрибору + ДанныеПоУслуге.ОбъемБезПрибора;
		Если НЕ ДанныеПоУслуге.НазначениеПрибораУчета = Перечисления.энргНазначениеПУ.МОП Тогда
			НадоРаспределить = НадоРаспределить - ?(ДанныеПоУслуге.НеУчитыватьПерерасчетыАбонентов, 0, ДанныеПоУслуге.ОбъемУслугиПерерасчет); // от сюда вычесть величину перерасчета
		КонецЕсли;
		
	КонецЕсли;
	
	ТочностьОбъемаНачислений 								= Метаданные.РегистрыНакопления.энргОбъемНачислений.Ресурсы.ОбъемУслуги.Тип.КвалификаторыЧисла.РазрядностьДробнойЧасти;
	НазначениеПрибораУчета 									= ДанныеПоУслуге.НазначениеПрибораУчета;
	ЕстьПотреблениеПоПрибору 								= ДанныеПоУслуге.ПоказанияПредоставлены <> 0 или НЕ ДанныеПоУслуге.ОбъемПоПрибору = 0;
	ЕстьФактическоеПотреблениеПоПрибору 					= ДанныеПоУслуге.ПоказанияПредоставленыПотребленный <> 0 ИЛИ НЕ ДанныеПоУслуге.ОбъемПотребленныйПоПрибору = 0;;	
	ОсталосьРаспределить 									= Новый Соответствие;
	СпособНачисленияОДН 									= Перечисления.энргСпособНачислений.ПустаяСсылка();
	ТарифныеЗоныИдентичны 									= ОбщегоНазначения.КоллекцииИдентичны(ДанныеПоУслуге.ОбъемПоПриборуТарифныЗоны, ДанныеПоУслуге.ПотреблениеАбонентовТарифныеЗоны, "Ключ");
	
	Если ДанныеПоУслуге.КорректироватьИндивидуальныйОбъемСУчетомОДПУ и ЕстьПотреблениеПоПрибору И ДанныеПоУслуге.ВсеПоПрибору Тогда
		ОсталосьРаспределить.Вставить(Справочники.энргТарифныеЗоны.БезРазбивки, НадоРаспределить - ДанныеПоУслуге.ПотреблениеАбонентов);		 		
		СпособНачисленияОДН 								= ДанныеПоУслуге.СпособНачисленияМКД;
	ИначеЕсли ДанныеПоУслуге.КорректироватьИндивидуальныйОбъемСУчетомОДПУ и НЕ ЕстьПотреблениеПоПрибору Тогда
		// Списываем начисленный индивидуальный объем по прибору учета, при условии что нет фактического потребления по ПУ
		Если Не ЕстьФактическоеПотреблениеПоПрибору Тогда
			Для Каждого СтрокаНачисленийАбонента ИЗ ДанныеПоУслуге.ОбъемПоПриборуКорректировать Цикл 
				Если ЗначениеЗаполнено(СтрокаНачисленийАбонента.Абонент) Тогда
					яНабор 										= НаборЗаписей;
					яНаборОбщий 								= ОбщийОбъемНачислений;
				Иначе
					яНабор 										= НаборЗаписейПомещение;
					яНаборОбщий 								= ОбщийОбъемНачисленийПомещений;
				КонецЕсли;			
				
				Если СтрокаНачисленийАбонента.СпособНачисления  = Перечисления.энргСпособНачислений.ПоПриборам 
					ИЛИ СтрокаНачисленийАбонента.СпособНачисления  = Перечисления.энргСпособНачислений.НачислениеПоСреднему Тогда
					Если НЕ СтрокаНачисленийАбонента.ОбъемУслуги = 0 ИЛИ НЕ СтрокаНачисленийАбонента.Сумма = 0 Тогда
						СтрокаНабора  							= яНабор.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаНабора, СтрокаНачисленийАбонента,,"ОбъемУслугиПотребленный");
						СтрокаНабора.Распределение 				= Истина;
						
						СтрокаНабора.ОбъемУслуги 				= -СтрокаНабора.ОбъемУслуги;
						СтрокаНабора.Сумма 						= -СтрокаНабора.Сумма;
						СтрокаНабора.Период 					= ГраницыПериода.ЗавершениеОП-1;
						ЗаполнитьЗначенияСвойств(яНаборОбщий.Добавить(),СтрокаНабора,,"ОбъемУслугиПотребленный");
					КонецЕсли;
					
					Если СтрокаНачисленийАбонента.ПомещениеРодитель = СтрокаНачисленийАбонента.Помещение Тогда
						// добавляем новую строку начислений
						СтрокаНабора  							= яНабор.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаНабора, СтрокаНачисленийАбонента,,"ОбъемУслугиПотребленный");
						СтрокаНабора.Распределение 				= Истина;
						СтрокаНабора.СпособНачисления 			= Перечисления.энргСпособНачислений.ПоНормативу;
						ОбъемУслуги 							= СтрокаНабора.НормаПотребления * СтрокаНабора.ЗначениеПлощади * ((СтрокаНабора.ПлощадьАбонентов - СтрокаНабора.ПлощадьСобственнаяПоставка) / (СтрокаНабора.ПлощадьАбонентов - СтрокаНабора.ПлощадьСобственнаяПоставка + СтрокаНабора.ПлощадьМОП)) * (СтрокаНабора.КонецПериода - СтрокаНабора.НачалоПериода) / (ГраницыПериода.ДнейВПериоде * 86400);
						СтрокаНабора.ОбъемУслуги 				= ОбъемУслуги;
						СтрокаНабора.Сумма 						= СтрокаНабора.ОбъемУслуги * СтрокаНабора.ЗначениеТарифа;
						СтрокаНабора.Период 					= ГраницыПериода.ЗавершениеОП-1;
						ЗаполнитьЗначенияСвойств(яНаборОбщий.Добавить(),СтрокаНабора,,"ОбъемУслугиПотребленный");
						РазделенныеЛицевыеСчета 				= ДанныеПоУслуге.РазделенныеЛицевыеСчета;
						
						Если НЕ РазделенныеЛицевыеСчета[СтрокаНачисленийАбонента.Помещение] = Неопределено Тогда
							ОсталосьВнутриПомещения 			= ОбъемУслуги;
							ПомещенияПотомки					= РазделенныеЛицевыеСчета[СтрокаНачисленийАбонента.Помещение];
							СуммаПлощадейПомещения 				= 0;
							Для Каждого ПомещениеПотомок Из ПомещенияПотомки Цикл
								ДанныеПомещения  				= ПомещениеПотомок.Значение[Услуга];
								СуммаПлощадейПомещения 			= СуммаПлощадейПомещения + ДанныеПомещения.Значениеплощади; 
							КонецЦикла;		
							
							ПереасчитатьСтроки 					= Новый Массив;
							
							Для Каждого ПомещениеПотомок Из ПомещенияПотомки Цикл
								ДанныеПомещения  				= ПомещениеПотомок.Значение[Услуга];				                 		
								
								ХэшСтрокиТарифа 				= ХэшСтрокиТарифа(ДанныеПомещения.ТарифнаяГруппа,Услуга,ДанныеПомещения.Поставщик,Справочники.энргТарифныеЗоны.БезРазбивки); 
								ЗначениеТарифа 					= ?(ЗначенияТарифов[ХэшСтрокиТарифа] = Неопределено, Новый Структура("Значение", 0), ЗначенияТарифов[ХэшСтрокиТарифа]);
								СтрокаНабора  					= НаборЗаписей.Добавить();
								ЗаполнитьЗначенияСвойств(СтрокаНабора, СтрокаНачисленийАбонента,,"ОбъемУслугиПотребленный");
								СтрокаНабора.Распределение 		= Истина;
								СтрокаНабора.Период 			= ГраницыПериода.ЗавершениеОП-1;
								СтрокаНабора.Помещение			= ПомещениеПотомок.Ключ;
								СтрокаНабора.Абонент			= ДанныеПомещения.Абонент;						
								
								Если ДанныеПомещения.СпособРаспределенияОбъемаПомещения = Перечисления.энргСпособыРаспределенияОбъема.ФиксированныйОбъем Тогда
									СтрокаНабора.ОбъемУслуги 	= ДанныеПомещения.ФиксированныйОбъемПотребления;
									ОсталосьВнутриПомещения 	= ОсталосьВнутриПомещения - СтрокаНабора.ОбъемУслуги;
								ИначеЕсли ДанныеПомещения.СпособРаспределенияОбъемаПомещения = Перечисления.энргСпособыРаспределенияОбъема.ДолевоеРаспределение Тогда
									СтрокаНабора.ОбъемУслуги = ОбъемУслуги * ДанныеПомещения.ДоляПотребленияЧислитель / ДанныеПомещения.ДоляПотребленияЗнаменатель;
									ОсталосьВнутриПомещения 	= ОсталосьВнутриПомещения - СтрокаНабора.ОбъемУслуги;
								ИначеЕсли ДанныеПомещения.СпособРаспределенияОбъемаПомещения = Перечисления.энргСпособыРаспределенияОбъема.Остаток Тогда	
									ПереасчитатьСтроки.Добавить(НаборЗаписей.Индекс(СтрокаНабора));
								Иначе
									Если ЗначениеЗаполнено(ДанныеПоУслуге.ВидПлощади) Тогда
										СтрокаНабора.ОбъемУслуги = ?(НЕ СуммаПлощадейПомещения = 0, ОбъемУслуги * ДанныеПомещения.ЗначениеПлощади / СуммаПлощадейПомещения, 0);
									Иначе
										СтрокаНабора.ОбъемУслуги = ?(НЕ СтрокаНачисленийАбонента.КоличествоЖильцов = 0, ОбъемУслуги * ДанныеПомещения.КоличествоПроживающих / СтрокаНачисленийАбонента.КоличествоЖильцов, 0);
									КонецЕсли;
									ОсталосьВнутриПомещения 	= ОсталосьВнутриПомещения - СтрокаНабора.ОбъемУслуги;
								КонецЕсли;											
								
								СтрокаНабора.Сумма				= СтрокаНабора.ОбъемУслуги * ЗначениеТарифа.Значение;				
							КонецЦикла;
							
							Если ПереасчитатьСтроки.Количество() > 0 Тогда
								Для Сч = 0 По ПереасчитатьСтроки.ВГраница() Цикл
									СтрокаНабора 				= НаборЗаписей.Получить(ПереасчитатьСтроки[Сч]);
									СтрокаНабора.ОбъемУслуги 	= ОсталосьВнутриПомещения;
									СтрокаНабора.Сумма			= СтрокаНабора.ОбъемУслуги * ЗначениеТарифа.Значение;
								КонецЦикла;						
							КонецЕсли;					
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;			
			КонецЦикла;
			
			Для Каждого СтрокаНачисленийНП ИЗ ДанныеПоУслуге.ОбъемПоПриборуНПКорректировать Цикл 
				Если ЗначениеЗаполнено(СтрокаНачисленийНП.ОбъектРасчета) Тогда
					яНабор 										= НаборЗаписейНП;
					яНаборОбщий 								= ОбщийОбъемНачислений;
				Иначе
					яНабор 										= НаборЗаписейПомещение;
					яНаборОбщий 								= ОбщийОбъемНачисленийПомещений;
				КонецЕсли;			
				
				Если СтрокаНачисленийНП.СпособНачисления  = Перечисления.энргСпособНачислений.ПоПриборам 
					ИЛИ СтрокаНачисленийНП.СпособНачисления  = Перечисления.энргСпособНачислений.НачислениеПоСреднему Тогда
					Если НЕ СтрокаНачисленийНП.ОбъемУслуги = 0 Тогда
						СтрокаНабора  				= яНабор.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаНабора, СтрокаНачисленийНП,,"ОбъемУслугиПотребленный");
						СтрокаНабора.Распределение 				= Истина;
						СтрокаНабора.ОбъемПоПрибору 			= -СтрокаНабора.ОбъемПоПрибору;
						СтрокаНабора.ОбъемУслуги 				= -СтрокаНабора.ОбъемУслуги;
						СтрокаНабора.Период 					= ГраницыПериода.ЗавершениеОП-1;
						ЗаполнитьЗначенияСвойств(яНаборОбщий.Добавить(),СтрокаНабора,,"ОбъемУслугиПотребленный");
					КонецЕсли;
					
					
