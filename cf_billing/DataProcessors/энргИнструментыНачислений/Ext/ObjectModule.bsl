	|			И ДанныеДляРасчетаПередНормой.МКД = НастройкаНачисленияГВСМКД.МКД
	|			И ДанныеДляРасчетаПередНормой.ТипСхемы = НастройкаНачисленияГВСМКД.ТипСхемы
	|			И ДанныеДляРасчетаПередНормой.ВидТепловогоПункта = НастройкаНачисленияГВСМКД.ПринадлежностьКТепловомуПункту
	|			И ДанныеДляРасчетаПередНормой.МКД = НастройкаНачисленияГВСМКД.МКД
	|		ЛЕВОЕ СОЕДИНЕНИЕ НормаСкоростиДвиженияВоды КАК НормаСкоростиДвиженияВоды
	|		ПО ДанныеДляРасчетаПередНормой.Организация = НормаСкоростиДвиженияВоды.Организация
	|			И ДанныеДляРасчетаПередНормой.ПериодНачисления = НормаСкоростиДвиженияВоды.ПериодНачисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДеньНачалаНачисленияПоСреднему КАК ДеньНачалаНачисленияПоСреднему
	|		ПО ДанныеДляРасчетаПередНормой.Организация = ДеньНачалаНачисленияПоСреднему.Организация
	|			И ДанныеДляРасчетаПередНормой.ПериодНачисления = ДеньНачалаНачисленияПоСреднему.ПериодНачисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПоставщикиНеНачислять КАК ПоставщикиНеНачислять
	|		ПО ДанныеДляРасчетаПередНормой.Организация = ПоставщикиНеНачислять.Организация
	|			И ДанныеДляРасчетаПередНормой.ПериодНачисления = ПоставщикиНеНачислять.ПериодНачисления
	|			И ДанныеДляРасчетаПередНормой.Район = ПоставщикиНеНачислять.Район
	|			И ДанныеДляРасчетаПередНормой.Поставщик = ПоставщикиНеНачислять.Поставщик
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДниИспользованияУслугПриОтсутствии КАК ДниИспользованияУслугПриОтсутствии
	|		ПО  ДанныеДляРасчетаПередНормой.ПериодНачисления = ДниИспользованияУслугПриОтсутствии.ПериодНачисления	
	|			И ДанныеДляРасчетаПередНормой.Организация = ДниИспользованияУслугПриОтсутствии.Организация
	|			И ДанныеДляРасчетаПередНормой.Район = ДниИспользованияУслугПриОтсутствии.Район
	|			И ДанныеДляРасчетаПередНормой.ЧастныйСектор = ДниИспользованияУслугПриОтсутствии.ЧастныйСектор
	|			И ДанныеДляРасчетаПередНормой.Строение = ДниИспользованияУслугПриОтсутствии.Строение
	|			И ДанныеДляРасчетаПередНормой.Помещение = ДниИспользованияУслугПриОтсутствии.Помещение	
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПроцентВетхостиСтроений КАК ПроцентВетхостиСтроений
	|		ПО  ДанныеДляРасчетаПередНормой.Организация = ПроцентВетхостиСтроений.Организация
	|			И ДанныеДляРасчетаПередНормой.ПериодНачисления = ПроцентВетхостиСтроений.ПериодНачисления
	|			И ДанныеДляРасчетаПередНормой.Район = ПроцентВетхостиСтроений.Район
	|			И ДанныеДляРасчетаПередНормой.ЧастныйСектор = ПроцентВетхостиСтроений.ЧастныйСектор
	|			И ДанныеДляРасчетаПередНормой.Строение = ПроцентВетхостиСтроений.Строение
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДниИспользованияУслугПриВременномОтключенииУслуги КАК ДниИспользованияУслугПриВременномОтключенииУслуги
	|		ПО ДанныеДляРасчетаПередНормой.ПериодНачисления = ДниИспользованияУслугПриВременномОтключенииУслуги.ПериодНачисления
	|		И ДанныеДляРасчетаПередНормой.Организация = ДниИспользованияУслугПриВременномОтключенииУслуги.Организация
	|		И ДанныеДляРасчетаПередНормой.Район = ДниИспользованияУслугПриВременномОтключенииУслуги.Район
	|		И ДанныеДляРасчетаПередНормой.ЧастныйСектор = ДниИспользованияУслугПриВременномОтключенииУслуги.ЧастныйСектор
	|		И ДанныеДляРасчетаПередНормой.Строение = ДниИспользованияУслугПриВременномОтключенииУслуги.Строение
	|		И ДанныеДляРасчетаПередНормой.Помещение = ДниИспользованияУслугПриВременномОтключенииУслуги.Помещение
	|		И ДанныеДляРасчетаПередНормой.Услуга = ДниИспользованияУслугПриВременномОтключенииУслуги.Услуга
	|		ЛЕВОЕ СОЕДИНЕНИЕ НазначенияПриборовУчета КАК НазначенияПриборовУчета
	|		ПО ДанныеДляРасчетаПередНормой.Организация = НазначенияПриборовУчета.Организация
	|			И ДанныеДляРасчетаПередНормой.Район = НазначенияПриборовУчета.Район
	|			И ДанныеДляРасчетаПередНормой.ЧастныйСектор = НазначенияПриборовУчета.ЧастныйСектор
	|			И ДанныеДляРасчетаПередНормой.Строение = НазначенияПриборовУчета.Строение
	|			И ДанныеДляРасчетаПередНормой.Помещение = НазначенияПриборовУчета.Помещение
	|			И ДанныеДляРасчетаПередНормой.ТочкаУчета = НазначенияПриборовУчета.ТочкаУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения КАК энргПомещения
	|		ПО ДанныеДляРасчетаПередНормой.ПомещениеРодитель = энргПомещения.Ссылка
	|;
	|
	|///////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДляРасчетаОбщие.ТочкаУчетаРодитель КАК ТочкаУчета
	|ПОМЕСТИТЬ СложныеТочки
	|ИЗ
	|	ДанныеДляРасчетаОбщие КАК ДанныеДляРасчетаОбщие
	|ГДЕ
	|	ДанныеДляРасчетаОбщие.ТочкаУчетаРодитель <> ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ДанныеДляРасчетаОбщие.ЗависимаяТочкаУчета
	|ИЗ
	|	ДанныеДляРасчетаОбщие КАК ДанныеДляРасчетаОбщие
	|ГДЕ
	|	ДанныеДляРасчетаОбщие.ЗависимаяТочкаУчета <> ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ДанныеДляРасчетаОбщие.СложнаяТочкаУчета
	|ИЗ
	|	ДанныеДляРасчетаОбщие КАК ДанныеДляРасчетаОбщие
	|ГДЕ
	|	ДанныеДляРасчетаОбщие.СложнаяТочкаУчета <> ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|
	|;
	|
	|///////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ *,
	|	ВЫБОР 
	|		КОГДА НЕ СложныеТочки.ТочкаУчета есть NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЭтоПростаяТочкаУчета,
	|	РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ДанныеДляРасчетаОбщие.НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(ДанныеДляРасчетаОбщие.КонецПериода, ДЕНЬ), ДЕНЬ) КАК РазностьДатГраницПериода
	|ПОМЕСТИТЬ ДанныеДляРасчета
	|ИЗ
	|	ДанныеДляРасчетаОбщие
	|		ЛЕВОЕ СОЕДИНЕНИЕ СложныеТочки КАК СложныеТочки
	|		ПО ДанныеДляРасчетаОбщие.ТочкаУчета = СложныеТочки.ТочкаУчета";

	Возврат Текст;
КонецФункции

#Область ОпределениеВыводимыхПриборовУчетаБезПоказаний

// Функция - Определяет выводимые приборы учета без указания конечных показаний в документе вывода.
// 		Списание среднего производиться не будет. МИНИМУМ - если по одной тарифной зоне отклонены показания, то весь прибор начисляем по среднему.
//		Поле "ВыводПрибораУчетаБезУказанияПоказаний" переопределяет поле "СниматьНачисленныйСредний" 	
// Возвращаемое значение:
//  Строка - Текст запроса
//
Функция ТекстЗапросаВыводимыхПриборовУчетаБезУказанияКонечныхПоказаний()
	
	Текст = ОбщегоНазначения.РазделительПакетаЗапросов() + 
	"ВЫБРАТЬ
	|	СтабильныеПериодыПоказания.ПериодНачисления КАК ПериодНачисления,
	|	СтабильныеПериодыПоказания.Организация КАК Организация,
	|	СтабильныеПериодыПоказания.Район КАК Район,
	|	СтабильныеПериодыПоказания.ЧастныйСектор КАК ЧастныйСектор,
	|	СтабильныеПериодыПоказания.Строение КАК Строение,
	|	СтабильныеПериодыПоказания.Помещение КАК Помещение,
	|	СтабильныеПериодыПоказания.ДокРегистратор КАК ДокРегистратор,
	|	СтабильныеПериодыПоказания.ПриборУчета КАК ПриборУчета,
	|	СтабильныеПериодыПоказания.Шкала КАК Шкала,
	|	СтабильныеПериодыПоказания.ТарифнаяЗона КАК ТарифнаяЗона
	|ПОМЕСТИТЬ СтабильныеПериодыНачалоВыведенныеПриборы
	|ИЗ
	|	СтабильныеПериодыПоказания КАК СтабильныеПериодыПоказания
	|ГДЕ
	|	СтабильныеПериодыПоказания.ПризнакВыводимогоПрибора
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтабильныеПериодыНачалоВыведенныеПриборы.Организация КАК Организация,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.ПериодНачисления КАК ПериодНачисления,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.Район КАК Район,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.ЧастныйСектор КАК ЧастныйСектор,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.Строение КАК Строение,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.Помещение КАК Помещение,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВыводимыеПриборыУчетаБезУказанияПоказаний
	|ИЗ
	|	СтабильныеПериодыНачалоВыведенныеПриборы КАК СтабильныеПериодыНачалоВыведенныеПриборы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПредоставленныеПоказания КАК ПредоставленныеПоказания
	|		ПО СтабильныеПериодыНачалоВыведенныеПриборы.ПериодНачисления = ПредоставленныеПоказания.ПериодНачисления
	|			И СтабильныеПериодыНачалоВыведенныеПриборы.Организация = ПредоставленныеПоказания.Организация
	|			И СтабильныеПериодыНачалоВыведенныеПриборы.Район = ПредоставленныеПоказания.Район
	|			И СтабильныеПериодыНачалоВыведенныеПриборы.ЧастныйСектор = ПредоставленныеПоказания.ЧастныйСектор
	|			И СтабильныеПериодыНачалоВыведенныеПриборы.Строение = ПредоставленныеПоказания.Строение
	|			И СтабильныеПериодыНачалоВыведенныеПриборы.Помещение = ПредоставленныеПоказания.Помещение
	|			И СтабильныеПериодыНачалоВыведенныеПриборы.ПриборУчета = ПредоставленныеПоказания.ПриборУчета
	|			И СтабильныеПериодыНачалоВыведенныеПриборы.Шкала = ПредоставленныеПоказания.Шкала
	|			И СтабильныеПериодыНачалоВыведенныеПриборы.ТарифнаяЗона = ПредоставленныеПоказания.ТарифнаяЗона
	|			И СтабильныеПериодыНачалоВыведенныеПриборы.ДокРегистратор = ПредоставленныеПоказания.ДокРегистратор
	|
	|СГРУППИРОВАТЬ ПО
	|	СтабильныеПериодыНачалоВыведенныеПриборы.Организация,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.ПериодНачисления,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.Район,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.ЧастныйСектор,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.Строение,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.Помещение,
	|	СтабильныеПериодыНачалоВыведенныеПриборы.ПриборУчета
	|
	|ИМЕЮЩИЕ
	|	МИНИМУМ(ВЫБОР
	|			КОГДА ПредоставленныеПоказания.ПериодНачисления ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ) = ЛОЖЬ";
	
	Возврат Текст;
	
КонецФункции
	
#КонецОбласти

#Область ПроверкаОграниченияВозобновленияРежимаПотребления

Функция ТекстЗапросаТочекОграничениеИВозобновлениеПроизошедшееВОдномМесяце()
	
	Текст = ОбщегоНазначения.РазделительПакетаЗапросов() +
	
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СтабильныеПериоды.Организация КАК Организация,
	|	СтабильныеПериоды.ПериодНачисления КАК ПериодНачисления,
	|	СтабильныеПериоды.Район КАК Район,
	|	СтабильныеПериоды.ЧастныйСектор КАК ЧастныйСектор,
	|	СтабильныеПериоды.Строение КАК Строение,
	|	СтабильныеПериоды.Помещение КАК Помещение,
	|	СтабильныеПериоды.ТочкаУчета КАК ТочкаУчета,
	|	СтабильныеПериоды.Услуга КАК Услуга,
	|	СтабильныеПериоды.ПриборУчета КАК ПриборУчета,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СтабильныеПериоды.ТипЗначенияДокРегистратора = ТИП(Документ.энргОперацияСУслугами)
	|					И СтабильныеПериоды.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ОграничениеРежимаПотребления)
	|				ТОГДА СтабильныеПериоды.ДокРегистратор
	|			ИНАЧЕ НЕОПРЕДЕЛЕНО
	|		КОНЕЦ) КАК ДокРегистраторОграничение,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СтабильныеПериоды.ТипЗначенияДокРегистратора = ТИП(Документ.энргОперацияСУслугами)
	|					И СтабильныеПериоды.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления)
	|				ТОГДА СтабильныеПериоды.ДокРегистратор
	|			ИНАЧЕ НЕОПРЕДЕЛЕНО
	|		КОНЕЦ) КАК ДокРегистраторВозобновление,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СтабильныеПериоды.ТипЗначенияДокРегистратора = ТИП(Документ.энргОперацияСУслугами)
	|					И СтабильныеПериоды.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ОграничениеРежимаПотребления)
	|				ТОГДА СтабильныеПериоды.ПериодРегистрации
	|			ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|		КОНЕЦ) КАК ПериодРегистрацииОграничение,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СтабильныеПериоды.ТипЗначенияДокРегистратора = ТИП(Документ.энргОперацияСУслугами)
	|					И СтабильныеПериоды.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления)
	|				ТОГДА СтабильныеПериоды.ПериодРегистрации
	|			ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|		КОНЕЦ) КАК ПериодРегистрацииВозобновление,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СтабильныеПериоды.ТипЗначенияДокРегистратора = ТИП(Документ.энргОперацияСУслугами)
	|					И СтабильныеПериоды.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ОграничениеРежимаПотребления)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ) КАК ЕстьОграничение,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СтабильныеПериоды.ТипЗначенияДокРегистратора = ТИП(Документ.энргОперацияСУслугами)
	|					И СтабильныеПериоды.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ) КАК ЕстьВозобновление
	|ПОМЕСТИТЬ ОграничениеИВозобновлениеПроизошедшееВОдномМесяце
	|ИЗ
	|	СтабильныеПериодыНачало КАК СтабильныеПериоды
	|
	|СГРУППИРОВАТЬ ПО
	|	СтабильныеПериоды.Организация,
	|	СтабильныеПериоды.ПериодНачисления,
	|	СтабильныеПериоды.Район,
	|	СтабильныеПериоды.ЧастныйСектор,
	|	СтабильныеПериоды.Строение,
	|	СтабильныеПериоды.Помещение,
	|	СтабильныеПериоды.ТочкаУчета,
	|	СтабильныеПериоды.Услуга,
	|	СтабильныеПериоды.ПриборУчета
	|
	|ИМЕЮЩИЕ
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СтабильныеПериоды.ТипЗначенияДокРегистратора = ТИП(Документ.энргОперацияСУслугами)
	|					И СтабильныеПериоды.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ОграничениеРежимаПотребления)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ) = ИСТИНА И
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СтабильныеПериоды.ТипЗначенияДокРегистратора = ТИП(Документ.энргОперацияСУслугами)
	|					И СтабильныеПериоды.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ) = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Организация КАК Организация,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПериодНачисления КАК ПериодНачисления,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Район КАК Район,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ЧастныйСектор КАК ЧастныйСектор,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Строение КАК Строение,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Помещение КАК Помещение,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ТочкаУчета КАК ТочкаУчета,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Услуга КАК Услуга,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПриборУчета КАК ПриборУчета,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ДокРегистраторОграничение КАК ДокРегистраторОграничение,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ДокРегистраторВозобновление КАК ДокРегистраторВозобновление,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПериодРегистрацииОграничение КАК ПериодРегистрацииОграничение,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПериодРегистрацииВозобновление КАК ПериодРегистрацииВозобновление,
	|	МИНИМУМ(ВЫБОР
	|			КОГДА ПериодыПоказаний.НачалоПериодДействия <= ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПериодРегистрацииОграничение
	|					И ПериодыПоказаний.ПоказанияТекущегоПериода
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ) КАК ДосчитыватьСреднееНормативДоОграничения,
	|	МИНИМУМ(ВЫБОР
	|			КОГДА ПериодыПоказаний.НачалоПериодДействия >= ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПериодРегистрацииВозобновление
	|					И ПериодыПоказаний.ПоказанияТекущегоПериода
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ) КАК ДосчитыватьСреднееНормативПослеВозобновления
	|ПОМЕСТИТЬ ПризнакиПредоставленияПоказанийПриборовОРПВОдномМесяце
	|ИЗ
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце КАК ОграничениеИВозобновлениеПроизошедшееВОдномМесяце
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПериодыПоказаний КАК ПериодыПоказаний
	|		ПО ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Организация = ПериодыПоказаний.Организация
	|			И ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПериодНачисления = ПериодыПоказаний.ПериодНачисления
	|			И ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Район = ПериодыПоказаний.Район
	|			И ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ЧастныйСектор = ПериодыПоказаний.ЧастныйСектор
	|			И ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Строение = ПериодыПоказаний.Строение
	|			И ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Помещение = ПериодыПоказаний.Помещение
	|			И ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПриборУчета = ПериодыПоказаний.ПриборУчета
	|
	|СГРУППИРОВАТЬ ПО
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ЧастныйСектор,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Район,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПериодРегистрацииОграничение,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Организация,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ДокРегистраторОграничение,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ТочкаУчета,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ДокРегистраторВозобновление,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Строение,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Помещение,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПериодНачисления,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.Услуга,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПриборУчета,
	|	ОграничениеИВозобновлениеПроизошедшееВОдномМесяце.ПериодРегистрацииВозобновление";
	
	Текст = Текст + ОбщегоНазначения.РазделительПакетаЗапросов();
	
	Возврат Текст;
	
КонецФункции
	
#КонецОбласти

#Область ПереопределениеНачальныхПоказанийПриВозобновленииУслуги

// Функция - Переопределяет начальные показания в момент начисления по возобновлению услуги, 
//				т.к. начальные показания берутся от даты документа до следующего, а надо от 	
//				предыдущих показаний принятых к учету
// Возвращаемое значение:
//  Строка - Текст запроса
//
Функция ТекстЗапросаПереопределениеНачальныхПоказанийПриВозобновленииУслуги()
	
	Текст = ОбщегоНазначения.РазделительПакетаЗапросов() + 
	
	"ВЫБРАТЬ
	|	ДанныеДляРасчетаПередНормой.ПериодНачисления КАК ПериодНачисления,
	|	ДанныеДляРасчетаПередНормой.Организация КАК Организация,
	|	ДанныеДляРасчетаПередНормой.Район КАК Район,
	|	ДанныеДляРасчетаПередНормой.ЧастныйСектор КАК ЧастныйСектор,
	|	ДанныеДляРасчетаПередНормой.Строение КАК Строение,
	|	ДанныеДляРасчетаПередНормой.Помещение КАК Помещение,
	|	ДанныеДляРасчетаПередНормой.СледующийРегистратор КАК СледующийРегистратор,
	|	ДанныеДляРасчетаПередНормой.ТочкаУчета КАК ТочкаУчета,
	|	ДанныеДляРасчетаПередНормой.ПриборУчета КАК ПриборУчета,
	|	ДанныеДляРасчетаПередНормой.Шкала КАК Шкала,
	|	ДанныеДляРасчетаПередНормой.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ДанныеДляРасчетаПередНормой.НачальныеПоказания КАК НачальныеПоказания
	|ПОМЕСТИТЬ ПереопределениеНачальныхПоказанийПриВозобновленииУслуги
	|ИЗ
	|	ДанныеДляРасчетаПередНормой КАК ДанныеДляРасчетаПередНормой
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ДанныеДляРасчетаПередНормой.СледующийРегистратор) = ТИП(Документ.энргОперацияСУслугами)
	|	И ВЫРАЗИТЬ(ДанныеДляРасчетаПередНормой.СледующийРегистратор КАК Документ.энргОперацияСУслугами).ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления)";
	
	Текст = Текст + ОбщегоНазначения.РазделительПакетаЗапросов();
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#Область НачисленияПоПриборам

Процедура ДобавитьРасчетОбъемаУслугиПоПриборам(Схема,ВыбираемыеПоля, ВычисляемыеПоля, МВТ, ТаблицаДанныеДляРасчета)
		
	ПереопределяемыеПоля 	= Новый Структура;
	ПереопределяемыеПоля.Вставить("ОбъемУслуги", 				"__РасходПоПоказаниям__");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленный",	"0");
	ПереопределяемыеПоля.Вставить("ЗначениеТарифа", 			"__ЗначениеТарифаПоПриборам__");
	ПереопределяемыеПоля.Вставить("ЗначениеТарифаРЭК", 			"__ЗначениеТарифаРЭКПоПриборам__");
	ПереопределяемыеПоля.Вставить("Сумма", 						"__РасходПоПоказаниям__ * __ЗначениеТарифаПоПриборам__");
	ПереопределяемыеПоля.Вставить("ПовыщающийКоэффициент", 		"1");
	ПереопределяемыеПоля.Вставить("СниматьНачисленныйСредний", 	"НЕ НачислятьПоПрибору");
	ПереопределяемыеПоля.Вставить("СпособНачисления", 			"ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.ПоПриборам)");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормы", 
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА -1
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __РасходПоПоказаниям__ * ( __КоличествоЧеловек__ *  Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ		
	|КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормыРасчетныйСпособ",
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__* ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __РасходПоПоказаниям__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");         	
	
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотери",				"__РасходПоПоказаниям__ * (Псевдоним.ПотериПроцент / 100) + Псевдоним.ПотериОбъем");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленныйПотери",	"0");
	
	ПодставитьВычисляемыПоля(Схема, МВТ, ТаблицаДанныеДляРасчета, ВыбираемыеПоля, ВычисляемыеПоля, ПереопределяемыеПоля);
	
	Условия = Новый Массив;
	Условия.Добавить("ПриборВведен");
	Условия.Добавить("ЕстьПоказанияАбонента");
	Условия.Добавить("НЕ ОбъемЗаПрошлыйГод");
	Условия.Добавить("НЕ СпособРаспределенияОбъемаПомещения = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем)");
	// лишнее условие: если отключить ТУ с ПУ от 1 числа с расходом = 0, то начисления нет и не снимает среднее!!!
	//Условия.Добавить(
	//"ВЫБОР
	//|	КОГДА АбонентЗакрытВТекущемПериоде 
	//|		ТОГДА ИСТИНА
	//|	КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ДанныеДляРасчета.НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(ДанныеДляРасчета.КонецПериода, ДЕНЬ), ДЕНЬ) = 0					
	//|		ТОГДА __РасходПоПоказаниям__ > 0
	//|	ИНАЧЕ ИСТИНА
	//|КОНЕЦ");
	
	// Условие не лишнее: если происходит смена тарифной категории от 1 числа месяца, то расход по ней 0 и эта строка лишняя,
	// Она мешает распределять объемы на комнаты в коммуналках - берет старый тариф из этой строки
	Условия.Добавить(
	"ВЫБОР
	|	КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ДанныеДляРасчета.НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(ДанныеДляРасчета.КонецПериода, ДЕНЬ), ДЕНЬ) = 0					
	|		И Не СледующийРегистратор Ссылка Документ.энргОперацияСЛицевымСчетом И Не СледующийРегистратор Ссылка Документ.энргОперацияСУслугами И Не СледующийРегистратор Ссылка Документ.энргОперацияСПриборомУчета
	|		ТОГДА __РасходПоПоказаниям__ > 0
	|	ИНАЧЕ ИСТИНА
	|КОНЕЦ");
	
	// Условие не лишнее: если происходит смена собственника с датой факта, то при начислении в текущем периоде его начислять не надо
	Условия.Добавить(
	"ВЫБОР
	|	КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ДанныеДляРасчета.НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(ДанныеДляРасчета.КонецПериода, ДЕНЬ), ДЕНЬ) = 0					
	|		И СледующийРегистратор Ссылка Документ.энргОперацияСЛицевымСчетом
	|		И ВЫРАЗИТЬ(СледующийРегистратор КАК Документ.энргОперацияСЛицевымСчетом).ДатаФактическогоСобытия <> ДатаВремя(1,1,1)
	|		И ВЫРАЗИТЬ(СледующийРегистратор КАК Документ.энргОперацияСЛицевымСчетом).ДатаФактическогоСобытия < НачалоОП
	|		ТОГДА ЛОЖЬ
	|	ИНАЧЕ ИСТИНА
	|КОНЕЦ");
	
	Условия.Добавить("ПоказанияВСрок");
	Условия.Добавить("НЕ НаличиеНеисправногоПУ");
	Условия.Добавить("НЕ СрокПоверкиИстек");
	
	
	Пакет 		= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 	= Пакет.Операторы[Пакет.Операторы.Количество()-1];
	ДобавитьУсловияОператораЗапроса(Оператор.Отбор,Условия,ВычисляемыеПоля, ТаблицаДанныеДляРасчета);
	
КонецПроцедуры

Процедура ДобавитьРасчетОбъемаПотребленногоПоПриборам(Схема,ВыбираемыеПоля, ВычисляемыеПоля,МВТ, ТаблицаДанныеДляРасчета)
		
	ПереопределяемыеПоля = Новый Структура;
	ПереопределяемыеПоля.Вставить("ОбъемУслуги", 				"0");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленный", 	"__РасходПоПоказаниям__");
	ПереопределяемыеПоля.Вставить("ЗначениеТарифа",				"__ЗначениеТарифаПоПриборам__");
	ПереопределяемыеПоля.Вставить("Сумма", 						"0");
	ПереопределяемыеПоля.Вставить("ПовыщающийКоэффициент", 		"1");
	ПереопределяемыеПоля.Вставить("СниматьНачисленныйСредний", 	"НЕ НачислятьПоПриборуПотребленный");
	ПереопределяемыеПоля.Вставить("СпособНачисления", 			"ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.ПоПриборам)");
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормы", 
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА -1
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __РасходПоПоказаниям__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормыРасчетныйСпособ",
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __РасходПоПоказаниям__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления  + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");
	
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотери",				"0");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленныйПотери",	"__РасходПоПоказаниям__ * (Псевдоним.ПотериПроцент / 100) + Псевдоним.ПотериОбъем");
	
	ПодставитьВычисляемыПоля(Схема, МВТ, ТаблицаДанныеДляРасчета, ВыбираемыеПоля, ВычисляемыеПоля, ПереопределяемыеПоля);
	
	Условия = Новый Массив;
	Условия.Добавить("ПриборВведен");
	Условия.Добавить("ЕстьПоказанияАбонента");
	Условия.Добавить("НЕ СпособРаспределенияОбъемаПомещения = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем)");
	Условия.Добавить(
	"ВЫБОР
	|	КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ДанныеДляРасчета.НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(ДанныеДляРасчета.КонецПериода, ДЕНЬ), ДЕНЬ) = 0					
	|		И Не СледующийРегистратор Ссылка Документ.энргОперацияСЛицевымСчетом И Не СледующийРегистратор Ссылка Документ.энргОперацияСУслугами И Не СледующийРегистратор Ссылка Документ.энргОперацияСПриборомУчета
	|		ТОГДА __РасходПоПоказаниям__ > 0
	|	ИНАЧЕ ИСТИНА
	|КОНЕЦ");
	
	//Условия.Добавить(
	//"ВЫБОР
	//|	КОГДА АбонентЗакрытВТекущемПериоде 
	//|		ТОГДА ИСТИНА
	//|	КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ДанныеДляРасчета.НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(ДанныеДляРасчета.КонецПериода, ДЕНЬ), ДЕНЬ) = 0					
	//|		ТОГДА __РасходПоПоказаниям__ > 0
	//|	ИНАЧЕ ИСТИНА
	//|КОНЕЦ");
	
	// Условие не лишнее: если происходит смена собственника с датой факта, то при начислении в текущем периоде его начислять не надо
	Условия.Добавить(
	"ВЫБОР
	|	КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ДанныеДляРасчета.НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(ДанныеДляРасчета.КонецПериода, ДЕНЬ), ДЕНЬ) = 0					
	|		И СледующийРегистратор Ссылка Документ.энргОперацияСЛицевымСчетом
	|		И ВЫРАЗИТЬ(СледующийРегистратор КАК Документ.энргОперацияСЛицевымСчетом).ДатаФактическогоСобытия <> ДатаВремя(1,1,1)
	|		И ВЫРАЗИТЬ(СледующийРегистратор КАК Документ.энргОперацияСЛицевымСчетом).ДатаФактическогоСобытия < НачалоОП
	|		ТОГДА ЛОЖЬ
	|	ИНАЧЕ ИСТИНА
	|КОНЕЦ");
	
	Условия.Добавить("ПоказанияВСрок");
	Условия.Добавить("НЕ НаличиеНеисправногоПУ");
	Условия.Добавить("НЕ СрокПоверкиИстек");
	
	Пакет 		= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 	= Пакет.Операторы[Пакет.Операторы.Количество()-1];
	ДобавитьУсловияОператораЗапроса(Оператор.Отбор,Условия,ВычисляемыеПоля, ТаблицаДанныеДляРасчета);
	
КонецПроцедуры

#КонецОбласти

#Область НачисленияПоНормативу

Процедура ДобавитьРасчетОбъемаУслугиПоНормативу(Схема,ВыбираемыеПоля,ВычисляемыеПоля,МВТ,ТаблицаДанныеДляРасчета)
	
	ПереопределяемыеПоля 	= Новый Структура;
		
	ПереопределяемыеПоля.Вставить("ПриборУчета", 				"ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)");
	ПереопределяемыеПоля.Вставить("Шкала", 						"ЗНАЧЕНИЕ(Справочник.энргШкалыПриборовУчета.Основная)");
	ПереопределяемыеПоля.Вставить("ТарифнаяЗона", 				"ЗНАЧЕНИЕ(Справочник.энргТарифныеЗоны.БезРазбивки)");
	ПереопределяемыеПоля.Вставить("НачальныеПоказания", 		"0");
	ПереопределяемыеПоля.Вставить("КонечныеПоказания", 			"0");
	
	ПереопределяемыеПоля.Вставить("ОбъемУслуги", 				
	"__ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__* __КоэффициентДляНачисленияСреднегоДляПотомка__");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленный",	"0");
	ПереопределяемыеПоля.Вставить("ЗначениеТарифа", 			"ЗначениеТарифаБезРазбивки");
	ПереопределяемыеПоля.Вставить("ЗначениеТарифаРЭК", 			"__ЗначениеТарифаРЭКПоПриборам__");
	ПереопределяемыеПоля.Вставить("Сумма", 						
	"__ОбъемУслугиПоНорме__ * ЗначениеТарифа * __ДлительностьПериодаПоНормативу__");
	ПереопределяемыеПоля.Вставить("СниматьНачисленныйСредний", 	"ЛОЖЬ");
	ПереопределяемыеПоля.Вставить("СпособНачисления", 			"ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.ПоНормативу)");
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормы", 
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА -1
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормыРасчетныйСпособ",
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА __ОбъемУслугиПоНорме__ *  __ДлительностьПериодаПоНормативу__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА  __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотери",				"0");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленныйПотери",	"0");
	
	ПодставитьВычисляемыПоля(Схема, МВТ, ТаблицаДанныеДляРасчета, ВыбираемыеПоля, ВычисляемыеПоля, ПереопределяемыеПоля);
	
	Условия = Новый Массив;
	Условия.Добавить("НЕ КоэффициентСезоности = 0");
	Условия.Добавить(
	"ВЫБОР
	|		КОГДА Псевдоним.ОбъемЗаПрошлыйГод
	|				И ВЫБОР
	|					КОГДА Псевдоним.ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
	|						ТОГДА Псевдоним.ЕстьСреднийПоВсемТочкамУслуги
	|					ИНАЧЕ Псевдоним.ЕстьСреднийПоВсемТочкамУслугиЗависитОтУслуги
	|				КОНЕЦ
	|			ТОГДА ЛОЖЬ
	|		КОГДА НЕ Псевдоним.ПриборВведен
	|					И Псевдоним.ТочкаУчетаРодитель <> ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|				ТОГДА ВЫБОР
	
	|						КОГДА НЕ Псевдоним.УслугаПолностьюОприборена И Не Псевдоним.ЕстьСреднийПоВсемТочкамУслугиРодителя
	|							ТОГДА ИСТИНА
	
	|						КОГДА Псевдоним.ТочкаУчетаРодительБезПоказаний ЕСТЬ NULL
	|							ТОГДА ИСТИНА
	|						ИНАЧЕ ЛОЖЬ
	|					КОНЕЦ
	
	|		КОГДА Псевдоним.ПриборВведен И Не Псевдоним.УслугаПолностьюОприборена И Не Псевдоним.ЕстьСреднийПоВсемТочкамУслуги
	|			ТОГДА ИСТИНА
	
	|		КОГДА Псевдоним.ПриборВведен
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ Псевдоним.СреднийОбъем < 0 И НЕ ПоказанияВСрок 
	|	КОНЕЦ");
	Условия.Добавить("НачислятьНорму 
	|ИЛИ НЕ ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)");
	Условия.Добавить("РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(КонецПериода, ДЕНЬ), ДЕНЬ) >= 1");
	//Условия.Добавить("НЕ СпособРаспределенияОбъемаПомещения = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем)");
	Условия.Добавить("НЕ РасчетТолькоПоПоказаниям");
	
	Пакет 		= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 	= Пакет.Операторы[Пакет.Операторы.Количество()-1];
	ДобавитьУсловияОператораЗапроса(Оператор.Отбор,Условия,ВычисляемыеПоля, ТаблицаДанныеДляРасчета);
	
КонецПроцедуры

Процедура ДобавитьРасчетОбъемаПотребленногоПоНормативу(Схема,ВыбираемыеПоля,ВычисляемыеПоля,МВТ,ТаблицаДанныеДляРасчета)
	
	ПереопределяемыеПоля 	= Новый Структура;
		
	ПереопределяемыеПоля.Вставить("ПриборУчета", 				"ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)");
	ПереопределяемыеПоля.Вставить("Шкала", 						"ЗНАЧЕНИЕ(Справочник.энргШкалыПриборовУчета.Основная)");
	ПереопределяемыеПоля.Вставить("ТарифнаяЗона", 				"ЗНАЧЕНИЕ(Справочник.энргТарифныеЗоны.БезРазбивки)");
	ПереопределяемыеПоля.Вставить("НачальныеПоказания", 		"0");
	ПереопределяемыеПоля.Вставить("КонечныеПоказания", 			"0");
	
	ПереопределяемыеПоля.Вставить("ОбъемУслуги", 				"0");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленный",	
	"__ОбъемУслугиПотребленныйПоНорме__ * __ДлительностьПериодаПоНормативуОбъемПотребленный__");
	ПереопределяемыеПоля.Вставить("Сумма", 						"0");
	ПереопределяемыеПоля.Вставить("СниматьНачисленныйСредний", 	"ЛОЖЬ");
	ПереопределяемыеПоля.Вставить("СпособНачисления", 			"ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.ПоНормативу)");
	ПереопределяемыеПоля.Вставить("НормаПотребления", 			"ВЫРАЗИТЬ(Псевдоним.НормаПотребления * Псевдоним.КоэффициентНорматива КАК  ЧИСЛО(15,6))");
	ПереопределяемыеПоля.Вставить("ЗначениеТарифа", 			"ЗначениеТарифаБезРазбивки");
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормы", 
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА -1
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПотребленныйПоНорме__ * __ДлительностьПериодаПоНормативуОбъемПотребленный__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления)/ Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормыРасчетныйСпособ",
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПотребленныйПоНорме__ * __ДлительностьПериодаПоНормативуОбъемПотребленный__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");
	
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотери",				"0");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленныйПотери",	"0");
	
	ПодставитьВычисляемыПоля(Схема, МВТ, ТаблицаДанныеДляРасчета, ВыбираемыеПоля, ВычисляемыеПоля, ПереопределяемыеПоля);
	
	Условия = Новый Массив;
	Условия.Добавить("НЕ КоэффициентСезоностиОбъемПотребленный = 0");
	Условия.Добавить(
	"ВЫБОР
	|		КОГДА НЕ Псевдоним.ПриборВведен
	|					И Псевдоним.ТочкаУчетаРодитель <> ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|				ТОГДА ВЫБОР
	
	|						КОГДА НЕ Псевдоним.УслугаПолностьюОприборена И Не Псевдоним.ЕстьСреднийПотребленныйПоВсемТочкамУслугиРодителя
	|							ТОГДА ИСТИНА

	|						КОГДА Псевдоним.ТочкаУчетаРодительБезПоказаний ЕСТЬ NULL
	|							ТОГДА ИСТИНА
	|						ИНАЧЕ ЛОЖЬ
	|					КОНЕЦ
	
	|		КОГДА Псевдоним.ПриборВведен И Не Псевдоним.УслугаПолностьюОприборена И Не Псевдоним.ЕстьСреднийПоВсемТочкамУслуги
	|			ТОГДА ИСТИНА

	|		КОГДА Псевдоним.ПриборВведен
	|			ТОГДА ЛОЖЬ
	|	ИНАЧЕ Псевдоним.СреднийОбъемПотребленный < 0 И НЕ ПоказанияВСрок
	|КОНЕЦ");
	
	
	Условия.Добавить("НачислятьНорму 
	|ИЛИ НЕ ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)");
	Условия.Добавить("РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(КонецПериода, ДЕНЬ), ДЕНЬ) >= 1");
	Условия.Добавить("НЕ СпособРаспределенияОбъемаПомещения = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем)");
	Условия.Добавить("НЕ РасчетТолькоПоПоказаниям");
	
	Пакет 		= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 	= Пакет.Операторы[Пакет.Операторы.Количество()-1];
	ДобавитьУсловияОператораЗапроса(Оператор.Отбор,Условия,ВычисляемыеПоля, ТаблицаДанныеДляРасчета);
	
КонецПроцедуры

Функция РассчитатьОбъемУслугиСтроктНабораПоНормативу(СтрокаНабора)
	МКД 											= ?(СтрокаНабора.ЧастныйСектор,Истина,Ложь);
	КоэффициентНормативаНеПрименятьСезонность 		= 0;
	
	Если СтрокаНабора.НеПрименятьСезонность Тогда
		КоэффициентНормативаНеПрименятьСезонность 	= СтрокаНабора.КоэффициентНормативаНеПрименятьСезонность;
	Иначе
		КоэффициентНормативаНеПрименятьСезонность 	= СтрокаНабора.КоэффициентНорматива;
	КонецЕсли;
	
	НаЧтоУмножаемНорматив  							= 0;
	Если СтрокаНабора.НаправлениеИспользованияТУ = Справочники.энргНаправлениеИспользованияТочекУчета.ПустаяСсылка()
		и СтрокаНабора.ЕстьИзмерителиНаправления Тогда
		НаЧтоУмножаемНорматив 						= СтрокаНабора.КоличествоИзмеретелейНаправления;
	ИначеЕсли НЕ СтрокаНабора.ВидПлощади = Перечисления.энргВидыПлощадей.ПустаяСсылка() Тогда
		НаЧтоУмножаемНорматив 						= СтрокаНабора.ЗначениеПлощади;
	ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаНабора.Абонент) Тогда
		НаЧтоУмножаемНорматив 						= СтрокаНабора.КоличествоЖильцов;
	ИначеЕсли НЕ СтрокаНабора.КоличествоПроживающих = 0 Тогда
		НаЧтоУмножаемНорматив 						= СтрокаНабора.КоличествоПроживающих;
	ИначеЕсли НЕ СтрокаНабора.КоличествоПрописанных = 0 Тогда
		НаЧтоУмножаемНорматив 						= СтрокаНабора.КоличествоПрописанных;
	Иначе
		НаЧтоУмножаемНорматив 						= СтрокаНабора.КоличествоСобственников;
	КонецЕсли;
	
	КоэффициентСдерживанияРостаПлаты 				= 0;
	Если СтрокаНабора.ИспользоватьКоэффициентСдерживанияРостаПлаты И МКД Тогда
		Если СтрокаНабора.ПлощадьАбонентов - СтрокаНабора.ПлощадьСобственнаяПоставка + СтрокаНабора.ПлощадьМОП = 0 Тогда
			КоэффициентСдерживанияРостаПлаты 		= 0;
		Иначе
			КоэффициентСдерживанияРостаПлаты 		= (СтрокаНабора.ПлощадьАбонентов - СтрокаНабора.ПлощадьСобственнаяПоставка) / (СтрокаНабора.ПлощадьАбонентов - СтрокаНабора.ПлощадьСобственнаяПоставка + СтрокаНабора.ПлощадьМОП);
		КонецЕсли;
	Иначе
		КоэффициентСдерживанияРостаПлаты 			= 1;
	КонецЕсли;
	
	Возврат СтрокаНабора.КоэффициентСезоности * Окр(СтрокаНабора.НормаПотребления * КоэффициентНормативаНеПрименятьСезонность,6) * НаЧтоУмножаемНорматив * КоэффициентСдерживанияРостаПлаты;
			
КонецФункции

#КонецОбласти

#Область НачисленияПоСреднемуНормативу

Процедура ДобавитьРасчетОбъемаУслугиПоСреднемуНормативуЗаПрошлыйГод(Схема,ВыбираемыеПоля, ВычисляемыеПоля, МВТ, ТаблицаДанныеДляРасчета)
	
	ПереопределяемыеПоля 	= Новый Структура;
		
	ПереопределяемыеПоля.Вставить("ОбъемУслуги", 				
	"__ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * __КоэффициентДляНачисленияСреднего__");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленный",	"0");
	ПереопределяемыеПоля.Вставить("Сумма", 						
	"__ОбъемУслугиПоНорме__ * ЗначениеТарифа * __ДлительностьПериодаПоНормативу__");
	ПереопределяемыеПоля.Вставить("СниматьНачисленныйСредний", 	"ЛОЖЬ");
	ПереопределяемыеПоля.Вставить("СпособНачисления", 			"ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.СреднееПоНормативу)");
	ПереопределяемыеПоля.Вставить("НачальныеПоказания", 		"0");
	ПереопределяемыеПоля.Вставить("КонечныеПоказания", 			"0");
	ПереопределяемыеПоля.Вставить("ПовыщающийКоэффициент", 		"1");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормы", 
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА -1
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА  __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормыРасчетныйСпособ",
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");
	
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотери",				"0");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленныйПотери",	"0");
	
	ПодставитьВычисляемыПоля(Схема, МВТ, ТаблицаДанныеДляРасчета, ВыбираемыеПоля, ВычисляемыеПоля, ПереопределяемыеПоля);
		
	Условия 				= Новый Массив;
	Условия.Добавить("НЕ КоэффициентСезоности = 0");
	Условия.Добавить("ОбъемЗаПрошлыйГод");
	Условия.Добавить("НачислятьНорму");
	Условия.Добавить("ПриборВведен");
	//Условия.Добавить("РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(КонецПериода, ДЕНЬ), ДЕНЬ) >= 1");
	Условия.Добавить(
	"ВЫБОР
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСУслугами
	|		И ВыводПрибораУчетаБезУказанияПоказаний	
	|		ТОГДА ИСТИНА
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСПриборомУчета
	|		И ВыводПрибораУчетаБезУказанияПоказаний
	|		ТОГДА ИСТИНА
	|	ИНАЧЕ ДанныеДляРасчета.РазностьДатГраницПериода >= 1
	|КОНЕЦ");
	Условия.Добавить("НЕ СпособРаспределенияОбъемаПомещения = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем)");
	Условия.Добавить("НЕ РасчетТолькоПоПоказаниям");
	Условия.Добавить(
	"ВЫБОР
	|		КОГДА Псевдоним.ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
	|			ТОГДА НЕ Псевдоним.ЕстьСреднийПоВсемТочкамУслуги
	|		ИНАЧЕ НЕ Псевдоним.ЕстьСреднийПоВсемТочкамУслугиЗависитОтУслуги
	|	КОНЕЦ");
	//Условия.Добавить(
	//"ВЫБОР
	//|		КОГДА Псевдоним.КорректироватьГодовойОбъем И Псевдоним.НеПрименятьСезонность
	//|			ТОГДА Истина
	//|		ИНАЧЕ МожноНачислятьСреднее
	//|	КОНЕЦ");
	
	Пакет 		= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 	= Пакет.Операторы[Пакет.Операторы.Количество()-1];
	ДобавитьУсловияОператораЗапроса(Оператор.Отбор,Условия,ВычисляемыеПоля,ТаблицаДанныеДляРасчета);
	
КонецПроцедуры

Процедура ДобавитьРасчетОбъемаУслугиПоСреднемуНормативу(Схема,ВыбираемыеПоля, ВычисляемыеПоля, МВТ, ТаблицаДанныеДляРасчета)
	
	ПереопределяемыеПоля 	= Новый Структура;
		
	ПереопределяемыеПоля.Вставить("ОбъемУслуги", 				
	"__ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * __КоэффициентДляНачисленияСреднего__");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленный",	"0");
	ПереопределяемыеПоля.Вставить("Сумма", 						
	"__ОбъемУслугиПоНорме__ * ЗначениеТарифаБезРазбивки * __ДлительностьПериодаПоНормативу__");
	ПереопределяемыеПоля.Вставить("СниматьНачисленныйСредний", 	"__СниматьНачисленныйСреднийСреднееПоНормативу__");
	ПереопределяемыеПоля.Вставить("СпособНачисления", 			"ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.СреднееПоНормативу)");
	ПереопределяемыеПоля.Вставить("НачальныеПоказания", 		"0");
	ПереопределяемыеПоля.Вставить("КонечныеПоказания", 			"0");
	ПереопределяемыеПоля.Вставить("ПовыщающийКоэффициент", 		"__ПовышающийКоэффициентСреднееПоНормативу__");
	ПереопределяемыеПоля.Вставить("ЗначениеТарифа", 			"ЗначениеТарифаБезРазбивки");
	ПереопределяемыеПоля.Вставить("ТарифнаяЗона",		 		"ЗНАЧЕНИЕ(Справочник.энргТарифныеЗоны.БезРазбивки)");
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормы", 
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА -1
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормыРасчетныйСпособ",
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");
	
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотери",				"0");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленныйПотери",	"0");
	
	ПодставитьВычисляемыПоля(Схема, МВТ, ТаблицаДанныеДляРасчета, ВыбираемыеПоля, ВычисляемыеПоля, ПереопределяемыеПоля);
	
	Условия 				= Новый Массив;
	Условия.Добавить("НЕ КоэффициентСезоности = 0");
	Условия.Добавить("НЕ ОбъемЗаПрошлыйГод");
	//Условия.Добавить("ПриборВведен");
	Условия.Добавить(
	"ВЫБОР
	|		КОГДА НЕ Псевдоним.ПриборВведен
	|					И Псевдоним.ТочкаУчетаРодитель <> ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|				ТОГДА ВЫБОР
	
	|						КОГДА НЕ Псевдоним.УслугаПолностьюОприборена И Не Псевдоним.ЕстьСреднийПоВсемТочкамУслугиРодителя
	|							ТОГДА ЛОЖЬ
	
	|						КОГДА Псевдоним.ТочкаУчетаРодительБезПоказаний ЕСТЬ NULL
	|							ТОГДА ЛОЖЬ
	|						ИНАЧЕ ИСТИНА
	|					КОНЕЦ
	
	|		КОГДА Псевдоним.ПриборВведен И Не Псевдоним.УслугаПолностьюОприборена И Не Псевдоним.ЕстьСреднийПоВсемТочкамУслуги
	|			ТОГДА ЛОЖЬ
	
	// если вывели ПУ, то остаток месяца надо считать по ПоСреднемуНормативу
	|			КОГДА НЕ Псевдоним.ПриборВведен  
	|					И ПоказанияВСрок
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Псевдоним.ПриборВведен
	|		КОНЕЦ");
	Условия.Добавить("НачислятьНорму 
	|ИЛИ НЕ ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)");
	Условия.Добавить("Не ПоказанияВСрок ИЛИ СрокПоверкиИстек ИЛИ НЕ ПриборВведен И ПоказанияВСрок");
	//Условия.Добавить("РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(КонецПериода, ДЕНЬ), ДЕНЬ) >= 1");
	Условия.Добавить(
	"ВЫБОР
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСУслугами
	|		И ВыводПрибораУчетаБезУказанияПоказаний	
	|		ТОГДА ИСТИНА
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСПриборомУчета
	|		И ВыводПрибораУчетаБезУказанияПоказаний
	|		ТОГДА ИСТИНА
	|	ИНАЧЕ ДанныеДляРасчета.РазностьДатГраницПериода >= 1
	|КОНЕЦ");
	Условия.Добавить("НЕ СпособРаспределенияОбъемаПомещения = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем)");
	Условия.Добавить("НЕ РасчетТолькоПоПоказаниям");
	Условия.Добавить(
	"ВЫБОР
	|		КОГДА Псевдоним.ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
	|			ТОГДА НЕ Псевдоним.ЕстьСреднийПоВсемТочкамУслуги
	|		ИНАЧЕ НЕ Псевдоним.ЕстьСреднийПоВсемТочкамУслугиЗависитОтУслуги
	|	КОНЕЦ");
	//Условия.Добавить(
	//"ВЫБОР
	//|		КОГДА Псевдоним.КорректироватьГодовойОбъем И Псевдоним.НеПрименятьСезонность
	//|			ТОГДА Истина
	//|		ИНАЧЕ МожноНачислятьСреднее
	//|	КОНЕЦ");
	

	Пакет 		= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 	= Пакет.Операторы[Пакет.Операторы.Количество()-1];
	ДобавитьУсловияОператораЗапроса(Оператор.Отбор,Условия,ВычисляемыеПоля,ТаблицаДанныеДляРасчета);
	
КонецПроцедуры

Процедура ДобавитьРасчетОбъемаПотребленногоПоСреднемуНормативу(Схема,ВыбираемыеПоля, ВычисляемыеПоля, МВТ, ТаблицаДанныеДляРасчета)
	
	ПереопределяемыеПоля 	= Новый Структура;
		
	ПереопределяемыеПоля.Вставить("ОбъемУслуги", 				"0");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленный",	
	"__ОбъемУслугиПотребленныйПоНорме__ * __ДлительностьПериодаПоНормативу__ * __КоэффициентДляНачисленияСреднего__"); 	
	ПереопределяемыеПоля.Вставить("Сумма", 						"0");
	ПереопределяемыеПоля.Вставить("СниматьНачисленныйСредний", 	"__СниматьНачисленныйСреднийСреднееПоНормативу__");
	ПереопределяемыеПоля.Вставить("СпособНачисления", 			"ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.СреднееПоНормативу)");
	ПереопределяемыеПоля.Вставить("НачальныеПоказания", 		"0");
	ПереопределяемыеПоля.Вставить("КонечныеПоказания", 			"0");
	ПереопределяемыеПоля.Вставить("ПовыщающийКоэффициент", 		"__ПовышающийКоэффициентСреднееПоНормативу__");
	ПереопределяемыеПоля.Вставить("ЗначениеТарифа",		 		"ЗначениеТарифаБезРазбивки");
	ПереопределяемыеПоля.Вставить("ТарифнаяЗона",		 		"ЗНАЧЕНИЕ(Справочник.энргТарифныеЗоны.БезРазбивки)");
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормы", 
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА -1
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА  __ОбъемУслугиПотребленныйПоНорме__ * __ДлительностьПериодаПоНормативу__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормыРасчетныйСпособ",
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА  __ОбъемУслугиПотребленныйПоНорме__ * __ДлительностьПериодаПоНормативу__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");
	
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотери",				"0");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленныйПотери",	"0");
	
	ПодставитьВычисляемыПоля(Схема, МВТ, ТаблицаДанныеДляРасчета, ВыбираемыеПоля, ВычисляемыеПоля, ПереопределяемыеПоля);
		
	Условия 				= Новый Массив;
	Условия.Добавить("НЕ КоэффициентСезоностиОбъемПотребленный = 0");
	//Условия.Добавить("ПриборВведен");
	Условия.Добавить(
	"ВЫБОР
	|		КОГДА НЕ Псевдоним.ПриборВведен
	|					И Псевдоним.ТочкаУчетаРодитель <> ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|				ТОГДА ВЫБОР
	
	|						КОГДА НЕ Псевдоним.УслугаПолностьюОприборена И Не Псевдоним.ЕстьСреднийПоВсемТочкамУслугиРодителя
	|							ТОГДА ЛОЖЬ
	
	|						КОГДА Псевдоним.ТочкаУчетаРодительБезПоказаний ЕСТЬ NULL
	|							ТОГДА ЛОЖЬ
	|						ИНАЧЕ ИСТИНА
	|					КОНЕЦ
	
	|		КОГДА Псевдоним.ПриборВведен И Не Псевдоним.УслугаПолностьюОприборена И Не Псевдоним.ЕстьСреднийПоВсемТочкамУслуги
	|			ТОГДА ЛОЖЬ

	|			КОГДА НЕ Псевдоним.ПриборВведен
	|					И ПоказанияВСрок
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Псевдоним.ПриборВведен
	|		КОНЕЦ");


	Условия.Добавить("НачислятьНорму 
	|ИЛИ НЕ ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)");
	Условия.Добавить("Не ПоказанияВСрок ИЛИ СрокПоверкиИстек ИЛИ НЕ ПриборВведен И ПоказанияВСрок");
	//Условия.Добавить("РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(КонецПериода, ДЕНЬ), ДЕНЬ) >= 1");
	Условия.Добавить(
	"ВЫБОР
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСУслугами
	|		И ВыводПрибораУчетаБезУказанияПоказаний	
	|		ТОГДА ИСТИНА
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСПриборомУчета
	|		И ВыводПрибораУчетаБезУказанияПоказаний
	|		ТОГДА ИСТИНА
	|	ИНАЧЕ ДанныеДляРасчета.РазностьДатГраницПериода >= 1
	|КОНЕЦ");
	Условия.Добавить("НЕ СпособРаспределенияОбъемаПомещения = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем)");
	Условия.Добавить("НЕ РасчетТолькоПоПоказаниям");
	Условия.Добавить(
	"ВЫБОР
	|		КОГДА Псевдоним.ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
	|			ТОГДА НЕ Псевдоним.ЕстьСреднийПотребленныйПоВсемТочкамУслуги
	|		ИНАЧЕ НЕ Псевдоним.ЕстьСреднийПотребленныйПоВсемТочкамУслугиЗависитОтУслуги
	|	КОНЕЦ");
	//Условия.Добавить(
	//"ВЫБОР
	//|		КОГДА Псевдоним.КорректироватьГодовойОбъем И Псевдоним.НеПрименятьСезонность
	//|			ТОГДА Истина
	//|		ИНАЧЕ МожноНачислятьСреднее
	//|	КОНЕЦ");
	
	Пакет 		= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 	= Пакет.Операторы[Пакет.Операторы.Количество()-1];
	ДобавитьУсловияОператораЗапроса(Оператор.Отбор,Условия, ВычисляемыеПоля,ТаблицаДанныеДляРасчета);
	
КонецПроцедуры

#КонецОбласти

#Область НачисленияПоСреднему

Процедура ДобавитьРасчетОбъемаУслугиПоСреднемуЗаПрошлыйГод(Схема,ВыбираемыеПоля, ВычисляемыеПоля, МВТ, ТаблицаДанныеДляРасчета)
	
	ПереопределяемыеПоля 	= Новый Структура;
		
	ПереопределяемыеПоля.Вставить("ОбъемУслуги", 				"__ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * __КоэффициентДляНачисленияСреднего__");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленный",	"0");
	ПереопределяемыеПоля.Вставить("Сумма", 						"__ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * ЗначениеТарифа");
	ПереопределяемыеПоля.Вставить("СниматьНачисленныйСредний", 	"ЛОЖЬ");
	ПереопределяемыеПоля.Вставить("СпособНачисления", 			"ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.НачислениеПоСреднему)");
	ПереопределяемыеПоля.Вставить("НачальныеПоказания", 		"0");
	ПереопределяемыеПоля.Вставить("КонечныеПоказания", 			"0");
	ПереопределяемыеПоля.Вставить("ПовыщающийКоэффициент", 		"1");
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормы", 
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА -1
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормыРасчетныйСпособ",
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");
	
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотери",				"__ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * (Псевдоним.ПотериПроцент / 100) + Псевдоним.ПотериОбъем");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленныйПотери",	"0");
	
	ПодставитьВычисляемыПоля(Схема, МВТ, ТаблицаДанныеДляРасчета, ВыбираемыеПоля, ВычисляемыеПоля, ПереопределяемыеПоля);
		
	Условия 	= Новый Массив;
	Условия.Добавить("НЕ КоэффициентСезоности = 0");
	Условия.Добавить("ОбъемЗаПрошлыйГод");
	//Условия.Добавить("РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(КонецПериода, ДЕНЬ), ДЕНЬ) >= 1");
	Условия.Добавить(
	"ВЫБОР
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСУслугами
	|		И ВыводПрибораУчетаБезУказанияПоказаний	
	|		ТОГДА ИСТИНА
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСПриборомУчета
	|		И ВыводПрибораУчетаБезУказанияПоказаний
	|		ТОГДА ИСТИНА
	|	ИНАЧЕ ДанныеДляРасчета.РазностьДатГраницПериода >= 1
	|КОНЕЦ");
	
	Условия.Добавить("НЕ СпособРаспределенияОбъемаПомещения = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем)");
	Условия.Добавить("НЕ РасчетТолькоПоПоказаниям");
	Условия.Добавить(
	"ВЫБОР
	|		КОГДА Псевдоним.ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
	|			ТОГДА Псевдоним.ЕстьСреднийПоВсемТочкамУслуги
	|		ИНАЧЕ Псевдоним.ЕстьСреднийПоВсемТочкамУслугиЗависитОтУслуги
	|	КОНЕЦ");
	//Условия.Добавить(
	//"ВЫБОР
	//|		КОГДА Псевдоним.КорректироватьГодовойОбъем И Псевдоним.НеПрименятьСезонность
	//|			ТОГДА Истина
	//|		ИНАЧЕ МожноНачислятьСреднее
	//|	КОНЕЦ");
	
	Пакет 		= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 	= Пакет.Операторы[Пакет.Операторы.Количество()-1];
	ДобавитьУсловияОператораЗапроса(Оператор.Отбор,Условия,ВычисляемыеПоля,ТаблицаДанныеДляРасчета);
	
КонецПроцедуры

Процедура ДобавитьРасчетОбъемаУслугиПоСреднему(Схема,ВыбираемыеПоля, ВычисляемыеПоля, МВТ, ТаблицаДанныеДляРасчета)
	
	ПереопределяемыеПоля 	= Новый Структура;
		
	ПереопределяемыеПоля.Вставить("ОбъемУслуги", 				"__ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * __КоэффициентДляНачисленияСреднего__");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленный",	"0");
	ПереопределяемыеПоля.Вставить("Сумма", 						"__ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * ЗначениеТарифа");
	ПереопределяемыеПоля.Вставить("СниматьНачисленныйСредний", 	
	"ВЫБОР 
	|		КОГДА НЕ ПриборВведен
	|			ТОГДА ЛОЖЬ
	|		КОГДА ВыводПрибораУчетаБезУказанияПоказаний
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА 
	|	КОНЕЦ");
	ПереопределяемыеПоля.Вставить("СпособНачисления", 			"ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.НачислениеПоСреднему)");
	ПереопределяемыеПоля.Вставить("НачальныеПоказания", 		"0");
	ПереопределяемыеПоля.Вставить("КонечныеПоказания", 			"0");
	ПереопределяемыеПоля.Вставить("ПовыщающийКоэффициент", 		"1");
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормы", 
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА -1
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");	
	ПереопределяемыеПоля.Вставить("ЗначениеСоциальнойНормыРасчетныйСпособ",
	"ВЫБОР
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.ПустаяСсылка)
	|			ТОГДА __ОбъемУслугиПоНорме__ * __ДлительностьПериодаПоНормативу__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		КОГДА Псевдоним.СпособОпределенияСоциальнойНормы = ЗНАЧЕНИЕ(Перечисление.энргСпособыОпределенияСоциальнойНормы.СоциальнаяНормаРавнаНормативуПотребления)
	|			ТОГДА __ОбъемУслугиПоНорме__ * ВЫБОР
	|					КОГДА Псевдоним.НормативПоДням
	|							И НЕ Псевдоним.НеПрименятьСезонность
	|						ТОГДА Псевдоним.ДнейВПериоде
	|					ИНАЧЕ 1 
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ Псевдоним.ЗначениеПлощади = 0
	|					ТОГДА __ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * (__КоличествоЧеловек__ * Псевдоним.СоциальнаяНормаПотребления + Псевдоним.ДопСоциальнаяНормаПотребления) / Псевдоним.ЗначениеПлощади
	|				ИНАЧЕ 0
	|			 КОНЕЦ
	|	КОНЕЦ");
	
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотери",				"__ОбъемУслугиПоСреднему__ * __ДлительностьПериода__ * (Псевдоним.ПотериПроцент / 100) + Псевдоним.ПотериОбъем");
	ПереопределяемыеПоля.Вставить("ОбъемУслугиПотребленныйПотери",	"0");
	
	ПодставитьВычисляемыПоля(Схема, МВТ, ТаблицаДанныеДляРасчета, ВыбираемыеПоля, ВычисляемыеПоля, ПереопределяемыеПоля);
		
	Условия 				= Новый Массив;
	Условия.Добавить("НЕ КоэффициентСезоности = 0");
	Условия.Добавить("НЕ ОбъемЗаПрошлыйГод");
	Условия.Добавить("
	|ВЫБОР
	|	КОГДА ПриборВведен
	|		ТОГДА НЕ ДанныеДляРасчета.ПоказанияВСрок Или ДанныеДляРасчета.СрокПоверкиИстек 
	|	ИНАЧЕ ДанныеДляРасчета.СреднийОбъем >= 0 
	|КОНЕЦ");	
	//Условия.Добавить("РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(НачалоПериода, ДЕНЬ), НАЧАЛОПЕРИОДА(КонецПериода, ДЕНЬ), ДЕНЬ) >= 1");
	Условия.Добавить(
	"ВЫБОР
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСУслугами
	|		И ВыводПрибораУчетаБезУказанияПоказаний	
	|		ТОГДА ИСТИНА
	|	КОГДА ДанныеДляРасчета.РазностьДатГраницПериода = 0					
	|		И СледующийРегистратор ССЫЛКА Документ.энргОперацияСПриборомУчета
	|		И ВыводПрибораУчетаБезУказанияПоказаний
	|		ТОГДА ИСТИНА
	|	ИНАЧЕ ДанныеДляРасчета.РазностьДатГраницПериода >= 1
	|КОНЕЦ");
	
	Условия.Добавить("НЕ СпособРаспределенияОбъемаПомещения = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОбъема.ФиксированныйОбъем)");
	Условия.Добавить("НЕ РасчетТолькоПоПоказаниям");
	Условия.Добавить(
	"ВЫБОР
	|		КОГДА Псевдоним.ЗависитОтУслуги = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
	|			ТОГДА Псевдоним.ЕстьСреднийПоВсемТочкамУслуги
	|		ИНАЧЕ Псевдоним.ЕстьСреднийПоВсемТочкамУслугиЗависитОтУслуги
	|	КОНЕЦ");	
	//Условия.Добавить(
	//"ВЫБОР
	//|		КОГДА Псевдоним.КорректироватьГодовойОбъем И Псевдоним.НеПрименятьСезонность
	//|			ТОГДА Истина
	//|		ИНАЧЕ МожноНачислятьСреднее
	//|	КОНЕЦ");
	
	Пакет 		= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 	= Пакет.Операторы[Пакет.Операторы.Количество()-1];
	ДобавитьУсловияОператораЗапроса(Оператор.Отбор,Условия,ВычисляемыеПоля,ТаблицаДанныеДляРасчета);
	
КонецПроцедуры

