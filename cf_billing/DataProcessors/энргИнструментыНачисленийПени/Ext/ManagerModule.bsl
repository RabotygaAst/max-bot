КонецФункции

Процедура ОтменитьОперациюНачисленийПени(Организация,ПериодНачисления,Район,МКД)
	Запрос  		= Новый Запрос;
	Запрос.Текст 	= 
	"ВЫБРАТЬ
	|	энргНачислениеПени.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.энргНачислениеПени КАК энргНачислениеПени
	|ГДЕ
	|	НЕ энргНачислениеПени.ПометкаУдаления
	|	И энргНачислениеПени.Район = &Район
	|	И энргНачислениеПени.Организация = &Организация
	|	И НАЧАЛОПЕРИОДА(энргНачислениеПени.Дата, МЕСЯЦ) = &ПериодНачисления
	|	И энргНачислениеПени.МКД = &Строение";
	
	Запрос.УстановитьПараметр("Организация", 				Организация);
	Запрос.УстановитьПараметр("Район", 						Район);
    Запрос.УстановитьПараметр("Строение", 					МКД);
	Запрос.УстановитьПараметр("ПериодНачисления", 			ПериодНачисления);
		
	Результат	= Запрос.Выполнить();
	
	ВыборкаДокументыОтменить 					= Результат.Выбрать();
	Пока ВыборкаДокументыОтменить.Следующий() Цикл				
		ДокументОбъектОтменить					= ВыборкаДокументыОтменить.Ссылка.ПолучитьОбъект();
		ДокументОбъектОтменить.УстановитьПометкуУдаления(Истина);
	КонецЦикла;		
		
КонецПроцедуры

#Область ТекЗапросов_НачислениеПени

Функция ВернутьТекстЗапросаНачисленияПени(НеНачислятьПениПриОтсутствииДолгаНаКонецПериода) 
	Текст = "";
	
	Если НеНачислятьПениПриОтсутствииДолгаНаКонецПериода Тогда
		Текст = 
		"ВЫБРАТЬ
		|	энргВзаиморасчетыПоМесяцамОстатки.Район КАК Район,
		|	энргВзаиморасчетыПоМесяцамОстатки.МКД КАК МКД,
		|	энргВзаиморасчетыПоМесяцамОстатки.Абонент КАК Абонент,
		|	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
		|	СУММА(энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток) КАК СуммаОстаток
		|ПОМЕСТИТЬ АбонентыСДолгамиНаКонецПериода
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
		|			&КонецПериода,
		|			Организация = &Организация
		|				И Район = &Район
		|				И МКД = &МКД
		|				И ПериодНачисления >= &НачалоУчетаДолга) КАК энргВзаиморасчетыПоМесяцамОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	энргВзаиморасчетыПоМесяцамОстатки.Район,
		|	энргВзаиморасчетыПоМесяцамОстатки.МКД,
		|	энргВзаиморасчетыПоМесяцамОстатки.Абонент,
		|	энргВзаиморасчетыПоМесяцамОстатки.Услуга
		|
		|ИМЕЮЩИЕ
		|	СУММА(энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток) > 0" + "
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|"; 
		
	КонецЕсли;	
	
	Текст = Текст +  
	
	"ВЫБРАТЬ
	|	&Район КАК Район,
	|	НЕОПРЕДЕЛЕНО КАК МКД,
	|	НЕОПРЕДЕЛЕНО КАК Абонент,
	|	НЕОПРЕДЕЛЕНО КАК Услуга,
	|	НЕОПРЕДЕЛЕНО КАК ПериодНачисления,
	|	СтавкиРефинансирования.Период КАК Период,
	|	СтавкиРефинансирования.Коэффициент КАК ЗначениеСтавкиРефинансирования
	|ПОМЕСТИТЬ ДополнительныеПериоды
	|ИЗ
	|	РегистрСведений.энргСтавкиРефинансирования КАК СтавкиРефинансирования
	|ГДЕ
	|	СтавкиРефинансирования.Организация = &Организация
	|	И СтавкиРефинансирования.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргНастройкиРасчетаПениПоУслугамСрезПоследних.Организация КАК Организация,
	|	энргНастройкиРасчетаПениПоУслугамСрезПоследних.Район КАК Район,
	|	энргНастройкиРасчетаПениПоУслугамСрезПоследних.Услуга КАК Услуга
	|ПОМЕСТИТЬ УслугиБезПени
	|ИЗ
	|	РегистрСведений.энргНастройкиРасчетаПениПоУслугам.СрезПоследних(
	|			&НачалоПериода,
	|			Организация = &Организация
	|				И Район = &Район) КАК энргНастройкиРасчетаПениПоУслугамСрезПоследних
	|ГДЕ
	|	энргНастройкиРасчетаПениПоУслугамСрезПоследних.НеНачислятьПеню
