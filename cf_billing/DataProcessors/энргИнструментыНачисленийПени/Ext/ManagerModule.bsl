/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////    АКТУАЛЬНЫЙ РАСЧЕТ В МОДУЛЕ ОБЪЕКТА    //////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

Процедура НачислитьПеню(Организация,ПериодНачисления,Район,МКД,Абонент,Документ, ВосстанавливатьВзаиморасчеты = Истина) Экспорт 
	
	// Обратная совместимость
	ВходныеПараметры = Новый Структура;
	ВходныеПараметры.Вставить("Организация", Организация);
	ВходныеПараметры.Вставить("ПериодНачисления", ПериодНачисления);
	ВходныеПараметры.Вставить("Район", Район);
	ВходныеПараметры.Вставить("МКД", МКД);
	энргНачисления.НачислитьПеню(ВходныеПараметры, Абонент, Документ);
	Возврат;
	
	РассчитыватьНаТекущуюДату = Ложь;
	
	ТекущаяДатаНачислений = ТекущаяДата();
	
	НачислятьПеню = Константы.энргНачислятьПеню.Получить();
	
	Если не НачислятьПеню тогда		
		Возврат;
	КонецЕсли;
	
	Если МКД = Неопределено тогда
		НачислитьПенюПоСпискуМКДВсегоРайона(Организация, ПериодНачисления, Район);
		Возврат;
		МКД = Справочники.энргСтроения.ПустаяСсылка();
	КонецЕсли;	
	
	ГраницыПериодаНачисления 	= Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация, Район, ПериодНачисления, Ложь);	
	МВТ 						= Новый МенеджерВременныхТаблиц;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.Организация КАК Организация,
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.ПериодНачалаУчетаПени КАК ПериодНачалаУчетаПени,
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.ПериодНачалаУчетаДолга КАК ПериодНачалаУчетаДолга,
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.НеНачислятьПениПриОтсутствииДолгаНаКонецПериода КАК НеНачислятьПениПриОтсутствииДолгаНаКонецПериода
	|ИЗ
	|	РегистрСведений.энргНастройкаНачалаРасчетаПени.СрезПоследних(, Организация = &Организация) КАК энргНастройкаНачалаРасчетаПениСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргНастройкаРасчетаПениСрезПоследних.НастройкаРасчета КАК НастройкаРасчета,
	|	энргНастройкаРасчетаПениСрезПоследних.РасчетПоТекущейСтавке КАК РасчетПоТекущейСтавке
	|ИЗ
	|	РегистрСведений.энргНастройкаРасчетаПени.СрезПоследних(&Период, Организация = &Организация) КАК энргНастройкаРасчетаПениСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргНастройкиНачисленияПениСрезПоследних.ГлубинаОтсрочки КАК ГлубинаОтсрочки,
	|	энргНастройкиНачисленияПениСрезПоследних.КрайнийСрокОплаты КАК КрайнийСрокОплаты,
	|	энргНастройкиНачисленияПениСрезПоследних.МаксимальнаяГлубинаЗадолженности КАК МаксимальнаяГлубинаЗадолженности,
	|	энргНастройкиНачисленияПениСрезПоследних.РассчитыватьНаТекущуюДату КАК РассчитыватьНаТекущуюДату
	|ИЗ
	|	РегистрСведений.энргНастройкиНачисленияПени.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район) КАК энргНастройкиНачисленияПениСрезПоследних";
	
	Запрос.УстановитьПараметр("Период", ГраницыПериодаНачисления.ЗавершениеОП-1);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Если РезультатЗапроса[0].Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена информация по началу расчета пени,
		|	 Начисление пени не может быть выполнено");
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Выборка.Следующий();
	НачалоРасчетаПени 	= Выборка.ПериодНачалаУчетаПени;
	НачалоУчетаДолга 	= Выборка.ПериодНачалаУчетаДолга;
	НеНачислятьПениПриОтсутствииДолгаНаКонецПериода 	= Выборка.НеНачислятьПениПриОтсутствииДолгаНаКонецПериода;
	
	Если РезультатЗапроса[1].Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены настройки расчет пени, Начисление пени не может быть выполнено");
		Возврат;
	КонецЕсли;
	Выборка = РезультатЗапроса[1].Выбрать();
	Выборка.Следующий();
	
	// Расчет по текущей ставке реф.
	РасчетПоТекущейСтавке = Выборка.РасчетПоТекущейСтавке;
	
	НастройкиРасчетаПени = Выборка.НастройкаРасчета.Получить();
	
	МаксЗначение = 0;
	Соответствие = Новый Соответствие;
	РангКоэффициента = 1;
	Для каждого Строка Из НастройкиРасчетаПени Цикл
		Если Строка.До = 0 Тогда
			НСтр = Новый Структура;
			НСтр.Вставить("Числитель", Строка.Числитель);
			НСтр.Вставить("Знаменатель", Строка.Знаменатель);
			НСтр.Вставить("РангКоэффициента", РангКоэффициента);
			
			Соответствие.Вставить(Строка.До, НСтр);
		Иначе
			Для Сч = Строка.От По Строка.До Цикл
				НСтр = Новый Структура;
				НСтр.Вставить("Числитель", Строка.Числитель);
				НСтр.Вставить("Знаменатель", Строка.Знаменатель);
				НСтр.Вставить("РангКоэффициента", РангКоэффициента);		
				Соответствие.Вставить(Сч, НСтр);	
				МаксЗначение = Макс(МаксЗначение, Сч);
			КонецЦикла;
		КонецЕсли;
		
		РангКоэффициента = РангКоэффициента + 1;
	КонецЦикла;
	
	НастройкиСтавокРефинансирования = ПолучитьСтавкиРефинансирования(ГраницыПериодаНачисления.НачалоОП, ГраницыПериодаНачисления.ЗавершениеОП, Организация, МВТ, РасчетПоТекущейСтавке);
	Если НастройкиСтавокРефинансирования.Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена информация по ставке рефинансирования,
		|	 Начисление пени не может быть выполнено");
		Возврат;
	КонецЕсли;
	
	Если РезультатЗапроса[2].Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены настройки начисления пени, Начисление пени не может быть выполнено");
		Возврат;
	КонецЕсли;
	Выборка = РезультатЗапроса[2].Выбрать();
	Выборка.Следующий();
	ГлубинаОтсрочки 					= Выборка.ГлубинаОтсрочки;
	КрайнийСрокОплаты 					= Выборка.КрайнийСрокОплаты;
	МаксимальнаяГлубинаЗадолженности 	= Выборка.МаксимальнаяГлубинаЗадолженности;
	
	КонецПериода = ГраницыПериодаНачисления.ЗавершениеОП;
	
	Если ГраницыПериодаНачисления.ПериодНачисления > НачалоМесяца(ТекущаяДатаНачислений) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущаяДатаНачислений < ГраницыПериодаНачисления.ЗавершениеОП И ТекущаяДатаНачислений > ГраницыПериодаНачисления.НачалоОП Тогда
		
		Если Выборка.РассчитыватьНаТекущуюДату Тогда
			
			РассчитыватьНаТекущуюДату = Истина;
			
			ГраницыПериодаНачисления.ЗавершениеОП = НачалоДня(ТекущаяДатаНачислений);
			ГраницыПериодаНачисления.ДнейВПериоде = (ГраницыПериодаНачисления.ЗавершениеОП - ГраницыПериодаНачисления.НачалоОП) / (60 * 60 * 24);
			
		КонецЕсли;
		
	КонецЕсли;
		
	// Настройки начисления пени.
	Выборка = РезультатЗапроса[2].Выбрать();
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = ВернутьТекстЗапросаНачисленияПени(НеНачислятьПениПриОтсутствииДолгаНаКонецПериода);	
	
	Запрос.УстановитьПараметр("ГлубинаОтсрочки", 			ГлубинаОтсрочки);
	Запрос.УстановитьПараметр("КонецПериода", 				ГраницыПериодаНачисления.ЗавершениеОП);
	Запрос.УстановитьПараметр("КонецПериодаДляДокумента",	КонецПериода - 1);
	Запрос.УстановитьПараметр("КрайнийСрокОплаты", 			КрайнийСрокОплаты);
	Запрос.УстановитьПараметр("МКД", 						МКД);
	Запрос.УстановитьПараметр("НачалоПериода", 				ГраницыПериодаНачисления.НачалоОП);
	Запрос.УстановитьПараметр("Организация", 				Организация);
	Запрос.УстановитьПараметр("Район", 						Район);
	Запрос.УстановитьПараметр("НачалоУчетаДолга", 			НачалоУчетаДолга);
	Запрос.УстановитьПараметр("РасчетПоТекущейСтавке", 		РасчетПоТекущейСтавке);
	Запрос.УстановитьПараметр("ЗавершениеОП", 				ГраницыПериодаНачисления.ЗавершениеОП-1);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ОтменитьОперациюНачисленийПени(Организация,ПериодНачисления,Район,МКД);
	КонецЕсли;
	
 	НаборНачислениеПени = Неопределено;
	ДокументОбъект = Неопределено; 	
	
	ВыборкаДокументНачисления = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	СменаСтавкиВПериоде = СменаСтавкиВПериоде(Организация, ГраницыПериодаНачисления.НачалоОП, ГраницыПериодаНачисления.ЗавершениеОП-1);	
	Пока ВыборкаДокументНачисления.Следующий() Цикл
		
		Если ЗначениеЗаполнено(ВыборкаДокументНачисления.ДокументНачисления) Тогда
			ДокументОбъект = ВыборкаДокументНачисления.ДокументНачисления.ПолучитьОбъект();
		иначе
			ДокументОбъект = Документы.энргНачислениеПени.СоздатьДокумент();
			ДокументОбъект.Район = Район;
			ДокументОбъект.МКД = МКД;
			ДокументОбъект.Организация = Организация;
			ДокументОбъект.ПериодНачисления = ПериодНачисления;
		КонецЕсли;
		
		//ДокументОбъект.Дата = ГраницыПериодаНачисления.ЗавершениеОП-1;
		ДокументОбъект.Дата = КонецПериода - 1;
		
		ДокументОбъект.ПометкаУдаления = Ложь;
		ДокументОбъект.Ответственный = Пользователи.ТекущийПользователь();
		ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		
		НаборНачислениеПени					= РегистрыНакопления.энргНачислениеПени.СоздатьНаборЗаписей();
		НаборНачислениеПени.Отбор.Регистратор.Установить(ДокументОбъект.Ссылка);
		НаборНачислениеПени.Записать();  	
		
		НовНабор = ДокументОбъект.Движения.энргНачислениеПени;
		
		Если ПериодНачисления < НачалоРасчетаПени  Или  ПериодНачисления < НачалоУчетаДолга Тогда 
			Продолжить;
		КонецЕсли;
		
		ВыборкаПериодНачисления = ВыборкаДокументНачисления.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
		Пока ВыборкаПериодНачисления.Следующий() Цикл
			
			ВыборкаУслуга = ВыборкаПериодНачисления.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
			Пока ВыборкаУслуга.Следующий() Цикл
				ВыборкаАбонент = ВыборкаУслуга.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
				Пока ВыборкаАбонент.Следующий() Цикл
					
					НачалоПериода 				= ВыборкаАбонент.ПериодНачало;
					ПериодНачалоДляРасчета 		= ВыборкаАбонент.ПериодНачало;
					ДнейНаДеньНачалаДляРасчета 	= ?(ВыборкаАбонент.ДнейНаДеньНачала = 0, -1, ВыборкаАбонент.ДнейНаДеньНачала);
					ТекПериод 					= ВыборкаАбонент.ПериодНачало;
					ВыборкаДетальныеЗаписи 		= ВыборкаАбонент.Выбрать();	
					СуммаПени 					= 0;
					ДнейПросрочкиВПериоде 		= 0;
					ДнейПросрочки 				= ВыборкаАбонент.ДнейНаДеньНачала;
					Оплата 						= 0;
					Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 						
						СуммаЗадолженности = ?(ВыборкаДетальныеЗаписи.СуммаНачальныйОстаток = 0, ВыборкаДетальныеЗаписи.СуммаКонечныйОстаток, ВыборкаДетальныеЗаписи.СуммаНачальныйОстаток);
						КоэффициентЧислитель = 1;
						КоэффициентЗнаменатель = 1;
						ПредКоэффициентЧислитель = 1;
						ПредКоэффициентЗнаменатель = 1;
						РангКоэффициента = 0;
						ПредыдущийРанг 						= Неопределено;
						НачисляемПеню 						= Ложь;  						
						
						ЗначениеСтавкиРефинансирования = ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования;
						ПричинаСменаСтавкиВПериоде = Ложь;
						
						Если СменаСтавкиВПериоде.ЕстьСмена и СменаСтавкиВПериоде.Период < ТекПериод Тогда 
							ЗначениеСтавкиРефинансирования = СменаСтавкиВПериоде.Коэффициент;
						КонецЕсли;
						
						Пока НачалоДня(ТекПериод) < НачалоДня(ВыборкаДетальныеЗаписи.Период) И НачалоДня(ТекПериод) < НачалоДня(ВыборкаДетальныеЗаписи.ДатаЗакрытияЛС) Цикл
							ДнейПросрочки 					= ДнейПросрочки + 1;							
							НачисляемПеню 					= Ложь;
							ПараметрыРасчетаИзменены 		= Ложь;
							Мораторий = Ложь;
							СтруктураКоэффициента 			= Соответствие.Получить(?(ДнейПросрочки>МаксЗначение,0,ДнейПросрочки));
							
							Если НЕ СтруктураКоэффициента = Неопределено Тогда
								ПараметрыРасчетаИзменены 	= НЕ КоэффициентЧислитель = СтруктураКоэффициента.Числитель ИЛИ НЕ КоэффициентЗнаменатель = СтруктураКоэффициента.Знаменатель ИЛИ НЕ РангКоэффициента = СтруктураКоэффициента.РангКоэффициента;  
								НачисляемПеню 				= Истина;								
							КонецЕсли;
							
							Если РассчитыватьНаТекущуюДату И ТекПериод = НАЧАЛОДНЯ(ТекущаяДатаНачислений + 60*60*24) Тогда
								ПараметрыРасчетаИзменены = Истина;
							КонецЕсли;
							
							Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ПериодОстановкиРасчетаПени) И ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ПериодВозобновленияРасчетаПени) Тогда
								Если ТекПериод >= НачалоДня(ВыборкаДетальныеЗаписи.ПериодОстановкиРасчетаПени) И ТекПериод < НачалоДня(ВыборкаДетальныеЗаписи.ПериодВозобновленияРасчетаПени + 1) Тогда	
									Мораторий = Истина;	
								КонецЕсли;
							КонецЕсли;
							
							Если НачисляемПеню и СменаСтавкиВПериоде.ЕстьСмена и ТекПериод = СменаСтавкиВПериоде.Период Тогда								
								ПараметрыРасчетаИзменены = Истина;
								ПричинаСменаСтавкиВПериоде = Истина;
							КонецЕсли; 						
							
							
							Если НачисляемПеню и ПараметрыРасчетаИзменены И ДнейПросрочкиВПериоде > 1 Тогда
								НСтр						= НовНабор.Добавить();
								ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
								НСтр.Организация			= Организация;
								НСтр.Район					= Район;
								НСтр.МКД					= МКД;
								НСтр.ПериодРасчета			= ПериодНачисления;
								//НСтр.Период					= КонецПериода-1; 
								НСтр.Период					= ДокументОбъект.Дата; 
								НСтр.ДатаНачисленияПени 	= ТекПериод;
								НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ДнейПросрочки - 1;
								НСтр.КоэффициентЧислитель 	= КоэффициентЧислитель;
								НСтр.КоэффициентЗнаменатель = КоэффициентЗнаменатель;
								НСтр.СуммаЗадолженности 	= СуммаЗадолженности;
								НСтр.ДнейПросрочки 			= ДнейПросрочкиВПериоде;
								//НСтр.СтавкаРефинансирования = ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования;
								НСтр.СтавкаРефинансирования = ЗначениеСтавкиРефинансирования;
								//Если Не Мораторий Тогда
									НСтр.Сумма 					= СуммаПени;
								//Иначе
								//	НСтр.Сумма 					= 0;
								//КонецЕсли;
								НСтр.Оплата	 				= 0;
								НСтр.НачалоПериода 			= НачалоПериода;
								НСтр.КонецПериода 			= ТекПериод - 1;
								
								Если ПричинаСменаСтавкиВПериоде Тогда 
									ЗначениеСтавкиРефинансирования = СменаСтавкиВПериоде.Коэффициент;
								КонецЕсли;
								                                                                                                                   	
								СуммаПени 					= 0;								
								ДнейПросрочкиВПериоде 		= 0;
								НСтр.ДатаНачалаНачисленияПени = ВыборкаДетальныеЗаписи.ДатаНачалаНачисленияПени;
								
								НачалоПериода 	= ТекПериод;
							КонецЕсли; 
							
							Если НЕ СтруктураКоэффициента = Неопределено Тогда
								КоэффициентЧислитель 		= СтруктураКоэффициента.Числитель;
								КоэффициентЗнаменатель 		= СтруктураКоэффициента.Знаменатель;
								РангКоэффициента 			= СтруктураКоэффициента.РангКоэффициента; 								
							КонецЕсли;
							
							Если НачисляемПеню Тогда
								
								//СтавкаРефинансированияДоля	= (ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования/100);
								СтавкаРефинансированияДоля	= (ЗначениеСтавкиРефинансирования/100);
								
								Если Не Мораторий Тогда
									СуммаПени 					= СуммаПени + СуммаЗадолженности * (КоэффициентЧислитель / КоэффициентЗнаменатель) * СтавкаРефинансированияДоля;
									ДнейПросрочкиВПериоде 		= ДнейПросрочкиВПериоде + 1;
								Иначе
									СуммаПени 					= СуммаПени + 0;
									ДнейПросрочкиВПериоде 		= ДнейПросрочкиВПериоде + 0;
								КонецЕсли;

							КонецЕсли;
							
							ТекПериод 						= ТекПериод + 86400;							
						КонецЦикла;
						
						Если НачисляемПеню и СуммаПени > 0  и Не ДнейПросрочки = 0  Тогда
							НСтр						= НовНабор.Добавить();
							ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
							//НСтр.Период					= КонецПериода - 1;
							НСтр.Период					= ДокументОбъект.Дата; 
							НСтр.Организация			= Организация;
							НСтр.Район					= Район;
							НСтр.МКД					= МКД;
							НСтр.ПериодРасчета			= ПериодНачисления;							
							НСтр.ДатаНачисленияПени 	= ТекПериод;										
							НСтр.ДатаНачалаНачисленияПени = ВыборкаДетальныеЗаписи.ДатаНачалаНачисленияПени;
							
							НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ДнейПросрочки;
							НСтр.КоэффициентЧислитель 	= КоэффициентЧислитель;
							НСтр.КоэффициентЗнаменатель = КоэффициентЗнаменатель;
							НСтр.СуммаЗадолженности 	= СуммаЗадолженности;
							НСтр.ДнейПросрочки 			= ДнейПросрочкиВПериоде;
							//НСтр.СтавкаРефинансирования = ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования;							
							НСтр.СтавкаРефинансирования = ЗначениеСтавкиРефинансирования;							
							//Если Не Мораторий Тогда
								НСтр.Сумма 					= СуммаПени;
							//Иначе
							//	НСтр.Сумма 					= 0;
							//КонецЕсли;
							
							//НСтр.Оплата	 				= Оплата;
							НСтр.НачалоПериода 			= НачалоПериода;
							НСтр.КонецПериода 			= ТекПериод - 1;
							
							СуммаПени 					= 0;								
							ДнейПросрочкиВПериоде 		= 0;
						КонецЕсли;
						
						Если Не НачисляемПеню И СтруктураКоэффициента = Неопределено И ВыборкаДетальныеЗаписи.ПериодНачало = ПериодНачисления Тогда 
							НСтр						= НовНабор.Добавить();
							ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
							//НСтр.Период					= КонецПериода - 1;
							НСтр.Период					= ДокументОбъект.Дата; 
							НСтр.Организация			= Организация;
							НСтр.Район					= Район;
							НСтр.МКД					= МКД;
							НСтр.ПериодРасчета			= ПериодНачисления;
							НСтр.ДатаНачисленияПени 	= Дата(1,1,1) ;				
							НСтр.ДатаНачалаНачисленияПени = Дата(1,1,1);						
							НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ДнейПросрочки;
							НСтр.КоэффициентЧислитель 	= 0;
							НСтр.КоэффициентЗнаменатель = 0;
							НСтр.СуммаЗадолженности 	= СуммаЗадолженности;
							НСтр.ДнейПросрочки 			= 0;
							НСтр.СтавкаРефинансирования = 0;							
							НСтр.Сумма	 				= 0;
							НСтр.Оплата	 				= 0;
							НСтр.НачалоПериода 			= НачалоПериода;
							НСтр.КонецПериода 			= ТекПериод - 1;
											
						КонецЕсли;
						
						НачалоПериода 	= ТекПериод;
						Оплата 			= ВыборкаДетальныеЗаписи.Оплата;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		
		
	КонецЦикла;
	
	// Проверка изменения настроек в периоде. При условии, что "РасчетПоТекущейСтавке" = Истина
	Если РасчетПоТекущейСтавке Тогда
		СнятьНачислениеПени(НовНабор, Организация, ГраницыПериодаНачисления.НачалоОП, ГраницыПериодаНачисления.ЗавершениеОП-1, ПериодНачисления, МКД, Район);
		ДоначислитьСуммыПени(НовНабор, Организация, ПериодНачисления,Район, МКД, ГраницыПериодаНачисления.НачалоОП, ГраницыПериодаНачисления.ЗавершениеОП, ГлубинаОтсрочки, КрайнийСрокОплаты, НачалоУчетаДолга, НачалоРасчетаПени);
	КонецЕсли;
	
	
	Если Не НовНабор = Неопределено Тогда 
		НаборЗаписейНачислений = НовНабор.Выгрузить();
		НаборНачислениеПени.Загрузить(НаборЗаписейНачислений);	
		Если Не НаборНачислениеПени = Неопределено и Не НаборНачислениеПени.Количество() = 0 Тогда
			НаборНачислениеПени.Записать();
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
	КонецЕсли;
	
	Абонент = Неопределено;

	Если ВосстанавливатьВзаиморасчеты Тогда 
		ПараметрыОперацииВЗ = Новый Структура("Организация,ПериодНачисления,Район,МКД,Абонент,СписокМКД",Организация,ПериодНачисления,Район,МКД, Абонент);
		энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты(ПараметрыОперацииВЗ);
	КонецЕсли;
	
КонецПроцедуры

#Область НачисленияПоСпискуМКД

Процедура НачислитьПенюПоСпискуМКДВсегоРайона(Организация, ПериодНачисления, Район) Экспорт 
	
	//НачислитьПенюПоСпискуМКДВсегоРайонаМногопоточно(Организация, ПериодНачисления, Район);
	//Возврат;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСтроения.Ссылка КАК МКД
		|ИЗ
		|	Справочник.энргСтроения КАК энргСтроения
		|ГДЕ
		|	энргСтроения.ПометкаУдаления = ЛОЖЬ
		|	И энргСтроения.Район = &Район
		|	И энргСтроения.ТипСтроения = &ТипСтроения
		|	И энргСтроения.Организация = &Организация
		|
		|УПОРЯДОЧИТЬ ПО
		|	МКД";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ТипСтроения", Перечисления.энргТипыСтроений.МКД);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Всего 				= Выборка.Количество();	
	Итерация			= 0;
	КоличествоИтераций 	= Итерация;
	КолвоСообщений		= Цел(Всего / 20);
	Постфикс 			= " из " + Всего;

	ПредставлениеРайон = "" + Район;
	Пока Выборка.Следующий() Цикл
		НачислитьПеню(Организация, ПериодНачисления, Район, Выборка.МКД, Неопределено, Неопределено, Ложь);
		
		Если КоличествоИтераций = КолвоСообщений Тогда
			ЗаписьЖурналаРегистрации(
				"Начисление пени." + ПредставлениеРайон,
				УровеньЖурналаРегистрации.Примечание,,,
				"Начислено " + Итерация + Постфикс);
	
			КоличествоИтераций = 0;
		КонецЕсли;
		
		Итерация = Итерация + 1;
		КоличествоИтераций = КоличествоИтераций + 1;
		
	КонецЦикла;
	
	// по частному
	НачислитьПеню(Организация, ПериодНачисления, Район, Справочники.энргСтроения.ПустаяСсылка(), Неопределено, Неопределено, Ложь);
	
	Абонент = Неопределено;
	
	ПараметрыОперацииВЗ = Новый Структура("Организация,ПериодНачисления,Район,МКД,Абонент,СписокМКД", Организация, ПериодНачисления, Район, Неопределено, Абонент);
	энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты(ПараметрыОперацииВЗ);
	
КонецПроцедуры

Процедура НачислитьПенюПоСпискуМКДВсегоРайонаМногопоточно(Организация, ПериодНачисления, Район) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСтроения.Ссылка КАК МКД,
		|	энргСтроения.Наименование КАК Наименование
		|ИЗ
		|	Справочник.энргСтроения КАК энргСтроения
		|ГДЕ
		|	энргСтроения.ПометкаУдаления = ЛОЖЬ
		|	И энргСтроения.Район = &Район
		|	И энргСтроения.ТипСтроения = &ТипСтроения
		|	И энргСтроения.Организация = &Организация
		|
		|УПОРЯДОЧИТЬ ПО
		|	МКД";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ТипСтроения", Перечисления.энргТипыСтроений.МКД);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Всего 				= Выборка.Количество();	
	Итерация			= 0;
	КоличествоИтераций 	= Итерация;
	КолвоСообщений		= Цел(Всего / 20);
	Постфикс 			= " из " + Всего;

	ПредставлениеРайон = "" + Район;
	
	ИмяМетода = "Обработки.энргИнструментыНачисленийПени.НачислитьПеню";
	ДлительныеОперацииСписок = Новый Массив;
	КоличествоПотоков = 10;
	ИтерацияПотоков = 0;
	
	ПрефиксОперации = "Начисление пени по району: " + ПредставлениеРайон;
	
	Пока Выборка.Следующий() Цикл
		//НачислитьПеню(Организация, ПериодНачисления, Район, Выборка.МКД, Неопределено, Неопределено, Ложь);
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
		ПараметрыВыполнения.ОжидатьЗавершение = 0;
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = ПрефиксОперации + " МКД: " + Выборка.Наименование;
		//ПараметрыВыполнения.Вставить("ИдентификаторФормы", ИдентификаторФормы);
		ДлительнаяОперация = ДлительныеОперации.ВыполнитьПроцедуру(
			ПараметрыВыполнения,
			ИмяМетода,
			Организация, ПериодНачисления, Район, Выборка.МКД, Неопределено, Неопределено, Ложь); 
			
		ДлительныеОперацииСписок.Добавить(ДлительнаяОперация);
		
		Если КоличествоПотоков = ИтерацияПотоков Тогда 
			
			ОжидатьЗавершениеВсехПотоков(ДлительныеОперацииСписок);
			
			ДлительныеОперацииСписок.Очистить();
			ИтерацияПотоков = 0;
			
		КонецЕсли;
		
		
		Если КоличествоИтераций = КолвоСообщений Тогда
			ЗаписьЖурналаРегистрации(
				"Начисление пени." + ПредставлениеРайон,
				УровеньЖурналаРегистрации.Примечание,,,
				"Начислено " + Итерация + Постфикс);
	
			КоличествоИтераций = 0;
		КонецЕсли;
		
		Итерация = Итерация + 1;
		КоличествоИтераций = КоличествоИтераций + 1;
		
		ИтерацияПотоков = ИтерацияПотоков + 1;		
	КонецЦикла;
	
	//// по частному
	//НачислитьПеню(Организация, ПериодНачисления, Район, Справочники.энргСтроения.ПустаяСсылка(), Неопределено, Неопределено, Ложь);
	//
	//Абонент = Неопределено;
	//
	//ПараметрыОперацииВЗ = Новый Структура("Организация,ПериодНачисления,Район,МКД,Абонент", Организация, ПериодНачисления, Район, Неопределено, Абонент);
	//энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты(ПараметрыОперацииВЗ);
	
КонецПроцедуры


Процедура НачислитьПенюПоСпискуМКДВсегоРайонаИтог(Организация,ПериодНачисления,Район,МКД,Абонент,Документ) Экспорт 
	
	РассчитыватьНаТекущуюДату = Ложь;
	
	ТекущаяДатаНачислений = ТекущаяДата();
	
	НачислятьПеню = Константы.энргНачислятьПеню.Получить();
	
	Если не НачислятьПеню тогда		
		Возврат;
	КонецЕсли;
	
	Если МКД = Неопределено тогда
		МКД = Справочники.энргСтроения.ПустаяСсылка();
	КонецЕсли;	
	
	ГраницыПериодаНачисления 	= Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация, Район, ПериодНачисления, Ложь);	
	МВТ 						= Новый МенеджерВременныхТаблиц;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.Организация КАК Организация,
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.ПериодНачалаУчетаПени КАК ПериодНачалаУчетаПени,
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.ПериодНачалаУчетаДолга КАК ПериодНачалаУчетаДолга,
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.НеНачислятьПениПриОтсутствииДолгаНаКонецПериода КАК НеНачислятьПениПриОтсутствииДолгаНаКонецПериода

	|ИЗ
	|	РегистрСведений.энргНастройкаНачалаРасчетаПени.СрезПоследних(, Организация = &Организация) КАК энргНастройкаНачалаРасчетаПениСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргНастройкаРасчетаПениСрезПоследних.НастройкаРасчета КАК НастройкаРасчета,
	|	энргНастройкаРасчетаПениСрезПоследних.РасчетПоТекущейСтавке КАК РасчетПоТекущейСтавке
	|ИЗ
	|	РегистрСведений.энргНастройкаРасчетаПени.СрезПоследних(&Период, ) КАК энргНастройкаРасчетаПениСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргНастройкиНачисленияПениСрезПоследних.ГлубинаОтсрочки КАК ГлубинаОтсрочки,
	|	энргНастройкиНачисленияПениСрезПоследних.КрайнийСрокОплаты КАК КрайнийСрокОплаты,
	|	энргНастройкиНачисленияПениСрезПоследних.МаксимальнаяГлубинаЗадолженности КАК МаксимальнаяГлубинаЗадолженности,
	|	энргНастройкиНачисленияПениСрезПоследних.РассчитыватьНатекущуюДату КАК РассчитыватьНаТекущуюДату
	|ИЗ
	|	РегистрСведений.энргНастройкиНачисленияПени.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район) КАК энргНастройкиНачисленияПениСрезПоследних";
	
	Запрос.УстановитьПараметр("Период", ГраницыПериодаНачисления.ЗавершениеОП-1);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Если РезультатЗапроса[0].Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена информация по началу расчета пени,
		|	 Начисление пени не может быть выполнено");
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Выборка.Следующий();
	НачалоРасчетаПени 	= Выборка.ПериодНачалаУчетаПени;
	НачалоУчетаДолга 	= Выборка.ПериодНачалаУчетаДолга;
	НеНачислятьПениПриОтсутствииДолгаНаКонецПериода	= Выборка.НеНачислятьПениПриОтсутствииДолгаНаКонецПериода;
	
	Если РезультатЗапроса[1].Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены настройки расчет пени, Начисление пени не может быть выполнено");
		Возврат;
	КонецЕсли;
	Выборка = РезультатЗапроса[1].Выбрать();
	Выборка.Следующий();
	
	// Расчет по текущей ставке реф.
	РасчетПоТекущейСтавке = Выборка.РасчетПоТекущейСтавке;
	
	НастройкиРасчетаПени = Выборка.НастройкаРасчета.Получить();
	
	МаксЗначение = 0;
	Соответствие = Новый Соответствие;
	РангКоэффициента = 1;
	Для каждого Строка Из НастройкиРасчетаПени Цикл
		Если Строка.До = 0 Тогда
			НСтр = Новый Структура;
			НСтр.Вставить("Числитель", Строка.Числитель);
			НСтр.Вставить("Знаменатель", Строка.Знаменатель);
			НСтр.Вставить("РангКоэффициента", РангКоэффициента);
			
			Соответствие.Вставить(Строка.До, НСтр);
		Иначе
			Для Сч = Строка.От По Строка.До Цикл
				НСтр = Новый Структура;
				НСтр.Вставить("Числитель", Строка.Числитель);
				НСтр.Вставить("Знаменатель", Строка.Знаменатель);
				НСтр.Вставить("РангКоэффициента", РангКоэффициента);		
				Соответствие.Вставить(Сч, НСтр);	
				МаксЗначение = Макс(МаксЗначение, Сч);
			КонецЦикла;
		КонецЕсли;
		
		РангКоэффициента = РангКоэффициента + 1;
	КонецЦикла;
	
	НастройкиСтавокРефинансирования = ПолучитьСтавкиРефинансирования(ГраницыПериодаНачисления.НачалоОП, ГраницыПериодаНачисления.ЗавершениеОП, Организация, МВТ, РасчетПоТекущейСтавке);
	Если НастройкиСтавокРефинансирования.Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена информация по ставке рефинансирования,
		|	 Начисление пени не может быть выполнено");
		Возврат;
	КонецЕсли;
	
	Если РезультатЗапроса[2].Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены настройки начисления пени, Начисление пени не может быть выполнено");
		Возврат;
	КонецЕсли;
	Выборка = РезультатЗапроса[2].Выбрать();
	Выборка.Следующий();
	ГлубинаОтсрочки 					= Выборка.ГлубинаОтсрочки;
	КрайнийСрокОплаты 					= Выборка.КрайнийСрокОплаты;
	МаксимальнаяГлубинаЗадолженности 	= Выборка.МаксимальнаяГлубинаЗадолженности;
	
	КонецПериода = ГраницыПериодаНачисления.ЗавершениеОП;
	
	Если ГраницыПериодаНачисления.ПериодНачисления > НачалоМесяца(ТекущаяДатаНачислений) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущаяДатаНачислений < ГраницыПериодаНачисления.ЗавершениеОП И ТекущаяДатаНачислений > ГраницыПериодаНачисления.НачалоОП Тогда
		
		Если Выборка.РассчитыватьНаТекущуюДату Тогда
			
			РассчитыватьНаТекущуюДату = Истина;
			
			ГраницыПериодаНачисления.ЗавершениеОП = НачалоДня(ТекущаяДатаНачислений);
			ГраницыПериодаНачисления.ДнейВПериоде = (ГраницыПериодаНачисления.ЗавершениеОП - ГраницыПериодаНачисления.НачалоОП) / (60 * 60 * 24);
			
		КонецЕсли;
		
	КонецЕсли;
		
	// Настройки начисления пени.
	Выборка = РезультатЗапроса[2].Выбрать();
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = ВернутьТекстЗапросаНачисленияПени(НеНачислятьПениПриОтсутствииДолгаНаКонецПериода);	
	
	Запрос.УстановитьПараметр("ГлубинаОтсрочки", 			ГлубинаОтсрочки);
	Запрос.УстановитьПараметр("КонецПериода", 				ГраницыПериодаНачисления.ЗавершениеОП);
	Запрос.УстановитьПараметр("КонецПериодаДляДокумента",	КонецПериода - 1);
	Запрос.УстановитьПараметр("КрайнийСрокОплаты", 			КрайнийСрокОплаты);
	Запрос.УстановитьПараметр("МКД", 						МКД);
	Запрос.УстановитьПараметр("НачалоПериода", 				ГраницыПериодаНачисления.НачалоОП);
	Запрос.УстановитьПараметр("Организация", 				Организация);
	Запрос.УстановитьПараметр("Район", 						Район);
	Запрос.УстановитьПараметр("НачалоУчетаДолга", 			НачалоУчетаДолга);
	Запрос.УстановитьПараметр("РасчетПоТекущейСтавке", 		РасчетПоТекущейСтавке);
	Запрос.УстановитьПараметр("ЗавершениеОП", 				ГраницыПериодаНачисления.ЗавершениеОП-1);
	
	РезультатЗапроса = Запрос.Выполнить();
 
 	НаборНачислениеПени = Неопределено;
	ДокументОбъект = Неопределено; 
	
	
	ВыборкаДокументНачисления = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	СменаСтавкиВПериоде = СменаСтавкиВПериоде(Организация, ГраницыПериодаНачисления.НачалоОП, ГраницыПериодаНачисления.ЗавершениеОП-1);	
	Пока ВыборкаДокументНачисления.Следующий() Цикл
		
		Если ЗначениеЗаполнено(ВыборкаДокументНачисления.ДокументНачисления) Тогда
			ДокументОбъект = ВыборкаДокументНачисления.ДокументНачисления.ПолучитьОбъект();
		иначе
			ДокументОбъект = Документы.энргНачислениеПени.СоздатьДокумент();
			ДокументОбъект.Район = Район;
			ДокументОбъект.МКД = МКД;
			ДокументОбъект.Организация = Организация;
			ДокументОбъект.ПериодНачисления = ПериодНачисления;
		КонецЕсли;
		
		//ДокументОбъект.Дата = ГраницыПериодаНачисления.ЗавершениеОП-1;
		ДокументОбъект.Дата = КонецПериода - 1;
		
		ДокументОбъект.ПометкаУдаления = Ложь;
		ДокументОбъект.Ответственный = Пользователи.ТекущийПользователь();
		ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		
		НаборНачислениеПени					= РегистрыНакопления.энргНачислениеПени.СоздатьНаборЗаписей();
		НаборНачислениеПени.Отбор.Регистратор.Установить(ДокументОбъект.Ссылка);
		НаборНачислениеПени.Записать();  	
		
		НовНабор = ДокументОбъект.Движения.энргНачислениеПени;
		
		Если ПериодНачисления < НачалоРасчетаПени  Или  ПериодНачисления < НачалоУчетаДолга Тогда 
			Продолжить;
		КонецЕсли;
		
		ВыборкаПериодНачисления = ВыборкаДокументНачисления.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
		Пока ВыборкаПериодНачисления.Следующий() Цикл
			
			ВыборкаУслуга = ВыборкаПериодНачисления.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
			Пока ВыборкаУслуга.Следующий() Цикл
				ВыборкаАбонент = ВыборкаУслуга.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
				Пока ВыборкаАбонент.Следующий() Цикл
					
					НачалоПериода 				= ВыборкаАбонент.ПериодНачало;
					ПериодНачалоДляРасчета 		= ВыборкаАбонент.ПериодНачало;
					ДнейНаДеньНачалаДляРасчета 	= ?(ВыборкаАбонент.ДнейНаДеньНачала = 0, -1, ВыборкаАбонент.ДнейНаДеньНачала);
					ТекПериод 					= ВыборкаАбонент.ПериодНачало;
					ВыборкаДетальныеЗаписи 		= ВыборкаАбонент.Выбрать();	
					СуммаПени 					= 0;
					ДнейПросрочкиВПериоде 		= 0;
					ДнейПросрочки 				= ВыборкаАбонент.ДнейНаДеньНачала;
					Оплата 						= 0;
					Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 						
						СуммаЗадолженности = ?(ВыборкаДетальныеЗаписи.СуммаНачальныйОстаток = 0, ВыборкаДетальныеЗаписи.СуммаКонечныйОстаток, ВыборкаДетальныеЗаписи.СуммаНачальныйОстаток);
						КоэффициентЧислитель = 1;
						КоэффициентЗнаменатель = 1;
						ПредКоэффициентЧислитель = 1;
						ПредКоэффициентЗнаменатель = 1;
						РангКоэффициента = 0;
						ПредыдущийРанг 						= Неопределено;
						НачисляемПеню 						= Ложь;  						
						
						ЗначениеСтавкиРефинансирования = ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования;
						ПричинаСменаСтавкиВПериоде = Ложь;
						
						Пока НачалоДня(ТекПериод) < НачалоДня(ВыборкаДетальныеЗаписи.Период) Цикл
							ДнейПросрочки 					= ДнейПросрочки + 1;							
							НачисляемПеню 					= Ложь;
							ПараметрыРасчетаИзменены 		= Ложь;
							Мораторий = Ложь;
							СтруктураКоэффициента 			= Соответствие.Получить(?(ДнейПросрочки>МаксЗначение,0,ДнейПросрочки));
							
							Если НЕ СтруктураКоэффициента = Неопределено Тогда
								ПараметрыРасчетаИзменены 	= НЕ КоэффициентЧислитель = СтруктураКоэффициента.Числитель ИЛИ НЕ КоэффициентЗнаменатель = СтруктураКоэффициента.Знаменатель ИЛИ НЕ РангКоэффициента = СтруктураКоэффициента.РангКоэффициента;  
								НачисляемПеню 				= Истина;								
							КонецЕсли;
							
							Если РассчитыватьНаТекущуюДату И ТекПериод = НАЧАЛОДНЯ(ТекущаяДатаНачислений + 60*60*24) Тогда
								ПараметрыРасчетаИзменены = Истина;
							КонецЕсли;
							
							Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ПериодОстановкиРасчетаПени) И ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ПериодВозобновленияРасчетаПени) Тогда
								Если ТекПериод >= НачалоДня(ВыборкаДетальныеЗаписи.ПериодОстановкиРасчетаПени) И ТекПериод < НачалоДня(ВыборкаДетальныеЗаписи.ПериодВозобновленияРасчетаПени + 1) Тогда	
									Мораторий = Истина;	
								КонецЕсли;
							КонецЕсли;
							
							Если НачисляемПеню и СменаСтавкиВПериоде.ЕстьСмена и ТекПериод = СменаСтавкиВПериоде.Период Тогда								
								ПараметрыРасчетаИзменены = Истина;
								ПричинаСменаСтавкиВПериоде = Истина;
							КонецЕсли; 						
							
							
							Если НачисляемПеню и ПараметрыРасчетаИзменены И ДнейПросрочкиВПериоде > 1 Тогда
								НСтр						= НовНабор.Добавить();
								ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
								НСтр.Организация			= Организация;
								НСтр.Район					= Район;
								НСтр.МКД					= МКД;
								НСтр.ПериодРасчета			= ПериодНачисления;
								//НСтр.Период					= КонецПериода-1; 
								НСтр.Период					= ДокументОбъект.Дата; 
								НСтр.ДатаНачисленияПени 	= ТекПериод;
								НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ДнейПросрочки - 1;
								НСтр.КоэффициентЧислитель 	= КоэффициентЧислитель;
								НСтр.КоэффициентЗнаменатель = КоэффициентЗнаменатель;
								НСтр.СуммаЗадолженности 	= СуммаЗадолженности;
								НСтр.ДнейПросрочки 			= ДнейПросрочкиВПериоде;
								//НСтр.СтавкаРефинансирования = ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования;
								НСтр.СтавкаРефинансирования = ЗначениеСтавкиРефинансирования;
								//Если Не Мораторий Тогда
									НСтр.Сумма 					= СуммаПени;
								//Иначе
								//	НСтр.Сумма 					= 0;
								//КонецЕсли;
								НСтр.Оплата	 				= Оплата;
								НСтр.НачалоПериода 			= НачалоПериода;
								НСтр.КонецПериода 			= ТекПериод - 1;
								
								Если ПричинаСменаСтавкиВПериоде Тогда 
									ЗначениеСтавкиРефинансирования = СменаСтавкиВПериоде.Коэффициент;
								КонецЕсли;
								                                                                                                                   	
								СуммаПени 					= 0;								
								ДнейПросрочкиВПериоде 		= 0;
								НСтр.ДатаНачалаНачисленияПени = ВыборкаДетальныеЗаписи.ДатаНачалаНачисленияПени;
								
								НачалоПериода 	= ТекПериод;
							КонецЕсли; 
							
							Если НЕ СтруктураКоэффициента = Неопределено Тогда
								КоэффициентЧислитель 		= СтруктураКоэффициента.Числитель;
								КоэффициентЗнаменатель 		= СтруктураКоэффициента.Знаменатель;
								РангКоэффициента 			= СтруктураКоэффициента.РангКоэффициента; 								
							КонецЕсли;
							
							Если НачисляемПеню Тогда
								
								//СтавкаРефинансированияДоля	= (ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования/100);
								СтавкаРефинансированияДоля	= (ЗначениеСтавкиРефинансирования/100);
								
								Если Не Мораторий Тогда
									СуммаПени 					= СуммаПени + СуммаЗадолженности * (КоэффициентЧислитель / КоэффициентЗнаменатель) * СтавкаРефинансированияДоля;
									ДнейПросрочкиВПериоде 		= ДнейПросрочкиВПериоде + 1;
								Иначе
									СуммаПени 					= СуммаПени + 0;
									ДнейПросрочкиВПериоде 		= ДнейПросрочкиВПериоде + 0;
								КонецЕсли;

							КонецЕсли;
							
							ТекПериод 						= ТекПериод + 86400;							
						КонецЦикла;
						
						Если НачисляемПеню и СуммаПени > 0  и Не ДнейПросрочки = 0  Тогда
							НСтр						= НовНабор.Добавить();
							ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
							//НСтр.Период					= КонецПериода - 1;
							НСтр.Период					= ДокументОбъект.Дата; 
							НСтр.Организация			= Организация;
							НСтр.Район					= Район;
							НСтр.МКД					= МКД;
							НСтр.ПериодРасчета			= ПериодНачисления;							
							НСтр.ДатаНачисленияПени 	= ТекПериод;										
							НСтр.ДатаНачалаНачисленияПени = ВыборкаДетальныеЗаписи.ДатаНачалаНачисленияПени;
							
							НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ДнейПросрочки;
							НСтр.КоэффициентЧислитель 	= КоэффициентЧислитель;
							НСтр.КоэффициентЗнаменатель = КоэффициентЗнаменатель;
							НСтр.СуммаЗадолженности 	= СуммаЗадолженности;
							НСтр.ДнейПросрочки 			= ДнейПросрочкиВПериоде;
							//НСтр.СтавкаРефинансирования = ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования;							
							НСтр.СтавкаРефинансирования = ЗначениеСтавкиРефинансирования;							
							//Если Не Мораторий Тогда
								НСтр.Сумма 					= СуммаПени;
							//Иначе
							//	НСтр.Сумма 					= 0;
							//КонецЕсли;
							
							НСтр.Оплата	 				= Оплата;
							НСтр.НачалоПериода 			= НачалоПериода;
							НСтр.КонецПериода 			= ТекПериод - 1;
							
							СуммаПени 					= 0;								
							ДнейПросрочкиВПериоде 		= 0;
						КонецЕсли;
						
						Если Не НачисляемПеню И СтруктураКоэффициента = Неопределено И ВыборкаДетальныеЗаписи.ПериодНачало = ПериодНачисления Тогда 
							НСтр						= НовНабор.Добавить();
							ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
							//НСтр.Период					= КонецПериода - 1;
							НСтр.Период					= ДокументОбъект.Дата; 
							НСтр.Организация			= Организация;
							НСтр.Район					= Район;
							НСтр.МКД					= МКД;
							НСтр.ПериодРасчета			= ПериодНачисления;
							НСтр.ДатаНачисленияПени 	= Дата(1,1,1) ;				
							НСтр.ДатаНачалаНачисленияПени = Дата(1,1,1);						
							НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ДнейПросрочки;
							НСтр.КоэффициентЧислитель 	= 0;
							НСтр.КоэффициентЗнаменатель = 0;
							НСтр.СуммаЗадолженности 	= СуммаЗадолженности;
							НСтр.ДнейПросрочки 			= 0;
							НСтр.СтавкаРефинансирования = 0;							
							НСтр.Сумма	 				= 0;
							НСтр.Оплата	 				= 0;
							НСтр.НачалоПериода 			= НачалоПериода;
							НСтр.КонецПериода 			= ТекПериод - 1;
											
						КонецЕсли;
						
						НачалоПериода 	= ТекПериод;
						Оплата 			= ВыборкаДетальныеЗаписи.Оплата;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		
		
	КонецЦикла;
	
	// Проверка изменения настроек в периоде. При условии, что "РасчетПоТекущейСтавке" = Истина
	Если РасчетПоТекущейСтавке Тогда
		СнятьНачислениеПени(НовНабор, Организация, ГраницыПериодаНачисления.НачалоОП, ГраницыПериодаНачисления.ЗавершениеОП-1, ПериодНачисления, МКД, Район);
		ДоначислитьСуммыПени(НовНабор, Организация, ПериодНачисления,Район, МКД, ГраницыПериодаНачисления.НачалоОП, ГраницыПериодаНачисления.ЗавершениеОП, ГлубинаОтсрочки, КрайнийСрокОплаты, НачалоУчетаДолга, НачалоРасчетаПени);
	КонецЕсли;
	
	
	Если Не НовНабор = Неопределено Тогда 
		НаборЗаписейНачислений = НовНабор.Выгрузить();
		НаборНачислениеПени.Загрузить(НаборЗаписейНачислений);	
		Если Не НаборНачислениеПени = Неопределено и Не НаборНачислениеПени.Количество() = 0 Тогда
			НаборНачислениеПени.Записать();
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
	КонецЕсли;
	
	//Абонент = Неопределено;
	//
	//ПараметрыОперацииВЗ = Новый Структура("Организация,ПериодНачисления,Район,МКД,Абонент",Организация,ПериодНачисления,Район,МКД, Абонент);
	//энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты(ПараметрыОперацииВЗ);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СменаСтавкиВПериоде(Организация, НП, КП)
	
	Результат = Новый Структура();
	Результат.Вставить("ЕстьСмена", Ложь);
	Результат.Вставить("Период", Неопределено);
	Результат.Вставить("Коэффициент", Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСтавкиРефинансирования.Период КАК Период,
		|	энргСтавкиРефинансирования.Коэффициент КАК Коэффициент
		|ИЗ
		|	РегистрСведений.энргСтавкиРефинансирования КАК энргСтавкиРефинансирования
		|ГДЕ
		|	энргСтавкиРефинансирования.Организация = &Организация
		|	И энргСтавкиРефинансирования.Период МЕЖДУ &НП И &КП";
	
	Запрос.УстановитьПараметр("КП", КП);
	Запрос.УстановитьПараметр("НП", НП);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
		Результат.ЕстьСмена = Истина;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура СнятьНачислениеПени(Набор,Организация, НачалоПериода, КонецПериода, ПериодНачисления, МКД = Неопределено, Район)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСтавкиРефинансированияСрезПоследних.Период КАК ПериодСтавкиДо,
		|	энргСтавкиРефинансированияСрезПоследних.Организация КАК Организация,
		|	ВложенныйЗапрос.Период КАК ПериодСтавкиС
		|ПОМЕСТИТЬ ИзменениеСтавкиВТекущемПериоде
		|ИЗ
		|	РегистрСведений.энргСтавкиРефинансирования.СрезПоследних(&НачалоПериода, Организация = &Организация) КАК энргСтавкиРефинансированияСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			МАКСИМУМ(энргСтавкиРефинансированияСрезПоследних.Период) КАК Период,
		|			энргСтавкиРефинансированияСрезПоследних.Организация КАК Организация
		|		ИЗ
		|			РегистрСведений.энргСтавкиРефинансирования КАК энргСтавкиРефинансированияСрезПоследних
		|		ГДЕ
		|			энргСтавкиРефинансированияСрезПоследних.Период < &НачалоПериода
		|		
		|		СГРУППИРОВАТЬ ПО
		|			энргСтавкиРефинансированияСрезПоследних.Организация) КАК ВложенныйЗапрос
		|		ПО энргСтавкиРефинансированияСрезПоследних.Организация = ВложенныйЗапрос.Организация
		|ГДЕ
		|	энргСтавкиРефинансированияСрезПоследних.Период МЕЖДУ &НачалоПериода И &КонецПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргСтавкиРефинансированияСрезПоследних.Период КАК ПериодСтавкиДо,
		|	энргСтавкиРефинансированияСрезПоследних.Организация КАК Организация,
		|	ВложенныйЗапрос.Период КАК ПериодСтавкиС
		|ПОМЕСТИТЬ ИзменениеНастроекШкалВТекущемПериоде
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(энргСтавкиРефинансированияСрезПоследних.Период) КАК Период,
		|		энргСтавкиРефинансированияСрезПоследних.Организация КАК Организация
		|	ИЗ
		|		РегистрСведений.энргНастройкаРасчетаПени КАК энргСтавкиРефинансированияСрезПоследних
		|	ГДЕ
		|		энргСтавкиРефинансированияСрезПоследних.Период < &НачалоПериода
		|	
		|	СГРУППИРОВАТЬ ПО
		|		энргСтавкиРефинансированияСрезПоследних.Организация) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргНастройкаРасчетаПени.СрезПоследних(&НачалоПериода, Организация = &Организация) КАК энргСтавкиРефинансированияСрезПоследних
		|		ПО ВложенныйЗапрос.Организация = энргСтавкиРефинансированияСрезПоследних.Организация
		|ГДЕ
		|	энргСтавкиРефинансированияСрезПоследних.Период МЕЖДУ &НачалоПериода И &КонецПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИзменениеСтавкиВТекущемПериоде.ПериодСтавкиДо КАК ПериодСтавкиДо,
		|	ИзменениеСтавкиВТекущемПериоде.Организация КАК Организация,
		|	ИзменениеСтавкиВТекущемПериоде.ПериодСтавкиС КАК ПериодСтавкиС
		|ПОМЕСТИТЬ ПериодыИзмененияНастроек
		|ИЗ
		|	ИзменениеСтавкиВТекущемПериоде КАК ИзменениеСтавкиВТекущемПериоде
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ИзменениеНастроекШкалВТекущемПериоде.ПериодСтавкиДо,
		|	ИзменениеНастроекШкалВТекущемПериоде.Организация,
		|	ИзменениеНастроекШкалВТекущемПериоде.ПериодСтавкиС
		|ИЗ
		|	ИзменениеНастроекШкалВТекущемПериоде КАК ИзменениеНастроекШкалВТекущемПериоде
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ПериодыИзмененияНастроек.ПериодСтавкиДо) КАК ПериодСтавкиДо,
		|	ПериодыИзмененияНастроек.Организация КАК Организация,
		|	МИНИМУМ(ПериодыИзмененияНастроек.ПериодСтавкиС) КАК ПериодСтавкиС
		|ПОМЕСТИТЬ ВТ_ПериодМинМакс
		|ИЗ
		|	ПериодыИзмененияНастроек КАК ПериодыИзмененияНастроек
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыИзмененияНастроек.Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргВзаиморасчетыПоПениОбороты.Организация КАК Организация,
		|	энргВзаиморасчетыПоПениОбороты.Район КАК Район,
		|	энргВзаиморасчетыПоПениОбороты.МКД КАК МКД,
		|	энргВзаиморасчетыПоПениОбороты.Абонент КАК Абонент,
		|	энргВзаиморасчетыПоПениОбороты.Услуга КАК Услуга,
		|	энргВзаиморасчетыПоПениОбороты.ПериодНачисления КАК ПериодНачисления,
		|	СУММА(-энргВзаиморасчетыПоПениОбороты.СуммаОстаток) КАК СУММА
		|ИЗ
		|	ВТ_ПериодМинМакс КАК ИзменениеСтавкиВТекущемПериоде
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.энргВзаиморасчетыПоПени.Остатки(
		|				,
		|				Организация = &Организация
		|					И МКД = &МКД
		|					И Район = &Район) КАК энргВзаиморасчетыПоПениОбороты
		|		ПО ИзменениеСтавкиВТекущемПериоде.Организация = энргВзаиморасчетыПоПениОбороты.Организация
		|			И (энргВзаиморасчетыПоПениОбороты.ПериодРасчета МЕЖДУ ИзменениеСтавкиВТекущемПериоде.ПериодСтавкиС И ИзменениеСтавкиВТекущемПериоде.ПериодСтавкиДо)
		|
		|СГРУППИРОВАТЬ ПО
		|	энргВзаиморасчетыПоПениОбороты.Организация,
		|	энргВзаиморасчетыПоПениОбороты.Район,
		|	энргВзаиморасчетыПоПениОбороты.МКД,
		|	энргВзаиморасчетыПоПениОбороты.Абонент,
		|	энргВзаиморасчетыПоПениОбороты.Услуга,
		|	энргВзаиморасчетыПоПениОбороты.ПериодНачисления
		|
		|УПОРЯДОЧИТЬ ПО
		|	Абонент,
		|	ПериодНачисления";
	
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	
	Если ЗначениеЗаполнено(МКД) Тогда 
		Запрос.УстановитьПараметр("МКД", МКД);
	иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И МКД = &МКД", "");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтрСнятие = Набор.добавить();
		ЗаполнитьЗначенияСвойств(СтрСнятие, ВыборкаДетальныеЗаписи);
		СтрСнятие.ПериодРасчета = ПериодНачисления;
		СтрСнятие.Период = КонецПериода;
	КонецЦикла;
	
	
КонецПроцедуры

Процедура ДоначислитьСуммыПени(Набор,Организация, ПериодНачисления, Район, МКД = Неопределено, НачалоПериода, КонецПериода, ГлубинаОтсрочки,КрайнийСрокОплаты,НачалоУчетаДолга,НачалоРасчетаПени)
	
	БылоИзменениеСтавки = Ложь;
	БылоИзменениеШкалы = Ложь;
	МаксЗначение = 0;
	МинЗначение = 0;
	
	Запрос = Новый Запрос;
	МВТ = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргСтавкиРефинансированияСрезПоследних.Период КАК ПериодСтавкиДо,
	|	энргСтавкиРефинансированияСрезПоследних.Организация КАК Организация,
	|	ВложенныйЗапрос.Период КАК ПериодСтавкиС,
	|	энргСтавкиРефинансированияСрезПоследних.Коэффициент КАК Коэффициент,
	|	ВложенныйЗапрос.Коэффициент КАК КоэффициентДо
	|ПОМЕСТИТЬ ИзменениеСтавкиВТекущемПериоде
	|ИЗ
	|	РегистрСведений.энргСтавкиРефинансирования.СрезПоследних(&НачалоПериода, Организация = &Организация) КАК энргСтавкиРефинансированияСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			МАКСИМУМ(энргСтавкиРефинансированияСрезПоследних.Период) КАК Период,
	|			энргСтавкиРефинансированияСрезПоследних.Организация КАК Организация,
	|			МАКСИМУМ(энргСтавкиРефинансированияСрезПоследних.Коэффициент) КАК Коэффициент
	|		ИЗ
	|			РегистрСведений.энргСтавкиРефинансирования КАК энргСтавкиРефинансированияСрезПоследних
	|		ГДЕ
	|			энргСтавкиРефинансированияСрезПоследних.Период < &НачалоПериода
	|		
	|		СГРУППИРОВАТЬ ПО
	|			энргСтавкиРефинансированияСрезПоследних.Организация) КАК ВложенныйЗапрос
	|		ПО энргСтавкиРефинансированияСрезПоследних.Организация = ВложенныйЗапрос.Организация
	|ГДЕ
	|	энргСтавкиРефинансированияСрезПоследних.Период МЕЖДУ &НачалоПериода И &КонецПериода";
	
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Запрос.Выполнить();
	ТЗ_ИзменениеСтавки = МВТ.Таблицы["ИзменениеСтавкиВТекущемПериоде"].ПолучитьДанные().Выгрузить();
	Если НЕ ТЗ_ИзменениеСтавки.Количество() = 0 Тогда 
		БылоИзменениеСтавки = Истина;
		нРез = МВТ.Таблицы["ИзменениеСтавкиВТекущемПериоде"].ПолучитьДанные();
		Выборка  									= нРез.Выбрать();
		Выборка.Следующий();
		КоэффициентРасчета = Выборка.Коэффициент;
	иначе
		нСтавкаРасчета 					= РегистрыСведений.энргСтавкиРефинансирования.СрезПоследних(НачалоПериода-1, Новый Структура("Организация", Организация));	
		КоэффициентРасчета				= нСтавкаРасчета[0].Коэффициент;
		
	КонецЕсли;
	


	// проверяем изменение шкалы в текущем периоде 
	Запрос = Новый Запрос;
 	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	энргСтавкиРефинансированияСрезПоследних.Период КАК ПериодСтавкиДо,
	|	энргСтавкиРефинансированияСрезПоследних.Организация КАК Организация,
	|	ВложенныйЗапрос.Период КАК ПериодСтавкиС,
	|	энргСтавкиРефинансированияСрезПоследних.НастройкаРасчета КАК НастройкаРасчета
	|ПОМЕСТИТЬ ИзменениеНастроекШкалВТекущемПериоде
	|ИЗ
	|	(ВЫБРАТЬ
	|		МАКСИМУМ(энргСтавкиРефинансированияСрезПоследних.Период) КАК Период,
	|		энргСтавкиРефинансированияСрезПоследних.Организация КАК Организация
	|	ИЗ
	|		РегистрСведений.энргНастройкаРасчетаПени КАК энргСтавкиРефинансированияСрезПоследних
	|	ГДЕ
	|		энргСтавкиРефинансированияСрезПоследних.Период < &НачалоПериода
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргСтавкиРефинансированияСрезПоследних.Организация) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргНастройкаРасчетаПени.СрезПоследних(&НачалоПериода, Организация = &Организация) КАК энргСтавкиРефинансированияСрезПоследних
	|		ПО ВложенныйЗапрос.Организация = энргСтавкиРефинансированияСрезПоследних.Организация
	|ГДЕ
	|	энргСтавкиРефинансированияСрезПоследних.Период МЕЖДУ &НачалоПериода И &КонецПериода";
	
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("Организация", Организация);				  
	
 
	Результат  								= Запрос.Выполнить();

	ТЗ_ИзменениеШкалы = МВТ.Таблицы["ИзменениеНастроекШкалВТекущемПериоде"].ПолучитьДанные().Выгрузить();
	резвыб = МВТ.Таблицы["ИзменениеНастроекШкалВТекущемПериоде"].ПолучитьДанные();
	Если НЕ ТЗ_ИзменениеШкалы.Количество() = 0 Тогда 
		БылоИзменениеШкалы = Истина;
		Выборка  									= резвыб.Выбрать();
		Выборка.Следующий();
				
		НастройкиРасчетаПени = Выборка.НастройкаРасчета.Получить();		
	иначе
		новНастройкиРасчета 					= РегистрыСведений.энргНастройкаРасчетаПени.СрезПоследних(НачалоПериода-1, Новый Структура("Организация", Организация));	
 		НастройкиРасчетаПени 					= новНастройкиРасчета[0].НастройкаРасчета.Получить();
		
	КонецЕсли;
	
	Соответствие = Новый Соответствие;
	РангКоэффициента = 1;
	Для каждого Строка Из НастройкиРасчетаПени Цикл
		Если Строка.До = 0 Тогда
			НСтр = Новый Структура;
			НСтр.Вставить("Числитель", Строка.Числитель);
			НСтр.Вставить("Знаменатель", Строка.Знаменатель);
			НСтр.Вставить("РангКоэффициента", РангКоэффициента);
			
			Соответствие.Вставить(Строка.До, НСтр);
		Иначе
			//МинЗначение = строка.От;
			Для Сч = Строка.От По Строка.До Цикл
				НСтр = Новый Структура;
				НСтр.Вставить("Числитель", Строка.Числитель);
				НСтр.Вставить("Знаменатель", Строка.Знаменатель);
				НСтр.Вставить("РангКоэффициента", РангКоэффициента);
				
				Соответствие.Вставить(Сч, НСтр);
				МаксЗначение = Макс(МаксЗначение, Сч);
			КонецЦикла;
		КонецЕсли;
		
		РангКоэффициента = РангКоэффициента + 1;
	КонецЦикла;

	
	// получаем периоды для переначисления
	Запрос = Новый Запрос;
 	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст ="ВЫБРАТЬ
	              |	ИзменениеСтавкиВТекущемПериоде.ПериодСтавкиДо КАК ПериодСтавкиДо,
	              |	ИзменениеСтавкиВТекущемПериоде.Организация КАК Организация,
	              |	ИзменениеСтавкиВТекущемПериоде.ПериодСтавкиС КАК ПериодСтавкиС,
	              |	ИзменениеСтавкиВТекущемПериоде.Коэффициент КАК Коэффициент
	              |ПОМЕСТИТЬ ПериодыИзмененияНастроек
	              |ИЗ
	              |	ИзменениеСтавкиВТекущемПериоде КАК ИзменениеСтавкиВТекущемПериоде
	              |
	              |ОБЪЕДИНИТЬ ВСЕ
	              |
	              |ВЫБРАТЬ
	              |	ИзменениеНастроекШкалВТекущемПериоде.ПериодСтавкиДо,
	              |	ИзменениеНастроекШкалВТекущемПериоде.Организация,
	              |	ИзменениеНастроекШкалВТекущемПериоде.ПериодСтавкиС,
	              |	NULL
	              |ИЗ
	              |	ИзменениеНастроекШкалВТекущемПериоде КАК ИзменениеНастроекШкалВТекущемПериоде
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ
	              |	МАКСИМУМ(ПериодыИзмененияНастроек.ПериодСтавкиДо) КАК ПериодСтавкиДо,
	              |	ПериодыИзмененияНастроек.Организация КАК Организация,
	              |	МИНИМУМ(ПериодыИзмененияНастроек.ПериодСтавкиС) КАК ПериодСтавкиС,
	              |	ЕСТЬNULL(ПериодыИзмененияНастроек.Коэффициент, 0) КАК Коэффициент
 	              |ИЗ
	              |	ПериодыИзмененияНастроек КАК ПериодыИзмененияНастроек
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	ПериодыИзмененияНастроек.Организация,
	              |	ЕСТЬNULL(ПериодыИзмененияНастроек.Коэффициент, 0)";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() тогда
 		Возврат;
	КонецЕсли;
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	ПериодСтавкиС 	= Выборка.ПериодСтавкиС; 
	ПериодСтавкиДо 	= Выборка.ПериодСтавкиДо; 
	
	Пока ПериодСтавкиС < ПериодСтавкиДо Цикл 
		
		ГраницыПериодаНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район, ПериодСтавкиС,Ложь);
		// Настройки начисления пени.
		Запрос = Новый Запрос;
		Запрос.Текст = ВернутьТекстЗапросаНачисленияПениПереначисление();	
		
		Запрос.УстановитьПараметр("ГлубинаОтсрочки", 								ГлубинаОтсрочки);
		Запрос.УстановитьПараметр("КонецПериода", 									ГраницыПериодаНачисления.ЗавершениеОП);
		Запрос.УстановитьПараметр("КрайнийСрокОплаты", 								КрайнийСрокОплаты);
		Запрос.УстановитьПараметр("МКД", 											МКД);
		Запрос.УстановитьПараметр("НачалоПериода", 									ГраницыПериодаНачисления.НачалоОП);
		Запрос.УстановитьПараметр("Организация", 									Организация);
		Запрос.УстановитьПараметр("Район", 											Район);
		Запрос.УстановитьПараметр("НачалоУчетаДолга", 								НачалоУчетаДолга);
		Запрос.УстановитьПараметр("КоэффициентРасчета", 							КоэффициентРасчета);
		Запрос.УстановитьПараметр("КоэффициентРасчета", 							КоэффициентРасчета);
		Запрос.УстановитьПараметр("ЗавершениеОП", 									ГраницыПериодаНачисления.ЗавершениеОП-1);
		
		РезультатЗапроса = Запрос.Выполнить();		
		
		ВыборкаПериодНачисления = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
		Пока ВыборкаПериодНачисления.Следующий() Цикл
			
			Если ПериодСтавкиС < НачалоРасчетаПени Или ПериодСтавкиС < НачалоУчетаДолга Тогда 
				Продолжить;
			КонецЕсли;
			
			
			ВыборкаУслуга = ВыборкаПериодНачисления.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
			Пока ВыборкаУслуга.Следующий() Цикл
				ВыборкаАбонент = ВыборкаУслуга.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
				Пока ВыборкаАбонент.Следующий() Цикл
					
					НачалоПериода 				= ВыборкаАбонент.ПериодНачало;
					Оплата 						= 0;
					ПериодНачалоДляРасчета 		= ВыборкаАбонент.ПериодНачало;
					ДнейНаДеньНачалаДляРасчета 	= ?(ВыборкаАбонент.ДнейНаДеньНачала = 0, -1, ВыборкаАбонент.ДнейНаДеньНачала);
					ТекПериод 					= ВыборкаАбонент.ПериодНачало;
					ВыборкаДетальныеЗаписи 		= ВыборкаАбонент.Выбрать();	
					СуммаПени 					= 0;
					ДнейПросрочкиВПериоде 		= 0;
					ДнейПросрочки 				= ВыборкаАбонент.ДнейНаДеньНачала;
					
					Пока ВыборкаДетальныеЗаписи.Следующий() Цикл				
						
						СуммаЗадолженности = ?(ВыборкаДетальныеЗаписи.СуммаНачальныйОстаток = 0, ВыборкаДетальныеЗаписи.СуммаКонечныйОстаток, ВыборкаДетальныеЗаписи.СуммаНачальныйОстаток);
						КоэффициентЧислитель = 1;
						КоэффициентЗнаменатель = 1;
						ПредКоэффициентЧислитель = 1;
						ПредКоэффициентЗнаменатель = 1;
						РангКоэффициента = 0;
						ПредыдущийРанг 						= Неопределено;
						НачисляемПеню 						= Ложь;  						
						Пока ТекПериод < ВыборкаДетальныеЗаписи.Период Цикл
							ДнейПросрочки 					= ДнейПросрочки + 1;							
							НачисляемПеню 					= Ложь;
							ПараметрыРасчетаИзменены 		= Ложь;
							СтруктураКоэффициента 			= Соответствие.Получить(?(ДнейПросрочки>МаксЗначение,0,ДнейПросрочки));
							
							Если НЕ СтруктураКоэффициента = Неопределено Тогда
								ПараметрыРасчетаИзменены 	= НЕ КоэффициентЧислитель = СтруктураКоэффициента.Числитель ИЛИ НЕ КоэффициентЗнаменатель = СтруктураКоэффициента.Знаменатель ИЛИ НЕ РангКоэффициента = СтруктураКоэффициента.РангКоэффициента;  
								НачисляемПеню 				= Истина;								
							КонецЕсли;
							
							Если НачисляемПеню и ПараметрыРасчетаИзменены И ДнейПросрочкиВПериоде > 1 Тогда
								НСтр						= Набор.Добавить();
								ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
								НСтр.Организация			= Организация;
								НСтр.Район					= Район;
								НСтр.МКД					= МКД;
								НСтр.ПериодРасчета			= ПериодНачисления;
								НСтр.Период					 = ГраницыПериодаНачисления.ЗавершениеОП-1;
								НСтр.ДатаНачисленияПени 	= ?(ТекПериод -1 = ГраницыПериодаНачисления.ЗавершениеОП-1,ГраницыПериодаНачисления.ЗавершениеОП-1, ТекПериод) ;
								НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ДнейПросрочки-1;
								НСтр.КоэффициентЧислитель 	= КоэффициентЧислитель;
								НСтр.КоэффициентЗнаменатель = КоэффициентЗнаменатель;
								НСтр.СуммаЗадолженности 	= СуммаЗадолженности;
								НСтр.ДнейПросрочки 			= ДнейПросрочкиВПериоде;
								НСтр.СтавкаРефинансирования = ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования;
								НСтр.ДатаНачалаНачисленияПени = ВыборкаДетальныеЗаписи.ДатаНачалаНачисленияПени;
								НСтр.Сумма 					= СуммаПени;
								НСтр.Оплата	 				= Оплата;
								НСтр.НачалоПериода 			= НачалоПериода;
								НСтр.КонецПериода 			= ТекПериод;								
								
								СуммаПени 					= 0;								
								ДнейПросрочкиВПериоде 		= 0;
								НачалоПериода				= ТекПериод;
							КонецЕсли; 
							
							Если НЕ СтруктураКоэффициента = Неопределено Тогда
								КоэффициентЧислитель 		= СтруктураКоэффициента.Числитель;
								КоэффициентЗнаменатель 		= СтруктураКоэффициента.Знаменатель;
								РангКоэффициента 			= СтруктураКоэффициента.РангКоэффициента; 								
							КонецЕсли;
							
							Если НачисляемПеню Тогда
								ДнейПросрочкиВПериоде 		= ДнейПросрочкиВПериоде + 1;
								СтавкаРефинансированияДоля	= (ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования/100);
								СуммаПени 					= СуммаПени + СуммаЗадолженности *  (КоэффициентЧислитель / КоэффициентЗнаменатель) * СтавкаРефинансированияДоля; 
							КонецЕсли;
							
							ТекПериод 						= ТекПериод + 86400;							
						КонецЦикла;
						
						Если НачисляемПеню и СуммаПени > 0 Тогда
							НСтр						= Набор.Добавить();
							ЗаполнитьЗначенияСвойств(НСтр, ВыборкаДетальныеЗаписи);
							НСтр.Период					= ГраницыПериодаНачисления.ЗавершениеОП-1;
							НСтр.Организация			= Организация;
							НСтр.Район					= Район;
							НСтр.МКД					= МКД;
							НСтр.ПериодРасчета			= ПериодНачисления;
							НСтр.ДатаНачисленияПени 	= ?(ТекПериод -1 = ГраницыПериодаНачисления.ЗавершениеОП-1,ГраницыПериодаНачисления.ЗавершениеОП-1, ТекПериод) ;
							НСтр.ДнейПросрочкиСДатыНачалаНачисленийПени = ДнейПросрочки;
							НСтр.КоэффициентЧислитель 	= КоэффициентЧислитель;
							НСтр.КоэффициентЗнаменатель = КоэффициентЗнаменатель;
							НСтр.СуммаЗадолженности 	= СуммаЗадолженности;
							НСтр.ДнейПросрочки 			= ДнейПросрочкиВПериоде;
							НСтр.СтавкаРефинансирования = ВыборкаДетальныеЗаписи.ЗначениеСтавкиРефинансирования;
							НСтр.ДатаНачалаНачисленияПени = ВыборкаДетальныеЗаписи.ДатаНачалаНачисленияПени;
							НСтр.Сумма 					= СуммаПени;
							НСтр.Оплата	 				= Оплата;
							НСтр.НачалоПериода 			= НачалоПериода;
							НСтр.КонецПериода 			= ТекПериод - 1;							
							
							СуммаПени 					= 0;								
							ДнейПросрочкиВПериоде 		= 0;
						КонецЕсли;
						
						НачалоПериода 	= ТекПериод;
						Оплата 			= ВыборкаДетальныеЗаписи.Оплата;
						
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
			
			
		КонецЦикла;
		
		ПериодСтавкиС = ДобавитьМесяц(ПериодСтавкиС,1);	
	КонецЦикла;

КонецПроцедуры

Функция ПолучитьСтавкиРефинансирования(НачалоОП, ЗавершениеОП, Организация, МВТ, РасчетПоТекущейСтавке)
	
	//// Ставки рефинансирования
	//Запрос  								= Новый Запрос;
	//Запрос.МенеджерВременныхТаблиц 			= МВТ;
