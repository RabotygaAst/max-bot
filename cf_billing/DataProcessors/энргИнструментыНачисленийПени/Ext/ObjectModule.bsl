#Область ОписаниеПеременных

#Область Основные

Перем Организация; 
Перем ПериодНачисления; 
Перем Район; 
Перем МКД; 
Перем Абонент; 
Перем Документ;

Перем Ошибки;

#КонецОбласти

#Область Служебные

Перем ПредставлениеРайон;

Перем РассчитыватьНаТекущуюДату;
Перем ТекущаяДатаНачислений;
Перем НачалоСледующегоДняПослеТекущейДатыНачислений;
Перем ГраницыПериодаНачисления;
Перем НачалоРасчетаПени;
Перем НачалоУчетаДолга;
Перем НеНачислятьПениПриОтсутствииДолгаНаКонецПериода;
Перем МаксЗначениеСтатика;
Перем РасчетПоТекущейСтавке;
Перем НастройкиРасчетаПениОтДо;
Перем НастройкиРасчетаПени;
Перем РангКоэффициента;

Перем КонецПериода;
Перем СтавкиНаПериод;
Перем ГлубинаОтсрочки;
Перем КрайнийСрокОплаты;
Перем МаксимальнаяГлубинаЗадолженности;
Перем СменаСтавкиВПериодеСтатика;

Перем ОсновнойЗапрос;
Перем МКДКНачислению;
	
#КонецОбласти

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Начисляет пеню.
//
// Параметры:
//  ВходныеПараметры	-	Структура	-	см. Обработка.энргИнструментыНачисленийПени.НовыеВходныеПараметры.
//
Процедура НачислитьПеню(ВходныеПараметры) Экспорт
	
	Если НЕ РазрешеноВыполнятьОперацию(ВходныеПараметры) Тогда 
		Возврат;
	КонецЕсли;
	
	ИнициализироватьОбщиеДанные(ВходныеПараметры);
	Если ГраницыПериодаНачисления.ПериодНачисления > НачалоМесяца(ТекущаяДатаНачислений) Тогда
		Возврат;
	КонецЕсли;
	
	Ошибки = Новый Массив;
	ПрочитатьНастройки();
	
	Если ПериодНачисления < НачалоРасчетаПени Или ПериодНачисления < НачалоУчетаДолга Тогда 
		Возврат;
	КонецЕсли;
	
	ОсновнойЗапрос = Новый Запрос;
	ОсновнойЗапрос.Текст = ВернутьТекстЗапросаНачисленияПени();	
	
	МКДКНачислению = Новый ТаблицаЗначений;
	МКДКНачислению.Колонки.Добавить("МКД", Новый ОписаниеТипов("СправочникСсылка.энргСтроения"));
	МКДКНачислению.Колонки.Добавить("Код", ОбщегоНазначения.ОписаниеТипаЧисло(15));
	МКДКНачислению.Колонки.Добавить("Наименование", ОбщегоНазначения.ОписаниеТипаСтрока(150));	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргСтроения.Ссылка КАК МКД,
	|	энргСтроения.Код КАК Код,
	|	энргСтроения.Наименование КАК Наименование
	|ИЗ
	|	Справочник.энргСтроения КАК энргСтроения
	|ГДЕ
	|	&Фильтр
	|
	|УПОРЯДОЧИТЬ ПО
	|	МКД";
	
	
	Фильтр = "энргСтроения.Ссылка В(&МКД)";
	
	Если МКД = Неопределено Тогда
		
		Фильтр = "
		|	энргСтроения.ПометкаУдаления = ЛОЖЬ
		|	И энргСтроения.Район = &Район
		|	И энргСтроения.ТипСтроения = &ТипСтроения
		|	И энргСтроения.Организация = &Организация";
		
	КонецЕсли;	
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Фильтр", Фильтр);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ТипСтроения", Перечисления.энргТипыСтроений.МКД);
	Запрос.УстановитьПараметр("МКД", МКД);
	
	РезультатЗапроса = Запрос.Выполнить();	
	Выборка = РезультатЗапроса.Выбрать();
	
	КоличествоПотоков = 7;
	ОбщееКоличество = Выборка.Количество();		
	Если ОбщееКоличество <= КоличествоПотоков Тогда 
		Порция = ОбщееКоличество;
	Иначе 
		Порция = Цел(ОбщееКоличество / КоличествоПотоков);
		Если (ОбщееКоличество % КоличествоПотоков) > 0 Тогда			
			Порция = Порция + 1;
		КонецЕсли;
	КонецЕсли;	
	
	МКДКНачислению.Очистить();
	Итерация = 0;
	ИтерацияПотока = 1;
	Пока Выборка.Следующий() Цикл
		
		Если Итерация = Порция И ИтерацияПотока < КоличествоПотоков Тогда
			
			Начислить();
			
			МКДКНачислению.Очистить();
			Итерация = 0;
			ИтерацияПотока = ИтерацияПотока + 1;
			
		КонецЕсли;
		
		НоваяСтрока = МКДКНачислению.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		
		Итерация = Итерация + 1;
	КонецЦикла;
	
	Если Итерация > 0 Тогда
		Начислить();
	КонецЕсли;	
	
	НачислитьЧастныйСектор();
	
	СписокМКД = МКД;
	Если ТипЗнч(МКД) = Тип("СправочникСсылка.энргСтроения") Тогда
		СписокМКД = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(МКД);
	КонецЕсли;	
		
	ПараметрыОперацииВЗ = Новый Структура("Организация,ПериодНачисления,Район,МКД,Абонент,СписокМКД", Организация, ПериодНачисления, Район,,, СписокМКД);
	энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты(ПараметрыОперацииВЗ, Истина);
	
	Если Ошибки.Количество() > 0 Тогда
		
		ТекстИсключения = СтрСоединить(Ошибки, Символы.ПС);
		ВызватьИсключение ТекстИсключения;
		
	КонецЕсли;
	
КонецПроцедуры

// Возвращает новые входные параметры процедуры "НачислитьПеню".
//
// Возвращаемое значение:
//  Структура: 
//   * Организация		-	Справочники.Организации				-	организация.
//   * ПериодНачисления	-	Дата								-	период расчета.
//   * Район			-	Справочники.энргЗоныОтвественности	-	район.
//   * МКД				-	Справочники.энргСтроения			-	МКД.
//   * Абонент			-	Неопределено						-	не используется.
//   * Документ			-	Неопределено						-	не используется.
//
Функция НовыеВходныеПараметры() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Организация", Справочники.Организации.НашаОрганизация);
	Результат.Вставить("ПериодНачисления", Дата(1,1,1));
	Результат.Вставить("Район", Справочники.энргЗоныОтвественности.ПустаяСсылка());
	Результат.Вставить("МКД", Неопределено);
	Результат.Вставить("Абонент", Неопределено);
	Результат.Вставить("Документ", Неопределено);
	
	Возврат Результат;	
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Валидация

Функция РазрешеноВыполнятьОперацию(ПроверяемыеПоля)
	
	Если НЕ ЗначениеЗаполнено(ПроверяемыеПоля.ПериодНачисления) ИЛИ НЕ ЗначениеЗаполнено(ПроверяемыеПоля.Район) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	ОбъектПроверки = Документы.энргРегистрацияПоказанийАбонента.СоздатьДокумент();
	ОбъектПроверки.Организация = ПроверяемыеПоля.Организация;
	ОбъектПроверки.Дата	= ПроверяемыеПоля.ПериодНачисления;
	ОбъектПроверки.Район = ПроверяемыеПоля.Район;
	
	Отказ = энргДатыЗапретаИзмененияПереопределяемый.ЗапрещеноИзменятьДанные(ОбъектПроверки);
		
	Если Отказ Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Для пользователя " + Пользователи.ТекущийПользователь() + 
			" район " + ПроверяемыеПоля.Район + " период " + ПроверяемыеПоля.ПериодНачисления + 
			" закрыт для редактирования");
	КонецЕсли; 		
	
	
	Отказ = НЕ Константы.энргНачислятьПеню.Получить();
	
	Возврат НЕ Отказ;
	
КонецФункции

#КонецОбласти

#Область Настройки

Процедура ИнициализироватьОбщиеДанные(ВходныеПараметры)
	
	РассчитыватьНаТекущуюДату = Ложь;	
	ТекущаяДатаНачислений = ТекущаяДата();
	НачалоСледующегоДняПослеТекущейДатыНачислений = НачалоДня(ТекущаяДатаНачислений + 86400);
	
	Организация = ВходныеПараметры.Организация;
	ПериодНачисления = ВходныеПараметры.ПериодНачисления;
	Район = ВходныеПараметры.Район;
	ПредставлениеРайон = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Район, "Наименование");
	МКД = ВходныеПараметры.МКД;
	Абонент = ВходныеПараметры.Абонент;
	Документ = ВходныеПараметры.Документ;
	
	ГраницыПериодаНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(
		Организация, 
		Район,
		ПериодНачисления,
		Ложь);	
		
	КонецПериода = ГраницыПериодаНачисления.ЗавершениеОП;
	
КонецПроцедуры

Процедура ПрочитатьНастройки()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.Организация КАК Организация,
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.ПериодНачалаУчетаПени КАК ПериодНачалаУчетаПени,
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.ПериодНачалаУчетаДолга КАК ПериодНачалаУчетаДолга,
	|	энргНастройкаНачалаРасчетаПениСрезПоследних.НеНачислятьПениПриОтсутствииДолгаНаКонецПериода КАК НеНачислятьПениПриОтсутствииДолгаНаКонецПериода
	|ИЗ
	|	РегистрСведений.энргНастройкаНачалаРасчетаПени.СрезПоследних(, Организация = &Организация) КАК энргНастройкаНачалаРасчетаПениСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргНастройкаРасчетаПениСрезПоследних.НастройкаРасчета КАК НастройкаРасчета,
	|	энргНастройкаРасчетаПениСрезПоследних.РасчетПоТекущейСтавке КАК РасчетПоТекущейСтавке
	|ИЗ
	|	РегистрСведений.энргНастройкаРасчетаПени.СрезПоследних(&Период, Организация = &Организация) КАК энргНастройкаРасчетаПениСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргНастройкиНачисленияПениСрезПоследних.ГлубинаОтсрочки КАК ГлубинаОтсрочки,
	|	энргНастройкиНачисленияПениСрезПоследних.КрайнийСрокОплаты КАК КрайнийСрокОплаты,
	|	энргНастройкиНачисленияПениСрезПоследних.МаксимальнаяГлубинаЗадолженности КАК МаксимальнаяГлубинаЗадолженности,
	|	энргНастройкиНачисленияПениСрезПоследних.РассчитыватьНаТекущуюДату КАК РассчитыватьНаТекущуюДату
	|ИЗ
	|	РегистрСведений.энргНастройкиНачисленияПени.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район) КАК энргНастройкиНачисленияПениСрезПоследних";
	
	Запрос.УстановитьПараметр("Период", ГраницыПериодаНачисления.ЗавершениеОП - 1);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Если РезультатЗапроса[0].Пустой() тогда
		
		Комментарий = "Не заполнена информация по началу расчета пени,
		|	 Начисление пени не может быть выполнено";
		
		ВызватьИсключение Комментарий;
		
	КонецЕсли;
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Выборка.Следующий();
	НачалоРасчетаПени 	= Выборка.ПериодНачалаУчетаПени;
	НачалоУчетаДолга 	= Выборка.ПериодНачалаУчетаДолга;
	НеНачислятьПениПриОтсутствииДолгаНаКонецПериода = Выборка.НеНачислятьПениПриОтсутствииДолгаНаКонецПериода;
	
	Если РезультатЗапроса[1].Пустой() тогда
		
		Комментарий = "Не заполнены настройки расчет пени,
		|	 Начисление пени не может быть выполнено";
		
		ВызватьИсключение Комментарий;
		
	КонецЕсли;
	Выборка = РезультатЗапроса[1].Выбрать();
	Выборка.Следующий();
	
	// Расчет по текущей ставке реф.
	РасчетПоТекущейСтавке = Выборка.РасчетПоТекущейСтавке;
	
	НастройкиРасчетаПени = Выборка.НастройкаРасчета.Получить();
	
	МаксЗначениеСтатика = 0;
	НастройкиРасчетаПениОтДо = Новый Соответствие;
	РангКоэффициента = 1;
	Для каждого Строка Из НастройкиРасчетаПени Цикл
		Если Строка.До = 0 Тогда
			
			НСтр = Новый Структура;
			НСтр.Вставить("Числитель", Строка.Числитель);
			НСтр.Вставить("Знаменатель", Строка.Знаменатель);
			НСтр.Вставить("РангКоэффициента", РангКоэффициента);
			
			НастройкиРасчетаПениОтДо.Вставить(Строка.До, НСтр);
			
		Иначе
			Для Сч = Строка.От По Строка.До Цикл
				
				НСтр = Новый Структура;
				НСтр.Вставить("Числитель", Строка.Числитель);
				НСтр.Вставить("Знаменатель", Строка.Знаменатель);
				НСтр.Вставить("РангКоэффициента", РангКоэффициента);		
				НастройкиРасчетаПениОтДо.Вставить(Сч, НСтр);	
				
				МаксЗначениеСтатика = Макс(МаксЗначениеСтатика, Сч);
				
			КонецЦикла;
		КонецЕсли;
		
		РангКоэффициента = РангКоэффициента + 1;
	КонецЦикла;	
	
	
	НастройкиСтавокРефинансирования = ПолучитьСтавкиРефинансирования();
	Если НастройкиСтавокРефинансирования.Пустой() Тогда 
		
		Комментарий = "Не заполнена информация по ставке рефинансирования,
		|	 Начисление пени не может быть выполнено";		
		ВызватьИсключение Комментарий;
		
	КонецЕсли;
	
	Если РезультатЗапроса[2].Пустой() Тогда 
		
		Комментарий = "Не заполнены настройки начисления пени, Начисление пени не может быть выполнено";		
		ВызватьИсключение Комментарий;
		
	КонецЕсли;
	Выборка = РезультатЗапроса[2].Выбрать();
	Выборка.Следующий();
	ГлубинаОтсрочки 					= Выборка.ГлубинаОтсрочки;
	КрайнийСрокОплаты 					= Выборка.КрайнийСрокОплаты;
	МаксимальнаяГлубинаЗадолженности 	= Выборка.МаксимальнаяГлубинаЗадолженности;

	Если ТекущаяДатаНачислений < ГраницыПериодаНачисления.ЗавершениеОП И ТекущаяДатаНачислений > ГраницыПериодаНачисления.НачалоОП Тогда
		
		Если Выборка.РассчитыватьНаТекущуюДату Тогда
			
			РассчитыватьНаТекущуюДату = Истина;
			
			ГраницыПериодаНачисления.ЗавершениеОП = НачалоДня(ТекущаяДатаНачислений);
			ГраницыПериодаНачисления.ДнейВПериоде = (ГраницыПериодаНачисления.ЗавершениеОП - ГраницыПериодаНачисления.НачалоОП) / (60 * 60 * 24);
			
		КонецЕсли;
		
	КонецЕсли;
	
	СменаСтавкиВПериодеСтатика = СменаСтавкиВПериоде();
	
КонецПроцедуры

Функция ПолучитьСтавкиРефинансирования()
	
	МВТ = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ; 
	Запрос.Текст =
		"ВЫБРАТЬ
		|	энргСтавкиРефинансированияСрезПоследних.Коэффициент КАК Коэффициент,
		|	&НачалоОП КАК Период
		|ПОМЕСТИТЬ СтавкиРефинансированияНабор
		|ИЗ
		|	РегистрСведений.энргСтавкиРефинансирования.СрезПоследних(&НачалоОП, Организация = &Организация) КАК энргСтавкиРефинансированияСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СтавкиРефинансированияНаборЛево.Период КАК ПериодС,
		|	СтавкиРефинансированияНаборЛево.Коэффициент КАК ЗначениеСтавкиРефинансирования,
		|	МИНИМУМ(ЕСТЬNULL(СтавкиРефинансированияНабор.Период, &ЗавершениеОП)) КАК ПериодПо
		|ПОМЕСТИТЬ СтавкиНаПериод
		|ИЗ
		|	СтавкиРефинансированияНабор КАК СтавкиРефинансированияНаборЛево
		|		ЛЕВОЕ СОЕДИНЕНИЕ СтавкиРефинансированияНабор КАК СтавкиРефинансированияНабор
		|		ПО СтавкиРефинансированияНаборЛево.Период < СтавкиРефинансированияНабор.Период
		|
		|СГРУППИРОВАТЬ ПО
		|	СтавкиРефинансированияНаборЛево.Период,
		|	СтавкиРефинансированияНаборЛево.Коэффициент";
	
	Запрос.УстановитьПараметр("НачалоОП", 		ГраницыПериодаНачисления.НачалоОП);
	Запрос.УстановитьПараметр("ЗавершениеОП", 	ГраницыПериодаНачисления.ЗавершениеОП);
	Запрос.УстановитьПараметр("Организация", 	Организация);	
	Запрос.Выполнить(); 	
	
	СтавкиНаПериод = МВТ.Таблицы["СтавкиНаПериод"].ПолучитьДанные().Выгрузить(); 
	Результат = МВТ.Таблицы["СтавкиРефинансированияНабор"].ПолучитьДанные();

	МВТ.Закрыть();	
	Возврат Результат; 	
	
КонецФункции

Функция СменаСтавкиВПериоде()
	
	Результат = Новый Структура();
	Результат.Вставить("ЕстьСмена", Ложь);
	Результат.Вставить("Период", Неопределено);
	Результат.Вставить("Коэффициент", Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСтавкиРефинансирования.Период КАК Период,
		|	энргСтавкиРефинансирования.Коэффициент КАК Коэффициент
		|ИЗ
		|	РегистрСведений.энргСтавкиРефинансирования КАК энргСтавкиРефинансирования
		|ГДЕ
		|	энргСтавкиРефинансирования.Организация = &Организация
		|	И энргСтавкиРефинансирования.Период МЕЖДУ &НП И &КП";
	
	Запрос.УстановитьПараметр("КП", ГраницыПериодаНачисления.ЗавершениеОП-1);
	Запрос.УстановитьПараметр("НП", ГраницыПериодаНачисления.НачалоОП);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
		Результат.ЕстьСмена = Истина;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

