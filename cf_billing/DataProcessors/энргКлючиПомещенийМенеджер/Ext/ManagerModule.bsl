Функция РезультатДанныеПомещенияПоКлючу(КлючПомещения) Экспорт
		
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		Если слжОбщегоНазначенияМодуль.ВоспроизводитьРезультатМетодов() Тогда; 
			Если НЕ Метаданные.Обработки.Найти("слжКлючиПомещенийМенеджер") = Неопределено Тогда
				Возврат Обработки["слжКлючиПомещенийМенеджер"].РезультатДанныеПомещенияПоКлючу(КлючПомещения);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Результат 						= РегистрыСведений.энргКлючиПомещений.РезультатДанныеПомещенияПоКлючу(КлючПомещения);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ПараметрыМетода 				= Новый Структура("КлючПомещения",КлючПомещения);
		ИмяМетода 						= "энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу";
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, Результат, ПараметрыМетода);
	КонецЕсли;
	
	Возврат Результат
	
КонецФункции

Функция КлючПомещенияПоСтроениюИПомещению(Строение, Помещение) Экспорт
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		Если слжОбщегоНазначенияМодуль.ВоспроизводитьРезультатМетодов() Тогда; 
			Если НЕ Метаданные.Обработки.Найти("слжКлючиПомещенийМенеджер") = Неопределено Тогда
				Возврат Обработки["слжКлючиПомещенийМенеджер"].КлючПомещенияПоСтроениюИПомещению(Строение, Помещение);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Результат 						= РегистрыСведений.энргКлючиПомещений.КлючПомещенияПоСтроениюИПомещению(Строение, Помещение);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргКлючиПомещенийМенеджер.КлючПомещенияПоСтроениюИПомещению";
		ПараметрыМетода 			= Новый Структура("Строение, Помещение",Строение, Помещение); 
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, Результат, ПараметрыМетода);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КлючиПомещенийПоРодителюПомещения(Организация, Родитель) Экспорт
	Схема 				= Неопределено;
	ТаблицаИерархии 	= "ИерархияРодителяПомещения";
	ТаблицаКлючей 		= "ДанныеПомещения";	 	
	
	Справочники.энргПомещения.ПомещенияПоРодителю(Схема, ТаблицаИерархии);
	
	ПараметрыСхемы 	= Новый Структура;
	ПараметрыВТ 	= Новый Массив;	
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица(ТаблицаИерархии, Новый Структура("Строение, Помещение", "Строение", "Помещение")));
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);	
	
	РегистрыСведений.энргКлючиПомещений.ДанныеПомещения(Схема, ПараметрыСхемы, ТаблицаКлючей);
	Пакет 									= Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1];
	Оператор 								= Пакет.Операторы[0];
	Оператор.ВыбираемыеПоля.Добавить("&Организация");
	КолонкаЗапроса  						= Пакет.Колонки[Пакет.Колонки.Количество()-1];
	КолонкаЗапроса.Псевдоним 				= "Организация"; 	
	
	ПараметрыСхемы 	= Новый Структура;
	ПараметрыВТ 	= Новый Массив;	
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица(ТаблицаКлючей, Новый Структура("Организация, Район, КлючПомещения", "Организация", "Район", "КлючПомещения")));
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);
	РегистрыСведений.энргАбонентыПомещений.ТекущийАбонентВПомещении(Схема, ПараметрыСхемы); 	
	
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация"	, Организация);
	ПараметрыЗапроса.Вставить("Родитель"	, Родитель);
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса); 
	
	Возврат РезультатЗапроса;	
КонецФункции

#Область ДанныеОКоличествеЧеловек

Функция КоличествоПроживающихПомещения(Период, Организация, Район, КлючПомещения) Экспорт
	Схема 				= Новый СхемаЗапроса;
	ПараметрыОтбора 	= Новый Структура;
	ПараметрыЗапроса 	= Новый Структура;
	
	ПараметрыВТ 		= Новый Массив;	
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Организация"		, "Организация")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Район"			, "Район")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("КлючПомещения"	, "КлючПомещения")));
	
	ПараметрыОтбора.Вставить("Период"		, энргФормированиеТекстовЗапроса.ПараметрПериодРавно("Период"));//Новый Структура("ИмяПараметра, ТипПараметра", "Период" ,"Период"));
	ПараметрыОтбора.Вставить("ПараметрыВТ"	, ПараметрыВТ);
	
	РегистрыСведений.энргКоличествоПроживающих.КоличествоПроживающихПомещения(Схема, ПараметрыОтбора);
	
	ПараметрыЗапроса.Вставить("Период"			, Новый Граница(Период, ВидГраницы.Исключая));
	ПараметрыЗапроса.Вставить("Организация"		, Организация);
	ПараметрыЗапроса.Вставить("Район"			, Район); 	
	ПараметрыЗапроса.Вставить("КлючПомещения"	, КлючПомещения);	
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);
КонецФункции

