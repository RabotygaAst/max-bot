// Процедура - Дополнить схему запроса актуальными адресами ключа помещений
//
// Параметры:
//  Схема						 - СхемаЗапроса - Схема запроса
//  ИмяВременнойТаблицыИсточника - Строка - Имя временной таблицы источника запроса с обязательными полями:
//      * КлючПомещения - Справочник.энргКлючиПомещения  - ссылка на объект,
//      * Строение - Справочник.энргСтроения  - ссылка на объект,
//      * Помещение - Справочник.энргПомещения  - ссылка на объект,
//      * ЧастныйСектор - Булево - признак частного сектора.
//
Процедура ДополнитьСхемуЗапросаАктуальнымиАдресамиКлючаПомещений(Схема, ИмяВременнойТаблицыИсточника) Экспорт	
	Пакет 		= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаКонтактнаяИнформацияКлючаПомещения(ИмяВременнойТаблицыИсточника));	
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	КонтактнаяИнформацияКлючаПомещения.КлючПомещения КАК КлючПомещения,
	|	КонтактнаяИнформацияКлючаПомещения.АдресОбъектаЛС КАК АдресОбъектаЛС,
	|	КонтактнаяИнформацияКлючаПомещения.ЗначениеПолейКИ КАК ЗначениеПолейКИ
	|ПОМЕСТИТЬ АктуальнаяКонтактнаяИнформацияКлючаПомещения
	|ИЗ
	|	(ВЫБРАТЬ
	|		КонтактнаяИнформацияКлючаПомещения.КлючПомещения КАК КлючПомещения,
	|		МАКСИМУМ(КонтактнаяИнформацияКлючаПомещения.НомерСтроки) КАК НомерСтроки
	|	ИЗ
	|		КонтактнаяИнформацияКлючаПомещения КАК КонтактнаяИнформацияКлючаПомещения
	|	
	|	СГРУППИРОВАТЬ ПО
	|		КонтактнаяИнформацияКлючаПомещения.КлючПомещения) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КонтактнаяИнформацияКлючаПомещения КАК КонтактнаяИнформацияКлючаПомещения
	|		ПО ВложенныйЗапрос.КлючПомещения = КонтактнаяИнформацияКлючаПомещения.КлючПомещения
	|			И ВложенныйЗапрос.НомерСтроки = КонтактнаяИнформацияКлючаПомещения.НомерСтроки");	
КонецПроцедуры 

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаКонтактнаяИнформацияКлючаПомещения(ИмяВременнойТаблицыИсточника) 
	Шаблон = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.АдресОбъектаЛС КАК АдресОбъектаЛС,
	|	ВложенныйЗапрос.Значение КАК ЗначениеПолейКИ,
	|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ КонтактнаяИнформацияКлючаПомещения
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВыборкаКлючейПомещений.КлючПомещения КАК КлючПомещения,
	|		энргСтроенияКонтактнаяИнформация.Представление КАК АдресОбъектаЛС,
	|		энргСтроенияКонтактнаяИнформация.Значение КАК Значение,
	|		энргСтроенияКонтактнаяИнформация.НомерСтроки КАК НомерСтроки
	|	ИЗ
	|		%1 КАК ВыборкаКлючейПомещений
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
	|			ПО ВыборкаКлючейПомещений.Строение = энргСтроенияКонтактнаяИнформация.Ссылка
	|				И (энргСтроенияКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес))
	|				И (энргСтроенияКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресДома))
	|				И (ВыборкаКлючейПомещений.ЧастныйСектор)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВыборкаКлючейПомещений.КлючПомещения,
	|		энргПомещенияКонтактнаяИнформация.Представление,
	|		энргПомещенияКонтактнаяИнформация.Значение,
	|		энргПомещенияКонтактнаяИнформация.НомерСтроки
	|	ИЗ
	|		%1 КАК ВыборкаКлючейПомещений
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПомещения.КонтактнаяИнформация КАК энргПомещенияКонтактнаяИнформация
	|			ПО ВыборкаКлючейПомещений.Помещение = энргПомещенияКонтактнаяИнформация.Ссылка
	|				И (энргПомещенияКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес))
	|				И (энргПомещенияКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресПомещения))
	|				И (НЕ ВыборкаКлючейПомещений.ЧастныйСектор)) КАК ВложенныйЗапрос";
	
	Результат = СтрШаблон(Шаблон, ИмяВременнойТаблицыИсточника);
	Возврат Результат;
КонецФункции

#КонецОбласти

#КонецЕсли