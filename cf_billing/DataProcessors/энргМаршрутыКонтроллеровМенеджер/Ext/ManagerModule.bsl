// Получает данные маршрута по ключу помещения.
//
// Параметры:
//  КлючПомещения	-	СправочникСсылка.энргКлючиПомещений.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ДанныеМаршрутаПоКлючуПомещения(КлючПомещения) Экспорт  
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		Если слжОбщегоНазначенияМодуль.ВоспроизводитьРезультатМетодов() Тогда; 
			Если НЕ Метаданные.Обработки.Найти("слжМаршрутыКонтроллеровМенеджер") = Неопределено Тогда
				Возврат Обработки["слжМаршрутыКонтроллеровМенеджер"].ДанныеМаршрутаПоКлючуПомещения(КлючПомещения);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Результат 						= Справочники.энргМаршрутыКонтроллеров.ДанныеМаршрутаПоКлючуПомещения(КлючПомещения);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "МаршрутыКонтроллеровМенеджер.ДанныеМаршрутаПоКлючуПомещения";
		ПараметрыМетода 			= Новый Структура("КлючПомещения", КлючПомещения);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, Результат, ПараметрыМетода);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Регистрирует ключ помещения в маршруте контролера.
//
// Параметры:
//  МаршрутКонтролера	-	СправочникСсылка.энргМаршрутыКонтроллеров.
//  КлючПомещения		-	СправочникСсылка.энргКлючиПомещений.
//
Процедура ЗарегистрироватьКлючПомещенияВМаршрутеКонтролера(МаршрутКонтролера, КлючПомещения) Экспорт
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		Если слжОбщегоНазначенияМодуль.ВоспроизводитьРезультатМетодов() Тогда; 
			Если НЕ Метаданные.Обработки.Найти("слжМаршрутыКонтроллеровМенеджер") = Неопределено Тогда
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли; 	
		
	РегистрыСведений.энргКлючиПомещенийМаршрутовКонтролеров.ЗарегистрироватьКлючПомещенияВМаршрутеКонтролера(МаршрутКонтролера, КлючПомещения);		
КонецПроцедуры

#КонецОбласти

#КонецЕсли