#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Функция СоздатьДокументыСписанияЗадолженности(ДанныеШапки, Результат) Экспорт
	РезультатСоздания 	= Новый Структура("Успешно, ТекстОшибки", Истина, "");
	
	Выборка 			= Результат.Выбрать();
	
	ДокМенеджер 		= Документы.энргБанкротство;
	ВидОперации 		= Перечисления.энргВидыОпераций.энргБанкротство_СписаниеНаЗабалансФЛ;
	Примечание			= "Документ создан " + ТекущаяДата() + " из обработки массового создания";
	ПериодНачисления	= Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ДанныеШапки.ДатаСозданияДокументов, ДанныеШапки.Организация, ДанныеШапки.Район);
		
	ТекАбонент 			= Неопределено;
	НДокумент			= Неопределено;	
	
	НачатьТранзакцию();
	Попытка
		Пока Выборка.Следующий() Цикл
			
			Если НЕ ТекАбонент = Выборка.Абонент Тогда
				Если НЕ НДокумент = Неопределено Тогда
					НДокумент.Записать(РежимЗаписиДокумента.Проведение);
				КонецЕсли;
				
				НДокумент = ДокМенеджер.СоздатьДокумент();
				НДокумент.Дата 				= ДанныеШапки.ДатаСозданияДокументов;
				НДокумент.ПериодНачисления 	= ПериодНачисления;
				НДокумент.Организация 		= ДанныеШапки.Организация;
				НДокумент.Район 			= ДанныеШапки.Район;
				НДокумент.Абонент 			= Выборка.Абонент;
				НДокумент.КлючПомещения 	= Выборка.КлючПомещения;
				НДокумент.Строение 			= Выборка.Строение;
				НДокумент.ВидОперации 		= ВидОперации;
				НДокумент.Примечание 		= Примечание;  				
			КонецЕсли;
			
			НСтрока = НДокумент.ДанныеСписания.Добавить();
			ЗаполнитьЗначенияСвойств(НСтрока, Выборка);			
			
			ТекАбонент = Выборка.Абонент;
		КонецЦикла;
		
		Если НЕ НДокумент = Неопределено Тогда
			НДокумент.Записать(РежимЗаписиДокумента.Проведение);
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
		//ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документы успешно созданы");
	Исключение
		ОтменитьТранзакцию();
		
		РезультатСоздания.Успешно 			= Ложь;
		РезультатСоздания.ТекстОшибки 		= СтрШаблон("1%(ЛС - 2%) ошибка: ", ТекАбонент, СокрЛП(ТекАбонент.ЛицевойСчет)) + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());	
		
		//ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка при создании документа: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	Возврат РезультатСоздания;
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли