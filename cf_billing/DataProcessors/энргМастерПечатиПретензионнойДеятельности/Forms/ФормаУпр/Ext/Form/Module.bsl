	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргЭтапПретензионноИсковойДеятельности.Абонент
	|ПОМЕСТИТЬ ВТ_АбонентыДляУдаления
	|ИЗ
	|	Документ.энргЭтапПретензионноИсковойДеятельности КАК энргЭтапПретензионноИсковойДеятельности
	|ГДЕ
	|	энргЭтапПретензионноИсковойДеятельности.Абонент = &Абонент
	|	И энргЭтапПретензионноИсковойДеятельности.ЭтапПИД = &ВидОперации2
	|	И энргЭтапПретензионноИсковойДеятельности.Дата МЕЖДУ &НачПериода И &КонПериода
	|;
	|
