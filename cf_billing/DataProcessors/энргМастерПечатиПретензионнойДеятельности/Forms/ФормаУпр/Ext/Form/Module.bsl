	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(энргВзаиморасчетыОстатки.СуммаОстаток) КАК Долг,
	|	энргВзаиморасчетыОстатки.Абонент,
	|	энргВзаиморасчетыОстатки.Услуга,
	|	энргВзаиморасчетыОстатки.Абонент.ЛицевойСчет КАК ЛС
	|ПОМЕСТИТЬ ВТ_Абоненты
	|ИЗ
	|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(&КонПериода, Абонент В ИЕРАРХИИ (&Абонент)) КАК энргВзаиморасчетыОстатки
	|ГДЕ
	|	НЕ энргВзаиморасчетыОстатки.Абонент В
	|				(ВЫБРАТЬ
	|					ВТ_АбонентыДляУдаления.Абонент
	|				ИЗ
	|					ВТ_АбонентыДляУдаления КАК ВТ_АбонентыДляУдаления)
	|	И энргВзаиморасчетыОстатки.СуммаОстаток <= &СуммаЗадолженности
	|
	|СГРУППИРОВАТЬ ПО
	|	энргВзаиморасчетыОстатки.Абонент,
	|	энргВзаиморасчетыОстатки.Услуга,
	|	энргВзаиморасчетыОстатки.Абонент.ЛицевойСчет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргАбонентыКонтактнаяИнформация.Представление КАК Адрес,
	|	энргАбонентыКонтактнаяИнформация.Ссылка.Ссылка КАК Абонент
	|ПОМЕСТИТЬ ВТ_Адрес
	|ИЗ
	|	Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
	|ГДЕ
	|	энргАбонентыКонтактнаяИнформация.Ссылка.Ссылка В
	|			(ВЫБРАТЬ
	|				ВТ_Абоненты.Абонент
	|			ИЗ
	|				ВТ_Абоненты КАК ВТ_Абоненты)
	|	И энргАбонентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЭтапПретензионноИсковойДеятельности.Ссылка КАК УведомлениеПредыдущее,
	|	энргЭтапПретензионноИсковойДеятельности.Дата КАК УведомлениеДата,
	|	энргЭтапПретензионноИсковойДеятельности.Абонент
	|ПОМЕСТИТЬ ВТ_ПредИзвещение
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		МАКСИМУМ(энргЭтапПретензионноИсковойДеятельности.Дата) КАК Дата,
	|		энргЭтапПретензионноИсковойДеятельности.Абонент КАК Абонент
	|	ИЗ
	|		Документ.энргЭтапПретензионноИсковойДеятельности КАК энргЭтапПретензионноИсковойДеятельности
	|	ГДЕ
	|		энргЭтапПретензионноИсковойДеятельности.Дата < &НачПериода
	|		И энргЭтапПретензионноИсковойДеятельности.Абонент В
	|				(ВЫБРАТЬ
	|					ВТ_Абоненты.Абонент
	|				ИЗ
	|					ВТ_Абоненты КАК ВТ_Абоненты)
	|		И энргЭтапПретензионноИсковойДеятельности.ЭтапПИД = &ВидОперации
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргЭтапПретензионноИсковойДеятельности.Абонент) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргЭтапПретензионноИсковойДеятельности КАК энргЭтапПретензионноИсковойДеятельности
	|		ПО ВложенныйЗапрос.Дата = энргЭтапПретензионноИсковойДеятельности.Дата
	|			И ВложенныйЗапрос.Абонент = энргЭтапПретензионноИсковойДеятельности.Абонент
	|ГДЕ
	|	энргЭтапПретензионноИсковойДеятельности.ЭтапПИД = &ВидОперации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Абоненты.ЛС,
	|	ВТ_Абоненты.Абонент,
	|	ВТ_Адрес.Адрес,
	|	ВТ_Абоненты.Долг,
	|	ВТ_Абоненты.Услуга,
	|	ВТ_ПредИзвещение.УведомлениеПредыдущее,
	|	ВТ_ПредИзвещение.УведомлениеДата
	|ИЗ
	|	ВТ_Абоненты КАК ВТ_Абоненты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Адрес КАК ВТ_Адрес
	|		ПО ВТ_Абоненты.Абонент = ВТ_Адрес.Абонент
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПредИзвещение КАК ВТ_ПредИзвещение
	|		ПО ВТ_Абоненты.Абонент = ВТ_ПредИзвещение.Абонент";
	Если ЗначениеЗаполнено(Объект.Абонент) Тогда	
		Запрос.УстановитьПараметр("Абонент", Объект.Абонент);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"энргЭтапПретензионноИсковойДеятельности.Абонент = &Абонент","");
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И энргЭтапПретензионноИсковойДеятельности.ЭтапПИД = &ВидОперации2","энргЭтапПретензионноИсковойДеятельности.ЭтапПИД = &ВидОперации2");
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"Абонент В ИЕРАРХИИ (&Абонент)","");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Абонент) Тогда	
		Запрос.УстановитьПараметр("СуммаЗадолженности", Объект.СуммаЗадолженности);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И энргВзаиморасчетыОстатки.СуммаОстаток <= &СуммаЗадолженности","");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВидОперации",Справочники.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Предупреждение);
	Запрос.УстановитьПараметр("ВидОперации2",Справочники.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Предупреждение);
	Запрос.УстановитьПараметр("КонПериода", Объект.КонПериода);
	Запрос.УстановитьПараметр("НачПериода", Объект.НачПериода);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	Объект.Предупреждение.Загрузить(ТЗ);
	
КонецПроцедуры

