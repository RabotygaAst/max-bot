&НаСервере
Функция  СформироватьДокументыПредНаСервере(ТабДок)
	НачатьТранзакцию();
	
	Для каждого Стр из объект.Уведомление Цикл
		// Проверяет был ли создан документ Извещение для данного абонента.
		// Если нет - Документ Предупреждение не сформируется!
		// Если да  - Документ Предупреждение сформируется!
		ДокОснование = Проверка(Стр.Абонент,Справочники.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Извещение);
		
		Если Стр.Сформировать Тогда
			
			Если ДокОснование <> Неопределено Тогда
				
				Док = Документы.энргЭтапПретензионноИсковойДеятельности.СоздатьДокумент(); 
				Док.Дата				= ТекущаяДата();
				Док.Абонент 			= Стр.Абонент;
				Док.АдресОбъекта		= Стр.Адрес;
				Док.Поставщик 			= Стр.Поставщик;
				Док.ЛицевойСчет 		= Стр.ЛС;
				Док.СуммаЗадолженности 	= Стр.Долг;
				Док.ЭтапПИД 			= Справочники.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Предупреждение; 				
				Док.Основание			= ДокОснование;
				
				Док.Записать(РежимЗаписиДокумента.Проведение);	
				
				Если Стр.Печатать Тогда
					ТабДок = Док.ЗаполнитьПредупреждение(ТабДок);
				КонецЕсли;
								
			иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для абонента: " + Стр.Абонент + " не найден документ ""Извещение""");				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	ЗафиксироватьТранзакцию();
	
	Возврат ТабДок;
КонецФункции

&НаКлиенте
Процедура СформироватьДокументыПред(Команда)
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.КоличествоЭкземпляров = 2;
	ТабДок.ОтображатьСетку = Ложь;
	
	СформироватьДокументыПредНаСервере(ТабДок).Показать();
КонецПроцедуры


&НаСервере
Функция Проверка(Абонент,Этап)
	
	Док = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргЭтапыПретензионноИсковойДеятельности.Регистратор КАК Документ
	|ИЗ
	|	РегистрСведений.энргЭтапыПретензионноИсковойДеятельности КАК энргЭтапыПретензионноИсковойДеятельности
	|ГДЕ
	|	энргЭтапыПретензионноИсковойДеятельности.Абонент = &Абонент
	|	И энргЭтапыПретензионноИсковойДеятельности.Регистратор.Дата МЕЖДУ &НП И &КП
	|	И энргЭтапыПретензионноИсковойДеятельности.Этап = &Этап";
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	Запрос.УстановитьПараметр("НП", НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("КП", КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Этап", Этап);
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Док = Выборка.Документ;
	КонецЕсли;
	
	Возврат Док;  	
	
КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Абоненты = Неопределено;
	Если Параметры.Свойство("Абоненты", Абоненты) Тогда
		ЗаполнитьНаСервере(Абоненты);
	КонецЕсли;
КонецПроцедуры
