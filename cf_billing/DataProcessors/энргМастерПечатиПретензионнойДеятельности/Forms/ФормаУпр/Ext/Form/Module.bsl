&НаСервере
Функция СформироватьДокументыНаСервере(ТабДок)
	НачатьТранзакцию();
	
	Для каждого Стр из объект.Уведомление Цикл
		
		Если Стр.Сформировать Тогда
			Док = Документы.энргЭтапПретензионноИсковойДеятельности.СоздатьДокумент(); 
			Док.Дата				= ТекущаяДата();
			Док.Абонент 			= Стр.Абонент;
			Док.АдресОбъекта		= Стр.Адрес;
			Док.Поставщик 			= Стр.Поставщик;
			Док.ЛицевойСчет 		= Стр.ЛС;
			Док.СуммаЗадолженности 	= Стр.Долг;
			Док.ЭтапПИД 			= Справочники.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Уведомление;		
			Док.Записать(РежимЗаписиДокумента.Проведение);
			
			Если Стр.Печатать Тогда
				ТабДок = Док.ЗаполнитьУведомление(ТабДок); 				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	ЗафиксироватьТранзакцию();
	
	Возврат ТабДок;
КонецФункции

&НаКлиенте
Процедура СформироватьДокументы(Команда)
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.КоличествоЭкземпляров = 2;
	ТабДок.ОтображатьСетку = Ложь;
	
	СформироватьДокументыНаСервере(ТабДок).Показать();
КонецПроцедуры

///////////////
// Извещение!///
///////////////

&НаСервере
Функция  СформироватьДокументыИзвНаСервере(ТабДок)
	НачатьТранзакцию();
	
	Для каждого Стр из объект.Уведомление Цикл
		// Проверяет был ли создан документ Уведомление для данного абонента.
		// Если нет - Документ Извещение не сформируется!
		// Если да  - Документ Извещение сформируется!
		ДокОснование = Проверка(Стр.Абонент,Справочники.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Уведомление);
		
		Если Стр.Сформировать Тогда
			
			Если  ДокОснование <> Неопределено Тогда
				Док = Документы.энргЭтапПретензионноИсковойДеятельности.СоздатьДокумент();
				Док.Дата									= ТекущаяДата();
				Док.Абонент 								= Стр.Абонент;
				Док.АдресОбъекта							= Стр.Адрес;
				Док.Поставщик 								= Стр.Поставщик;
				Док.ЛицевойСчет 							= Стр.ЛС;
				Док.СуммаЗадолженности 						= Стр.Долг;
				Док.ЭтапПИД 								= Справочники.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Извещение;				
				Док.Основание								= ДокОснование;				
				Док.Записать(РежимЗаписиДокумента.Проведение);
				Если Стр.Печатать Тогда
					ТабДок = Док.ЗаполнитьИзвещение(ТабДок);
				КонецЕсли; 				
				
			иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для абонента: " + Стр.Абонент + " не найден документ ""Уведомление"""); 				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	ЗафиксироватьТранзакцию();
	
	Возврат ТабДок;
	
КонецФункции

&НаКлиенте
Процедура СформироватьДокументыИзв(Команда)
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.КоличествоЭкземпляров = 2;
	ТабДок.ОтображатьСетку = Ложь;
	
	СформироватьДокументыИзвНаСервере(ТабДок).Показать();
КонецПроцедуры

