Функция ИзменитьЗадолженность(Знач ТекущееСостояниеЗадолженности, Знач ДанныеДокумента) Экспорт 	
	УменьшитьАванс(ТекущееСостояниеЗадолженности,ДанныеДокумента);
	УвеличитьЗадолженность(ТекущееСостояниеЗадолженности,ДанныеДокумента);
	Оплатить(ТекущееСостояниеЗадолженности,ДанныеДокумента);
	Возврат ТекущееСостояниеЗадолженности;	
КонецФункции

Функция СформироватьНаборыДляЗаписи(Знач ИсходноеСостояние, Знач ТекущееСостояниеЗадолженности) Экспорт 
	
КонецФункции

Процедура ЗаполнитьЗадолженностьНаГраницуНарушенияПоследовательности(МВТ,СостояниеЗадолженностиВсехАбонентов, Знач ИмяТаблицыАбоненты,Знач ИмяТаблицыГраницаНарушения, Знач Делегат = Неопределено) Экспорт	
	
	Если Делегат = Неопределено Тогда
		Делегат 					= ДелегатЗаполнитьЗадолженностьНаГраницуНарушенияПоследовательностиПоУмолчанию();
	КонецЕсли;
	
	ИмяТаблицыОстаткиНаНачало 		= "ОстатокЗадолженностиПоУслугамНаНачалоПериода";
	Делегат.МетодПолучитьОстатокЗадолженностиНаНачалоПериода.Вызвать(Новый Структура("МВТ,ИмяТаблицыДляПомещения",МВТ,ИмяТаблицыОстаткиНаНачало));
	
	ИмяТаблицыВзаиморасчетыОбороты 	= "ОборотыВзаиморасчетовПоУслугамЗаПериодНачисления";
	Делегат.МетодПолучитьОборотыЗадолженностиЗаПериод.Вызвать(Новый Структура("МВТ,ИмяТаблицыДляПомещения",МВТ,ИмяТаблицыВзаиморасчетыОбороты));
				
	Результат   					= РезультатЗадолженностьНаГраницуНарушенияПоследовательности(МВТ,ИмяТаблицыАбоненты,ИмяТаблицыГраницаНарушения,ИмяТаблицыОстаткиНаНачало,ИмяТаблицыВзаиморасчетыОбороты);
	Выборка 						= Результат.Выбрать();
	текАбонент 						= Неопределено;
	Пока Выборка.Следующий() Цикл
		Если Не текАбонент = Выборка.Абонент Тогда
			УслугиПоМесяцам 		= ОписаниеТаблицыЗадолженности();
			Если СостояниеЗадолженностиВсехАбонентов[Выборка.Абонент] = Неопределено Тогда
				СостояниеЗадолженностиВсехАбонентов.Вставить(Выборка.Абонент, Новый Структура("УслугиПоМесяцам", УслугиПоМесяцам));			
			КонецЕсли;
		КонецЕсли;		
		УслугиПоМесяцам 			= СостояниеЗадолженностиВсехАбонентов[Выборка.Абонент].УслугиПоМесяцам;
		ЗаполнитьЗначенияСвойств(УслугиПоМесяцам.Добавить(), Выборка);		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеВсехДокументовИзмененияЗадолженности(МВТ, ДанныеИзмененияЗадолженностиВсехДокументов, Знач ИмяТаблицыДокументыДляПроведения, Знач Делегат = Неопределено) Экспорт  
	
	Если Делегат = Неопределено Тогда
		Делегат 						= ДелегатЗаполнитьДанныеВсехДокументовИзмененияЗадолженностиПоУмолчанию();
	КонецЕсли;
	
	Результат   						= РезультатДанныеДокументовИзмененияЗадолженности(МВТ, ИмяТаблицыДокументыДляПроведения);
	Выборка 							= Результат.Выбрать();
	текАбонент 							= Неопределено;
	текРегистратор 						= Неопределено;
	Пока Выборка.Следующий() Цикл
		Если Не текАбонент = Выборка.Абонент 
			ИЛИ НЕ текРегистратор = Выборка.ДокРегистратор Тогда
			УслугиПоМесяцам 			= ОписаниеТаблицыДанныеДокумента();
			Если ДанныеИзмененияЗадолженностиВсехДокументов[Выборка.Абонент] = Неопределено Тогда
				СоотвествиеРегистратор 	= Новый Соответствие;
				СоотвествиеРегистратор.Вставить(Выборка.ДокРегистратор, Новый Структура("УслугиПоМесяцам", УслугиПоМесяцам));
				ДанныеИзмененияЗадолженностиВсехДокументов.Вставить(Выборка.Абонент, СоотвествиеРегистратор);			
			ИначеЕсли ДанныеИзмененияЗадолженностиВсехДокументов[Выборка.Абонент][Выборка.ДокРегистратор] = Неопределено Тогда
				ДанныеИзмененияЗадолженностиВсехДокументов[Выборка.Абонент].Вставить(Выборка.ДокРегистратор, Новый Структура("УслугиПоМесяцам", УслугиПоМесяцам));				
			КонецЕсли;
		КонецЕсли; 				
		НачисленияПоУслугам 			= ДанныеИзмененияЗадолженностиВсехДокументов[Выборка.Абонент][Выборка.Регистратор].УслугиПоМесяцам;
		ЗаполнитьЗначенияСвойств(НачисленияПоУслугам.Добавить(), Выборка);
		текАбонент 						= Выборка.Абонент;
		текРегистратор 					= Выборка.ДокРегистратор;
	КонецЦикла;
	
КонецПроцедуры

