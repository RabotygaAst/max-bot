Функция ТекстЗапросаЗадолженностьНаГраницу()
	
	Текст 	=
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.Поставщик КАК Поставщик,
	|	ВложенныйЗапрос.ПериодРасчета КАК ПериодРасчета,
	|	СУММА(ВложенныйЗапрос.Сумма) КАК Сумма
	|ИЗ
	|	(ВЫБРАТЬ
	|		ОстатокНачалоПериода.Организация КАК Организация,
	|		ОстатокНачалоПериода.ПериодНачисления КАК ПериодНачисления,
	|		ОстатокНачалоПериода.Район КАК Район,
	|		ОстатокНачалоПериода.МКД КАК МКД,
	|		ОстатокНачалоПериода.Абонент КАК Абонент,
	|		ОстатокНачалоПериода.Услуга КАК Услуга,
	|		ОстатокНачалоПериода.Поставщик КАК Поставщик,
	|		ОстатокНачалоПериода.ПериодНачисления КАК ПериодРасчета,
	|		ОстатокНачалоПериода.Сумма КАК Сумма
	|	ИЗ
	|		РазличныеАбоненты КАК РазличныеАбоненты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОстатокЗадолженностиПоУслугамНаНачалоПериода КАК ОстатокНачалоПериода
	|			ПО РазличныеАбоненты.Район = ОстатокНачалоПериода.Район
	|				И РазличныеАбоненты.МКД = ОстатокНачалоПериода.МКД
	|				И РазличныеАбоненты.Абонент = ОстатокНачалоПериода.Абонент
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВзаиморасчетыОбороты.Организация КАК Организация,
	|		ВзаиморасчетыОбороты.ПериодНачисления,
	|		ВзаиморасчетыОбороты.Район,
	|		ВзаиморасчетыОбороты.МКД,
	|		ВзаиморасчетыОбороты.Абонент,
	|		ВзаиморасчетыОбороты.Услуга,
	|		ВзаиморасчетыОбороты.Поставщик,
	|		ВзаиморасчетыОбороты.ПериодНачисления,
	|		СУММА(ВзаиморасчетыОбороты.Сумма)
	|	ИЗ
	|		ГраницаНарушенияПоследовательности КАК ГраницаНарушенияПоследовательности
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОборотыВзаиморасчетовПоУслугамЗаПериодНачисления КАК ВзаиморасчетыОбороты
	|			ПО (ВЫБОР
	|					КОГДА ГраницаНарушенияПоследовательности.ДатаРегистратора > ВзаиморасчетыОбороты.Период
	|						ТОГДА ИСТИНА
	|					КОГДА ГраницаНарушенияПоследовательности.ДатаРегистратора = ВзаиморасчетыОбороты.Период
	|						ТОГДА ВЫБОР
	|								КОГДА ГраницаНарушенияПоследовательности.ДопПорядок = 0
	|										И ВзаиморасчетыОбороты.Регистратор ССЫЛКА Документ.энргНачисление
	|									ТОГДА ЛОЖЬ
	|								ИНАЧЕ ГраницаНарушенияПоследовательности.ДокРегистратор > ВзаиморасчетыОбороты.Регистратор
	|							КОНЕЦ
	|					ИНАЧЕ ЛОЖЬ
	|				КОНЕЦ)
	|				И ГраницаНарушенияПоследовательности.Район = ВзаиморасчетыОбороты.Район
	|				И ГраницаНарушенияПоследовательности.МКД = ВзаиморасчетыОбороты.МКД
	|				И ГраницаНарушенияПоследовательности.Абонент = ВзаиморасчетыОбороты.Абонент
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ВзаиморасчетыОбороты.Организация,
	|		ВзаиморасчетыОбороты.ПериодНачисления,
	|		ВзаиморасчетыОбороты.Район,
	|		ВзаиморасчетыОбороты.МКД,
	|		ВзаиморасчетыОбороты.Абонент,
	|		ВзаиморасчетыОбороты.Услуга,
	|		ВзаиморасчетыОбороты.Поставщик,
	|		ВзаиморасчетыОбороты.ПериодНачисления) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Организация,
	|	ВложенныйЗапрос.ПериодНачисления,
	|	ВложенныйЗапрос.Район,
	|	ВложенныйЗапрос.МКД,
	|	ВложенныйЗапрос.Абонент,
	|	ВложенныйЗапрос.Услуга,
	|	ВложенныйЗапрос.Поставщик,
	|	ВложенныйЗапрос.ПериодРасчета
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	ПериодНачисления,
	|	Район,
	|	МКД,
	|	Абонент,
	|	ПериодРасчета,
	|	Услуга";
	Возврат Текст;

КонецФункции

Функция ОписаниеТаблицыЗадолженности()
	тзУслугиПоМесяцам 			= Новый ТаблицаЗначений;
	тзУслугиПоМесяцам.Колонки.Добавить("Организация", 		Новый ОписаниеТипов("СправочникСсылка.Организации"));
	тзУслугиПоМесяцам.Колонки.Добавить("Район", 			Новый ОписаниеТипов("СправочникСсылка.энргЗоныОтвественности"));	
	тзУслугиПоМесяцам.Колонки.Добавить("МКД", 				Новый ОписаниеТипов("СправочникСсылка.энргСтроения"));
	тзУслугиПоМесяцам.Колонки.Добавить("Абонент", 			Новый ОписаниеТипов("СправочникСсылка.энргАбоненты"));
	тзУслугиПоМесяцам.Колонки.Добавить("Услуга", 			Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	тзУслугиПоМесяцам.Колонки.Добавить("ПериодНачисления", 	Новый ОписаниеТипов("Дата"));
	тзУслугиПоМесяцам.Колонки.Добавить("Поставщик", 		Новый ОписаниеТипов("СправочникСсылка.энргКонтрагенты"));
	тзУслугиПоМесяцам.Колонки.Добавить("Сумма", 			Метаданные.РегистрыНакопления.энргВзаиморасчетыПоМесяцам.Ресурсы.Сумма.Тип);
	Возврат тзУслугиПоМесяцам;
КонецФункции

Функция ОписаниеТаблицыДанныеДокумента()
	тзНачисленияПоУслугам 		= Новый ТаблицаЗначений;
	тзНачисленияПоУслугам.Колонки.Добавить("Организация", 			Новый ОписаниеТипов("СправочникСсылка.Организации"));
	тзНачисленияПоУслугам.Колонки.Добавить("Район", 				Новый ОписаниеТипов("СправочникСсылка.энргЗоныОтвественности"));
	тзНачисленияПоУслугам.Колонки.Добавить("МКД", 					Новый ОписаниеТипов("СправочникСсылка.энргСтроения"));
	тзНачисленияПоУслугам.Колонки.Добавить("Абонент", 				Новый ОписаниеТипов("СправочникСсылка.энргАбоненты"));
	тзНачисленияПоУслугам.Колонки.Добавить("Услуга", 				Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	тзНачисленияПоУслугам.Колонки.Добавить("Поставщик", 			Новый ОписаниеТипов("СправочникСсылка.энргКонтрагенты"));
	тзНачисленияПоУслугам.Колонки.Добавить("ПериодНачисления", 		Новый ОписаниеТипов("Дата"));
	тзНачисленияПоУслугам.Колонки.Добавить("ПериодРасчета", 		Новый ОписаниеТипов("Дата"));
	тзНачисленияПоУслугам.Колонки.Добавить("Сумма", 				Метаданные.РегистрыНакопления.энргОбъемНачислений.Ресурсы.Сумма.Тип);
	Возврат тзНачисленияПоУслугам;
