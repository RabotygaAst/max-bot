#Область РаботаСОтборами

Функция СформироватьСписокОтборов()
	
	Результат 		= Новый Массив;
	ОсновнойОтбор 	= Новый Структура("Организация,Район", "Организация", "Район");
	Результат.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(ОсновнойОтбор));
	
	Если НЕ МКД = Неопределено Тогда 
		Отбор = Новый Структура("МКД", "МКД");
		Результат.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Отбор));
	КонецЕсли;
	
	Если НЕ СписокМКД = Неопределено Тогда 
		Отбор = Новый Структура("МКД", "СписокМКД");
		Результат.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Отбор));
	КонецЕсли;

	
	Если НЕ Абонент = Неопределено Тогда 
		Отбор = Новый Структура("Абонент", "Абонент");
		Результат.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Отбор));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СформироватьПараметрыЗапроса()
	
	Результат = Новый Структура;
	Результат.Вставить("ПериодНачисления"			, ПериодНачисления);
	Результат.Вставить("Организация"				, Организация);
	Результат.Вставить("Район"						, Район);
	Результат.Вставить("НачалоПериодаРасчета"		, ГраницыПериодаНачисления.НачалоПериодаРасчета);
	Результат.Вставить("КонецПериодаРасчета"		, ГраницыПериодаНачисления.КонецПериодаРасчета);
	Результат.Вставить("СначалаТекущиеНачисления"	, СначалаТекущиеНачисления);	
	
	Если НЕ МКД = Неопределено Тогда 
		Результат.Вставить("МКД", МКД);
	КонецЕсли;
	
	Если НЕ СписокМКД = Неопределено Тогда 
		Результат.Вставить("СписокМКД", СписокМКД);
	КонецЕсли;
	
	Если НЕ Абонент = Неопределено Тогда 
		Результат.Вставить("Абонент", Абонент);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
	
#КонецОбласти

#КонецОбласти

#Область РеализацияИнтерфейса_РаспределениеДенежныхСредств

#Область УвеличениеЗадолженности

Процедура УвеличитьЗадолженность(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора)
				
	Если НЕ ДанныеДокумента.ЭтоКорректировкаОплаты И ПараметрыОперации.СуммаАвансаЖивымиДеньгами > 0 тогда
		 УменьшитьАванс(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора);
	КонецЕсли;
	
	ТаблицаВзаиморасчеты 	= ДанныеДокумента.НаборТаблиц.энргВзаиморасчетыПоПени;
	РасшифровкаНачислений 	= ДанныеНачисленияРегистратора.Расшифровка;	
	РасшифровкаНачислений.Сортировать("СуммаНачислений,ПериодРасчета");
	
	РасшифровкаЗадолженности= ДанныеЗадолженности.Расшифровка;
	
	БылиИзменения = Ложь;
	
	////////// сначала отрицательные строки записываем в аванс
	////////для Каждого СтрокаНачисления из РасшифровкаНачислений цикл
	////////	
	////////	Если СтрокаНачисления.СуммаНачислений = 0 ИЛИ (ДанныеДокумента.ЭтоКорректировкаОплаты И СтрокаНачисления.ПериодРасчета > ПараметрыОперации.ПериодНачисления) тогда
	////////		Продолжить;
	////////	ИначеЕсли СтрокаНачисления.СуммаНачислений < 0 тогда
	////////		
	////////		ОтрицательнаяСуммаНачислений(
	////////			ПараметрыОперации,
	////////			ДанныеДокумента, 
	////////			-СтрокаНачисления.СуммаНачислений, 
	////////			СтрокаНачисления.Услуга, 
	////////			СтрокаНачисления.Поставщик, 
	////////			СтрокаНачисления.ПериодРасчета);
	////////			
	////////			БылиИзменения = Истина;	
	////////		СтрокаНачисления.СуммаНачислений = 0;
	////////		Продолжить;
	////////		
	////////	КонецЕсли;
	////////	
	////////КонецЦикла;
	////////
	////////// если отрицательные строки дали аванс, то закрываем им положительнве строки из этого же документа
	////////Если ПараметрыОперации.СуммаАванса > 0 тогда
	////////	// Пеня не гасится авансом
	////////	// УменьшитьАванс(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора);
	////////КонецЕсли;
	
	
	
	для Каждого СтрокаНачисления из РасшифровкаНачислений цикл
		
		Если СтрокаНачисления.СуммаНачислений = 0 ИЛИ (ДанныеДокумента.ЭтоКорректировкаОплаты И СтрокаНачисления.ПериодРасчета > ПараметрыОперации.ПериодНачисления) тогда
			Продолжить;
		ИначеЕсли СтрокаНачисления.СуммаНачислений < 0 тогда
			
			ОтрицательнаяСуммаНачислений(
				ПараметрыОперации, 
				ДанныеДокумента, 
				-СтрокаНачисления.СуммаНачислений, 
				СтрокаНачисления.Услуга, 
				СтрокаНачисления.Поставщик, 
				СтрокаНачисления.ПериодРасчета);
				
			СтрокаНачисления.СуммаНачислений = 0;
			Продолжить;
			
		КонецЕсли;
		
		БылиИзменения 									= Истина;
		
		СтрокаЗадолженности  							= РасшифровкаЗадолженности.Добавить();
		//ЗаполнитьЗначенияСвойств(СтрокаЗадолженности, СтрокаНачисления,, "ПериодРасчета");
		ЗаполнитьЗначенияСвойств(СтрокаЗадолженности, СтрокаНачисления);
		СтрокаЗадолженности.СуммаЗадолженности			= СтрокаНачисления.СуммаНачислений;
		
				
		СтрокаВзаиморасчеты 							= ТаблицаВзаиморасчеты.Добавить();
		СтрокаВзаиморасчеты.Организация					= ПараметрыОперации.Организация;
		СтрокаВзаиморасчеты.ПериодРегистрации			= ПараметрыОперации.ПериодНачисления;		
		СтрокаВзаиморасчеты.Район 						= ПараметрыОперации.Район;
		СтрокаВзаиморасчеты.ВидДвижения					= ВидДвиженияНакопления.Приход;
		СтрокаВзаиморасчеты.Активность					= Истина;
		СтрокаВзаиморасчеты.Период 						= ДанныеДокумента.Период;
		СтрокаВзаиморасчеты.МКД 						= ДанныеДокумента.МКД;
		СтрокаВзаиморасчеты.Абонент 					= ДанныеДокумента.Абонент; 		
		СтрокаВзаиморасчеты.Услуга 						= СтрокаНачисления.Услуга;
		//СтрокаВзаиморасчеты.Поставщик 					= СтрокаНачисления.Поставщик;
		СтрокаВзаиморасчеты.Сумма 						= СтрокаНачисления.СуммаНачислений;
		СтрокаВзаиморасчеты.ПериодНачисления			= СтрокаНачисления.ПериодНачисления;		
		СтрокаВзаиморасчеты.ПериодРасчета				= СтрокаНачисления.ПериодРасчета;
		//СтрокаВзаиморасчеты.ПериодРасчета				= ?(ЗначениеЗаполнено(СтрокаНачисления.ПериодРасчета), СтрокаНачисления.ПериодРасчета, Неопределено);
	КонецЦикла; 
	
	Если БылиИзменения Тогда
		//РасшифровкаЗадолженности.Свернуть("ПериодРасчета,ПорядокПериодРасчета,ПорядокПогашенияУслуги,Поставщик,Услуга", "СуммаЗадолженности");
		//РасшифровкаЗадолженности.Сортировать("ПорядокПериодРасчета,ПериодРасчета,ПорядокПогашенияУслуги,Услуга");
		РасшифровкаЗадолженности.Свернуть("ПериодРасчета,ПериодНачисления,ПорядокПериодРасчета,ПорядокПросуженнойЗадолженности,ПорядокПогашенияУслуги,Поставщик,Услуга", "СуммаЗадолженности");
		РасшифровкаЗадолженности.Сортировать("ПорядокПросуженнойЗадолженности,ПорядокПериодРасчета,ПериодРасчета,ПериодНачисления,ПорядокПогашенияУслуги,Услуга");
		ДанныеЗадолженности.СуммаЗадолженности = РасшифровкаЗадолженности.Итог("СуммаЗадолженности");
	КонецЕсли;
	
	Если ТипЗнч(ДанныеДокумента.Регистратор) = Тип("ДокументСсылка.энргРучноеИзменениеПени") Тогда
		Для Каждого ТекСтрока Из ТаблицаВзаиморасчеты Цикл
			НовСтрока = ДанныеДокумента.НаборТаблиц.энргНачислениеПени.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока);
			НовСтрока.ПериодРасчета	= ПараметрыОперации.ПериодНачисления;
			Если ТекСтрока.ВидДвижения	= ВидДвиженияНакопления.Расход Тогда
				НовСтрока.Сумма	= -НовСтрока.Сумма;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура ОтрицательнаяСуммаНачислений(ПараметрыОперации, ДанныеДокумента, Сумма, Услуга, Поставщик, ПериодРасчета)

	ПараметрыОперации.вставить("СнятьТекущие",Истина);
	ПараметрыОперации.вставить("ВозвратАванса",Новый Структура("Услуга,Поставщик,ПериодРасчета", Услуга, Поставщик, ПериодРасчета));
	
	Если НЕ ПараметрыОперации.ОтрицательныеНачисленияСоздаютАвансы Или ПараметрыОперации.ЭтоНачислениеТекущегоМесяца Тогда
		// Списываем задолженность по услуге за текущий период.
		СписатьЗадолженность(ПараметрыОперации, ДанныеДокумента, Сумма, Услуга, Поставщик, ПериодРасчета);
		// Списываем задолженность по другим услугам за текущий период.
		СписатьЗадолженность(ПараметрыОперации, ДанныеДокумента, Сумма, Неопределено, Поставщик, ПериодРасчета);	
	КонецЕсли;	
	// Списываем пропорционально и записываем в аванс если что то останется.
	СписатьЗадолженность(ПараметрыОперации, ДанныеДокумента, Сумма, Неопределено, Неопределено, Неопределено);
	
	Если Сумма > 0 Тогда
		// вот тут надо Сумму = 0!!!!
		Сумма = 0;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область УменьшениеЗадолженностиПени

Процедура РаспределитьОплатуАбонентаПоНазначениюПлатежа(ПараметрыОперации, ДанныеОплаты, ДанныеДокумента)
		
	РасшифровкаОплаты = ДанныеОплаты.Расшифровка;
	Для Каждого СтрокаОплаты Из РасшифровкаОплаты Цикл
		
		Если СтрокаОплаты.Разделитель <> ДанныеДокумента.Разделитель Тогда
			Продолжить;
		КонецЕсли;
		
		СписатьЗадолженность(ПараметрыОперации, ДанныеДокумента, СтрокаОплаты.Сумма, СтрокаОплаты.Услуга, СтрокаОплаты.Поставщик, СтрокаОплаты.ПериодВзаиморасчетов);
		          		
		Если СтрокаОплаты.Сумма > 0 Тогда
			ПараметрыОперации.ОсвободившиесяДеньги.Сумма = ПараметрыОперации.ОсвободившиесяДеньги.Сумма + СтрокаОплаты.Сумма;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура РаспределитьОстатокОплатыАбонента(ПараметрыОперации, ДанныеОплаты, ДанныеДокумента)
	
	СписатьЗадолженность(ПараметрыОперации, ДанныеДокумента, ПараметрыОперации.ОсвободившиесяДеньги.Сумма, Неопределено, Неопределено, Неопределено);
	
КонецПроцедуры


Процедура СписатьЗадолженность(ПараметрыОперации, ДанныеДокумента, Сумма, Услуга = Неопределено, Поставщик = Неопределено, ПериодРасчета  = Неопределено)	
	
	Если Сумма <= 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ Услуга = Неопределено И ЗначениеЗаполнено(Услуга) Тогда
		яУслуга = Услуга;
	КонецЕсли;
	
	Если НЕ ПериодРасчета = Неопределено И ЗначениеЗаполнено(ПериодРасчета) Тогда
		яПериодРасчета = ПериодРасчета;
	КонецЕсли;
	
	Если НЕ Поставщик = Неопределено И ЗначениеЗаполнено(Поставщик) Тогда
		яПоставщик = Поставщик;
	КонецЕсли;
	
	Если НЕ яУслуга = Неопределено ИЛИ НЕ яПериодРасчета = Неопределено ИЛИ НЕ яПоставщик = Неопределено Тогда
		СписатьЗадолженностьПоУслуге(ПараметрыОперации, ДанныеДокумента, Сумма, яУслуга, яПоставщик, яПериодРасчета);	
	иначеЕсли ПараметрыОперации.СпособРаспределенияОплаты = Перечисления.энргСпособыРаспределенияОплаты.ПоУслугамСогласноНастройкамРаспределения тогда
		СписатьЗадолженностьСогласноНастройкиРаспределения(ПараметрыОперации, ДанныеДокумента, Сумма);
	иначе
		СписатьЗадолженностьПропорциональноЗадолженности(ПараметрыОперации, ДанныеДокумента, Сумма);
	КонецЕсли;	
		
КонецПроцедуры

Процедура СписатьЗадолженностьПоУслуге(ПараметрыОперации, ДанныеДокумента, НадоСписать, Услуга, Поставщик, ПериодРасчета)
	
	перем яПериодРасчета, яУслуга, яПоставщик;
	
	РасшифровкаЗадолженности 	= ДанныеЗадолженности.Расшифровка;	
	ТаблицаВзаиморасчеты 		= ДанныеДокумента.НаборТаблиц.энргВзаиморасчетыПоПени;
	
	ЭтоОплата = Истина;
	СнятьТекущие = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОперации, "СнятьТекущие", Ложь);
	Если СнятьТекущие Тогда
		ЭтоОплата = Ложь;
	КонецЕсли;
	
	ТаблицаОплатаУслуг = Неопределено;
	Если ЭтоОплата Тогда
		ТаблицаОплатаУслуг = ДанныеДокумента.НаборТаблиц.энргОплатаПени;
	КонецЕсли;
	
	Если НЕ ПериодРасчета = Неопределено И НЕ Услуга = Неопределено И НЕ Поставщик = Неопределено Тогда
		
		СтруктураПоиска  						= Новый Структура("Услуга,ПериодНачисления,Поставщик");
		СтруктураПоиска.Услуга 					= Услуга;
		СтруктураПоиска.ПериодНачисления 		= ПериодРасчета;
		СтруктураПоиска.Поставщик 				= Поставщик;
		
	ИначеЕсли НЕ ПериодРасчета = Неопределено И НЕ Услуга = Неопределено И Поставщик = Неопределено Тогда
		
		СтруктураПоиска  						= Новый Структура("ПериодНачисления,Услуга");
		СтруктураПоиска.ПериодНачисления 		= ПериодРасчета;
		СтруктураПоиска.Услуга 					= Услуга;
		
	ИначеЕсли НЕ ПериодРасчета = Неопределено И Услуга = Неопределено И НЕ Поставщик = Неопределено Тогда 
		
		СтруктураПоиска  						= Новый Структура("ПериодНачисления,Поставщик");
		СтруктураПоиска.ПериодНачисления 		= ПериодРасчета;
		СтруктураПоиска.Поставщик 				= Поставщик;
		
	ИначеЕсли ПериодРасчета = Неопределено И НЕ Услуга = Неопределено И НЕ Поставщик = Неопределено Тогда 
		
		СтруктураПоиска  						= Новый Структура("Услуга,Поставщик");
		СтруктураПоиска.Услуга 					= Услуга;
		СтруктураПоиска.Поставщик 				= Поставщик;
		
	ИначеЕсли НЕ ПериодРасчета = Неопределено И Услуга = Неопределено И Поставщик = Неопределено Тогда
		
		СтруктураПоиска  						= Новый Структура("ПериодНачисления");
		СтруктураПоиска.ПериодНачисления 		= ПериодРасчета;
		
	ИначеЕсли ПериодРасчета = Неопределено И Услуга = Неопределено И НЕ Поставщик = Неопределено Тогда
		
		СтруктураПоиска  						= Новый Структура("Поставщик");
		СтруктураПоиска.Поставщик 				= Поставщик;
		
	ИначеЕсли ПериодРасчета = Неопределено И НЕ Услуга = Неопределено И Поставщик = Неопределено Тогда
		
		СтруктураПоиска  						= Новый Структура("Услуга");
		СтруктураПоиска.Услуга 					= Услуга;	
		
	Иначе
		ВызватьИсключение "Что то пошло не так";		
	КонецЕсли;
	
	СтрокиЗадолженности = РасшифровкаЗадолженности.НайтиСтроки(СтруктураПоиска);	
	МассивУдаляемых 	= Новый Массив;
	
	для Каждого СтрокаЗадолженности из СтрокиЗадолженности цикл
		Списываем = Мин(НадоСписать, СтрокаЗадолженности.СуммаЗадолженности);
		
		// Уменьшаем задолженность по месяцам.
		СтрокаВзаиморасчеты 					= ТаблицаВзаиморасчеты.Добавить();		
		СтрокаВзаиморасчеты.Активность	 		= Истина;
		СтрокаВзаиморасчеты.ВидДвижения 		= ВидДвиженияНакопления.Расход;
		СтрокаВзаиморасчеты.Организация 		= ПараметрыОперации.Организация;
		СтрокаВзаиморасчеты.Район		 		= ПараметрыОперации.Район;
		СтрокаВзаиморасчеты.ПериодРегистрации	= ПараметрыОперации.ПериодНачисления;
		СтрокаВзаиморасчеты.МКД			 		= ДанныеДокумента.МКД;
		СтрокаВзаиморасчеты.Абонент				= ДанныеДокумента.Абонент;
		СтрокаВзаиморасчеты.Период	 			= ДанныеДокумента.период;
		СтрокаВзаиморасчеты.Услуга				= СтрокаЗадолженности.Услуга;
		//СтрокаВзаиморасчеты.Поставщик			= СтрокаЗадолженности.Поставщик;
		СтрокаВзаиморасчеты.ПериодНачисления	= СтрокаЗадолженности.ПериодНачисления;
		СтрокаВзаиморасчеты.ПериодРасчета 		= СтрокаЗадолженности.ПериодРасчета;
		СтрокаВзаиморасчеты.Сумма				= Списываем; 		
		
		Если ЭтоОплата Тогда
			СтрокаОплатаУслуг 						= ТаблицаОплатаУслуг.Добавить();
			СтрокаОплатаУслуг.Активность	 		= Истина;
			СтрокаОплатаУслуг.Организация 			= ПараметрыОперации.Организация;
			СтрокаОплатаУслуг.Район		 			= ПараметрыОперации.Район;
			СтрокаОплатаУслуг.МКД			 		= ДанныеДокумента.МКД;
			СтрокаОплатаУслуг.Абонент				= ДанныеДокумента.Абонент;
			СтрокаОплатаУслуг.Период	 			= ДанныеДокумента.период;
			//СтрокаОплатаУслуг.ИсточникПоступления	= ДанныеДокумента.ИсточникПоступления;
			//СтрокаОплатаУслуг.Кассир				= ДанныеДокумента.Кассир;
			СтрокаОплатаУслуг.Услуга				= СтрокаЗадолженности.Услуга;
			СтрокаОплатаУслуг.Поставщик				= СтрокаЗадолженности.Поставщик;
			СтрокаОплатаУслуг.ПериодНачисления		= СтрокаЗадолженности.ПериодНачисления;
			СтрокаОплатаУслуг.ПериодРасчета			= ПараметрыОперации.ПериодНачисления;//СтрокаЗадолженности.ПериодРасчета;
			СтрокаОплатаУслуг.ПериодНачисленияПени	= СтрокаЗадолженности.ПериодРасчета;
			СтрокаОплатаУслуг.Сумма					= Списываем;
		КонецЕсли;		
		
		СтрокаЗадолженности.СуммаЗадолженности 	= СтрокаЗадолженности.СуммаЗадолженности - Списываем; 		
		НадоСписать 							= НадоСписать - Списываем;
		
		Если СтрокаЗадолженности.СуммаЗадолженности = 0 тогда
			МассивУдаляемых.Добавить(СтрокаЗадолженности);
		КонецЕсли;  		
		
		Если НадоСписать = 0 Тогда
			Прервать;
		КонецЕсли; 		
		
	КонецЦикла;
	
	для Каждого УдаляемаяСтрока из МассивУдаляемых цикл
		РасшифровкаЗадолженности.Удалить(УдаляемаяСтрока);
	КонецЦикла;
	
КонецПроцедуры

Процедура СписатьЗадолженностьСогласноНастройкиРаспределения(ПараметрыОперации, ДанныеДокумента, НадоСписать)
	
	ВызватьИсключение "Проверить";
	
	ТаблицаВзаиморасчеты = ДанныеДокумента.НаборТаблиц.энргВзаиморасчетыПоМесяцам;
	
	Если ДанныеДокумента.ЭтоОплата Тогда 
		ТаблицаОплатаУслуг			 	= ДанныеДокумента.НаборТаблиц.энргОплатаУслуг;
	иначе
		ТаблицаАвансыИспользованные 	= ДанныеДокумента.НаборТаблиц.энргАвансыИспользованные
	КонецЕсли;
	
	РасшифровкаЗадолженности 	= ДанныеЗадолженности.Расшифровка;	
	МассивУдаляемых				= Новый Массив;
	
	для Каждого СтрокаЗадолженности из РасшифровкаЗадолженности цикл
		
		Списываем = Мин(СтрокаЗадолженности.СуммаЗадолженности,НадоСписать);
		
		СтрокаЗадолженности.СуммаЗадолженности = СтрокаЗадолженности.СуммаЗадолженности - Списываем;
		
		Если СтрокаЗадолженности.СуммаЗадолженности = 0 тогда
			МассивУдаляемых.Добавить(СтрокаЗадолженности);
		КонецЕсли;
				
		СтрокаВзаиморасчеты 							= ТаблицаВзаиморасчеты.Добавить();
		СтрокаВзаиморасчеты.Организация		 			= ПараметрыОперации.Организация;
		СтрокаВзаиморасчеты.Район 						= ПараметрыОперации.Район;
		СтрокаВзаиморасчеты.ПериодНачисления 			= СтрокаЗадолженности.ПериодРасчета;
		СтрокаВзаиморасчеты.ВидДвижения					= ВидДвиженияНакопления.Расход;
		СтрокаВзаиморасчеты.Активность					= Истина;
		СтрокаВзаиморасчеты.Период 						= ДанныеДокумента.Период;		
		СтрокаВзаиморасчеты.МКД 						= ДанныеДокумента.МКД;
		СтрокаВзаиморасчеты.Абонент 					= ДанныеДокумента.Абонент;
		СтрокаВзаиморасчеты.Услуга 						= СтрокаЗадолженности.услуга;
		СтрокаВзаиморасчеты.Сумма 						= Списываем;
		СтрокаВзаиморасчеты.Поставщик					= СтрокаЗадолженности.Поставщик;
		СтрокаВзаиморасчеты.ПериодРегистрации			= ПараметрыОперации.ПериодНачисления;
		
		Если ДанныеДокумента.ЭтоОплата тогда 
			СтрокаОплатаУслуг 							= ТаблицаОплатаУслуг.добавить();
			СтрокаОплатаУслуг.Активность				= истина;
			СтрокаОплатаУслуг.Период 					= ДанныеДокумента.Период;
			СтрокаОплатаУслуг.Организация				= ПараметрыОперации.Организация;
			СтрокаОплатаУслуг.Район 					= ПараметрыОперации.Район;
			СтрокаОплатаУслуг.МКД 						= ДанныеДокумента.МКД;
			СтрокаОплатаУслуг.Абонент 					= ДанныеДокумента.Абонент;
			СтрокаОплатаУслуг.Услуга 					= СтрокаЗадолженности.Услуга;
			СтрокаОплатаУслуг.Поставщик					= СтрокаЗадолженности.Поставщик;
			СтрокаОплатаУслуг.Сумма 					= Списываем;
			СтрокаОплатаУслуг.ПериодНачисления			= СтрокаЗадолженности.ПериодРасчета;
			СтрокаОплатаУслуг.ПериодРасчета				= ПараметрыОперации.ПериодНачисления;
			СтрокаОплатаУслуг.Кассир					= ДанныеДокумента.Кассир;
			СтрокаОплатаУслуг.ИсточникПоступления		= ДанныеДокумента.ИсточникПоступления;
			СтрокаОплатаУслуг.Разделитель				= ДанныеДокумента.Разделитель;
		иначе
			ТаблицаАвансыИспользованные					= ДанныеДокумента.НаборТаблиц.энргАвансыИспользованные;
			ЗаписьАвансыИспользованные					= ТаблицаАвансыИспользованные.добавить();
			ЗаписьАвансыИспользованные.Активность  		= истина;
			ЗаписьАвансыИспользованные.Период  			= ДанныеДокумента.Период;
			ЗаписьАвансыИспользованные.Организация		= ПараметрыОперации.Организация;
			ЗаписьАвансыИспользованные.Район  			= ПараметрыОперации.Район;
			ЗаписьАвансыИспользованные.МКД	  			= ДанныеДокумента.МКД;
			ЗаписьАвансыИспользованные.Абонент  		= ДанныеДокумента.Абонент;
			ЗаписьАвансыИспользованные.Сумма 			= Списываем;
			ЗаписьАвансыИспользованные.ПериодНачисления	= ПараметрыОперации.ПериодНачисления;
			ЗаписьАвансыИспользованные.Поставщик		= СтрокаЗадолженности.Поставщик;
			ЗаписьАвансыИспользованные.Услуга			= СтрокаЗадолженности.услуга;
			ЗаписьАвансыИспользованные.ПериодРасчета	= ПараметрыОперации.ПериодНачисления;
			ЗаписьАвансыИспользованные.Разделитель		= ДанныеДокумента.Разделитель;
			// Возвращаем использованный аванс на услугу с которой снимаем начисления.					
			ТаблицаАвансыИспользованные					= ДанныеДокумента.НаборТаблиц.энргАвансыИспользованные;
			ЗаписьАвансыИспользованные					= ТаблицаАвансыИспользованные.добавить();
			ЗаписьАвансыИспользованные.Активность  		= истина;
			ЗаписьАвансыИспользованные.Период  			= ДанныеДокумента.Период;
			ЗаписьАвансыИспользованные.Район  			= ПараметрыОперации.Район;
			ЗаписьАвансыИспользованные.МКД	  			= ДанныеДокумента.МКД;
			ЗаписьАвансыИспользованные.Абонент  		= ДанныеДокумента.Абонент;
			ЗаписьАвансыИспользованные.Сумма 			= -Списываем;
			ЗаписьАвансыИспользованные.ПериодНачисления	= ПараметрыОперации.ПериодНачисления;
			ЗаписьАвансыИспользованные.Поставщик		= ПараметрыОперации.ВозвратАванса.Поставщик;
			ЗаписьАвансыИспользованные.Услуга			= ПараметрыОперации.ВозвратАванса.услуга;
			ЗаписьАвансыИспользованные.ПериодРасчета	= ПараметрыОперации.ПериодНачисления;
			ЗаписьАвансыИспользованные.Разделитель		= ДанныеДокумента.Разделитель;
		КонецЕсли;
												
		НадоСписать = НадоСписать - Списываем;
	КонецЦикла; 
	
	для Каждого УдаляемаяСтрока из МассивУдаляемых цикл
		РасшифровкаЗадолженности.Удалить(УдаляемаяСтрока);
	КонецЦикла;
	
КонецПроцедуры

Процедура СписатьЗадолженностьПропорциональноЗадолженности(ПараметрыОперации, ДанныеДокумента, НадоСписать)
	
	РасшифровкаЗадолженности = ДанныеЗадолженности.Расшифровка;
	
	ПериодыЗадолженности = РасшифровкаЗадолженности.Скопировать();
	ПериодыЗадолженности.Свернуть("ПериодНачисления,ПериодРасчета,ПорядокПросуженнойЗадолженности","СуммаЗадолженности");
	ПериодыЗадолженности.Сортировать("ПорядокПросуженнойЗадолженности,ПериодРасчета,ПериодНачисления"); 	
	
	ТаблицаВзаиморасчеты 	= ДанныеДокумента.НаборТаблиц.энргВзаиморасчетыПоПени;
	ТаблицаОплата 			= ДанныеДокумента.НаборТаблиц.энргОплатаПени;
		
	СтрокиУдалить = Новый Массив;
	
	Для Сч = 0 По ПериодыЗадолженности.Количество() - 1 Цикл
		//СтрокиВПериоде 										= РасшифровкаЗадолженности.НайтиСтроки(Новый Структура("ПериодРасчета", ПериодыЗадолженности[Сч].ПериодРасчета));
		СтрокиВПериоде 										= РасшифровкаЗадолженности.НайтиСтроки(Новый Структура("ПорядокПросуженнойЗадолженности,ПериодНачисления,ПериодРасчета", ПериодыЗадолженности[Сч].ПорядокПросуженнойЗадолженности, ПериодыЗадолженности[Сч].ПериодНачисления, ПериодыЗадолженности[Сч].ПериодРасчета));
		ОстатокСуммы 										= НадоСписать;
		ОбщаяСуммаЗаПериод									= ПериодыЗадолженности[Сч].СуммаЗадолженности;
		
		Для ИндексСтроки = 0 По СтрокиВПериоде.ВГраница() Цикл			
			
			Если ОбщаяСуммаЗаПериод = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ДоляВПериоде	 								= СтрокиВПериоде[ИндексСтроки].СуммаЗадолженности / ОбщаяСуммаЗаПериод;
			СписываемПоДоле 								= ?(ИндексСтроки = СтрокиВПериоде.ВГраница(), НадоСписать, ДоляВПериоде * ОстатокСуммы);
			Списываем 										= Окр(Мин(СписываемПоДоле, СтрокиВПериоде[ИндексСтроки].СуммаЗадолженности),2);
			НадоСписать 									= НадоСписать - Списываем;
						
			СтрокаВзаиморасчеты 							= ТаблицаВзаиморасчеты.Добавить();
			СтрокаВзаиморасчеты.Организация		 			= ПараметрыОперации.Организация;
			СтрокаВзаиморасчеты.ПериодНачисления 			= СтрокиВПериоде[ИндексСтроки].ПериодНачисления;
			СтрокаВзаиморасчеты.ПериодРасчета 				= СтрокиВПериоде[ИндексСтроки].ПериодРасчета;
			СтрокаВзаиморасчеты.ПериодРегистрации			= ПараметрыОперации.ПериодНачисления;
			СтрокаВзаиморасчеты.Район 						= ПараметрыОперации.Район;
			СтрокаВзаиморасчеты.ВидДвижения					= ВидДвиженияНакопления.Расход;
			СтрокаВзаиморасчеты.Активность					= Истина;
			СтрокаВзаиморасчеты.Период 						= ДанныеДокумента.Период;			
			СтрокаВзаиморасчеты.МКД 						= ДанныеДокумента.МКД;
			СтрокаВзаиморасчеты.Абонент 					= ДанныеДокумента.Абонент;
			//СтрокаВзаиморасчеты.Поставщик					= СтрокиВПериоде[ИндексСтроки].Поставщик;
			СтрокаВзаиморасчеты.Услуга 						= СтрокиВПериоде[ИндексСтроки].Услуга;
			СтрокаВзаиморасчеты.Сумма 						= Списываем;
			СтрокаВзаиморасчеты.Разделитель					= ДанныеДокумента.Разделитель;
			
			СтрокиВПериоде[ИндексСтроки].СуммаЗадолженности = СтрокиВПериоде[ИндексСтроки].СуммаЗадолженности - Списываем;
			Если СтрокиВПериоде[ИндексСтроки].СуммаЗадолженности = 0 Тогда
				СтрокиУдалить.Добавить(СтрокиВПериоде[ИндексСтроки]);
			КонецЕсли;
			
			Если ДанныеДокумента.ЭтоОплата тогда						
				СтрокаОплатаУслуг 							= ТаблицаОплата.добавить();
				СтрокаОплатаУслуг.Активность				= Истина;  				
				СтрокаОплатаУслуг.Организация				= ПараметрыОперации.Организация;
				СтрокаОплатаУслуг.Район 					= ПараметрыОперации.Район;
				СтрокаОплатаУслуг.Период 					= ДанныеДокумента.Период;
				СтрокаОплатаУслуг.МКД 						= ДанныеДокумента.МКД;
				СтрокаОплатаУслуг.Абонент 					= ДанныеДокумента.Абонент;
				//СтрокаОплатаУслуг.Кассир					= ДанныеДокумента.Кассир;
				//СтрокаОплатаУслуг.ИсточникПоступления		= ДанныеДокумента.ИсточникПоступления;
				СтрокаОплатаУслуг.Услуга 					= СтрокиВПериоде[ИндексСтроки].услуга;
				СтрокаОплатаУслуг.Поставщик					= СтрокиВПериоде[ИндексСтроки].Поставщик;
				СтрокаОплатаУслуг.Сумма 					= Списываем;
				СтрокаОплатаУслуг.ПериодНачисления 			= СтрокиВПериоде[ИндексСтроки].ПериодНачисления;
				СтрокаОплатаУслуг.ПериодРасчета 			= ПараметрыОперации.ПериодНачисления; //СтрокиВПериоде[ИндексСтроки].ПериодРасчета;
				СтрокаОплатаУслуг.ПериодНачисленияПени		= СтрокиВПериоде[ИндексСтроки].ПериодРасчета;
				СтрокаОплатаУслуг.Разделитель				= ДанныеДокумента.Разделитель;
			иначе
				
			КонецЕсли; 			
			
			Если НадоСписать = 0 тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НадоСписать = 0 тогда
			Прервать;
		КонецЕсли; 		
	КонецЦикла;
	
	Для Каждого СтрокаУдалить Из СтрокиУдалить Цикл
		РасшифровкаЗадолженности.Удалить(СтрокаУдалить);
	КонецЦикла;
			
КонецПроцедуры

#КонецОбласти

#Область РаботаСАвансами

#Область УвеличениеАванса

Процедура СторнироватьОплату(ПараметрыОперации, ДанныеДокумента, ДанныеНачислений)	
		
	ТаблицаОплатаУслуг  				= ДанныеДокумента.НаборТаблиц.энргОплатаПени;
	ТаблицаАвансыИспользованные			= ДанныеДокумента.НаборТаблиц.энргАвансыИспользованные;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&Район КАК Район,
	|	&МКД КАК МКД,
	|	&Абонент КАК Абонент,
	|	&период КАК Период,
	|	&ПериодНачисления КАК ПериодРасчета,
	|	ИСТИНА КАК Активность,
	|	энргОплатаПени.Услуга КАК Услуга,
	|	энргОплатаПени.Поставщик КАК Поставщик,
	|	&ИсточникПоступления КАК ИсточникПоступления,
	|	энргОплатаПени.ПериодНачисления КАК ПериодНачисления,
	|	энргОплатаПени.ПериодНачисленияПени КАК ПериодНачисленияПени,
	|	-энргОплатаПени.Сумма КАК Сумма,
	|	энргОплатаПени.Разделитель КАК Разделитель
	|ИЗ
	|	Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.энргОплатаПени КАК энргОплатаПени
	|		ПО энргПерерасчетКорректировкаОплаты.ДокументОплаты = энргОплатаПени.Регистратор
	|			И (энргОплатаПени.Абонент = &Абонент)
	|			И (энргПерерасчетКорректировкаОплаты.УслугаБыло = энргОплатаПени.Услуга
	|				ИЛИ энргПерерасчетКорректировкаОплаты.УслугаБыло = ЗНАЧЕНИЕ(Справочник.энргвидыуслуг.пустаяссылка))
	|			И (энргПерерасчетКорректировкаОплаты.ПоставщикБыло = энргОплатаПени.Поставщик
	|				ИЛИ энргПерерасчетКорректировкаОплаты.ПоставщикБыло = ЗНАЧЕНИЕ(Справочник.энргконтрагенты.пустаяссылка))
	|			И энргПерерасчетКорректировкаОплаты.Разделитель = энргОплатаПени.Разделитель
	|			И (энргОплатаПени.Сумма > 0)
	|ГДЕ
	|	энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ДанныеДокумента.Регистратор);
	Запрос.УстановитьПараметр("ПериодНачисления", ПараметрыОперации.ПериодНачисления);
	Запрос.УстановитьПараметр("Абонент", ДанныеДокумента.Абонент);
	Запрос.УстановитьПараметр("период", ДанныеДокумента.период);
	Запрос.УстановитьПараметр("МКД", ДанныеДокумента.МКД);
	Запрос.УстановитьПараметр("Район", ПараметрыОперации.Район);
	Запрос.УстановитьПараметр("Организация", ПараметрыОперации.Организация);
	Запрос.УстановитьПараметр("ИсточникПоступления", ДанныеДокумента.ИсточникПоступления);
	
	
	Результат 			= Запрос.Выполнить();
	Выборка  			= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаОплатаУслуг.Добавить(), Выборка);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&Район КАК Район,
	|	&МКД КАК МКД,
	|	&Абонент КАК Абонент,
	|	&Ссылка КАК ДокументОплаты,
	|	энргАвансыИспользованные.Услуга КАК Услуга,
	|	энргАвансыИспользованные.Поставщик КАК Поставщик,
	|	энргАвансыИспользованные.ПериодРасчета КАК ПериодНачисления,
	|	-энргАвансыИспользованные.Сумма КАК Сумма,
	|	&период КАК Период,
	|	&ПериодНачисления КАК ПериодРасчета,
	|	ИСТИНА КАК Активность,
	|	энргАвансыИспользованные.Разделитель КАК Разделитель,
	|	ИСТИНА КАК ЭтоПеня
	|ИЗ
	|	РегистрНакопления.энргАвансыИспользованные КАК энргАвансыИспользованные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|		ПО энргАвансыИспользованные.ДокументОплаты = энргПерерасчетКорректировкаОплаты.ДокументОплаты
	|			И энргАвансыИспользованные.Разделитель = энргПерерасчетКорректировкаОплаты.Разделитель
	|			И (энргАвансыИспользованные.Абонент = &Абонент)
	|			И энргАвансыИспользованные.ПериодРасчета <= энргПерерасчетКорректировкаОплаты.Ссылка.ПериодНачисления
	|			И (энргПерерасчетКорректировкаОплаты.УслугаБыло = энргАвансыИспользованные.Услуга
	|				ИЛИ энргПерерасчетКорректировкаОплаты.УслугаБыло = ЗНАЧЕНИЕ(Справочник.энргвидыуслуг.пустаяссылка))
	|			И (энргПерерасчетКорректировкаОплаты.ПоставщикБыло = энргАвансыИспользованные.Поставщик
	|				ИЛИ энргПерерасчетКорректировкаОплаты.ПоставщикБыло = ЗНАЧЕНИЕ(Справочник.энргконтрагенты.пустаяссылка))
	|			И (энргАвансыИспользованные.Сумма > 0)
	|			И (энргАвансыИспользованные.Регистратор ССЫЛКА Документ.энргНачислениеПени
	|				ИЛИ энргАвансыИспользованные.Регистратор ССЫЛКА Документ.энргРучноеИзменениеПени)
	|ГДЕ
	|	энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка
	|	И энргАвансыИспользованные.Регистратор <> &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ДанныеДокумента.Регистратор);
	Запрос.УстановитьПараметр("ПериодНачисления", ПараметрыОперации.ПериодНачисления);
	Запрос.УстановитьПараметр("Абонент", ДанныеДокумента.Абонент);
	Запрос.УстановитьПараметр("период", ДанныеДокумента.период);
	Запрос.УстановитьПараметр("МКД", ДанныеДокумента.МКД);
	Запрос.УстановитьПараметр("Район", ПараметрыОперации.Район);
	Запрос.УстановитьПараметр("Организация", ПараметрыОперации.Организация);
	
	
	Результат 			= Запрос.Выполнить();
	Выборка  			= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаАвансыИспользованные.Добавить(), Выборка);
	КонецЦикла;	
КонецПроцедуры

#КонецОбласти

#Область УменьшениеАванс

Процедура УменьшитьАванс(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора)	
			
	Если ПараметрыОперации.СпособРаспределенияОплаты = Перечисления.энргСпособыРаспределенияОплаты.ПоУслугамСогласноНастройкамРаспределения тогда
		УменьшитьАвансСогласноНастройкиРаспределения(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора);
	иначе
		УменьшитьАвансПропорциональноЗадолженности(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора);
	КонецЕсли;
	
КонецПроцедуры

Процедура УменьшитьАвансСогласноНастройкиРаспределения(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора)
	
	ТаблицаАвансы 				= ДанныеДокумента.НаборТаблиц.энргАвансы;
	ТаблицаАвансыИспользованные = ДанныеДокумента.НаборТаблиц.энргАвансыИспользованные;
		
	ОстатокАванса		 		= ПараметрыОперации.СуммаАвансаЖивымиДеньгами;
	ОписаниеСтрокиначислений  	= Новый ФиксированнаяСтруктура("Период,Услуга,Организация, ПериодНачисления,Сумма");
	НастройкиПорядкаПогашения 	= ПараметрыОперации.НастройкиПорядкаПогашения;
	ВыборкаПорядок  			= НастройкиПорядкаПогашения.выбрать();
	Пока ВыборкаПорядок.Следующий() и ОстатокАванса > 0 цикл			
		
		НачисленияПоУслуге = ДанныеНачисленияРегистратора.Получить(ВыборкаПорядок.Услуга);
		
		Если НачисленияПоУслуге <> Неопределено тогда 
			
			ПериодыНачислений = НачисленияПоУслуге.ПериодыНачислений;			
			МассивУдаляемых = Новый Массив;
			
			для Каждого ПериодНачисления из ПериодыНачислений цикл 								
				
				Списываем = Мин(ОстатокАванса,ПериодНачисления.СуммаНачислений);
				Если  Списываем = 0 тогда
					Продолжить;
				КонецЕсли;			
				
				Если ПериодНачисления.СуммаНачислений < 0 тогда
					
					ПараметрыОперации.Сумма = -ПериодНачисления.СуммаНачислений;
					ОтрицательнаяСуммаНачислений(
						ПараметрыОперации, 
						ДанныеДокумента, 
						-ПериодНачисления.СуммаНачислений, 
						ВыборкаПорядок.Услуга,
						ПериодНачисления.Поставщик,
						ПериодНачисления.ПериодРасчета);
						
					ОстатокАванса = ОстатокАванса - ПериодНачисления.СуммаНачислений;
					МассивУдаляемых.Добавить(ПериодНачисления);
					
				иначе
					ВызватьИсключение "Проверь меня";
					
					ДобавитьРасходАванса(ПараметрыОперации, ДанныеДокумента, Списываем, Неопределено);					
					ОстатокАванса  						= ОстатокАванса - Списываем;			
					ПериодНачисления.СуммаНачислений 	= ПериодНачисления.СуммаНачислений -Списываем;
				КонецЕсли;
				
				Если ПериодНачисления.СуммаНачислений = 0 тогда
					МассивУдаляемых.Добавить(ПериодНачисления);
				КонецЕсли;				
			КонецЦикла;
			
			// Удаляем нулевые строки.
			для Каждого УдаляемаяСтрока из МассивУдаляемых цикл
				ПериодыНачислений.Удалить(УдаляемаяСтрока);
			КонецЦикла;
			
			// Если не осталось строк начисления удаляем все по ключу.
			Если НачисленияПоУслуге.ПериодыНачислений.количество() = 0 тогда
				ДанныеНачисленияРегистратора.Удалить(ВыборкаПорядок.Услуга)
			КонецЕсли; 
			
		КонецЕсли;
		
	КонецЦикла;
	
	ПараметрыОперации.СуммаАванса				= ПараметрыОперации.СуммаАванса - (ПараметрыОперации.СуммаАвансаЖивымиДеньгами - ОстатокАванса);
	ПараметрыОперации.СуммаАвансаЖивымиДеньгами = ОстатокАванса;
	
КонецПроцедуры

Процедура УменьшитьАвансПропорциональноЗадолженности(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора)
	
	РасшифровкаНачислений   = ДанныеНачисленияРегистратора.Расшифровка;
	ОсталосьСписать			= ПараметрыОперации.СуммаАвансаЖивымиДеньгами;
	ПериодыЗадолженности 	= РасшифровкаНачислений.Скопировать();
	
	// {Авансом закрываем только положительное начисление (в перерасчете могут быть строки как +, так и - суммы)
	Для Каждого ТекСтрока Из ПериодыЗадолженности Цикл
		ТекСтрока.СуммаНачислений = Макс(0, ТекСтрока.СуммаНачислений);	
	КонецЦикла;
	// }
	
	ПериодыЗадолженности.Свернуть("ПериодРасчета","СуммаНачислений");
	ПериодыЗадолженности.Сортировать("ПериодРасчета");	
	
	ТаблицаАвансыИспользованные	= ДанныеДокумента.НаборТаблиц.энргАвансыИспользованные;
	
	Для Сч = 0 По ПериодыЗадолженности.Количество() - 1 Цикл
		ОбщаяСуммаЗаПериод	= ПериодыЗадолженности[Сч].СуммаНачислений;
		
		СтрокиВПериоде 		= РасшифровкаНачислений.НайтиСтроки(Новый Структура("ПериодРасчета", ПериодыЗадолженности[Сч].ПериодРасчета));
		
		Для ИндексСтроки = 0 По СтрокиВПериоде.ВГраница() Цикл				
			
			Если ОбщаяСуммаЗаПериод = 0 Тогда 
				Продолжить;
			КонецЕсли;			
			
			Если СтрокиВПериоде[ИндексСтроки].СуммаНачислений < 0 Тогда 
				Продолжить;
			КонецЕсли;
			
			ДоляВПериоде	 								= СтрокиВПериоде[ИндексСтроки].СуммаНачислений / ОбщаяСуммаЗаПериод;
			СписываемПоДоле 								= ?(ИндексСтроки = СтрокиВПериоде.ВГраница(), ОсталосьСписать, ДоляВПериоде * ПараметрыОперации.СуммаАвансаЖивымиДеньгами);
			Списываем 										= Окр(Мин(СписываемПоДоле, СтрокиВПериоде[ИндексСтроки].СуммаНачислений), 2);
			ОсталосьСписать 								= ОсталосьСписать - Списываем;
			СтрокиВПериоде[ИндексСтроки].СуммаНачислений	= СтрокиВПериоде[ИндексСтроки].СуммаНачислений - Списываем;
			ПараметрыИспользованияАванса  					= Новый Структура("Услуга,Поставщик,ПериодРасчета", СтрокиВПериоде[ИндексСтроки].Услуга, СтрокиВПериоде[ИндексСтроки].Поставщик, СтрокиВПериоде[ИндексСтроки].ПериодНачисления);
			ДобавитьРасходАванса(ПараметрыОперации, ДанныеДокумента, Списываем, ПараметрыИспользованияАванса);
			
			Если ОсталосьСписать = 0 Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ОсталосьСписать = 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыОперации.СуммаАванса				= ПараметрыОперации.СуммаАванса - (ПараметрыОперации.СуммаАвансаЖивымиДеньгами - ОсталосьСписать);
	ПараметрыОперации.СуммаАвансаЖивымиДеньгами = ОсталосьСписать;
	
КонецПроцедуры

Процедура ДобавитьРасходАванса(ПараметрыОперации, ДанныеДокумента, Сумма, ПараметрыИспользованияАванса)
	
	ТаблицаАвансы 				= ДанныеДокумента.НаборТаблиц.энргАвансы;
	ТаблицаАвансыИспользованные = ДанныеДокумента.НаборТаблиц.энргАвансыИспользованные;
	
	Авансы 			= ПараметрыОперации.Авансы;
	ОсталосьСписать = Сумма;
	УдаляемыеСтроки = Новый Массив;
	
	Для Сч = 0 По Авансы.ВГраница() Цикл	
		
		Если Не Авансы[Сч].ЖивыеДеньги Тогда
			Продолжить;
		КонецЕсли;

		//Если  Авансы[Сч].ДокументОплаты = ДанныеДокумента.Регистратор Тогда
		//	// это только для отрицательного Перерасчета, который образует аванс. Этот аванс списывать не надо.
		//	Продолжить;			
		//КонецЕсли;
		Списываем 										= Мин(Авансы[Сч].СуммаАванса,ОсталосьСписать);
		ОсталосьСписать 								= ОсталосьСписать - Списываем;
		Авансы[Сч].СуммаАванса 							= Авансы[Сч].СуммаАванса - Списываем;
		
		Если Авансы[Сч].СуммаАванса = 0 Тогда
			УдаляемыеСтроки.Добавить(Сч);
		КонецЕсли;
		
		ЗаписьАвансы  									= ТаблицаАвансы.добавить();
		ЗаписьАвансы.ВидДвижения 						= ВидДвиженияНакопления.Расход;
		ЗаписьАвансы.Активность  						= истина;
		ЗаписьАвансы.Период  							= ДанныеДокумента.Период;			
		ЗаписьАвансы.МКД	  							= ДанныеДокумента.МКД;
		ЗаписьАвансы.Абонент  							= ДанныеДокумента.Абонент;
		ЗаписьАвансы.Сумма 								= Списываем;
		ЗаписьАвансы.ПериодНачисления 					= ПараметрыОперации.ПериодНачисления;
		ЗаписьАвансы.Организация 						= ПараметрыОперации.Организация;
		ЗаписьАвансы.Район  							= ПараметрыОперации.Район;
		ЗаписьАвансы.ДокументОплаты 					= Авансы[Сч].ДокументОплаты;
		ЗаписьАвансы.Разделитель	 					= Авансы[Сч].Разделитель;
		
		Если НЕ ПараметрыИспользованияАванса = Неопределено Тогда
			ЗаписьАвансыИспользованые					= ТаблицаАвансыИспользованные.добавить();
			ЗаписьАвансыИспользованые.Активность		= Истина;
			ЗаписьАвансыИспользованые.Период  			= ДанныеДокумента.Период;		
			ЗаписьАвансыИспользованые.МКД	 			= ДанныеДокумента.МКД;
			ЗаписьАвансыИспользованые.Абонент			= ДанныеДокумента.Абонент;
			ЗаписьАвансыИспользованые.Услуга			= ПараметрыИспользованияАванса.Услуга;
			ЗаписьАвансыИспользованые.Поставщик			= ПараметрыИспользованияАванса.Поставщик;
			ЗаписьАвансыИспользованые.ПериодРасчета		= ПараметрыОперации.ПериодНачисления;
			ЗаписьАвансыИспользованые.Сумма 			= Списываем;		
			ЗаписьАвансыИспользованые.ПериодНачисления	= ПараметрыИспользованияАванса.ПериодРасчета;
			ЗаписьАвансыИспользованые.Организация		= ПараметрыОперации.Организация;
			ЗаписьАвансыИспользованые.Район  			= ПараметрыОперации.Район;
			ЗаписьАвансыИспользованые.ДокументОплаты	= Авансы[Сч].ДокументОплаты;
			ЗаписьАвансыИспользованые.Разделитель		= Авансы[Сч].Разделитель;
		КонецЕсли;
	
		Если ОсталосьСписать = 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Смещение = 0;
	
	Для Индекс = 0 По УдаляемыеСтроки.ВГраница() Цикл
		Авансы.Удалить(УдаляемыеСтроки[Индекс - Смещение]);
		Смещение = Смещение + 1;
	КонецЦикла;
	
	Если ТипЗнч(ДанныеДокумента.Регистратор) = Тип("ДокументСсылка.энргРучноеИзменениеПени") Тогда
		Для Каждого ТекСтрока Из ТаблицаАвансыИспользованные Цикл
			НовСтрока = ДанныеДокумента.НаборТаблиц.энргНачислениеПени.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти  

#КонецОбласти

#КонецОбласти

#Область СозданиеТаблицЗадолженности

Процедура СоздатьТаблицыРасшифровок()
	
	РасшифровкаНачисленийВспомогательная = Новый ТаблицаЗначений;
	Колонки = РасшифровкаНачисленийВспомогательная.Колонки;
	Колонки.Добавить("ПериодНачисления",				Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	Колонки.Добавить("ПериодРасчета",					Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	Колонки.Добавить("Услуга",							Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	Колонки.Добавить("ПорядокПериодРасчета",			Новый ОписаниеТипов("Число"));
	Колонки.Добавить("ПорядокПогашенияУслуги",			Новый ОписаниеТипов("Число"));
	Колонки.Добавить("ПорядокПросуженнойЗадолженности",	Новый ОписаниеТипов("Число"));
	Колонки.Добавить("СуммаНачислений",					Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));
	Колонки.Добавить("Поставщик",						Новый ОписаниеТипов("СправочникСсылка.энргКонтрагенты"));
	
	РасшифровкаЗадолженностиВспомогательная = Новый ТаблицаЗначений;
	Колонки = РасшифровкаЗадолженностиВспомогательная.Колонки;
	Колонки.Добавить("ПорядокПериодРасчета",			Новый ОписаниеТипов("Число"));
	Колонки.Добавить("ПорядокПогашенияУслуги",			Новый ОписаниеТипов("Число"));
	Колонки.Добавить("ПорядокПросуженнойЗадолженности",	Новый ОписаниеТипов("Число"));
	Колонки.Добавить("Услуга",							Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	Колонки.Добавить("ПериодРасчета",					Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	Колонки.Добавить("ПериодНачисления",				Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	Колонки.Добавить("СуммаЗадолженности",				Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));
	Колонки.Добавить("Поставщик",						Новый ОписаниеТипов("СправочникСсылка.энргКонтрагенты")); 
	
КонецПроцедуры
	
#КонецОбласти

#Область ЗаполнениеТаблицЗадолженности

Функция ЗаполнитьТаблицуЗадолженностьНаГраницу(АбонентОбхода)
	
	перем ТекПериодыЗадолженность,ТекУслуга,ЗадолженностьУслуга;
	
	РасшифровкаЗадолженностиВспомогательная.Очистить();
	ОписаниеЗадолженности 	= ОписаниеЗадолженности();	
	ЗадолженностьВсего  	= 0; 
	ЕстьПоставщик 			= ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ВыборкаЗадолженность, "Поставщик");
	
	Если АбонентОбхода  = ВыборкаЗадолженность.Абонент тогда		
		Пока АбонентОбхода = ВыборкаЗадолженность.Абонент Цикл  			
			Если ЗначениеЗаполнено(ВыборкаЗадолженность.Услуга)
				И (ЕстьПоставщик И ЗначениеЗаполнено(ВыборкаЗадолженность.Поставщик) Или Не ЕстьПоставщик)  
				И ЗначениеЗаполнено(ВыборкаЗадолженность.ПериодРасчета) Тогда 				
				
				СтрокаЗадолженности = РасшифровкаЗадолженностиВспомогательная.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаЗадолженности, ВыборкаЗадолженность);
				СтрокаЗадолженности.СуммаЗадолженности	= ВыборкаЗадолженность.ЗадолженностьНачалоПериода;
				ЗадолженностьВсего 						= ЗадолженностьВсего + ВыборкаЗадолженность.ЗадолженностьНачалоПериода;
				
			КонецЕсли;
			
			Если НЕ ВыборкаЗадолженность.Следующий() тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;				  
	КонецЕсли; 	
	
	ДанныеЗадолженности = Новый Структура(ОписаниеЗадолженности);
	ДанныеЗадолженности.СуммаЗадолженности = ЗадолженностьВсего;
	ДанныеЗадолженности.Расшифровка = РасшифровкаЗадолженностиВспомогательная;
	
	Возврат ДанныеЗадолженности;
	
КонецФункции

Функция ЗаполнитьТаблицуНачисленоВПериоде(АбонентОбхода)
	перем ТекРасшифровкаНачислений;	
		
	РасшифровкаНачисленийВспомогательная.Очистить();
	
	ОписаниеНачислений  	= Новый ФиксированнаяСтруктура("СуммаНачислений,Расшифровка");
	СуммаНачислений 		= 0;
	ТекДокументНачисления 	= Неопределено;
	
	ДанныеНачислений  		= Новый Соответствие;
	
	Если АбонентОбхода  = ВыборкаДанныеНачислений.Абонент тогда		
		Пока АбонентОбхода = ВыборкаДанныеНачислений.Абонент цикл 			
			
			Если НЕ ТекДокументНачисления = ВыборкаДанныеНачислений.ДокРегистратор Тогда
				Если НЕ ТекДокументНачисления = Неопределено Тогда
					
					текОписаниеНачислений = Новый Структура(ОписаниеНачислений);
					текОписаниеНачислений.СуммаНачислений 	= СуммаНачислений;
					текОписаниеНачислений.Расшифровка 		= ТекРасшифровкаНачислений;
					ДанныеНачислений.Вставить(ТекДокументНачисления, текОписаниеНачислений);
					
				КонецЕсли;				
				
				ТекРасшифровкаНачислений 	= РасшифровкаНачисленийВспомогательная.Скопировать();
				СуммаНачислений 			= 0;
				
			КонецЕсли;        			
						
			СтрокаНачисления	  				= ТекРасшифровкаНачислений.Добавить();
			СтрокаНачисления.ПериодНачисления 	= ВыборкаДанныеНачислений.ПериодНачисления;
			СтрокаНачисления.ПериодРасчета 		= ВыборкаДанныеНачислений.ПериодРасчета;
			СтрокаНачисления.Услуга		 		= ВыборкаДанныеНачислений.Услуга;
			СтрокаНачисления.Поставщик 			= ВыборкаДанныеНачислений.Поставщик;
			СтрокаНачисления.СуммаНачислений	= ВыборкаДанныеНачислений.СуммаНачислений;
			СуммаНачислений 					= СуммаНачислений + ВыборкаДанныеНачислений.СуммаНачислений;
			ТекДокументНачисления 				= ВыборкаДанныеНачислений.ДокРегистратор;
			
			Если НЕ ВыборкаДанныеНачислений.Следующий() тогда
				Прервать;
			КонецЕсли; 
			
		КонецЦикла;				  
	КонецЕсли; 	
	
	Если НЕ ТекДокументНачисления = Неопределено Тогда
		
		текОписаниеНачислений = Новый Структура(ОписаниеНачислений);
		текОписаниеНачислений.СуммаНачислений 	= СуммаНачислений;
		текОписаниеНачислений.Расшифровка 		= ТекРасшифровкаНачислений;
		
		ДанныеНачислений.Вставить(ТекДокументНачисления, текОписаниеНачислений);
		
	КонецЕсли;
	
	Возврат ДанныеНачислений; 
	
КонецФункции
	
#КонецОбласти

Функция ОписаниеЗадолженности()
	
	Возврат Новый ФиксированнаяСтруктура("СуммаЗадолженности,Расшифровка");
	
КонецФункции

#КонецОбласти