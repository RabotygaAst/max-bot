#Область ОписаниеПеременных

перем ВидЗадолженности Экспорт; // Вид задолженности оплаты услуги
перем ПериодНачисления Экспорт; // Период начисления услуги
перем Организация Экспорт; // Организация предоставляющая услуги
перем Район Экспорт; // Район, в котором оказывается услуга
перем МКД Экспорт; // Адресс МКД, по которому оказываются услуги
перем СписокМКД Экспорт; // Список адрессов МКД, по которым оказываются услуги
перем Абонент Экспорт; // Клиент, который пользуется услугой
перем ГраницыПериодаНачисления Экспорт; // Дата границы периода начисления
перем СначалаТекущиеНачисления Экспорт; // Параметр определяющий сначала текущие показания


перем РезультатЗапросаЗадолженности Экспорт; // Возвращает результат запроса задолжностей
перем ВыборкаЗадолженность Экспорт; // Выборка результата запроса задолжностей

перем ДанныеЗадолженности Экспорт; // Данные, содержащие полный пакет информации касательно задолженности
перем РасшифровкаЗадолженностиВспомогательная Экспорт; // Таблица значений дополнительных данных задолженности

перем РезультатЗапросаДанныеНачислений Экспорт; // Результат запроса данных начислений
перем ВыборкаДанныеНачислений Экспорт; // Выборка данных начислений

перем ДанныеНачислений Экспорт; // Дата начислений документа
перем РасшифровкаНачисленийВспомогательная Экспорт; // Таблица значений дополнительных данных начислений

#КонецОбласти 

#Область СлужебныйПрограммныйИнтерфейс

Процедура Инициализировать(МВТ) Экспорт 	
	
	ПараметрыЗапроса = СформироватьПараметрыЗапроса();
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("ПараметрыВТ", СформироватьСписокОтборов());	 	
	
	РезультатЗапросаЗадолженности = РезультатЗапросаЗадолженностиНаГраницуСбитойПоследовательности(
		МВТ,
		ПараметрыЗапроса,
		ПараметрыОтбора);
		
	РезультатЗапросаДанныеНачислений = РезультатЗапросаДанныеДокументовСбитыхВПоследовательности(
		МВТ,
		ПараметрыЗапроса);	
		
	СоздатьТаблицыРасшифровок();
	
КонецПроцедуры

Процедура ИнициализироватьВыборки() Экспорт 
	
	ВыборкаЗадолженность = РезультатЗапросаЗадолженности.Выбрать();
	ВыборкаЗадолженность.Следующий();
	
	ВыборкаДанныеНачислений = РезультатЗапросаДанныеНачислений.Выбрать();
	ВыборкаДанныеНачислений.Следующий();
	
КонецПроцедуры

Процедура СформироватьТаблицыДанныхЗадолженности(АбонентОбхода) Экспорт 
	ЗаполнитьТаблицуЗадолженностьНаГраницу(АбонентОбхода);
	ЗаполнитьТаблицуНачисленоВПериоде(АбонентОбхода);
КонецПроцедуры


#Область РеализацияИнтерфейса_РаспределениеДенежныхСредств

Процедура УвеличитьЗадолженностьАбонента(ПараметрыОперации, ДанныеДокумента) Экспорт 
		
	ДанныеНачисленияРегистратора = ДанныеНачислений[ДанныеДокумента.Регистратор];
	Если ДанныеНачисленияРегистратора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УвеличитьЗадолженность(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора);
	
КонецПроцедуры

Процедура РаспределитьОплатуАбонентаПоНазначению(ПараметрыОперации, Оплата, ДанныеДокумента) Экспорт 
	
	ОплатаДолга = Оплата[ВидЗадолженности];
	Если ОплатаДолга = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеОплаты = ОплатаДолга[ДанныеДокумента.Регистратор];
	Если ДанныеОплаты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РаспределитьОплатуАбонентаПоНазначениюПлатежа(ПараметрыОперации, ДанныеОплаты, ДанныеДокумента);
	
КонецПроцедуры

Процедура РаспределитьОплатуАбонента(ПараметрыОперации, Оплата, ДанныеДокумента) Экспорт 
	
	//ОплатаДолга = Оплата[ВидЗадолженности];
	//Если ОплатаДолга = Неопределено Тогда
	//	Возврат;
	//КонецЕсли;
	//
	//ДанныеОплаты = ОплатаДолга[ДанныеДокумента.Регистратор];
	//Если ДанныеОплаты = Неопределено Тогда
	//	Возврат;
	//КонецЕсли;
	
	Если ПараметрыОперации.ОсвободившиесяДеньги.Сумма <= 0 Тогда
		Возврат;		
	КонецЕсли;
	ДанныеОплаты = Неопределено;
	
	РаспределитьОстатокОплатыАбонента(ПараметрыОперации, ДанныеОплаты, ДанныеДокумента);
	
КонецПроцедуры

Процедура РаспределитьПерерасчетСОплатой(ПараметрыОперации, Оплата, ДанныеДокумента) Экспорт
	
	Если ДанныеДокумента.ЭтоКорректировкаОплаты Тогда
		ДанныеНачисленияРегистратора = ДанныеНачислений[ДанныеДокумента.Регистратор];
		
		СторнироватьОплату(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора);
		Если НЕ ДанныеНачисленияРегистратора = Неопределено Тогда
			УвеличитьЗадолженность(ПараметрыОперации, ДанныеДокумента, ДанныеНачисленияРегистратора);			
		КонецЕсли;
	КонецЕсли;
	
	РаспределитьОплатуАбонентаПоНазначению(ПараметрыОперации, Оплата, ДанныеДокумента);	
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РеализацияИнтерфейса_ПолучениеДанных

#Область ЗадолженностиНаГраницуСбитойПоследовательности

Функция РезультатЗапросаЗадолженностиНаГраницуСбитойПоследовательности(МВТ, ПараметрыЗапроса, ПараметрыОтбора)
	
	СхемаЗапроса = Новый СхемаЗапроса;
	
	ОстаткиНаГраницу(СхемаЗапроса, ПараметрыОтбора);
	ОборотыЗаПериод(СхемаЗапроса, ПараметрыОтбора);
	СформироватьИтоговуюВыборку(СхемаЗапроса);
	
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьЗапрос(СхемаЗапроса, ПараметрыЗапроса, МВТ);
	Возврат РезультатЗапроса;	
	
КонецФункции

Процедура ОстаткиНаГраницу(СхемаЗапроса, ПараметрыОтбора)
	
	ПараметрыОтбора.Вставить("Период", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("НачалоПериодаРасчета"));
	РегистрыНакопления.энргВзаиморасчетыПоПени.ЗаполнитьСхемуЗадолженностьНаМоментВремени(СхемаЗапроса, ПараметрыОтбора, "ОстатокНачалоПериодаПени");
	
	ПараметрыОтбора.Вставить("Период", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("КонецПериодаРасчета"));
	РегистрыСведений.энргПросуженнаяПени.ПросуженнаяПениЗаПериод(СхемаЗапроса, ПараметрыОтбора, "ПросуженнаяПениНачалоПериода");
	
КонецПроцедуры 

Процедура ОборотыЗаПериод(СхемаЗапроса, ПараметрыОтбора)
	
	ПараметрыОтбора.Вставить("НачалоПериода", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("НачалоПериодаРасчета"));
	ПараметрыОтбора.Вставить("КонецПериода", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("КонецПериодаРасчета"));
	РегистрыНакопления.энргВзаиморасчетыПоПени.ЗаполнитьСхемуОборотыВзаиморасчетов(СхемаЗапроса, ПараметрыОтбора, "ВзаиморасчетыПениОбороты");	
	
КонецПроцедуры

Процедура СформироватьИтоговуюВыборку(СхемаЗапроса)
	
	Пакет = СхемаЗапроса.ПакетЗапросов.Добавить(); 	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.ПериодРасчета КАК ПериодРасчета,
	|	СУММА(ВложенныйЗапрос.ЗадолженностьНачалоПериода) КАК ЗадолженностьНачалоПериода,
	|	ВЫБОР
	|		КОГДА &СначалаТекущиеНачисления
	|				И ВложенныйЗапрос.ПериодРасчета = &ПериодНачисления
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК ПорядокПериодРасчета,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СпособРаспределенияОплаты.СпособРаспределения, ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОплаты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОплаты.ПоУслугамСогласноНастройкамРаспределения)
	|			ТОГДА ЕСТЬNULL(ПорядокПогашенияУслуг.Порядок, 99999)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ПорядокПогашенияУслуги,
	|	ВЫБОР
	|		КОГДА ПросуженнаяПениНачалоПериода.Район ЕСТЬ NULL
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ПорядокПросуженнойЗадолженности
	|ИЗ
	|	(ВЫБРАТЬ
	|		ОстатокНачалоПериодаПени.ПериодНачисления КАК ПериодНачисления,
	|		РазличныеАбоненты.Район КАК Район,
	|		РазличныеАбоненты.МКД КАК МКД,
	|		РазличныеАбоненты.Абонент КАК Абонент,
	|		ЕСТЬNULL(ОстатокНачалоПериодаПени.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга,
	|		ЕСТЬNULL(ОстатокНачалоПериодаПени.ПериодРасчета, ДАТАВРЕМЯ(1, 1, 1)) КАК ПериодРасчета,
	|		ЕСТЬNULL(ОстатокНачалоПериодаПени.СуммаОстаток, 0) КАК ЗадолженностьНачалоПериода
	|	ИЗ
	|		РазличныеАбоненты КАК РазличныеАбоненты
	|			ЛЕВОЕ СОЕДИНЕНИЕ ОстатокНачалоПериодаПени КАК ОстатокНачалоПериодаПени
	|			ПО РазличныеАбоненты.Район = ОстатокНачалоПериодаПени.Район
	|				И РазличныеАбоненты.МКД = ОстатокНачалоПериодаПени.МКД
	|				И РазличныеАбоненты.Абонент = ОстатокНачалоПериодаПени.Абонент
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВзаиморасчетыПениОбороты.ПериодНачисления,
	|		МинимумРегистратор.Район,
	|		МинимумРегистратор.МКД,
	|		МинимумРегистратор.Абонент,
	|		ЕСТЬNULL(ВзаиморасчетыПениОбороты.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)),
	|		ЕСТЬNULL(ВзаиморасчетыПениОбороты.ПериодРасчета, ДАТАВРЕМЯ(1, 1, 1)),
	|		СУММА(ЕСТЬNULL(ВзаиморасчетыПениОбороты.СуммаОборот, 0))
	|	ИЗ
	|		МинимумРегистратор КАК МинимумРегистратор
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВзаиморасчетыПениОбороты КАК ВзаиморасчетыПениОбороты
	|			ПО (ВЫБОР
	|					КОГДА МинимумРегистратор.ДатаРегистратора > ВзаиморасчетыПениОбороты.Период
	|						ТОГДА ИСТИНА
	//|					КОГДА МинимумРегистратор.ДатаРегистратора = ВзаиморасчетыПениОбороты.Период
	//|						ТОГДА ВЫБОР
	//|								КОГДА МинимумРегистратор.ДопПорядок = 10
	//|									ТОГДА ИСТИНА
	//|								ИНАЧЕ МинимумРегистратор.ДокРегистратор > ВзаиморасчетыПениОбороты.Регистратор
	//|							КОНЕЦ
	|					ИНАЧЕ ЛОЖЬ
	|				КОНЕЦ)
	|				И МинимумРегистратор.Район = ВзаиморасчетыПениОбороты.Район
	|				И МинимумРегистратор.МКД = ВзаиморасчетыПениОбороты.МКД
	|				И МинимумРегистратор.Абонент = ВзаиморасчетыПениОбороты.Абонент
	|	
	|	СГРУППИРОВАТЬ ПО
	|		МинимумРегистратор.Район,
	|		МинимумРегистратор.МКД,
	|		МинимумРегистратор.Абонент,
	|		ВзаиморасчетыПениОбороты.Услуга,
	|		ВзаиморасчетыПениОбороты.ПериодНачисления,
	|		ЕСТЬNULL(ВзаиморасчетыПениОбороты.ПериодРасчета, ДАТАВРЕМЯ(1, 1, 1))) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПорядокПогашенияУслуг КАК ПорядокПогашенияУслуг
	|		ПО ВложенныйЗапрос.Услуга = ПорядокПогашенияУслуг.Услуга
	|		ЛЕВОЕ СОЕДИНЕНИЕ СпособРаспределенияОплаты КАК СпособРаспределенияОплаты
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПросуженнаяПениНачалоПериода КАК ПросуженнаяПениНачалоПериода
	|		ПО ВложенныйЗапрос.Район = ПросуженнаяПениНачалоПериода.Район
	|			И ВложенныйЗапрос.МКД = ПросуженнаяПениНачалоПериода.МКД
	|			И ВложенныйЗапрос.Абонент = ПросуженнаяПениНачалоПериода.Абонент
	|			И ВложенныйЗапрос.Услуга = ПросуженнаяПениНачалоПериода.Услуга
	|			И ВложенныйЗапрос.ПериодРасчета = ПросуженнаяПениНачалоПериода.ПериодРасчета
	|			И ВложенныйЗапрос.ПериодНачисления = ПросуженнаяПениНачалоПериода.ПериодНачисления
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.ПериодНачисления,
	|	ВложенныйЗапрос.Район,
	|	ВложенныйЗапрос.МКД,
	|	ВложенныйЗапрос.Абонент,
	|	ВложенныйЗапрос.Услуга,
	|	ВложенныйЗапрос.ПериодРасчета,
	|	ВЫБОР
	|		КОГДА &СначалаТекущиеНачисления
	|				И ВложенныйЗапрос.ПериодРасчета = &ПериодНачисления
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СпособРаспределенияОплаты.СпособРаспределения, ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОплаты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Перечисление.энргСпособыРаспределенияОплаты.ПоУслугамСогласноНастройкамРаспределения)
	|			ТОГДА ЕСТЬNULL(ПорядокПогашенияУслуг.Порядок, 99999)
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ПросуженнаяПениНачалоПериода.Район ЕСТЬ NULL
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Район,
	|	МКД,
	|	Абонент,
	|	ПорядокПросуженнойЗадолженности,
	|	ПорядокПериодРасчета,
	|	ПериодНачисления,
	|	ПериодРасчета,
	|	ПорядокПогашенияУслуги,
	|	Услуга");
	
КонецПроцедуры

#КонецОбласти

#Область ДанныеДокументовСбитыхВПоследовательности

Функция РезультатЗапросаДанныеДокументовСбитыхВПоследовательности(МВТ, ПараметрыЗапроса)
	
	Запрос = Новый Запрос;	
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = ТекстДанныеНачислений();		
	
	СписокПараметров = Запрос.НайтиПараметры();
	Для Каждого ПараметрЗапроса Из СписокПараметров Цикл
		ЗначениеПараметра = ПараметрыЗапроса[ПараметрЗапроса.Имя];
		Запрос.УстановитьПараметр(ПараметрЗапроса.Имя, ЗначениеПараметра);
	КонецЦикла;
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция ТекстДанныеНачислений()
	
	Текст =
	"ВЫБРАТЬ
	|	энргНачислениеПени.ПериодНачисления КАК ПериодНачисления,
	|	ДокументыДляПроведения.Район КАК Район,
	|	ДокументыДляПроведения.МКД КАК МКД,
	|	ДокументыДляПроведения.Абонент КАК Абонент,
	|	ДокументыДляПроведения.ДокРегистратор КАК ДокРегистратор,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СпособРаспределенияОплаты.ПерерасчетыВключатьВРасчетныйПериод, ЛОЖЬ)
