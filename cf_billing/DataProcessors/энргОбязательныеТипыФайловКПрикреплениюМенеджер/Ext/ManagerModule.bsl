#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Получает обязательные типы файлов.
//
// Параметры:
//  ВладелецФайла	-	см. ОбщегоНазначения.ИдентификаторОбъектаМетаданных.
//  ВидОперации		-	ПеречислениеСсылка.бестВидыОпераций.
// 
// Возвращаемое значение:
//   РезультатЗапроса
//
Функция РезультатПолученияОбязательныхТиповФайлов(ВладелецФайла, ВидОперации = Неопределено) Экспорт
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		Если слжОбщегоНазначенияМодуль.ВоспроизводитьРезультатМетодов() Тогда; 
			Если НЕ Метаданные.Обработки.Найти("слжОбязательныеТипыФайловКПрикреплениюМенеджер") = Неопределено Тогда
				Возврат Обработки["слжОбязательныеТипыФайловКПрикреплениюМенеджер"].РезультатПолученияОбязательныхТиповФайлов(ВладелецФайла, ВидОперации);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Результат 						= энргРаботаСПрикрепленнымиФайламиСервер.РезультатПолученияОбязательныхТиповФайлов(ВладелецФайла, ВидОперации);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргОбязательныеТипыФайловКПрикреплению.РезультатПолученияОбязательныхТиповФайлов";
		ПараметрыМетода 			= Новый Структура("ВладелецФайла, ВидОперации", ВладелецФайла, ВидОперации);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, Результат, ПараметрыМетода);
	КонецЕсли;
	
	Возврат Результат; 	
	
КонецФункции

#КонецОбласти

#КонецЕсли