&НаКлиенте
Процедура УстановитьНомерСтрокУслуг(Строки, НомерСтроки=1)

	Для Каждого Строка Из Строки Цикл 		
		Строка.НомерСтроки 				= НомерСтроки;
		Строка.РаспределятьНаАбонентов	=  ПризнакРаспределенияНаАбонентов;
		
		НомерСтроки 					= НомерСтроки + 1;
		УстановитьНомерСтрокУслуг(Строка.ПолучитьЭлементы(), НомерСтроки);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьНовуюСтрокуДанными(ТекущиеДанные) 
	ТекущиеДанные.IDСтроки 					=  Новый УникальныйИдентификатор;
	ТекущиеДанные.РаспределятьНаАбонентов	=  ПризнакРаспределенияНаАбонентов;
	ТекущиеДанные.ТехническиеСвойстваТУ 	=  "Не заполнены";
	ТекущиеДанные.СредстваИзмерения			=  "Не заполнены";
КонецПроцедуры 


&НаСервере
Процедура ОчиститьНеИспользуемыеПриборыУчета()
	ПустоеОписаниеПУ = ПустоеОписаниеХарактеристикПрибораУчета();	
	Для Каждого ТекСтрока Из Объект.ТочкиУчета Цикл
		НетПриборов = Объект.Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекСтрока.IDСтроки)).Количество() = 0;
		Если НетПриборов Тогда 
			ЗаполнитьЗначенияСвойств(ТекСтрока, ПустоеОписаниеПУ);
		КонецЕсли;  	
	КонецЦикла; 		
КонецПроцедуры

&НаСервере
Функция ПустоеОписаниеХарактеристикПрибораУчета()
	Описание = Новый Структура;
	Описание.Вставить("ВидКанальности"				, Справочники.энргВидыКанальности.ПустаяСсылка());	
	Описание.Вставить("ОписаниеПрибора"				, "");	
	Описание.Вставить("ПриборУчета"					, Справочники.энргПриборыУчетаАбонента.ПустаяСсылка());	
	Описание.Вставить("ТипУзлаУчета"				, Справочники.энргТипыУзловУчета.ПустаяСсылка());	
	Описание.Вставить("ЗаводскойНомер"				, "");	
	Описание.Вставить("ДатаПоверкиСчетчика"			, Дата(1,1,1));	
	Описание.Вставить("ДатаУстановкиПломбы"			, Дата(1,1,1));	
	Описание.Вставить("НомерПломбы"					, "");	
	Описание.Вставить("ТипПрибораУчета"				, Справочники.энргТипыПриборовУчета.ПустаяСсылка());	
	Описание.Вставить("СистемаУчетаЭлектроэнергии"	, Справочники.энргСистемыУчетаЭлектроэнергии.ПустаяСсылка());	
	Описание.Вставить("СобственникСИ"				, Перечисления.энргБалансоваяПринадлежность.ПустаяСсылка());
	Описание.Вставить("БалансоваяПринадлежность"	, Перечисления.энргБалансоваяПринадлежность.ПустаяСсылка());

	Возврат Описание;
КонецФункции

#КонецОбласти