		ЗаполнитьВходнымиДанными();
	КонецЕсли;
	
	ИспользоватьТарифныеЗоны 		= ПолучитьФункциональнуюОпцию("энргИспользоватьТарифныеЗоны");
	ИспользоватьШкалыПриборовУчета 	= ПолучитьФункциональнуюОпцию("энргИспользоватьШкалыПриборовУчета");
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма,,,,"УслугиДерево");	
	
	РаботаСУстановкойСвойствЭлементовФормы();
КонецПроцедуры

