&НаСервере
Функция СоотвествиеРеквизитовСвойствамПрибораУчета()
	Возврат энргРаботаСприборамиУчетаСервер.СоотвествиеРеквизитовСвойствамПрибораУчета();
КонецФункции

&НаСервере
Функция ПолучаемыеСвойстваПриборовУчета()
	Возврат энргРаботаСприборамиУчетаСервер.ПолучаемыеСвойстваПриборовУчета();	
КонецФункции

&НаСервере
Процедура ЗаписатьПараметрыТочекИПриборовУчета()
	
	Сч 														= 0;
	Для Каждого СтрокаТочки Из Измерители Цикл
		ЗаписываемаяСтрока  								= Измерители[Сч];
		ЗаписываемаяСтрока.КоэффициентПУ 					= ?(ЗаписываемаяСтрока.ВспомогательноеОборудование, 1, КоэффициентПУ);
		ЗаписываемаяСтрока.ТипУзлаУчета 					= ?(ЗаписываемаяСтрока.ВспомогательноеОборудование, Справочники.энргТипыУзловУчета.ПустаяСсылка(), ТипУзлаУчета);
		ЗаписываемаяСтрока.ВидКанальности 					= ВидКанальности;
		
		СвойстваПрибора 									= ПолучаемыеСвойстваПриборовУчета();
		ДанныеПрибораУчета 									= Новый Структура(СвойстваПрибора);
		СоотвествиеРеквизитов 								= СоотвествиеРеквизитовСвойствамПрибораУчета();
		Для Каждого КлючЗначение Из СоотвествиеРеквизитов Цикл	
			Если КлючЗначение.Значение = "ВидКанальности" Тогда
				ДанныеПрибораУчета.ВидКанальности = ВидКанальности;
			Иначе
				ДанныеПрибораУчета[КлючЗначение.Значение] 		= СтрокаТочки[КлючЗначение.Ключ];
			КонецЕсли;
		КонецЦикла;
		ЗаписываемаяСтрока.ОписаниеПрибора 					= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектаВСтрокуJSON(ДанныеПрибораУчета);		
		Сч 													= Сч + 1;		
	КонецЦикла;
	
КонецПроцедуры


&НаСервере
Процедура ЗаполнитьВходнымиДанными()
	ВходныеПараметры = Параметры.ВходныеПараметры;
	
	Если ВходныеПараметры.Свойство("Замена") Тогда
		Замена = ВходныеПараметры.Замена;
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ЗаменаВспомогательныхПУ") Тогда
		ЗаменаВспомогательныхПУ = ВходныеПараметры.ЗаменаВспомогательныхПУ;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтаФорма, ВходныеПараметры, "ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета, Услуга, НаименованиеТочки, ВидКанальности, ТипУзлаУчета, ВидОперации, КоэффициентПУ, ВызывающаяПодсистема");
	
	Если Замена Тогда
		ВходныеПараметры.Измерители 			= Обработки.энргОперацияУзламиУчета.ОбработатьВходнуюТаблицу(ВходныеПараметры.Измерители,"Вывод",Ложь);
		ВходныеПараметры.ШкалыПриборовУчета 	= Обработки.энргОперацияУзламиУчета.ОбработатьВходнуюТаблицу(ВходныеПараметры.ШкалыПриборовУчета,"Вывод",Ложь);
		ВходныеПараметры.ПоказанияПриборовУчета = Обработки.энргОперацияУзламиУчета.ОбработатьВходнуюТаблицу(ВходныеПараметры.ПоказанияПриборовУчета,"Вывод",Ложь);
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.Измерители				, Измерители);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.ШкалыПриборовУчета		, Шкалы);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.ПоказанияПриборовУчета	, ПоказанияПриборовУчета);	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.ШкалыИзмерителей			, ШкалыИзмерителей);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.НомераПломб				, НомераПломб);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.ФормулыРасчетаУслуг		, ФормулыРасчетаУслуг);
	
	ЗаполнитьВидКанальности();
	Если Замена Тогда
		ЗаполнитьИзмерителиЗамена();
	Иначе
		Если ВходныеПараметры.Измерители.Количество() = 0 Тогда
			ЗаполнитьИзмерители(); 
		КонецЕсли;
	КонецЕсли;
	
	Если ВходныеПараметры.ШкалыПриборовУчета.Количество() = 0 Тогда
		ЗаполнитьШкалы(); 
	КонецЕсли; 	
	
	
	мСписокУслуг 					= энргРаботаСПоставщикамиСервер.ПолучитьСоставУслуги(Услуга);
	ТаблицаФормулыРасчетаУслуг 		= Элементы.ФормулыРасчетаУслуг;
	ПолеУслуга  					= ТаблицаФормулыРасчетаУслуг.ПодчиненныеЭлементы.Найти("ФормулыРасчетаУслуга");
	ПолеУслуга.СписокВыбора.ЗагрузитьЗначения(мСписокУслуг);
КонецПроцедуры

&НаСервере
Процедура РаботаСУстановкойСвойствЭлементовФормы()
	
	Если ВызывающаяПодсистема = "ЮЛ" Тогда
		ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ 	= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("бестИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ");
		Элементы.СтраницаФормулыРасчетаУслуг.Видимость 	= Истина;
		Элементы.ИзмерителиФаза.Видимость 				= ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ;
		Элементы.ИзмерителиДоступКПУ.Видимость 			= ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ;
		Элементы.ИзмерителиГруппа2.Видимость 			= ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ;
		Элементы.ИзмерителиГруппа1.Видимость 			= ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ;
		Элементы.КоэффициентПУ.Видимость 				= ИспользоватьДанныеДляРасчетаЭлектроэнерииЮЛ;		
	КонецЕсли;
	
	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьШкалы()
	
	Шкалы.Очистить();
	
	Если НЕ ЗначениеЗаполнено(ТипУзлаУчета) Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗапроса 	= Справочники.энргВидыКанальности.ПолучитьШкалыВидаКанальности(ВидКанальности);
	Выборка 			= РезультатЗапроса.Выбрать();
	//Если ВызывающаяПодсистема = "ЮЛ" Тогда
	//	ИспользоватьТарифныеЗоны = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("бестИспользоватьТарифныеЗоны");
	//Иначе
	//	ИспользоватьТарифныеЗоны = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	//КонецЕсли;
	Пока Выборка.Следующий() Цикл
		НоваяСтрока 			= Шкалы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		IDСтрокиШкалы 			= Новый УникальныйИдентификатор;;
		НоваяСтрока.IDСтроки 	= IDСтрокиШкалы;
		Если НЕ ИспользоватьТарифныеЗоны Тогда
			НоваяСтрокаПоказаний 				= ПоказанияПриборовУчета.Добавить();
			НоваяСтрокаПоказаний.ТарифнаяЗона 	= Справочники.энргТарифныеЗоны.БезРазбивки;
			НоваяСтрокаПоказаний.IDСтроки 		= IDСтрокиШкалы;
			НоваяСтрока.ВидДифференцированности = Справочники.энргВидыДифференцированности.Однотарифный;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТарифныеЗоны(Состав, IDСтроки)
	
	ТЗПоказанияПУ = ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки", IDСтроки));
	
	Для Каждого Стр из ТЗПоказанияПУ Цикл
		
		ПоказанияПриборовУчета.Удалить(Стр);
	КонецЦикла;
	
	//ПоказанияПриборовУчета.Очистить();
	
	Для Каждого ТекТарифнаяЗона из Состав Цикл 
		НоваяСтрока = ПоказанияПриборовУчета.Добавить();
		НоваяСтрока.IDСтроки 		= IDСтроки;
		НоваяСтрока.ТарифнаяЗона 	= ТекТарифнаяЗона;
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьВсеТаблицы()
	Измерители.Очистить();
	ШкалыИзмерителей.Очистить();
	НомераПломб.Очистить();
	ПоказанияПриборовУчета.Очистить();
	ФормулыРасчетаУслуг.Очистить();
	Шкалы.Очистить();
КонецПроцедуры

&НаСервере
Функция  ПолучитьКлючиЗаполнения()
	Возврат Обработки.энргОперацияУзламиУчета.ПолучитьКлючиЗаполненияСредствИзмерений();
КонецФункции

&НаКлиенте
Процедура ЗаполнитьКоэфициент(ТекущиеДанные)
	
	Если КоэффициентПУ = 0 тогда
		Если НЕ ТекущиеДанные.ВспомогательноеОборудование И (ЗначениеЗаполнено(ТекущиеДанные.ЗаводскойНомер) или ЗначениеЗаполнено(ТекущиеДанные.ДатаПоверкиСчетчика) или ЗначениеЗаполнено(ТекущиеДанные.ТипПрибораУчета)) Тогда
			КоэффициентПУ = 1;
		КонецЕсли; 	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВидКанальности()
	
	ВидКанальности = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТипУзлаУчета, "ВидКанальности");
	
	Если НЕ ЗначениеЗаполнено(ВидКанальности) Тогда
		ВидКанальности = Справочники.энргВидыКанальности.Одноканальный;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьМежповерочныйИнтервалПоТипуПУ(ТипПрибораУчета)
	Возврат энргРаботаСприборамиУчетаСервер.ПолучитьМежповерочныйИнтервалПоТипуПУ(ТипПрибораУчета);
КонецФункции

&НаСервере
Процедура НастроитьВидимостьЭлементов()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ПоказанияПриборовУчетаВидДифференцированности",
		"Видимость",
		ИспользоватьТарифныеЗоны);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ПоказанияПриборовУчета1ТарифнаяЗона",
		"Видимость",
		ИспользоватьТарифныеЗоны);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ПоказанияПриборовУчетаШкала",
		"Видимость",
		ИспользоватьШкалыПриборовУчета);  
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"Страницы",
		"Видимость",
		Не ЗаменаВспомогательныхПУ);  
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ТипУзлаУчета",
		"Доступность",
		Не ЗаменаВспомогательныхПУ);
				
	Если ВызывающаяПодсистема = "ЮЛ" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ТипУзлаУчета",
			"ТолькоПросмотр",
			Замена);			
	КонецЕсли;
			
