&НаКлиенте
Процедура ПоказанияПриборовУчетаШкалаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Шкалы.ТекущиеДанные;
	Если НЕ ИспользоватьТарифныеЗоны Тогда 
		ТекущиеДанные.ВидДифференцированности = ПредопределенноеЗначение("Справочник.энргВидыДифференцированности.Однотарифный");
	КонецЕсли;
	 
	ВидДифференцированности = ТекущиеДанные.ВидДифференцированности;
	Состав 					= энргРаботаСТочкамиУчетаСервер.СоставВидаДифференцированности(ВидДифференцированности);
	
	ЗаполнитьТарифныеЗоны(Состав, ТекущиеДанные.IDСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказанияПриборовУчетаВидДифференцированностиПриИзменении(Элемент)	
	
	ТекущиеДанные 			= Элементы.Шкалы.ТекущиеДанные;
	Если НЕ ИспользоватьШкалыПриборовУчета Тогда 
		ТекущиеДанные.Шкала = ПредопределенноеЗначение("Справочник.энргШкалыПриборовУчета.Основная");
	КонецЕсли;
	ВидДифференцированности = ТекущиеДанные.ВидДифференцированности;
	Состав 					= энргРаботаСТочкамиУчетаСервер.СоставВидаДифференцированности(ВидДифференцированности);
	
	ЗаполнитьТарифныеЗоны(Состав, ТекущиеДанные.IDСтроки);
	
	ПоказанияПриборовУчетаВидДифференцированностиПриИзмененииПереопределяемый(Элемент);
	
КонецПроцедуры

#КонецОбласти 

#КонецОбласти

#Область РаботаСТаблицейФормулыРасчетаУслуг

&НаКлиенте
Процедура ФормулыРасчетаФормулаРасчетаПредставлениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ПриборыУчета 				= Новый Массив;
	
	Для Каждого Строка Из Измерители Цикл		
		Если Строка.ВспомогательноеОборудование Тогда
			Продолжить;
		КонецЕсли;
		мШкалы					= Новый Массив;
		
		Для Каждого СтрокаШкалы Из Шкалы Цикл
			мШкалы.Добавить(Новый Структура("Шкала,ВидПараметра",СтрокаШкалы.Шкала,СтрокаШкалы.ВидПараметра));
		КонецЦикла;
		ОписаниеПрибораУчета  	= Новый Структура;
		ОписаниеПрибораУчета.Вставить("ПриборУчета", 		Строка.ПриборУчета);
		ОписаниеПрибораУчета.Вставить("ЗаводскойНомер",		Строка.ЗаводскойНомер);
		ОписаниеПрибораУчета.Вставить("Шкалы", 				мШкалы);
		ПриборыУчета.Добавить(ОписаниеПрибораУчета);		
	КонецЦикла;   	
	Оповещение 					= Новый ОписаниеОповещения("НастройкаФормулыРасчетаЗавершение",ЭтаФорма,Новый Структура("КлючСтроки", Элементы.ФормулыРасчетаУслуг.ТекущаяСтрока));
	ТекущиеДанные 				= Элементы.ФормулыРасчетаУслуг.ТекущиеДанные; 
	мСписокУслуг 				= энргРаботаСПоставщикамиСервер.ПолучитьСоставУслуги(Услуга);
	ПараметрыФормы  			= Новый Структура;
	ПараметрыФормы.Вставить("ПредставлениеФормулы", 	ТекущиеДанные.ФормулаРасчетаПредставление);
	ПараметрыФормы.Вставить("Услуга", 					?(ТекущиеДанные = Неопределено,ПредопределенноеЗначение("Справочник.энргВидыУслуг.ПустаяСсылка"),ТекущиеДанные.Услуга));
	ПараметрыФормы.Вставить("УзелУчета", 				Истина);
	ПараметрыФормы.Вставить("СоставУслуги", 			мСписокУслуг);
	ПараметрыФормы.Вставить("ПриборыУчета", 			ПриборыУчета);
	ОткрытьФорму("ОбщаяФорма.энргНастройкаФормулРасчета", ПараметрыФормы,,,,,Оповещение);
	
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаФормулыРасчетаЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт 
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТипЗнч(РезультатЗакрытия) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не РезультатЗакрытия.Свойство("ПредставлениеФормулы") ИЛИ Не РезультатЗакрытия.Свойство("ФормулаРасчета") Тогда
		Возврат;
	КонецЕсли;
	
	КлючСтроки  											= ДополнительныеПараметры.КлючСтроки;
	
	ТекущиеДанные  										= ФормулыРасчетаУслуг.НайтиПоИдентификатору(КлючСтроки);
	ТекущиеДанные.ФормулаРасчетаПредставление 			= РезультатЗакрытия.ПредставлениеФормулы;
	ТекущиеДанные.ФормулаРасчета 						= РезультатЗакрытия.ФормулаРасчета;
	  
	
КонецПроцедуры

