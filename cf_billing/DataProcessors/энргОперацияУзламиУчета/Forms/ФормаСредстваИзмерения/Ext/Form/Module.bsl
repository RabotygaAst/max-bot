#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗаполнитьВходнымиДанными();	
	РаботаСУстановкойСвойствЭлементовФормы();
	НастроитьВидимостьЭлементов();
КонецПроцедуры

#Конецобласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Завершить(Команда)
	
	Ошибки = Новый Массив;
	ПроверитьПередЗакрытием(Ошибки);
	Если НЕ Ошибки.Количество() = 0 Тогда
		//ПоказатьПредупреждение(, СтрСоединить(Ошибки, Символы.ПС));
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрСоединить(Ошибки, Символы.ПС));
		Возврат;
	КонецЕсли;
	
	Закрыть(ПолучитьРезультат());
	
КонецПроцедуры

&НаСервере
Функция ПолучитьРезультат() 
	
	КлючиДанных 		= ПолучитьКлючиЗаполнения();
	ДанныеЗакрытия		= Новый Структура(КлючиДанных.Реквизиты + ", " + КлючиДанных.Таблицы);
	
	ЗаполнитьЗначенияСвойств(ДанныеЗакрытия, ЭтаФорма, КлючиДанных.Реквизиты);	
	ЗаписатьПараметрыТочекИПриборовУчета();
	
	ДанныеЗакрытия.Измерители 				= ОбщегоНазначения.ТаблицаЗначенийВМассив(Измерители.Выгрузить());
	ДанныеЗакрытия.ПоказанияПриборовУчета 	= ОбщегоНазначения.ТаблицаЗначенийВМассив(ПоказанияПриборовУчета.Выгрузить());
	ДанныеЗакрытия.ШкалыПриборовУчета 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(Шкалы.Выгрузить());
	ДанныеЗакрытия.ШкалыИзмерителей 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(ШкалыИзмерителей.Выгрузить());
	ДанныеЗакрытия.НомераПломб 				= ОбщегоНазначения.ТаблицаЗначенийВМассив(НомераПломб.Выгрузить()); 
	ДанныеЗакрытия.ФормулыРасчетаУслуг 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(ФормулыРасчетаУслуг.Выгрузить()); 
	
	Возврат ДанныеЗакрытия;
КонецФункции

&НаСервере
Процедура ПроверитьПередЗакрытием(Ошибки)
	
	Ошибки = Новый Массив;
	КолвоНЕВспомОборудования = Измерители.НайтиСтроки(Новый Структура("ВспомогательноеОборудование", Ложь)).Количество();
	Если ЗаменаВспомогательныхПУ Тогда 
		Возврат; 
	ИначеЕсли Измерители.Количество() > 0 И КолвоНЕВспомОборудования = 0 Тогда
		Ошибки.Добавить("Не указан прибор учета");
	ИначеЕсли КолвоНЕВспомОборудования > 1 Тогда
		Ошибки.Добавить("Приборов учетов указано больше, чем один");
	КонецЕсли;
	
	ВалидироватьТаблицы(Ошибки);
	
КонецПроцедуры // ПроверитьПередЗакрытием(Ошибки)()

&НаСервере
Процедура ВалидироватьТаблицы(Ошибки)
	
	ЕстьОшибки = Ложь;
	Шаблон = "Измерители[%1].%2";
	ОтборПломб = Новый Структура("IDСтрокиИзмерителя", Неопределено);
	ОтборШкал = Новый Структура("IDСтроки", Неопределено);
	Индекс = 0;
	Для Каждого СтрокаНабора из Измерители Цикл 
		
		Если НЕ ЗначениеЗаполнено(СтрокаНабора.ЗаводскойНомер) Тогда
			ОбщегоНазначения.СообщитьПользователю("Заполните поле Заводской номер",, СтрШаблон(Шаблон, Индекс, "ЗаводскойНомер"));
			//Ошибки.Добавить(НСтр("ru = 'Заполните поле Заводской номер'"));
			ЕстьОшибки = Истина;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаНабора.ТипПрибораУчета) Тогда
			ОбщегоНазначения.СообщитьПользователю("Заполните поле Тип средства измерения",, СтрШаблон(Шаблон, Индекс, "ТипПрибораУчета"));
			//Ошибки.Добавить(НСтр("ru = 'Заполните поле Тип средства измерения'"));
			ЕстьОшибки = Истина;
		КонецЕсли;		
		
		Индекс = Индекс + 1;
		//ОбщегоНазначения.СообщитьПользователю(
	КонецЦикла;	
	
	ВалидироватьПломбы(СтрокаНабора, ОтборПломб, Ошибки, ЕстьОшибки);
	ВалидироватьШкалы(Ошибки, ЕстьОшибки);
	
	Если ЕстьОшибки Тогда 
		Ошибки.Добавить(НСтр("ru = 'Заполните поля табличных частей'"));
	КонецЕсли;  	
	
КонецПроцедуры

&НаСервере
Процедура ВалидироватьПломбы(СтрокаПрибора, ОтборСтрок, Ошибки, ЕстьОшибки)
	
	//ОтборСтрок.IDСтрокиИзмерителя = СтрокаПрибора.IDСтроки;
	//НаборСтрок = НомераПломб.НайтиСтроки(ОтборСтрок);
	Шаблон = "НомераПломб[%1].%2";
	Индекс = 0;
	Для Каждого СтрокаНабора из НомераПломб Цикл 
		
		Если НЕ ЗначениеЗаполнено(СтрокаНабора.НомерПломбы) Тогда
			ОбщегоНазначения.СообщитьПользователю("Заполните поле Номер пломбы'",, СтрШаблон(Шаблон, Индекс, "НомерПломбы"));
			ЕстьОшибки = Истина;
			//Ошибки.Добавить(НСтр("ru = 'Заполните поле Номер пломбы'"));
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаНабора.ВидПломбы) Тогда
			ОбщегоНазначения.СообщитьПользователю("Заполните поле Вид пломбы",, СтрШаблон(Шаблон, Индекс, "ВидПломбы"));
			ЕстьОшибки = Истина;
			//Ошибки.Добавить(НСтр("ru = 'Заполните поле Вид пломбы'"));
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаНабора.КлючСтроки) Тогда
			ОбщегоНазначения.СообщитьПользователю("Заполните поле Место установки пломбы",, СтрШаблон(Шаблон, Индекс, "КлючСтроки"));
			ЕстьОшибки = Истина;
			//Ошибки.Добавить(НСтр("ru = 'Заполните поле Место установки пломбы'"));
		КонецЕсли;
		
		Индекс = Индекс + 1;
		
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ВалидироватьШкалы(Ошибки, ЕстьОшибки)
	
	Шаблон = "Шкалы[%1].%2";
	Индекс = 0;
	
	Для Каждого СтрокаНабора из Шкалы Цикл 
		
		Если НЕ ЗначениеЗаполнено(СтрокаНабора.Шкала) Тогда
			ОбщегоНазначения.СообщитьПользователю("Заполните поле Шкала",, СтрШаблон(Шаблон, Индекс, "Шкала"));
			ЕстьОшибки = Истина;
			//Ошибки.Добавить(НСтр("ru = 'Заполните поле Шкала'"));
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаНабора.ВидДифференцированности) Тогда
			ОбщегоНазначения.СообщитьПользователю("Заполните поле Вид дифференцированности",, СтрШаблон(Шаблон, Индекс, "ВидДифференцированности"));
			ЕстьОшибки = Истина;
			//Ошибки.Добавить(НСтр("ru = 'Заполните поле Вид дифференцированности'"));
		КонецЕсли;
		
		Индекс = Индекс + 1;
		
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТипУзлаУчетаПриИзменении(Элемент)
	ЗаполнитьВидКанальности();
	ОчиститьВсеТаблицы();
	Если Замена Тогда
		ЗаполнитьИзмерителиЗамена();
	Иначе
		ЗаполнитьИзмерители();
	КонецЕсли;
	ЗаполнитьШкалы();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИзмерители()
	
	РезультатЗапроса 	= Справочники.энргТипыУзловУчета.ПолучитьСоставУзлаИШкалы(ТипУзлаУчета);
	Выборка 			= РезультатЗапроса.Выбрать();
	ТекIDСтрокиСостава 	= Неопределено;
	IDСтроки			= Неопределено;			
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ТекIDСтрокиСостава = Выборка.IDСтрокиСостава Тогда
			НоваяСтрока = Измерители.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			//НоваяСтрока.Родитель = Выборка.ТипИзмерителя;
			IDСтроки				= новый УникальныйИдентификатор;
			НоваяСтрока.IDСтроки 	= IDСтроки;
		КонецЕсли;		
		
		Если НЕ Строка(Выборка.IDСтрокиШкалыИзмерителя) = "" Тогда
			НоваяСтрокаШкал 			= ШкалыИзмерителей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаШкал, Выборка);
			НоваяСтрокаШкал.IDСтроки 	= IDСтроки;
		КонецЕсли;
		
		
		ТекIDСтрокиСостава = Выборка.IDСтрокиСостава;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИзмерителиЗамена()
	
	Если ВызывающаяПодсистема = "ЮЛ" Тогда
		ЗаполнитьИзмерителиЗаменаЮЛ();
		Возврат;
	КонецЕсли;	
	
	РезультатЗапроса 	= Справочники.энргТипыУзловУчета.ПолучитьСоставУзлаИШкалы(ТипУзлаУчета);
	Выборка 			= РезультатЗапроса.Выбрать();
	ТекIDСтрокиСостава 	= Неопределено;
	IDСтроки			= Неопределено;			
	Пока Выборка.Следующий() Цикл
		
		Если ВызывающаяПодсистема <> "МКД" Тогда
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("ТипИзмерителя", Выборка.ТипИзмерителя);
			мНайденныеСтроки = Измерители.НайтиСтроки(ПараметрыОтбора);
			Если мНайденныеСтроки.Количество() <> 0 Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ТекIDСтрокиСостава = Выборка.IDСтрокиСостава Тогда
			НоваяСтрока = Измерители.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			IDСтроки				= новый УникальныйИдентификатор;
			НоваяСтрока.IDСтроки 	= IDСтроки;
			НоваяСтрока.Ввод		= Истина;
		КонецЕсли;		
		
		Если НЕ Строка(Выборка.IDСтрокиШкалыИзмерителя) = "" Тогда
			НоваяСтрокаШкал 			= ШкалыИзмерителей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаШкал, Выборка);
			НоваяСтрокаШкал.IDСтроки 	= IDСтроки;
		КонецЕсли;		
		
		ТекIDСтрокиСостава = Выборка.IDСтрокиСостава;
		
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИзмерителиЗаменаЮЛ()
		
	РезультатЗапроса 	= Справочники.энргТипыУзловУчета.ПолучитьСоставУзлаИШкалы(ТипУзлаУчета); 
	Выборка 			= РезультатЗапроса.Выбрать();
	ТекIDСтрокиСостава 	= Неопределено;
	IDСтроки			= Неопределено;
	
	СоставУзла = РезультатЗапроса.Выгрузить();
	
	Для Каждого Строка Из Измерители Цикл
		
		Если ЗначениеЗаполнено(Строка.IDСтрокиСостава) Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("ТипИзмерителя", Строка.ТипИзмерителя);
		Если ЗаменаВспомогательныхПУ И Строка.ВспомогательноеОборудование Тогда
			ПараметрыОтбора.Вставить("Фаза"							, Строка.Фаза);
			ПараметрыОтбора.Вставить("ВспомогательноеОборудование"	, Строка.ВспомогательноеОборудование);
			ПараметрыОтбора.Вставить("РасположениеИзмерителя"		, Строка.РасположениеИзмерителя);
		КонецЕсли;
		
		мСтрокиПоТипуИзмерителя = СоставУзла.НайтиСтроки(ПараметрыОтбора);		
		Если ЗначениеЗаполнено(мСтрокиПоТипуИзмерителя) Тогда
			Строка.IDСтрокиСостава = мСтрокиПоТипуИзмерителя[0].IDСтрокиСостава;  
			СоставУзла.Удалить(мСтрокиПоТипуИзмерителя[0]);
		КонецЕсли;   	
	КонецЦикла;


	Пока Выборка.Следующий() Цикл
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("ТипИзмерителя"	, Выборка.ТипИзмерителя);
		ПараметрыОтбора.Вставить("IDСтрокиСостава"	, Выборка.IDСтрокиСостава);
		мНайденныеСтроки = Измерители.НайтиСтроки(ПараметрыОтбора);
		Если мНайденныеСтроки.Количество() <> 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ТекIDСтрокиСостава = Выборка.IDСтрокиСостава Тогда
			НоваяСтрока = Измерители.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			IDСтроки				= новый УникальныйИдентификатор;
			НоваяСтрока.IDСтроки 	= IDСтроки;
			НоваяСтрока.Ввод		= Истина;
		КонецЕсли;		
		
		Если НЕ Строка(Выборка.IDСтрокиШкалыИзмерителя) = "" Тогда
			НоваяСтрокаШкал 			= ШкалыИзмерителей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаШкал, Выборка);
			НоваяСтрокаШкал.IDСтроки 	= IDСтроки;
		КонецЕсли;
				
		ТекIDСтрокиСостава = Выборка.IDСтрокиСостава;
		
	КонецЦикла;

КонецПроцедуры


&НаКлиенте
Процедура ВидКанальностиПриИзменении(Элемент)
	ЗаполнитьШкалы();
КонецПроцедуры

