#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗаполнитьВходнымиДанными();	
КонецПроцедуры

#Конецобласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТипУзлаУчетаПриИзменении(Элемент) 	
	ЗаполнитьВидКанальности();
	ЗаполнитьИзмерители();
	ЗаполнитьШкалы();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИзмерители()
	ОчиститьВсеТаблицы();
	
	РезультатЗапроса 	= Справочники.энргТипыУзловУчета.ПолучитьСоставУзлаИШкалы(ТипУзлаУчета);
	Выборка 			= РезультатЗапроса.Выбрать();
	ТекIDСтрокиСостава 	= Неопределено;
	IDСтроки			= Неопределено;			
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ТекIDСтрокиСостава = Выборка.IDСтрокиСостава Тогда
			НоваяСтрока = Измерители.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			//НоваяСтрока.Родитель = Выборка.ТипИзмерителя;
			IDСтроки				= новый УникальныйИдентификатор;
			НоваяСтрока.IDСтроки 	= IDСтроки;
		КонецЕсли;		
		
		Если НЕ Строка(Выборка.IDСтрокиШкалыИзмерителя) = "" Тогда
			НоваяСтрокаШкал 			= ШкалыИзмерителей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаШкал, Выборка);
			НоваяСтрокаШкал.IDСтроки 	= IDСтроки;
		КонецЕсли;
		
		
		ТекIDСтрокиСостава = Выборка.IDСтрокиСостава;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ВидКанальностиПриИзменении(Элемент)
	ЗаполнитьШкалы();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыИзмерители

#Область СобытияТаблицыИзмерители

&НаКлиенте
Процедура ИзмерителиПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.Измерители.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПоказанияПриборовУчета1ТекущиеПоказания"	, "Видимость"		, НЕ ТекущиеДанные.РегистрируетОбъем);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПоказанияПриборовУчета"						, "Видимость"		, НЕ ТекущиеДанные.ВспомогательноеОборудование);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ИзмерителиФаза"								, "ТолькоПросмотр"	, ТекущиеДанные.ВспомогательноеОборудование);//?(ЗначениеЗаполнено(ТекущиеДанные.Фаза), Истина, Ложь));

КонецПроцедуры

&НаКлиенте
Процедура ИзмерителиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда
		Элемент.ТекущиеДанные.IDСтроки = Новый УникальныйИдентификатор;
	КонецЕсли;	
КонецПроцедуры 

#КонецОбласти

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыШкалы

#Область СобытияТаблицыШкалы

&НаКлиенте
Процедура ШкалыПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ШкалыПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.Шкалы.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(Элементы.ПоказанияПриборовУчета, "IDСтроки", ТекущиеДанные.IDСтроки);
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовТаблицыШкалы

&НаКлиенте
Процедура ПоказанияПриборовУчетаВидДифференцированностиПриИзменении(Элемент)	
	ТекущиеДанные 			= Элементы.Шкалы.ТекущиеДанные;
	ВидДифференцированности = ТекущиеДанные.ВидДифференцированности;
	Состав 					= энргРаботаСТочкамиУчетаСервер.СоставВидаДифференцированности(ВидДифференцированности);
	
	ЗаполнитьТарифныеЗоны(Состав, ТекущиеДанные.IDСтроки); 	
КонецПроцедуры

#КонецОбласти 

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыФормулыРасчетаУслуг

&НаКлиенте
Процедура ФормулыРасчетаФормулаРасчетаПредставлениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ПриборыУчета 				= Новый Массив;
	
	Для Каждого Строка Из Измерители Цикл		
		Если Строка.ВспомогательноеОборудование Тогда
			Продолжить;
		КонецЕсли;
		мШкалы					= Новый Массив;
		
		Для Каждого СтрокаШкалы Из Шкалы Цикл
			мШкалы.Добавить(Новый Структура("Шкала,ВидПараметра",СтрокаШкалы.Шкала,СтрокаШкалы.ВидПараметра));
		КонецЦикла;
		ОписаниеПрибораУчета  	= Новый Структура;
		ОписаниеПрибораУчета.Вставить("ПриборУчета", 		Строка.ПриборУчета);
		ОписаниеПрибораУчета.Вставить("ЗаводскойНомер",		Строка.ЗаводскойНомер);
		ОписаниеПрибораУчета.Вставить("Шкалы", 				мШкалы);
		ПриборыУчета.Добавить(ОписаниеПрибораУчета);		
	КонецЦикла;   	
	Оповещение 					= Новый ОписаниеОповещения("НастройкаФормулыРасчетаЗавершение",ЭтаФорма,Новый Структура("КлючСтроки", Элементы.ФормулыРасчетаУслуг.ТекущаяСтрока));
	ТекущиеДанные 				= Элементы.ФормулыРасчетаУслуг.ТекущиеДанные; 
	мСписокУслуг 				= энргРаботаСПоставщикамиСервер.ПолучитьСоставУслуги(Услуга);
	ПараметрыФормы  			= Новый Структура;
	ПараметрыФормы.Вставить("ПредставлениеФормулы", 	ТекущиеДанные.ФормулаРасчетаПредставление);
	ПараметрыФормы.Вставить("Услуга", 					?(ТекущиеДанные = Неопределено,ПредопределенноеЗначение("Справочник.энргВидыУслуг.ПустаяСсылка"),ТекущиеДанные.Услуга));
	ПараметрыФормы.Вставить("УзелУчета", 				Истина);
	ПараметрыФормы.Вставить("СоставУслуги", 			мСписокУслуг);
	ПараметрыФормы.Вставить("ПриборыУчета", 			ПриборыУчета);
	ОткрытьФорму("ОбщаяФорма.энргНастройкаФормулРасчета", ПараметрыФормы,,,,,Оповещение);
	
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаФормулыРасчетаЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт 
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТипЗнч(РезультатЗакрытия) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не РезультатЗакрытия.Свойство("ПредставлениеФормулы") ИЛИ Не РезультатЗакрытия.Свойство("ФормулаРасчета") Тогда
		Возврат;
	КонецЕсли;
	
	КлючСтроки  											= ДополнительныеПараметры.КлючСтроки;
	
	ТекущиеДанные  										= ФормулыРасчетаУслуг.НайтиПоИдентификатору(КлючСтроки);
	ТекущиеДанные.ФормулаРасчетаПредставление 			= РезультатЗакрытия.ПредставлениеФормулы;
	ТекущиеДанные.ФормулаРасчета 						= РезультатЗакрытия.ФормулаРасчета;
	  
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПоказанияПриборовУчета

&НаКлиенте
Процедура ПоказанияПриборовУчета1ТекущиеПоказанияПриИзменении(Элемент)
	ДопПараменты	= Новый Структура;
	ДопПараменты.Вставить("ПриборУчета", Элементы.Измерители.ТекущиеДанные.ПриборУчета);
	энргРаботаСПоказаниямиПриборовУчетаКлиент.ПересчитатьСтрокуПриборовУчета(Элементы.ПоказанияПриборовУчета.ТекущиеДанные,энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Элементы.Измерители.ТекущиеДанные.ПриборУчета,"РегистрируетОбъем"),ДатаДокумента,,,ДопПараменты);
КонецПроцедуры

&НаКлиенте
Процедура ПоказанияПриборовУчетаСостояниеПоказанийПриИзменении(Элемент)
	
	ТекущиеДанныеТочкиУчета = Элементы.Измерители.ТекущиеДанные;
	Если ТекущиеДанныеТочкиУчета = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ПоказанияПриборовУчета.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РегистрируетОбъем = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущиеДанныеТочкиУчета.ПриборУчета, "РегистрируетОбъем", Истина);
	ДопПараменты	= Новый Структура;
	ДопПараменты.Вставить("ПриборУчета", ТекущиеДанныеТочкиУчета.ПриборУчета);
	энргРаботаСПоказаниямиПриборовУчетаКлиент.ПересчитатьСтрокуПриборовУчета(
		ТекущиеДанные,
		РегистрируетОбъем,
		ДатаДокумента,
		Новый Структура("СтатусИзмененПользователем", Истина),,ДопПараменты);
		
КонецПроцедуры

&НаКлиенте
Процедура ПоказанияПриборовУчетаПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры
	
#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Завершить(Команда)
	Ошибки = "";
	ПроверитьПередЗакрытием(Ошибки);
	Если НЕ ПустаяСтрока(Ошибки) Тогда
		ПоказатьПредупреждение(, Ошибки);
		Возврат;
	КонецЕсли;
	
	Закрыть(ПолучитьРезультат());
КонецПроцедуры

&НаСервере
Функция ПолучитьРезультат() 
	
	КлючиДанных 		= ПолучитьКлючиЗаполнения();
	ДанныеЗакрытия		= Новый Структура(КлючиДанных.Реквизиты + ", " + КлючиДанных.Таблицы);
	
	ЗаполнитьЗначенияСвойств(ДанныеЗакрытия, ЭтаФорма, КлючиДанных.Реквизиты);	
	
	ЗаписатьПараметрыТочекИПриборовУчета();
	
	ДанныеЗакрытия.Измерители 				= ОбщегоНазначения.ТаблицаЗначенийВМассив(Измерители.Выгрузить());
	ДанныеЗакрытия.ПоказанияПриборовУчета 	= ОбщегоНазначения.ТаблицаЗначенийВМассив(ПоказанияПриборовУчета.Выгрузить());
	ДанныеЗакрытия.ШкалыПриборовУчета 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(Шкалы.Выгрузить());
	ДанныеЗакрытия.ШкалыИзмерителей 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(ШкалыИзмерителей.Выгрузить());
	ДанныеЗакрытия.НомераПломб 				= ОбщегоНазначения.ТаблицаЗначенийВМассив(НомераПломб.Выгрузить()); 
	ДанныеЗакрытия.ФормулыРасчетаУслуг 		= ОбщегоНазначения.ТаблицаЗначенийВМассив(ФормулыРасчетаУслуг.Выгрузить()); 
	
	Возврат ДанныеЗакрытия;
КонецФункции

&НаСервере
Процедура ПроверитьПередЗакрытием(Ошибки)
	КолвоНЕВспомОборудования = Измерители.НайтиСтроки(Новый Структура("ВспомогательноеОборудование", Ложь)).Количество();
	Если ЗаменаВспомогательныхПУ Тогда 
		Возврат; 
	ИначеЕсли Измерители.Количество() > 0 И КолвоНЕВспомОборудования = 0 Тогда
		Ошибки = "Не указан прибор учета";
	ИначеЕсли КолвоНЕВспомОборудования > 1 Тогда
		Ошибки = "Приборов учетов указано больше, чем один";
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаписатьПараметрыТочекИПриборовУчета()
	
	Сч 														= 0;
	Для Каждого СтрокаТочки Из Измерители Цикл
		ЗаписываемаяСтрока  								= Измерители[Сч];
		ЗаписываемаяСтрока.КоэффициентПУ 					= ?(ЗаписываемаяСтрока.ВспомогательноеОборудование, 1, КоэффициентПУ);
		ЗаписываемаяСтрока.ТипУзлаУчета 					= ?(ЗаписываемаяСтрока.ВспомогательноеОборудование, Справочники.энргТипыУзловУчета.ПустаяСсылка(), ТипУзлаУчета);
		Сч 													= Сч + 1;		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВходнымиДанными()
	ВходныеПараметры 	= Параметры.ВходныеПараметры;

	Если ВходныеПараметры.Свойство("ЗаменаВспомогательныхПУ") Тогда
		ЗаменаВспомогательныхПУ = ВходныеПараметры.ЗаменаВспомогательныхПУ;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтаФорма, ВходныеПараметры, "ДатаДокумента, Услуга, НаименованиеТочки, ВидКанальности, ТипУзлаУчета, ВидОперации, КоэффициентПУ, ВызывающаяПодсистема");
	
	Если ЗаменаВспомогательныхПУ Тогда 
		ВходныеПараметры.Измерители	= Обработки.энргОперацияУзламиУчета.ОбработатьВходнуюТаблицу(ВходныеПараметры.Измерители, "ВспомогательноеОборудование", Истина);	
	КонецЕсли;
	ВходныеПараметры.Измерители	= Обработки.энргОперацияУзламиУчета.ОбработатьВходнуюТаблицу(ВходныеПараметры.Измерители, "Ввод", Ложь);
	ВходныеПараметры.ШкалыПриборовУчета 	= Обработки.энргОперацияУзламиУчета.ОбработатьВходнуюТаблицу(ВходныеПараметры.ШкалыПриборовУчета, "Вывод", Истина);
	ВходныеПараметры.ПоказанияПриборовУчета = Обработки.энргОперацияУзламиУчета.ОбработатьВходнуюТаблицу(ВходныеПараметры.ПоказанияПриборовУчета, "Вывод", Истина);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.Измерители				, Измерители);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.ШкалыПриборовУчета		, Шкалы);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.ПоказанияПриборовУчета	, ПоказанияПриборовУчета);	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.ШкалыИзмерителей			, ШкалыИзмерителей);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.НомераПломб				, НомераПломб);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ВходныеПараметры.ФормулыРасчетаУслуг		, ФормулыРасчетаУслуг);
	
	ЗаполнитьВидКанальности();
	
	Если ВходныеПараметры.Измерители.Количество() = 0 Тогда
		ЗаполнитьИзмерители(); 
	КонецЕсли;
	
	Если ВходныеПараметры.ШкалыПриборовУчета.Количество() = 0 Тогда
		ЗаполнитьШкалы(); 
	КонецЕсли; 	
	
	мСписокУслуг 					= энргРаботаСПоставщикамиСервер.ПолучитьСоставУслуги(Услуга);
	ТаблицаФормулыРасчетаУслуг 		= Элементы.ФормулыРасчетаУслуг;
	ПолеУслуга  					= ТаблицаФормулыРасчетаУслуг.ПодчиненныеЭлементы.Найти("ФормулыРасчетаУслуга");
	ПолеУслуга.СписокВыбора.ЗагрузитьЗначения(мСписокУслуг);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьШкалы()
	
	Шкалы.Очистить();
	
	Если НЕ ЗначениеЗаполнено(ТипУзлаУчета) Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗапроса 	= Справочники.энргВидыКанальности.ПолучитьШкалыВидаКанальности(ВидКанальности);
	Выборка 			= РезультатЗапроса.Выбрать();
	
	ИспользоватьТарифныеЗоны = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	Пока Выборка.Следующий() Цикл
		НоваяСтрока 			= Шкалы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		IDСтрокиШкалы 			= Новый УникальныйИдентификатор;;
		НоваяСтрока.IDСтроки 	= IDСтрокиШкалы;
		Если НЕ ИспользоватьТарифныеЗоны Тогда
			НоваяСтрокаПоказаний 				= ПоказанияПриборовУчета.Добавить();
			НоваяСтрокаПоказаний.ТарифнаяЗона 	= Справочники.энргТарифныеЗоны.БезРазбивки;
			НоваяСтрокаПоказаний.IDСтроки 		= IDСтрокиШкалы;
			НоваяСтрока.ВидДифференцированности = Справочники.энргВидыДифференцированности.Однотарифный;
		КонецЕсли;
	КонецЦикла;
	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТарифныеЗоны(Состав, IDСтроки)
	
	ПоказанияПриборовУчета.Очистить();
	
	Для Каждого ТекТарифнаяЗона из Состав Цикл 
		НоваяСтрока = ПоказанияПриборовУчета.Добавить();
		НоваяСтрока.IDСтроки 		= IDСтроки;
		НоваяСтрока.ТарифнаяЗона 	= ТекТарифнаяЗона;
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьВсеТаблицы()
	Измерители.Очистить();
	ШкалыИзмерителей.Очистить();
	НомераПломб.Очистить();
	ПоказанияПриборовУчета.Очистить();
	ФормулыРасчетаУслуг.Очистить();
	Шкалы.Очистить();
КонецПроцедуры

&НаСервере
Функция  ПолучитьКлючиЗаполнения()
	Возврат Обработки.энргОперацияУзламиУчета.ПолучитьКлючиЗаполненияСредствИзмерений();
КонецФункции

&НаСервере
Процедура ЗаполнитьВидКанальности()
	ВидКанальности = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТипУзлаУчета, "ВидКанальности");
	
	//Если (Шкалы.Количество() = 0 и НЕ ВходныеПараметры.ИспользоватьШкалыПриборовУчета) Тогда
	Если НЕ ЗначениеЗаполнено(ВидКанальности) Тогда
		ВидКанальности = Справочники.энргВидыКанальности.Одноканальный;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
