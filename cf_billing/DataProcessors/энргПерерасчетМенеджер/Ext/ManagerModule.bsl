Функция ДанныеНачисленийЗаПериод(Знач Организация,Знач Район,Знач ПериодНачисления, Знач НачПериода,Знач КонПериода,Знач тзРасшифровка, Знач тзПомещения, Ссылка = Неопределено) Экспорт 
		
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация"		, Организация);
	ПараметрыЗапроса.Вставить("Распределение"	, Ложь);
	ПараметрыЗапроса.Вставить("Район"			, Район);
	ПараметрыЗапроса.Вставить("НачалоПериода"	, НачПериода);
	//ПараметрыЗапроса.Вставить("КонецПериода", 	?(НачалоМесяца(КонПериода) = ПериодНачисления,НачалоМесяца(КонПериода)-1,КонецМесяца(КонПериода))); Было
	ПараметрыЗапроса.Вставить("КонецПериода"	, КонПериода);
	ПараметрыЗапроса.Вставить("Расшифровка"		, тзРасшифровка); 	
	ПараметрыЗапроса.Вставить("КлючиПомещений"	, тзПомещения.ВыгрузитьКолонку("КлючПомещения"));
	ПараметрыЗапроса.Вставить("Регистратор"		, Ссылка);
	
	ПараметрыСхемы 		= Новый Структура;
	ПараметрыВТ 		= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Организация,Район,Распределение","Организация","Район","Распределение")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрПериодМежду("Период", Новый Структура("НачалоПериода,КонецПериода","НачалоПериода","КонецПериода")));
	//ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрПериодМежду("ПериодНачисления", Новый Структура("НачалоПериода,КонецПериода","НачалоПериода","КонецПериода")));
	//ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипМеньшеРавно(Новый Структура("ПериодНачисления","КонецПериода")));

	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("КлючПомещения","КлючиПомещений")));
	Если Ссылка <> Неопределено Тогда
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипНеРавно(Новый Структура("Регистратор","Регистратор")));
	КонецЕсли;
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	Схема 				= Неопределено;
	РегистрыНакопления.энргОбъемНачислений.ЗаполнитьСхемуНаборомЗаписейПоКлючуПомещения(Схема,ПараметрыСхемы, "НаборЗаписейПоОрганизации"); 
	  	
	ПараметрыСхемы 		= Новый Структура;
	ПараметрыВТ 		= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Район,Распределение","Район","Распределение")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрПериодМежду("Период", Новый Структура("НачалоПериода,КонецПериода","НачалоПериода","КонецПериода")));
	//ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрПериодМежду("ПериодНачисления", Новый Структура("НачалоПериода,КонецПериода","НачалоПериода","КонецПериода")));
	//ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипМеньшеРавно(Новый Структура("ПериодНачисления","КонецПериода")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("КлючПомещения","КлючиПомещений")));
	Если Ссылка <> Неопределено Тогда
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипНеРавно(Новый Структура("Регистратор","Регистратор")));
	КонецЕсли;
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);
	РегистрыНакопления.энргОбъемНачислений.ЗаполнитьСхемуНаборомЗаписейПоКлючуПомещения(Схема,ПараметрыСхемы, "НаборЗаписейБезОрганизации");
		
	ЗаполнитьСхемуДанныеРасшифровки(Схема,"Расшифровка");
	ЗаполнитьСхемуУслугиТочекДругихОрганизаций(Схема,"НачислениеПоПлательщикам");
	Пакет 				= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаДанныеНачисленийЗаПериод());
		
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);	
	
КонецФункции

Функция ДанныеРаспределенияЗаПериод(Знач Организация,Знач Район,Знач ПериодНачисления, Знач НачПериода,Знач КонПериода, Знач тзПомещения, АбонентСтарый) Экспорт 
	
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация"		, Организация);
	ПараметрыЗапроса.Вставить("Распределение"	, Истина);
	ПараметрыЗапроса.Вставить("Район"			, Район);
	ПараметрыЗапроса.Вставить("НачалоПериода"	, НачПериода);
	ПараметрыЗапроса.Вставить("КонецПериода"	, КонПериода);
	ПараметрыЗапроса.Вставить("КлючиПомещений"	, тзПомещения.ВыгрузитьКолонку("КлючПомещения"));
	ПараметрыЗапроса.Вставить("Абоненты"		, АбонентСтарый);
	
	ПараметрыСхемы 		= Новый Структура;
	ПараметрыВТ 		= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Организация,Район,Распределение","Организация","Район","Распределение")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрПериодМежду("Период", Новый Структура("НачалоПериода,КонецПериода","НачалоПериода","КонецПериода")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("КлючПомещения","КлючиПомещений")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("Абонент","Абоненты")));
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	Схема 				= Неопределено;
	РегистрыНакопления.энргОбъемНачислений.ЗаполнитьСхемуНаборомЗаписейРаспределенияПоКлючуПомещения(Схема,ПараметрыСхемы, "НаборЗаписейПоРаспределению"); 
	  	
	Пакет 				= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаДанныеРаспределенияЗаПериод());
		
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);	
	
КонецФункции

Функция ДанныеНачисленныйСреднийЗаПериод(Знач Организация,Знач Район, Знач ПериодНачисления, Знач НачПериода,Знач КонПериода, Знач тзПомещения, Ссылка = Неопределено) Экспорт 
	ПараметрыЗапроса  		= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация"		, Организация);
	ПараметрыЗапроса.Вставить("Район"			, Район);
	ПараметрыЗапроса.Вставить("КлючиПомещений"	, тзПомещения.ВыгрузитьКолонку("КлючПомещения"));
	ПараметрыЗапроса.Вставить("НачалоПериода"	, НачПериода);
	//ПараметрыЗапроса.Вставить("КонецПериода", 	?(НачалоМесяца(КонПериода) = ПериодНачисления,НачалоМесяца(КонПериода)-1,КонецМесяца(КонПериода))); Было
	ПараметрыЗапроса.Вставить("КонецПериода"	, КонПериода);
	ПараметрыЗапроса.Вставить("Регистратор"		, Ссылка);
	
	ПараметрыСхемы 		= Новый Структура;
	ПараметрыВТ 		= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Организация,Район,Распределение","Организация","Район","Распределение")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрПериодМежду("Период", Новый Структура("НачалоПериода,КонецПериода","НачалоПериода","КонецПериода")));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("КлючПомещения","КлючиПомещений")));
	Если Ссылка <> Неопределено Тогда
		ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипНеРавно(Новый Структура("Регистратор","Регистратор")));
	КонецЕсли;
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	Схема 			= Неопределено;
	РегистрыНакопления.энргНачисленныйСреднийОбъем.ЗаполнитьСхемуНаборомЗаписейПоКлючуПомещения(Схема,ПараметрыСхемы, "ДействующиеТочки");
	ПараметрыВТ 		= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Период","КонецПериода")));
	ПараметрыСхемы.Вставить("ПараметрыВТ", ПараметрыВТ);
	РегистрыСведений.энргРодительТочкиУчета.АктуальныеРодителиТочекУчета(Схема,ПараметрыСхемы, "РодителиТУ");
	
	Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаДанныеНачисленныйСреднийЗаПериод());
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьСхемуДанныеРасшифровки(Схема, ТаблицаДляПомещения)
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаРасшифровкаНачислений());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения; 
	
КонецПроцедуры

Процедура ЗаполнитьСхемуУслугиТочекДругихОрганизаций(Схема, ТаблицаДляПомещения)
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаУслугиТочекДругихОрганизаций());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения; 
	
КонецПроцедуры

Функция ТекстЗапросаРасшифровкаНачислений()
	
	Текст = 
	"ВЫБРАТЬ
	|	Расшифровка.ТочкаУчета КАК ТочкаУчета,
	|	Расшифровка.Организация КАК Организация,
	|	Расшифровка.Услуга КАК Услуга
	|ИЗ
	|	&Расшифровка КАК Расшифровка";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаУслугиТочекДругихОрганизаций()
	
	Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расшифровка.ТочкаУчета КАК ТочкаУчета,
	|	Расшифровка.Организация КАК Организация,
	|	Расшифровка.Услуга КАК Услуга	
	|ИЗ
	|	Расшифровка КАК Расшифровка
	|ГДЕ
	|	Расшифровка.Организация <> &Организация";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаДанныеНачисленийЗаПериод()
	
	Текст 	=
	"ВЫБРАТЬ
	|	НаборЗаписейПоОрганизации.*
	|ИЗ
	|	НаборЗаписейПоОрганизации КАК НаборЗаписейПоОрганизации
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НаборЗаписейБезОрганизации.*
	|ИЗ
	|	НаборЗаписейБезОрганизации КАК НаборЗаписейБезОрганизации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НачислениеПоПлательщикам КАК НачислениеПоПлательщикам
	|		ПО НаборЗаписейБезОрганизации.Услуга = НачислениеПоПлательщикам.Услуга
	|			И НаборЗаписейБезОрганизации.Организация = НачислениеПоПлательщикам.Организация
	|			И НаборЗаписейБезОрганизации.ТочкаУчета = НачислениеПоПлательщикам.ТочкаУчета
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргОбъемНачислений.Период КАК Период,
	|	энргОбъемНачислений.Регистратор КАК Регистратор,
	|	энргОбъемНачислений.НомерСтроки КАК НомерСтроки,
	|	энргОбъемНачислений.Активность КАК Активность,
	|	энргОбъемНачислений.Организация КАК Организация,
	|	энргОбъемНачислений.Район КАК Район,
	|	энргОбъемНачислений.Распределение КАК Распределение,
	|	энргОбъемНачислений.Строение КАК Строение,
	|	энргОбъемНачислений.Помещение КАК Помещение,
	|	энргОбъемНачислений.КлючПомещения КАК КлючПомещения,
	|	энргОбъемНачислений.Абонент КАК Абонент,
	|	энргОбъемНачислений.Услуга КАК Услуга,
	|	энргОбъемНачислений.ТочкаУчета КАК ТочкаУчета,
	|	энргОбъемНачислений.ВидНачисления КАК ВидНачисления,
	|	энргОбъемНачислений.СпособНачисления КАК СпособНачисления,
	|	энргОбъемНачислений.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	энргОбъемНачислений.Измеритель КАК Измеритель,
	|	энргОбъемНачислений.ПриборУчета КАК ПриборУчета,
	|	энргОбъемНачислений.Шкала КАК Шкала,
	|	энргОбъемНачислений.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргОбъемНачислений.ЗначениеТарифа КАК ЗначениеТарифа,
	|	энргОбъемНачислений.Поставщик КАК Поставщик,
	|	энргОбъемНачислений.ПериодРасчета КАК ПериодРасчета,
	|	энргОбъемНачислений.ПериодНачисления КАК ПериодНачисления,
	|	энргОбъемНачислений.ЧастныйСектор КАК ЧастныйСектор,
	|	энргОбъемНачислений.СверхНорматива КАК СверхНорматива,
	|	энргОбъемНачислений.НеПрименятьСезонность КАК НеПрименятьСезонность,
	|	энргОбъемНачислений.БылУстановленныйПриборВЭтомГоду КАК БылУстановленныйПриборВЭтомГоду,
	|	энргОбъемНачислений.ОбъемУслуги КАК ОбъемУслуги,
	|	энргОбъемНачислений.ОбъемУслугиПотери КАК ОбъемУслугиПотери,
	|	энргОбъемНачислений.ОбъемУслугиПотребленный КАК ОбъемУслугиПотребленный,
	|	энргОбъемНачислений.ОбъемУслугиПотребленныйПотери КАК ОбъемУслугиПотребленныйПотери,
	|	энргОбъемНачислений.ОбъемУслугиПотребленныйСоцНорма КАК ОбъемУслугиПотребленныйСоцНорма,
	|	энргОбъемНачислений.ОбъемУслугиСоцНорма КАК ОбъемУслугиСоцНорма,
	|	энргОбъемНачислений.Сумма КАК Сумма,
	|	энргОбъемНачислений.СуммаПоПовышенномуКоэффициенту КАК СуммаПоПовышенномуКоэффициенту,
	|	энргОбъемНачислений.СуммаСниженияСтоимости КАК СуммаСниженияСтоимости,
	|	энргОбъемНачислений.ВидБлагоустройства КАК ВидБлагоустройства,
	|	энргОбъемНачислений.ВидДифференцированности КАК ВидДифференцированности,
