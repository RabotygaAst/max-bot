Функция ТекстЗапросаДанныеРаспределенияЗаПериод()
	
	Текст 	=
	"ВЫБРАТЬ
	|	НаборЗаписейПоРаспределению.*
	|ИЗ
	|	НаборЗаписейПоРаспределению КАК НаборЗаписейПоРаспределению
	|";
	Возврат Текст;

КонецФункции

Функция ТекстЗапросаДанныеНачисленныйСреднийЗаПериод()
	
	Текст 	=
	"ВЫБРАТЬ
	|	ДействующиеТочки.*,
	|	ЕСТЬNULL(РодителиТУ.РодительТочкиУчета,ДействующиеТочки.ТочкаУчета) КАК ТочкаУчетаСУчетомРодителя,
	|	ВЫБОР
	|		КОГДА энргУслугиТочекУчетаСрезПоследних.Услуга.СоставнаяУслуга
	|			ТОГДА энргУслугиТочекУчетаСрезПоследних.Услуга
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
	|	КОНЕЦ КАК СоставнаяУслуга
	|ИЗ
	|	ДействующиеТочки КАК ДействующиеТочки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РодителиТУ КАК РодителиТУ
	|		ПО ДействующиеТочки.ТочкаУчета = РодителиТУ.ТочкаУчета 
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
	|				&КонецПериода,
	|				(Организация, Район, КлючПомещения, ТочкаУчета) В
	|					(ВЫБРАТЬ
	|						ВТ.Организация,
	|						ВТ.Район,
	|						ВТ.КлючПомещения,
	|						ВТ.ТочкаУчета
	|					ИЗ
	|						ДействующиеТочки КАК ВТ)) КАК энргУслугиТочекУчетаСрезПоследних 
	|		ПО ДействующиеТочки.ТочкаУчета = энргУслугиТочекУчетаСрезПоследних.ТочкаУчета";
	Возврат Текст;

