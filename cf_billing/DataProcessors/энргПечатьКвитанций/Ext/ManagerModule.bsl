Функция СоотвествиеПараметровСвойствам(ОбъектМетаданных)
	
	Соотвествие 	= Новый Структура;
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ОбъектМетаданных",ОбъектМетаданных);
	Запрос.Текст 	="ВЫБРАТЬ
	|	энргНастройкиПечатныхФорм.Параметр,
	|	энргНастройкиПечатныхФорм.ЗначениеПараметра
	|ИЗ
	|	РегистрСведений.энргНастройкиПечатныхФорм КАК энргНастройкиПечатныхФорм
	|ГДЕ
	|	энргНастройкиПечатныхФорм.ОбъектМетаданных = &ОбъектМетаданных";
	Результат  	= Запрос.Выполнить();
	Выборка  	= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		Соотвествие.Вставить(Выборка.Параметр,Выборка.ЗначениеПараметра);
	КонецЦикла;   
	
	Возврат Соотвествие;
КонецФункции

Функция ПолучитьРеквизитыКвитанции(Выборка, ДанныеОрганизации, ПериодНачисления)
	РеквизитыКвитанции = Новый Структура;
	                                                                                                          
	РеквизитыКвитанции.Вставить("ТекстПолучателя", 			СокрЛП(ДанныеОрганизации.Организация.Наименование));
	РеквизитыКвитанции.Вставить("НомерСчетаПолучателя", 			ДанныеОрганизации.БанковскийСчет.НомерСчета);
	РеквизитыКвитанции.Вставить("НаименованиеБанкаПолучателя", 		ДанныеОрганизации.БанковскийСчет.Банк.Наименование);
	РеквизитыКвитанции.Вставить("БИКБанкаПолучателя", 				ДанныеОрганизации.БанковскийСчет.Банк.Код);
	РеквизитыКвитанции.Вставить("СчетБанкаПолучателя", 				ДанныеОрганизации.БанковскийСчет.Банк.КоррСчет);
	РеквизитыКвитанции.Вставить("СуммаЧислом",		 				Выборка.КОплате);
	//РеквизитыКвитанции.Вставить("ИННПолучателя", 					ДанныеОрганизации.Организация.ИНН);
	РеквизитыКвитанции.Вставить("НомерЛицевогоСчетаПлательщика", 	СокрЛП(Выборка.Абонент.ЛицевойСчет));
	
	//РеквизитыКвитанции.Вставить("АдресПлательщика", 				Выборка.АдресОбъекта);
	//РеквизитыКвитанции.Вставить("НазначениеПлатежа", 				"Оплата услуг водоснабжения и водоотведения");
	
	ПериодОплаты = Формат(ПериодНачисления, "ДФ=MM")+"-"+Формат(ПериодНачисления, "ДФ=MM")+"."+Формат(ПериодНачисления, "ДФ=yyyy"); 
	
	РеквизитыКвитанции.Вставить("ПериодОплаты", 					ПериодОплаты);
	РеквизитыКвитанции.Вставить("ФамилияПлательщика", 				СокрЛП(Выборка.Абонент));
	//РеквизитыКвитанции.Вставить("ИмяПлательщика", 				ДанныеОрганизации.Абонент.Имя);
	//РеквизитыКвитанции.Вставить("ОтчествоПлательщика", 			ДанныеОрганизации.Абонент.Отчество);
	Возврат РеквизитыКвитанции;
КонецФункции	

