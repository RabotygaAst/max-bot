#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

// Печатает.
//
// Параметры:
//  МассивОбъектов			-	Массив.
//  ПараметрыПечати			-	Структура.
//  КоллекцияПечатныхФорм	-	ТаблицаЗначений.
//  ОбъектыПечати			-	см. УправлениеПечатьюПереопределяемый.ПриПечати.ОбъектыПечати.
//  ПараметрыВывода			-	Структура.
//           
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ИмяМакета 				= КоллекцияПечатныхФорм[0].ИмяМакета;
	СинонимМакета 			= КоллекцияПечатныхФорм[0].СинонимМакета;
	
	Если ИмяМакета = "ПФ_MXL_Квитанция" тогда
		ТабличныйДокумент 		= СформироватьКвитанциюMXL(ПараметрыПечати, МассивОбъектов,ИмяМакета);
	ИначеЕсли ИмяМакета = "ПФ_MXL_бестКвитанция" тогда
		ТабличныйДокумент 		= СформироватьКвитанцию(ПараметрыПечати, МассивОбъектов,ИмяМакета, ОбъектыПечати);
	КонецЕсли;	
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, ИмяМакета) Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		ИмяМакета, "Квитанция за " + Формат(ПараметрыПечати.ПериодФормированияКвитанций, "ДФ='MMMM yy'"),
		ТабличныйДокумент, ,
		"Обработка.энргПечатьКвитанций." + ИмяМакета);
	КонецЕсли;
	
	энргФормированиеПечатныхФорм.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);
	
КонецПроцедуры

// Формирует квитанцию.
//
// Параметры:
//  ПараметрыПечати	-	Структура.
//  МассивОбъектов	-	Массив,Соответствие	-	данные о печатаемых объектах.
//  ИмяМакета		-	Строка.
//  ОбъектыПечати	-	см. УправлениеПечатьюПереопределяемый.ПриПечати.ОбъектыПечати.
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьКвитанцию(ПараметрыПечати, МассивОбъектов, ИмяМакета, ОбъектыПечати) Экспорт 
	
	СоотвествиеПараметров					= СоотвествиеПараметровСвойствам("Обработка.энргПечатьДоговора");
	
	Макет 									= УправлениеПечатью.МакетПечатнойФормы("Обработка.энргПечатьКвитанций." +ИмяМакета);
	
	ТабДок 									= Новый ТабличныйДокумент;
	
	ОбластиМакета = Новый Структура;
	ОбластиМакета.Вставить("Шапка");
	ОбластиМакета.Вставить("Шапка_СтрокаПУ");
	ОбластиМакета.Вставить("Шапка_Подвал");
	ОбластиМакета.Вставить("Шапка2");
	ОбластиМакета.Вставить("Шапка3");
	ОбластиМакета.Вставить("Шапка4");
	ОбластиМакета.Вставить("УслугиСтрока");
	ОбластиМакета.Вставить("Итого4");
	ОбластиМакета.Вставить("Шапка5");
	ОбластиМакета.Вставить("Строка5");
	ОбластиМакета.Вставить("ДополнительнаяИнформация");
	ОбластиМакета.Вставить("ДопИнформацияФилиала");
	
	для Каждого КлючЗначение из ОбластиМакета  цикл
		ОбластиМакета[КлючЗначение.ключ]	= Макет.получитьОбласть(КлючЗначение.ключ);
	КонецЦикла;  	
	
	ПоказанияПриборовУчета = Новый ТаблицаЗначений;
	ПоказанияПриборовУчета.Колонки.Добавить("Услуга");
	ПоказанияПриборовУчета.Колонки.Добавить("ПриборУчета");
	ПоказанияПриборовУчета.Колонки.Добавить("Показание");
	ПоказанияПриборовУчета.Колонки.Добавить("ДатаПоверки");
	
	МВТ										= Новый МенеджерВременныхТаблиц;
	СформироватьТаблицуАбонентов(МВТ, МассивОбъектов, ПараметрыПечати);
	
	СтруктураРезультат	= ПолучитьДанныеКвитанция(МВТ, ПараметрыПечати);
	ВыборкаРайонов = СтруктураРезультат.РезультатОсновногоЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ПоказанияМКДПустые = СтруктураРезультат.РезультатЗапросаПоказаний.Пустой(); 
	ВыборкаПоказаний = СтруктураРезультат.РезультатЗапросаПоказаний.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	
	ДанныеОрганизации = Новый Структура("Организация, ИНН, КПП, БИК, ЮрАдресОрганизации, ТелефонОрганизации, БанковскийСчет, КоррСчет, ЭлПочта");
	
	ПериодНачисления						= Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ПараметрыПечати.ПериодФормированияКвитанций, ПараметрыПечати.Организация, ПараметрыПечати.Район);
	ПериодКвитанции							= Формат(ПериодНачисления, "ДФ='MMMM yyy'");
	
	ВыводитьРазделитель = Истина;
	ВыведенныеПУ = Новый Соответствие;
	
	
	ВыводитьРазделитель = Не ВыводитьРазделитель;
	ВыведенныеПУ.Очистить();
	
	МассивОбъектов.Очистить();	// в МассивОбъектов должны содержаться только Абоненты
	
	Пока ВыборкаРайонов.Следующий() Цикл
		Если ПолучитьФункциональнуюОпцию("энргИспользоватьАбонентскиеОтделы") Тогда
			КонтрагентДляШапки = ВыборкаРайонов.Район;
		ИначеЕсли ВыборкаРайонов.Район.Филиалы.Количество() > 0 Тогда
			Филиал 				= ВыборкаРайонов.Район.Филиалы[0].Филиал;
			
			КонтрагентДляШапки 	= новый Структура("Контрагент", Справочники.энргКонтрагенты.ПустаяСсылка());
			Если ПараметрыПечати.Свойство("Организация") Тогда
				МассивСтрок = Филиал.ИзменяемыеРеквизиты.НайтиСтроки(Новый Структура("Организация",ПараметрыПечати.Организация));
				Если МассивСтрок.Количество() > 0 Тогда
					КонтрагентДляШапки.Контрагент = МассивСтрок[0].Контрагент;
				Иначе 
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для абонентского отдела: " + Филиал + " не указаны параметры печати. Заполните табличную часть ""Настройки"".");
					Продолжить;
				КонецЕсли; 				
			КонецЕсли;
			
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для Территориального органа " + ВыборкаРайонов.Район + " не указаны параметры печати. Укажите их в абонентском отделе.");
			Продолжить;
		КонецЕсли;
		
		
		ДанныеОрганизации = Новый Структура("Организация, ИНН, КПП, БИК, ЮрАдресОрганизации, ТелефонОрганизации, БанковскийСчет, КоррСчет, ЭлПочта");
		
		ДанныеОрганизации.Организация 			= ПараметрыПечати.Организация;
		ДанныеОрганизации.ИНН  					= ДанныеОрганизации.Организация.ИНН;
		ДанныеОрганизации.КПП		  			= ДанныеОрганизации.Организация.КПП;	
		ДанныеОрганизации.ЮрАдресОрганизации	= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ДанныеОрганизации.Организация, Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента);
		ДанныеОрганизации.ЭлПочта				= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ДанныеОрганизации.Организация, Справочники.ВидыКонтактнойИнформации.EmailКонтрагента);
		ДанныеОрганизации.ТелефонОрганизации	= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ДанныеОрганизации.Организация, Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента);
		ДанныеОрганизации.БанковскийСчет		= ДанныеОрганизации.Организация.ОсновнойБанковскийСчет;
		ДанныеОрганизации.БИК		  			= ДанныеОрганизации.Организация.ОсновнойБанковскийСчет.Банк.Код;
		ДанныеОрганизации.КоррСчет				= ДанныеОрганизации.Организация.ОсновнойБанковскийСчет.Банк.КоррСчет;
		
		
		Выборка = ВыборкаРайонов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выборка.Следующий() Цикл
			МассивОбъектов.Добавить(Выборка.Абонент);
			
			НомерСтрокиНачало	= ТабДок.ВысотаТаблицы + 1;
			ОбластьШапка									= ОбластиМакета.Шапка;
			ОбластьШапка.Параметры.АдресОбъекта				= Выборка.АдресОбъекта;
			ОбластьШапка.Параметры.ЛицевойСчет 				= Выборка.ЛицевойСчет;
			ТабДок.Вывести(ОбластьШапка);
			
			РезультатПриборы 						= энргРаботаСприборамиУчетаСервер.ПоказанияПриборовУчета(Неопределено,ДанныеОрганизации.Организация,Выборка.Абонент.Район,Выборка.КлючПомещения);
			ВыборкаПриборы  						= РезультатПриборы.выбрать();
			
			Пока ВыборкаПриборы.следующий() цикл
				ОбластьШапка_СтрокаПУ				= ОбластиМакета.Шапка_СтрокаПУ;
				ЗаполнитьЗначенияСвойств(ОбластьШапка_СтрокаПУ.Параметры,ВыборкаПриборы);
				ТабДок.Вывести(ОбластьШапка_СтрокаПУ);
			КонецЦикла;
			
			ОбластьШапка_Подвал						= ОбластиМакета.Шапка_Подвал;
			ОбластьШапка_Подвал.Параметры.Абонент 	= Выборка.Абонент;
			ТабДок.Вывести(ОбластьШапка_Подвал);
			
			ОбластьШапка2									= ОбластиМакета.Шапка2;		
			ЗаполнитьЗначенияСвойств(ОбластьШапка2.Параметры, ДанныеОрганизации);
			ЗаполнитьЗначенияСвойств(ОбластьШапка2.Параметры, Выборка);		
			ОбластьШапка2.Параметры.Период 					= ПериодКвитанции;
			
			РеквизитыКвитанции 												= ПолучитьРеквизитыКвитанции(Выборка, ДанныеОрганизации, ПериодНачисления);
			QRСтрока 														= УправлениеПечатью.ФорматнаяСтрокаУФЭБС(РеквизитыКвитанции);
			
			Если Не ПустаяСтрока(QRСтрока) Тогда
				ДанныеQRКода = УправлениеПечатью.ДанныеQRКода(QRСтрока, 1, 120);
				Если НЕ ТипЗнч(ДанныеQRКода) = Тип("ДвоичныеДанные") Тогда
					Шаблон 													= Нстр("ru = 'Не удалось сформировать QR-код для абонента %1. Технические подробности см. в журнале регистрации.'");
					ТекстСообщения 											= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон, Выборка.Абонент);
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				Иначе
					КартинкаQRКода								= Новый Картинка(ДанныеQRКода);
					ОбластьШапка2.Рисунки.QRКод.Картинка		= КартинкаQRКода;
				КонецЕсли;
			КонецЕсли;
			
			ТабДок.Вывести(ОбластьШапка2);
			
			ОбластьШапка3									= ОбластиМакета.Шапка3;
			ЗаполнитьЗначенияСвойств(ОбластьШапка3.Параметры, ДанныеОрганизации);
			ЗаполнитьЗначенияСвойств(ОбластьШапка3.Параметры, Выборка);
			ОбластьШапка3.Параметры.Период 					= ПериодКвитанции;
			ОбластьШапка3.Параметры.ДатаОплатыСчета			= Дата(Год(ДобавитьМесяц(ПериодНачисления, 1)), Месяц(ДобавитьМесяц(ПериодНачисления, 1)), 10);
			ТабДок.Вывести(ОбластьШапка3);
			
			ОбластьШапка4									= ОбластиМакета.Шапка4;
			ОбластьШапка4.Параметры.Период 					= ПериодКвитанции;
			ТабДок.Вывести(ОбластьШапка4);
			
			ОбластьУслугиСтрока								= ОбластиМакета.УслугиСтрока;
			ВыборкаУслуги = Выборка.Выбрать();
			Пока ВыборкаУслуги.Следующий() Цикл	
				Если ЗначениеЗаполнено(ВыборкаУслуги.Услуга) Тогда
					ЗаполнитьЗначенияСвойств(ОбластьУслугиСтрока.Параметры, ВыборкаУслуги);			
					ТабДок.Вывести(ОбластьУслугиСтрока);	
				КонецЕсли;
			КонецЦикла;
			
			ОбластьИтого4									= ОбластиМакета.Итого4;
			ОбластьИтого4.Параметры.Период 					= ПериодКвитанции;
			ЗаполнитьЗначенияСвойств(ОбластьИтого4.Параметры, Выборка);
			ОбластьИтого4.Параметры.КОплате 				= Выборка.КОплате + Выборка.СуммаПени;
			ТабДок.Вывести(ОбластьИтого4);
			
			Если Не ПоказанияМКДПустые Тогда
				ОбластьШапка5									= ОбластиМакета.Шапка5;
				ОбластьШапка5.Параметры.Организация				= ДанныеОрганизации.Организация;
				ТабДок.Вывести(ОбластьШапка5);
				
				ВыборкаПоказаний.Сбросить();
				Если ВыборкаПоказаний.НайтиСледующий(Новый Структура("МКД", Выборка.МКД)) Тогда 
					ВыборкаПоказанийПУ = ВыборкаПоказаний.Выбрать();
					НомерСтроки = 0;
					Пока ВыборкаПоказанийПУ.Следующий() Цикл
						НомерСтроки = НомерСтроки + 1;  
						ОбластьСтрока5	= ОбластиМакета.Строка5;
						ЗаполнитьЗначенияСвойств(ОбластьСтрока5.Параметры, ВыборкаПоказанийПУ);
						ОбластьСтрока5.Параметры.НомерСтроки = НомерСтроки;
						ТабДок.Вывести(ОбластьСтрока5);	
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
			//Если ВыводитьРазделитель тогда
			
			ОбластьДопИнформацияФилиала	= ОбластиМакета.ДопИнформацияФилиала; 	
			ЗаполнитьЗначенияСвойств(ОбластьДопИнформацияФилиала.Параметры, Выборка);
			ТабДок.Вывести(ОбластьДопИнформацияФилиала);
			
			ОбластьДополнительнаяИнформация	= ОбластиМакета.ДополнительнаяИнформация; 			
			ТабДок.Вывести(ОбластьДополнительнаяИнформация);
			
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДок, НомерСтрокиНачало, ОбъектыПечати, Выборка.Абонент);
			
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			
		КонецЦикла;
	КонецЦикла;
	ТабДок.КлючПараметровПечати				= "ПАРАМЕТРЫ_ПЕЧАТИ_Квитанция";
	ТабДок.АвтоМасштаб						= Истина;
	ТабДок.ОриентацияСтраницы				= ОриентацияСтраницы.Портрет;
	
	Возврат ТабДок;	  	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Квитанция

Функция СформироватьКвитанциюMXL(ПараметрыПечати, МассивОбъектов,ИмяМакета) 
	
	СоотвествиеПараметров					= СоотвествиеПараметровСвойствам("Обработка.энргПечатьДоговора");
	
	Макет 									= УправлениеПечатью.МакетПечатнойФормы("Обработка.энргПечатьКвитанций." +ИмяМакета);
	
	ТабДок 									= Новый ТабличныйДокумент;
	
	ОбластиМакета = Новый Структура;
	ОбластиМакета.Вставить("Шапка");
	ОбластиМакета.Вставить("Услуги");
	ОбластиМакета.Вставить("УслугиИтог");
	ОбластиМакета.Вставить("ШапкаПУ");
	ОбластиМакета.Вставить("ПоказанияПУ");
	ОбластиМакета.Вставить("ПоказанияПоМКД");
	ОбластиМакета.Вставить("СправочнаяИнформация");
	ОбластиМакета.Вставить("ДопОбластьРазрыв");
	ОбластиМакета.Вставить("Отступ");
	ОбластиМакета.Вставить("ШапкаПУОтступ");
	
	для Каждого КлючЗначение из ОбластиМакета  цикл
		ОбластиМакета[КлючЗначение.ключ]	= Макет.получитьОбласть(КлючЗначение.ключ);
	КонецЦикла;  	
	
	ПоказанияПриборовУчета = Новый ТаблицаЗначений;
	ПоказанияПриборовУчета.Колонки.Добавить("Услуга");
	ПоказанияПриборовУчета.Колонки.Добавить("ПриборУчета");
	ПоказанияПриборовУчета.Колонки.Добавить("Показание");
	ПоказанияПриборовУчета.Колонки.Добавить("ДатаПоверки");
		
	МВТ										= Новый МенеджерВременныхТаблиц;
	СформироватьТаблицуАбонентов(МВТ, МассивОбъектов, ПараметрыПечати);
	
	Выборка 								= ПолучитьДанныеКвитанция(МВТ, ПараметрыПечати);
	
	ДанныеОрганизации = Новый Структура("Организация, ЮрАдресОрганизации, ТелефонОрганизации, БанковскийСчет");
	
	//ДанныеОрганизации.Организация  			= ОрганизацииСлужебный.ОрганизацияПоУмолчанию();
	ДанныеОрганизации.Организация  			= ПараметрыПечати.Организация;
	ДанныеОрганизации.ЮрАдресОрганизации	= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ДанныеОрганизации.Организация, Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации);
	ДанныеОрганизации.ТелефонОрганизации	= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ДанныеОрганизации.Организация, Справочники.ВидыКонтактнойИнформации.ТелефонОрганизации);
	ДанныеОрганизации.БанковскийСчет		= ДанныеОрганизации.Организация.ОсновнойБанковскийСчет;
	ПериодНачисления						= Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ПараметрыПечати.ПериодФормированияКвитанций, ПараметрыПечати.Организация, ПараметрыПечати.Район);
	ПериодКвитанции							= Формат(ПериодНачисления, "ДФ='ММММ ггг'");
	
	ВыводитьРазделитель = Истина;
	ВыведенныеПУ = Новый Соответствие;
	
	Пока Выборка.Следующий() Цикл
		ВыводитьРазделитель = Не ВыводитьРазделитель;
		ВыведенныеПУ.Очистить();
		
		ОбластьШапка									= ОбластиМакета.Шапка;
		ОбластьШапка.Параметры.Период 					= ПериодКвитанции;
		//ОбластьШапка.Параметры.Абонент					= Выборка.Абонент.Наименование;
		ОбластьШапка.Параметры.Адрес 					= Выборка.АдресАбонента;
		ОбластьШапка.Параметры.КоличествоПроживающих	= Выборка.КоличествоПроживающих;
		//ОбластьШапка.Параметры.НормативПотребления		= Выборка.ЗначениеНормы;
		ОбластьШапка.Параметры.ЛС 						= Выборка.Абонент.ЛицевойСчет;
		
		ТабДок.Вывести(ОбластьШапка);
		
		Если ЗначениеЗаполнено(Выборка.Абонент.МКД) тогда
			ОбластьПоказанияПоМКД						= ОбластиМакета.ПоказанияПоМКД;
			ТабДок.Вывести(ОбластьПоказанияПоМКД);
		КонецЕсли;	
		
		ОбластьСправочнаяИнформация										= ОбластиМакета.СправочнаяИнформация;
		ОбластьСправочнаяИнформация.Параметры.Поставщик					= ДанныеОрганизации.Организация.Наименование;
		ОбластьСправочнаяИнформация.Параметры.ЮрАдресПоставщика			= ДанныеОрганизации.ЮрАдресОрганизации;
		ОбластьСправочнаяИнформация.Параметры.ИНН						= ДанныеОрганизации.Организация.ИНН;
		ОбластьСправочнаяИнформация.Параметры.КПП						= ДанныеОрганизации.Организация.КПП;
		ОбластьСправочнаяИнформация.Параметры.Телефон					= ДанныеОрганизации.ТелефонОрганизации;
				                                           	
		ОбластьСправочнаяИнформация.Параметры.Банк 						= ДанныеОрганизации.БанковскийСчет.Банк.Наименование;
		ОбластьСправочнаяИнформация.Параметры.РС						= ДанныеОрганизации.БанковскийСчет.НомерСчета;
		ОбластьСправочнаяИнформация.Параметры.БИК						= ДанныеОрганизации.БанковскийСчет.Банк.Код;
		ОбластьСправочнаяИнформация.Параметры.КС						= ДанныеОрганизации.БанковскийСчет.Банк.КоррСчет;
		
		ОбластьСправочнаяИнформация.Параметры.Задолженность				= Выборка.Задолженность;
		ОбластьСправочнаяИнформация.Параметры.ДатаПоследнейОплаты		= Формат(Выборка.ДатаПлатежа, "ДЛФ=Д");
		ОбластьСправочнаяИнформация.Параметры.Период 					= ПериодКвитанции;
		
		РеквизитыКвитанции 												= ПолучитьРеквизитыКвитанции(Выборка, ДанныеОрганизации, ПериодНачисления);
		
		QRСтрока 														= УправлениеПечатью.ФорматнаяСтрокаУФЭБС(РеквизитыКвитанции);
		
		ВывестиQRКод 													= Истина;
		
		Если ПустаяСтрока(QRСтрока) Тогда
			ВывестиQRКод 												= Ложь;
		КонецЕсли;
		
		Если ВывестиQRКод тогда
			ДанныеQRКода 												= УправлениеПечатью.ДанныеQRКода(QRСтрока, 1, 120);
			
			Если НЕ ТипЗнч(ДанныеQRКода) = Тип("ДвоичныеДанные") Тогда
				
				Шаблон 													= Нстр("ru = 'Не удалось сформировать QR-код для абонента %1.
						 														|Технические подробности см. в журнале регистрации.'");
				ТекстСообщения 											= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон,
								 											Выборка.Абонент);
								 
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				
				ВывестиQRКод 											= Ложь;
			КонецЕсли;
		КонецЕсли;	
		
		Если ВывестиQRКод тогда	
			КартинкаQRКода 												= Новый Картинка(ДанныеQRКода);
			ОбластьСправочнаяИнформация.Рисунки.QRКод.Картинка 			= КартинкаQRКода;
		КонецЕсли;	
		
		ТабДок.Вывести(ОбластьСправочнаяИнформация);
		
		ПоказанияПриборовУчета.Очистить();
		
		КоличествоУслуг = 0;
		УслугиВыборка = Выборка.Выбрать();
		Пока УслугиВыборка.Следующий() Цикл	
			Если ЗначениеЗаполнено(УслугиВыборка.Услуга) и УслугиВыборка.КОплате<>0 тогда
					ОбластьУслуги							        = ОбластиМакета.Услуги;
					ОбластьУслуги.Параметры.Услуга					= УслугиВыборка.Услуга;
					ОбластьУслуги.Параметры.ЕдИзм					= УслугиВыборка.ЕдиницаИзмерения;
					ОбластьУслуги.Параметры.Объем					= УслугиВыборка.Объем;
					ОбластьУслуги.Параметры.Тариф					= УслугиВыборка.Тариф;
					ОбластьУслуги.Параметры.Сумма					= УслугиВыборка.СуммаПоТарифу;
					ОбластьУслуги.Параметры.Перерасчет				= УслугиВыборка.Перерасчет;
					ОбластьУслуги.Параметры.КОплате					= УслугиВыборка.КОплате;
					ТабДок.Вывести(ОбластьУслуги);
					КоличествоУслуг = КоличествоУслуг + 1;
			КонецЕсли;
			
			//Если ЗначениеЗаполнено(УслугиВыборка.ПриборУчета) и УслугиВыборка.Показание<>0 тогда
			Если ЗначениеЗаполнено(УслугиВыборка.ПриборУчета) и ВыведенныеПУ.Получить(УслугиВыборка.ПриборУчета) = Неопределено тогда
				ЗаполнитьЗначенияСвойств(ПоказанияПриборовУчета.Добавить(), УслугиВыборка);
				ВыведенныеПУ.Вставить(УслугиВыборка.ПриборУчета, УслугиВыборка.Показание);
			КонецЕсли;
		КонецЦикла;	
		
		ОбластьУслугиИтог									= ОбластиМакета.УслугиИтог;
		ИтогоПоУслугам										= Выборка.КОплате;
		ФормСтрока = "Л = ru_RU; ДП = Истина";
		ПарПредмета= "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2";
		ОбластьУслугиИтог.Параметры.ИтогоПрописью			= ЧислоПрописью(ИтогоПоУслугам, ФормСтрока, ПарПредмета);
		ОбластьУслугиИтог.Параметры.ИтогоКОплате			= ИтогоПоУслугам;
		ТабДок.Вывести(ОбластьУслугиИтог);
		
		Если ПоказанияПриборовУчета.Количество()>0 тогда
			ОбластьШапкаПУ 										= ОбластиМакета.ШапкаПУ;
			ТабДок.Вывести(ОбластьШапкаПУ);
		Иначе
			ШапкаПУОтступ 										= ОбластиМакета.ШапкаПУОтступ;
			ТабДок.Вывести(ШапкаПУОтступ);
		КонецЕсли;	
		
		Для каждого ПоказаниеПУ из ПоказанияПриборовУчета Цикл
			ОбластьПоказанияПУ							    = ОбластиМакета.ПоказанияПУ;
			ОбластьПоказанияПУ.Параметры.СчетчикПоУслуге	= ПоказаниеПУ.Услуга;
			ОбластьПоказанияПУ.Параметры.НомерСчетчика		= ПоказаниеПУ.ПриборУчета;
			ОбластьПоказанияПУ.Параметры.ПоследниеПоказания	= ПоказаниеПУ.Показание;
			ОбластьПоказанияПУ.Параметры.СрокПоверки		= Формат(ПоказаниеПУ.ДатаПоверки, "ДЛФ=Д");
			ТабДок.Вывести(ОбластьПоказанияПУ);
		КонецЦикла;
		
		КоличествоДопСтрок = 11 - (КоличествоУслуг + ПоказанияПриборовУчета.Количество());
		
		Если КоличествоДопСтрок > 0 тогда//и НЕ ВыводитьРазделитель тогда
			Для ДопСтрока=1 по КоличествоДопСтрок Цикл
				ОбластьРазрыв = ОбластиМакета.ДопОбластьРазрыв;
				ТабДок.Вывести(ОбластьРазрыв);
			КонецЦикла;	
		КонецЕсли;	
			
		Если ВыводитьРазделитель тогда
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
		Иначе
			Отступ = ОбластиМакета.Отступ;
			ТабДок.Вывести(Отступ);
		КонецЕсли;	
	КонецЦикла;	  
	
	ТабДок.КлючПараметровПечати				= "ПАРАМЕТРЫ_ПЕЧАТИ_Квитанция";
	ТабДок.АвтоМасштаб						= Истина;
	//ТабДок.ЭкземпляровНаСтранице			= 2;
	
	Возврат ТабДок;	  	
КонецФункции

#КонецОбласти

Процедура СформироватьТаблицуАбонентов(МВТ, МассивОбъектов,ПараметрыПечати)
	ОтборПоАбонентам 	= Новый Массив;
	ОтборПоРайонам		= Новый Массив;
	ОтборПоДомам		= Новый Массив;
	ОтборПоКонтроллерам	= Новый Массив;
	ОтборПоОрганизациям	= Новый Массив;
	
	Для каждого ОбъектОтбора из МассивОбъектов Цикл
		Если ТипЗнч(ОбъектОтбора) = Тип("СправочникСсылка.энргАбоненты") тогда
			ОтборПоАбонентам.Добавить(ОбъектОтбора);
		КонецЕсли;
		
		Если  ТипЗнч(ОбъектОтбора) = Тип("СправочникСсылка.энргЗоныОтвественности") тогда
			ОтборПоРайонам.Добавить(ОбъектОтбора);
		КонецЕсли;
		
		Если  ТипЗнч(ОбъектОтбора) = Тип("СправочникСсылка.энргСтроения") тогда
			ОтборПоДомам.Добавить(ОбъектОтбора);
		КонецЕсли;
		
		Если  ТипЗнч(ОбъектОтбора) = Тип("СправочникСсылка.энргСотрудники") тогда
			ОтборПоКонтроллерам.Добавить(ОбъектОтбора);
		КонецЕсли;
		
		Если  ТипЗнч(ОбъектОтбора) = Тип("СправочникСсылка.Организации") тогда
			ОтборПоОрганизациям.Добавить(ОбъектОтбора);
		КонецЕсли;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	энргАбоненты.Ссылка КАК Абонент,
	|	энргАбоненты.Организация КАК Организация,
	|	энргАбоненты.Район КАК Район,
	|	энргАбоненты.КлючПомещения.Строение КАК МКД,
	|	энргАбоненты.КлючПомещения.Помещение КАК Помещение,
	|	энргАбоненты.КлючПомещения КАК КлючПомещения,
	|	энргФилиалыАбонентовСрезПоследних.Филиал КАК Филиал,
	|	ПОДСТРОКА(энргОбъявленияРайоновСрезПоследних.Объявление, 1, 1024) КАК ДопИнформация
	|ПОМЕСТИТЬ ВТ_ТолькоАбонентИзСправочника
	|ИЗ
	|	Справочник.энргАбоненты КАК энргАбоненты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргФилиалыАбонентов.СрезПоследних(&Период, ) КАК энргФилиалыАбонентовСрезПоследних
	|		ПО энргФилиалыАбонентовСрезПоследних.Абонент = энргАбоненты.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргОбъявленияРайонов.СрезПоследних(&Период, ) КАК энргОбъявленияРайоновСрезПоследних
	|		ПО энргОбъявленияРайоновСрезПоследних.Район = энргАбоненты.Район
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеЛССрезПоследних.Абонент КАК Абонент
	|ПОМЕСТИТЬ ВТ_ДействующиеЛС
	|ИЗ
	|	РегистрСведений.энргСостояниеЛС.СрезПоследних(
	|			&ПериодНач,
	|			(Организация, Район, Абонент) В
	|				(ВЫБРАТЬ
	|					ВТ.Организация,
	|					ВТ.Район,
	|					ВТ.Абонент
	|				ИЗ
	|					ВТ_ТолькоАбонентИзСправочника КАК ВТ)) КАК энргСостояниеЛССрезПоследних
	|ГДЕ
	|	энргСостояниеЛССрезПоследних.Состояние
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргСостояниеЛССрезПоследних.Абонент
	|ИЗ
	|	РегистрСведений.энргСостояниеЛС.СрезПоследних(
	|			&Период,
	|			(Организация, Район, Абонент) В
	|				(ВЫБРАТЬ
	|					ВТ.Организация,
	|					ВТ.Район,
	|					ВТ.Абонент
	|				ИЗ
	|					ВТ_ТолькоАбонентИзСправочника КАК ВТ)) КАК энргСостояниеЛССрезПоследних
	|ГДЕ
	|	энргСостояниеЛССрезПоследних.Состояние
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ТолькоАбонентИзСправочника.Абонент КАК Абонент,
	|	ВТ_ТолькоАбонентИзСправочника.Организация КАК Организация,
	|	ВТ_ТолькоАбонентИзСправочника.Район КАК Район,
	|	ВТ_ТолькоАбонентИзСправочника.Филиал КАК Филиал,
	|	ВТ_ТолькоАбонентИзСправочника.МКД КАК МКД,
	|	ВТ_ТолькоАбонентИзСправочника.Помещение КАК Помещение,
	|	ВТ_ТолькоАбонентИзСправочника.КлючПомещения КАК КлючПомещения,
	|	ВТ_ТолькоАбонентИзСправочника.ДопИнформация
	|ПОМЕСТИТЬ ВТ_ТолькоАбонент
	|ИЗ
	|	ВТ_ТолькоАбонентИзСправочника КАК ВТ_ТолькоАбонентИзСправочника
	//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ДействующиеЛС КАК ВТ_ДействующиеЛС
	//|		ПО ВТ_ТолькоАбонентИзСправочника.Абонент = ВТ_ДействующиеЛС.Абонент
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ТолькоАбонентИзСправочника.Абонент,
	|	ВТ_ТолькоАбонентИзСправочника.Организация,
	|	ВТ_ТолькоАбонентИзСправочника.Район,
	|	ВТ_ТолькоАбонентИзСправочника.Филиал,
	|	ВТ_ТолькоАбонентИзСправочника.МКД,
	|	ВТ_ТолькоАбонентИзСправочника.Помещение,
	|	ВТ_ТолькоАбонентИзСправочника.КлючПомещения,
	|	ВТ_ТолькоАбонентИзСправочника.ДопИнформация;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА энргЗначениеПлощадейМКДСрезПоследних.ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадьМКД)
	|				ТОГДА энргЗначениеПлощадейМКДСрезПоследних.Площадь
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК ОбщаяПлощадьМКД,
	|	энргЗначениеПлощадейМКДСрезПоследних.МКД КАК МКД,
	|	МАКСИМУМ(ВЫБОР
