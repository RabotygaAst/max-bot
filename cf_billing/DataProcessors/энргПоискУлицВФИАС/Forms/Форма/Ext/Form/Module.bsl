#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗаполнитьНаСервере();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСоответствиеУлиц

&НаКлиенте
Процедура СоответствиеУлицПриАктивизацииСтроки(Элемент)
	ТекСтрока = Элементы.СоответствиеУлиц.ТекущиеДанные;

	Если ТекСтрока = Неопределено или НЕ ЗначениеЗаполнено(ТекСтрока.УлицаНедобавленнаяВФИАС) тогда
		Возврат;
	КонецЕсли;
		
	УстановитьОтборПоВсемДинамическимСпискам(ТекСтрока.УлицаНедобавленнаяВФИАС);
КонецПроцедуры

&НаКлиенте
Процедура СоответствиеУлицУлицаНедобавленнаяВФИАСПриИзменении(Элемент)
	СтруктураСтрока = СоответствиеУлицУлицаНедобавленнаяВФИАСПриИзмененииНаСервере(Элементы.СоответствиеУлиц.ТекущиеДанные.УлицаНедобавленнаяВФИАС);
КонецПроцедуры

&НаКлиенте
Процедура СоответствиеУлицПредставлениеАдресаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекСтрока = Элементы.СоответствиеУлиц.ТекущиеДанные;
	
	МодульУправлениеКонтактнойИнформациейКлиент 		= ОбщегоНазначенияКлиент.ОбщийМодуль("УправлениеКонтактнойИнформациейКлиент");
	
	ПараметрыФормыКонтактнойИнформации 					= МодульУправлениеКонтактнойИнформациейКлиент.ПараметрыФормыКонтактнойИнформации(ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресНедобавленногоОбъекта"),""); 
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяРеквизита", Элемент.Имя);
		
	ДанныеСтроки 										= Новый Структура("Представление,ЗначенияПолей",ТекСтрока.ПредставлениеАдреса,ТекСтрока.ЗначениеАдреса);
	
	ПараметрыФормыКонтактнойИнформации.Значение		 	= ДанныеСтроки.ЗначенияПолей;
	ПараметрыФормыКонтактнойИнформации.Представление 	= ДанныеСтроки.Представление;
	
	ПараметрыФормыКонтактнойИнформации.Вставить("Заголовок");
	ПараметрыФормыКонтактнойИнформации.Заголовок	 	= "Адрес ФИАС";
	
	Оповещение 											= Новый ОписаниеОповещения("АдресНедобавленногоОбъектаНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура);
	Оповещение.ДополнительныеПараметры.Вставить("ДанныеЗаполнения",  ДанныеСтроки);
	Оповещение.ДополнительныеПараметры.Вставить("ЭтоТабличнаяЧасть", Ложь);
	Оповещение.ДополнительныеПараметры.Вставить("Элемент",           Элемент);
	Оповещение.ДополнительныеПараметры.Вставить("ДанныеСтроки",      ДанныеСтроки);		
	Оповещение.ДополнительныеПараметры.Вставить("Результат",         Результат);
	Оповещение.ДополнительныеПараметры.Вставить("Форма",             ЭтаФорма);
	
	МодульУправлениеКонтактнойИнформациейКлиент.ОткрытьФормуКонтактнойИнформации(ПараметрыФормыКонтактнойИнформации,,Оповещение);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Заполнить(Команда)
	ЗаполнитьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура Обработать(Команда)
	ОбработатьНаСервере();
	ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Обработка завершена'"));
	ЗаполнитьНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьНаСервере()
	СоответствиеУлиц.Очистить();
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргУлицыНедобавленныеВФИАС.Ссылка КАК Ссылка,
	|	энргУлицыНедобавленныеВФИАСКонтактнаяИнформация.Представление КАК Представление,
	|	энргУлицыНедобавленныеВФИАСКонтактнаяИнформация.Значение КАК Значение,
	|	энргУлицыНедобавленныеВФИАСКонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей
	|ИЗ
	|	Справочник.энргУлицыНедобавленныеВФИАС.КонтактнаяИнформация КАК энргУлицыНедобавленныеВФИАСКонтактнаяИнформация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргУлицыНедобавленныеВФИАС КАК энргУлицыНедобавленныеВФИАС
	|		ПО энргУлицыНедобавленныеВФИАСКонтактнаяИнформация.Ссылка = энргУлицыНедобавленныеВФИАС.Ссылка
	|			И (энргУлицыНедобавленныеВФИАСКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресНедобавленногоОбъекта))
	|ГДЕ
	|	НЕ энргУлицыНедобавленныеВФИАС.ПометкаУдаления
	|	И НЕ энргУлицыНедобавленныеВФИАС.ДобавленВФИАС";
	
	РезультатЗапроса 		= Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи 	= РезультатЗапроса.Выбрать();
	
	МенеджерУлиц 			= Справочники.энргУлицыНедобавленныеВФИАС;
	ТипКонтактнойИнформации = Перечисления.ТипыКонтактнойИнформации.Адрес;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НовСтр = СоответствиеУлиц.Добавить();
		
		НовСтр.УлицаНедобавленнаяВФИАС 	= ВыборкаДетальныеЗаписи.Ссылка;
		НовСтр.ПредставлениеАдреса  	= ВыборкаДетальныеЗаписи.Представление;
		
		//УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(ВыборкаДетальныеЗаписи.Представление,Перечисления.ТипыКонтактнойИнформации.Адрес);
		//УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияВСтруктуруJSON(УправлениеКонтактнойИнформациейСлужебный.АдресXMLВXDTO(ВыборкаДетальныеЗаписи.ЗначенияПолей, "", Перечисления.ТипыКонтактнойИнформации.Адрес));
		//УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(УправлениеКонтактнойИнформациейСлужебный.АдресXMLВXDTO(ВыборкаДетальныеЗаписи.ЗначенияПолей, "", Перечисления.ТипыКонтактнойИнформации.Адрес));
		//УправлениеКонтактнойИнформациейСлужебный.АдресXMLВXDTO(ВыборкаДетальныеЗаписи.ЗначенияПолей, "", Перечисления.ТипыКонтактнойИнформации.Адрес);
		//УправлениеКонтактнойИнформациейСлужебный.ПривестиКонтактнуюИнформациюXML(ВыборкаДетальныеЗаписи.Значение);
		
		СтрокаJSON = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(ВыборкаДетальныеЗаписи.Представление,Справочники.ВидыКонтактнойИнформации.АдресНедобавленногоОбъекта);
		Если ЗначениеЗаполнено(Найти(СтрокаJSON,"ВСвободнойФорме")) Тогда
			НовСтр.ЗначениеАдреса  = ВыборкаДетальныеЗаписи.Значение;
		Иначе
			НовСтр.ЗначениеАдреса  = ВыборкаДетальныеЗаписи.Значение;
			//НовСтр.ЗначениеАдреса  = СтрокаJSON;
			НовСтр.УлицаНайдена = Истина;
		КонецЕсли;
		
		НовСтр.НайденоСоответствиеВФИАС = МенеджерУлиц.ЕстьСоответствиеУлицыВФИАС(ВыборкаДетальныеЗаписи.Значение, ТипКонтактнойИнформации);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьНаСервере()
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Обработать", Истина);
	НайденныеСтроки = СоответствиеУлиц.НайтиСтроки(ПараметрыОтбора);
	Для каждого стр из НайденныеСтроки Цикл
		УлицаОб = стр.УлицаНедобавленнаяВФИАС.ПолучитьОбъект();
		УлицаОб.ДобавленВФИАС = Истина;
		СтрокиКИ 							= УлицаОб.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип,Вид",Перечисления.ТипыКонтактнойИнформации.Адрес,Справочники.ВидыКонтактнойИнформации.АдресНедобавленногоОбъекта));
		Если СтрокиКИ.Количество() > 0 Тогда
			СтрокиКИ[0].Представление = стр.ПредставлениеАдреса;
			СтрокиКИ[0].Значение = стр.ЗначениеАдреса;
			СтрокиКИ[0].ЗначенияПолей = УправлениеКонтактнойИнформациейСлужебный.ПривестиКонтактнуюИнформациюXML(стр.ЗначениеАдреса).ДанныеXML;
		КонецЕсли;
		УлицаОб.Записать();
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСтроения.Ссылка КАК Строение,
		|	энргПомещения.Ссылка КАК Помещение
		|ИЗ
		|	Справочник.энргСтроения КАК энргСтроения
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения КАК энргПомещения
		|		ПО энргПомещения.Строение = энргСтроения.Ссылка
		|ГДЕ
		|	энргСтроения.УлицаНедобавленнаяВФИАС = &УлицаНедобавленнаяВФИАС
		|ИТОГИ ПО
		|	Строение";
		
		Запрос.УстановитьПараметр("УлицаНедобавленнаяВФИАС", стр.УлицаНедобавленнаяВФИАС);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаСтроение = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаСтроение.Следующий() Цикл
			СтроениеОбъект	= ВыборкаСтроение.Строение.ПолучитьОбъект();
			СтруктураКИ 	= ПоправитьКИВОбъекте(СтроениеОбъект, Справочники.ВидыКонтактнойИнформации.АдресДома, СтрокиКИ);
			
			ВыборкаДетальныеЗаписи = ВыборкаСтроение.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() и СтруктураКИ <> Неопределено Цикл
				Если НЕ ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Помещение) Тогда
					Продолжить;
				КонецЕсли;
				
				ПомещениеОб = ВыборкаДетальныеЗаписи.Помещение.ПолучитьОбъект();
				ПоправитьКИВПомещении(ПомещениеОб, ВыборкаДетальныеЗаписи, СтруктураКИ, СтрокиКИ);
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПоправитьКИВОбъекте(Об, Вид, СтрокиКИУлицыНеДобавленнойВФИАС)
	//Об 					= ОбСсылка.ПолучитьОбъект();
	Значение 			= СтрокиКИУлицыНеДобавленнойВФИАС[0].Значение;
	СтрокиКИ			= Об.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип,Вид",Перечисления.ТипыКонтактнойИнформации.Адрес,Вид));
	СтруктураВозврат 	= Неопределено;
	
	Если СтрокиКИ.Количество() > 0 Тогда
		СтруктураБезДома 				= УправлениеКонтактнойИнформациейСлужебный.СтрокаJSONВСтруктуру(Значение);
		СтруктураСтарая 				= УправлениеКонтактнойИнформациейСлужебный.СтрокаJSONВСтруктуру(СтрокиКИ[0].Значение);
		СтруктураБезДома.buildings 		= СтруктураСтарая.buildings;
		СтруктураБезДома.houseNumber 	= СтруктураСтарая.houseNumber;
		СтруктураБезДома.houseType 		= СтруктураСтарая.houseType;
		СтруктураБезДома.Value			= "";
		СтруктураВозврат 				= СтруктураБезДома;
		
		JSONБезПредставления 			= УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(СтруктураБезДома);		
		ФорматКонтактнойИнформации 		= ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокиКИ[0].Вид, "Тип, ВключатьСтрануВПредставление, ПроверятьПоФИАС");
		ФорматКонтактнойИнформации.Вставить("ФорматАдреса", "ФИАС");
		
		СтруктураБезДома.Value 			= УправлениеКонтактнойИнформациейСлужебный.ПредставлениеКонтактнойИнформации(JSONБезПредставления, ФорматКонтактнойИнформации);
		СтрокиКИ[0].Значение 			= УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(СтруктураБезДома);
		СтрокиКИ[0].Представление 		= СтруктураБезДома.Value;
		
		Об.Наименование 				= Справочники.энргСтроения.СформироватьНаименование(СтрокиКИ[0].Значение);
	КонецЕсли;
	
	Об.Записать();
	
	Возврат  СтруктураВозврат;
КонецФункции

&НаСервере
Процедура ПоправитьКИВПомещении(ПомещениеОб, ВыборкаДетальныеЗаписи, СтруктураКИ, СтрокиКИУлицыНеДобавленнойВФИАС)
	СтрокиКИ	= ПомещениеОб.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип,Вид",Перечисления.ТипыКонтактнойИнформации.Адрес,Справочники.ВидыКонтактнойИнформации.АдресПомещения));
	
	Если СтрокиКИ.Количество() > 0 Тогда
		СтруктураСтарая 			= УправлениеКонтактнойИнформациейСлужебный.СтрокаJSONВСтруктуру(СтрокиКИ[0].Значение);
		СтруктураНовая 				= СтруктураКИ;
		СтруктураНовая.apartments 	= СтруктураСтарая.apartments;
		JSONБезПредставления 		= УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(СтруктураНовая);
		ФорматКонтактнойИнформации 	= ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокиКИ[0].Вид, "Тип, ВключатьСтрануВПредставление, ПроверятьПоФИАС");
		ФорматКонтактнойИнформации.Вставить("ФорматАдреса", "ФИАС");
		
		СтруктураНовая.Value 		= УправлениеКонтактнойИнформациейСлужебный.ПредставлениеКонтактнойИнформации(JSONБезПредставления, ФорматКонтактнойИнформации);
		СтрокиКИ[0].Значение 		= УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(СтруктураНовая);
		СтрокиКИ[0].Представление 	= СтруктураНовая.Value;
		
		ПомещениеОб.Наименование 	= Справочники.энргПомещения.СформироватьНаименование(СтрокиКИ[0].Значение);
	КонецЕсли;
	
	ПомещениеОб.Записать();
КонецПроцедуры

&НаКлиенте
Процедура АдресНедобавленногоОбъектаНачалоВыбораЗавершение(Знач РезультатЗакрытия, Знач ДополнительныеПараметры) Экспорт 
	
	Если ТипЗнч(РезультатЗакрытия) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(РезультатЗакрытия.Значение);
	#Если ВебКлиент Тогда
		СтруктураJSON = ПрочитатьJSONСервер(ЧтениеJSON);
	#Иначе
		СтруктураJSON = ПрочитатьJSON(ЧтениеJSON);	
	#КонецЕсли  
	
	ЧтениеJSON.Закрыть(); 
	
	ТекСтрока = Элементы.СоответствиеУлиц.ТекущиеДанные;
	ТекСтрока.ПредставлениеАдреса	= РезультатЗакрытия.Представление;
	ТекСтрока.ЗначениеАдреса		= РезультатЗакрытия.Значение;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПрочитатьJSONСервер(ЧтениеJSON)
	Возврат  ПрочитатьJSON(ЧтениеJSON);
КонецФункции

&НаСервере
Функция СоответствиеУлицУлицаНедобавленнаяВФИАСПриИзмененииНаСервере(УлицаНедобавленнаяВФИАС)
	СтруктураСтрока =  Новый Структура;
	СтруктураСтрока.Вставить("УлицаНайдена", Ложь);
	СтруктураСтрока.Вставить("ПредставлениеАдреса", "");
	СтруктураСтрока.Вставить("ЗначениеАдреса", "");
	
	СтрокиКИ 							= УлицаНедобавленнаяВФИАС.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип,Вид",Перечисления.ТипыКонтактнойИнформации.Адрес,Справочники.ВидыКонтактнойИнформации.АдресНедобавленногоОбъекта));
	
	Если СтрокиКИ.Количество() > 0 Тогда
		СтруктураСтрока.ПредставлениеАдреса = СтрокиКИ[0].Представление; 
		СтрокаJSON = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(СтруктураСтрока.ПредставлениеАдреса,Справочники.ВидыКонтактнойИнформации.АдресНедобавленногоОбъекта);
		Если ЗначениеЗаполнено(Найти(СтрокаJSON,"ВСвободнойФорме")) Тогда
			СтруктураСтрока.ЗначениеАдреса  = СтрокиКИ[0].Значение;
		Иначе
			СтруктураСтрока.ЗначениеАдреса  = СтрокаJSON;
			СтруктураСтрока.УлицаНайдена = Истина;
		КонецЕсли;
	КонецЕсли;
	Возврат СтруктураСтрока;
КонецФункции

&НаСервере
Процедура УстановитьОтборПоВсемДинамическимСпискам(УлицаНедобавленнаяВФИАС)
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Помещения,"Строение.УлицаНедобавленнаяВФИАС",УлицаНедобавленнаяВФИАС,ВидСравненияКомпоновкиДанных.Равно,,,РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Строения,"УлицаНедобавленнаяВФИАС",УлицаНедобавленнаяВФИАС,ВидСравненияКомпоновкиДанных.Равно,,,РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный);
КонецПроцедуры

#КонецОбласти
