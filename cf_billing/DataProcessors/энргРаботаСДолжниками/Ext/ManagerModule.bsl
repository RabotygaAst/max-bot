#Область СлужебныйПрограммныйИнтерфейс

Функция ПолучитьЗапрос(Отборы = Неопределено, ИсключитьЗадачи = Ложь) Экспорт 
	Перем ТекДата, Организация, Район, Абонент, Задолженность,КоличествоДнейПросрочки,МКД,Услуга,Ответственный,Этап, Поставщик, ГруппаАбонента, КоличествоНеоплаченныхПериодов, УчитыватьСуммуНормативногоРасхода, Улица, НаселенныйПункт;
	
	Если Отборы = Неопределено Тогда
		Отборы = Новый Структура;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = ТекстЗапроса();
	// Установка параметров в зависимости от отборов
	Если Не Отборы.Свойство("ТекДата", ТекДата) Или Не ЗначениеЗаполнено(ТекДата) Тогда
		ТекДата = ТекущаяДата();
	КонецЕсли;	
	Запрос.УстановитьПараметр("ТекДата", ТекДата);
	Запрос.УстановитьПараметр("ИсключитьЗадачи", ИсключитьЗадачи);
	
	Если Отборы.Свойство("Организация", Организация) И ЗначениеЗаполнено(Организация) Тогда
		Запрос.УстановитьПараметр("Организация", Организация);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргЗадачаПИД.Организация = &Организация", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Организация = &Организация", 				 "Истина");
	КонецЕсли;
	
	Если Отборы.Свойство("Район", Район) И ЗначениеЗаполнено(Район) Тогда
		Запрос.УстановитьПараметр("Район", Район);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргЗадачаПИД.Район = &Район", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Район = &Район", 				 "Истина");
	КонецЕсли;
	
	Если Отборы.Свойство("МКД", МКД) И ЗначениеЗаполнено(МКД) Тогда
		Запрос.УстановитьПараметр("МКД", МКД);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргЗадачаПИД.МКД = &МКД", 			"Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&МКД = энргКлючиПомещений.Строение", 	"Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "МКД = &МКД",				 			"Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргКлючиПомещений.Строение = &МКД",	"Истина");
	КонецЕсли;

	Если Отборы.Свойство("Абонент", Абонент) И ЗначениеЗаполнено(Абонент) Тогда
		Запрос.УстановитьПараметр("Абонент", Абонент);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргЗадачаПИД.Абонент = &Абонент", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Абонент = &Абонент", 				 "Истина");
	КонецЕсли;

	Если Отборы.Свойство("Задолженность", Задолженность) И ЗначениеЗаполнено(Задолженность) Тогда
		Запрос.УстановитьПараметр("Задолженность", Задолженность);
	Иначе
		Запрос.УстановитьПараметр("Задолженность", 0);
	КонецЕсли;

	Если Отборы.Свойство("КоличествоДнейПросрочки", КоличествоДнейПросрочки) И ЗначениеЗаполнено(КоличествоДнейПросрочки) Тогда
		Запрос.УстановитьПараметр("КоличествоДнейПросрочки", КоличествоДнейПросрочки);
	Иначе
		Запрос.УстановитьПараметр("КоличествоДнейПросрочки", 0);
	КонецЕсли;
	
	Если Отборы.Свойство("Услуга", Услуга) И ЗначениеЗаполнено(Услуга) Тогда
		Запрос.УстановитьПараметр("Услуга", Услуга);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Услуга = &Услуга", "Истина");
	КонецЕсли;
	
	Если Отборы.Свойство("Ответственный", Ответственный) И ЗначениеЗаполнено(Ответственный) Тогда
		Запрос.УстановитьПараметр("Ответственный", Ответственный);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргЗадачаПИД.Исполнитель = &Ответственный", 			  "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТ_ЭтапыИОтветственные.Ответственный = &Ответственный", "Истина");	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЕСТЬNULL(ВТ_ЭтапыИОтветственные.Ответственный, ВТ_Остатки.Ответственный) = &Ответственный", "Истина");	
	КонецЕсли;

	Если Отборы.Свойство("Этап", Этап) И ЗначениеЗаполнено(Этап) Тогда
		Запрос.УстановитьПараметр("Этап", Этап);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргЗадачаПИД.Этап = &Этап", 			"Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТ_ЭтапыИОтветственные.Этап = &Этап", "Истина");
	КонецЕсли;

	Если Отборы.Свойство("Поставщик", Поставщик) И ЗначениеЗаполнено(Поставщик) Тогда
		Запрос.УстановитьПараметр("Поставщик", Поставщик);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Поставщик = &Поставщик", " Истина");
	КонецЕсли;	

	Если Отборы.Свойство("ГруппаАбонента", ГруппаАбонента) И ЗначениеЗаполнено(ГруппаАбонента) Тогда
		Запрос.УстановитьПараметр("ГруппаАбонента", ГруппаАбонента);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргЗадачаПИД.Абонент В ИЕРАРХИИ(&ГруппаАбонента)", " Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Абонент В ИЕРАРХИИ (&ГруппаАбонента)",			  " Истина");
	КонецЕсли;
	
	Если Отборы.Свойство("КоличествоНеоплаченныхПериодов", КоличествоНеоплаченныхПериодов) И ЗначениеЗаполнено(КоличествоНеоплаченныхПериодов) Тогда
		Запрос.УстановитьПараметр("КоличествоНеоплаченныхПериодов", КоличествоНеоплаченныхПериодов);
	Иначе
		Запрос.УстановитьПараметр("КоличествоНеоплаченныхПериодов", 0);
	КонецЕсли;
	
	Если Отборы.Свойство("УчитыватьСуммуНормативногоРасхода", УчитыватьСуммуНормативногоРасхода) Тогда
		Запрос.УстановитьПараметр("УчитыватьСуммуНормативногоРасхода", УчитыватьСуммуНормативногоРасхода);
	КонецЕсли;
	
	Если Отборы.Свойство("НаселенныйПункт", НаселенныйПункт) И ЗначениеЗаполнено(НаселенныйПункт)
		Или Отборы.Свойство("Улица", Улица) И ЗначениеЗаполнено(Улица) Тогда
		
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "&ОтборАдрес", ПолучитьТекстПроверкаНаАдрес(Запрос, НаселенныйПункт, Улица));		
	Иначе 
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "&ОтборАдрес", "Истина");		
	КонецЕсли;
	
		
	Возврат Запрос;
КонецФункции
 
Функция ПолучитьСписокОтборовСхемы(Схема) Экспорт

	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСхемыПИДОрганизацийСрезПоследних.Организация КАК Организация,
		|	энргСхемыПИДОрганизацийСрезПоследних.Район КАК Район,
		|	энргСхемыПИДОрганизацийСрезПоследних.МКД КАК МКД,
		|	энргСхемыПИДОрганизацийСрезПоследних.ГруппаАбонента КАК ГруппаАбонента,
		|	энргСхемыПИДОрганизацийСрезПоследних.Абонент КАК Абонент,
		|	энргСхемыПИДОрганизацийСрезПоследних.Услуга КАК Услуга
		|ИЗ
		|	РегистрСведений.энргСхемыПИДОрганизаций.СрезПоследних(&ТекДата, ) КАК энргСхемыПИДОрганизацийСрезПоследних
		|ГДЕ
		|	энргСхемыПИДОрганизацийСрезПоследних.Схема = &Схема";
	
	Запрос.УстановитьПараметр("Схема", Схема);
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
	
	РезультатЗапроса = Запрос.Выполнить();
	ПарамОтбора = "";
	Для каждого Колонка Из РезультатЗапроса.Колонки Цикл
		ПарамОтбора = ?(ПустаяСтрока(ПарамОтбора), "", ПарамОтбора + ", ") + Колонка.Имя;
	КонецЦикла;
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ВариантОтбора = Новый Структура(ПарамОтбора);
		ЗаполнитьЗначенияСвойств(ВариантОтбора, Выборка);
		
		Результат.Добавить(ВариантОтбора);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции 

#Область РаботаСФормированиемОтчета

Функция СформироватьКвитанции(ПериодНачисления, Организация, Район, ДополнительныеПараметры = Неопределено) Экспорт
	
	ТабличныйДокумент						= Новый ТабличныйДокумент;
	ТабличныйДокумент.ОриентацияСтраницы 	= ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.АвтоМасштаб 			= Истина;
	
	ИмяМакета 								= Документы.рксЕдиныйПлатежныйДокумент.ПолучитьИмяМакета(ПериодНачисления);

	Если ИмяМакета = "ПФ_MXL_КвитанцияЕПДОт01012020" Тогда
		Результат = Документы.рксЕдиныйПлатежныйДокумент.ПолучитьДокументыЕПДДляОтчетаОт01012020(ПериодНачисления, Организация, Район, ДополнительныеПараметры);
		Документы.рксЕдиныйПлатежныйДокумент.ЗаполнитьМакетЕПДОт01012020(Результат, ТабличныйДокумент, ИмяМакета, ДополнительныеПараметры);
	КонецЕсли;

	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РаботаСОтборомПоАдресу

Функция ПолучитьТекстПроверкаНаАдрес(Запрос, НаселенныйПункт, Улица)
	Шаблон = "ВЫБОР
	|			КОГДА энргАбонентыКонтактнаяИнформация.Тип = Значение(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|					И энргАбонентыКонтактнаяИнформация.Вид = Значение(Справочник.ВидыКонтактнойИнформации.АдресОбъекта)
	|				ТОГДА энргАбоненты.КонтактнаяИнформация.Представление ПОДОБНО &Представление
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ";
	
	
	ОбщийТекст = "";
	
	Если ЗначениеЗаполнено(НаселенныйПункт) Тогда
		ДополнитьОбщийТекст(ОбщийТекст, Шаблон, "&НаселенныйПункт");
		Запрос.УстановитьПараметр("НаселенныйПункт", "%" + НаселенныйПункт + "%");		
	КонецЕсли;
	Если ЗначениеЗаполнено(Улица) Тогда
		ДополнитьОбщийТекст(ОбщийТекст, Шаблон, "&Улица");
		Запрос.УстановитьПараметр("Улица", "%" + Улица + "%");		
	КонецЕсли;
		
	Возврат ?(ОбщийТекст = "", "", "  " + ОбщийТекст );
	
КонецФункции

Процедура ДополнитьОбщийТекст(ОбщийТекст, Шаблон, ПодстрокаЗамены)
	ОбщийТекст = ОбщийТекст + ?(ОбщийТекст = "", "", " ИЛИ ") + СтрЗаменить(Шаблон, "&Представление", ПодстрокаЗамены);
КонецПроцедуры

#КонецОбласти

Функция ТекстЗапроса() Экспорт 

	Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	энргЗадачаПИД.Абонент КАК Абонент,
		|	энргЗадачаПИД.Этап КАК Этап,
		|	энргЗадачаПИД.ДатаСледЭтапа КАК ДатаСледЭтапа,
		|	энргЗадачаПИД.Организация КАК Организация,
		|	энргЗадачаПИД.Исполнитель КАК Ответственный,
		|	энргЗадачаПИД.Ссылка КАК Задача
		|ПОМЕСТИТЬ ВТ_ЭтапыИОтветственные
		|ИЗ
		|	Задача.энргЗадачаПИД КАК энргЗадачаПИД
		|ГДЕ
		|	НЕ энргЗадачаПИД.Выполнена
		|	И энргЗадачаПИД.Абонент <> ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка)
		|	И энргЗадачаПИД.Организация = &Организация
		|	И энргЗадачаПИД.Этап = &Этап
		|	И НЕ энргЗадачаПИД.ПометкаУдаления
		|	И энргЗадачаПИД.Район = &Район
		|	И энргЗадачаПИД.МКД = &МКД
		|	И энргЗадачаПИД.Абонент = &Абонент
		|	И энргЗадачаПИД.Исполнитель = &Ответственный
		|	И энргЗадачаПИД.Абонент В ИЕРАРХИИ(&ГруппаАбонента)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ЭтапыИОтветственные.Абонент КАК Абонент,
		|	ВТ_ЭтапыИОтветственные.Этап КАК Этап,
		|	ВТ_ЭтапыИОтветственные.ДатаСледЭтапа КАК ДатаСледЭтапа,
		|	ВТ_ЭтапыИОтветственные.Организация КАК Организация,
		|	ВТ_ЭтапыИОтветственные.Ответственный КАК Ответственный,
		|	ВТ_ЭтапыИОтветственные.Задача КАК Задача,
		|	энргЗадачаПИДЗадолженность.Услуга КАК Услуга,
		|	энргЗадачаПИДЗадолженность.ПериодНачисления КАК ПериодНачисления
		|ПОМЕСТИТЬ ВТ_ЗадачиПоЗадолженности
		|ИЗ
		|	ВТ_ЭтапыИОтветственные КАК ВТ_ЭтапыИОтветственные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.Задолженность КАК энргЗадачаПИДЗадолженность
		|		ПО ВТ_ЭтапыИОтветственные.Задача = энргЗадачаПИДЗадолженность.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	энргВзаиморасчетыПоМесяцамОстатки.Организация КАК Организация,
		|	энргВзаиморасчетыПоМесяцамОстатки.Район КАК Район,
		|	энргВзаиморасчетыПоМесяцамОстатки.Абонент КАК Абонент,
		|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления КАК ПериодНачисления,
		|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток КАК СуммаОстаток,
		|	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
		|	МАКСИМУМ(энргНастройкиНачисленияПени.Период) КАК Период
		|ПОМЕСТИТЬ ВТ_НепогашеныеНачисления
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
		|			&ТекДата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И Услуга = &Услуга
		|				И Абонент = &Абонент
		|				И МКД = &МКД
		|				И Поставщик = &Поставщик
		|				И Абонент В ИЕРАРХИИ (&ГруппаАбонента)) КАК энргВзаиморасчетыПоМесяцамОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргНастройкиНачисленияПени КАК энргНастройкиНачисленияПени
		|		ПО энргВзаиморасчетыПоМесяцамОстатки.Организация = энргНастройкиНачисленияПени.Организация
		|			И энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления >= энргНастройкиНачисленияПени.Период
		|			И энргВзаиморасчетыПоМесяцамОстатки.Район = энргНастройкиНачисленияПени.Район
		|ГДЕ
		|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток > 0
		|	И энргВзаиморасчетыПоМесяцамОстатки.Услуга <> ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	энргВзаиморасчетыПоМесяцамОстатки.Организация,
		|	энргВзаиморасчетыПоМесяцамОстатки.Район,
		|	энргВзаиморасчетыПоМесяцамОстатки.Абонент,
		|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления,
		|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток,
		|	энргВзаиморасчетыПоМесяцамОстатки.Услуга
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
