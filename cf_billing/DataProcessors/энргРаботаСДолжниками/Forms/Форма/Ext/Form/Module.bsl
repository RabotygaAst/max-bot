&НаСервере
Процедура ЗаполнитьДерево()
	ДолжникиНов.ПолучитьЭлементы().Очистить();
	
	Отборы = Новый Структура("Организация, Район, МКД, Абонент, Задолженность, КоличествоДнейПросрочки, Услуга, Ответственный, Этап, Поставщик, НаселенныйПункт, Улица");
	ЗаполнитьЗначенияСвойств(Отборы, Объект);
	Отборы.Вставить("ТекДата", КонецДня(объект.Период));

	Запрос = Обработки.энргРаботаСДолжниками.ПолучитьЗапрос(Отборы, Не ОтобразитьЗадолженностьПИР); 
	
	РезультатДерево = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	ЗначениеВДанныеФормы(РезультатДерево, ДолжникиНов);
КонецПроцедуры

