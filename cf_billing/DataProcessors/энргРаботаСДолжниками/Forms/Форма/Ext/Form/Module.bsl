КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСМС(Команда)
	СоздатьСобытие(ПредопределенноеЗначение("Справочник.энргСпособСвязи.ОтправкаСМС"));
КонецПроцедуры

&НаКлиенте
Процедура ЗапланироватьОтправку(Команда)
	СоотДолжникЗадача = Новый Соответствие;
	
	ИмяПредЭтапа  = СтрЗаменить(Команда.Имя, "КомандаЭтап", "ЭтапПретензионноИсковойДеятельности");
	Этап		  = ПредопределенноеЗначение("Справочник.энргВидыОперацийПИД." + ИмяПредЭтапа);
	ИмяМакета	  = СтрЗаменить(Команда.Имя, "КомандаЭтап", "ПФ_MXL");
	
	ЕстьДолжникиБезЗадач = Ложь;
	Для каждого ТекСтрока Из Элементы.Должники.ВыделенныеСтроки Цикл
		ТекДанные = Элементы.Должники.ДанныеСтроки(ТекСтрока);
		
		Если ТекДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТекДанные.Задача) Тогда
			ЕстьДолжникиБезЗадач = Истина;
			СоотДолжникЗадача.Вставить(ТекСтрока, "");
		КонецЕсли;
	КонецЦикла;

	Если ЕстьДолжникиБезЗадач Тогда
		СписокКнопок = Новый СписокЗначений;
		СписокКнопок.Добавить(КодВозвратаДиалога.Пропустить, "Пропустить абонентов");
		Если ЗначениеЗаполнено(Объект.Схема) Тогда
			СписокКнопок.Добавить(КодВозвратаДиалога.ОК, "Создать задачи для абонентов");
		КонецЕсли;
		СписокКнопок.Добавить(КодВозвратаДиалога.Отмена);
		ПарамВопроса = Новый Структура("ИмяМакета, СоотДолжникЗадача, Этап", ИмяМакета, СоотДолжникЗадача, Этап);
		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаОтветаНаСозданиеЗадач", ЭтотОбъект, ПарамВопроса);

		ПоказатьВопрос(ОписаниеОповещения, "Выделены абоненты без задач.", СписокКнопок);
	Иначе
		СоздатьЗапланированнуюОтправку(ИмяМакета, Этап, СоотДолжникЗадача);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьПеренаправление(Команда)
	Задача = Элементы.ПеренапраленныеЗадачи.ТекущаяСтрока;
	
	Если ЗначениеЗаполнено(Задача) Тогда
	
		ПарамФормы = Новый Структура("ПодтвердитьПеренаправление", Истина);
		ПарамФормы.Вставить("ЗначенияЗаполнения", ПолучитьПараметрыФормыПеренаправления(Задача));

		ОписОпов = Новый ОписаниеОповещения("СменаИсполнителя", ЭтаФорма, Новый Структура("Задача", Задача));
		ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ФормаСменыИсполнителя", ПарамФормы, ЭтаФорма,,,, ОписОпов);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура НазначитьИсполнителя(Команда)
	Задача = Элементы.ЗадачиМне.ТекущаяСтрока;
	
	Если ЗначениеЗаполнено(Задача) Тогда
		
		ПарамФормы = Новый Структура;
		ПарамФормы.Вставить("ЗначенияЗаполнения", Новый Структура("НазначениеИсполнителя", Истина));
		
		ОписОпов = Новый ОписаниеОповещения("НазначениеИсполнителя", ЭтаФорма, Новый Структура("Задача", Задача));
		ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ФормаСменыИсполнителя", ПарамФормы, ЭтаФорма,,,, ОписОпов);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура СобытиеПИР(Команда)
	СписокАбонентов = Новый Массив;
	МассивАбонентов	= Новый Массив;
	
	Для каждого ТекСтрока Из Элементы.ДолжникиНов.ВыделенныеСтроки Цикл
		ТекДанные = Элементы.ДолжникиНов.ДанныеСтроки(ТекСтрока);
		
		Если СписокАбонентов.Найти(ТекДанные.Абонент) = Неопределено Тогда
			СписокАбонентов.Добавить(ТекДанные.Абонент);
			
			//СтрокаАбоненты = Новый Структура("Абонент, Основание, IDЭтапа", ТекДанные.Абонент, Задача.Ссылка, IDЭтапа);
			СтрокаАбоненты = Новый Структура("Абонент", ТекДанные.Абонент);
			МассивАбонентов.Добавить(СтрокаАбоненты);
		КонецЕсли;
	КонецЦикла;
	
	//ОткрытьФорму("Обработка.бестГрупповойВводСобытийПИР.Форма",
	//Новый Структура("СписокАбонентов", СписокАбонентов),
	//ЭтаФорма, УникальныйИдентификатор);
	
		
	ПарамФормы = Новый Структура("Организация, Район, Одинарный", Объект.Организация, Объект.Район, Ложь);
	ПарамФормы.Вставить("Абоненты", МассивАбонентов);
	ФормаКакСтрока = энргОбщегоНазначенияКлиент.ПолучитьФормыПИРДляОтображенияКакСтрока();				
	ОткрытьФорму(ФормаКакСтрока.ФормаДокумента, ПарамФормы, ЭтаФорма, УникальныйИдентификатор,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ДополнительныеФункцииНаКлиенте

&НаКлиенте
Процедура СоздатьЗадачи(СписокСтрок, СоотОргСхема, СоотСхемаЭтап, ОбновитьСписки = Истина, СоотДолжникЗадача = Неопределено)
	
	// Определение стартовых этапов для используемых схем
	Для каждого ЭлемСоот Из СоотСхемаЭтап Цикл
		
		Если ТипЗнч(ЭлемСоот.Значение) = Тип("Массив") Тогда 
			Схема = ЭлемСоот.Ключ;
			НачальныеЭтапыСхемы = Новый СписокЗначений;
			НачальныеЭтапыСхемы.ЗагрузитьЗначения(ЭлемСоот.Значение);
			
			Этап = Неопределено;
			
			ДополнительныеПараметры = Новый Структура("СоотОргСхема, СоотСхемаЭтап, СписокСтрок, Схема", СоотОргСхема, СоотСхемаЭтап, СписокСтрок, Схема);
			ОписаниеОповещения		= Новый ОписаниеОповещения("ОбработкаВыбораЭтапа", ЭтотОбъект, ДополнительныеПараметры);
			НачальныеЭтапыСхемы.ПоказатьВыборЭлемента(ОписаниеОповещения, "Выберите начальный этап для схемы """ + Схема + """");
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	// Удаление строк, для которых не удалось установить схему
	УдаляемыеСтроки = Новый Массив;
	Для каждого ТекСтрока Из СписокСтрок Цикл
		Схема = СоотОргСхема.Получить(ТекСтрока.Организация);
		Если Не ЗначениеЗаполнено(Схема) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для абонента " + ТекСтрока.Абонент + " не создана задача, т.к. не определена схема.");
			УдаляемыеСтроки.Добавить(ТекСтрока);
		Иначе
			ТекСтрока.Вставить("Схема", Схема);
		КонецЕсли;
	КонецЦикла;
	
	УдалитьЭлементыИзМасива(СписокСтрок, УдаляемыеСтроки);
	
	// Удаление строк, для которых не удалось установить стартовый этап
	УдаляемыеСтроки = Новый Массив;
	Для каждого ТекСтрока Из СписокСтрок Цикл
		Этап = СоотСхемаЭтап.Получить(ТекСтрока.Схема);
		Если Не ЗначениеЗаполнено(Этап) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для абонента " + ТекСтрока.Абонент + " не создана задача, т.к. не определён стартовый этап.");
			УдаляемыеСтроки.Добавить(ТекСтрока);
		Иначе
			ТекСтрока.Вставить("Этап", Этап);
		КонецЕсли;
	КонецЦикла;
	
	УдалитьЭлементыИзМасива(СписокСтрок, УдаляемыеСтроки);	
	
	СоздатьЗадачиНаСервере(СписокСтрок, СоотДолжникЗадача);
	Если ОбновитьСписки Тогда
		ОбновитьСписки();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЭлементыИзМасива(СписокСтрок, УдаляемыеСтроки)
	
	Перем Индекс, УдалСтрока;
	
	Для каждого УдалСтрока Из УдаляемыеСтроки Цикл
		Индекс = СписокСтрок.Найти(УдалСтрока);
		Если Индекс <> Неопределено Тогда
			СписокСтрок.Удалить(Индекс);
		КонецЕсли;
	КонецЦикла;
	УдаляемыеСтроки.Очистить();

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораЭтапа(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	СоотОргСхема  = ДополнительныеПараметры.СоотОргСхема;
	СоотСхемаЭтап = ДополнительныеПараметры.СоотСхемаЭтап;
	СписокСтрок   = ДополнительныеПараметры.СписокСтрок;
	Схема		  = ДополнительныеПараметры.Схема;
	
	Этап = ВыбранныйЭлемент;
	Если Этап = Неопределено Тогда
		СоотСхемаЭтап[Схема] = Неопределено;
	Иначе
		СоотСхемаЭтап[Схема] = Этап.Значение;
	КонецЕсли;
	
	СоздатьЗадачи(СписокСтрок, СоотОргСхема, СоотСхемаЭтап);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПараметрыЗадачиПИД(Знач ТекСтрока)
	
	Перем ТекАбонент, ТекОрганизация, ТекПоставщик;
	
	ТекАбонент		=?(ТекСтрока = Неопределено, ПредопределенноеЗначение("Справочник.энргАбоненты.ПустаяСсылка"),	  ТекСтрока.Абонент);
	ТекОрганизация	=?(ТекСтрока = Неопределено, ПредопределенноеЗначение("Справочник.Организации.ПустаяСсылка"),	  ТекСтрока.Организация);
	//ТекПоставщик	=?(ТекСтрока = Неопределено, ПредопределенноеЗначение("Справочник.энргКонтрагенты.ПустаяСсылка"), ТекСтрока.Поставщик);
	
	ЗадачиПИД.Параметры.УстановитьЗначениеПараметра("Абонент",		ТекАбонент);
	ЗадачиПИД.Параметры.УстановитьЗначениеПараметра("Организация",	ТекОрганизация);
	//ЗадачиПИД.Параметры.УстановитьЗначениеПараметра("Поставщик",	ТекПоставщик);

КонецПроцедуры

&НаКлиенте
Процедура СоздатьСобытие(ТипСобытия)
	СписокАбонентов = Новый Массив;
	Организация		= Неопределено;
	СоотАбонЗадач	= Новый Соответствие;
	                               
	Для каждого ТекСтрока Из Элементы.ДолжникиНов.ВыделенныеСтроки Цикл
		//ТекДанные = Элементы.Должники.ДанныеСтроки(ТекСтрока);
		ТекДанные = Элементы.ДолжникиНов.ДанныеСтроки(ТекСтрока);
		Если ТекДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;          
		
		ДобавлениеПодчиненныхЭлементов(ТекДанные, СписокАбонентов, СоотАбонЗадач);
		
		Если ЗначениеЗаполнено(ТекДанные.Организация) И Не ЗначениеЗаполнено(Организация) Тогда
			Организация = ТекДанные.Организация;		
		КонецЕсли;
		//НовСтрока = Новый Структура;
		//НовСтрока.Вставить("Абонент",   ТекДанные.Абонент);
		//НовСтрока.Вставить("Основание", ТекДанные.Задача);
		//СписокАбонентов.Добавить(НовСтрока);
	КонецЦикла;
	
	Если СписокАбонентов.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нет выделенных строк.");
		Возврат;
	КонецЕсли;
	
	ПарамФормы = Новый Структура;
	ПарамФормы.Вставить("ТипСобытия",  ТипСобытия);
	ПарамФормы.Вставить("Организация", Организация);
	ПарамФормы.Вставить("Абоненты",	   СписокАбонентов);
	
	ОткрытьФорму("Документ.энргСобытие.ФормаОбъекта", ПарамФормы, ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура ДобавлениеПодчиненныхЭлементов(Ветвь, СписокАбонентов, СоотАбонЗадач)
	Подветви = Ветвь.ПолучитьЭлементы();
	
	Если ЗначениеЗаполнено(Подветви) Тогда
		Для каждого Подветвь Из Подветви Цикл
			ДобавлениеПодчиненныхЭлементов(Подветвь, СписокАбонентов, СоотАбонЗадач);
		КонецЦикла;
	Иначе
		Ключ = ?(ТипЗнч(Ветвь.Задача) = Тип("ЗадачаСсылка.энргЗадачаПИД") И ЗначениеЗаполнено(Ветвь.Задача), Ветвь.Задача, Ветвь.Абонент);
		Если СоотАбонЗадач.Получить(Ключ) = Неопределено Тогда
			СоотАбонЗадач.Вставить(Ключ, Истина);
			
			НовСтрока = Новый Структура("Абонент, Основание", Ветвь.Абонент, Ветвь.Задача);
			СписокАбонентов.Добавить(НовСтрока);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура СоздатьЗапланированнуюОтправку(ИмяМакета, Этап, СоотДолжникЗадача)
	ДопПарам = Новый Структура("ИмяМакета, СоотДолжникЗадача", ИмяМакета, СоотДолжникЗадача);
	ОписОпов = Новый ОписаниеОповещения("СоздатьЗапланированнуюОтправкуПослеВыбораДаты", ЭтотОбъект, ДопПарам);
	ПоказатьВводДаты(ОписОпов, ТекущаяДата(), "Планируемая дата отправки", ЧастиДаты.Дата);
КонецПроцедуры

&НаКлиенте
Процедура СоздатьЗапланированнуюОтправкуПослеВыбораДаты(Дата, ДополнительныеПараметры) Экспорт
	
	ИмяМакета = ДополнительныеПараметры.ИмяМакета;
	СоотДолжникЗадача = ДополнительныеПараметры.СоотДолжникЗадача;
	
	Если (Дата <> Неопределено) Тогда 
		СписокАбонентов = Новый Массив;
		Организация		= Неопределено; 
		
		Для каждого ТекСтрока Из Элементы.Должники.ВыделенныеСтроки Цикл
			ТекДанные = Элементы.Должники.ДанныеСтроки(ТекСтрока);
			
			Если ТекДанные = Неопределено Или Не ЗначениеЗаполнено(ТекДанные.Абонент) Тогда
				Продолжить;
			КонецЕсли;
			
			ЗадачаСоот = СоотДолжникЗадача.Получить(ТекСтрока);
			Если ЗадачаСоот = "" Тогда
				Продолжить;
			КонецЕсли;
			Если ЗначениеЗаполнено(ТекДанные.Организация) И Не ЗначениеЗаполнено(Организация) Тогда
				Организация = ТекДанные.Организация;		
			КонецЕсли;
			
			Абонент = ТекДанные.Абонент;
			Основание = ?(ЗадачаСоот = Неопределено, ТекДанные.Задача, ЗадачаСоот);
			Если Не ЗначениеЗаполнено(Основание) Тогда
				Продолжить;
			КонецЕсли;
			
			НовСтрока = Новый Структура;
			НовСтрока.Вставить("Абонент",   ТекДанные.Абонент);
			НовСтрока.Вставить("Основание", Основание);
			СписокАбонентов.Добавить(НовСтрока);
		КонецЦикла;
		
		Если СписокАбонентов.Количество() = 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нет выделенных строк.");
			Возврат;
		КонецЕсли;
		
		ПарамФормы = Новый Структура;
		ПарамФормы.Вставить("ТипСобытия",				ПредопределенноеЗначение("Справочник.энргСпособСвязи.ОтправкаПисьмаНаЭлектроннуюПочту"));
		ПарамФормы.Вставить("Организация",				Организация);
		ПарамФормы.Вставить("Абоненты",					СписокАбонентов);
		ПарамФормы.Вставить("ПланируемаяДатаОтправки",	Дата);
		ПарамФормы.Вставить("МакетПечатнойФормы",		ИмяМакета);
		
		ОткрытьФорму("Документ.энргСобытие.ФормаОбъекта", ПарамФормы, ЭтаФорма);
	КонецЕсли;

	ОбновитьСписки();
КонецПроцедуры 

&НаКлиенте
Процедура ОбработкаОтветаНаСозданиеЗадач(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ИмяМакета = ДополнительныеПараметры.ИмяМакета;
	СоотДолжникЗадача = ДополнительныеПараметры.СоотДолжникЗадача;
	Этап = ДополнительныеПараметры.Этап;
	
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	ИначеЕсли Ответ = КодВозвратаДиалога.ОК Тогда 
		ЗапуститьЗадачу(Неопределено, Этап, СоотДолжникЗадача);
	КонецЕсли;
	СоздатьЗапланированнуюОтправку(ИмяМакета, Этап, СоотДолжникЗадача);
КонецПроцедуры

#КонецОбласти

#Область ДополнительныеФункцииНаСервере
&НаСервере
Процедура ПроверитьСоответствиеОтборов()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	|	энргСхемыПИДОрганизацийСрезПоследних.Организация КАК Организация,
	|	энргСхемыПИДОрганизацийСрезПоследних.Район КАК Район,
	|	энргСхемыПИДОрганизацийСрезПоследних.МКД КАК МКД,
	|	энргСхемыПИДОрганизацийСрезПоследних.Абонент КАК Абонент,
	|	энргСхемыПИДОрганизацийСрезПоследних.Услуга КАК Услуга
	|ИЗ
	|	РегистрСведений.энргСхемыПИДОрганизаций.СрезПоследних(&ТекДата, ) КАК энргСхемыПИДОрганизацийСрезПоследних
	|ГДЕ
	|	энргСхемыПИДОрганизацийСрезПоследних.Схема = &Схема";
	
	Запрос.УстановитьПараметр("Схема", Объект.Схема);
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		Если не Выборка.Район = Объект.Район Тогда 
			объект.Схема = Неопределено;
		КонецЕсли;
		Если не Выборка.Организация = Объект.Организация Тогда 
			объект.Схема = Неопределено;
		КонецЕсли;

		Если не Выборка.МКД = Объект.МКД Тогда 
			объект.Схема = Неопределено;
		КонецЕсли;
		Если не Выборка.Услуга = Объект.Услуга Тогда 
			объект.Схема = Неопределено;
		КонецЕсли;

		Если не Выборка.Абонент = Объект.Абонент Тогда 
			объект.Схема = Неопределено;
		КонецЕсли;

	КонецЦикла;
	

КонецПроцедуры

