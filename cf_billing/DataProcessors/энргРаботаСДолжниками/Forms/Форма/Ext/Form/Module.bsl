&НаКлиенте
Процедура ДолжникиНовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	Если ЗначениеЗаполнено(ВыбраннаяСтрока) Тогда
		ТекДанные = Элементы.ДолжникиНов.ДанныеСтроки(ВыбраннаяСтрока);
		Если (Поле = Элементы.ДолжникиНовЭтап Или Поле = Элементы.ДолжникиНовОтветственный 
				Или Поле = Элементы.ДолжникиНовКолДнейСледЭтапа Или Поле = Элементы.ДолжникиНовЗадача) 
					И ЗначениеЗаполнено(ТекДанные.Задача) И ЗначениеЗаполнено(ТекДанные.КоличествоЗадач < 2)Тогда
			ПарамФормы = Новый Структура("Ключ", ТекДанные.Задача);
			ОткрытьФорму("Задача.энргЗадачаПИД.ФормаОбъекта", ПарамФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		ИначеЕсли Поле = Элементы.ДолжникиНовАбонент Тогда 
			ПарамФормы = Новый Структура("Ключ", ТекДанные.Абонент);
			ОткрытьФорму("Справочник.энргАбоненты.ФормаОбъекта", ПарамФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

