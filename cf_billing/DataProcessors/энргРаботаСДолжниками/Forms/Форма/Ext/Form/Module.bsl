		ПарамФормы = Новый Структура("Ключ", ВыбраннаяСтрока);
		ОткрытьФорму("Задача.энргЗадачаПИД.ФормаОбъекта", ПарамФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗадачиМнеПриАктивизацииСтроки(Элемент)
	
	// Определение доступности кнопки "Объединить задачи"
	МожноОбъединить = Элементы.ЗадачиМне.ВыделенныеСтроки.Количество() > 1;
	
	Если МожноОбъединить Тогда
		ТекАбонент = Неопределено;
		Для каждого ТекСтрока Из Элементы.ЗадачиМне.ВыделенныеСтроки Цикл
			ТекДанные = Элементы.ЗадачиМне.ДанныеСтроки(ТекСтрока);

			Если ТекАбонент = Неопределено Тогда
			
				ТекАбонент = ТекДанные.Абонент;
			
			ИначеЕсли ТекАбонент <> ТекДанные.Абонент Тогда 
				МожноОбъединить = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Элементы.ЗадачиМнеОбъединитьЗадачи.Доступность = МожноОбъединить;
	
	ТекСтрока = Элементы.ЗадачиМне.ТекущиеДанные;
	Элементы.ЗадачиМнеНазначитьИсполнителя.Доступность = ?(ТекСтрока = Неопределено, Ложь, ТекСтрока.ЗадачаПодчиненным);
	
	ОтборПредЭтапы = ПредыдущиеЭтапы.КомпоновщикНастроек.Настройки.Отбор.Элементы;
	ПолеКомпановки = Новый ПолеКомпоновкиДанных("Ссылка.стартоваяЗадача");
	Для каждого ТекОтбор Из ОтборПредЭтапы Цикл
		Если ТекОтбор.ЛевоеЗначение = ПолеКомпановки Тогда
			Если ТекСтрока = Неопределено Тогда
				ТекОтбор.ПравоеЗначение = Неопределено;
			Иначе
				ТекОтбор.ПравоеЗначение = ТекСтрока.СтартоваяЗадача;
			КонецЕсли;
			
			Возврат;
		КонецЕсли;
	КонецЦикла;
	Элементы.ПредыдущиеЭтапы.Обновить();
КонецПроцедуры

#КонецОбласти

