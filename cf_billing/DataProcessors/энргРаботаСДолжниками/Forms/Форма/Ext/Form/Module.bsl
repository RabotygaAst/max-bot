&НаСервере
Процедура СоздатьЗадачиНаСервере(СписокСтрок, СоотДолжникЗадача = Неопределено)
		Исполнитель = Пользователи.ТекущийПользователь();
	Для каждого ТекСтрока Из СписокСтрок Цикл
		
		Должник = ТекСтрока.Абонент;
		ПараметрыОбъекта = Новый Структура("Абонент, МКД, Район, ЛицевойСчет, АдресОбъекта, Организация, Услуга", Должник);
		энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыАбонента(Должник, ПараметрыОбъекта);
		
		ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, ТекСтрока);
		ПараметрыОбъекта.Вставить("СуммаЗадолженности",			ТекСтрока.Задолженность);
		ПараметрыОбъекта.Вставить("ПериодНачисления",			Объект.Период);
		ПараметрыОбъекта.Вставить("Схема",						ТекСтрока.Схема);
		ПараметрыОбъекта.Вставить("Ссылка",						Неопределено);
		ПараметрыОбъекта.Вставить("Исполнитель",				Исполнитель);
		ПараметрыОбъекта.Вставить("ПериодНачисления",			ТекСтрока.ПериодНачисления);
		
		Отказ = Ложь;
		НовЗадача = Задачи.энргЗадачаПИД.СоздатьПодчиненнуюЗадачу(Отказ, ТекСтрока.Этап, ПараметрыОбъекта);
		Если ТипЗнч(СоотДолжникЗадача) = Тип("Соответствие") Тогда
			СоотДолжникЗадача.Вставить(ТекСтрока.ТекСтрока, НовЗадача);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьСхемыПоУмолчанию(СоотОргСхема)

	Организации = Новый Массив;
	Для каждого ТекОрг Из СоотОргСхема Цикл
		Организации.Добавить(ТекОрг.Ключ);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	энргСхемыПИДОрганизацийСрезПоследних.Организация КАК Организация,
		|	энргСхемыПИДОрганизацийСрезПоследних.Схема КАК Схема
		|ИЗ
		|	РегистрСведений.энргСхемыПИДОрганизаций.СрезПоследних(, Организация В (&Организации)) КАК энргСхемыПИДОрганизацийСрезПоследних";
	
	Запрос.УстановитьПараметр("Организации", Организации);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СоотОргСхема[Выборка.Организация] = Выборка.Схема;
	КонецЦикла;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьНачальныеЭтапыСхем(СоотСхемаЭтап)

	Схемы = Новый Массив;
	Для каждого ЭлемСоот Из СоотСхемаЭтап Цикл
		Схемы.Добавить(ЭлемСоот.Ключ);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСхемыПИДЭтапы.Этап КАК Этап,
		|	энргСхемыПИДЭтапы.Ссылка КАК Схема,
		|	энргСхемыПИДЭтапы.НомерСтроки КАК НомерСтроки,
		|	энргСхемыПИДЭтапы.Необязательный КАК Необязательный
		|ИЗ
		|	Справочник.энргСхемыПИД.Этапы КАК энргСхемыПИДЭтапы
		|ГДЕ
		|	энргСхемыПИДЭтапы.Ссылка В(&Схемы)
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|ИТОГИ ПО
		|	Схема";
	
	Запрос.УстановитьПараметр("Схемы", Схемы);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСхема = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСхема.Следующий() Цикл
		ПослЭтап = Ложь;
		Выборка  = ВыборкаСхема.Выбрать();
		
		СписокЭтапов  = Новый Массив;
	
		Пока Выборка.Следующий() Цикл
			ПослЭтап = Не Выборка.Необязательный;
			СписокЭтапов.Добавить(Выборка.Этап);
			
			Если ПослЭтап Тогда 
				Прервать;				
			КонецЕсли;
		КонецЦикла;
		
		Если СписокЭтапов.Количество() = 1 Тогда
			СоотСхемаЭтап[ВыборкаСхема.Схема] = СписокЭтапов[0];
		ИначеЕсли СписокЭтапов.Количество() = 0 Тогда
			СоотСхемаЭтап[ВыборкаСхема.Схема] = Неопределено;
		Иначе
			СоотСхемаЭтап[ВыборкаСхема.Схема] = СписокЭтапов;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

