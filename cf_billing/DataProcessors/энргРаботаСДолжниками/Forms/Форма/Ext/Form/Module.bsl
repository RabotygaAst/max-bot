&НаКлиенте
Процедура ЗапуститьЗадачу(Команда, Этап = Неопределено, СоотДолжникЗадача = Неопределено)
	
	СписокСтрок  = Новый Массив;
	СоотОргСхема = Новый Соответствие;
	МассивЗадач	 = Новый Массив;
	                               
	Для каждого ТекСтрока Из Элементы.ДолжникиНов.ВыделенныеСтроки Цикл
		ТекДанные = Элементы.ДолжникиНов.ДанныеСтроки(ТекСтрока);
		
		НовСтрока = Новый Структура("Организация, МКД, Район, Задолженность, Схема, Этап, Абонент, Услуга, ПериодНачисления");
		ЗаполнитьЗначенияСвойств(НовСтрока, ТекДанные);
		НовСтрока.Вставить("ТекСтрока", ТекСтрока);
		СписокСтрок.Добавить(НовСтрока);
		Если СоотОргСхема.Получить(НовСтрока.Организация) = Неопределено Тогда 
			СоотОргСхема.Вставить(НовСтрока.Организация, Объект.Схема);
		КонецЕсли;
	КонецЦикла;
	
	Если СписокСтрок.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Схема) Тогда
		ЗаполнитьСхемыПоУмолчанию(СоотОргСхема);
	КонецЕсли;
	
	СоотСхемаЭтап = Новый Соответствие;
	Для каждого ЭлемСоот Из СоотОргСхема Цикл
		Если СоотСхемаЭтап.Получить(ЭлемСоот.Значение) = Неопределено Тогда 
			СоотСхемаЭтап.Вставить(ЭлемСоот.Значение, Этап);
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(Этап) Тогда
		ЗаполнитьНачальныеЭтапыСхем(СоотСхемаЭтап);
	КонецЕсли;
	
	
	НачатьПИРНаСервере(СоотОргСхема, СоотСхемаЭтап);
	
	Элементы.ЗадачиПИД_ДосудебнаяРабота.Обновить();
	Элементы.ЗадачиПИД_СудебнаяРабота.Обновить();
	Элементы.ЗадачиПИД_ИсполнительнаяРабота.Обновить();
	

	//
	//СоздатьЗадачи(СписокСтрок, СоотОргСхема, СоотСхемаЭтап, Не ЗначениеЗаполнено(Этап), СоотДолжникЗадача);
КонецПроцедуры

// Начать пир новая процедура 

&НаСервере
Процедура НачатьПИРНаСервере(СоотОргСхема, СоотСхемаЭтап)
	ВыбранныеЭлементы = Элементы.ДолжникиНов.ВыделенныеСтроки;  //ДеревоДолжников.НайтиПоИдентификатору(17)
	
	СоотвествиеЗадачи = Новый Соответствие;
	
	
	Для каждого ИдСтроки Из ВыбранныеЭлементы Цикл
	
		Ветвь = ДолжникиНов.НайтиПоИдентификатору(ИдСтроки);
		
		ТекАбонент = Ветвь.Абонент;
	
		Если Не ЗначениеЗаполнено(ТекАбонент) Тогда
			Продолжить;
		КонецЕсли;

		ПарамЗадачи = СоотвествиеЗадачи.Получить(ТекАбонент);
		Должник = ТекАбонент;
		Если ПарамЗадачи = Неопределено Тогда
		
			ПарамЗадачи = Новый Структура("Абонент, Организация, Район, СуммаЗадолженности,ЛицевойСчет, АдресОбъекта,ПериодНачисления", Должник);
			
			энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыАбонента(Должник, ПарамЗадачи);
			ЗаполнитьЗначенияСвойств(ПарамЗадачи, Ветвь);
			ПарамЗадачи.Вставить("МКД", Ветвь.Дом);
						
			Задолженность = Новый ТаблицаЗначений;
			Задолженность.Колонки.Добавить("Услуга", 			Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
			Задолженность.Колонки.Добавить("ПериодНачисления", 	Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Дата)));
			Задолженность.Колонки.Добавить("Задолженность",		Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
			
			
			ПарамЗадачи.Вставить("Задолженность", Задолженность);
			СоотвествиеЗадачи.Вставить(ТекАбонент, ПарамЗадачи);
		КонецЕсли;
		
		ЗаполнитьЗадолженностьЗадачи(Ветвь, ПарамЗадачи);
	КонецЦикла;
	
	Для каждого ПарамЗадачи Из СоотвествиеЗадачи Цикл
	
		ПарамТекЗадачи = ПарамЗадачи.Значение;
		
		НовЗадача = Задачи.энргЗадачаПИД.СоздатьЗадачу();
		НовЗадача.Схема = Объект.Схема;
		НовЗадача.Дата = ТекущаяДата();
		ЗаполнитьЗначенияСвойств(НовЗадача, ПарамТекЗадачи); 
	    СуммаЗадолженности = 0;
		Для каждого СтрокаЗадол Из ПарамТекЗадачи.Задолженность Цикл
			СтрокаТЧ = НовЗадача.Задолженность.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаЗадол);
		    СуммаЗадолженности = СуммаЗадолженности + СтрокаЗадол.Задолженность;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(НовЗадача.Задолженность) Тогда
		
			НовЗадача.СуммаЗадолженности = СуммаЗадолженности;
			
			Задачи.энргЗадачаПИД.ЗаполнитьНаименованиеИЭтап(НовЗадача);
			Попытка
				НовЗадача.Записать();
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось создать задачу для абонента " + ПарамЗадачи.Ключ);
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
	ЗаполнитьДерево();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗадолженностьЗадачи(Ветвь, ПарамЗадачи)

	Подветви = Ветвь.ПолучитьЭлементы();
	
	Если Подветви.Количество() = 0 Тогда
		Если ЗначениеЗаполнено(Ветвь.Задача) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У абонента " + Ветвь.Абонент + " по за период " + Формат(Ветвь.ПериодНачисления, "ДФ='MMMM гггг'") + " по услуге " + Ветвь.Услуга + " уже начат ПИР ");
		Иначе
			Задолженность = ПарамЗадачи.Задолженность;
			
			ПарамЗадолженности = Новый Структура("Услуга, ПериодНачисления");
			ЗаполнитьЗначенияСвойств(ПарамЗадолженности, Ветвь);
			ЗаписиТЗ = Задолженность.НайтиСтроки(ПарамЗадолженности);
			Если Не ЗначениеЗаполнено(ЗаписиТЗ) Тогда
				СтрокаТЗ = Задолженность.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЗ, Ветвь);
			КонецЕсли;
		КонецЕсли;
	Иначе
		Для каждого Подветвь Из Подветви Цикл
			ЗаполнитьЗадолженностьЗадачи(Подветвь, ПарамЗадачи);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписки()
	
	//Элементы.ДолжникиНов.Обновить();
	Элементы.ЗадачиПИД_ДосудебнаяРабота.Обновить();
	Элементы.ЗадачиПИД_ИсполнительнаяРабота.Обновить();
	Элементы.ЗадачиПИД_СудебнаяРабота.Обновить();
	Элементы.ЗадачиМне.Обновить();
	Элементы.ЗадачиМнеОРП.Обновить();
	Элементы.ПредыдущиеЭтапы.Обновить();
	Элементы.ПеренапраленныеЗадачи.Обновить();
	//ОбновитьДанные(Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыделитьВсех(Команда)
	Элементы.ДолжникиНов.ВыделенныеСтроки.Очистить();
	
	Для каждого ТекСтрока Из ДолжникиНов.ПолучитьЭлементы() Цикл
		Элементы.ДолжникиНов.ВыделенныеСтроки.Добавить(ТекСтрока.ПолучитьИдентификатор());  
	КонецЦикла;
