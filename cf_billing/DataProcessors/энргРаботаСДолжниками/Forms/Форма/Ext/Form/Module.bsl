#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Объект.Период = ТекущаяДатаСеанса();
	УстановитьОтборыДляДолжников();
	ОбновитьДокументыКСогласованиюНаСервере();
	ПринятоВРаботу = Ложь;
	
	ЗадачиМне.Параметры.УстановитьЗначениеПараметра("ТекДата", 			 КонецДня(Объект.Период));
	ЗадачиМне.Параметры.УстановитьЗначениеПараметра("ТекПользователь", 	 ПараметрыСеанса.ТекущийПользователь);
	ЗадачиМне.Параметры.УстановитьЗначениеПараметра("ЗадачиПодчиненных", ЗадачиПодчиненных);
	
	ЗадачиМнеОРП.Параметры.УстановитьЗначениеПараметра("ТекДата", 			 КонецДня(Объект.Период));
	ЗадачиМнеОРП.Параметры.УстановитьЗначениеПараметра("ТекПользователь", 	 ПараметрыСеанса.ТекущийПользователь);
	ЗадачиМнеОРП.Параметры.УстановитьЗначениеПараметра("ЗадачиПодчиненных",  Истина);

	ПеренапраленныеЗадачи.Параметры.УстановитьЗначениеПараметра("НовыйИсполнитель", Исполнитель);	
	ПеренапраленныеЗадачи.Параметры.УстановитьЗначениеПараметра("ПланируемаяДатаВыполнения", Объект.Период);
	ПеренапраленныеЗадачи.Параметры.УстановитьЗначениеПараметра("ТекДата", НачалоДня(Объект.Период));

	Элементы.ДолжникиОтправитьСМС.Видимость = ОтправкаSMS.ДоступнаОтправкаSMS(); 
	
	// Создание команд планировния отправки ЭП
	СпрЭтаповПИД  = Справочники.энргВидыОперацийПИД;
	СписокМакетов = СпрЭтаповПИД.ПолучитьСписокМакетовПечати();
	
	Для каждого ТекМакет Из СписокМакетов Цикл
		Префикс	 = "ПФ_MXL_";
		ИмяЭтапа = СтрЗаменить(ТекМакет.Значение, Префикс, "ЭтапПретензионноИсковойДеятельности_");
		ИмяКмд	 = СтрЗаменить(ТекМакет.Значение, Префикс, "КомандаЭтап_");
		Этап	 = СпрЭтаповПИД[ИмяЭтапа];
		
		// Добавление команды
		Кмд			  = ЭтаФорма.Команды.Добавить(ИмяКмд);
		Кмд.Действие  = "ЗапланироватьОтправку";
		Кмд.Заголовок = Строка(Этап);
		
		// Добавление новой кнопки
		ЭлементКМД			   = Элементы.Добавить(ИмяКмд, Тип("КнопкаФормы"), Элементы.ГрппаКнопкОтправкиЭП);
		ЭлементКМД.Вид		   = ВидКнопкиФормы.ОбычнаяКнопка;
		ЭлементКМД.ИмяКоманды  = ИмяКмд;
		ЭлементКМД.Картинка	   = БиблиотекаКартинок.ОтправитьЭлектронноеПисьмо;
		ЭлементКМД.Отображение = ОтображениеКнопки.КартинкаИТекст
	КонецЦикла;
	
	// ++ Акимов Д.В.
	// Настройка доступности в зависимости от прав
	энргОбщегоНазначения.УстановитьДоступностьЭлементовПоРолям(ЭтаФорма, Новый Структура("ДолжникиЗапуститьЗадачу"), Метаданные.Задачи.энргЗадачаПИД);
	
	ИменаКомандНаФорме = Новый Структура("ДолжникиОтправитьСМС");
	Для каждого ТекЭлемент Из Элементы.ГрппаКнопкОтправкиЭП.ПодчиненныеЭлементы Цикл
		ИменаКомандНаФорме.Вставить(ТекЭлемент.Имя);
	КонецЦикла;
	энргОбщегоНазначения.УстановитьДоступностьЭлементовПоРолям(ЭтаФорма, ИменаКомандНаФорме, Метаданные.Документы.энргСобытие);
	// -- Акимов Д.В.
КонецПроцедуры

