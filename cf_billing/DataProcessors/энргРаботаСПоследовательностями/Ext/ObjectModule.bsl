		Текст 				= СтрЗаменить(Текст,"И (энргМаксимальныеПоказанияСрез.Строение = &Строение)","");
		Текст				= СтрЗаменить(Текст,"И (энргМаксимальныеПоказанияСрез.Помещение = &Помещение)","");
