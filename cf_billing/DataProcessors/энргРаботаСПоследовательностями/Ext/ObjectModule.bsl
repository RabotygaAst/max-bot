#Область СреднийОбъемПотребленияМКД

Функция РезультатаЗапросаСреднегоПотребленияМКД(Организация,ПериодНачисления,Район)
	
	ГраницыПериода  								= Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления);
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	МВТ  											= Новый МенеджерВременныхТаблиц;
	
	Запрос  			= Новый Запрос;
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	//Запрос.УстановитьПараметр("МКД",				МКД);
	Запрос.МенеджерВременныхТаблиц  				= МВТ;
	Текст 											= ТекстЗапросаСреднийОбъемМКД();
	
	//Если МКД = Неопределено Тогда
	//	Текст 										= СтрЗаменить(Текст, "И (СтабильныеПериоды.МКД = &МКД)","");
	//	Текст 										= СтрЗаменить(Текст, "И СтабильныеПериоды.МКД = &МКД","");
	//	Текст 										= СтрЗаменить(Текст, "И (РасчетСреднегоОбъема.МКД = &МКД)","");
	//	Текст 										= СтрЗаменить(Текст, "И РасчетСреднегоОбъема.МКД = &МКД","");					
	//КонецЕсли;	
	
	Запрос.Текст 		= Текст;
	Запрос.Выполнить();
	
	Текст 								= "ВЫБРАТЬ * ИЗ ПериодыПолученияСезонности КАК ПериодыПолученияСезонности";
	Запрос 								= Новый Запрос(Текст);
	Запрос.МенеджерВременныхТаблиц 		= МВТ;
	РезультатПериодыПолученияСезонности = Запрос.Выполнить();
	Выборка 							= РезультатПериодыПолученияСезонности.Выбрать();
	Если Выборка.Следующий() Тогда
		ТекстГраницОтчетногоПериода 	= энргНачисления.ТекстГраницОтчетногоПериода(Выборка.ПериодНачисленияНачало,Выборка.ПериодНачисленияКонец,Ложь);
	КонецЕсли;
	
	Текст 								= "ВЫБРАТЬ * ПОМЕСТИТЬ ТаблицаПериодов  ИЗ (" + ТекстГраницОтчетногоПериода + ") КАК ВложенныйЗапрос";
	Если НЕ ПустаяСтрока(ТекстГраницОтчетногоПериода) Тогда
		Схема 								= Новый СхемаЗапроса;
		Пакет 								= Схема.ПакетЗапросов[0];
		Пакет.УстановитьТекстЗапроса(Текст);
		//Пакет.Операторы[0].ВыбираемыеПоля.Добавить("&Район");
		//Колонка  							= Пакет.Колонки[Пакет.Колонки.Количество()-1];
		//Колонка.Псевдоним 					= "Район";
		СоотвествиеПолей 					= Новый Структура("Организация,Район","Организация","Район");
		
		Параметры 							= Новый Структура;
		ПараметрыВТ 						= Новый Массив;
		ПараметрыВТ.Добавить(Новый Структура());
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", СоотвествиеПолей));
		
		РегистрыСведений.энргДлительностиПериодов.ПериодыСезонностиКоллекцияПериодов(Схема,Параметры,"ТаблицаПериодов", "ПериодыСезонности");		
	Иначе		
		РегистрыСведений.энргДлительностиПериодов.ПериодыСезонностиПустаяТаблица(Схема,Параметры,"ПериодыСезонности");				
	КонецЕсли;
	
	Запрос 								= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.МенеджерВременныхТаблиц 		= МВТ;
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.Выполнить(); 
	
	Текст = 
	"ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВложенныйЗапрос.ЭтоОбъемПотребленный) КАК КоличествоРасчитанныхОбъемов,
	|	МАКСИМУМ(ВложенныйЗапрос.ЭтоОбъемПотребленный) КАК ЭтоОбъемПотребленный,
	|	ВЫБОР
	|		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВложенныйЗапрос.ЭтоОбъемПотребленный) = 1
	|				И МАКСИМУМ(ВложенныйЗапрос.ЭтоОбъемПотребленный)
	|			ТОГДА СУММА(ВложенныйЗапрос.ОбъемПотребленный)
	|		КОГДА НЕ КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВложенныйЗапрос.ЭтоОбъемПотребленный) = 1
	|			ТОГДА СУММА(ВложенныйЗапрос.ОбъемПотребленный)
	|		ИНАЧЕ -1
	|	КОНЕЦ КАК ОбъемПотребленный,
	|	ВЫБОР
	|		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВложенныйЗапрос.ЭтоОбъемПотребленный) = 1
	|				И НЕ МАКСИМУМ(ВложенныйЗапрос.ЭтоОбъемПотребленный)
	|			ТОГДА СУММА(ВложенныйЗапрос.Объем)
	|		КОГДА НЕ КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВложенныйЗапрос.ЭтоОбъемПотребленный) = 1
	|			ТОГДА СУММА(ВложенныйЗапрос.Объем)
	|		ИНАЧЕ -1
	|	КОНЕЦ КАК Объем,
	|	МАКСИМУМ(ВложенныйЗапрос.КоличествоМесяцевПотребленный) КАК КоличествоМесяцевПотребленный,
	|	МАКСИМУМ(ВложенныйЗапрос.КоличествоМесяцев) КАК КоличествоМесяцев,
	|	МАКСИМУМ(ВложенныйЗапрос.СуммарныйОбъемПотребленный) КАК СуммарныйОбъемПотребленный,
	|	МАКСИМУМ(ВложенныйЗапрос.СуммарныйОбъем) КАК СуммарныйОбъем,
	|	МАКСИМУМ(ВложенныйЗапрос.КоличествоМесяцевСезонности) КАК КоличествоМесяцевСезонности,
	|	МАКСИМУМ(ВложенныйЗапрос.КоличествоМесяцевСезонностиПотребленный) КАК КоличествоМесяцевСезонностиПотребленный
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.Район КАК Район,
	|		ВложенныйЗапрос.МКД КАК МКД,
	|		ВложенныйЗапрос.Услуга КАК Услуга,
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		ВложенныйЗапрос.Шкала КАК Шкала,
	|		ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|		ВложенныйЗапрос.ЭтоОбъемПотребленный КАК ЭтоОбъемПотребленный,
	|		ВложенныйЗапрос.СуммарныйОбъемПотребленный КАК СуммарныйОбъемПотребленный,
	|		ВложенныйЗапрос.СуммарныйОбъем КАК СуммарныйОбъем,
	|		ВЫБОР
	|			КОГДА ВЫБОР
	|					КОГДА НЕ ВложенныйЗапрос.Сезонность = ЗНАЧЕНИЕ(Справочник.энргВидыСезонности.ПУстаяСсылка)
	|						ТОГДА СУММА(ЕСТЬNULL(ПериодыСезонности.КоличествоМесяцевСезонности, 0))
	|					ИНАЧЕ ВложенныйЗапрос.КоличествоМесяцев
	|				КОНЕЦ = 0
	|				ТОГДА 0
	|			ИНАЧЕ ВложенныйЗапрос.СуммарныйОбъемПотребленный / ВЫБОР
	|					КОГДА НЕ ВложенныйЗапрос.Сезонность = ЗНАЧЕНИЕ(Справочник.энргВидыСезонности.ПУстаяСсылка)
	|						ТОГДА СУММА(ЕСТЬNULL(ПериодыСезонности.КоличествоМесяцевСезонности, 0))
	|					ИНАЧЕ ВложенныйЗапрос.КоличествоМесяцев
	|				КОНЕЦ
	|		КОНЕЦ КАК ОбъемПотребленный,
	|		ВЫБОР
	|			КОГДА ВЫБОР
	|					КОГДА НЕ ВложенныйЗапрос.Сезонность = ЗНАЧЕНИЕ(Справочник.энргВидыСезонности.ПУстаяСсылка)
	|						ТОГДА СУММА(ЕСТЬNULL(ПериодыСезонности.КоличествоМесяцевСезонности, 0))
	|					ИНАЧЕ ВложенныйЗапрос.КоличествоМесяцев
	|				КОНЕЦ = 0
	|				ТОГДА 0
	|			ИНАЧЕ ВложенныйЗапрос.СуммарныйОбъем / ВЫБОР
	|					КОГДА НЕ ВложенныйЗапрос.Сезонность = ЗНАЧЕНИЕ(Справочник.энргВидыСезонности.ПУстаяСсылка)
	|						ТОГДА СУММА(ЕСТЬNULL(ПериодыСезонности.КоличествоМесяцевСезонности, 0))
	|					ИНАЧЕ ВложенныйЗапрос.КоличествоМесяцев
	|				КОНЕЦ
	|		КОНЕЦ КАК Объем,
	|		ВЫБОР
	|			КОГДА ВложенныйЗапрос.ЭтоОбъемПотребленный
	|				ТОГДА ВложенныйЗапрос.КоличествоМесяцев
	|			ИНАЧЕ 0
	|		КОНЕЦ КАК КоличествоМесяцевПотребленный,
	|		ВЫБОР
	|			КОГДА НЕ ВложенныйЗапрос.ЭтоОбъемПотребленный
	|				ТОГДА ВложенныйЗапрос.КоличествоМесяцев
	|			ИНАЧЕ 0
	|		КОНЕЦ КАК КоличествоМесяцев,
	|		ВЫБОР
	|			КОГДА ВложенныйЗапрос.ЭтоОбъемПотребленный
	|				ТОГДА СУММА(ЕСТЬNULL(ПериодыСезонности.КоличествоМесяцевСезонности, 0))
	|			ИНАЧЕ 0
	|		КОНЕЦ КАК КоличествоМесяцевСезонностиПотребленный,
	|		ВЫБОР
	|			КОГДА НЕ ВложенныйЗапрос.ЭтоОбъемПотребленный
	|				ТОГДА СУММА(ЕСТЬNULL(ПериодыСезонности.КоличествоМесяцевСезонности, 0))
	|			ИНАЧЕ 0
	|		КОНЕЦ КАК КоличествоМесяцевСезонности
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ПериодыРасчетаСреднего.Организация КАК Организация,
	|			ПериодыРасчетаСреднего.Район КАК Район,
	|			ПериодыРасчетаСреднего.МКД КАК МКД,
	|			ПериодыРасчетаСреднего.Услуга КАК Услуга,
	|			ПериодыРасчетаСреднего.ТочкаУчета КАК ТочкаУчета,
	|			ПериодыРасчетаСреднего.Шкала КАК Шкала,
	|			ПериодыРасчетаСреднего.КоличествоМесяцев КАК КоличествоМесяцев,
	|			ПериодыРасчетаСреднего.ТарифнаяЗона КАК ТарифнаяЗона,
	|			ПериодыРасчетаСреднего.НачалоПериода КАК НачалоПериода,
	|			ПериодыРасчетаСреднего.КонецПериода КАК КонецПериода,
	|			ПериодыРасчетаСреднего.Сезонность КАК Сезонность,
	|			ПериодыРасчетаСреднего.ЭтоОбъемПотребленный КАК ЭтоОбъемПотребленный,
	|			ВЫБОР
	|				КОГДА ПериодыРасчетаСреднего.ЭтоОбъемПотребленный
	|					ТОГДА СУММА(РасчетСреднегоОбъема.ОбъемУслуги)
	|				ИНАЧЕ 0
	|			КОНЕЦ КАК СуммарныйОбъемПотребленный,
	|			ВЫБОР
	|				КОГДА НЕ ПериодыРасчетаСреднего.ЭтоОбъемПотребленный
	|					ТОГДА СУММА(РасчетСреднегоОбъема.ОбъемУслуги)
	|				ИНАЧЕ 0
	|			КОНЕЦ КАК СуммарныйОбъем
	|		ИЗ
	|			ПериодыРасчетаСреднего КАК ПериодыРасчетаСреднего
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргРасчетСреднегоОбъемаМКД КАК РасчетСреднегоОбъема
	|				ПО ПериодыРасчетаСреднего.Район = РасчетСреднегоОбъема.Район
	|					И ПериодыРасчетаСреднего.МКД = РасчетСреднегоОбъема.МКД
	|					И ПериодыРасчетаСреднего.ТочкаУчета = РасчетСреднегоОбъема.ТочкаУчета
	|					И ПериодыРасчетаСреднего.Шкала = РасчетСреднегоОбъема.Шкала
	|					И ПериодыРасчетаСреднего.ТарифнаяЗона = РасчетСреднегоОбъема.ТарифнаяЗона
	|					И (РасчетСреднегоОбъема.ПериодНачисления МЕЖДУ ПериодыРасчетаСреднего.НачалоПериода И ПериодыРасчетаСреднего.КонецПериода)
	|					И (РасчетСреднегоОбъема.Организация = &Организация)
	|					И (РасчетСреднегоОбъема.Район = &Район)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ПериодыРасчетаСреднего.Организация,
	|			ПериодыРасчетаСреднего.Район,
	|			ПериодыРасчетаСреднего.МКД,
	|			ПериодыРасчетаСреднего.Услуга,
	|			ПериодыРасчетаСреднего.ТочкаУчета,
	|			ПериодыРасчетаСреднего.Шкала,
	|			ПериодыРасчетаСреднего.КоличествоМесяцев,
	|			ПериодыРасчетаСреднего.ТарифнаяЗона,
	|			ПериодыРасчетаСреднего.ЭтоОбъемПотребленный,
	|			ПериодыРасчетаСреднего.НачалоПериода,
	|			ПериодыРасчетаСреднего.КонецПериода,
	|			ПериодыРасчетаСреднего.Сезонность) КАК ВложенныйЗапрос
	|			ЛЕВОЕ СОЕДИНЕНИЕ ПериодыСезонности КАК ПериодыСезонности
	|			ПО ВложенныйЗапрос.Организация = ПериодыСезонности.Организация
	|				И ВложенныйЗапрос.Район = ПериодыСезонности.Район
	|				И ВложенныйЗапрос.Сезонность = ПериодыСезонности.Сезонность
	|				И (ПериодыСезонности.ПериодНачисления МЕЖДУ ВложенныйЗапрос.НачалоПериода И ВложенныйЗапрос.КонецПериода)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ВложенныйЗапрос.Район,
	|		ВложенныйЗапрос.МКД,
	|		ВложенныйЗапрос.Услуга,
	|		ВложенныйЗапрос.ТочкаУчета,
	|		ВложенныйЗапрос.Шкала,
	|		ВложенныйЗапрос.СуммарныйОбъемПотребленный,
	|		ВложенныйЗапрос.СуммарныйОбъем,
	|		ВложенныйЗапрос.КоличествоМесяцев,
	|		ВложенныйЗапрос.ЭтоОбъемПотребленный,
	|		ВложенныйЗапрос.ТарифнаяЗона,
	|		ВложенныйЗапрос.Сезонность) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Район,
	|	ВложенныйЗапрос.МКД,
	|	ВложенныйЗапрос.Услуга,
	|	ВложенныйЗапрос.ТочкаУчета,
	|	ВложенныйЗапрос.Шкала,
	|	ВложенныйЗапрос.ТарифнаяЗона";
	
	Запрос 								= Новый Запрос();
	//Если МКД = Неопределено Тогда
	//	Текст 							= СтрЗаменить(Текст, "И (РасчетСреднегоОбъема.МКД = &МКД)","");
	//	Текст 							= СтрЗаменить(Текст, "И РасчетСреднегоОбъема.МКД = &МКД","");
	//КонецЕсли;
	
	Запрос.Текст 						= Текст;
	Запрос.МенеджерВременныхТаблиц 		= МВТ;
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	//Запрос.УстановитьПараметр("МКД",				МКД);
	результат 							= Запрос.Выполнить();
	
	Возврат результат;
	
КонецФункции

Функция ТекстЗапросаСреднийОбъемМКД()
	
	текст  = 
	"ВЫБРАТЬ
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.Организация КАК Организация,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.Услуга КАК Услуга,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.КоличествоПоказаний КАК КоличествоПоказаний,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.КоличествоПериодов КАК КоличествоПериодов,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.ЗаПрошлыйГод КАК ЗаПрошлыйГод,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.ПоВсемНачислениям КАК ПоВсемНачислениям,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.НачислятьСреднийОбъемНеБолееМесяцев КАК НачислятьСреднийОбъемНеБолееМесяцев,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.ЗаПрошлыйГодОбъемПотребленный КАК ЗаПрошлыйГодОбъемПотребленный,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.КоличествоПериодовОбъемПотребленный КАК КоличествоПериодовОбъемПотребленный,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.КоличествоПоказанийОбъемПотребленный КАК КоличествоПоказанийОбъемПотребленный,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.НачислятьСреднийОбъемНеБолееМесяцевОбъемПотребленный КАК НачислятьСреднийОбъемНеБолееМесяцевОбъемПотребленный,
	|	энргНастройкиРасчетаСреднегоПотребленияСрезПоследних.ПоВсемНачислениямОбъемПотребленный КАК ПоВсемНачислениямОбъемПотребленный
	|ПОМЕСТИТЬ НастройкиРасчетаСреднегоПотребления
	|ИЗ
	|	РегистрСведений.энргНастройкиРасчетаСреднегоПотребления.СрезПоследних(
	|			&ПериодНачисления,
	|			Организация = &Организация
	|				И Район = &Район) КАК энргНастройкиРасчетаСреднегоПотребленияСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСпособыРасчетаПоНаправлениямСрезПоследних.Организация КАК Организация,
	|	энргСпособыРасчетаПоНаправлениямСрезПоследних.Район КАК Район,
	|	энргСпособыРасчетаПоНаправлениямСрезПоследних.Услуга КАК Услуга,
	|	энргСпособыРасчетаПоНаправлениямСрезПоследних.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	энргСпособыРасчетаПоНаправлениямСрезПоследних.ВидПлощади КАК ВидПлощади,
	|	энргСпособыРасчетаПоНаправлениямСрезПоследних.Сезонность КАК Сезонность
	|ПОМЕСТИТЬ СпособыРасчетаПоНаправлениям
	|ИЗ
	|	РегистрСведений.энргСпособыРасчетаПоНаправлениям.СрезПоследних(
	|			&ПериодНачисления,
	|			Организация = &Организация
	|				И Район = &Район) КАК энргСпособыРасчетаПоНаправлениямСрезПоследних
	|ГДЕ
	|	НЕ энргСпособыРасчетаПоНаправлениямСрезПоследних.Сезонность = ЗНАЧЕНИЕ(Справочник.энргВидыСезонности.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ВложенныйЗапрос.КоличествоПредоставленных КАК КоличествоПредоставленных,
	|	ВложенныйЗапрос.СрокНеПредоставления КАК СрокНеПредоставления,
	|	ВложенныйЗапрос.КонецПериода КАК КонецПериода,
	|	ВложенныйЗапрос.КоличествоПоказаний КАК КоличествоПоказаний,
	|	ВложенныйЗапрос.КоличествоПериодов КАК КоличествоПериодов,
	|	ВложенныйЗапрос.ЗаПрошлыйГод КАК ЗаПрошлыйГод,
	|	ВложенныйЗапрос.НачислятьСреднийОбъемНеБолееМесяцев КАК НачислятьСреднийОбъемНеБолееМесяцев,
	|	ВложенныйЗапрос.ЭтоОбъемПотребленный КАК ЭтоОбъемПотребленный,
	|	ВложенныйЗапрос.ДатаСостоянияПрибора КАК ДатаСостоянияПрибора,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ЕСТЬNULL(СпособыРасчетаПоНаправлениям.Сезонность, ЗНАЧЕНИЕ(Справочник.энргВидыСезонности.ПустаяСсылка)) КАК Сезонность
	|ПОМЕСТИТЬ ТочкиДляРасчета
	|ИЗ
	|	(ВЫБРАТЬ
	|		РасчетСреднегоОбъема.Район КАК Район,
	|		РасчетСреднегоОбъема.МКД КАК МКД,
	|		РасчетСреднегоОбъема.ТочкаУчета КАК ТочкаУчета,
	|		СтабильныеПериоды.Услуга КАК Услуга,
	|		РасчетСреднегоОбъема.Шкала КАК Шкала,
	|		РасчетСреднегоОбъема.ТарифнаяЗона КАК ТарифнаяЗона,
	|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ НАЧАЛОПЕРИОДА(РасчетСреднегоОбъема.ПериодНачисления, МЕСЯЦ)) КАК КоличествоПредоставленных,
	|		РАЗНОСТЬДАТ(МАКСИМУМ(РасчетСреднегоОбъема.ПериодНачисления), &ПериодНачисления, МЕСЯЦ) КАК СрокНеПредоставления,
	|		МАКСИМУМ(РасчетСреднегоОбъема.ПериодНачисления) КАК КонецПериода,
	|		МАКСИМУМ(СтабильныеПериоды.КоличествоПоказаний) КАК КоличествоПоказаний,
	|		МАКСИМУМ(СтабильныеПериоды.КоличествоПериодов) КАК КоличествоПериодов,
	|		МАКСИМУМ(СтабильныеПериоды.ЗаПрошлыйГод) КАК ЗаПрошлыйГод,
	|		МАКСИМУМ(СтабильныеПериоды.НачислятьСреднийОбъемНеБолееМесяцев) КАК НачислятьСреднийОбъемНеБолееМесяцев,
	|		ЛОЖЬ КАК ЭтоОбъемПотребленный,
	|		СтабильныеПериоды.ДатаСостоянияПрибора КАК ДатаСостоянияПрибора,
	|		СтабильныеПериоды.Организация КАК Организация
	|	ИЗ
	|		(ВЫБРАТЬ РАЗЛИЧНЫЕ
