	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргРасчетСреднегоОбъемаМКД КАК РасчетСреднегоОбъема
	|					ПО ТочкиДляРасчета.Район = РасчетСреднегоОбъема.Район
	|						И ТочкиДляРасчета.МКД = РасчетСреднегоОбъема.МКД
	|						И ТочкиДляРасчета.ТочкаУчета = РасчетСреднегоОбъема.ТочкаУчета
	|						И ТочкиДляРасчета.Шкала = РасчетСреднегоОбъема.Шкала
	|						И ТочкиДляРасчета.ТарифнаяЗона = РасчетСреднегоОбъема.ТарифнаяЗона
	|						И (РасчетСреднегоОбъема.ПериодНачисления <= ДОБАВИТЬКДАТЕ(ТочкиДляРасчета.КонецПериода, МЕСЯЦ, -ТочкиДляРасчета.КоличествоПериодов + 1))
	|						И (РасчетСреднегоОбъема.Организация = &Организация)
	|						И (РасчетСреднегоОбъема.Район = &Район)
	//|						И (РасчетСреднегоОбъема.МКД = &МКД)
	|						И (НЕ ТочкиДляРасчета.ЗаПрошлыйГод)
	|			
	|			СГРУППИРОВАТЬ ПО
	|				ТочкиДляРасчета.Район,
	|				ТочкиДляРасчета.МКД,
	|				ТочкиДляРасчета.Услуга,
	|				ТочкиДляРасчета.ТочкаУчета,
	|				ТочкиДляРасчета.Шкала,
	|				ТочкиДляРасчета.ТарифнаяЗона,
	|				ТочкиДляРасчета.КонецПериода,
	|				ТочкиДляРасчета.ЭтоОбъемПотребленный,
	|				ТочкиДляРасчета.Организация,
	|				ТочкиДляРасчета.КоличествоПоказаний,
	|				ТочкиДляРасчета.Сезонность) КАК ВложенныйЗапрос
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ВложенныйЗапрос.КонецПериода,
	|			ВложенныйЗапрос.ЭтоОбъемПотребленный,
	|			ВложенныйЗапрос.Район,
	|			ВложенныйЗапрос.МКД,
	|			ВложенныйЗапрос.Услуга,
	|			ВложенныйЗапрос.ТочкаУчета,
	|			ВложенныйЗапрос.Шкала,
	|			ВложенныйЗапрос.ТарифнаяЗона,
	|			ВложенныйЗапрос.Организация,
	|			ВложенныйЗапрос.КоличествоПоказаний,
	|			ВложенныйЗапрос.Сезонность) КАК ВложенныйЗапрос
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ВложенныйЗапрос.Район,
	|		ВложенныйЗапрос.МКД,
	|		ВложенныйЗапрос.Услуга,
	|		ВложенныйЗапрос.ТочкаУчета,
	|		ВложенныйЗапрос.Шкала,
	|		ВложенныйЗапрос.ТарифнаяЗона,
	|		ВложенныйЗапрос.КонецПериода,
	|		ВложенныйЗапрос.ЭтоОбъемПотребленный,
	|		ВложенныйЗапрос.Организация,
	|		ВложенныйЗапрос.КоличествоПоказаний,
	|		ВложенныйЗапрос.Сезонность
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ТочкиДляРасчета.Район,
	|		ТочкиДляРасчета.МКД,
	|		ТочкиДляРасчета.Услуга,
	|		ТочкиДляРасчета.ТочкаУчета,
	|		ТочкиДляРасчета.Шкала,
	|		ТочкиДляРасчета.ТарифнаяЗона,
	|		ТочкиДляРасчета.КонецПериода,
	|		ТочкиДляРасчета.ЭтоОбъемПотребленный,
	|		ТочкиДляРасчета.ДатаСостоянияПрибора,
	|		ТочкиДляРасчета.Организация,
	|		ТочкиДляРасчета.КоличествоПоказаний,
	|		ТочкиДляРасчета.Сезонность
	|	ИЗ
	|		ТочкиДляРасчета КАК ТочкиДляРасчета) КАК ВложенныйЗапрос
	|ГДЕ
	|	РАЗНОСТЬДАТ(ВложенныйЗапрос.НачалоПериода, ВложенныйЗапрос.КонецПериода, МЕСЯЦ) + 1 >= ВложенныйЗапрос.КоличествоПоказаний
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Район,
	|	ВложенныйЗапрос.МКД,
	|	ВложенныйЗапрос.Услуга,
	|	ВложенныйЗапрос.ТочкаУчета,
	|	ВложенныйЗапрос.Шкала,
	|	ВложенныйЗапрос.ТарифнаяЗона,
	|	ВложенныйЗапрос.КонецПериода,
	|	ВложенныйЗапрос.ЭтоОбъемПотребленный,
	|	ВложенныйЗапрос.Организация,
	|	ВложенныйЗапрос.Сезонность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	ПериодыРасчетаСреднего.Район КАК Район,
	|	МИНИМУМ(ПериодыРасчетаСреднего.НачалоПериода) КАК ПериодНачисленияНачало,
	|	МАКСИМУМ(ПериодыРасчетаСреднего.КонецПериода) КАК ПериодНачисленияКонец
	|ПОМЕСТИТЬ ПериодыПолученияСезонности
	|ИЗ
	|	ПериодыРасчетаСреднего КАК ПериодыРасчетаСреднего
	|
	|СГРУППИРОВАТЬ ПО
	|	ПериодыРасчетаСреднего.Район"; 
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

Функция ПараметрыЗаписиЖурнала(ИмяОперации,ПериодНачисления,Район)
	
	ПараметрыЗаписиЖурнала  = Новый Структура();
	
	СоотвествиеОпераций  	= Новый Структура;	
	СоотвествиеОпераций.Вставить("ОтложенныеДвиженияДокументовНачисленияМКД",			"Работа с последовательностями (биллинг). Чтение данных на начало периода расчета (мкд)");
	СоотвествиеОпераций.Вставить("ВосстановитьПоследовательностьСтабильныеПериодыМКД",	"Работа с последовательностями (биллинг). События мкд");
	СоотвествиеОпераций.Вставить("ВосстановитьПоследовательностьПоказанияПУМКД",		"Работа с последовательностями (биллинг). Показания мкд");
	СоотвествиеОпераций.Вставить("ОтложенныеДвиженияДокументовНачисления",				"Работа с последовательностями (биллинг). Чтение данных на начало периода расчета");
	СоотвествиеОпераций.Вставить("ВосстановитьПоследовательностьСтабильныеПериоды",		"Работа с последовательностями (биллинг). События абонентов");
	СоотвествиеОпераций.Вставить("ВосстановитьПоследовательностьПоказанияПУ",			"Работа с последовательностями (биллинг). Показания абонентов");
	СоотвествиеОпераций.Вставить("ВосстановитьПоследовательностиВзаиморасчетов",		"Работа с последовательностями (биллинг). Взаиморасчеты с абонентами");
	СоотвествиеОпераций.Вставить("ПерерасчетСреднихНачислений",							"Работа с начислениями (биллинг). Перерасчет средних начислений");
	
	ПараметрыЗаписиЖурнала.Вставить("ИмяОперации", СоотвествиеОпераций[ИмяОперации]);
	ПараметрыЗаписиЖурнала.Вставить("Уровень", УровеньЖурналаРегистрации.Информация);
	ПараметрыЗаписиЖурнала.Вставить("Метаданные", РегистрыСведений.энргСтабильныеПериодыМКД);
	ПараметрыЗаписиЖурнала.Вставить("КомментарийСтарт", "Запуск по району " + Район + " за период " + Формат(ПериодНачисления,"ДФ='ММММ гггг'"));
	ПараметрыЗаписиЖурнала.Вставить("КомментарийСтоп", "Завершение по району " 	+ Район + " за период " + Формат(ПериодНачисления,"ДФ='ММММ гггг'"));
	
	Возврат ПараметрыЗаписиЖурнала;
	
КонецФункции

Процедура ЗаполнитьСоставЖильцов(СтрокаСтабПериоды, Выборка, СоставЖильцовРазделенныхЛС)
	Если НЕ ЗначениеЗаполнено(Выборка.Абонент) Тогда
		СтрокаСтабПериоды.СоставЖильцов = СоставЖильцовРазделенныхЛС[Выборка.Помещение];
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Выборка.ПомещениеРодитель) Тогда
		Если СоставЖильцовРазделенныхЛС[Выборка.ПомещениеРодитель] = Неопределено Тогда
			СоставЖильцовРазделенныхЛС.Вставить(Выборка.ПомещениеРодитель, ПолучитьСоставЖильцов(Выборка))
		Иначе
			СоставЖильцовРазделенныхЛС[Выборка.ПомещениеРодитель] = ПолучитьСоставЖильцов(Выборка, СоставЖильцовРазделенныхЛС[Выборка.ПомещениеРодитель]);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьСоставЖильцов(Выборка, стрСоставЖильцов = "")
	
	яСоставЖильцов 						= Новый ФиксированнаяСтруктура("КоличествоПроживающих,КоличествоПрописанных,КоличествоСобственников", 0, 0, 0);
	
	IDКлючПомещения 					= "" + Выборка.КлючПомещения.УникальныйИдентификатор();
	СоставЖильцов  						= Новый Соответствие;
	Если НЕ ПустаяСтрока(стрСоставЖильцов) Тогда
		Чтение  						= Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(стрСоставЖильцов);
		СоставЖильцов 					= ПрочитатьJSON(Чтение,Истина);
	КонецЕсли;
	
	Если СоставЖильцов[IDКлючПомещения] = Неопределено Тогда
		Значение 						= Новый Структура(яСоставЖильцов);
		ЗаполнитьЗначенияСвойств(Значение,Выборка); 
		СоставЖильцов.Вставить(IDКлючПомещения, Значение);
	Иначе
		Значение 						= Новый Структура(яСоставЖильцов);
		ЗаполнитьЗначенияСвойств(Значение,Выборка);
		СоставЖильцов[IDКлючПомещения] 	= Значение;
	КонецЕсли; 	
	
	Запись 								= Новый ЗаписьJSON;
	Запись.УстановитьСтроку();	
	ЗаписатьJSON(Запись,СоставЖильцов);
	
	Возврат Запись.Закрыть()
	
КонецФункции

Функция СоздатьНаборЗаписей(МенеджерРегистраСведений)
	
	НаборЗаписей = МенеджерРегистраСведений.СоздатьНаборЗаписей();
	НаборЗаписей.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	
	Возврат НаборЗаписей;
	
КонецФункции

Функция ПроверитьДатуЗапретаИзменения(Организация, Район, ПериодНачисления)
	Отказ = Ложь;
	
	ДокДляПроверки = Документы.энргРегистрацияПоказанийАбонента.СоздатьДокумент();
	ДокДляПроверки.Организация	= Организация;
	ДокДляПроверки.Дата			= ПериодНачисления;
	ДокДляПроверки.Район		= Район;	
	Попытка
		ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ДокДляПроверки, Отказ, Истина, Истина);
	Исключение
		Отказ	= Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для пользователя " + Пользователи.ТекущийПользователь() + " район " + Район + " период " + ПериодНачисления + " закрыт для редактирования");
	КонецПопытки;
	
	Возврат Отказ;
	
КонецФункции

Функция ИнициализироватьСервисыВзаиморасчетов(МВТ, ОписаниеПериода, ОписаниеОтборов)
	
	Результат = Новый Массив;
	
	СервисДолга = Обработки.энргМенеджерВзаиморасчетовПоМесяцам.Создать();
	ЗаполнитьЗначенияСвойств(СервисДолга, ОписаниеОтборов);
	СервисДолга.ВидЗадолженности = Перечисления.энргВидыЗадолженности.ОсновнойДолг;
	СервисДолга.ГраницыПериодаНачисления = ОписаниеПериода;
	СервисДолга.Инициализировать(МВТ);
	
	Результат.Добавить(СервисДолга);	
	
	СервисДолга = Обработки.энргМенеджерВзаиморасчетовПоПене.Создать();
	ЗаполнитьЗначенияСвойств(СервисДолга, ОписаниеОтборов);
	СервисДолга.ВидЗадолженности = Перечисления.энргВидыЗадолженности.Пеня;
	СервисДолга.ГраницыПериодаНачисления = ОписаниеПериода;
	СервисДолга.Инициализировать(МВТ);
	
	Результат.Добавить(СервисДолга);
	
	Возврат Результат;
	
КонецФункции

