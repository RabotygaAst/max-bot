#Область ОбработчикиСобытий

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	УстройствоПечати = ПодключаемоеОборудованиеВызовСервера.ВернутьИдентификаторУстройстваДляПечатиДокументов();
	ОбновитьСостояниеКассовойСменыНаСервере();

КонецПроцедуры

// Процедура получает текущее состояние кассовой смены и управляет доступностью элементов,
// связанных с изменением состояния смены.
//
&НаСервере
Процедура ОбновитьСостояниеКассовойСменыНаСервере()
	
	Смена 										= ПодключаемоеОборудованиеВызовСервера.ПолучитьСостояниеКассовойСмены();
	ОткрытаяСмена 								= Перечисления.СтатусыКассовойСмены.Открыта;
	СменаОткрыта 								= ?(Смена.СтатусСмены = ОткрытаяСмена, Истина, Ложь);
	
	Элементы.ОткрытьКассовуюСмену.Доступность 	= НЕ СменаОткрыта;
	Элементы.ЗакрытьКассовуюСмену.Доступность 	= СменаОткрыта;
	Элементы.СнятьОтчетБезГашения.Доступность 	= СменаОткрыта;
	Элементы.СоздатьКвитанцию.Доступность 		= СменаОткрыта;
		
КонецПроцедуры


// Процедура вызывается при нажатии на кнопку "Открыть кассовую смену".
//
&НаКлиенте
Процедура ОткрытьКассовуюСмену(Команда)
	
	ОткрытьКассовуюСменуНаКлиенте();
	
КонецПроцедуры

// Процедура открывает кассовую смену на клиенте.
//
&НаКлиенте
Процедура ОткрытьКассовуюСменуНаКлиенте()
	
	ОчиститьСообщения();
	
	Если НЕ УстройствоПечати.Пустая() Тогда
		ИдентификаторУстройства = УстройствоПечати;
		ОткрытьКассовуюСменуНаКлиентеЗавершение(ИдентификаторУстройства, Неопределено)
	Иначе
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("ФискальныйРегистратор");
		ПоддерживаемыеТипыВО.Добавить("ПринтерЧеков");
		ОписаниеОповещения = Новый ОписаниеОповещения("ОткрытьКассовуюСменуНаКлиентеЗавершение", ЭтотОбъект);
		МенеджерОборудованияКлиент.ПредложитьВыбратьУстройство(ОписаниеОповещения, ПоддерживаемыеТипыВО,
				НСтр("ru='Выберите фискальный регистратор или принтер документов'"), НСтр("ru='Печатающие устройство не подключено.'"));
	КонецЕсли;
	
КонецПроцедуры

// Процедура открывает кассовую смену на клиенте.
//
&НаКлиенте
Процедура ОткрытьКассовуюСменуНаКлиентеЗавершение(ИдентификаторУстройства, Параметры) Экспорт

	// Подключение устройства
	Если ИдентификаторУстройства <> Неопределено Тогда
		ОписаниеОшибки = "";
		
		Результат = МенеджерОборудованияКлиент.ПодключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства, ОписаниеОшибки);
		Если Результат Тогда
			ВходныеПараметры  = Неопределено;
			ВыходныеПараметры = Неопределено;
			// Открыть смену на фискальном регистраторе.
			Результат = МенеджерОборудованияКлиент.ВыполнитьКоманду(ИдентификаторУстройства, "OpenDay", ВходныеПараметры, ВыходныеПараметры);
			
			Если Результат Тогда
					
				Результат = ОткрытьКассовуюСменуНаСервереБезКонтекста(ОписаниеОшибки);
					
				Если Не Результат Тогда
					ТекстСообщения = НСтр("ru = 'При открытии смены произошла ошибка. Смена не открыта.
							|Дополнительное описание: %ДополнительноеОписание%'");
					ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				КонецЕсли;
					
				Текст = НСтр("ru = 'СМЕНА ОТКРЫТА'");
				ПечатьТекстаНаПечатаюющемУстройстве(Текст, ИдентификаторУстройства);
					
			Иначе
				ТекстСообщения = НСтр("ru = 'При открытии смены произошла ошибка. Смена не открыта на фискальном регистраторе.
					|Дополнительное описание: %ДополнительноеОписание%'");
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ВыходныеПараметры[1]);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
			
			МенеджерОборудованияКлиент.ОтключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства);
		
		Иначе
			ТекстСообщения = НСтр("ru = 'При подключении устройства произошла ошибка. Смена не открыта на фискальном регистраторе.
				|Дополнительное описание: %ДополнительноеОписание%'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		
	КонецЕсли;
	
	ОбновитьСостояниеКассовойСменыНаСервере();
	
КонецПроцедуры

// Процедура печати текста на печатаюющем устройстве.
//
&НаКлиенте
Процедура ПечатьТекстаНаПечатаюющемУстройстве(Текст, ИдентификаторУстройства = Неопределено)
	
	Если ИдентификаторУстройства <> Неопределено Тогда
		ОписаниеОшибки = "";
		Если МенеджерОборудованияКлиент.ПодключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства, ОписаниеОшибки) Тогда
			
			ВходныеПараметры = Новый Массив();
			ВходныеПараметры.Добавить(Текст); // Произвольный текст для печати в чеке.
			ВыходныеПараметры = Неопределено;
			Результат = МенеджерОборудованияКлиент.ВыполнитьКоманду(ИдентификаторУстройства, "PrintText", ВходныеПараметры, ВыходныеПараметры);
			Если Не Результат Тогда
				ТекстСообщения = НСтр("ru = 'При печати произошла ошибка: ""%ОписаниеОшибки%"".'");
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ВыходныеПараметры[1]);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
			МенеджерОборудованияКлиент.ОтключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства, ОписаниеОшибки);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОткрытьКассовуюсменуНаСервереБезКонтекста(ОписаниеОшибки = "")
	
	Возврат ПодключаемоеОборудованиеВызовСервера.ОткрытьКассовуюСмену(ОписаниеОшибки);
	
КонецФункции

// Процедура вызывается при нажатии на кнопку "Отчет без гашения".
//
&НаКлиенте
Процедура СнятьОтчетБезГашения(Команда)
	
	ОчиститьСообщения();
	
	Если УстройствоПечати.Пустая() Тогда
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("ФискальныйРегистратор");
		ПоддерживаемыеТипыВО.Добавить("ПринтерЧеков");
		ОписаниеОповещения = Новый ОписаниеОповещения("СнятьОтчетБезГашенияЗавершение", ЭтотОбъект);
		МенеджерОборудованияКлиент.ПредложитьВыбратьУстройство(ОписаниеОповещения, ПоддерживаемыеТипыВО,
			НСтр("ru='Выберите фискальный регистратор или принтер документов'"), НСтр("ru='Печатающие устройство не подключено.'"));
	Иначе
		ИдентификаторУстройства = УстройствоПечати;
		СнятьОтчетБезГашенияЗавершение(ИдентификаторУстройства, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьОтчетБезГашенияЗавершение(ИдентификаторУстройства, Параметры) Экспорт
	
	ОписаниеОшибки = "";
	
	Результат = МенеджерОборудованияКлиент.ПодключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства, ОписаниеОшибки);
	
	Если Результат Тогда
		
		ВходныеПараметры  = Неопределено;
		ВыходныеПараметры = Неопределено;
		
		Результат = МенеджерОборудованияКлиент.ВыполнитьКоманду(ИдентификаторУстройства, "PrintXReport", ВходныеПараметры, ВыходныеПараметры);
		
		Если Не Результат Тогда
			ТекстСообщения = НСтр("ru = 'При снятии отчета на фискальном регистраторе произошла ошибка.
								|""%ОписаниеОшибки%""
								|Отчет на фискальном регистраторе не сформирован.'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ВыходныеПараметры[1]);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		
		МенеджерОборудованияКлиент.ОтключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства);
		
	Иначе
		ТекстСообщения = НСтр("ru = 'При подключении устройства произошла ошибка.
			|Отчет не напечатан и смена не закрыта на фискальном регистраторе.
			|Дополнительное описание: %ДополнительноеОписание%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

// Процедура вызывается при нажатии на кнопку "Закрыть кассовую смену".
//
&НаКлиенте
Процедура ЗакрытьКассовуюСмену(Команда)
	
	ОчиститьСообщения();
	
	Если УстройствоПечати.Пустая() Тогда
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("ФискальныйРегистратор");
		ПоддерживаемыеТипыВО.Добавить("ПринтерЧеков");
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗакрытьКассовуюСменуЗавершение", ЭтотОбъект);
		МенеджерОборудованияКлиент.ПредложитьВыбратьУстройство(ОписаниеОповещения, ПоддерживаемыеТипыВО,
			НСтр("ru='Выберите фискальный регистратор или принтер документов'"), НСтр("ru='Печатающие устройство не подключено.'"));
	Иначе
		ИдентификаторУстройства = УстройствоПечати;
		ЗакрытьКассовуюСменуЗавершение(ИдентификаторУстройства, Неопределено);
	КонецЕсли;
		
	ОбновитьСостояниеКассовойСменыНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьКассовуюСменуЗавершение(ИдентификаторУстройства, Параметры) Экспорт
	
	ОписаниеОшибки = "";
	ОшибкаПриСнятииZОтчета = Ложь;
	
	Результат = МенеджерОборудованияКлиент.ПодключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства, ОписаниеОшибки);
	
	Если Результат Тогда
		
		ВходныеПараметры  = Неопределено;
		ВыходныеПараметры = Неопределено;
		
		Результат = МенеджерОборудованияКлиент.ВыполнитьКоманду(ИдентификаторУстройства, "PrintZReport", ВходныеПараметры, ВыходныеПараметры);
		
		Если Не Результат Тогда
			ТекстСообщения = НСтр("ru = 'При снятии отчета на фискальном регистраторе произошла ошибка.
				|""%ОписаниеОшибки%""
				|Отчет на фискальном регистраторе не сформирован.'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ВыходныеПараметры[1]);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Иначе
			// Если НЕ ЗаархивироватьДокументыНаСервере() Тогда
			//	ТекстПредупреждения = НСтр("ru = 'Ошибка записи документов'");
			//	ПоказатьПредупреждение(, ТекстПредупреждения, 10);
			//	Возврат;
			// КонецЕсли;
			Результат = ЗакрытьКассовуюСменуНаСервереБезКонтекста(ОписаниеОшибки);
		КонецЕсли;
		
		МенеджерОборудованияКлиент.ОтключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства);
		
	Иначе
		ТекстСообщения = НСтр("ru = 'При подключении устройства произошла ошибка.
			|Отчет не напечатан и смена не закрыта на фискальном регистраторе.
			|Дополнительное описание: %ДополнительноеОписание%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	ОбновитьСостояниеКассовойСменыНаСервере();
	
КонецПроцедуры

&НаСервере
Функция ЗакрытьКассовуюСменуНаСервереБезКонтекста(ОписаниеОшибки = "")
	
	Возврат ПодключаемоеОборудованиеВызовСервера.ЗакрытьКассовуюСмену(ОписаниеОшибки);
	
КонецФункции










