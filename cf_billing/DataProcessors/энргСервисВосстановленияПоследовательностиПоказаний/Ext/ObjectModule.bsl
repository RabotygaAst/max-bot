Функция СтатичныеДополнительныеПараметрыПоказаний(ПериодыПриемаПоказаний, НачалоПериодаРасчета)
	
	Результат = Новый Структура;
	Результат.Вставить("НачалоПериодаРасчета", НачалоПериодаРасчета);
	
	Результат.Вставить("Исключен", Перечисления.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности);
	Результат.Вставить("ПроведенСНарушением", Перечисления.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности);
	Результат.Вставить("ПроведенВПоследовательности", Перечисления.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности);
	
	Результат.Вставить("ПоказанияОтклонены"			, Перечисления.энргСостояниеПоказаний.Отклонены);
	Результат.Вставить("ПоказанияПриняты"			, Перечисления.энргСостояниеПоказаний.Приняты);
	Результат.Вставить("ПустоеСостояниеПоказаний"	, Перечисления.энргСостояниеПоказаний.ПустаяСсылка());
	
	Результат.Вставить("НаборПредоставленных"			, Новый Соответствие);
	Результат.Вставить("НаборРасчетСреднего"			, Новый Соответствие);
	Результат.Вставить("НаборМаксимальныеПоказания"		, Новый Соответствие);
	Результат.Вставить("НаборМаксимальныеПоказанияСрез"	, Новый Соответствие);
	
	Результат.Вставить("НачПокНеЯвляютсяКонечнымиПриУстПрибора", энргРаботаСКонстантами.ЗначениеКонстантыНачальныеПоказанияПУНеРавныКонечнымВПериодеВведенияВЭксплуатациюПУ());
	Результат.Вставить("РасчетПриОтклоненииПоказанийПоСреднемуИлиНормативу", энргРаботаСКонстантами.ЗначениеКонстантыРасчетПриОтклоненииПоказанийПоСреднемуИлиНормативу());
	
	Результат.Вставить("ПоказанияС"	, ?(не ЗначениеЗаполнено(ПериодыПриемаПоказаний.ДатаС),	1, ПериодыПриемаПоказаний.ДатаС));
	Результат.Вставить("ПоказанияПО", ?(не ЗначениеЗаполнено(ПериодыПриемаПоказаний.ДатаПо), 31, ПериодыПриемаПоказаний.ДатаПо));	
	
	Результат.Вставить("ПараметрыОперации",	НовыеПараметрыОперации());
	Результат.Вставить("ПричиныОтклоненияИсключая", энргРаботаСПоказаниямиПриборовУчетаСервер.ПричиныОтклоненияИсключая());
	
	Результат.Вставить("АктЗамены", Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ);
	Возврат Результат;
	
КонецФункции

