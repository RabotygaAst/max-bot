Процедура ОчиститьДанныеИсключенногоИзПоследовательности(МенеджерыРегистров, Выборка, ПараметрыПроведений)
	
	МенеджерэнргПоказанияПУПоследовательность = МенеджерыРегистров.энргПоказанияПУПоследовательность;	
	МенеджерэнргМаксимальныеПоказания		  =	МенеджерыРегистров.энргМаксимальныеПоказания;
	МенеджерэнргПредоставленныеПоказания	  = МенеджерыРегистров.энргПредоставленныеПоказания;	
	МенеджерэнргМаксимальныеПоказанияСрез	  =	МенеджерыРегистров.энргМаксимальныеПоказанияСрез;
	
	// Очищаем данные.	
	НаборПоследовательности = СоздатьНаборЗаписей(МенеджерэнргПоказанияПУПоследовательность);
	НаборПоследовательности.Отбор.ДокРегистратор.установить(Выборка.ДокРегистратор);
	НаборПоследовательности.Отбор.Организация.установить(Организация);
	НаборПоследовательности.Отбор.ПериодНачисления.установить(ПериодНачисления);
	НаборПоследовательности.Отбор.Район.установить(Район);
	НаборПоследовательности.Отбор.СостояниеПроведения.установить(Выборка.СостояниеПроведения);
	НаборПоследовательности.Отбор.ЧастныйСектор.установить(ПараметрыПроведений.ЧастныйСектор);
	НаборПоследовательности.Отбор.Строение.установить(ПараметрыПроведений.Строение);
	НаборПоследовательности.Отбор.Помещение.установить(ПараметрыПроведений.Помещение);
	НаборПоследовательности.Отбор.ПриборУчета.установить(ПараметрыПроведений.ПриборУчета);
	НаборПоследовательности.Отбор.ПериодРегистрации.установить(Выборка.ПериодРегистрации);
	НаборПоследовательности.Отбор.ДатаРегистратора.установить(Выборка.ДатаРегистратора);
	НаборПоследовательности.Записать();
	
	// Получаем таблицу максимальных показаний по регистратору.
	НаборМаксПоказаний  = СоздатьНаборЗаписей(МенеджерэнргМаксимальныеПоказания);
	НаборМаксПоказаний.Отбор.Период.установить(Выборка.ПериодРегистрации);
	НаборМаксПоказаний.Отбор.ДокРегистратор.установить(Выборка.ДокРегистратор);
	НаборМаксПоказаний.Отбор.Организация.установить(Организация);
	НаборМаксПоказаний.Отбор.Район.установить(Район);
	НаборМаксПоказаний.Отбор.КлючПомещения.установить(ПараметрыПроведений.КлючПомещения);
	НаборМаксПоказаний.Отбор.ПриборУчета.установить(ПараметрыПроведений.ПриборУчета);	
	НаборМаксПоказаний.Записать();
	
	НаборПредоставленных = СоздатьНаборЗаписей(МенеджерэнргПредоставленныеПоказания);
	НаборПредоставленных.Отбор.ДокРегистратор.установить(Выборка.ДокРегистратор);
	НаборПредоставленных.Отбор.Организация.установить(Организация);
	НаборПредоставленных.Отбор.ПериодНачисления.установить(ПериодНачисления);
	НаборПредоставленных.Отбор.Район.установить(Район);
	НаборПредоставленных.Отбор.ЧастныйСектор.установить(ПараметрыПроведений.ЧастныйСектор);
	НаборПредоставленных.Отбор.Строение.установить(ПараметрыПроведений.Строение);
	НаборПредоставленных.Отбор.Помещение.установить(ПараметрыПроведений.Помещение);
	НаборПредоставленных.Отбор.ПриборУчета.установить(ПараметрыПроведений.ПриборУчета);
	НаборПредоставленных.Записать();
	
	НаборМаксПоказанийСрез	= СоздатьНаборЗаписей(МенеджерэнргМаксимальныеПоказанияСрез);
	НаборМаксПоказанийСрез.Отбор.Организация.установить(Организация);
	НаборМаксПоказанийСрез.Отбор.ПериодНачисления.установить(ПериодНачисления);
	НаборМаксПоказанийСрез.Отбор.Район.установить(Район);
	НаборМаксПоказанийСрез.Отбор.ЧастныйСектор.установить(ПараметрыПроведений.ЧастныйСектор);
	НаборМаксПоказанийСрез.Отбор.Строение.установить(ПараметрыПроведений.Строение);
	НаборМаксПоказанийСрез.Отбор.Помещение.установить(ПараметрыПроведений.Помещение);
	НаборМаксПоказанийСрез.Отбор.ПриборУчета.установить(ПараметрыПроведений.ПриборУчета); 				
	//НаборМаксПоказанийСрез.Отбор.Шкала.установить(Шкала);
	//НаборМаксПоказанийСрез.Отбор.ТарифнаяЗона.установить(ТарифнаяЗона);	
	НаборМаксПоказанийСрез.Записать();
	
