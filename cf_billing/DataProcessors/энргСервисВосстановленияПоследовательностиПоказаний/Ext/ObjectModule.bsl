#Область ОписаниеПеременных

перем ПериодНачисления Экспорт; // Период начисления услуги
перем Организация Экспорт; // Организация предоставляющая услуги
перем Район Экспорт; // Район, в котором оказывается услуга
перем ЧастныйСектор Экспорт; // Булево - Является ли строение частным сектором
перем Строение Экспорт; // Адрес, по которому оказавается услуга
перем Помещение Экспорт; // Помещение, в котором оказывается услуга

перем Строения Экспорт; // Строения для изменения структуры запроса

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ВосстановитьПоследовательность() Экспорт 
	
	Отказ = ПроверитьДатуЗапретаИзменения(Организация, Район, ПериодНачисления);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ГраницыПериода = Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация, Район, ПериодНачисления); 	
	
	Отбор = Новый Структура;
	Отбор.Вставить("НачалоПериодаРасчета"	, ГраницыПериода.НачалоОП);
	Отбор.Вставить("КонецПериодаРасчета"	, ГраницыПериода.ЗавершениеОП);
	Отбор.Вставить("ПриборУчета"			, Неопределено);
	Отбор.Вставить("КолвоНедопусковПодряд"	, энргРаботаСКонстантами.ЗначениеКонстантыКоличествоНедопусковДляОтклоненияПоказаний());	
	 
	Отказ 	= Ложь;
	Ошибки 	= Новый Массив;

	МВТ  		= Новый МенеджерВременныхТаблиц;
	Результат  	= РезультатЗапросаПоказанияПУ(МВТ, Отбор);
	
	ДанныеМаксимальногоПотребления 	= ДанныеМаксимальногоПотребления(Отбор.НачалоПериодаРасчета);
	
	РезультатСреднийОбъем	= РезультатСреднийОбъемПотребления(МВТ, Отбор);
	ВыборкаСреднийОбъем 	= РезультатСреднийОбъем.Выбрать();
	
	ПериодыПриемаПоказаний 	= РегистрыСведений.энргПериодыПриемаПоказаний.ПолучитьПоследнее(ПериодНачисления, Новый Структура("Организация", Организация));
	
	ПредыдущиеМакс 			= 0;
	Выборка  				= Результат.Выбрать();
	ТекЧастныйСектор		= Неопределено;
	ТекСтроение				= Неопределено;
	ТекПомещение			= Неопределено;
	ТекКлючПомещения		= Неопределено;
	ТекПрибор 				= Неопределено;
	ТекШкала		 		= Неопределено;
	ТекТарифнаяЗона 		= Неопределено;
	ТекРегистрируетОбъем 	= Неопределено;
	МассивДокументов		= Неопределено;
	НомерПозиции 			= Неопределено;
	ДанныеСреднегоОбъема 	= Неопределено;
	ТекНедопускПрибора		= Неопределено;
	
	ОписаниеСтроки 				= ОписаниеСтрокиМассивДокументов();
	ОписаниеПараметрыПроведений	= ОписаниеСтрокиПараметрыПроведения();		
	
	//
	МенеджерэнргПоказанияПУПоследовательность = РегистрыСведений.энргПоказанияПУПоследовательность;
	МенеджерэнргПредоставленныеПоказания	  = РегистрыСведений.энргПредоставленныеПоказания;
	МенеджерэнргРасчетСреднегоОбъема		  =	РегистрыСведений.энргРасчетСреднегоОбъема;
	МенеджерэнргМаксимальныеПоказания		  = РегистрыСведений.энргМаксимальныеПоказания;
	МенеджерэнргМаксимальныеПоказанияСрез	  = РегистрыСведений.энргМаксимальныеПоказанияСрез;
	
	МенеджерыРегистров = Новый Структура;
	МенеджерыРегистров.Вставить("энргПоказанияПУПоследовательность", МенеджерэнргПоказанияПУПоследовательность);
	МенеджерыРегистров.Вставить("энргПредоставленныеПоказания", МенеджерэнргПредоставленныеПоказания);
	МенеджерыРегистров.Вставить("энргРасчетСреднегоОбъема", МенеджерэнргРасчетСреднегоОбъема);
	МенеджерыРегистров.Вставить("энргМаксимальныеПоказания", МенеджерэнргМаксимальныеПоказания);
	МенеджерыРегистров.Вставить("энргМаксимальныеПоказанияСрез", МенеджерэнргМаксимальныеПоказанияСрез);
	
	// 
	СтатичныеДопПараметры = СтатичныеДополнительныеПараметрыПоказаний(ПериодыПриемаПоказаний, Отбор.НачалоПериодаРасчета);
	ЗапросПоследовательности = ЗапросПоследовательности();
	
	Всего 				= Выборка.Количество();	
	Итерация			= 0;
	КоличествоИтераций 	= Итерация;
	КолвоСообщений		= Цел(Всего / 10);
	Постфикс 			= " из " + Всего;
	
	Если Всего > 0 тогда
		ВыборкаСреднийОбъем.Следующий();
		НачатьТранзакцию();
	КонецЕсли;
	
	Пока Выборка.Следующий() цикл
		Если НЕ ТекЧастныйСектор = Выборка.ЧастныйСектор
			ИЛИ НЕ ТекСтроение = Выборка.Строение 
			ИЛИ ТекПомещение<> Выборка.Помещение
			ИЛИ ТекПрибор <> Выборка.ПриборУчета
			ИЛИ ТекШкала <> Выборка.Шкала
			ИЛИ ТекТарифнаяЗона <> Выборка.ТарифнаяЗона Тогда  			  			
			
			Если ТекПомещение <> Неопределено Тогда
				
				Если Не Отказ Тогда
					ПараметрыПроведений = Новый Структура(ОписаниеПараметрыПроведений,
						ТекЧастныйСектор, ТекСтроение, ТекПомещение, ТекКлючПомещения, ТекПрибор, ТекШкала, 
						ТекТарифнаяЗона, НомерПозиции, ТекРегистрируетОбъем, ТекНедопускПрибора);
						
					ОтказПоТарифнойЗоне	= Ложь;
					ОтказПоТарифнойЗоне	= ПровестиПоказанияПриборовУчета(
						ПараметрыПроведений,
						МассивДокументов,
						ДанныеСреднегоОбъема,
						ДанныеМаксимальногоПотребления,
						Ошибки,
						МенеджерыРегистров,
						СтатичныеДопПараметры);
					
					Если ОтказПоТарифнойЗоне Тогда
						Отказ = Истина;
					КонецЕсли;
				КонецЕсли;
				
				Если ТекПомещение <> Выборка.Помещение или ТекПрибор <> Выборка.ПриборУчета тогда
									
					Если НЕ Отказ Тогда
						
						Попытка
							
							ЗаписатьНаборыЗаписейПоПрибору(СтатичныеДопПараметры.НаборПредоставленных);
							ЗаписатьНаборыЗаписейПоПрибору(СтатичныеДопПараметры.НаборРасчетСреднего);
							ЗаписатьНаборыЗаписейПоПрибору(СтатичныеДопПараметры.НаборМаксимальныеПоказания);
							ЗаписатьНаборыЗаписей(СтатичныеДопПараметры.НаборМаксимальныеПоказанияСрез);							
							
							УстановитьУспешныйСтатусПроведенияВПоследовательности(
								МенеджерыРегистров,
								ПараметрыПроведений,
								СтатичныеДопПараметры.ПроведенСНарушением,
								СтатичныеДопПараметры.ПроведенВПоследовательности,
								ЗапросПоследовательности);
							
							ЗафиксироватьТранзакцию();
							
						Исключение
							ОтменитьТранзакцию();				
							
							ИнформацияОбОшибке = ИнформацияОбОшибке();
							ППО = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
							Ошибки.Добавить(ППО);
							
						КонецПопытки;					
						
					Иначе 
						
						ОтменитьТранзакцию();				
						
					КонецЕсли;
					
					Отказ = Ложь;
					НачатьТранзакцию();					
					
					СтатичныеДопПараметры.НаборПредоставленных.Очистить();
					СтатичныеДопПараметры.НаборРасчетСреднего.Очистить();
					СтатичныеДопПараметры.НаборМаксимальныеПоказания.Очистить();
					СтатичныеДопПараметры.НаборМаксимальныеПоказанияСрез.Очистить();					
					
				КонецЕсли;
				
				МассивДокументов.Очистить();
			КонецЕсли;
			
			Если ТекПомещение <> Выборка.Помещение Тогда
				ДанныеСреднегоОбъема = ДанныеСреднегоОбъемаАбонента(ВыборкаСреднийОбъем, Выборка);
			КонецЕсли;
			
			МассивДокументов	= Новый Массив;
			НомерПозиции 		= Выборка.НомерПозици + 1;			
			
		КонецЕсли; 	
		
		ДанныеСтроки = Новый Структура(ОписаниеСтроки);
		ЗаполнитьЗначенияСвойств(ДанныеСтроки, Выборка);
		МассивДокументов.Добавить(ДанныеСтроки);		
		
		ДополнитьНаборЗаписейВСоответствиеПредоставленныеПоказания(СтатичныеДопПараметры, МенеджерэнргПредоставленныеПоказания, Выборка);
		ДополнитьНаборЗаписейВСоответствиеРасчетСреднегоОбъема(СтатичныеДопПараметры, МенеджерэнргРасчетСреднегоОбъема, Выборка);
		ДополнитьНаборЗаписейВСоответствиеМаксимальныеПоказания(СтатичныеДопПараметры, МенеджерэнргМаксимальныеПоказания, Выборка);
		ДополнитьНаборЗаписейВСоответствиеМаксимальныеПоказанияСрез(СтатичныеДопПараметры, МенеджерэнргМаксимальныеПоказанияСрез, Выборка); 		
				 		
		ТекЧастныйСектор 						= Выборка.ЧастныйСектор;
		ТекСтроение								= Выборка.Строение;
		ТекПомещение  							= Выборка.Помещение;
		ТекКлючПомещения						= Выборка.КлючПомещения;
		ТекПрибор 								= Выборка.ПриборУчета;
		ТекШкала 								= Выборка.Шкала;
		ТекТарифнаяЗона 						= Выборка.ТарифнаяЗона;
		ТекРегистрируетОбъем					= Выборка.РегистрируетОбъем;
		ТекНедопускПрибора						= Выборка.НедопускПрибора;
		
		
		Если КоличествоИтераций = КолвоСообщений Тогда
			Процент = Цел(Итерация / Всего * 100);
			ДлительныеОперации.СообщитьПрогресс(Процент, "Восстановление последовательности показаний физ.лица: " + Итерация + Постфикс);
			КоличествоИтераций = 0;
		КонецЕсли;
		
		Итерация = Итерация + 1;
		КоличествоИтераций = КоличествоИтераций + 1;
		
	КонецЦикла;
	
	Если НЕ ТекПомещение = Неопределено  тогда
		
		Если НЕ Отказ Тогда
			ПараметрыПроведений = Новый Структура(ОписаниеПараметрыПроведений,
				ТекЧастныйСектор, ТекСтроение, ТекПомещение, ТекКлючПомещения, ТекПрибор, ТекШкала, 
				ТекТарифнаяЗона, НомерПозиции, ТекРегистрируетОбъем, ТекНедопускПрибора);
			
			ОтказПоТарифнойЗоне	= Ложь;
			ОтказПоТарифнойЗоне	= ПровестиПоказанияПриборовУчета(
				ПараметрыПроведений,
				МассивДокументов,
				ДанныеСреднегоОбъема,
				ДанныеМаксимальногоПотребления,
				Ошибки,
				МенеджерыРегистров,
				СтатичныеДопПараметры);
			
			Если ОтказПоТарифнойЗоне Тогда
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ Отказ тогда
			
			Попытка
				
				ЗаписатьНаборыЗаписейПоПрибору(СтатичныеДопПараметры.НаборПредоставленных);
				ЗаписатьНаборыЗаписейПоПрибору(СтатичныеДопПараметры.НаборРасчетСреднего);
				ЗаписатьНаборыЗаписейПоПрибору(СтатичныеДопПараметры.НаборМаксимальныеПоказания);
				ЗаписатьНаборыЗаписей(СтатичныеДопПараметры.НаборМаксимальныеПоказанияСрез);  				
				
				УстановитьУспешныйСтатусПроведенияВПоследовательности(
					МенеджерыРегистров,
					ПараметрыПроведений,
					СтатичныеДопПараметры.ПроведенСНарушением,
					СтатичныеДопПараметры.ПроведенВПоследовательности,
					ЗапросПоследовательности);
				
				ЗафиксироватьТранзакцию();
				
			Исключение
				
				ОтменитьТранзакцию();				
				
				ИнформацияОбОшибке = ИнформацияОбОшибке();
				ППО = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
				Ошибки.Добавить(ППО);
				
			КонецПопытки;			
			
		иначе
			ОтменитьТранзакцию(); 			 
		КонецЕсли; 
		
	КонецЕсли; 
	
	Если Ошибки.Количество() > 0 Тогда
		ВызватьИсключение СтрСоединить(Ошибки, Символы.ПС);
	КонецЕсли; 	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПолучениеДанных

Функция РезультатЗапросаПоказанияПУ(МВТ, Отбор) 
	
	Запрос  = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Текст =
	"ВЫБРАТЬ
	|	энргПоказанияПУПоследовательность.Организация КАК Организация,
	|	энргПоказанияПУПоследовательность.ПериодНачисления КАК ПериодНачисления,
	|	энргПоказанияПУПоследовательность.Район КАК Район,
	|	энргПоказанияПУПоследовательность.ЧастныйСектор КАК ЧастныйСектор,
	|	энргПоказанияПУПоследовательность.Строение КАК Строение,
	|	энргПоказанияПУПоследовательность.Помещение КАК Помещение,
	|	энргПоказанияПУПоследовательность.ПриборУчета КАК ПриборУчета,
	|	МИНИМУМ(энргПоказанияПУПоследовательность.ПериодРегистрации) КАК ПериодРегистрации
	|ПОМЕСТИТЬ МинимальныйПериод
	|ИЗ
	|	РегистрСведений.энргПоказанияПУПоследовательность КАК энргПоказанияПУПоследовательность
	|ГДЕ
	|	энргПоказанияПУПоследовательность.Организация = &Организация
	|	И энргПоказанияПУПоследовательность.ПериодНачисления = &ПериодНачисления
	|	И энргПоказанияПУПоследовательность.Район = &Район
	|	И энргПоказанияПУПоследовательность.СостояниеПроведения В (ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности), ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности))
	|	И энргПоказанияПУПоследовательность.ЧастныйСектор = &ЧастныйСектор
	|	И энргПоказанияПУПоследовательность.Строение = &Строение
	|	И энргПоказанияПУПоследовательность.Помещение = &Помещение
	|
	|СГРУППИРОВАТЬ ПО
	|	энргПоказанияПУПоследовательность.Организация,
	|	энргПоказанияПУПоследовательность.ПериодНачисления,
	|	энргПоказанияПУПоследовательность.Район,
	|	энргПоказанияПУПоследовательность.ЧастныйСектор,
	|	энргПоказанияПУПоследовательность.Строение,
	|	энргПоказанияПУПоследовательность.Помещение,
	|	энргПоказанияПУПоследовательность.ПриборУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МинимальныйПериод.Организация КАК Организация,
	|	МинимальныйПериод.ПериодНачисления КАК ПериодНачисления,
	|	МинимальныйПериод.Район КАК Район,
	|	МинимальныйПериод.ЧастныйСектор КАК ЧастныйСектор,
	|	МинимальныйПериод.Строение КАК Строение,
	|	МинимальныйПериод.Помещение КАК Помещение,
	|	МинимальныйПериод.ПриборУчета КАК ПриборУчета,
	|	МинимальныйПериод.ПериодРегистрации КАК ПериодРегистрации,
	|	МИНИМУМ(энргПоказанияПУПоследовательность.ДатаРегистратора) КАК ДатаРегистратора
	|ПОМЕСТИТЬ МинимальнаяДатаРегистратора
	|ИЗ
	|	МинимальныйПериод КАК МинимальныйПериод
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргПоказанияПУПоследовательность КАК энргПоказанияПУПоследовательность
	|		ПО МинимальныйПериод.Организация = энргПоказанияПУПоследовательность.Организация
	|			И МинимальныйПериод.ПериодНачисления = энргПоказанияПУПоследовательность.ПериодНачисления
	|			И МинимальныйПериод.Район = энргПоказанияПУПоследовательность.Район
	|			И (энргПоказанияПУПоследовательность.СостояниеПроведения В (ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности), ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности)))
	|			И МинимальныйПериод.ЧастныйСектор = энргПоказанияПУПоследовательность.ЧастныйСектор
