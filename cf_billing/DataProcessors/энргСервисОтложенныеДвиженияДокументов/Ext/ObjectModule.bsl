	Запрос.УстановитьПараметр("Район", ОсновныеПараметры.Район);
	Запрос.УстановитьПараметр("МКД", Строение);
	Если Помещение = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргВзаиморасчетыПоследовательность.Абонент = &Абонент", "");	
	Иначе 			
		Запрос.УстановитьПараметр("Абонент", Помещение);
