	|		И (КлючиНорматива.Измеритель = ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеПараметрыРасчетаСИзмерителями.*,
	|	КлючиНорматива.КлючНорматива КАК КлючНорматива,
	|	КлючиНорматива.КлючСоцНорматива КАК КлючСоцНорматива,
	|	ЛОЖЬ КАК ЯвляетсяПомещениемСРазделеннымиЛС
	|ПОМЕСТИТЬ СтабильныеПериодыВводНачальныхОстатковСИзмерителями
	|ИЗ
	|	ВсеПараметрыРасчетаСИзмерителями КАК ВсеПараметрыРасчетаСИзмерителями
	|		ЛЕВОЕ СОЕДИНЕНИЕ КлючиНорматива КАК КлючиНорматива
	|		ПО ВсеПараметрыРасчетаСИзмерителями.Строение = КлючиНорматива.Строение
	|			И ВсеПараметрыРасчетаСИзмерителями.Помещение = КлючиНорматива.Помещение
	|			И ВсеПараметрыРасчетаСИзмерителями.Услуга = КлючиНорматива.Услуга
	|			И ВсеПараметрыРасчетаСИзмерителями.НаправлениеИспользованияТУ = КлючиНорматива.НаправлениеИспользованияТУ
	|			И ВсеПараметрыРасчетаСИзмерителями.Измеритель = КлючиНорматива.Измеритель";
		 		
	Возврат Текст;
	
КонецФункции 

Функция СтабильныеПериодыДокументыНачисления(ПериодНачисления)
	
	Текст 	=  
	"ВЫБРАТЬ
	|	СтабильныеПериоды.Организация КАК Организация,
	|	СтабильныеПериоды.ПериодНачисления КАК ПериодНачисления,
	|	СтабильныеПериоды.Район КАК Район,
	|	СтабильныеПериоды.ЧастныйСектор КАК ЧастныйСектор,
	|	СтабильныеПериоды.Строение КАК Строение,
	|	СтабильныеПериоды.Помещение КАК Помещение,
	|	СтабильныеПериоды.Услуга КАК Услуга,
	|	СтабильныеПериоды.ТочкаУчета КАК ТочкаУчета,
	|	МАКСИМУМ(СтабильныеПериоды.НомерПозиции) КАК НомерПозиции
	|ПОМЕСТИТЬ НомерСтрок
	|ИЗ
	|	РегистрСведений.энргСтабильныеПериоды КАК СтабильныеПериоды
	|ГДЕ
	|	СтабильныеПериоды.Организация = &Организация
	|	И СтабильныеПериоды.ПериодНачисления = &ПредыдущийПериод
	|	И СтабильныеПериоды.Район = &Район
	|	И СтабильныеПериоды.ЧастныйСектор = &ЧастныйСектор
	|	И СтабильныеПериоды.Строение В (&Строение)
	|	И СтабильныеПериоды.Помещение = &Помещение
	|
	|СГРУППИРОВАТЬ ПО
	|	СтабильныеПериоды.Организация,
	|	СтабильныеПериоды.ПериодНачисления,
	|	СтабильныеПериоды.Район,
	|	СтабильныеПериоды.ЧастныйСектор,
	|	СтабильныеПериоды.Строение,
	|	СтабильныеПериоды.Помещение,
	|	СтабильныеПериоды.Услуга,
	|	СтабильныеПериоды.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	&Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	0 КАК НомерПозиции,
	|	ЛОЖЬ КАК БлокировочныйАкт,
	|	0 КАК ГодПостройки,
	| "+ энргНачисления.СформироватьСтрокуДляЗапроса("энргСтабильныеПериоды","СтабильныеПериоды","Организация,ПериодНачисления,НомерПозиции,БлокировочныйАкт,СоставЖильцов") + "
	|ПОМЕСТИТЬ ПараметрыСтаблиногоПериода
	|ИЗ
	|	НомерСтрок КАК НомерСтрок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСтабильныеПериоды КАК СтабильныеПериоды
	|		ПО НомерСтрок.Организация = СтабильныеПериоды.Организация
	|			И НомерСтрок.ПериодНачисления = СтабильныеПериоды.ПериодНачисления
	|			И НомерСтрок.Район = СтабильныеПериоды.Район
	|			И НомерСтрок.ЧастныйСектор = СтабильныеПериоды.ЧастныйСектор
	|			И НомерСтрок.Строение = СтабильныеПериоды.Строение
	|			И НомерСтрок.Помещение = СтабильныеПериоды.Помещение
	|			И НомерСтрок.Услуга = СтабильныеПериоды.Услуга
	|			И НомерСтрок.ТочкаУчета = СтабильныеПериоды.ТочкаУчета
	|			И НомерСтрок.НомерПозиции = СтабильныеПериоды.НомерПозиции
	|			И (СтабильныеПериоды.Организация = &Организация)
	|			И (СтабильныеПериоды.ПериодНачисления = &ПредыдущийПериод)
	|			И (СтабильныеПериоды.Район = &Район)
	|			И (СтабильныеПериоды.ЧастныйСектор = &ЧастныйСектор)
	|			И (СтабильныеПериоды.Строение В (&Строение))
	|			И (СтабильныеПериоды.Помещение = &Помещение)
	|ГДЕ
	|	СтабильныеПериоды.УслугаПодключена";
	
	ИмяТаблицыПараметрыСтаблиногоПериода = "ПараметрыСтаблиногоПериода";
	Если ПериодНачисления = НачалоГода(ПериодНачисления) Тогда
		Текст 	= Текст + ОбщегоНазначения.РазделительПакетаЗапросов(); 
		
		Текст 	= Текст + Справочники.энргКлючиНормативов.ТекстОпределенияКлючейНорматива(Ложь, "ПараметрыСтаблиногоПериода");

		Текст 	= Текст + ОбщегоНазначения.РазделительПакетаЗапросов(); 	
		
		Текст  	= Текст +
		"ВЫБРАТЬ
		| "+ энргНачисления.СформироватьСтрокуДляЗапроса("энргСтабильныеПериоды","ВсеПараметрыРасчета","КлючНорматива,КлючСоцНорматива,СоставЖильцов",Истина,Ложь) + "
		|	КлючиНорматива.КлючНорматива КАК КлючНорматива,
		|	КлючиНорматива.КлючСоцНорматива КАК КлючСоцНорматива
		|ПОМЕСТИТЬ ВсеПараметрыРасчетаКлючНорматива
		|ИЗ
		|	ПараметрыСтаблиногоПериода КАК ВсеПараметрыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ КлючиНормативаПараметрыСтаблиногоПериода КАК КлючиНорматива
		|		ПО (ВсеПараметрыРасчета.Строение = КлючиНорматива.Строение)
		|		И (ВсеПараметрыРасчета.Помещение = КлючиНорматива.Помещение)
		|		И (ВсеПараметрыРасчета.Услуга = КлючиНорматива.Услуга)
		|		И (ВсеПараметрыРасчета.НаправлениеИспользованияТУ = КлючиНорматива.НаправлениеИспользованияТУ)
		|		И (КлючиНорматива.Измеритель = ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление))";
		
		ИмяТаблицыПараметрыСтаблиногоПериода = "ВсеПараметрыРасчетаКлючНорматива";		
	КонецЕсли;
	
	Текст 		= Текст + ОбщегоНазначения.РазделительПакетаЗапросов();	
	
	Текст 		= Текст + 
	"ВЫБРАТЬ
	| "+ энргНачисления.СформироватьСтрокуДляЗапроса("энргСтабильныеПериоды","ПараметрыСтаблиногоПериода","ПериодРегистрации,ДатаРегистратора,ДокРегистратор,СоставЖильцов",Истина,Ложь) + "
	|	&ПериодРегистрации КАК ПериодРегистрации,
	|	ДокументыДляПроведения.ДатаРегистратора КАК ДатаРегистратора,
	|	ДокументыДляПроведения.ДокРегистратор КАК ДокРегистратор	
	|ПОМЕСТИТЬ СтабильныеПериодыДокументыНачислений
	|ИЗ
	|	" + ИмяТаблицыПараметрыСтаблиногоПериода + " КАК ПараметрыСтаблиногоПериода
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДокументыДляПроведения КАК ДокументыДляПроведения
	|		ПО ПараметрыСтаблиногоПериода.Организация = ДокументыДляПроведения.Организация
	|			И ПараметрыСтаблиногоПериода.ПериодНачисления = ДокументыДляПроведения.ПериодНачисления
	|			И ПараметрыСтаблиногоПериода.Район = ДокументыДляПроведения.Район
	|			И ПараметрыСтаблиногоПериода.ЧастныйСектор = ДокументыДляПроведения.ЧастныйСектор
	|			И НЕ ДокументыДляПроведения.ДокРегистратор Ссылка Документ.энргВводНачальныхОстатков
	|			И (ВЫБОР
	|					КОГДА ДокументыДляПроведения.ЧастныйСектор
	|						ТОГДА ИСТИНА 
	|					ИНАЧЕ ПараметрыСтаблиногоПериода.Строение = ДокументыДляПроведения.Строение
	|				КОНЕЦ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////	
	|ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|" + энргНачисления.СформироватьСтрокуДляЗапроса("энргСтабильныеПериодыШкалы","СтабильныеПериодыШкалы","Организация,ПериодНачисления,НомерПозиции,ДатаРегистратора,ДокРегистратор") + "		
	|ПОМЕСТИТЬ ПараметрыШкалСтаблиногоПериода
	|ИЗ
	|	НомерСтрок КАК НомерСтрок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСтабильныеПериодыШкалы КАК СтабильныеПериодыШкалы
	|		ПО НомерСтрок.Организация = СтабильныеПериодыШкалы.Организация
	|			И НомерСтрок.ПериодНачисления = СтабильныеПериодыШкалы.ПериодНачисления
	|			И НомерСтрок.Район = СтабильныеПериодыШкалы.Район
	|			И НомерСтрок.ЧастныйСектор = СтабильныеПериодыШкалы.ЧастныйСектор
	|			И НомерСтрок.Строение = СтабильныеПериодыШкалы.Строение
	|			И НомерСтрок.Помещение = СтабильныеПериодыШкалы.Помещение
	|			И НомерСтрок.ТочкаУчета = СтабильныеПериодыШкалы.ТочкаУчета	
	|			И НомерСтрок.НомерПозиции = СтабильныеПериодыШкалы.НомерПозиции
	|			И (СтабильныеПериодыШкалы.Организация = &Организация)
	|			И (СтабильныеПериодыШкалы.ПериодНачисления = &ПредыдущийПериод)
	|			И (СтабильныеПериодыШкалы.Район = &Район)
	|			И (СтабильныеПериодыШкалы.ЧастныйСектор = &ЧастныйСектор)
	|			И (СтабильныеПериодыШкалы.Строение В (&Строение))
	|			И (СтабильныеПериодыШкалы.Помещение = &Помещение)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////	
	|ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|" + энргНачисления.СформироватьСтрокуДляЗапроса("энргСтабильныеПериодыИзмерителиНаправлений","энргСтабильныеПериодыИзмерителиНаправлений","Организация,ПериодНачисления,НомерПозиции,ДатаРегистратора,ДокРегистратор") + "		
	|ПОМЕСТИТЬ ПараметрыИзмерителиСтаблиногоПериода
	|ИЗ
	|	НомерСтрок КАК НомерСтрок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСтабильныеПериодыИзмерителиНаправлений КАК энргСтабильныеПериодыИзмерителиНаправлений
	|		ПО НомерСтрок.Организация = энргСтабильныеПериодыИзмерителиНаправлений.Организация
	|			И НомерСтрок.ПериодНачисления = энргСтабильныеПериодыИзмерителиНаправлений.ПериодНачисления
	|			И НомерСтрок.Район = энргСтабильныеПериодыИзмерителиНаправлений.Район
	|			И НомерСтрок.ЧастныйСектор = энргСтабильныеПериодыИзмерителиНаправлений.ЧастныйСектор
	|			И НомерСтрок.Строение = энргСтабильныеПериодыИзмерителиНаправлений.Строение
	|			И НомерСтрок.Помещение = энргСтабильныеПериодыИзмерителиНаправлений.Помещение
	|			И НомерСтрок.ТочкаУчета = энргСтабильныеПериодыИзмерителиНаправлений.ТочкаУчета	
	|			И НомерСтрок.НомерПозиции = энргСтабильныеПериодыИзмерителиНаправлений.НомерПозиции
	|			И (энргСтабильныеПериодыИзмерителиНаправлений.Организация = &Организация)
	|			И (энргСтабильныеПериодыИзмерителиНаправлений.ПериодНачисления = &ПредыдущийПериод)
	|			И (энргСтабильныеПериодыИзмерителиНаправлений.Район = &Район)
	|			И (энргСтабильныеПериодыИзмерителиНаправлений.ЧастныйСектор = &ЧастныйСектор)
	|			И (энргСтабильныеПериодыИзмерителиНаправлений.Строение В (&Строение))
	|			И (энргСтабильныеПериодыИзмерителиНаправлений.Помещение = &Помещение)";
	
	Возврат Текст;
	
КонецФункции  

#КонецОбласти

#Область ОбработкаПолученныхДанных

Процедура ОчиститьДанныеПриПустомРезультатеЗапроса(ОсновныеПараметры, МВТ, ДополнительныеПараметры)
	
	Ошибки = Новый Массив;
	ПериодНачисления = ОсновныеПараметры.ПериодНачисления;
	РезультатДокументыДляПроведения = МВТ.Таблицы["ДокументыДляПроведения"].ПолучитьДанные();	
	ИмяСобытияОшибки = НСтр("ru = 'Выполнение отложенных движений физ лица. Очистка данных пустой выборки'");
	
	Если НЕ РезультатДокументыДляПроведения.Пустой() Тогда
		
		ВыборкаДокументыДляПроведения = РезультатДокументыДляПроведения.Выбрать();
		
		Пока ВыборкаДокументыДляПроведения.Следующий() Цикл
			НаборСтабильныеПериоды = РегистрыСведений.энргСтабильныеПериоды.СоздатьНаборЗаписей();
			НаборСтабильныеПериоды.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			НаборСтабильныеПериоды.Отбор.Организация.Установить(ВыборкаДокументыДляПроведения.Организация);
			НаборСтабильныеПериоды.Отбор.ПериодНачисления.Установить(ПериодНачисления);
			НаборСтабильныеПериоды.Отбор.Район.Установить(ВыборкаДокументыДляПроведения.Район);
			НаборСтабильныеПериоды.Отбор.ЧастныйСектор.Установить(ВыборкаДокументыДляПроведения.ЧастныйСектор);
			Если Не ВыборкаДокументыДляПроведения.ЧастныйСектор Тогда
				НаборСтабильныеПериоды.Отбор.Строение.Установить(ВыборкаДокументыДляПроведения.Строение);
			КонецЕсли;
			НаборСтабильныеПериоды.Отбор.ДокРегистратор.Установить(ВыборкаДокументыДляПроведения.ДокРегистратор);
			
			НаборСтабильныеПериодыШкалы	= РегистрыСведений.энргСтабильныеПериодыШкалы.СоздатьНаборЗаписей();
			НаборСтабильныеПериодыШкалы.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			НаборСтабильныеПериодыШкалы.Отбор.Организация.Установить(ВыборкаДокументыДляПроведения.Организация);
			НаборСтабильныеПериодыШкалы.Отбор.ПериодНачисления.Установить(ПериодНачисления);
			НаборСтабильныеПериодыШкалы.Отбор.Район.Установить(ВыборкаДокументыДляПроведения.Район);
			НаборСтабильныеПериодыШкалы.Отбор.ЧастныйСектор.Установить(ВыборкаДокументыДляПроведения.ЧастныйСектор);
			Если Не ВыборкаДокументыДляПроведения.ЧастныйСектор Тогда
				НаборСтабильныеПериодыШкалы.Отбор.Строение.Установить(ВыборкаДокументыДляПроведения.Строение);
			КонецЕсли;
			НаборСтабильныеПериодыШкалы.Отбор.ДокРегистратор.Установить(ВыборкаДокументыДляПроведения.ДокРегистратор);				 
			
			НаборСтабильныеПериодыИзмерителиНаправлений = РегистрыСведений.энргСтабильныеПериодыИзмерителиНаправлений.СоздатьНаборЗаписей();
			НаборСтабильныеПериодыИзмерителиНаправлений.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			НаборСтабильныеПериодыИзмерителиНаправлений.Отбор.Организация.Установить(ВыборкаДокументыДляПроведения.Организация);
			НаборСтабильныеПериодыИзмерителиНаправлений.Отбор.ПериодНачисления.Установить(ПериодНачисления);
			НаборСтабильныеПериодыИзмерителиНаправлений.Отбор.Район.Установить(ВыборкаДокументыДляПроведения.Район);
			НаборСтабильныеПериодыИзмерителиНаправлений.Отбор.ЧастныйСектор.Установить(ВыборкаДокументыДляПроведения.ЧастныйСектор);
			Если Не ВыборкаДокументыДляПроведения.ЧастныйСектор Тогда
				НаборСтабильныеПериодыИзмерителиНаправлений.Отбор.Строение.Установить(ВыборкаДокументыДляПроведения.Строение);
			КонецЕсли;
			НаборСтабильныеПериодыИзмерителиНаправлений.Отбор.ДокРегистратор.Установить(ВыборкаДокументыДляПроведения.ДокРегистратор);				 
			
			НаборНомерСтрокСтабПериода = РегистрыСведений.энргНомераСтрокСтабильногоПериода.СоздатьНаборЗаписей();
			НаборНомерСтрокСтабПериода.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			НаборНомерСтрокСтабПериода.Отбор.Организация.Установить(ВыборкаДокументыДляПроведения.Организация);
			НаборНомерСтрокСтабПериода.Отбор.ПериодНачисления.Установить(ПериодНачисления);
			НаборНомерСтрокСтабПериода.Отбор.Район.Установить(ВыборкаДокументыДляПроведения.Район);
			НаборНомерСтрокСтабПериода.Отбор.ЧастныйСектор.Установить(ВыборкаДокументыДляПроведения.ЧастныйСектор);
			Если Не ВыборкаДокументыДляПроведения.ЧастныйСектор Тогда
				НаборНомерСтрокСтабПериода.Отбор.Строение.Установить(ВыборкаДокументыДляПроведения.Строение);
			КонецЕсли;
			НаборНомерСтрокСтабПериода.Отбор.ДокРегистратор.Установить(ВыборкаДокументыДляПроведения.ДокРегистратор); 			 
			
			НаборМаксимальныеПоказания = РегистрыСведений.энргМаксимальныеПоказанияСрез.СоздатьНаборЗаписей();
			НаборМаксимальныеПоказания.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			НаборМаксимальныеПоказания.Отбор.Организация.Установить(ВыборкаДокументыДляПроведения.Организация);
			НаборМаксимальныеПоказания.Отбор.ПериодНачисления.Установить(ПериодНачисления);
			НаборМаксимальныеПоказания.Отбор.Район.Установить(ВыборкаДокументыДляПроведения.Район);
			НаборМаксимальныеПоказания.Отбор.ЧастныйСектор.Установить(ВыборкаДокументыДляПроведения.ЧастныйСектор);
			Если НЕ ВыборкаДокументыДляПроведения.ЧастныйСектор Тогда
				НаборМаксимальныеПоказания.Отбор.Строение.Установить(ВыборкаДокументыДляПроведения.Строение);
			КонецЕсли;
			
			НачатьТранзакцию();
			
			Попытка
				
				НаборСтабильныеПериоды.Записать();
				НаборСтабильныеПериодыШкалы.Записать();
				НаборСтабильныеПериодыИзмерителиНаправлений.Записать();
				НаборНомерСтрокСтабПериода.Записать(); 						
				НаборМаксимальныеПоказания.Записать();
				
				ЗафиксироватьТранзакцию();
				
			Исключение
				
				ОтменитьТранзакцию();
				
				Инфо = ИнформацияОбОшибке();
				ПредставлениеОшибки = ПодробноеПредставлениеОшибки(Инфо);
				
				Префикс = "Строение: ";
				Если НЕ ВыборкаДокументыДляПроведения.ЧастныйСектор Тогда
					Префикс = Префикс + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыборкаДокументыДляПроведения.Строение, "Наименование");
				Иначе 			
					Префикс = Префикс + "частный сектор";
				КонецЕсли;
				Ошибка = Префикс + ". Причина: " + ПредставлениеОшибки; 				
				Ошибки.Добавить(Ошибка);	
							
				ЗаписьЖурналаРегистрации(
					ИмяСобытияОшибки,
					УровеньЖурналаРегистрации.Ошибка,,,
					Ошибка);
				
			КонецПопытки;
			
		КонецЦикла;	
		
	КонецЕсли;
	
	Если Ошибки.Количество() > 0 Тогда
		ВызватьИсключение СтрСоединить(Ошибки, Символы.ПС);
	КонецЕсли;
	
КонецПроцедуры

#Область ОбработкаДанныхПриЗаполненномРезультатеЗапроса

Процедура ОбработатьДанные(ОсновныеПараметры, Выборка, Контекст, ДополнительныеПараметры)
	
	МенеджерСтабильныеПериоды = РегистрыСведений.энргСтабильныеПериоды;
	МенеджерСтабильныеПериодыШкалы = РегистрыСведений.энргСтабильныеПериодыШкалы;
	МенеджерСтабильныеПериодыИзмерителиНаправлений = РегистрыСведений.энргСтабильныеПериодыИзмерителиНаправлений;
	МенеджерНомераСтрокСтабильногоПериода = РегистрыСведений.энргНомераСтрокСтабильногоПериода;
	МенеджерМаксимальныеПоказанияСрез = РегистрыСведений.энргМаксимальныеПоказанияСрез;
	
	СоставЖильцовРазделенныхЛС = Новый Соответствие;	
	Пока Выборка.Следующий() Цикл 		
		
		МКД	= ?(НЕ Выборка.ЧастныйСектор, Выборка.Строение, Контекст.ПустоеСтроение);
		
		Если НЕ Контекст.ТекМКД = МКД тогда  
			
			СоставЖильцовРазделенныхЛС = Новый Соответствие;
			
			Если НЕ Контекст.ТекМКД = Неопределено Тогда 
				
				ОперацииПриСменеМКД(ОсновныеПараметры, Контекст);			
							
			КонецЕсли;
						
			Контекст.НаборСтабильныеПериоды = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(МенеджерСтабильныеПериоды);
			//РегистрыСведений.энргСтабильныеПериоды.СоздатьНаборЗаписей();
			//Контекст.НаборСтабильныеПериоды.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			
			Контекст.НаборСтабильныеПериодыШкалы = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(МенеджерСтабильныеПериодыШкалы);
			//РегистрыСведений.энргСтабильныеПериодыШкалы.СоздатьНаборЗаписей();
			//Контекст.НаборСтабильныеПериодыШкалы.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			
			Контекст.НаборСтабильныеПериодыИзмерителиНаправлений = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(МенеджерСтабильныеПериодыИзмерителиНаправлений);
			//РегистрыСведений.энргСтабильныеПериодыИзмерителиНаправлений.СоздатьНаборЗаписей();
			//Контекст.НаборСтабильныеПериодыИзмерителиНаправлений.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			
			Контекст.НаборНомерСтрокСтабПериода = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(МенеджерНомераСтрокСтабильногоПериода);
			//РегистрыСведений.энргНомераСтрокСтабильногоПериода.СоздатьНаборЗаписей();
			//Контекст.НаборНомерСтрокСтабПериода.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			
			Контекст.НаборМаксимальныеПоказания = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(МенеджерМаксимальныеПоказанияСрез);
			//РегистрыСведений.энргМаксимальныеПоказанияСрез.СоздатьНаборЗаписей();
			//Контекст.НаборМаксимальныеПоказания.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
			
		КонецЕсли;     		
			
		СтрокаСтабПериоды = Контекст.НаборСтабильныеПериоды.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаСтабПериоды, Выборка);	
		Если Выборка.ЭтоВводНачальныхОстатков Тогда
			ЗаполнитьСоставЖильцов(СтрокаСтабПериоды, Выборка, СоставЖильцовРазделенныхЛС);
		КонецЕсли;		
		СтрокаСтабПериоды.ПериодНачисления = ОсновныеПараметры.ПериодНачисления;
		
		//СтрокаНомеровСтрок = Контекст.НаборНомерСтрокСтабПериода.Добавить();
		//ЗаполнитьЗначенияСвойств(СтрокаНомеровСтрок, Выборка);
		//СтрокаНомеровСтрок.ПериодНачисления = ОсновныеПараметры.ПериодНачисления;
		//СтрокаНомеровСтрок.Период  			= Выборка.ДатаРегистратора;
			
		Контекст.ТекМКД = ?(НЕ Выборка.ЧастныйСектор, Выборка.Строение, Контекст.ПустоеСтроение);
	КонецЦикла;  
	
	Если НЕ Контекст.ТекМКД = Неопределено Тогда 
		
		ОперацииПриСменеМКД(ОсновныеПараметры, Контекст);
	
	КонецЕсли;	
	
КонецПроцедуры

Процедура ЗаполнитьКонтекст(Контекст, РезультатЗапроса)
	
	Контекст.Вставить("Ошибки", Новый Массив);
	Контекст.Вставить("ИмяСобытияОшибки", НСтр("ru = 'Выполнение отложенных движений физ лица. Заполнение данных'"));
	Контекст.Вставить("ПустоеСтроение", ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка"));
	Контекст.Вставить("ТекМКД", Неопределено);
	Контекст.Вставить("РазделСтабильныеПериоды", ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление.энргРазделыЗаписи.СтабильныеПериоды"));
	Контекст.Вставить("НаборСтабильныеПериоды", Неопределено);
	Контекст.Вставить("НаборНомерСтрокСтабПериода", Неопределено); 	
	
	Контекст.Вставить("ВыборкаДокументов",  РезультатЗапроса[1].Выбрать());
	Контекст.Вставить("ЕстьСледующийДокумент", Контекст.ВыборкаДокументов.Следующий());
	
	Контекст.Вставить("ВыборкаШкалы", РезультатЗапроса[3].Выбрать());
	Контекст.Вставить("НаборСтабильныеПериодыШкалы", Неопределено);
	Контекст.Вставить("ЕстьСледующийШкалы", Контекст.ВыборкаШкалы.Следующий());
	
	Контекст.Вставить("ВыборкаИзмерители", РезультатЗапроса[4].Выбрать());
	Контекст.Вставить("НаборСтабильныеПериодыИзмерителиНаправлений", Неопределено);
	Контекст.Вставить("ЕстьСледующийИзмерители", Контекст.ВыборкаИзмерители.Следующий());
	
	Контекст.Вставить("ВыборкаПоказания", РезультатЗапроса[2].Выбрать());
	Контекст.Вставить("НаборМаксимальныеПоказания", Неопределено);
	Контекст.Вставить("ЕстьСледующийПоказания", Контекст.ВыборкаПоказания.Следующий());
	
КонецПроцедуры

#Область ОперацииПриСменеМКД

Процедура ОперацииПриСменеМКД(ОсновныеПараметры, Контекст)
	
	ЗаполнитьПоказания(Контекст);	
	ЗаполнитьШкалы(Контекст);
	ЗаполнитьИзмерители(Контекст); 	
	
	Если ОсновныеПараметры.СбрасыватьСостояниеПоследовательности Тогда 
		ПодготовленныеПоследовательности = ПодготовитьДанныеПоследовательности(ОсновныеПараметры, Контекст);
	КонецЕсли;
	
	
	НачатьТранзакцию();
	
	Попытка 
		
		ОчиститьТекущиеЗаписи(ОсновныеПараметры, Контекст); 		
		
		Если ОсновныеПараметры.СбрасыватьСостояниеПоследовательности Тогда 
			СброситьСостояниеПоследовательностей(ПодготовленныеПоследовательности, ОсновныеПараметры, Контекст);			
		КонецЕсли;
		
		НаборОтложенные = РегистрыСведений.энргОтложенныеДвиженияДокументов.СоздатьНаборЗаписей();
		НаборОтложенные.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
		НаборОтложенные.Отбор.Организация.Установить(ОсновныеПараметры.Организация);
		НаборОтложенные.Отбор.ПериодНачисления.Установить(ОсновныеПараметры.ПериодНачисления);
		НаборОтложенные.Отбор.Район.Установить(ОсновныеПараметры.Район); 						
		НаборОтложенные.Отбор.РазделЗаписи.Установить(Контекст.РазделСтабильныеПериоды);
		НаборОтложенные.Отбор.ЧастныйСектор.Установить(НЕ ЗначениеЗаполнено(Контекст.ТекМКД));
		НаборОтложенные.Отбор.Строение.Установить(Контекст.ТекМКД);
		НаборОтложенные.Записать(); 
		
		Контекст.НаборСтабильныеПериоды.Записать(Ложь);
		Контекст.НаборСтабильныеПериодыШкалы.Записать(Ложь);
		Контекст.НаборСтабильныеПериодыИзмерителиНаправлений.Записать(Ложь);
		Контекст.НаборНомерСтрокСтабПериода.Записать(Ложь); 						
		Контекст.НаборМаксимальныеПоказания.Записать(Ложь);
		
		ЗафиксироватьТранзакцию();		
		 
	Исключение
		
		ОтменитьТранзакцию(); 					
		
		ПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Префикс = "Строение: ";
		Если ЗначениеЗаполнено(Контекст.ТекМКД) Тогда
			Префикс = Префикс + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Контекст.ТекМКД, "Наименование");
		Иначе 			
			Префикс = Префикс + "частный сектор";
		КонецЕсли;
		Ошибка = Префикс + ". Причина: " + ПредставлениеОшибки;
		Контекст.Ошибки.Добавить(Ошибка);
		
		ЗаписьЖурналаРегистрации(
			Контекст.ИмяСобытияОшибки,
			УровеньЖурналаРегистрации.Ошибка,,,
			Ошибка);
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаполнитьПоказания(Контекст)
	
	НаборМаксимальныеПоказания = Контекст.НаборМаксимальныеПоказания;
	ВыборкаПоказания = Контекст.ВыборкаПоказания;
	ЕстьСледующийПоказания = Контекст.ЕстьСледующийПоказания;
	
	Пока ЕстьСледующийПоказания И ?(НЕ ВыборкаПоказания.ЧастныйСектор, ВыборкаПоказания.Строение, Контекст.ПустоеСтроение) = Контекст.ТекМКД Цикл
		
		СтрокаНабораПоказаний = НаборМаксимальныеПоказания.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНабораПоказаний, ВыборкаПоказания);
		
		Если ВыборкаПоказания.ЭтоВводНачальныхОстатков Тогда
			СтрокаНабораПоказаний = НаборМаксимальныеПоказания.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаНабораПоказаний, ВыборкаПоказания);
			СтрокаНабораПоказаний.ПериодНачисления = НачалоМесяца(ВыборкаПоказания.ПериодНачисления - 1);						
		КонецЕсли; 					
		
		ЕстьСледующийПоказания = ВыборкаПоказания.Следующий();
		Если НЕ ЕстьСледующийПоказания Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьШкалы(Контекст)
	
	НаборСтабильныеПериодыШкалы = Контекст.НаборСтабильныеПериодыШкалы;
	ВыборкаШкалы = Контекст.ВыборкаШкалы;
	ЕстьСледующийШкалы = Контекст.ЕстьСледующийШкалы;
	
	Пока ЕстьСледующийШкалы И ?(НЕ ВыборкаШкалы.ЧастныйСектор, ВыборкаШкалы.Строение, Контекст.ПустоеСтроение) = Контекст.ТекМКД Цикл
		
		СтрокаНабораПоказаний = НаборСтабильныеПериодыШкалы.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНабораПоказаний, ВыборкаШкалы);
		
		ЕстьСледующийШкалы = ВыборкаШкалы.Следующий();
		Если НЕ ЕстьСледующийШкалы Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьИзмерители(Контекст)
	
	НаборСтабильныеПериодыИзмерителиНаправлений = Контекст.НаборСтабильныеПериодыИзмерителиНаправлений;
	ВыборкаИзмерители = Контекст.ВыборкаИзмерители;
	ЕстьСледующийИзмерители = Контекст.ЕстьСледующийИзмерители;
	
	Пока ЕстьСледующийИзмерители И ?(НЕ ВыборкаИзмерители.ЧастныйСектор, ВыборкаИзмерители.Строение, Контекст.ПустоеСтроение) = Контекст.ТекМКД Цикл
		
		СтрокаНабораИзмерители = НаборСтабильныеПериодыИзмерителиНаправлений.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНабораИзмерители, ВыборкаИзмерители);
		
		ЕстьСледующийИзмерители = ВыборкаИзмерители.Следующий();
		Если НЕ ЕстьСледующийИзмерители Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОчиститьТекущиеЗаписи(ОсновныеПараметры, Контекст)
	
	ЕстьСледующийДокумент = Контекст.ЕстьСледующийДокумент;
	ВыборкаДокументов = Контекст.ВыборкаДокументов;
	
	// Очищаем набор записей и создаем приемники данных.
	Пока ЕстьСледующийДокумент И ?(НЕ ВыборкаДокументов.ЧастныйСектор, ВыборкаДокументов.Строение, Контекст.ПустоеСтроение) = Контекст.ТекМКД Цикл
		
		ОчиститьНаборыЗаписей(
			ОсновныеПараметры.Организация, 
			ОсновныеПараметры.ПериодНачисления, 
			ОсновныеПараметры.Район,
			ВыборкаДокументов.ЧастныйСектор, 
			ВыборкаДокументов.Строение, 
			ВыборкаДокументов.ДокРегистратор, 
			ВыборкаДокументов.ЭтоВводНачальныхОстатков);
		
		ЕстьСледующийДокумент = ВыборкаДокументов.Следующий();
		Если НЕ ЕстьСледующийДокумент Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОчиститьНаборыЗаписей(Организация, ПериодНачисления, Район, ЧастныйСектор, Строение, ДокРегистратор, ВводНачальныхОстатков)
	
	НаборСтабильныеПериоды = РегистрыСведений.энргСтабильныеПериоды.СоздатьНаборЗаписей();
	НаборСтабильныеПериоды.ДополнительныеСвойства.Вставить("НеПроверятьДатуЗапретаРедактирования",Истина);
	НаборСтабильныеПериоды.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	НаборСтабильныеПериоды.Отбор.Организация.Установить(Организация);
	НаборСтабильныеПериоды.Отбор.ПериодНачисления.Установить(ПериодНачисления);
	НаборСтабильныеПериоды.Отбор.Район.Установить(Район);
	НаборСтабильныеПериоды.Отбор.ЧастныйСектор.Установить(ЧастныйСектор);
	Если НЕ ЧастныйСектор Тогда 
		НаборСтабильныеПериоды.Отбор.Строение.Установить(Строение);
	КонецЕсли;
	НаборСтабильныеПериоды.записать();
	
	НаборСтабильныеПериоды = РегистрыСведений.энргСтабильныеПериодыШкалы.СоздатьНаборЗаписей();
	НаборСтабильныеПериоды.ДополнительныеСвойства.Вставить("НеПроверятьДатуЗапретаРедактирования",Истина);
	НаборСтабильныеПериоды.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	НаборСтабильныеПериоды.Отбор.Организация.Установить(Организация);
	НаборСтабильныеПериоды.Отбор.ПериодНачисления.Установить(ПериодНачисления);
	НаборСтабильныеПериоды.Отбор.Район.Установить(Район);
	НаборСтабильныеПериоды.Отбор.ЧастныйСектор.Установить(ЧастныйСектор);
	Если НЕ ЧастныйСектор Тогда 
		НаборСтабильныеПериоды.Отбор.Строение.Установить(Строение);
	КонецЕсли;
	НаборСтабильныеПериоды.записать();
	  	
	НаборСтабильныеПериоды = РегистрыСведений.энргСтабильныеПериодыИзмерителиНаправлений.СоздатьНаборЗаписей();
	НаборСтабильныеПериоды.ДополнительныеСвойства.Вставить("НеПроверятьДатуЗапретаРедактирования",Истина);
	НаборСтабильныеПериоды.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	НаборСтабильныеПериоды.Отбор.Организация.Установить(Организация);
	НаборСтабильныеПериоды.Отбор.ПериодНачисления.Установить(ПериодНачисления);
	НаборСтабильныеПериоды.Отбор.Район.Установить(Район);
	НаборСтабильныеПериоды.Отбор.ЧастныйСектор.Установить(ЧастныйСектор);
	Если НЕ ЧастныйСектор Тогда 
		НаборСтабильныеПериоды.Отбор.Строение.Установить(Строение);
	КонецЕсли;
	НаборСтабильныеПериоды.записать();
	
	НаборНомерСтрокСтабПериода = РегистрыСведений.энргНомераСтрокСтабильногоПериода.СоздатьНаборЗаписей();
	НаборНомерСтрокСтабПериода.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	НаборНомерСтрокСтабПериода.Отбор.Организация.Установить(Организация);
	НаборНомерСтрокСтабПериода.Отбор.ПериодНачисления.Установить(ПериодНачисления);
	НаборНомерСтрокСтабПериода.Отбор.Район.Установить(Район);
	НаборНомерСтрокСтабПериода.Отбор.ЧастныйСектор.Установить(ЧастныйСектор);
	Если НЕ ЧастныйСектор Тогда 
		НаборНомерСтрокСтабПериода.Отбор.Строение.Установить(Строение);
	КонецЕсли;
	НаборНомерСтрокСтабПериода.Записать();
	
	НаборМаксимальныеПоказания = РегистрыСведений.энргМаксимальныеПоказанияСрез.СоздатьНаборЗаписей();
	НаборМаксимальныеПоказания.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых", Истина);
	НаборМаксимальныеПоказания.Отбор.Организация.Установить(Организация);
	НаборМаксимальныеПоказания.Отбор.ПериодНачисления.Установить(ПериодНачисления);
	НаборМаксимальныеПоказания.Отбор.Район.Установить(Район);
	НаборМаксимальныеПоказания.Отбор.ЧастныйСектор.Установить(ЧастныйСектор);
	Если НЕ ЧастныйСектор Тогда 
		НаборМаксимальныеПоказания.Отбор.Строение.Установить(Строение);
	КонецЕсли;
	НаборМаксимальныеПоказания.Записать();
	
	Если ВводНачальныхОстатков тогда
		
		ПредыдущийПериод = НачалоМесяца(ПериодНачисления-1);
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргМаксимальныеПоказанияСрез.ПриборУчета КАК ПриборУчета
		|ИЗ
		|	РегистрСведений.энргМаксимальныеПоказанияСрез КАК энргМаксимальныеПоказанияСрез
		|ГДЕ
		|	энргМаксимальныеПоказанияСрез.Организация = &Организация
		|	И энргМаксимальныеПоказанияСрез.ПериодНачисления = &ПериодНачисления
		|	И энргМаксимальныеПоказанияСрез.Район = &Район
		|	И энргМаксимальныеПоказанияСрез.ЧастныйСектор = &ЧастныйСектор
		|	И энргМаксимальныеПоказанияСрез.Строение = &Строение
		|	И энргМаксимальныеПоказанияСрез.ДокРегистратор = &ДокРегистратор
		|
		|СГРУППИРОВАТЬ ПО
		|	энргМаксимальныеПоказанияСрез.ПриборУчета";
		Запрос.УстановитьПараметр("Организация",		Организация);
		Запрос.УстановитьПараметр("ПериодНачисления",	ПредыдущийПериод);
		Запрос.УстановитьПараметр("Район",				Район);
		Запрос.УстановитьПараметр("ЧастныйСектор",		ЧастныйСектор);
		Запрос.УстановитьПараметр("ДокРегистратор",		ДокРегистратор);
		Если НЕ ЧастныйСектор Тогда 
			Запрос.УстановитьПараметр("Строение",		Строение);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргМаксимальныеПоказанияСрез.Строение = &Строение", "");
		КонецЕсли;
		ВыборкаМаксПок = Запрос.Выполнить().Выбрать();
		Пока ВыборкаМаксПок.Следующий() Цикл 
			
			НаборМаксимальныеПоказания = РегистрыСведений.энргМаксимальныеПоказанияСрез.СоздатьНаборЗаписей();
			НаборМаксимальныеПоказания.Отбор.Организация.Установить(Организация);
			НаборМаксимальныеПоказания.Отбор.ПериодНачисления.Установить(ПредыдущийПериод);
			НаборМаксимальныеПоказания.Отбор.Район.Установить(Район);
			НаборМаксимальныеПоказания.Отбор.ЧастныйСектор.Установить(ЧастныйСектор);
			Если НЕ ЧастныйСектор Тогда 
				НаборМаксимальныеПоказания.Отбор.Строение.Установить(Строение);
			КонецЕсли;
			НаборМаксимальныеПоказания.Отбор.ПриборУчета.Установить(ВыборкаМаксПок.ПриборУчета);
			НаборМаксимальныеПоказания.Записать();
		КонецЦикла;
	КонецЕсли; 
	
	
	//// ИЗ-ЗА этого возникает конфликт блокировок
	//НаборОтложенныхДвижений = РегистрыСведений.энргОтложенныеДвиженияДокументов.СоздатьНаборЗаписей();
	//НаборОтложенныхДвижений.Отбор.ДокРегистратор.Установить(ДокРегистратор);
	//НаборОтложенныхДвижений.Записать();
	
КонецПроцедуры

#Область СбросПоследовательностей

Функция ПодготовитьДанныеПоследовательности(ОсновныеПараметры, Контекст)
	
	Результат = Новый Структура;
	
	РезультатЗапросаСтабильные = РезультатЗапросаСостояниеПоследовательностиСтабильные(
		ОсновныеПараметры,
		Контекст.ТекМКД);		
	
	РезультатЗапросаПоказания = РезультатЗапросаСостояниеПоследовательностиПоказания(
		ОсновныеПараметры,
		Контекст.ТекМКД);
	
	РезультатЗапросаВзаиморасчеты = РезультатЗапросаСостояниеПоследовательностиВзаиморасчеты(
		ОсновныеПараметры,
		Контекст.ТекМКД);
		
	Результат.Вставить("энргСтабильныеПериодыПоследовательность", РезультатЗапросаСтабильные);
	Результат.Вставить("энргПоказанияПУПоследовательность", РезультатЗапросаПоказания);
	Результат.Вставить("энргВзаиморасчетыПоследовательность", РезультатЗапросаВзаиморасчеты);
	
	Возврат Результат;
	
КонецФункции

Функция РезультатЗапросаСостояниеПоследовательностиСтабильные(ОсновныеПараметры, Строение, Помещение = Неопределено)
	
	ЧастныйСектор = НЕ ЗначениеЗаполнено(Строение);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСтабильныеПериодыПоследовательность.Организация КАК Организация,
		|	энргСтабильныеПериодыПоследовательность.ПериодНачисления КАК ПериодНачисления,
		|	энргСтабильныеПериодыПоследовательность.Район КАК Район,
		|	ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности) КАК СостояниеПроведения,
		|	энргСтабильныеПериодыПоследовательность.ЧастныйСектор КАК ЧастныйСектор,
		|	энргСтабильныеПериодыПоследовательность.Строение КАК Строение,
		|	энргСтабильныеПериодыПоследовательность.Помещение КАК Помещение,
		|	энргСтабильныеПериодыПоследовательность.ПериодРегистрации КАК ПериодРегистрации,
		|	энргСтабильныеПериодыПоследовательность.ДатаРегистратора КАК ДатаРегистратора,
		|	энргСтабильныеПериодыПоследовательность.ДокРегистратор КАК ДокРегистратор,
		|	энргСтабильныеПериодыПоследовательность.УдалитьАбонент КАК УдалитьАбонент
		|ИЗ
		|	РегистрСведений.энргСтабильныеПериодыПоследовательность КАК энргСтабильныеПериодыПоследовательность
		|ГДЕ
		|	энргСтабильныеПериодыПоследовательность.Организация = &Организация
		|	И энргСтабильныеПериодыПоследовательность.ПериодНачисления = &ПериодНачисления
		|	И энргСтабильныеПериодыПоследовательность.Район = &Район
		|	И энргСтабильныеПериодыПоследовательность.СостояниеПроведения = ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности)
		|	И энргСтабильныеПериодыПоследовательность.ЧастныйСектор = &ЧастныйСектор
		|	И энргСтабильныеПериодыПоследовательность.Строение = &Строение
		|	И энргСтабильныеПериодыПоследовательность.Помещение = &Помещение";   	
	                                      
	Запрос.УстановитьПараметр("Организация", ОсновныеПараметры.Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", ОсновныеПараметры.ПериодНачисления);
	Запрос.УстановитьПараметр("Район", ОсновныеПараметры.Район);
	Запрос.УстановитьПараметр("ЧастныйСектор", ЧастныйСектор);
	Если НЕ ЧастныйСектор Тогда
		Запрос.УстановитьПараметр("Строение", Строение);
		Если Помещение = Неопределено Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргСтабильныеПериодыПоследовательность.Помещение = &Помещение", "");	
		Иначе 			
			Запрос.УстановитьПараметр("Помещение", Помещение);
		КонецЕсли;
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргСтабильныеПериодыПоследовательность.Строение = &Строение", "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргСтабильныеПериодыПоследовательность.Помещение = &Помещение", "");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();	
	Возврат РезультатЗапроса;
	
КонецФункции

Функция РезультатЗапросаСостояниеПоследовательностиПоказания(ОсновныеПараметры, Строение, Помещение = Неопределено)
	
	ЧастныйСектор = НЕ ЗначениеЗаполнено(Строение);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргПоказанияПУПоследовательность.Организация КАК Организация,
		|	энргПоказанияПУПоследовательность.ПериодНачисления КАК ПериодНачисления,
		|	энргПоказанияПУПоследовательность.Район КАК Район,
		|	ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности) КАК СостояниеПроведения,
		|	энргПоказанияПУПоследовательность.ЧастныйСектор КАК ЧастныйСектор,
		|	энргПоказанияПУПоследовательность.Строение КАК Строение,
		|	энргПоказанияПУПоследовательность.Помещение КАК Помещение,
		|	энргПоказанияПУПоследовательность.ПриборУчета КАК ПриборУчета,
		|	энргПоказанияПУПоследовательность.ПериодРегистрации КАК ПериодРегистрации,
		|	энргПоказанияПУПоследовательность.Разделитель КАК Разделитель,
		|	энргПоказанияПУПоследовательность.ДатаРегистратора КАК ДатаРегистратора,
		|	энргПоказанияПУПоследовательность.ДокРегистратор КАК ДокРегистратор,
		|	энргПоказанияПУПоследовательность.ВыводПрибораУчета КАК ВыводПрибораУчета,
		|	энргПоказанияПУПоследовательность.ИмяТабЧасти КАК ИмяТабЧасти
		|ИЗ
		|	РегистрСведений.энргПоказанияПУПоследовательность КАК энргПоказанияПУПоследовательность
		|ГДЕ
		|	энргПоказанияПУПоследовательность.Организация = &Организация
		|	И энргПоказанияПУПоследовательность.ПериодНачисления = &ПериодНачисления
		|	И энргПоказанияПУПоследовательность.Район = &Район
		|	И энргПоказанияПУПоследовательность.СостояниеПроведения = ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности)
		|	И энргПоказанияПУПоследовательность.ЧастныйСектор = &ЧастныйСектор
		|	И энргПоказанияПУПоследовательность.Строение = &Строение
		|	И энргПоказанияПУПоследовательность.Помещение = &Помещение";   	
	                                      
	Запрос.УстановитьПараметр("Организация", ОсновныеПараметры.Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", ОсновныеПараметры.ПериодНачисления);
	Запрос.УстановитьПараметр("Район", ОсновныеПараметры.Район);
	Запрос.УстановитьПараметр("ЧастныйСектор", ЧастныйСектор);
	Если НЕ ЧастныйСектор Тогда
		Запрос.УстановитьПараметр("Строение", Строение);
		Если Помещение = Неопределено Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргПоказанияПУПоследовательность.Помещение = &Помещение", "");	
		Иначе 			
			Запрос.УстановитьПараметр("Помещение", Помещение);
		КонецЕсли;
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргПоказанияПУПоследовательность.Строение = &Строение", "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргПоказанияПУПоследовательность.Помещение = &Помещение", "");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();	
	Возврат РезультатЗапроса;
	
КонецФункции

Функция РезультатЗапросаСостояниеПоследовательностиВзаиморасчеты(ОсновныеПараметры, Строение, Помещение = Неопределено)
	
	ЧастныйСектор = НЕ ЗначениеЗаполнено(Строение);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргВзаиморасчетыПоследовательность.Организация КАК Организация,
		|	энргВзаиморасчетыПоследовательность.ПериодНачисления КАК ПериодНачисления,
		|	энргВзаиморасчетыПоследовательность.Район КАК Район,
		|	ЗНАЧЕНИЕ(Перечисление.энргСостояниеДокументаВПоследовательности.ПроведенСНарушениемПоследовательности) КАК СостояниеПроведения,
