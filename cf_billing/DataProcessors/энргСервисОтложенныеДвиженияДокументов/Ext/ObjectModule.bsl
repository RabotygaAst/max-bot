#Область РаботаССоставомЖильцом

Процедура ЗаполнитьСоставЖильцов(СтрокаСтабПериоды, Выборка, СоставЖильцовРазделенныхЛС)
	Если НЕ ЗначениеЗаполнено(Выборка.Абонент) Тогда
		   СтрокаСтабПериоды.СоставЖильцов = СоставЖильцовРазделенныхЛС[Выборка.Помещение];
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Выборка.ПомещениеРодитель) Тогда
		Если СоставЖильцовРазделенныхЛС[Выборка.ПомещениеРодитель] = Неопределено Тогда
			СоставЖильцовРазделенныхЛС.Вставить(Выборка.ПомещениеРодитель, ПолучитьСоставЖильцов(Выборка))
		Иначе
			СоставЖильцовРазделенныхЛС[Выборка.ПомещениеРодитель] = ПолучитьСоставЖильцов(Выборка, СоставЖильцовРазделенныхЛС[Выборка.ПомещениеРодитель]);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьСоставЖильцов(Выборка, стрСоставЖильцов = "")
	
	яСоставЖильцов 						= Новый ФиксированнаяСтруктура("КоличествоПроживающих,КоличествоПрописанных,КоличествоСобственников", 0, 0, 0);
	
	IDКлючПомещения 					= "" + Выборка.КлючПомещения.УникальныйИдентификатор();
	СоставЖильцов  						= Новый Соответствие;
	Если НЕ ПустаяСтрока(стрСоставЖильцов) Тогда
		Чтение  						= Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(стрСоставЖильцов);
		СоставЖильцов 					= ПрочитатьJSON(Чтение,Истина);
	КонецЕсли;
	
	Если СоставЖильцов[IDКлючПомещения] = Неопределено Тогда
		Значение 						= Новый Структура(яСоставЖильцов);
		ЗаполнитьЗначенияСвойств(Значение,Выборка); 
		СоставЖильцов.Вставить(IDКлючПомещения, Значение);
	Иначе
		Значение 						= Новый Структура(яСоставЖильцов);
		ЗаполнитьЗначенияСвойств(Значение,Выборка);
		СоставЖильцов[IDКлючПомещения] 	= Значение;
	КонецЕсли; 	
	
	Запись 								= Новый ЗаписьJSON;
	Запись.УстановитьСтроку();	
	ЗаписатьJSON(Запись,СоставЖильцов);
	
	Возврат Запись.Закрыть()
	
КонецФункции
	
#КонецОбласти

#Область РаботаССреднимОбъемомПотребления

// ПЕРЕНЕСТИ ОБЛАСТЬ В ДРУГОЙ МОДУЛЬ
////////////////////////////////////

Процедура ПересчитатьСреднийОбъемПотребления(ОсновныеПараметры)
	
	Организация = ОсновныеПараметры.Организация;
	ПериодНачисления = ОсновныеПараметры.ПериодНачисления;
	Район = ОсновныеПараметры.Район;
	Строение = ОсновныеПараметры.Строение;	
	
	ЧастныйСектор = Неопределено;
	Если Не Строение = Неопределено И ЗначениеЗаполнено(Строение) Тогда
		ЧастныйСектор = Ложь;
	ИначеЕсли Не Строение = Неопределено Тогда
		ЧастныйСектор = Истина;		
	КонецЕсли;	
	
	Если НЕ ЧастныйСектор = Неопределено И ЧастныйСектор И НЕ Строение = Неопределено И НЕ ЗначениеЗаполнено(Строение) Тогда
		ПересчитатьСреднийОбъемПотребленияАбонентов(Организация, ПериодНачисления, Район, ЧастныйСектор);
	Иначе
		ПересчитатьСреднийОбъемПотребленияАбонентов(Организация, ПериодНачисления, Район, ЧастныйСектор, Строение);
	КонецЕсли;
	
КонецПроцедуры

// Выполнение регламентных процедур
//
// Параметры:
//   ПериодНачисления 		- Период начисления, по которому происходит восстановление последовательности.
