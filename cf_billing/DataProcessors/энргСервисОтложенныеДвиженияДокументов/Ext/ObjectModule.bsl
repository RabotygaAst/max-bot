#Область СлужебныйПрограммныйИнтерфейс

Процедура ВыполнитьОтложенныеДвиженияДокументов(ОсновныеПараметры, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если НЕ РазрешеноВыполнятьОперацию(ОсновныеПараметры) Тогда 
		Возврат;
	КонецЕсли;
	
	ГраницыПериода = Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(
		ОсновныеПараметры.Организация, 
		ОсновныеПараметры.Район, 
		ОсновныеПараметры.ПериодНачисления, 
		Ложь);
	
	МВТ = Новый МенеджерВременныхТаблиц;	
	РезультатЗапроса = РезультатНачальныеОстаткиСтабильногоПериода(
		МВТ,
		ОсновныеПараметры,
		ГраницыПериода.НачалоОП);
		
		
	Выборка = РезультатЗапроса[0].Выбрать();	
	Если Выборка.Количество() = 0 тогда		
		
		ПересчитатьСреднийОбъемПотребления(ОсновныеПараметры);	
		ОчиститьДанныеПриПустомРезультатеЗапроса(ОсновныеПараметры, МВТ, ДополнительныеПараметры);
		Возврат;
		
	КонецЕсли;	
		
	МВТ.Закрыть(); 	
	
	Контекст = Новый Структура;
	ЗаполнитьКонтекст(Контекст, РезультатЗапроса);
	ОбработатьДанные(ОсновныеПараметры, Выборка, Контекст, ДополнительныеПараметры);		
	
	Если Контекст.Ошибки.Количество() > 0 Тогда
		ВызватьИсключение СтрСоединить(Контекст.Ошибки, Символы.ПС);
	КонецЕсли;
	
	ПересчитатьСреднийОбъемПотребления(ОсновныеПараметры);	
	
КонецПроцедуры

Функция НовыеОсновныеПараметры() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ПериодНачисления", Дата(1, 1, 1));
	Результат.Вставить("Организация", Справочники.Организации.НашаОрганизация);
	Результат.Вставить("Район", Справочники.энргЗоныОтвественности.ПустаяСсылка());	
	Результат.Вставить("ЧастныйСектор", Неопределено);
	Результат.Вставить("Строение", Неопределено);
	Результат.Вставить("Помещение", Неопределено);	
	Результат.Вставить("Строения", Неопределено);
	Результат.Вставить("СбрасыватьСостояниеПоследовательности", Истина);
	
	Возврат Результат
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Валидация

Функция РазрешеноВыполнятьОперацию(ПроверяемыеПоля)
	
	Если НЕ ЗначениеЗаполнено(ПроверяемыеПоля.ПериодНачисления) ИЛИ НЕ ЗначениеЗаполнено(ПроверяемыеПоля.Район) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	ОбъектПроверки = Документы.энргРегистрацияПоказанийАбонента.СоздатьДокумент();
	ОбъектПроверки.Организация = ПроверяемыеПоля.Организация;
	ОбъектПроверки.Дата	= ПроверяемыеПоля.ПериодНачисления;
	ОбъектПроверки.Район = ПроверяемыеПоля.Район;
	
	Отказ = энргДатыЗапретаИзмененияПереопределяемый.ЗапрещеноИзменятьДанные(ОбъектПроверки);
		
	Если Отказ Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Для пользователя " + Пользователи.ТекущийПользователь() + 
			" район " + ПроверяемыеПоля.Район + " период " + ПроверяемыеПоля.ПериодНачисления + 
			" закрыт для редактирования");
	КонецЕсли; 		
	
	Возврат НЕ Отказ;
	
КонецФункции

#КонецОбласти

#Область ПолучениеДанных

Функция РезультатНачальныеОстаткиСтабильногоПериода(МВТ, ОсновныеПараметры, ПериодРегистрации)
	
	Организация = ОсновныеПараметры.Организация;
	ПериодНачисления = ОсновныеПараметры.ПериодНачисления;
	Район = ОсновныеПараметры.Район;
	Строение = ОсновныеПараметры.Строение;
	Помещение = ОсновныеПараметры.Помещение;
	
	
	Разделить = "
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";  
	
