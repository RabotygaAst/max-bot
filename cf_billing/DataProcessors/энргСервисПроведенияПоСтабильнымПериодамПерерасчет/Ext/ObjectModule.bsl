#Область СлужебныеПроцедурыИФункции

Функция ПолучитьДанныеВременнойТаблицы(МВТ,ИмяТаблицы,ПоляПорядка)
	
	Таблица 						= МВТ.Таблицы[ИмяТаблицы];
	Схема 							= Новый СхемаЗапроса;
	Пакет 							= Схема.ПакетЗапросов[0];
	Источник 						= Пакет.Операторы[0].Источники.Добавить(Тип("ОписаниеВременнойТаблицыСхемыЗапроса"),ИмяТаблицы,ИмяТаблицы);
	Оператор 						= Пакет.Операторы[0];
	Для Каждого КолонкаВт ИЗ Таблица.Колонки Цикл
		ДобавитьКолонкуЗапросаИзВременнойТаблицы(Оператор,Источник.Источник,Пакет.Колонки,МВТ,0,ИмяТаблицы,КолонкаВт.Имя,"");
	КонецЦикла;
	
	мПоляПорядка 					= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ПоляПорядка);
	Для Сч = 0 По мПоляПорядка.ВГраница() Цикл
		Если Пакет.Колонки.Найти(мПоляПорядка[Сч]) = Неопределено Тогда
			Продолжить;
		КонецЕсли; 		
		Пакет.Порядок.Добавить(мПоляПорядка[Сч]);
	КонецЦикла;
		
	Запрос  						= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
	Возврат Запрос.Выполнить();
	
КонецФункции

Процедура ЗаполнитьСхемуЗапросаПромежуточнымиДанными(Схема, СоотвествиеПолей)
	
	Параметры 								= Новый Массив;
	Параметры.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", СоотвествиеПолей));
	Параметры.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраВСписке", Новый Структура("Помещение","мПомещения")));
	
	РегистрыСведений.энргСтабильныеПериодыПоследовательность.НаборДокументовДляПроведенияПоФактическомуПериоду(Схема,Параметры,ИмяТаблицыПериодов,"ДокументыДляПроведения");
	Параметры[0].СоотвествиеПолей.Вставить("ПериодНачисления", "ПериодНачисленияНачало");
	РегистрыСведений.энргСтабильныеПериоды.СостояниеНаНачалоПериодаНачисления(Схема,Параметры,"СостояниеНаНачалоПериодаНачисления");
	Параметры[0].СоотвествиеПолей.Удалить("ПериодНачисления");
	
	ИзменяемыеПараметрыПоТипам 				= Новый Соответствие;
	
	ТаблицыДанных	 						= Новый Массив;	
	ТипыОбъектовИзмененияСостояния			= Метаданные.ОпределяемыеТипы.энргОбъектыИзмененияСтабильногоПериода.Тип.Типы();
	Для Каждого ТипОбъекта Из ТипыОбъектовИзмененияСостояния Цикл
		МетаданныеИмя 						= Метаданные.НайтиПоТипу(ТипОбъекта);		
		Менеджер 							= Новый (Тип("ДокументМенеджер." + МетаданныеИмя.Имя));
		ТипСсылка 							= Тип("ДокументСсылка." + МетаданныеИмя.Имя); 
		Если ТипСсылка = Тип("ДокументСсылка.энргОперацияСУслугами") И Не ПодключениеУслугиПервыйДокумент Тогда
			ИзменяемыеПараметрыРасчета 			= Менеджер.ИзменяемыеПараметрыРасчета(Ложь);
		Иначе 
			ИзменяемыеПараметрыРасчета 			= Менеджер.ИзменяемыеПараметрыРасчета();
		КонецЕсли;
		ИзменяемыеПараметрыПоТипам.Вставить(ТипСсылка, ИзменяемыеПараметрыРасчета);		
		Менеджер.ПолучитьДанныеДляПроведенияПоСтабильнымПериодам(Схема, ТаблицыДанных);		
	КонецЦикла;
	
	ТаблицыИзмененияПлощади  				= Новый Массив;
	ТипыОбъектовИзмененияПлощади 			= Метаданные.ОпределяемыеТипы.энргОбъектыИзмененияПлощади.Тип.Типы();
	Для Каждого ТипОбъекта Из ТипыОбъектовИзмененияПлощади Цикл
		МетаданныеИмя 						= Метаданные.НайтиПоТипу(ТипОбъекта);		
		Менеджер 							= Новый (Тип("ДокументМенеджер." + МетаданныеИмя.Имя));	
		ТипСсылка 							= Тип("ДокументСсылка." + МетаданныеИмя.Имя);
		Если ИзменяемыеПараметрыПоТипам[ТипСсылка] = Неопределено Тогда
			ИзменяемыеПараметрыРасчета 		= Менеджер.ИзменяемыеПараметрыРасчета();			
			ИзменяемыеПараметрыПоТипам.Вставить(ТипСсылка, ИзменяемыеПараметрыРасчета);
		КонецЕсли;
		Менеджер.ПолучитьДанныеИзмененияПлощади(Схема, ТаблицыИзмененияПлощади);		
	КонецЦикла;
	
	ТаблицыИзмененияШкал  					= Новый Массив;
	ТипыОбъектовИзмененияСоставаШкал		= Метаданные.ОпределяемыеТипы.энргОбъектыИзмененияШкал.Тип.Типы();
	Для Каждого ТипОбъекта Из ТипыОбъектовИзмененияСоставаШкал Цикл
		МетаданныеИмя 						= Метаданные.НайтиПоТипу(ТипОбъекта);		
		Менеджер 							= Новый (Тип("ДокументМенеджер." + МетаданныеИмя.Имя));	
		ТипСсылка 							= Тип("ДокументСсылка." + МетаданныеИмя.Имя);
		Если ИзменяемыеПараметрыПоТипам[ТипСсылка] = Неопределено Тогда
			ИзменяемыеПараметрыРасчета 		= Менеджер.ИзменяемыеПараметрыРасчета();		
			ИзменяемыеПараметрыПоТипам.Вставить(ТипСсылка, ИзменяемыеПараметрыРасчета);
		КонецЕсли;
		Менеджер.ПолучитьДанныеИзмененияСоставаШкал(Схема, ТаблицыИзмененияШкал);		
	КонецЦикла;	
	
	ТаблицыИзмененияИзмерителей				= Новый Массив;
	ТипыОбъектовИзмененияСоставаШкал		= Метаданные.ОпределяемыеТипы.энргОбъектыИзмененияИзмерителей.Тип.Типы();
	Для Каждого ТипОбъекта Из ТипыОбъектовИзмененияСоставаШкал Цикл
		МетаданныеИмя 						= Метаданные.НайтиПоТипу(ТипОбъекта);		
		Менеджер 							= Новый (Тип("ДокументМенеджер." + МетаданныеИмя.Имя));	
		ТипСсылка 							= Тип("ДокументСсылка." + МетаданныеИмя.Имя);
		Если ИзменяемыеПараметрыПоТипам[ТипСсылка] = Неопределено Тогда
			ИзменяемыеПараметрыРасчета 		= Менеджер.ИзменяемыеПараметрыРасчета();		
			ИзменяемыеПараметрыПоТипам.Вставить(ТипСсылка, ИзменяемыеПараметрыРасчета);
		КонецЕсли;
		Менеджер.ПолучитьДанныеИзмененияИзмерителей(Схема, ТаблицыИзмененияИзмерителей);		
	КонецЦикла;
	
КонецПроцедуры

Процедура ПолучитьПомежуточныеДанные(Схема, МВТ, СоотвествиеПолей)
	
	Запрос  								= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.МенеджерВременныхТаблиц 			= Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", 			Организация);
	Запрос.УстановитьПараметр("ПериодНачисленияНачало", ПериодНачисленияНачало);
	Запрос.УстановитьПараметр("Район", 					Район);
	Запрос.УстановитьПараметр("ЧастныйСектор", 			ЧастныйСектор);
	Запрос.УстановитьПараметр("Строение", 				Строение);
	Запрос.УстановитьПараметр("мПомещения", 			мПомещения);
    ГраницыОтчетногоПериода 				= Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ДобавитьМесяц(ПериодНачисленияЗавершение, 1));
	Запрос.УстановитьПараметр("ОкончаниеПериода",			ГраницыОтчетногоПериода.ЗавершениеОП);

	Запрос.Выполнить();
	МВТ 									= Запрос.МенеджерВременныхТаблиц;
	
КонецПроцедуры

Процедура ДобавитьКолонкуЗапросаИзВременнойТаблицы(Оператор,Источник,КолонкиЗапроса,МВТ,Индекс,ИмяТаблицы,ИмяКолонки,ЗначениеПоУмолчанию) 
	
	Если НЕ МВТ.Таблицы[ИмяТаблицы].Колонки.Найти(ИмяКолонки) = Неопределено Тогда  
		КолонкаТаблицы 			= МВТ.Таблицы[ИмяТаблицы].Колонки[ИмяКолонки];
		Источник.ДоступныеПоля.Добавить(ИмяКолонки,КолонкаТаблицы.ТипЗначения);		
		Если Индекс = 0 Тогда
			Оператор.ВыбираемыеПоля.Добавить(КолонкаТаблицы.Имя);
			Колонка 			= КолонкиЗапроса[КолонкиЗапроса.Количество()-1];
			Колонка.Псевдоним 	= КолонкаТаблицы.Имя;
		Иначе
			Оператор.ВыбираемыеПоля.Добавить(КолонкаТаблицы.Имя, КолонкиЗапроса.Индекс(КолонкиЗапроса.Найти(ИмяКолонки)));
		КонецЕсли;
	Иначе
		Если Индекс = 0 Тогда
			Оператор.ВыбираемыеПоля.Добавить(ЗначениеПоУмолчанию);
			Колонка 			= КолонкиЗапроса[КолонкиЗапроса.Количество()-1];
			Колонка.Псевдоним 	= ИмяКолонки;
		Иначе
			Оператор.ВыбираемыеПоля.Добавить(ЗначениеПоУмолчанию, КолонкиЗапроса.Индекс(КолонкиЗапроса.Найти(ИмяКолонки)));
		КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьНачальныеОстаткиПериодаНачисления()
	
	ЗаполнитьНачальныеОстаткиПериодаНачисленияНаборПериоды();
	ЗаполнитьНачальныеОстаткиПериодаНачисленияНаборШкалы();
	ЗаполнитьНачальныеОстаткиПериодаНачисленияНаборИзмерители();
	
КонецПроцедуры

Процедура ЗаполнитьНачальныеОстаткиПериодаНачисленияНаборПериоды()
	
	ТекущиеДанныеПомещения 						= Новый Соответствие;
	
	Для Каждого СтрокаНабора Из НаборПериоды Цикл
		
		Если НЕ СтрокаНабора.ПериодНачисления  = ДобавитьМесяц(ТекущийПериодНачисления,-1) Тогда
			Продолжить;
		КонецЕсли;
		ИндексСтроки  							= НаборПериоды.Индекс(СтрокаНабора);
		Если ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета] = Неопределено Тогда
			
			СоотвествиеУслуга  					= Новый Соответствие;
			СоотвествиеУслуга.Вставить(СтрокаНабора.Услуга, Новый Структура("НомерПозиции,ИндексСтроки", СтрокаНабора.НомерПозиции, ИндексСтроки));
			ТекущиеДанныеПомещения.Вставить(СтрокаНабора.ТочкаУчета, СоотвествиеУслуга);
			
		ИначеЕсли ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета][СтрокаНабора.Услуга] = Неопределено Тогда 
			
			ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета].Вставить(СтрокаНабора.Услуга, Новый Структура("НомерПозиции,ИндексСтроки", СтрокаНабора.НомерПозиции, ИндексСтроки));
			
		ИначеЕсли ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета][СтрокаНабора.Услуга].НомерПозиции < СтрокаНабора.НомерПозиции Тогда
			ЗначениеСоотвествия 				= ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета][СтрокаНабора.Услуга];
			ЗначениеСоотвествия.НомерПозиции 	= СтрокаНабора.НомерПозиции;
			ЗначениеСоотвествия.ИндексСтроки 	=	 ИндексСтроки;
			
		КонецЕсли;		
	КонецЦикла;
	  	
	ГраницыОП 									= энргНачисления.ГраницыОтчетногоПериода(Организация,Район,ТекущийПериодНачисления);
	
	Для Каждого КлючЗначениеТочкаУчета Из ТекущиеДанныеПомещения Цикл
		Для Каждого КлючЗначениеУслуга Из КлючЗначениеТочкаУчета.Значение Цикл
			ЗначениеСоотвествия					= КлючЗначениеУслуга.Значение;
			ИсходнаяСтрока 						= НаборПериоды[ЗначениеСоотвествия.ИндексСтроки];
			НоваяСтрока 						= НаборПериоды.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсходнаяСтрока);
			НоваяСтрока.ПериодНачисления  		= ТекущийПериодНачисления;
			НоваяСтрока.НомерПозиции  			= 0;
			НоваяСтрока.ПериодРегистрации		= ГраницыОП.НачалоОП;
			НоваяСтрока.ДокРегистратор			= Документы.энргНачисление.ПустаяСсылка();
			НоваяСтрока.ДатаРегистратора		= ГраницыОП.НачалоОП -1;
		КонецЦикла;		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьНачальныеОстаткиПериодаНачисленияНаборШкалы()

	ТекущиеДанныеПомещения 							= Новый Соответствие;
	
	Для Каждого СтрокаНабора Из НаборШкалы Цикл		
  
		Если НЕ СтрокаНабора.ПериодНачисления  = ДобавитьМесяц(ТекущийПериодНачисления,-1) Тогда
			Продолжить;
		КонецЕсли;
		ИндексСтроки  								= НаборШкалы.Индекс(СтрокаНабора);
		Если ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета] = Неопределено Тогда
						
			ТекущиеДанныеПомещения.Вставить(СтрокаНабора.ТочкаУчета, Новый Структура("НомерПозиции,ИндексСтроки", СтрокаНабора.НомерПозиции, ИндексСтроки));
						
		ИначеЕсли ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета].НомерПозиции < СтрокаНабора.НомерПозиции Тогда
			ЗначениеСоотвествия 					= ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета];
			ЗначениеСоотвествия.НомерПозиции 		= СтрокаНабора.НомерПозиции;
			ЗначениеСоотвествия.ИндексСтроки 		= ИндексСтроки;
			
		КонецЕсли;		
	КонецЦикла;
	
	ГраницыОП 										= энргНачисления.ГраницыОтчетногоПериода(Организация,Район,ТекущийПериодНачисления);
	
	Для Каждого КлючЗначениеТочкаУчета Из ТекущиеДанныеПомещения Цикл
		ЗначениеСоотвествия 						= КлючЗначениеТочкаУчета.Значение;
		ИсходнаяСтрока 								= НаборШкалы[ЗначениеСоотвествия.ИндексСтроки];
		НоваяСтрока 								= НаборШкалы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсходнаяСтрока);
		НоваяСтрока.ПериодНачисления  				= ТекущийПериодНачисления;
		НоваяСтрока.НомерПозиции  					= 0;
		НоваяСтрока.ДокРегистратор					= Документы.энргНачисление.ПустаяСсылка();
		НоваяСтрока.ДатаРегистратора				= ГраницыОП.НачалоОП -1;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьНачальныеОстаткиПериодаНачисленияНаборИзмерители()
	
	ТекущиеДанныеПомещения 						= Новый Соответствие;
	
	Для Каждого СтрокаНабора Из НаборИзмерители Цикл
		
		Если НЕ СтрокаНабора.ПериодНачисления  = ДобавитьМесяц(ТекущийПериодНачисления,-1) Тогда
			Продолжить;
		КонецЕсли;
		ИндексСтроки  							= НаборИзмерители.Индекс(СтрокаНабора);
		Если ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета] = Неопределено Тогда
			СоотвествиеИзмеритель 				= Новый Соответствие;
			СоотвествиеИзмеритель.Вставить(СтрокаНабора.Измеритель, Новый Структура("НомерПозиции,ИндексСтроки", СтрокаНабора.НомерПозиции, ИндексСтроки));
			ТекущиеДанныеПомещения.Вставить(СтрокаНабора.ТочкаУчета, СоотвествиеИзмеритель);
		ИначеЕсли ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета][СтрокаНабора.Измеритель] = Неопределено Тогда
			
			ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета].Вставить(СтрокаНабора.Измеритель, Новый Структура("НомерПозиции,ИндексСтроки", СтрокаНабора.НомерПозиции, ИндексСтроки));
			
		ИначеЕсли ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета][СтрокаНабора.Измеритель].НомерПозиции < СтрокаНабора.НомерПозиции Тогда
			
			ЗначениеСоотвествия 				= ТекущиеДанныеПомещения[СтрокаНабора.ТочкаУчета][СтрокаНабора.Измеритель];
			ЗначениеСоотвествия.НомерПозиции 	= СтрокаНабора.НомерПозиции;
			ЗначениеСоотвествия.ИндексСтроки 	= ИндексСтроки;
			
		КонецЕсли;		
	КонецЦикла;
		
	Для Каждого КлючЗначениеТочкаУчета Из ТекущиеДанныеПомещения Цикл
		Для Каждого КлючЗначениеИзмеритель Из КлючЗначениеТочкаУчета.Значение Цикл
			ЗначениеСоотвествия 				= КлючЗначениеИзмеритель.Значение;
			ИсходнаяСтрока 						= НаборИзмерители[ЗначениеСоотвествия.ИндексСтроки];
			НоваяСтрока 						= НаборИзмерители.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсходнаяСтрока);
			НоваяСтрока.ПериодНачисления  		= ТекущийПериодНачисления;
			НоваяСтрока.НомерПозиции  			= 0;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьПериодыНачислений(текПериодНачисления)
	Если ТекущийПериодНачисления = Неопределено И Не текПериодНачисления = Неопределено Тогда
		ТекущийПериодНачисления 		= текПериодНачисления;
	ИначеЕсли ТекущийПериодНачисления = Неопределено и текПериодНачисления = Неопределено  Тогда
		ТекущийПериодНачисления 		= ПериодНачисленияНачало;
		Пока ТекущийПериодНачисления <= ПериодНачисленияЗавершение Цикл
			ЗаполнитьНачальныеОстаткиПериодаНачисления();
			ТекущийПериодНачисления 	= ДобавитьМесяц(ТекущийПериодНачисления,1);
		КонецЦикла;																																								  
	Иначе
		Пока ТекущийПериодНачисления < текПериодНачисления Цикл
			ТекущийПериодНачисления 		= ДобавитьМесяц(ТекущийПериодНачисления,1);
			ЗаполнитьНачальныеОстаткиПериодаНачисления();
			//ТекущийПериодНачисления 	= ДобавитьМесяц(ТекущийПериодНачисления,1);
		КонецЦикла;		 		 
	КонецЕсли;
КонецПроцедуры

