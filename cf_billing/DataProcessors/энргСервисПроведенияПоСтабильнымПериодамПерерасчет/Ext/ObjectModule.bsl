#Область ОписаниеПеременных

Перем Организация Экспорт; // Организация предоставляющая услуги
Перем ПериодНачисления Экспорт; // Период начисления услуги
Перем Район Экспорт; // Район, в котором оказывается услуга
Перем ЧастныйСектор Экспорт; // Булево - Является ли строение частным сектором
Перем Строение Экспорт; // Адрес, по которому оказавается услуга
Перем мПомещения Экспорт; // Массив помещений, используемый в качестве параметра к запросу внутри модуля
перем НаборПериоды Экспорт; // Периодов начисления и регистрации услуг
перем НаборШкалы Экспорт; // Шкалы приборов учета
перем НаборИзмерители Экспорт; // Измерители направлений использования
перем ПериодНачисленияНачало Экспорт; // Фиксирует начало периода начислений
перем ПериодНачисленияЗавершение Экспорт; // Фиксирует завершение периода начислений
перем ПроверятьДатуЗапретаИзменения Экспорт; // Призрак наличия даты запрета изменения
перем ПодключениеУслугиПервыйДокумент Экспорт; // Признак наличия подключения услуги первого документа
Перем ИмяТаблицыПериодов, ИзменяемыеПараметрыПоТипам, ПоляПорядка, ИзмеренияИсключая;
Перем ТаблицыДанных, ТаблицыИзмененияПлощади, ТаблицыИзмененияШкал, ТаблицыИзмененияИзмерителей;
Перем ТекущийПериодНачисления;

#КонецОбласти

#Область ПрограммныйИнтерфейс

#Область Конструктор

// Инициализирует.
//
// Параметры:
//  МВТ	-	МенеджерВременныхТаблиц.
// 
// Возвращаемое значение:
//   Неопределено.
//
Функция Инициализировать(МВТ) Экспорт 
	ПроверятьДатуЗапретаИзменения 				= Ложь;

	ИмяТаблицыПериодов 							= "ТаблицаПериодов";
	
	СоотвествиеПолей 							= Новый Структура("Организация,Район,ЧастныйСектор,Строение","Организация","Район","ЧастныйСектор","Строение");
	
	ПоляПорядка 								= "Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение,ПериодРегистрации,ДатаРегистратора,ДокРегистратор";
	мПоляПорядка 								= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ПоляПорядка);
		
	Схема 										= Неопределено; 	
	
	ТекстГраницОтчетногоПериода 				= энргНачисления.ТекстГраницОтчетногоПериода(ПериодНачисленияНачало,ПериодНачисленияЗавершение,Ложь);
	
	Схема  										= Новый СхемаЗапроса;
	Пакет 										= Схема.ПакетЗапросов[0];
	Пакет.УстановитьТекстЗапроса(ТекстГраницОтчетногоПериода);
	Пакет.ТаблицаДляПомещения 					= ИмяТаблицыПериодов;
	Для Каждого Оператор Из Пакет.Операторы Цикл
		Оператор.ВыбираемыеПоля.Добавить("&Район");
	КонецЦикла;
	ЗаполнитьСхемуЗапросаПромежуточнымиДанными(Схема,СоотвествиеПолей);
	ПолучитьПомежуточныеДанные(Схема, МВТ, СоотвествиеПолей);
	
	НаборПериоды 								= РегистрыСведений.энргСтабильныеПериоды.СоздатьНаборЗаписей();
	НаборШкалы 									= РегистрыСведений.энргСтабильныеПериодыШкалы.СоздатьНаборЗаписей();
	НаборИзмерители 							= РегистрыСведений.энргСтабильныеПериодыИзмерителиНаправлений.СоздатьНаборЗаписей();
	
КонецФункции

#КонецОбласти

#Область РеализацияИнтерефейса

// Получает значения параметров по направлениям услуг.
//
// Параметры:
//  МенеджерВременныхТаблиц.
// 
// Возвращаемое значение:
//   Соответствие.
//
Функция ЗначенияПараметровПоНаправлениямУслуг(МВТ) Экспорт 
	Возврат РегистрыСведений.энргСпособыРасчетаПоНаправлениям.ЗначенияПараметровПоНаправлениямУслугКоллекцияПериодов(МВТ,Организация,Район, ИмяТаблицыПериодов)
КонецФункции

// Получает описание ключевых параметров норматива.
