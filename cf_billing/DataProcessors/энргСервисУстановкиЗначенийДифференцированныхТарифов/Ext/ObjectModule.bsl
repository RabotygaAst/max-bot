#Область ОписаниеПеременных

Перем ПараметрыОперации Экспорт; // Стуктура параметров операции
Перем ВнешнийКонтекст Экспорт; // Внешний контекст

#Область ЛокальныеПараметрыОбходаВыборки

#Область Логирование

Перем ИмяСобытия;
Перем Ошибки;
Перем ШаблонОшибки;

#КонецОбласти

Перем НастройкаДиапазонов;
Перем ЛокальнаяНастройкаДиапазонов;
Перем ОписаниеСтрокиНастройкиДиапазонов;
Перем ОтборЗначенияТарифа;
Перем ДоляОбъемаПоПериодам;
Перем ОкруглятьДолюДо;
Перем ОкруглятьОбъемДо;

Перем РезультатРаспределения;
Перем ОписаниеРесурсовРаспределения;
Перем ШаблонТаблицыРаспределения;

Перем ЗначенияТарифов;

#Область ПараметрыСменыКлючаВыборки

Перем ТекЧастныйСектор;
Перем ТекМКД;
Перем ТекАбонент;
Перем ТекБлагоустройство;
Перем ЕстьОшибкаВМКД;
	
#КонецОбласти

#КонецОбласти
 
#КонецОбласти

#Область ПрограммныйИнтерфейс

// Выполняет следующие операции:
//		1. Распределение объемов выходящих за лимит первого диапазона.
// 		2. Заполнение значений тарифов(в зависимости от диапазона) и сумм.
//
Процедура ВыполнитьОперацию() Экспорт
		
	ВалидироватьДанные();
	
	МВТ = Новый МенеджерВременныхТаблиц;
	Если НЕ ЕстьУслугиКУстановкеЗначенияТарифов(МВТ) Тогда 
		Возврат;
	КонецЕсли;
	
	ИнициализироватьГраницыПериода();
	ПрочитатьНастройки(МВТ);
	
	РезультатЗапроса = ДокументыКУстановкеЗначенийТарифов(МВТ);
	МВТ.Закрыть();
	
	ОбработатьРезультатЗапроса(РезультатЗапроса);

	Если Ошибки.Количество() > 0 Тогда 
		ТекстОшибок = СтрСоединить(Ошибки, Символы.ПС);
		ВызватьИсключение ТекстОшибок;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция СформироватьСтрокуДляЗапроса(ИмяРегистра, ИмяТаблицы, ИсключаемыеПоля, ПерваяСтрока = Ложь, ПоследняяСтрока = Истина, ЭтоГруппировка = Ложь) Экспорт
	
	ОписаниеТаблицы = энргНачисления.ИзмеренияТаблицыОбъемов(ИмяРегистра); 
	
	ПоляИсключая 	= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИсключаемыеПоля,, Истина);
	ПоляИзмерений 	= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ОписаниеТаблицы.Измерения,, Истина);
	ПоляРесурсов	= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ОписаниеТаблицы.Ресурсы,, Истина);
	ПоляРеквизитов	= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ОписаниеТаблицы.Реквизиты,, Истина);
	
	ДобавляемыеПоля = Новый Массив;
	ДобавляемыеПоля.Добавить(ИмяТаблицы + ".Период" + ?(Не ЭтоГруппировка, " КАК Период", ","));
	ДобавляемыеПоля.Добавить(ИмяТаблицы + ".Регистратор" + ?(Не ЭтоГруппировка, " КАК Регистратор", ","));
	ДобавитьПоля(ДобавляемыеПоля, ИмяТаблицы, ПоляИзмерений, ПоляИсключая, ЭтоГруппировка);
	ДобавитьПоля(ДобавляемыеПоля, ИмяТаблицы, ПоляРесурсов, ПоляИсключая, ЭтоГруппировка);
	ДобавитьПоля(ДобавляемыеПоля, ИмяТаблицы, ПоляРеквизитов, ПоляИсключая, ЭтоГруппировка);
	
	Разделитель = "," + Символы.ПС;
	СимволПервойСтроки = ?(ПерваяСтрока, "", Символы.ПС);
	СимволПоследнейСтроки = ?(ПоследняяСтрока, "", ",");
	Результат = СимволПервойСтроки + СтрСоединить(ДобавляемыеПоля, Разделитель) + СимволПоследнейСтроки;
		
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьПоля(ДобавляемыеПоля, ИмяТаблицы, ПоляТаблицы, ПоляИсключая, ЭтоГруппировка)
	
	Для Каждого Поле Из ПоляТаблицы Цикл
		
		Если НЕ ПоляИсключая.Найти(Поле) = Неопределено ИЛИ Лев(ВРЕГ(Поле), 7) = "УДАЛИТЬ" Тогда
			Продолжить;
		КонецЕсли;
		
		Результат = ИмяТаблицы + "." + Поле + ?(Не ЭтоГруппировка, " КАК " + Поле, ",");		
		ДобавляемыеПоля.Добавить(Результат);
		
	КонецЦикла;
	
КонецПроцедуры

#Область Валидация

Процедура ВалидироватьДанные()
	
	Ошибки = Новый Массив;
	Если НЕ ЗначениеЗаполнено(ПараметрыОперации.ПериодНачисления) Тогда
		Ошибки.Добавить("Период начисления");
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ПараметрыОперации.Район) тогда
		Ошибки.Добавить("Район");		
	КонецЕсли;                   
	
	Если Ошибки.Количество() > 0 Тогда
		
		Комментарий = "Не заполнены обязательные поля:" + Символы.ПС + СтрСоединить(Ошибки, Символы.ПС);
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Комментарий);
		ВызватьИсключение Комментарий;
		
	КонецЕсли;
	
	ПроверитьДатуЗапретаИзменения();
	
КонецПроцедуры 

Процедура ПроверитьДатуЗапретаИзменения()
	
	ОбъектПроверки = Документы.энргРегистрацияПоказанийАбонента.СоздатьДокумент();
	ОбъектПроверки.Организация	= ПараметрыОперации.Организация;
	ОбъектПроверки.Дата			= ПараметрыОперации.ПериодНачисления;
	ОбъектПроверки.Район		= ПараметрыОперации.Район;
	
	Отказ = энргДатыЗапретаИзмененияПереопределяемый.ЗапрещеноИзменятьДанные(ОбъектПроверки);
		
	Если Отказ Тогда
		
		Комментарий = "Для пользователя " + Пользователи.ТекущийПользователь() + 
			" район " + ПараметрыОперации.Район + " период " + ПараметрыОперации.ПериодНачисления + 
			" закрыт для редактирования";
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Комментарий);
		ВызватьИсключение Комментарий;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ПроцессРаспределения

Процедура ОбработатьРезультатЗапроса(РезультатЗапроса)
	
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	
	ЕстьОшибкаВМКД = Ложь;
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ТекМКД = Выборка.МКД Тогда
			
			Если НЕ ТекМКД = Неопределено Тогда
				ПриСменеМКД();
			КонецЕсли;
			
			ЕстьОшибкаВМКД = Ложь;
			
		КонецЕсли;
		
		Если НЕ ТекАбонент = Выборка.Абонент Тогда			
			ПриСменеАбонента(Выборка);			
		КонецЕсли;
		
		Если Выборка.ОбъемУслуги < 0 ИЛИ Выборка.ОбъемУслугиПотребленный < 0 ИЛИ ЕстьОшибкаВМКД Тогда
			
			ОбновитьКлючиСмены(Выборка);
			Продолжить;
			
		КонецЕсли;		
		
		РесурсыРаспределения = ОпределитьРесурыРаспределения(Выборка);
		ДоляПоТарифнойЗонеОтОбщегоОбъема = ОпределитьДолюПоТарифнойЗонеОтОбщегоОбъема(Выборка);				
		
		Если НЕ ТекБлагоустройство = Выборка.ВидБлагоустройства Тогда
			ОбновитьНастройкуДиапазонов(Выборка);
		КонецЕсли;		
		
		Попытка
			
			РаспределитьОбъем(Выборка, РесурсыРаспределения, ДоляПоТарифнойЗонеОтОбщегоОбъема);			
			
		Исключение
			
			
			Инфо = ИнформацияОбОшибке();
			ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(Инфо);
			
			Комментарий = СтрШаблон(
				ШаблонОшибки,
				ПараметрыОперации.ПериодНачисления,
				ПараметрыОперации.Организация,
				ПараметрыОперации.Район,
				Выборка.ЧастныйСектор,
				Выборка.МКД,
				ПодробноеПредставлениеОшибки); 
				
			Ошибки.Добавить(Комментарий);	
				
			ЗаписьЖурналаРегистрации(
			ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка,,,
			Комментарий);
			
			ЕстьОшибкаВМКД = Истина;
			
		КонецПопытки;			
				
		ОбновитьКлючиСмены(Выборка);
		
	КонецЦикла;
	
	Если НЕ ТекМКД = Неопределено Тогда
		ПриСменеМКД();
	КонецЕсли;
	
КонецПроцедуры

Процедура РаспределитьОбъем(Выборка, РесурсыРаспределения, ДоляПоТарифнойЗонеОтОбщегоОбъема)
	
	Списали = 0;		
	СписалиПоТЗ = 0;	 
	
	Постфикс = ?(Выборка.ЭтоОбъемПотребленный, "Потребленный", "");	
	
	ОбъемПериодаОтрицательный = Выборка["ОбъемУслугиПериода" + Постфикс] < 0;
	ОтрицательныйОбъемВнутриПериода = Выборка["ОбъемУслугиПериодаОтрицательный" + Постфикс];
	Если Выборка["ОбъемУслугиПериода" + Постфикс] < 0 Тогда
		ОтрицательныйОбъемВнутриПериода = 0;
	КонецЕсли;
	
	Если (Выборка["ОбъемУслугиПериода" + Постфикс] - ОтрицательныйОбъемВнутриПериода) = 0 Тогда
		ДоляПоТарифнойЗоне	= 0;
	Иначе
		ДоляПоТарифнойЗоне = Окр(Выборка["ОбъемУслуги" + Постфикс] / (Выборка["ОбъемУслугиПериода" + Постфикс] - ОтрицательныйОбъемВнутриПериода), ОкруглятьДолюДо);
	КонецЕсли;
	
	Для Каждого СтрокаНастройкиДиапазона Из ЛокальнаяНастройкаДиапазонов Цикл
		
		Если СтрокаНастройкиДиапазона["ОсталосьСписать" + Постфикс] = 0 Тогда 
			Продолжить;
		КонецЕсли;	
		
		Если Списали = Выборка["ОбщийОбъемУслуги" + Постфикс] Тогда 
			Прервать;
		КонецЕсли;
		
		Если СписалиПоТЗ = Выборка["ОбъемУслуги" + Постфикс] Тогда 
			Прервать;
		КонецЕсли;
		
		Если ОбъемПериодаОтрицательный Тогда
			Списываем = Выборка["ОбъемУслуги" + Постфикс];
		Иначе 
			
			ОбъемУвеличенияОтрицательногоОбъемаВнутриПериода = ?(ПараметрыОперации.Диапазон = СтрокаНастройкиДиапазона.Диапазон, ОтрицательныйОбъемВнутриПериода, 0); 
			ЛимитДиапазона = СтрокаНастройкиДиапазона.Разница - ОбъемУвеличенияОтрицательногоОбъемаВнутриПериода;			
			Если НЕ СтрокаНастройкиДиапазона.ЛимитУвеличен Тогда
				ЛимитДиапазона = Окр(ЛимитДиапазона * ДоляПоТарифнойЗонеОтОбщегоОбъема, ОкруглятьОбъемДо); 
			КонецЕсли;
			
			Списываем = Окр(ЛимитДиапазона * ДоляПоТарифнойЗоне, ОкруглятьОбъемДо); 
			Если СтрокаНастройкиДиапазона.Диапазон = Выборка.МаксимальныйДиапазон Тогда
				Списываем = Выборка["ОбъемУслуги" + Постфикс] - СписалиПоТЗ;
			КонецЕсли;
			
		КонецЕсли;	 
		
		НоваяСтрокаНачисления = РесурсыРаспределения.ТаблицаРаспределения.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаНачисления, Выборка);
		НоваяСтрокаНачисления.НачалоПериода = Выборка.НачалоПериодаОригинал;
		НоваяСтрокаНачисления.ДиапазонДифференцированногоТарифа = СтрокаНастройкиДиапазона.Диапазон;
		НоваяСтрокаНачисления["ОбъемУслуги" + Постфикс] = Списываем;
		НоваяСтрокаНачисления.ЗначениеТарифа = ЗначениеТарифа(НоваяСтрокаНачисления);
		НоваяСтрокаНачисления.Сумма = 0;
		Если НЕ Выборка.ЭтоОбъемПотребленный Тогда  
			НоваяСтрокаНачисления.Сумма = НоваяСтрокаНачисления.ОбъемУслуги * НоваяСтрокаНачисления.ЗначениеТарифа;
		КонецЕсли;	
		
		СтрокаНастройкиДиапазона["ОсталосьСписать" + Постфикс] = СтрокаНастройкиДиапазона["ОсталосьСписать" + Постфикс] - Списываем;
		Списали = Списали + Списываем;
		СписалиПоТЗ = СписалиПоТЗ + Списываем;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ОпределитьРесурыРаспределения(Выборка) 
	
	РесурсыРаспределения = РезультатРаспределения[Выборка.Регистратор];  
	Если РесурсыРаспределения = Неопределено Тогда
		
		РесурсыРаспределения = Новый Структура(ОписаниеРесурсовРаспределения);
		РесурсыРаспределения.ТаблицаРаспределения = ШаблонТаблицыРаспределения.Скопировать();
		РесурсыРаспределения.СтрокиУдаления = ШаблонТаблицыРаспределения.Скопировать(, "Абонент,ТочкаУчета");
		
		РезультатРаспределения.Вставить(Выборка.Регистратор, РесурсыРаспределения);
		РесурсыРаспределения = РезультатРаспределения[Выборка.Регистратор];
		
	КонецЕсли;
	
	НоваяСтрокаУдаления = РесурсыРаспределения.СтрокиУдаления.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрокаУдаления, Выборка);

	Возврат РесурсыРаспределения;
	
КонецФункции  

Функция ОпределитьДолюПоТарифнойЗонеОтОбщегоОбъема(Выборка) 
	
	ДоляПоТарифнойЗонеОтОбщегоОбъема = ДоляОбъемаПоПериодам[Выборка.НачалоПериода];  
	Если ДоляПоТарифнойЗонеОтОбщегоОбъема = Неопределено Тогда
		
		ЭтоОбъемПотребленный = Новый Соответствие;
		ЭтоОбъемПотребленный.Вставить(Выборка.ЭтоОбъемПотребленный, ДоляПоТарифнойЗонеОтОбщегоОбъема(Выборка)); 
		
		ДоляОбъемаПоПериодам.Вставить(Выборка.НачалоПериода, ЭтоОбъемПотребленный);
		
	ИначеЕсли ДоляПоТарифнойЗонеОтОбщегоОбъема[Выборка.ЭтоОбъемПотребленный] = Неопределено Тогда 
		
		ДоляПоТарифнойЗонеОтОбщегоОбъема.Вставить(Выборка.ЭтоОбъемПотребленный, ДоляПоТарифнойЗонеОтОбщегоОбъема(Выборка));
		
	КонецЕсли;	
	
	ДоляПоТарифнойЗонеОтОбщегоОбъема = ДоляОбъемаПоПериодам[Выборка.НачалоПериода][Выборка.ЭтоОбъемПотребленный];
	Возврат ДоляПоТарифнойЗонеОтОбщегоОбъема;
	
КонецФункции

Функция ДоляПоТарифнойЗонеОтОбщегоОбъема(Выборка)
	
	Постфикс = ?(Выборка.ЭтоОбъемПотребленный, "Потребленный", "");
	Результат = Окр(Выборка["ОбъемУслугиПериода" + Постфикс] / Выборка["ОбщийОбъемУслуги" + Постфикс], ОкруглятьДолюДо);

	Возврат Результат;
	
КонецФункции

Процедура ОбновитьКлючиСмены(Выборка)
		
	ТекМКД = Выборка.МКД;
	ТекЧастныйСектор = Выборка.ЧастныйСектор;
	ТекАбонент = Выборка.Абонент;
	ТекБлагоустройство = Выборка.ВидБлагоустройства;
	
КонецПроцедуры

Функция ЗначениеТарифа(СтрокаНачисления)
	
	Результат = 0;
	
	ЗаполнитьЗначенияСвойств(ОтборЗначенияТарифа, СтрокаНачисления);
	ОтборЗначенияТарифа.ГруппаПотребителей = СтрокаНачисления.ТарифнаяГруппа;
	ОтборЗначенияТарифа.Диапазон = СтрокаНачисления.ДиапазонДифференцированногоТарифа;
	НайденныеСтроки = ЗначенияТарифов.НайтиСтроки(ОтборЗначенияТарифа);
	Если НайденныеСтроки.Количество() > 0 Тогда
		Результат = НайденныеСтроки[0].Значение;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#Область СменаКлючаМКД

Процедура ПриСменеМКД()
	
	Если НЕ ЕстьОшибкаВМКД Тогда 
		НаборыЗаписей = Новый Массив;
		Для Каждого КлючЗначениеРегистратор из РезультатРаспределения Цикл 
			
			ПодготовитьДанныеКЗаписи(НаборыЗаписей, КлючЗначениеРегистратор);
			
		КонецЦикла;
		
		ЗаписатьДанные(НаборыЗаписей);
		
	КонецЕсли;

	РезультатРаспределения.Очистить();
	
КонецПроцедуры

Процедура ПодготовитьДанныеКЗаписи(НаборыЗаписей, КлючЗначениеРегистратор)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СтрокиУдалить.Абонент КАК Абонент,
		|	СтрокиУдалить.ТочкаУчета КАК ТочкаУчета
		|ПОМЕСТИТЬ СтрокиКУдалению
		|ИЗ
		|	&СтрокиУдалить КАК СтрокиУдалить
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	 " + СформироватьСтрокуДляЗапроса("энргОбъемНачислений", "энргОбъемНачислений", "", Истина) + "
		|ИЗ
		|	РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
		|		ЛЕВОЕ СОЕДИНЕНИЕ СтрокиКУдалению КАК СтрокиКУдалению
		|		ПО энргОбъемНачислений.Абонент = СтрокиКУдалению.Абонент
		|			И энргОбъемНачислений.ТочкаУчета = СтрокиКУдалению.ТочкаУчета
		|			И НЕ энргОбъемНачислений.ЭтоСписаниеНачислений
		|			И (ВЫБОР
		|				КОГДА &ЭтоСвязанныйПерерасчет
		|					ТОГДА энргОбъемНачислений.ОбъемУслугиПотребленный > 0
		|							ИЛИ энргОбъемНачислений.ОбъемУслуги > 0
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ)
		|ГДЕ
		|	энргОбъемНачислений.Регистратор = &Регистратор
		|	И СтрокиКУдалению.Абонент ЕСТЬ NULL";
	
	
	
	Запрос.УстановитьПараметр("Регистратор", КлючЗначениеРегистратор.Ключ);
	Запрос.УстановитьПараметр("СтрокиУдалить", КлючЗначениеРегистратор.Значение.СтрокиУдаления);
	Запрос.УстановитьПараметр("ЭтоСвязанныйПерерасчет", ТипЗнч(КлючЗначениеРегистратор.Ключ) = Тип("ДокументСсылка.энргПерерасчет"));
	
	РезультатЗапроса = Запрос.Выполнить();	
	ТаблицаДанных = РезультатЗапроса.Выгрузить();
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(КлючЗначениеРегистратор.Значение.ТаблицаРаспределения, ТаблицаДанных);
	
	НаборЗаписи = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыНакопления.энргОбъемНачислений);
	НаборЗаписи.ОбменДанными.Загрузка = Истина;
	НаборЗаписи.Отбор.Регистратор.Установить(КлючЗначениеРегистратор.Ключ);
	НаборЗаписи.Загрузить(ТаблицаДанных);
	
	НаборыЗаписей.Добавить(НаборЗаписи);
	ДополнитьСвязанныеТаблицы(НаборыЗаписей, КлючЗначениеРегистратор, ТаблицаДанных);
		
КонецПроцедуры

Процедура ДополнитьСвязанныеТаблицы(НаборыЗаписей, КлючЗначениеРегистратор, ТаблицаДанных)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	" + СформироватьСтрокуДляЗапроса("энргОбъемНачислений", "энргОбъемНачислений", "", Истина, Ложь) + "
	|	ВЫБОР
	|		КОГДА энргОбъемНачислений.ЧастныйСектор
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|		ИНАЧЕ энргОбъемНачислений.Строение
	|	КОНЕЦ КАК МКД	
	|ПОМЕСТИТЬ ИсходнаяТаблицаДанных
	|ИЗ
	|	&ТаблицаДанных КАК энргОбъемНачислений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	" + СформироватьСтрокуДляЗапроса("энргОбъемНачислений", "ИсходнаяТаблицаДанных", "", Истина) + "
	|ПОМЕСТИТЬ НаборОтложенные
	|ИЗ
	|	ИсходнаяТаблицаДанных КАК ИсходнаяТаблицаДанных
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &НеобходимоЗаписыватьСредний
	|				ТОГДА ВЫБОР
	|						КОГДА ИсходнаяТаблицаДанных.УслугаОграничена
	|							ТОГДА ЛОЖЬ
	|						КОГДА ИсходнаяТаблицаДанных.ДоговорЗаключенДоТП
	|							ТОГДА ЛОЖЬ
	|						КОГДА ИсходнаяТаблицаДанных.Поставщик = ИсходнаяТаблицаДанных.ФизЛицо
	|							ТОГДА ЛОЖЬ
	|						КОГДА ИсходнаяТаблицаДанных.СпособНачисления = ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.ПоПриборам)
	|								И ИсходнаяТаблицаДанных.СниматьНачисленныйСредний
	|								И НЕ ИсходнаяТаблицаДанных.УслугаПолностьюОприборена
	|							ТОГДА ЛОЖЬ
	|						ИНАЧЕ ИСТИНА
	|					КОНЕЦ
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ";
	
	Запрос.Текст = Запрос.Текст + ОбщегоНазначения.РазделительПакетаЗапросов() + 
	ТекстЗапросаДанныеНачисленныйСреднийОбъем();
	
	Запрос.Текст = Запрос.Текст + ОбщегоНазначения.РазделительПакетаЗапросов() +
	
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ОбъемНачислений.Абонент КАК Абонент,
	|	ОбъемНачислений.Услуга КАК Услуга,
	|	СУММА(ОбъемНачислений.Сумма) КАК Сумма,
	|	СУММА(ОбъемНачислений.ОбъемУслуги) КАК ОбъемУслуги,
	|	СУММА(ОбъемНачислений.ОбъемУслугиПотребленный) КАК ОбъемУслугиПотребленный,
	|	СУММА(ОбъемНачислений.ОбъемУслугиПотери) КАК ОбъемУслугиПотери,
	|	СУММА(ОбъемНачислений.ОбъемУслугиПотребленныйПотери) КАК ОбъемУслугиПотребленныйПотери,
	|	МАКСИМУМ(ОбъемНачислений.Организация) КАК Организация,
	|	МАКСИМУМ(ОбъемНачислений.Период) КАК Период,
	|	МАКСИМУМ(&ПериодНачисления) КАК ПериодНачисления,
	|	МАКСИМУМ(ОбъемНачислений.МКД) КАК МКД,
	|	МАКСИМУМ(ОбъемНачислений.Район) КАК Район,
	|	МАКСИМУМ(ОбъемНачислений.Поставщик) КАК Поставщик
	|ИЗ
	|	ИсходнаяТаблицаДанных КАК ОбъемНачислений
	|
	|СГРУППИРОВАТЬ ПО
	|	ОбъемНачислений.Абонент,
	|	ОбъемНачислений.Услуга
	|
	|ИМЕЮЩИЕ
	|	СУММА(ОбъемНачислений.Сумма) <> 0";
		
	Запрос.УстановитьПараметр("ТаблицаДанных", ТаблицаДанных);
	Запрос.УстановитьПараметр("ПериодНачисления", ПараметрыОперации.ПериодНачисления);
	Запрос.УстановитьПараметр("НеобходимоЗаписыватьСредний", ТипЗнч(КлючЗначениеРегистратор.Ключ) = Тип("ДокументСсылка.энргНачисление"));
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ОбщееЧислоПакетов = РезультатЗапроса.Количество();
	Результат = РезультатЗапроса[ОбщееЧислоПакетов - 1].Выгрузить();
	Если НЕ Результат.Количество() = 0 Тогда
		
		НаборЗаписи = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыНакопления.энргВзаиморасчеты);
		НаборЗаписи.ОбменДанными.Загрузка = Истина;
		НаборЗаписи.Отбор.Регистратор.Установить(КлючЗначениеРегистратор.Ключ);
		НаборЗаписи.Загрузить(Результат);
		
		НаборыЗаписей.Добавить(НаборЗаписи);
		
	КонецЕсли;
	
	Результат = РезультатЗапроса[ОбщееЧислоПакетов - 2].Выгрузить();
	Если НЕ Результат.Количество() = 0 Тогда
		
		НаборЗаписи = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыНакопления.энргНачисленныйСреднийОбъем);
		НаборЗаписи.ОбменДанными.Загрузка = Истина;
		НаборЗаписи.Отбор.Регистратор.Установить(КлючЗначениеРегистратор.Ключ);
		НаборЗаписи.Загрузить(Результат);
		
		НаборыЗаписей.Добавить(НаборЗаписи);
		
	КонецЕсли;
	
	
КонецПроцедуры

Функция ТекстЗапросаДанныеНачисленныйСреднийОбъем()
	Текст = 
	"ВЫБРАТЬ
	|	Набор.Период КАК Период,
	|	Набор.Район КАК Район,
	|	Набор.Организация КАК Организация,
	|	ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.энргСпособНачислений.ПоФормуламРасчета) КАК СпособНачисления,
	|	ВЫБОР
	|		КОГДА Набор.ВладелецЗависимойТочкиУчета = ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка)
	|			ТОГДА Набор.Абонент
	|		ИНАЧЕ Набор.ВладелецЗависимойТочкиУчета
	|	КОНЕЦ КАК Абонент,
	|	Набор.Услуга КАК Услуга,
	|	Набор.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	Набор.ЗависимаяТочкаУчета КАК ТочкаУчета,
	|	ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПУстаяСсылка) КАК ПриборУчета,
	|	ЗНАЧЕНИЕ(СПравочник.энргШкалыПриборовУчета.ПустаяСсылка) КАК Шкала,
	|	ЗНАЧЕНИЕ(СПравочник.энргТарифныеЗоны.БезРазбивки) КАК ТарифнаяЗона,
	|	Набор.ЗначениеТарифа КАК ЗначениеТарифа,
	|	Набор.ТарифнаяГруппа КАК ТарифнаяГруппа,
	|	-ВЫБОР
	|		КОГДА Набор.Техническая
	|			ТОГДА Набор.ОбъемУслугиТехнический
	|		ИНАЧЕ Набор.ОбъемУслуги
	|	КОНЕЦ * Набор.КоэффициентФормула КАК ОбъемУслуги,
	|	-Набор.ОбъемУслугиПотребленный * Набор.КоэффициентФормула КАК ОбъемУслугиПотребленный,
	|	-Набор.ОбъемУслугиПотери * Набор.КоэффициентФормула КАК ОбъемУслугиПотери,
	|	-Набор.ОбъемУслугиПотребленныйПотери * Набор.КоэффициентФормула КАК ОбъемУслугиПотребленныйПотери,
	|	-Набор.Сумма * Набор.КоэффициентФормула КАК Сумма,
	|	Набор.Поставщик КАК Поставщик,
	|	Набор.Строение КАК Строение,
	|	Набор.Помещение КАК Помещение,
	|	Набор.ЧастныйСектор КАК ЧастныйСектор,
	|	Набор.ПериодНачисления КАК ПериодНачисления,
	|	Набор.СниматьНачисленныйСреднийПоФормулам КАК СниматьНачисленныйСреднийПоФормулам,
	|	Набор.СниматьНачисленныйСредний КАК СниматьНачисленныйСредний,
	|	Набор.СниматьНачисленныйСреднийЗависимыхТочек КАК СниматьНачисленныйСреднийЗависимыхТочек,
	|	Набор.КоэффициентФормула КАК КоэффициентФормула,
	|	ЛОЖЬ КАК ИзменятьВзаиморасчеты,
	|	Набор.СверхНорматива КАК СверхНорматива,
	|	Набор.ВидБлагоустройства КАК ВидБлагоустройства,
	|	Набор.ДиапазонДифференцированногоТарифа КАК ДиапазонДифференцированногоТарифа,
	|	Набор.НормаПотребления КАК НормаПотребления
	|ПОМЕСТИТЬ Промежуточная_СниматьНачисленныйСреднийПоФормулам
	|ИЗ
	|	&НаборОтложенные КАК Набор
	|ГДЕ
	|	(НЕ Набор.Сумма = 0
	|			ИЛИ НЕ Набор.ОбъемУслуги = 0
	|			ИЛИ НЕ Набор.ОбъемУслугиПотребленный = 0)
	|	И Набор.СниматьНачисленныйСреднийПоФормулам
	|	И Набор.СпособНачисления = ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.ПоПриборам)
	|	И НЕ Набор.ЗависимаяТочкаУчета = ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Набор.СоставнаяУслуга КАК СоставнаяУслуга,
	|	Набор.ЗависимаяТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ВТдляВсехСоставныхУслуг
	|ИЗ
	|	&НаборОтложенные КАК Набор
	|ГДЕ
	|	НЕ Набор.СоставнаяУслуга = ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТдляВсехСоставныхУслуг.СоставнаяУслуга КАК СоставнаяУслуга,
	|	ВТдляВсехСоставныхУслуг.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ВТдляСоставныхУслуг
	|ИЗ
	|	ВТдляВсехСоставныхУслуг КАК ВТдляВсехСоставныхУслуг
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Промежуточная_СниматьНачисленныйСреднийПоФормулам КАК СниматьНачисленныйСреднийПоФормулам1
	|		ПО ВТдляВсехСоставныхУслуг.ТочкаУчета = СниматьНачисленныйСреднийПоФормулам1.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Набор.СоставнаяУслуга КАК СоставнаяУслуга,
	|	Набор.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ СгруппированныеТУ
	|ИЗ
	|	ВТдляСоставныхУслуг КАК Набор
	|
	|СГРУППИРОВАТЬ ПО
	|	Набор.СоставнаяУслуга,
	|	Набор.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТдляСоставныхУслуг.ТочкаУчета КАК ТочкаУчета,
	|	энргВидыУслугСоставляющиеУслуг.Услуга КАК Услуга
	|ПОМЕСТИТЬ ТУ_Услуги
	|ИЗ
	|	ВТдляСоставныхУслуг КАК ВТдляСоставныхУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|		ПО ВТдляСоставныхУслуг.СоставнаяУслуга = энргВидыУслугСоставляющиеУслуг.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТдляСоставныхУслуг.ТочкаУчета,
	|	энргВидыУслугСоставляющиеУслуг.Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Набор.Строение КАК Строение,
	|	Набор.Помещение КАК Помещение,
	|	Набор.ВидБлагоустройства КАК ВидБлагоустройства,
	|	Набор.НормаПотребления КАК НормаПотребления,
	|	Набор.ТарифнаяГруппа КАК ТарифнаяГруппа,
	|	Набор.ЗначениеТарифа КАК ЗначениеТарифа,
	|	Набор.ТочкаУчета КАК ТочкаУчета,
	|	Набор.Услуга КАК Услуга,
	|	ЗНАЧЕНИЕ(СПравочник.энргШкалыПриборовУчета.ПустаяСсылка) КАК Шкала,
	|	Набор.ТарифнаяЗона КАК ТарифнаяЗона
	|ПОМЕСТИТЬ ВТдляВсехТУ
	|ИЗ
	|	&НаборОтложенные КАК Набор
	|ГДЕ
	|	Набор.ЗависимаяТочкаУчета = ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТдляВсехТУ.Строение КАК Строение,
	|	ВТдляВсехТУ.Помещение КАК Помещение,
	|	МАКСИМУМ(ВТдляВсехТУ.ТарифнаяГруппа) КАК ТарифнаяГруппа,
	|	МАКСИМУМ(ВТдляВсехТУ.ЗначениеТарифа) КАК ЗначениеТарифа,
	|	МАКСИМУМ(ВТдляВсехТУ.ВидБлагоустройства) КАК ВидБлагоустройства,
	|	МАКСИМУМ(ВТдляВсехТУ.НормаПотребления) КАК НормаПотребления,
	|	ВТдляВсехТУ.ТочкаУчета КАК ТочкаУчета,
	|	ВТдляВсехТУ.Услуга КАК Услуга,
	|	ВТдляВсехТУ.Шкала КАК Шкала,
	|	ВТдляВсехТУ.ТарифнаяЗона КАК ТарифнаяЗона
	|ПОМЕСТИТЬ ВТдляВсехТУСгруппированная
	|ИЗ
	|	ВТдляВсехТУ КАК ВТдляВсехТУ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТдляВсехТУ.Строение,
	|	ВТдляВсехТУ.Помещение,
	|	ВТдляВсехТУ.ТочкаУчета,
	|	ВТдляВсехТУ.Услуга,
	|	ВТдляВсехТУ.Шкала,
