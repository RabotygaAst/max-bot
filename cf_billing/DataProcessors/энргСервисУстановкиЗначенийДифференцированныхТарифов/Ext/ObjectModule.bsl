	|	ПромежуточныйИтог.Период КАК Период,
	|	ПромежуточныйИтог.ПериодНачисления КАК ПериодНачисления,
	|	ПромежуточныйИтог.МКД КАК МКД,
	|	ПромежуточныйИтог.Строение КАК Строение,
	|	ПромежуточныйИтог.ЧастныйСектор КАК ЧастныйСектор,
	|	ПромежуточныйИтог.Район КАК Район,
	|	ПромежуточныйИтог.Помещение КАК Помещение,
	|	ПромежуточныйИтог.Поставщик КАК Поставщик,
	|	ПромежуточныйИтог.СниматьНачисленныйСредний КАК СниматьНачисленныйСредний,
	|	ПромежуточныйИтог.ИзменятьВзаиморасчеты КАК ИзменятьВзаиморасчеты,
	|	ПромежуточныйИтог.СверхНорматива КАК СверхНорматива,
	|	ПромежуточныйИтог.ВидБлагоустройства КАК ВидБлагоустройства, 
	|	ПромежуточныйИтог.ДиапазонДифференцированногоТарифа КАК ДиапазонДифференцированногоТарифа,
	|	ПромежуточныйИтог.НормаПотребления КАК НормаПотребления
	|ИЗ
	|	ПромежуточныйИтог КАК ПромежуточныйИтог
	|ГДЕ
	|	(НЕ ПромежуточныйИтог.ОбъемУслуги = 0
	|			ИЛИ НЕ ПромежуточныйИтог.ОбъемУслугиПотребленный = 0)"; 
	
	
	Текст = СтрЗаменить(Текст, "&НаборОтложенные", "НаборОтложенные");	
	Возврат Текст;
	
КонецФункции

Процедура ЗаписатьДанные(НаборыЗаписей)
	
	НачатьТранзакцию();
	Попытка
		
		Для Каждого НаборЗаписи Из НаборыЗаписей Цикл
			 
			НаборЗаписи.Записать();
			
		КонецЦикла;
				
		ЗафиксироватьТранзакцию();
	
	Исключение               
		
	    ОтменитьТранзакцию();
		
		Инфо = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(Инфо);
		
		Комментарий = СтрШаблон(
			ШаблонОшибки,
			ПараметрыОперации.ПериодНачисления,
			ПараметрыОперации.Организация,
			ПараметрыОперации.Район,
			ТекЧастныйСектор,
			ТекМКД,
			ПодробноеПредставлениеОшибки); 
		
		Ошибки.Добавить(Комментарий);	
		
		ЗаписьЖурналаРегистрации(
		ИмяСобытия,
		УровеньЖурналаРегистрации.Ошибка,
		Справочники,
		ТекМКД,
		Комментарий);		
		
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

