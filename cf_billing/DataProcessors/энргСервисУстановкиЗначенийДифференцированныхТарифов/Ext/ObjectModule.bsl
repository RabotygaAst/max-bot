	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			УслугиКРаспределению.Абонент КАК Абонент,
	|			УслугиКРаспределению.Услуга КАК Услуга,
	|			УслугиКРаспределению.НачалоПериода КАК НачалоПериода,
	|			СУММА(ВЫБОР
	|					КОГДА УслугиКРаспределению.ОбъемУслуги < 0
	|						ТОГДА УслугиКРаспределению.ОбъемУслуги
	|					ИНАЧЕ 0
	|				КОНЕЦ) КАК ОбъемУслугиПериодаОтрицательный,
	|			СУММА(ВЫБОР
	|					КОГДА УслугиКРаспределению.ОбъемУслугиПотребленный < 0
	|						ТОГДА УслугиКРаспределению.ОбъемУслугиПотребленный
	|					ИНАЧЕ 0
	|				КОНЕЦ) КАК ОбъемУслугиПериодаОтрицательныйПотребленный
	|		ИЗ
	|			УслугиКРаспределению КАК УслугиКРаспределению
	|		
	|		СГРУППИРОВАТЬ ПО
	|			УслугиКРаспределению.Абонент,
	|			УслугиКРаспределению.Услуга,
	|			УслугиКРаспределению.НачалоПериода) КАК ОтрицательныеОбъемыВнутриПериода
	|		ПО УслугиКРаспределению.Абонент = ОтрицательныеОбъемыВнутриПериода.Абонент
	|			И УслугиКРаспределению.Услуга = ОтрицательныеОбъемыВнутриПериода.Услуга
	|			И УслугиКРаспределению.НачалоПериода = ОтрицательныеОбъемыВнутриПериода.НачалоПериода
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ОбъемыВРазрезеПериодов.Абонент КАК Абонент,
	|			ОбъемыВРазрезеПериодов.Услуга КАК Услуга,
	|			СУММА(ОбъемыВРазрезеПериодов.ОбъемУслугиПериода) КАК ОбъемУслугиПериодаОбщийОтрицательный,
	|			СУММА(ОбъемыВРазрезеПериодов.ОбъемУслугиПериодаПотребленный) КАК ОбъемУслугиПериодаОбщийОтрицательныйПотребленный
	|		ИЗ
	|			ОбъемыВРазрезеПериодов КАК ОбъемыВРазрезеПериодов
	|		ГДЕ
	|			ОбъемыВРазрезеПериодов.ОбъемУслугиПериода < 0
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ОбъемыВРазрезеПериодов.Абонент,
	|			ОбъемыВРазрезеПериодов.Услуга) КАК ПериодыСОбщимОбъемомМеньшеНуля
	|		ПО УслугиКРаспределению.Абонент = ПериодыСОбщимОбъемомМеньшеНуля.Абонент
	|			И УслугиКРаспределению.Услуга = ПериодыСОбщимОбъемомМеньшеНуля.Услуга
	|
	|УПОРЯДОЧИТЬ ПО
	|	МКД,
	|	Абонент,
	|	Услуга,
	|	ТочкаУчета,
	|	НачалоПериода,
	|	ТарифнаяЗона";
	
	Возврат Текст;
	
КонецФункции

Функция КоэффициентыИзмененияЛимитовДифференцированныхТарифов()
	
	Схема = Неопределено;
	ПоместитьВ = "КоэффициентыИзмененияЛимитовДифференцированныхТарифов";
	ПараметрыОтбора	 = Новый Структура;
	ПараметрыВТ 	 = Новый Массив;

	ПараметрыОтбора.Вставить("Период", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("КП"));
	
	ОтборРавно = Новый Структура("Организация,Район", "Организация", "Район");
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(ОтборРавно));
	
	ОтборВ = Новый Структура("Абонент", "Абонент");
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица("НачисленныеОбъемы", ОтборВ));
	
	ПараметрыОтбора.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	РегистрыСведений.энргКоэффициентИзмененияЛимитовДифференцированныхТарифов.АктуальныеДанные(Схема, ПараметрыОтбора, ПоместитьВ);
	Текст = Схема.ПолучитьТекстЗапроса();
	
	Возврат Текст;
	
КонецФункции

Функция ИсключенныеАбонентыИзРаспределенияДифференцированныхТарифов()
	
	Схема = Неопределено;
	ПоместитьВ = "ИсключенныеАбонентыИзРаспределенияДифференцированныхТарифов";
	ПараметрыОтбора	 = Новый Структура;
	ПараметрыВТ 	 = Новый Массив;

	ПараметрыОтбора.Вставить("Период", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("КП"));
	
	ОтборРавно = Новый Структура("Организация,Район", "Организация", "Район");
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(ОтборРавно));
	
	ОтборВ = Новый Структура("Абонент", "Абонент");
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица("УслугиКРаспределениюНачало", ОтборВ));
	
	ОтборГдеБольше = Новый Структура("ДатаЗавершенияИсключения", "ДАТАВРЕМЯ(1,1,1)");
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипБольше(ОтборГдеБольше));
	
	ОтборГдеБольшеРавно = Новый Структура("ДатаЗавершенияИсключения", "&НП");
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипБольшеРавно(ОтборГдеБольшеРавно));
	
	ПараметрыОтбора.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	РегистрыСведений.энргИсключенныеАбонентыИзРаспределенияДифференцированныхТарифов.АктуальныеДанные(Схема, ПараметрыОтбора, ПоместитьВ);
	Текст = Схема.ПолучитьТекстЗапроса();
	
	Возврат Текст;
	
КонецФункции

Функция НовыеПараметрыОперации()
	
	Результат = Новый Структура;
	Результат.Вставить("ПериодНачисления", Дата(1,1,1));
	Результат.Вставить("Организация", Справочники.Организации.НашаОрганизация);
