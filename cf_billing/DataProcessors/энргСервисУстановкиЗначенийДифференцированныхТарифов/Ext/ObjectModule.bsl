Процедура ПриСменеАбонента(Выборка)
	
	ДоляОбъемаПоПериодам.Очистить();
	ОбновитьНастройкуДиапазонов(Выборка);
	
КонецПроцедуры

Процедура ОбновитьНастройкуДиапазонов(Выборка)
	
	ЛокальнаяНастройкаДиапазонов.Очистить();
	НайденныеСтроки = НастройкаДиапазонов.НайтиСтроки(Новый Структура("Услуга,ВидБлагоустройства", Выборка.Услуга, Выборка.ВидБлагоустройства));		
	Для Каждого НайденнаяСтрока из НайденныеСтроки Цикл
		
		//Если НайденнаяСтрока.Диапазон > Выборка.МаксимальныйДиапазон Тогда
		//	Возврат;
		//КонецЕсли;
		
		ОбщееУвеличениеЛимитаПервогоДиапазона = 0;
		ЛимитУвеличен = Ложь;
		Если НайденнаяСтрока.Диапазон = ПараметрыОперации.Диапазон Тогда			
			ОбщееУвеличениеЛимитаПервогоДиапазона = - Выборка.ОбъемУслугиПериодаОбщийОтрицательный;
			ЛимитУвеличен = Выборка.ОбъемУслугиПериодаОбщийОтрицательный < 0;
		КонецЕсли;
		
		НоваяСтрока = Новый Структура(ОписаниеСтрокиНастройкиДиапазонов);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, НайденнаяСтрока);
		НоваяСтрока.Разница = ((НайденнаяСтрока.До - НайденнаяСтрока.От) * Выборка.КоэффициентИзмененияЛимитаДиапазона) + ОбщееУвеличениеЛимитаПервогоДиапазона;
		НоваяСтрока.ОсталосьСписать = НоваяСтрока.Разница;
		НоваяСтрока.ОсталосьСписатьПотребленный = НоваяСтрока.Разница;
		НоваяСтрока.ЛимитУвеличен = ЛимитУвеличен;
		
		ЛокальнаяНастройкаДиапазонов.Добавить(НоваяСтрока);
		
	КонецЦикла;
		
КонецПроцедуры

