Функция ЕстьУслугиКУстановкеЗначенияТарифов(МВТ)
	
	СпособРасчета = Перечисления.энргТерриториальныеСпособыРасчета.ДифференцированныеТарифы;
	
	Схема = Неопределено;
	ПараметрыЗапроса = Новый Структура;
	ПараметрыОтбора	 = Новый Структура;
	ПараметрыВТ 	 = Новый Массив;
	
	Отборы = Новый Структура(
	"Организация,Район,СпособРасчета", 
	"Организация",
	"Район",	
	"СпособРасчета");
	
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Отборы)); 		
	ПараметрыОтбора.Вставить("Период", Новый Структура("ИмяПараметра,ТипПараметра", "Период" ,"ТипПараметраГраницаИсключая"));	
	ПараметрыОтбора.Вставить("ПараметрыВТ", ПараметрыВТ);

	ПараметрыЗапроса.Вставить("Период", ПараметрыОперации.ПериодНачисления);
	ПараметрыЗапроса.Вставить("Организация", ПараметрыОперации.Организация);
	ПараметрыЗапроса.Вставить("Район", ПараметрыОперации.Район);
	ПараметрыЗапроса.Вставить("СпособРасчета", СпособРасчета);
	
	РегистрыСведений.энргТерриториальныеСпособыРасчета.АктуальныеДанныеСрезПоследних(Схема, ПараметрыОтбора, "УслугиСДифференцированнымТарифом");	
	энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса, МВТ);	
	
	РезультатЗапроса = МВТ.Таблицы[0].ПолучитьДанные();
	Возврат НЕ РезультатЗапроса.Пустой();	
	
КонецФункции 

Процедура ПрочитатьНастройки(МВТ)
	
	Схема = Неопределено;
	ПараметрыЗапроса = Новый Структура;
	ПараметрыОтбора	 = Новый Структура;
	ПараметрыВТ 	 = Новый Массив;
	
	Отборы = Новый Структура(
	"Организация,Район", 
	"Организация",
	"Район");
	
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Отборы));
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица("УслугиСДифференцированнымТарифом", Новый Структура("Услуга", "Услуга")));
	ПараметрыОтбора.Вставить("ПараметрыВТ", ПараметрыВТ);
	ПараметрыОтбора.Вставить(энргФормированиеТекстовЗапроса.ПараметрПериодРавно("Период"));  

	ПараметрыЗапроса.Вставить("Период", ПараметрыОперации.ПериодНачисления);
	ПараметрыЗапроса.Вставить("Организация", ПараметрыОперации.Организация);
	ПараметрыЗапроса.Вставить("Район", ПараметрыОперации.Район);
	
	РегистрыСведений.энргНастройкаДиапазоновДифференцированногоТарифа.АктуальныеДанныеСрезПоследних(Схема, ПараметрыОтбора, "НастройкиДиапазоновДифференцированногоТарифа");
	РегистрыСведений.энргЗначенияТарифовДиапазоновДифференцированногоТарифа.АктуальныеДанныеСрезПоследних(Схема, ПараметрыОтбора, "ЗначенияТарифовДиапазоновДифференцированногоТарифа");
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса, МВТ);

    НастройкаДиапазонов = МВТ.Таблицы[2].ПолучитьДанные().Выгрузить();
	НастройкаДиапазонов.Сортировать("Услуга, ВидБлагоустройства, ПриоритетДиапазона");
	НастройкаДиапазонов.Индексы.Добавить("Услуга, ВидБлагоустройства");	
	
	ЗначенияТарифов = МВТ.Таблицы[3].ПолучитьДанные().Выгрузить();	
	ЗначенияТарифов.Индексы.Добавить("Услуга, ГруппаПотребителей, ТарифнаяЗона, Диапазон"); 
	
КонецПроцедуры

Функция ДокументыКУстановкеЗначенийТарифов(МВТ)
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = ТекстЗапросаДокументыКУстановкеЗначенийТарифов(); 
	
	Если НЕ ЗначениеЗаполнено(ПараметрыОперации.ЧастныйСектор) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргОбъемНачислений.ЧастныйСектор = &ЧастныйСектор", "");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПараметрыОперации.Строения) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргОбъемНачислений.Строение В(&Строения)", "");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПараметрыОперации.Абонент) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И энргОбъемНачислений.Абонент = &Абонент", "");
	КонецЕсли;                                                                                   	
	
	Запрос.УстановитьПараметр("НП", ПараметрыОперации.НачалоОП);
	Запрос.УстановитьПараметр("КП", ПараметрыОперации.ЗавершениеОП - 1);	
	Запрос.УстановитьПараметр("Организация", ПараметрыОперации.Организация);
	Запрос.УстановитьПараметр("Район", ПараметрыОперации.Район);      
	Запрос.УстановитьПараметр("ЧастныйСектор", ПараметрыОперации.ЧастныйСектор);
	Запрос.УстановитьПараметр("Строения", ПараметрыОперации.Строения);
	Запрос.УстановитьПараметр("Абонент", ПараметрыОперации.Абонент);
	Запрос.УстановитьПараметр("Диапазон", ПараметрыОперации.Диапазон);

	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса;	
	
КонецФункции

Функция ТекстЗапросаДокументыКУстановкеЗначенийТарифов()
	
	Текст = 
	"ВЫБРАТЬ
	|	" + СформироватьСтрокуДляЗапроса("энргОбъемНачислений", "энргОбъемНачислений", "НачалоПериода", Истина, Ложь) + "
	|	ВЫБОР
	|		КОГДА энргОбъемНачислений.Регистратор ССЫЛКА Документ.энргПерерасчет
	|				И ВЫРАЗИТЬ(энргОбъемНачислений.Регистратор КАК Документ.энргПерерасчет).ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет)
	|				И энргОбъемНачислений.НачалоПериода = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА &НП
	|		ИНАЧЕ энргОбъемНачислений.НачалоПериода
	|	КОНЕЦ КАК НачалоПериода,
	|	энргОбъемНачислений.НачалоПериода КАК НачалоПериодаОригинал,	
	|	ВЫБОР
	|		КОГДА энргОбъемНачислений.Регистратор ССЫЛКА Документ.энргНачисление
	|			ТОГДА 1
	|		КОГДА энргОбъемНачислений.Регистратор ССЫЛКА Документ.энргПерерасчет
	|				И ВЫРАЗИТЬ(энргОбъемНачислений.Регистратор КАК Документ.энргПерерасчет).ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет)
	|			ТОГДА 2
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ПриоритетРегистратора
	|ПОМЕСТИТЬ НачисленныеОбъемы
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
	|ГДЕ
	|	энргОбъемНачислений.Период МЕЖДУ &НП И &КП
	|	И энргОбъемНачислений.Организация = &Организация
	|	И энргОбъемНачислений.Район = &Район
	|	И НЕ энргОбъемНачислений.Распределение
	|	И энргОбъемНачислений.ЧастныйСектор = &ЧастныйСектор
	|	И энргОбъемНачислений.Строение В(&Строения)
	|	И энргОбъемНачислений.Абонент = &Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НачисленныеОбъемы.Абонент КАК Абонент,
	|	НачисленныеОбъемы.ТочкаУчета КАК ТочкаУчета,
	|	МАКСИМУМ(НачисленныеОбъемы.ПриоритетРегистратора) КАК ПриоритетРегистратора
	|ПОМЕСТИТЬ МаксимальныйПриоритетРегистратораТочекУчета
	|ИЗ
	|	НачисленныеОбъемы КАК НачисленныеОбъемы
	|
	|СГРУППИРОВАТЬ ПО
	|	НачисленныеОбъемы.Абонент,
	|	НачисленныеОбъемы.ТочкаУчета
	|
	|ИМЕЮЩИЕ
	|	МАКСИМУМ(НачисленныеОбъемы.ПриоритетРегистратора) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НачисленныеОбъемы.Абонент КАК Абонент,
	|	НачисленныеОбъемы.ТочкаУчета КАК ТочкаУчета,
	|	МАКСИМУМ(НачисленныеОбъемы.Регистратор) КАК Регистратор
	|ПОМЕСТИТЬ РегистраторыТочекУчета
	|ИЗ
	|	МаксимальныйПриоритетРегистратораТочекУчета КАК МаксимальныйПриоритетРегистратораТочекУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НачисленныеОбъемы КАК НачисленныеОбъемы
	|		ПО МаксимальныйПриоритетРегистратораТочекУчета.Абонент = НачисленныеОбъемы.Абонент
	|			И МаксимальныйПриоритетРегистратораТочекУчета.ТочкаУчета = НачисленныеОбъемы.ТочкаУчета
	|			И МаксимальныйПриоритетРегистратораТочекУчета.ПриоритетРегистратора = НачисленныеОбъемы.ПриоритетРегистратора
	|
	|СГРУППИРОВАТЬ ПО
	|	НачисленныеОбъемы.Абонент,
	|	НачисленныеОбъемы.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";
	
	Текст = Текст + КоэффициентыИзмененияЛимитовДифференцированныхТарифов();
	Текст = Текст + ОбщегоНазначения.РазделительПакетаЗапросов() +
	
	"ВЫБРАТЬ
	|	" + СформироватьСтрокуДляЗапроса("энргОбъемНачислений", "НачисленныеОбъемы", "", Истина, Ложь) + "
	|	НачисленныеОбъемы.НачалоПериодаОригинал КАК НачалоПериодаОригинал,
	|	ЕСТЬNULL(КоэффициентыИзмененияЛимитовДифференцированныхТарифов.Коэффициент, 1) КАК КоэффициентИзмененияЛимитаДиапазона
	|ПОМЕСТИТЬ ДанныеКРаспределению
	|ИЗ
	|	РегистраторыТочекУчета КАК РегистраторыТочекУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НачисленныеОбъемы КАК НачисленныеОбъемы	
	|			ЛЕВОЕ СОЕДИНЕНИЕ КоэффициентыИзмененияЛимитовДифференцированныхТарифов КАК КоэффициентыИзмененияЛимитовДифференцированныхТарифов
