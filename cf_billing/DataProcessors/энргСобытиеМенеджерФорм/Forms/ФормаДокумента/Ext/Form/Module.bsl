#Область СобытияЭлементовФормы

&НаКлиенте
Процедура ТипСобытияПриИзменении(Элемент)
	УправлениеВидимостью();
	ЗаполнитьПараметрыНаСервере();
	УстановитьПараметрыВыбораПриИзмененииТипСобытия();
	ИзменитьНазванияПолейТЧ();
	УправлениеВидимостьюФункцийПечати();
КонецПроцедуры

&НаКлиенте
Процедура СпособОтправкиПриИзменении(Элемент)
	УправлениеВидимостьюФункцииОтправкиНаПочту();
	РасчитатьСрокиОУведомленииОВводеОРП();
КонецПроцедуры

&НаКлиенте
Процедура ПотребителиОснованиеПриИзменении(Элемент)
	ТекСтрока = Элементы.Абоненты.ТекущиеДанные;
	Если ТекСтрока = Неопределено Или Не ЗначениеЗаполнено(ТекСтрока.Основание) Тогда
		Возврат;
	КонецЕсли;
	
	ТекСтрока.Абонент = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекСтрока.Основание, "Абонент");
КонецПроцедуры

&НаКлиенте
Процедура ЭтапПриИзменении(Элемент)
	НенужныеАбоненты = ПолучитьНенужныхАбонентов();
	Если НЕ НенужныеАбоненты.Количество() = 0 Тогда
		Оповещение 		= Новый ОписаниеОповещения("ПослеОтветаНаВопросУдаленияНенужныхПотребителей", ЭтотОбъект, Новый Структура("НенужныеАбоненты", НенужныеАбоненты));
		ТекстВопроса 	= 
		"Абоненты не подходящие по отбору Этап: 
		|%1. Удалить данных абонентов?";
		
		ТекстВопроса = СтрШаблон(ТекстВопроса, СтрСоединить(НенужныеАбоненты, ","));
		ПоказатьВопрос(Оповещение, ТекстВопроса , РежимДиалогаВопрос.ДаНетОтмена,,, "Очистка таблицы потребителей");	
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПослеОтветаНаВопросУдаленияНенужныхПотребителей(Результат, ДопПараметры) Экспорт 
	Если Результат = Неопределено 
		ИЛИ Результат = КодВозвратаДиалога.Нет 
		ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда 
		Возврат;
	КонецЕсли;
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОчиститьТаблицуОтНенужныхАбонентов(ДопПараметры);		
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ОчиститьТаблицуОтНенужныхАбонентов(ДопПараметры)
	Для Каждого ТекАбонент из ДопПараметры.НенужныеАбоненты Цикл 
		//ТаблицаОчистки 	= Объект.Абоненты;
		Отбор 			= Новый Структура("Абонент", ТекАбонент);
		энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.Абоненты, Отбор);
	КонецЦикла;
КонецПроцедуры


#КонецОбласти


#Область СобытияПередачиНаСогласования

&НаКлиенте
Процедура ПередатьНаСогласование(Команда)
	Ошибки = ОшибкиПередОтправкойНаСогласование();
	Если Ошибки.Количество() > 0 Тогда
		ПоказатьПредупреждение(, СтрСоединить(Ошибки, Символы.ПС));
		Возврат;
	КонецЕсли;	
	
	Результат = ПередатьНаСогласованиеНаСервере();
	ОбновитьНадписьСтатусаСобытия();
	ПоказатьПредупреждение(, Результат); 	
КонецПроцедуры

&НаСервере
Функция ПередатьНаСогласованиеНаСервере()
	Результат 				= "Статус успешно зарегистрирован";
	МенеджерРегистра 		= РегистрыСведений.энргСтатусСогласованияСобытий;
	
	ОписаниеОжидаемыхДанных = МенеджерРегистра.ПолучитьОписаниеОбъекта();
	ОписаниеОжидаемыхДанных.Организация 	= Объект.Организация;
	ОписаниеОжидаемыхДанных.Район 			= Объект.Район;
	ОписаниеОжидаемыхДанных.ДокРегистратор 	= Объект.Ссылка;
	ОписаниеОжидаемыхДанных.Исполнитель 	= Объект.Согласующий;
	ОписаниеОжидаемыхДанных.Статус 			= Перечисления.энргСтатусыСогласованияСобытий.ТребуетСогласования;
	
	Попытка
		МенеджерРегистра.ЗарегистрироватьСтатусПередачаНаСогласование(ТекущаяДата(), ОписаниеОжидаемыхДанных);
		СтатусСогласования = ОписаниеОжидаемыхДанных.Статус;
	Исключение
		ИнформацияОбОшибке		= ИнформацияОбОшибке();
		Результат 				= "Статус не зарегистрирован по причине: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		
		Комментарий				= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		НеобязательныеПараметры = энргОбщегоНазначения.НеобязательныеПараметрыРегистацииОшибки();
		НеобязательныеПараметры.ВыводитьСообщениеПользователю = Ложь;		
		энргОбщегоНазначения.ЗарегистрироватьОшибку("Изменение статуса", УровеньЖурналаРегистрации.Ошибка, Комментарий, НеобязательныеПараметры); 		
	КонецПопытки;
	
	Возврат Результат;	
КонецФункции


&НаКлиенте
Функция ОшибкиПередОтправкойНаСогласование()
	Ошибки = Новый Массив;
	
	Если НЕ ЗначениеЗаполнено(Объект.Согласующий) Тогда
		Ошибки.Добавить("Не указано поле Согласующий");
	КонецЕсли;
	
	Если Параметры.Ключ.Пустая() Тогда 
		Ошибки.Добавить("Необходимо Записать объект");	
	КонецЕсли;	
	
	Возврат Ошибки;	
КонецФункции

#КонецОбласти

#Область СобытияСогласования

&НаКлиенте
Процедура Согласовать(Команда)
	Ошибки = ОшибкиПередСогласованием();
	Если Ошибки.Количество() > 0 Тогда
		ПоказатьПредупреждение(, СтрСоединить(Ошибки, Символы.ПС));
		Возврат;
	КонецЕсли;	
	
	Результат = СогласоватьНаСервере();
	ОбновитьНадписьСтатусаСобытия();
	ПоказатьПредупреждение(, Результат);
КонецПроцедуры

