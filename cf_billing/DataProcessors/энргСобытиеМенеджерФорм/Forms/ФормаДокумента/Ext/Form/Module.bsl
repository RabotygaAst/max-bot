	Возврат Ошибки;	
КонецФункции

#КонецОбласти


#Область СобытияВыполнения

&НаКлиенте
Процедура Выполнено(Команда)
	НедостаточноФайлов = Ложь;
	энргРаботаСПрикрепленнымиФайламиКлиент.ПередЗаписью(НедостаточноФайлов, ЭтотОбъект);
	Если НедостаточноФайлов Тогда
		Возврат;
	КонецЕсли;
	
	Ошибки = ОшибкиПередРегистрациейВыполненияСобытия();
	Если Ошибки.Количество() > 0 Тогда
		ПоказатьПредупреждение(, СтрСоединить(Ошибки, Символы.ПС));
		Возврат;
	КонецЕсли;
	
	Результат = ЗарегистрироватьСтатусВыполнен();
	ОбновитьНадписьСтатусаСобытия();
	ПоказатьПредупреждение(, Результат);	
КонецПроцедуры

&НаСервере
Функция ЗарегистрироватьСтатусВыполнен()
	Результат 				= "Событие выполнено успешно";
	МенеджерРегистра 		= РегистрыСведений.энргСтатусВыполненияСобытий;
	ОписаниеОжидаемыхДанных = МенеджерРегистра.ПолучитьОписаниеОбъекта();
	ПериодВыполнения		= ТекущаяДата();
	ОписаниеОжидаемыхДанных.Организация 	= Объект.Организация;
	ОписаниеОжидаемыхДанных.Район 			= Объект.Район;
	ОписаниеОжидаемыхДанных.ДокРегистратор 	= Объект.Ссылка;
	ОписаниеОжидаемыхДанных.Ответственный 	= Пользователи.ТекущийПользователь();
	ОписаниеОжидаемыхДанных.Статус 			= Истина;
	
	Попытка
		МенеджерРегистра.ЗарегистрироватьСтатусВыполнен(ПериодВыполнения, ОписаниеОжидаемыхДанных);
		Исполнитель 		= ОписаниеОжидаемыхДанных.Ответственный;
		ДатаВыполнения 		= ПериодВыполнения;
		СтатусВыполнения	= Истина;
	Исключение
		ИнформацияОбОшибке		= ИнформацияОбОшибке();
		Результат 				= "Событие не выполнено по причине: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		
		Комментарий				= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		НеобязательныеПараметры = энргОбщегоНазначения.НеобязательныеПараметрыРегистацииОшибки();
		НеобязательныеПараметры.ВыводитьСообщениеПользователю = Ложь;		
		энргОбщегоНазначения.ЗарегистрироватьОшибку("Выполнение события", УровеньЖурналаРегистрации.Ошибка, Комментарий, НеобязательныеПараметры); 		
	КонецПопытки;
	
	Возврат Результат;	
КонецФункции


&НаКлиенте
Функция ОшибкиПередРегистрациейВыполненияСобытия()
	Ошибки = Новый Массив;
	Если Параметры.Ключ.Пустая() Тогда 
		Ошибки.Добавить("Необходимо Записать объект");	
	КонецЕсли;
	
	ТребуетСогласования = ПолучитьСвойствоТребуетСогласования();
	Если ТребуетСогласования и НЕ СтатусСогласования = ПредопределенноеЗначение("Перечисление.энргСтатусыСогласованияСобытий.Согласовано") Тогда 
		Ошибки.Добавить("Событие не согласовано");	
	КонецЕсли;
	
	Возврат Ошибки;	
КонецФункции

#КонецОбласти


#Область РаботаСТаблицейПараметры

&НаСервере
Процедура ЗаполнитьПараметрыНаСервере()
	
	ЗначПарам = Новый Соответствие;
	
	Для каждого СтрокаТЧ Из Объект.Параметры Цикл
		ЗначПарам.Вставить(СтрокаТЧ.Параметр, СтрокаТЧ.Значение);
	КонецЦикла;
	
	
	Объект.Параметры.Очистить();
	
	СписокПараметровТипа = Справочники.энргСпособСвязи.ПолучитьСписокПараметров(Объект.ТипСобытия);
	
	Для каждого Параметр Из СписокПараметровТипа Цикл
		
		Если ЗначениеЗаполнено(Параметр) Тогда
			Значение = ЗначПарам.Получить(Параметр);			
			
			Если Параметр = ПланыВидовХарактеристик.бестПараметрыТиповСобытий.ТелефонАбонента И Объект.Одинарный И ЗначениеЗаполнено(Объект.Абоненты) Тогда	
				СтрокаТЧ 			= Объект.Параметры.Добавить();			
				СтрокаТЧ.Параметр 	= Параметр;
				СтрокаТЧ.Значение = Документы.энргСобытие.ПолучитьТелефонАбонента(Объект.Абоненты[0].Абонент, Истина);
				
			ИначеЕсли Параметр = ПланыВидовХарактеристик.бестПараметрыТиповСобытий.АдресЭлектроннойПочты И Объект.Одинарный И ЗначениеЗаполнено(Объект.Абоненты) Тогда	
				СтрокаТЧ 			= Объект.Параметры.Добавить();			
				СтрокаТЧ.Параметр 	= Параметр;
				СтрокаТЧ.Значение = Документы.энргСобытие.ПолучитьЭлектроннуюПочтуАбонента(Объект.Абоненты[0].Абонент);
				
			ИначеЕсли Параметр = ПланыВидовХарактеристик.бестПараметрыТиповСобытий.Суд_СудебныйУчасток Тогда
				СтрокаТЧ 			= Объект.Параметры.Добавить();			
				СтрокаТЧ.Параметр 	= Параметр;
				СтрокаТч.Значение = СудебноеУчреждение(Объект.Абоненты[0].Основание);						
				
			ИначеЕсли не Значение = Неопределено Тогда		
				СтрокаТЧ 			= Объект.Параметры.Добавить();			
				СтрокаТЧ.Параметр 	= Параметр;
				СтрокаТЧ.Значение = Значение;
			Иначе
				СтрокаТЧ 			= Объект.Параметры.Добавить();			
				СтрокаТЧ.Параметр 	= Параметр;				
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СудебноеУчреждение(Основание)
	ОтборСтроения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Основание, "МКД");
	Возврат Справочники.энргСудебныеУчастки.ПолучитьСудебноеУчреждениеПоСтроению(ОтборСтроения);	
КонецФункции

#КонецОбласти

#Область СобытияОтправкиПисьмаНаПочту

&НаКлиенте
Процедура ОтправитьУведомление(Команда)
	Ошибки = ОшибкиПередРегистрациейВыполненияСобытия();
	Если Ошибки.Количество() > 0 Тогда
		ПоказатьПредупреждение(, СтрСоединить(Ошибки, Символы.ПС));
		Возврат;
	КонецЕсли;
	
	Результат = ЗарегистрироватьСтатусВыполнен();
	ОбновитьНадписьСтатусаСобытия();
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаСервере
Процедура УправлениеВидимостью()
	УправлениеВидимостьюФункцийСогласования();
	УправлениеВидимостьюФункцииОтправкиНаПочту();
КонецПроцедуры

&НаСервере
Процедура УправлениеВидимостьюФункцийСогласования()
	ЗначениеСвойства = ПолучитьСвойствоТребуетСогласования();
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаГруппаСогласования", "Видимость", ЗначениеСвойства);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Согласование"			, "Видимость", ЗначениеСвойства);
КонецПроцедуры

&НаКлиенте
Процедура УправлениеВидимостьюФункцийПечати()
	СписокМакетовТипа = ПолучитьТипыМакетов();
	МакетПоиска = Элементы.ФормаКоманднаяПанель.ПодчиненныеЭлементы.ФормаПечать.ПодчиненныеЭлементы;
	Для каждого Строка Из  МакетПоиска Цикл 
		Строка.Видимость = Ложь;
	КонецЦикла;
	
	Для каждого Макет Из СписокМакетовТипа Цикл
		Если ЗначениеЗаполнено(Макет) Тогда
			Для каждого Строка Из  МакетПоиска Цикл
				Если СтрЗаменить(ВРег(Макет), " ", "") = Сред(Врег(Строка.Имя),38) Тогда
					Строка.Видимость = Истина;
				КонецЕсли;  				
			КонецЦикла;			
		КонецЕсли;
	КонецЦикла; 	
КонецПроцедуры 

&НаСервере
Процедура УправлениеВидимостьюФункцииОтправкиНаПочту()
	ЗначениеСвойства = ПолучитьСвойствоСобытиеОтправки();
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СпособОтправки"	, "Видимость", ЗначениеСвойства);
	
	ЗначениеСвойства = Объект.СпособОтправки = ПредопределенноеЗначение("Справочник.энргСпособыОтправкиУведомлений.ЭлектроннаяПочта");	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаОтправитьУведомление"	, "Видимость", ЗначениеСвойства);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Выполнено"					, "Видимость", НЕ ЗначениеСвойства);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаПередатьНаСогласование", "Видимость", НЕ ЗначениеСвойства);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Группа7"					, "Видимость", ЗначениеСвойства);
	
	ЗначениеСвойства = ПустаяСтрока(Объект.МакетПечатнойФормы);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаШаблонСообщения", "Видимость", ЗначениеСвойства);
КонецПроцедуры

&НаСервере
Функция ПолучитьТипыМакетов()
СписокМакетовТипа = Справочники.энргСпособСвязи.ПолучитьСписокМакетовПФ(Объект.ТипСобытия);
Возврат СписокМакетовТипа;	
КонецФункции

&НаКлиенте
Процедура УстановитьПараметрыВыбораПриИзмененииТипСобытия()
	// Этапы
	МассивЭтапов 		= ПолучитьМассивЭтаповИзТипаСобытия();
	НовыйМассив 		= Новый Массив;
	Если НЕ МассивЭтапов.Количество() = 0 Тогда		
		НовыйПараметр 							= Новый ПараметрВыбора("Отбор.Ссылка", МассивЭтапов);		
		НовыйМассив.Добавить(НовыйПараметр);
		ЗначениеСвойства 						= Новый ФиксированныйМассив(НовыйМассив);
	Иначе 
		ЗначениеСвойства						= Новый ФиксированныйМассив(НовыйМассив);
	КонецЕсли; 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Этап", "ПараметрыВыбора", ЗначениеСвойства);
	
	// Согласующие
	МассивСогласующих 	= ПолучитьДоступныеСогласующиеИзТипаСобытия();
	НовыйМассив 		= Новый Массив;
	Если НЕ МассивСогласующих.Количество() = 0 Тогда		
		НовыйПараметр 							= Новый ПараметрВыбора("Отбор.Ссылка", МассивСогласующих);		
		НовыйМассив.Добавить(НовыйПараметр);
		ЗначениеСвойства 						= Новый ФиксированныйМассив(НовыйМассив);
	Иначе 
		ЗначениеСвойства						= Новый ФиксированныйМассив(НовыйМассив);
	КонецЕсли; 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Согласующий", "ПараметрыВыбора", ЗначениеСвойства);	
КонецПроцедуры


&НаСервере
Процедура ИзменитьНазванияПолейТЧ()
	Если Объект.ТипСобытия 	= Справочники.энргСпособСвязи.НаправлениеУведомленияИсполнителюНаВводОРП 			ИЛИ
		Объект.ТипСобытия 	= Справочники.энргСпособСвязи.НаправлениеУведомленияИсполнителюОПереносеОРП 		ИЛИ
		Объект.ТипСобытия 	= Справочники.энргСпособСвязи.НаправлениеУведомленияИсполнителюОбОтменеОРП 			ИЛИ
		Объект.ТипСобытия 	= Справочники.энргСпособСвязи.НаправлениеУведомленияОВозобновленииЭнергоснабжения 	Тогда
		Элементы.Абоненты.ПодчиненныеЭлементы.ПотребителиАбонент.Заголовок = "Абоненты";
	КонецЕсли;
КонецПроцедуры


&НаСервере
Процедура ОбновитьСтатусСогласованияСобытия()
	Результат 	= энргОбщегоНазначения.ПолучитьАктуальныйСтатусСобытия(ТекущаяДата(), Объект.Организация, Объект.Район, Объект.Ссылка);
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	СтатусСогласования = Выборка.Статус;
	Если СтатусСогласования = Перечисления.энргСтатусыСогласованияСобытий.Согласовано Тогда
		ДатаСогласования = Выборка.Период;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтатусВыполненияСобытия()
	Результат = энргОбщегоНазначения.ПолучитьАктуальныйСтатусВыполненияСобытия(ТекущаяДата(), Объект.Организация, Объект.Район, Объект.Ссылка);
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка 	= Результат.Выбрать();
	Выборка.Следующий();
	
	СтатусВыполнения = Выборка.Статус;
	Если Выборка.Статус Тогда
		Исполнитель 	= Выборка.Ответственный;
		ДатаВыполнения 	= Выборка.Период;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПочтуУАбонентов()
	Для каждого стр из Объект.Абоненты Цикл
		Абонент = стр.Абонент;
		Если ТипЗнч(Абонент) = Тип("СправочникСсылка.энргДоговорыКонтрагентов") Тогда
			Контрагент = Абонент.Контрагент;
			КИ = Контрагент.КонтактнаяИнформация;
			мПочта = КИ.НайтиСтроки(Новый Структура("Вид", Справочники.ВидыКонтактнойИнформации.EmailКонтрагента));
			Для каждого Адрес из мПочта Цикл
				НовСтр = Объект.Параметры.Добавить();
				НовСтр.Параметр = ПланыВидовХарактеристик.бестПараметрыТиповСобытий.АдресЭлектроннойПочты;
				НовСтр.Значение = Адрес.Представление;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры // ОбновитьПочтуУАбонентов()

&НаСервере
Процедура ОбновитьНадписьСтатусаСобытия()
	ЗначениеСвойства = "Статус: ";
	Если СтатусВыполнения Тогда 
		ЗначениеСвойства = ЗначениеСвойства + "Выполнено";
	Иначе
		ЗначениеСвойства = ЗначениеСвойства + СтатусСогласования;
	КонецЕсли; 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтатусСобытия", "Заголовок", ЗначениеСвойства);
КонецПроцедуры



&НаСервере
Функция ПолучитьСвойствоТребуетСогласования()
	Если ЗначениеЗаполнено(Объект.ТипСобытия) Тогда 
		ЗначениеСвойства = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ТипСобытия, "ТребуетСогласования");
	Иначе 
		ЗначениеСвойства = Ложь;
	КонецЕсли;
	
	Возврат ЗначениеСвойства;
КонецФункции

&НаСервере
Функция ПолучитьСвойствоСобытиеОтправки()
	Если ЗначениеЗаполнено(Объект.ТипСобытия) Тогда 
		ЗначениеСвойства = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ТипСобытия, "СобытиеОтправки");
	Иначе 
		ЗначениеСвойства = Ложь;
	КонецЕсли;
	
	Возврат ЗначениеСвойства;
КонецФункции

&НаСервере
Функция ПолучитьМассивЭтаповИзТипаСобытия()	
	Возврат Справочники.энргСпособСвязи.ПолучитьДоступныеЭтапыПИР(Объект.ТипСобытия);
КонецФункции

&НаСервере
Функция ПолучитьДоступныеСогласующиеИзТипаСобытия()
	Результат 	= Новый Массив;
	
	МассивРолей = Справочники.энргСпособСвязи.ПолучитьРолиСогласующих(Объект.ТипСобытия);
	Если МассивРолей.Количество() = 0 Тогда 
		Возврат Результат;
	КонецЕсли;
	
	РезультатЗапроса	= энргОбщегоНазначения.ПолучитьПользователейСОтборомПоРолям(Объект.Организация, Объект.Район, МассивРолей);
	Результат			= РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Пользователь");
	
	Возврат Результат
КонецФункции


&НаСервере
Функция ПолучитьНенужныхАбонентов()
	Результат 				= Новый Массив;
	
	Период 					= Новый Граница(Объект.Дата, ВидГраницы.Исключая);
	СписокАбонентовОтбор 	= Объект.Абоненты.Выгрузить().ВыгрузитьКолонку("Абонент");
	РезультатЗапроса		= Задачи.энргЗадачаПИД.ПолучитьЗадачиПринятыеВРаботуПоАбонентам(Период, СписокАбонентовОтбор);
	Выборка 				= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(СписокАбонентовОтбор, Выборка.Абонент);
	КонецЦикла;
	
	Если НЕ СписокАбонентовОтбор.Количество() = 0 Тогда
		Результат = СписокАбонентовОтбор;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область РасчетСроковВУведомленииОВводеОРП

&НаСервере
Процедура РасчитатьСрокиОУведомленииОВводеОРП()
	Если НЕ Объект.ТипСобытия = Справочники.энргСпособСвязи.НаправлениеУведомленияНаВводОРП Тогда 
		Возврат;
	КонецЕсли;
	
	Если Объект.СпособОтправки = Справочники.энргСпособыОтправкиУведомлений.ЗаказнойПочтой Тогда
		РасчитатьСрокиОРППриОтправкеЗаказнойПочтой();	
	ИначеЕсли Объект.СпособОтправки = Справочники.энргСпособыОтправкиУведомлений.ВручитьПодРоспись Тогда 
		РасчитатьСрокиОРППриВручинииПодРоспись();	
	КонецЕсли;
КонецПроцедуры


&НаСервере
Процедура РасчитатьСрокиОРППриОтправкеЗаказнойПочтой()
	ПВХ				= ПланыВидовХарактеристик.бестПараметрыТиповСобытий.СрокПогашенияЗадолженности;
	ИскомыеСтроки 	= Объект.Параметры.НайтиСтроки(Новый Структура("Параметр", ПВХ));
	Если ИскомыеСтроки.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден параметр: " + ПВХ);
		Возврат;
	КонецЕсли;
	
	СрокДляОтправкиЗаказнойПочтой = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПВХ, "СрокДляОтправкиЗаказнойПочтой");
	
	СтрокаПараметра 			= ИскомыеСтроки[0];
	СтрокаПараметра.Значение 	= Объект.Дата + (86400 * СрокДляОтправкиЗаказнойПочтой);	
КонецПроцедуры

&НаСервере
Процедура РасчитатьСрокиОРППриВручинииПодРоспись()
	ПВХ				= ПланыВидовХарактеристик.бестПараметрыТиповСобытий.СрокПогашенияЗадолженности;
	ИскомыеСтроки 	= Объект.Параметры.НайтиСтроки(Новый Структура("Параметр", ПВХ));
	Если ИскомыеСтроки.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден параметр: " + ПВХ);
		Возврат;
	КонецЕсли;
	
	СрокДляВрученияПодРоспись 	= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПВХ, "СрокДляВрученияПодРоспись");		
	СтрокаПараметра 			= ИскомыеСтроки[0];
	ДатаПогашенияЗадолженности	= Объект.Дата + (86400 * СрокДляВрученияПодРоспись);
	СтрокаПараметра.Значение 	= ДатаПогашенияЗадолженности;
	
	
	ПВХ				= ПланыВидовХарактеристик.бестПараметрыТиповСобытий.ПланируемаяДатаВведенияОРП;
	ИскомыеСтроки 	= Объект.Параметры.НайтиСтроки(Новый Структура("Параметр", ПВХ));
	Если ИскомыеСтроки.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден параметр: " + ПВХ);
		Возврат;
	КонецЕсли;
	
	СрокДляВрученияПодРоспись 	= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПВХ, "СрокОтКрайнейДатыПогашенияДолга");		
	СтрокаПараметра 			= ИскомыеСтроки[0];
	СтрокаПараметра.Значение 	= ДатаПогашенияЗадолженности + (86400 * СрокДляВрученияПодРоспись);	
КонецПроцедуры

#КонецОбласти

#Область РаботаСШаблономСообщений

&НаСервере
Процедура ИнициализироватьШаблоныСообщений()
	Справочники.энргШаблоныСообщений.ДобавлениеКомандПараметров(ЭтаФорма, "КомандыПараметрыТемы", "КомТемы", "ВставитьПараметр");
	Справочники.энргШаблоныСообщений.ДобавлениеКомандПараметров(ЭтаФорма, "КомандыПараметрыТекста", "КомТекста", "ВставитьПараметр");
	
	Элементы.МакетПечатнойФормы.СписокВыбора.Очистить();
	СписокМакетов = Справочники.энргВидыОперацийПИД.ПолучитьСписокМакетовПечати();
	Элементы.МакетПечатнойФормы.СписокВыбора.Добавить("", "Нет");
	Для каждого ТекЭлем Из СписокМакетов Цикл
		Элементы.МакетПечатнойФормы.СписокВыбора.Добавить(ТекЭлем.Значение, ТекЭлем.Представление);
	КонецЦикла;
КонецПроцедуры


&НаКлиенте
Процедура ВставитьПараметр(Команда)
	Если Лев(Команда.Имя, 7) = "КомТемы" Тогда
		Элемент = Элементы.ТемаСобытия;
	Иначе
		Элемент = Элементы.ТекстШаблона;
	КонецЕсли;
	
	Элемент.ВыделенныйТекст = ВставитьПараметрНаСервере(Команда.Имя);
КонецПроцедуры

&НаСервере
Функция ВставитьПараметрНаСервере(ИмяКоманды)
	Префикс = ?(Лев(ИмяКоманды, 7) = "КомТемы", "КомТемы", "КомТекста");
	Возврат Справочники.энргШаблоныСообщений.ЗаменаКоманды(ИмяКоманды, Префикс); 
КонецФункции

&НаКлиенте
Процедура ВыбратьШаблон(Команда)
	ОткрытьФорму("Справочник.энргШаблоныСообщений.ФормаВыбора",, Элементы.ТекстШаблона);
КонецПроцедуры

&НаКлиенте
Процедура МакетПечатнойФормыПриИзменении(Элемент)
	УправлениеВидимостью();
	//ЗначениеСвойства = Объект.СпособОтправки = ПредопределенноеЗначение("Справочник.энргСпособыОтправкиУведомлений.ЭлектроннаяПочта");	
	//ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Группа7", "Видимость", ЗначениеСвойства);
КонецПроцедуры

&НаКлиенте
Процедура ТемаСобытияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ОткрытьФорму("Справочник.энргШаблоныСообщений.ФормаВыбора",, Элемент);
КонецПроцедуры

&НаКлиенте
Процедура ТемаСобытияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Объект.ТемаСобытия = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыбранноеЗначение, "Наименование"); 
		Объект.ТекстШаблона = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыбранноеЗначение, "ТекстШаблона"); 
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ТекстШаблонаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Объект.ТемаСобытия 	= энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыбранноеЗначение, "Наименование");
		Объект.ТекстШаблона = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыбранноеЗначение, "ТекстШаблона"); 
	КонецЕсли;
КонецПроцедуры

#КонецОбласти