#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс 

// Получает действующие услуги строения.
//
// Параметры:
//  Организация			-	СправочникСсылка.Организации.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  МКД					-	СправочникСсылка.энргСтроения.
//  ПолучаемыеСвойства	-	Структура.
//  Период				-	Дата.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ДействующиеУслугиСтроения(Организация,Район,МКД,ПолучаемыеСвойства = "",Период = Неопределено) Экспорт 
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		Если слжОбщегоНазначенияМодуль.ВоспроизводитьРезультатМетодов() Тогда; 
			Если НЕ Метаданные.Обработки.Найти("слжСостояниеУслугСтроенийМенеджер") = Неопределено Тогда
				Возврат Обработки["слжСостояниеУслугСтроенийМенеджер"].ДействующиеУслугиСтроения(Организация,Район,МКД,Период);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	мПолучаемыеСвойства 			= СтрРазделить(ПолучаемыеСвойства,",",Ложь);
	Схема 							= Неопределено;
	ПараметрыСхемы 					= Новый Структура;
	ПараметрыЗапроса 				= Новый Структура("Организация,Район,МКД",Организация,Район,МКД);
	Если Не Период = Неопределено Тогда
		ПараметрыСхемы.Вставить("Период", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("Период"));
		ПараметрыЗапроса.Вставить("Период", Период);
	КонецЕсли;
	
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Организация,Район,МКД,Строение","Организация","Район","МКД","МКД")));
	
	РегистрыСведений.энргАктивностьТочекУчетаМКД.АктивныеТочкиУчета(Схема,ПараметрыСхемы,"ДействующиеТочкиУчета");
	РегистрыСведений.энргУслугиТочекУчетаМКД.УслугиДействующихТочек(Схема,ПараметрыСхемы,"УслугиДействующихТочек");
	РегистрыСведений.энргПоставщикиУслугМКД.ЗаполнитьСхемуПоставщикиУслугМКД(Схема,ПараметрыСхемы,"ПоставщикиУслугМКД");
	
	Если НЕ мПолучаемыеСвойства.Найти("СтруктураСети") = Неопределено Тогда
		РегистрыСведений.энргТУМКДНаСтруктуреСети.ЗаполнитьСхемуСтруктураСетиДействующихТочек(Схема,ПараметрыСхемы,"СтруктураСетиДействующихТочек");
	КонецЕсли;  	
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаДействующиеУслугиСтроения());
	
	Если НЕ мПолучаемыеСвойства.Найти("СтруктураСети") = Неопределено Тогда
		ГлавныйОператорВыбора  		= Пакет.Операторы[0];
		ИсточникВложенныйЗапрос 	= ГлавныйОператорВыбора.Источники[0].Источник.Запрос;
		ОператорВложенного 			= ИсточникВложенныйЗапрос.Операторы[0];
		ВторойВложенныйИсточник 	= ОператорВложенного.Источники[0].Источник.Запрос;
		ОператорВыбора 				= ВторойВложенныйИсточник.Операторы[0];
		ИсточникСтруктураСети 		= ОператорВыбора.Источники.Добавить("СтруктураСетиДействующихТочек");
		
		мУсловияСоединения 			= Новый Массив;
		мУсловияСоединения.Добавить("ДействующиеТочкиУчета.Организация = СтруктураСетиДействующихТочек.Организация");
		мУсловияСоединения.Добавить("ДействующиеТочкиУчета.Район = СтруктураСетиДействующихТочек.Район");
		мУсловияСоединения.Добавить("ДействующиеТочкиУчета.МКД = СтруктураСетиДействующихТочек.МКД");
		мУсловияСоединения.Добавить("ДействующиеТочкиУчета.ТочкаУчета = СтруктураСетиДействующихТочек.ТочкаУчета");
		
		Соединение 					= ОператорВыбора.Источники[0].Соединения.Добавить("СтруктураСетиДействующихТочек",СтрСоединить(мУсловияСоединения,Символы.ПС + " И "));
		ОператорВыбора.ВыбираемыеПоля.Добавить("ЕСТЬNULL(СтруктураСетиДействующихТочек.СтруктураСети, Значение(Справочник.бестСтруктураСети.ПустаяСсылка))");
		КолонкаЗапроса  			= ВторойВложенныйИсточник.Колонки[ВторойВложенныйИсточник.Колонки.Количество()-1];
		КолонкаЗапроса.Псевдоним 	= "СтруктураСети";
		
		ОператорВложенного.ВыбираемыеПоля.Добавить("ВложенныйЗапрос.СтруктураСети");
		КолонкаЗапроса  			= ИсточникВложенныйЗапрос.Колонки[ИсточникВложенныйЗапрос.Колонки.Количество()-1];
		КолонкаЗапроса.Псевдоним 	= "СтруктураСети";
		
		ГлавныйОператорВыбора.ВыбираемыеПоля.Добавить("ВложенныйЗапрос.СтруктураСети");
		КолонкаЗапроса  			= Пакет.Колонки[Пакет.Колонки.Количество()-1];
		КолонкаЗапроса.Псевдоним 	= "СтруктураСети";
	КонецЕсли;
	
	Результат						= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "СостояниеУслугСтроенийМенеджер.ДействующиеУслугиСтроения";
		ПараметрыМетода 			= Новый Структура("Организация,Район,МКД,Период", Организация,Район,МКД,Период);
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультатЗапросаКодом(ИмяМетода, Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаДействующиеУслугиСтроения()
	Текст  =
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.СоставнаяУслуга КАК СоставнаяУслуга,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.ЧастьСоставной КАК ЧастьСоставной,
	|	ЕСТЬNULL(ПоставщикиУслугМКД.Поставщик, ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка)) КАК Поставщик
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.Организация КАК Организация,
	|		ВложенныйЗапрос.Район КАК Район,
	|		ВложенныйЗапрос.МКД КАК МКД,
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		ЕСТЬNULL(энргВидыУслугСоставляющиеУслуг.Ссылка, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК СоставнаяУслуга,
	|		ВЫБОР
	|			КОГДА энргВидыУслугСоставляющиеУслуг.Ссылка ЕСТЬ NULL
	|				ТОГДА ВложенныйЗапрос.Услуга
	|			ИНАЧЕ энргВидыУслугСоставляющиеУслуг.Услуга
	|		КОНЕЦ КАК Услуга,
	|		ВЫБОР
	|			КОГДА энргВидыУслугСоставляющиеУслуг.Ссылка ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ КАК ЧастьСоставной
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ДействующиеТочкиУчета.Организация КАК Организация,
	|			ДействующиеТочкиУчета.Район КАК Район,
	|			ДействующиеТочкиУчета.МКД КАК МКД,
	|			ДействующиеТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|			ЕСТЬNULL(УслугиДействующихТочек.Услуга, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)) КАК Услуга
	|		ИЗ
	|			ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
	|				ЛЕВОЕ СОЕДИНЕНИЕ УслугиДействующихТочек КАК УслугиДействующихТочек
	|				ПО ДействующиеТочкиУчета.Организация = УслугиДействующихТочек.Организация
	|					И ДействующиеТочкиУчета.Район = УслугиДействующихТочек.Район
	|					И ДействующиеТочкиУчета.МКД = УслугиДействующихТочек.МКД
	|					И ДействующиеТочкиУчета.ТочкаУчета = УслугиДействующихТочек.ТочкаУчета) КАК ВложенныйЗапрос
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|			ПО ВложенныйЗапрос.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПоставщикиУслугМКД КАК ПоставщикиУслугМКД
	|		ПО ВложенныйЗапрос.Организация = ПоставщикиУслугМКД.Организация
	|			И ВложенныйЗапрос.Район = ПоставщикиУслугМКД.Район
	|			И ВложенныйЗапрос.МКД = ПоставщикиУслугМКД.МКД
	|			И ВложенныйЗапрос.ТочкаУчета = ПоставщикиУслугМКД.ТочкаУчета
	|			И ВложенныйЗапрос.Услуга = ПоставщикиУслугМКД.Услуга
	|			И ВложенныйЗапрос.ЧастьСоставной = ПоставщикиУслугМКД.ЧастьСоставной";	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#КонецЕсли