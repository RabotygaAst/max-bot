#Область ВспомогательныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьСписокАбонентовСервер()
	
	Объект.Абоненты.Очистить();
	
	Результат 								= энргРаботаСЛицевымСчетомСервер.ТочкиУчетаРазделенныхЛС(Объект.Дата,Объект.Организация,Объект.Район,Объект.КлючПомещения, Объект.Услуга); 
	Выборка  								= Результат.выбрать();
	
	Пока Выборка.следующий() цикл
		НовСтр  					= Объект.Абоненты.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Выборка);		
	КонецЦикла;
	
КонецПроцедуры


#КонецОбласти
