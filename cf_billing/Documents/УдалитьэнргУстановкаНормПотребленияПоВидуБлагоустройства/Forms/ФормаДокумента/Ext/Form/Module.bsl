

#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании

	// МенюОтчеты
	МенюОтчеты.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюОтчеты);
	// Конец МенюОтчеты

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если Не ЗначениеЗаполнено(Объект.Ссылка) тогда
		Если Объект.ЗначенияНормВода.Количество() > 0 тогда			
			СтраницаРодитель  					= Элементы.СтраницаИндивидуальныеНормы;
			Элементы.Страницы.ТекущаяСтраница 	= СтраницаРодитель;
			СтраницаРодитель 					= Элементы.СтраницыИндивидуальныеНормыЖКХ;
			СтраницаРодитель.ТекущаяСтраница 	= Элементы.СтраницаНормыВода;
		ИначеЕсли Объект.ЗначенияНормЭлектроэнергия.Количество() > 0 тогда 			
			СтраницаРодитель  					= Элементы.СтраницаИндивидуальныеНормы;
			Элементы.Страницы.ТекущаяСтраница 	= СтраницаРодитель;
			СтраницаРодитель 					= Элементы.СтраницыИндивидуальныеНормыЖКХ;
			СтраницаРодитель.ТекущаяСтраница 	= Элементы.СтраницаНормыЭлектроэнергия;
		ИначеЕсли Объект.ЗначениеНормМКДВода.Количество() > 0 тогда
			СтраницаРодитель  					= Элементы.СтраницыНормыОДН;
			Элементы.Страницы.ТекущаяСтраница 	= СтраницаРодитель;
			СтраницаРодитель 					= Элементы.СтраницыНормыПотребленияОДНЖКХ;
			СтраницаРодитель.ТекущаяСтраница 	= Элементы.СтраницаНормыОДНВода;
		ИначеЕсли Объект.ЗначениеНормМКДЭлектроэнергия.Количество() > 0 тогда			
			СтраницаРодитель  					= Элементы.СтраницыНормыОДН;
			Элементы.Страницы.ТекущаяСтраница 	= СтраницаРодитель;
			СтраницаРодитель 					= Элементы.СтраницыНормыПотребленияОДНЖКХ;
			СтраницаРодитель.ТекущаяСтраница 	= Элементы.СтраницаНормыОДНЭлектроэнергия;
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

