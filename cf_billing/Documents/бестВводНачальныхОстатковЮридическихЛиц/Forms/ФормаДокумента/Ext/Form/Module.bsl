
#Область СобытияФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	бестЛокализацияСервер.ПриСозданииНаСервере_бестПлатежныйДокумент(ЭтотОбъект);
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Задолженность, "ДокументОснование", Объект.Ссылка);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Оплата,        "ДокументОснование", Объект.Ссылка);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(СчетФактурыНаАванс, "ДокументОснование", Объект.Ссылка);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(СчетФактурыНаАванс, "ДокументОплаты", 
		Документы.бестПлатежноеПоручениеВходящееЭЭЮрЛица.ПустаяСсылка());
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	Обработки.бестФормированиеПлатежныхДокументов.СоздатьСФНаАванс(Новый Структура("ВводНачальныхОстатков", Объект.Ссылка));
КонецПроцедуры

#КонецОбласти

#Область Команды

&НаКлиенте
Процедура ЗарегистрироватьЗадолженность(Команда)
	ДопПараметры = Новый Структура();
	ДопПараметры.Вставить("ЭтоОплата", Ложь);
	ДопПараметры.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.бестВидыОпераций.ПлатежныйДокумент_Расчетный"));
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		НовоеОписаниеОповещение = Новый ОписаниеОповещения("ОткрытьПДПослеВопроса", ЭтотОбъект, ДопПараметры);
		ПоказатьВопрос(НовоеОписаниеОповещение, "Необходимо записать документ. Записать данный документ?", РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;

	ОткрытьПодчиненныйДокумент(ДопПараметры);
КонецПроцедуры

