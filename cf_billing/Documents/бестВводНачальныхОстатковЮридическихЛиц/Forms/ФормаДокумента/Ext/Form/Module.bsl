#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОткрытьПДПослеВопроса(Результат, ДопПараметры) Экспорт
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Записать();
	ОткрытьПодчиненныйДокумент(ДопПараметры);
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПодчиненныйДокумент(ДопПараметры)
	ДанныеЗаполнения  = Новый Структура;
	ДанныеЗаполнения.Вставить("Район",				Объект.Район);
	ДанныеЗаполнения.Вставить("Организация",		Объект.Организация);
	ДанныеЗаполнения.Вставить("ДокументОснование",	Объект.Ссылка);

	Если ДопПараметры.ЭтоОплата Тогда
				
		ПараметрыОткрытия  =Новый Структура;
		ПараметрыОткрытия.Вставить("ЗначенияЗаполнения",ДанныеЗаполнения);
		ОткрытьФорму("Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица.ФормаОбъекта", ПараметрыОткрытия);
		
	Иначе 
		
		ДанныеЗаполнения.Вставить("ВидОперации",		ДопПараметры.ВидОперации);
		ДанныеЗаполнения.Вставить("ТипЗадолженности",	ПредопределенноеЗначение("Перечисление.бестВидыРасчета.Фактический"));
		ДанныеЗаполнения.Вставить("Договор",			Объект.Договор);
		
		ПараметрыОткрытия  =Новый Структура;
		ПараметрыОткрытия.Вставить("ЗначенияЗаполнения",ДанныеЗаполнения);
		ОткрытьФорму("Документ.бестПлатежныйДокумент.ФормаОбъекта", ПараметрыОткрытия);
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрДокументОплаты(ПлатежноеПоручениеВходящее)
	   ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(СчетФактурыНаАванс, "ДокументОплаты", ПлатежноеПоручениеВходящее);
КонецПроцедуры
   
#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОплата

&НаКлиенте
Процедура ОплатаПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.Оплата.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		УстановитьПараметрДокументОплаты(ТекДанные.ПлатежноеПоручениеВходящее);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти