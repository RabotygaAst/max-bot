Процедура УстановитьОтборТарифныхЗонПоУмолчанию() 
	ИмяТаблицыПоказаний						= "НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона";
	ИмяТаблицыОригинальныхЗон				= "ТекущиеПоказанияПриборовУчета";
	ТаблицаФормыПоказаний	 				= Элементы[ИмяТаблицыПоказаний];
	ТаблицаФормыОригинальныхЗон				= Элементы[ИмяТаблицыОригинальныхЗон];
	
	ТаблицаФормыПоказаний.ОтборСтрок		= Новый ФиксированнаяСтруктура("ОригинальнаяТарифнаяЗона", Ложь);
	//	ТаблицаФормыОригинальныхЗон.ОтборСтрок	= Новый ФиксированнаяСтруктура("ОригинальнаяТарифнаяЗона", Истина); 
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборСтрокПоказаний()
	
	ИмяТаблицыТочек 						= "НеЗагруженныеДанныеНеЗагруженныеПоказания";
	ИмяТаблицыПоказаний						= "НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона";
	ИмяТаблицыОригинальныхЗон				= "ТекущиеПоказанияПриборовУчета";
	ТаблицаФормыПоказаний	 				= Элементы[ИмяТаблицыПоказаний];
	ТаблицаФормыОригинальныхЗон				= Элементы[ИмяТаблицыОригинальныхЗон];
	
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаФормыПоказаний.ОтборСтрок		= Новый ФиксированнаяСтруктура("IDСтроки, ОригинальнаяТарифнаяЗона", ТекущиеДанные.IDСтроки, Ложь);
	ТаблицаФормыОригинальныхЗон.ОтборСтрок	= Новый ФиксированнаяСтруктура("IDСтрокиТочкиУчета", ТекущиеДанные.IDСтроки);
	
