#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//энргЛокализацияСервер.ПриСозданииНаСервере_энргОбходнойЛист(ЭтотОбъект);
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если НЕ ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			ОпределитьПериодНачисления();
		КонецЕсли;
	КонецЕсли;
	УстановитьСвойстваЭлементовФормы();
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	УстановитьЗначениеСвойстваСкрытьСтроку();
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьОтборТарифныхЗонПоУмолчанию();
	ЗаполнитьКоличествоАктивныхДлительныхОпераций();
	ПоказатьНадписьСозданияДокументов(); 
	УстановитьОтборЗагруженныхДанных();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ОсталосьСоздатьДокументовДлительныхОпераций = КоличествоОсталосьСоздатьДокументовРегистратора(ТекущийОбъект.Ссылка);
	
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	ЗаполнитьТаблицуПоказанийИзФайла();
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ЗаполнитьТаблицуПоказанийИзФайла();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда		
		ОпределитьПериодНачисления();
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	ОпределитьПериодНачисления();
КонецПроцедуры

&НаКлиенте
Процедура ИсточникПоказанийПриИзменении(Элемент)
	УстановитьСвойстваЭлементовФормы();
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗагруженныеДанныеЗагруженныеПУ

&НаКлиенте
Процедура ЗагруженныеДанныеЗагруженныеПУПриАктивизацииСтроки(Элемент)
	
	ТаблицаФормыПоказанияИзФайла = Элементы["ЗагруженныеПоказанияИзФайла"];
	ТаблицаФормыПоказанияИзБазы	= Элементы["ЗагруженныеПоказанияИзБазы"];
	
	ТекущиеДанные = Элементы["ЗагруженныеДанныеЗагруженныеПУ"].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаФормыПоказанияИзФайла.ОтборСтрок = Новый ФиксированнаяСтруктура("IDСтроки", ТекущиеДанные.IDСтроки);
	ТаблицаФормыПоказанияИзБазы.ОтборСтрок = Новый ФиксированнаяСтруктура("IDСтрокиТочкиУчета", ТекущиеДанные.IDСтроки);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТекущиеПоказанияПриборовУчета

&НаКлиенте
Процедура ТекущиеПоказанияПриборовУчетаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда
		ТекущиеПоказанияНезагруженные = Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказания.ТекущиеДанные; 
		Элемент.ТекущиеДанные.IDСтроки = ТекущиеПоказанияНезагруженные.IDСтроки;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыНеЗагруженныеДанныеНеЗагруженныеПоказания

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияПриАктивизацииСтроки(Элемент)
	
	УстановитьОтборСтрокПоказаний();
	// ОбновитьАктуальныеПриборыУчетаКлючаПомещенияКВыбору(); тест закоментил
	
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияНомерПрибораУчетаСталоНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекДанные = Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказания.ТекущиеДанные;
	ОпределитьАктуальныеПриборыУчета(ТекДанные);
КонецПроцедуры 

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияПриИзменении(Элемент)
	ТекДанные = Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказания.ТекущиеДанные;
	СтрокаЗаполнена = ЗначениеЗаполнено(ТекДанные.Договор) И ЗначениеЗаполнено(ТекДанные.ОбъектРасчета) И ЗначениеЗаполнено(ТекДанные.НомерПрибораУчетаСтало);   
	Если СтрокаЗаполнена Тогда        
		ТекДанные.Исправлен = Истина;
		ОбновитьДанныеПрибораУчета(ТекДанные); 
	Иначе
		ТекДанные.Исправлен = Ложь;
		ОчиститьТЧ(ТекДанные.IDСтроки);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьЗначениеСвойстваСкрытьСтроку()
	Для Каждого ТекСтрока Из Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания Цикл		
		ТекСтрока.СкрытьСтроку = ТекСтрока.ОписаниеОшибки = "ПУ не найден";
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

