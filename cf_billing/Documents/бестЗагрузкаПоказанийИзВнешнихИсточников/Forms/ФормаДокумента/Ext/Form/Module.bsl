&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры

// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

#Область ЗагрузкаДанных

&НаКлиенте
Процедура ЗаполнитьПоказания(Команда)
	
	Ошибки = ПроверитьВозможностьЗагрузки();
	Если НЕ ПустаяСтрока(Ошибки) Тогда 
		НовоеОписаниеОповощение = Новый ОписаниеОповещения("ЗаполнитьПоказанияПослеВопроса", ЭтотОбъект);
		ПоказатьВопрос(НовоеОписаниеОповощение,Ошибки,РежимДиалогаВопрос.ДаНет,,,,);
		Возврат;
	КонецЕсли;
	Если ЕстьНеЗагруженныеДанные() Тогда 
		НовоеОписаниеОповощение = Новый ОписаниеОповещения("ЗаполнитьПоказанияПослеВопросаОчистки", ЭтотОбъект);
		ПоказатьВопрос(НовоеОписаниеОповощение, "Данные табличных частей документа будут очищены. Продолжить загрузку?", РежимДиалогаВопрос.ДаНет,,, "Очистка данных");
	Иначе 
		ОчиститьТЧ();
		ЗагрузитьПоказания(); 
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ОткрытьФормуЗапускаСозданияДокументов(Команда)
	ОткрытьФормуЗапускаСозданияДокументовВФоне();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПодборПрибораУчета

&НаКлиенте
Процедура ОпределитьАктуальныеПриборыУчета(ТекДанные)
	
	ОбъектРасчета = ТекДанные.ОбъектРасчета;
	
	ИдентификаторСтроки = ТекДанные.IDСтроки;
	
	ПараметрыОтбораПрибораУчета = НовыеПараметрыОтбораПрибораУчета();
	ПараметрыОтбораПрибораУчета.Организация				= Объект.Организация;
	ПараметрыОтбораПрибораУчета.Вставить("Период",		Объект.Дата);
	ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало 	= ТекДанные.НомерПрибораУчетаСтало;
	ПараметрыОтбораПрибораУчета.Район 					= энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекДанные.Договор, "Район");		
	ПараметрыОтбораПрибораУчета.ОбъектРасчета			= ТекДанные.ОбъектРасчета;
		
	ПредставлениеПриборыУчета = Новый СписокЗначений;// Обратная совместимость
	АктуальныеПриборыУчета(ПараметрыОтбораПрибораУчета, ПредставлениеПриборыУчета);
	ДополнитьАктуальныеПриборыУчетаКВыбору(ПредставлениеПриборыУчета);
	
КонецПроцедуры  

&НаКлиенте
Процедура ДополнитьАктуальныеПриборыУчетаКВыбору(мПриборыУчета)
	
	Если ТипЗнч(мПриборыУчета) = Тип("СписокЗначений") Тогда
		
		ЭлементФомы = Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказанияНомерПрибораУчетаСтало;
		ЭлементФомы.СписокВыбора.Очистить();
		Для Каждого ТекКлючЗначение из мПриборыУчета Цикл
			ЭлементФомы.СписокВыбора.Добавить(ТекКлючЗначение.Значение, ТекКлючЗначение.Представление);
		КонецЦикла;
		
		Возврат;
	КонецЕсли;
	
	мПриборыУчета = ОбщегоНазначенияКлиентСервер.СвернутьМассив(мПриборыУчета);
	Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказанияНомерПрибораУчетаСтало.СписокВыбора.ЗагрузитьЗначения(мПриборыУчета);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура АктуальныеПриборыУчета(ПараметрыОтбораПрибораУчета, НаборПриборов)

	РезультатЗапроса	= бестРаботаСприборамиУчетаСервер.ДействующиеПриборыУчетаПоОбъектуРасчетаСПоказаниями(КонецДня(ПараметрыОтбораПрибораУчета.Период), ПараметрыОтбораПрибораУчета.Организация, ПараметрыОтбораПрибораУчета.Район, ПараметрыОтбораПрибораУчета.ОбъектРасчета); 
	
	//РезультатЗапроса = энргРаботаСПоказаниямиПриборовУчетаСервер.РезультатЗапросаАктуальныхПриборовМКДИхПоказаний(
	//	КонецДня(ПараметрыОтбораПрибораУчета.Период),
	//	ПараметрыОтбораПрибораУчета);
		
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ТекПриборУчета 	= Неопределено;
	ТекЗавНомер 	= Неопределено;
	Выборка  		= РезультатЗапроса.Выбрать(); 	
	
	СтрокаПрибора = "";
	ШаблонПоказаний = "%1:%2";	
	
	Пока Выборка.Следующий() цикл		
		
		Если НЕ ТекПриборУчета = Выборка.ПриборУчета Тогда
			
			Если НЕ ТекПриборУчета = Неопределено Тогда
				СтрокаПрибораИтог = СокрЛП(ТекЗавНомер) + " (" + СокрЛП(СтрокаПрибора) + ")" ; 				
				НаборПриборов.Добавить(СокрЛП(ТекЗавНомер), СтрокаПрибораИтог);
			КонецЕсли;
			
			СтрокаПрибора = "";
					
		КонецЕсли;	
		
		СтрокаПрибора 	= СтрокаПрибора + " " + СтрШаблон(ШаблонПоказаний, Выборка.ТарифнаяЗона, Формат(Выборка.Показание, "ЧГ=0"));
		ТекПриборУчета 	= Выборка.ПриборУчета;
		ТекЗавНомер 	= Выборка.ЗаводскойНомерПриборУчета;
		
	КонецЦикла;
	
	Если НЕ ТекПриборУчета = Неопределено Тогда
		СтрокаПрибораИтог = СокрЛП(ТекЗавНомер) + " (" + СокрЛП(СтрокаПрибора) + ")" ; 				
		НаборПриборов.Добавить(СокрЛП(ТекЗавНомер), СтрокаПрибораИтог);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НовыеПараметрыОтбораПрибораУчета()
	
	Результат = Новый Структура;
	Результат.Вставить("НомерПрибораУчетаСтало"		, "");
	Результат.Вставить("Район"						, ПредопределенноеЗначение("Справочник.энргЗоныОтвественности.ПустаяСсылка"));
	Результат.Вставить("ОбъектРасчета"				, ПредопределенноеЗначение("Справочник.бестОбъектыРасчета.ПустаяСсылка")); 
	Результат.Вставить("Договор"					, ПредопределенноеЗначение("Справочник.энргДоговорыКонтрагентов.ПустаяСсылка"));
	Результат.Вставить("Организация"				, ПредопределенноеЗначение("Справочник.Организации.ПустаяСсылка"));

	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьТаблицуПоказанийИзФайла()
	
	ЗагруженныеПоказанияИзФайла.Очистить();
	Для Каждого ЗагруженныйПУ Из Объект.ТочкиУчета Цикл 
		Если ЗагруженныйПУ.СостояниеИсправления = 1 Тогда
			Продолжить;
		КонецЕсли;
				
		СтрокаПоказанияИзФайла = ЗагруженныеПоказанияИзФайла.Добавить();
		СтрокаПоказанияИзФайла.IDСтроки = ЗагруженныйПУ.IDСтроки; 
		
		СтрокаБылаИсправлена = Объект.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона.НайтиСтроки(Новый Структура("IDСтроки", ЗагруженныйПУ.IDСтроки));
		СтрокаСразуЗагружена = Объект.ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ЗагруженныйПУ.IDСтроки)); 
		Если СтрокаБылаИсправлена.Количество() > 0 Тогда
			СтрокаПоказанияИзФайла.ТарифнаяЗона = СтрокаБылаИсправлена[0].ТарифнаяЗона;
			СтрокаПоказанияИзФайла.ТекущиеПоказания = СтрокаБылаИсправлена[0].ТекущиеПоказания;
		ИначеЕсли СтрокаСразуЗагружена.Количество() > 0 Тогда
			СтрокаПоказанияИзФайла.ТарифнаяЗона = СтрокаСразуЗагружена[0].ТарифнаяЗона;
			СтрокаПоказанияИзФайла.ТекущиеПоказания = СтрокаСразуЗагружена[0].ТекущиеПоказания;
		КонецЕсли;
	КонецЦикла;   

КонецПроцедуры 

#КонецОбласти

#Область ОбновлениеДанныхПередИсправлением

&НаКлиенте
Процедура ОбновитьДанныеПрибораУчета(ТекДанные)
		
	ИдентификаторСтроки = ТекДанные.IDСтроки;
	
	ПараметрыОтбораПрибораУчета = НовыеПараметрыОтбораПрибораУчета();
	ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало 	= ТекДанные.НомерПрибораУчетаСтало;
	ПараметрыОтбораПрибораУчета.Район 					= энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекДанные.Договор, "Район");
	ПараметрыОтбораПрибораУчета.ОбъектРасчета 			= ТекДанные.ОбъектРасчета;
	ПараметрыОтбораПрибораУчета.Договор		 			= ТекДанные.Договор;
	ПараметрыОтбораПрибораУчета.Организация 			= Объект.Организация;
	
	мПриборыУчета = Новый Массив;	
	ЗаполнитьДанныеПриборовУчета(ИдентификаторСтроки, ПараметрыОтбораПрибораУчета, мПриборыУчета);
	
	//ДополнитьАктуальныеПриборыУчетаКВыбору(мПриборыУчета);
	//ТекДанные.НомерПрибораУчетаСтало = "";
	
	УстановитьОтборСтрокПоказаний();
	
КонецПроцедуры 

&НаСервере
Процедура ЗаполнитьДанныеПриборовУчета(ИдентификаторСтроки, ПараметрыОтбораПрибораУчета, мПриборыУчета)
	
	ОчиститьТЧ(ИдентификаторСтроки);	
	Если НЕ ЗначениеЗаполнено(ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало) Тогда
		Возврат;
	КонецЕсли;  	
	
	ТаблицаТочек 		= Объект.ТочкиУчета;
	ТаблицаШкалы 		= Объект.ШкалыПриборовУчета;
	ТаблицаПоказания 	= Объект.ПоказанияПриборовУчета;		
	
	Результат	= бестРаботаСприборамиУчетаСервер.ДействующиеПриборыУчетаПоОбъектуРасчета(КонецДня(Объект.Дата), ПараметрыОтбораПрибораУчета.Организация, ПараметрыОтбораПрибораУчета.Район, ПараметрыОтбораПрибораУчета.ОбъектРасчета); 
		
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;	
	
	ПоказанияИзФайла	= Объект.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона.НайтиСтроки(Новый Структура("IDСтроки", ИдентификаторСтроки));
	ПриборУчетаИзФайла	= Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания.НайтиСтроки(Новый Структура("IDСтроки", ИдентификаторСтроки));
	
	ПриборУчетаБыло	= ПриборУчетаИзФайла[0].НомерПрибораУчетаБыло;
	ПриборУчетаСтало = ПриборУчетаИзФайла[0].НомерПрибораУчетаСтало;
	ДатаПоказаний = ПриборУчетаИзФайла[0].ДатаПоказаний; 
	НомерПоказаний = ПриборУчетаИзФайла[0].НомерПоказаний;
	
	Выборка  		= Результат.выбрать();  
	ТекТочкаУчета 								= Неопределено;
	ТекПрибор 									= Неопределено;
	ТекШкала 									= Неопределено;
	IDСтрокиТочки 								= Неопределено;
	IDСтрокиШкалы 								= Неопределено;
	Пока Выборка.следующий() цикл 
		Если мПриборыУчета.Найти(Выборка.ЗаводскойНомерПриборУчета) = Неопределено Тогда
			// Заполняем приборами для отображения выбора из списка пользователю
			мПриборыУчета.Добавить(Выборка.ЗаводскойНомерПриборУчета);
		КонецЕсли;
		
		Если НЕ ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало = Выборка.ЗаводскойНомерПриборУчета Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Или Не ТекПрибор = Выборка.ПриборУчета Тогда
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= ТаблицаТочек.Добавить();
			IDСтрокиТочки 						= ИдентификаторСтроки;
			ЗаполнитьЗначенияСвойств(СтрокаТочкиУчета, Выборка);
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.ДатаПоказаний      = ДатаПоказаний;
			СтрокаТочкиУчета.Договор			= ПараметрыОтбораПрибораУчета.Договор; 
			СтрокаТочкиУчета.СостояниеИсправления = 1;
			СтрокаТочкиУчета.ПриборУчетаИзФайла = ПриборУчетаБыло; 
			СтрокаТочкиУчета.НомерПоказаний = НомерПоказаний;
		КонецЕсли;
		
		Если НоваяТочка ИЛИ НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= ТаблицаШкалы.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
		КонецЕсли;

		СтрокаПоказаний 						= ТаблицаПоказания.Добавить();
		СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		СтрокаПоказаний.IDСтрокиТочкиУчета		= IDСтрокиТочки;
		СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона; 
		Для Каждого ТекСтрокаПоказанийФайла из ПоказанияИзФайла Цикл 
			Если СтрокаПоказаний.ТарифнаяЗона = ТекСтрокаПоказанийФайла.ТарифнаяЗона Тогда
				СтрокаПоказаний.ТекущиеПоказания = ТекСтрокаПоказанийФайла.ТекущиеПоказания;
				Прервать;
			КонецЕсли;			
		КонецЦикла;
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
		ТекШкала 								= Выборка.Шкала;
	КонецЦикла;

	бестРаботаСПоказаниямиПриборовУчетаНПСервер.ОбновитьТЧПоказанияПрибораУчета(Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета, ДатаПоказаний, Объект.Организация,ПараметрыОтбораПрибораУчета.Район,Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаДанныхИзВнешнихИсточников

&НаКлиенте
Процедура ЗаполнитьПоказанияПослеВопросаОчистки(Результат, ДопПараметры) Экспорт
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьТЧ();
	ЗагрузитьПоказания();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоказанияПослеВопроса(Результат, ДопПараметры) Экспорт
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Записать();    
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьПоказания()
	
	ЭтотОбъект.Модифицированность = Истина;
	АдресВХ = УпаковатьВоВременноеХранилище(объект.ФайлДляЧтения);
	ОбработатьФайлНаСервере(АдресВХ);
	Записать();
	УстановитьЗначениеСвойстваСкрытьСтроку();
	
	ОбновитьНадписьВыполненияДлительныхОперацийКлиент();
	ОткрытьФормуЗапускаСозданияДокументовВФоне();
	
КонецПроцедуры

&НаКлиенте
Функция УпаковатьВоВременноеХранилище(ФайлДляЧтения)
	Файл 	= Новый ДвоичныеДанные(ФайлДляЧтения);
	Адрес 	= ПоместитьВоВременноеХранилище(Файл, ЭтаФорма.УникальныйИдентификатор);
	
	Возврат Адрес;
КонецФункции 

&НаСервере
Процедура ОбработатьФайлНаСервере(АдресВХ)
	ОбработкаЗагрузки 	= ПолучитьОбработкуЗагрузки();
	ОбработкаЗагрузки.ЗагрузитьПоказания(Объект, АдресВХ);
КонецПроцедуры 

#КонецОбласти

#Область ИсправлениеДанныхЗагруженныхИзВнешнихИсточников

&НаКлиенте
Процедура ИсправитьДанные(Команда)
	Ошибки = ПроверитьВозможностьЗагрузки(Истина);
	Если НЕ ПустаяСтрока(Ошибки) Тогда 
		НовоеОписаниеОповощение = Новый ОписаниеОповещения("ИсправитьДанныеПослеВопроса", ЭтотОбъект);
		ПоказатьВопрос(НовоеОписаниеОповощение,Ошибки,РежимДиалогаВопрос.ДаНет,,,,);
		Возврат;
	КонецЕсли;
	
	ИсправитьДанныеНаСервере();
	ЭтотОбъект.Модифицированность = Истина;
	Записать();
КонецПроцедуры 

&НаКлиенте
Процедура ИсправитьДанныеПослеВопроса(Результат, ДопПараметры) Экспорт
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ИсправитьДанныеНаСервере();
	Записать();    
КонецПроцедуры

&НаСервере   
Процедура ИсправитьДанныеНаСервере()
	
	МассивID = Новый Массив;
	Для Каждого СтрокаПрибора Из Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания Цикл 
		
		Если Не СтрокаПрибора.Исправлен Тогда 
			Продолжить;
		КонецЕсли;	
		
		МассивID.Добавить(СтрокаПрибора.IDСтроки);
	КонецЦикла;
	
	Успешно 			= Ложь;
	РезультатЗапроса 	= ТаблицаДанныхКПереносу(МассивID);
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ОбработкаЗагрузки = ПолучитьОбработкуЗагрузки();
	ОбработкаЗагрузки.ОбработатьИсправленныеДанные(Объект, РезультатЗапроса, Успешно, ДополнительныеПараметры);
	
	Если ДополнительныеПараметры.Свойство("МассивID") Тогда 
		УстановитьПризнакИсправленияСтрок(ДополнительныеПараметры.МассивID);
		Возврат;
	КонецЕсли;
		
	Если НЕ Успешно Тогда 
		Возврат;
	КонецЕсли;
	
	УстановитьПризнакИсправленияСтрок(МассивID); 
		
КонецПроцедуры

&НаСервере
Процедура УстановитьПризнакИсправленияСтрок(МассивID)
	
	Для Каждого СтрокаИдентификатор Из МассивID Цикл
		
		СвязаныеСтроки = Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания.НайтиСтроки(Новый Структура("IDСтроки", СтрокаИдентификатор)); 
		Для Каждого СтрокаОшибочныхДанных Из СвязаныеСтроки Цикл	
			Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания.Удалить(СтрокаОшибочныхДанных); 
		КонецЦикла;
		
		ПоказанияИзФайла = Объект.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона.НайтиСтроки(Новый Структура("IDСтроки", СтрокаИдентификатор));
		
		СвязаныеСтрокиТУ = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("IDСтроки", СтрокаИдентификатор)); 			
		Для Каждого СтрокаТУ Из СвязаныеСтрокиТУ Цикл
			СтрокаТУ.СостояниеИсправления = 0;
			
			СтрокиПоказанияИзФайла = ЗагруженныеПоказанияИзФайла.НайтиСтроки(Новый Структура("IDСтроки, ТарифнаяЗона", СтрокаТУ.IDСтроки, ПоказанияИзФайла[0].ТарифнаяЗона));  
			Если СтрокиПоказанияИзФайла.Количество() > 0 Тогда
				СтрокиПоказанияИзФайла[0].ТекущиеПоказания = ПоказанияИзФайла[0].ТекущиеПоказания;
			Иначе
				ЗагруженноеПоказание = ЗагруженныеПоказанияИзФайла.Добавить();
				ЗагруженноеПоказание.ТарифнаяЗона = ПоказанияИзФайла[0].ТарифнаяЗона;
				ЗагруженноеПоказание.ТекущиеПоказания = ПоказанияИзФайла[0].ТекущиеПоказания;
				ЗагруженноеПоказание.IDСтроки = СтрокаИдентификатор;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла; 
	
КонецПроцедуры

&НаСервере
Функция ТаблицаДанныхКПереносу(МассивID)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.IDСтроки КАК IDСтроки,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.ОбъектРасчета КАК ОбъектРасчета,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.Договор КАК Договор,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.Услуга КАК Услуга,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.ДатаПоказаний КАК ДатаПоказаний
	|ПОМЕСТИТЬ ТаблицаТочкиУчета
	|ИЗ
	|	&ТаблицаТочкиУчета КАК энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета
	|ГДЕ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.IDСтроки В(&МассивID)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.IDСтроки КАК IDСтроки,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.IDСтрокиТочкиУчета КАК IDСтрокиТочкиУчета,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.ВидДифференцированности КАК ВидДифференцированности,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.Шкала КАК Шкала
	|ПОМЕСТИТЬ ТаблицаШкалыПриборовУчета
	|ИЗ
	|	&ТаблицаШкалыПриборовУчета КАК энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета
	|ГДЕ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.IDСтрокиТочкиУчета В(&МассивID)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.IDСтроки КАК IDСтроки,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.IDСтрокиТочкиУчета КАК IDСтрокиТочкиУчета,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.ТекущиеПоказания КАК ТекущиеПоказания,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.ПредыдущиеПоказания КАК ПредыдущиеПоказания
	|ПОМЕСТИТЬ ТаблицаПоказанияПриборовУчета
	|ИЗ
	|	&ТаблицаПоказанияПриборовУчета КАК энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета
	|ГДЕ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.IDСтрокиТочкиУчета В(&МассивID)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	ТаблицаТочкиУчета.IDСтроки КАК IDСтроки,
	|	ТаблицаТочкиУчета.ОбъектРасчета КАК ОбъектРасчета,
	|	ТаблицаТочкиУчета.Договор КАК Договор,
	|	ТаблицаТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	ТаблицаТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	ТаблицаТочкиУчета.Услуга КАК Услуга,
	|	ТаблицаШкалыПриборовУчета.ВидДифференцированности КАК ВидДифференцированности,
	|	ТаблицаШкалыПриборовУчета.Шкала КАК Шкала,
	|	ТаблицаПоказанияПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТаблицаПоказанияПриборовУчета.ТекущиеПоказания КАК ТекущиеПоказанияФайла,
	|	ТаблицаПоказанияПриборовУчета.ПредыдущиеПоказания КАК ПредыдущиеПоказания,
	|	энргДоговорыКонтрагентов.Район КАК Район,
	|	ТаблицаТочкиУчета.ДатаПоказаний КАК ДатаПоказаний
	|ИЗ
	|	ТаблицаТочкиУчета КАК ТаблицаТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаШкалыПриборовУчета КАК ТаблицаШкалыПриборовУчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПоказанияПриборовУчета КАК ТаблицаПоказанияПриборовУчета
	|			ПО ТаблицаШкалыПриборовУчета.IDСтроки = ТаблицаПоказанияПриборовУчета.IDСтроки
	|		ПО ТаблицаТочкиУчета.IDСтроки = ТаблицаШкалыПриборовУчета.IDСтрокиТочкиУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|		ПО ТаблицаТочкиУчета.Договор = энргДоговорыКонтрагентов.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Договор,
	|	ОбъектРасчета,
	|	ТочкаУчета,
	|	ПриборУчета,
	|	Шкала";
	
	Запрос.УстановитьПараметр("ТаблицаТочкиУчета"				, Объект.ТочкиУчета.Выгрузить());
	Запрос.УстановитьПараметр("ТаблицаШкалыПриборовУчета"		, Объект.ШкалыПриборовУчета.Выгрузить());
	Запрос.УстановитьПараметр("ТаблицаПоказанияПриборовУчета"	, Объект.ПоказанияПриборовУчета.Выгрузить());
	Запрос.УстановитьПараметр("МассивID"						, МассивID);
	Запрос.УстановитьПараметр("Организация"						, Объект.Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса;
КонецФункции

