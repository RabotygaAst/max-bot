Процедура ЗаполнитьТЧ(ЭтотОбъект,ДанныеЗаполнения,мТЧ)
	Для каждого ТЧ из мТЧ Цикл
		Для каждого стр из ДанныеЗаполнения[ТЧ] Цикл
			НовСтр = ЭтотОбъект[ТЧ].Добавить();
			ЗаполнитьЗначенияСвойств(НовСтр, стр); 
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область Расторжение_Договора

Процедура РасторжениеПерезаключениеДоговора(ЭтоПерезаключение) 
	ДанныеШапки 					= ДанныеШапки();
	
	Пакет = ПолучитьДанныеТЧДляЗакрытияПерезаключения();
	ДанныеПоказанийПриборовУчета 	= Пакет[0];
	ДанныеДоговорыТУ			 	= Пакет[1];
	
	УстановитьСостояниеДоговоров(ДанныеШапки,Движения,Ложь);//отключаем договор

	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПоказанийПриборовУчета,	Движения.бестПоказанияПриборовУчетаНП);
	
	Если ЭтоПерезаключение Тогда 
		бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеДоговорыТУ,	Движения.бестДоговорыТочекУчета);
	КонецЕсли;

КонецПроцедуры
	
Функция ПолучитьДанныеТЧДляЗакрытияПерезаключения()
	ПериодДо = Новый Граница(МоментВремени(),ВидГраницы.Исключая);
	МВТ = Новый МенеджерВременныхТаблиц;
	
	Запрос  	= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка",				Ссылка);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("Договор",			Договор);
	Запрос.УстановитьПараметр("НовыйДоговор",		НовыйДоговор);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Период",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия),КонецДня(ДатаФактическогоСобытия),Дата));
	Запрос.УстановитьПараметр("ПериодДо",			ПериодДо);
	Запрос.УстановитьПараметр("ПериодРегистрации",	Дата);  	
	Текст 		= 
		"ВЫБРАТЬ
		|	&Период КАК Период,
		|	&Организация КАК Организация,
		|	&Район КАК Район,
		|	&Договор КАК Договор,
		|	&ПериодРегистрации КАК ПериодРегистрации,
		|	&ПериодНачисления КАК ПериодНачисления,
		|	ТаблицаПриборовУчета.ТочкаУчета КАК ТочкаУчета,
		|	ТаблицаПриборовУчета.ПриборУчета КАК ПриборУчета,
		|	ТаблицаПоказанийПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ТаблицаПоказанийПриборовУчета.ТекущиеПоказания КАК Показание,
		|	ТаблицаПоказанийПриборовУчета.СостояниеПоказаний КАК СостояниеПоказаний,
		|	ТаблицаПоказанийПриборовУчета.ПричинаОтклонения КАК ПричинаОтклонения,
		|	ЛОЖЬ КАК КС,
		|	ТаблицаПоказанийПриборовУчета.Переворот КАК Переворот,
		|	ТаблицаПоказанийПриборовУчета.НомерСтроки КАК НомерСтрокиТЧ,
		|	ТаблицаПриборовУчета.ОбъектРасчета КАК ОбъектРасчета,
		|	ШкалыПриборовУчета.Шкала КАК Шкала,
		|	ТаблицаПриборовУчета.УзелУчета КАК УзелУчета,
		|	ТаблицаПриборовУчета.ПриборУчета.ТипПрибораУчета КАК ТипПрибораУчета
		|ПОМЕСТИТЬ ВТ_Показания
		|ИЗ
		|	Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ТочкиУчетаЗакрытие КАК ТаблицаПриборовУчета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ПоказанияПриборовУчета КАК ТаблицаПоказанийПриборовУчета
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ШкалыПриборовУчета КАК ШкалыПриборовУчета
		|			ПО (ШкалыПриборовУчета.IDСтроки = ТаблицаПоказанийПриборовУчета.IDСтроки)
		|				И (ТаблицаПоказанийПриборовУчета.Ссылка = &ссылка)
		|		ПО (ТаблицаПриборовУчета.Ссылка = ШкалыПриборовУчета.Ссылка)
		|			И (ТаблицаПриборовУчета.IDСтроки = ШкалыПриборовУчета.IDСтрокиТочкиУчета)
		|			И (ТаблицаПриборовУчета.Ссылка = &ссылка)
		|			И (ШкалыПриборовУчета.Ссылка = &Ссылка)
		|			И (НЕ ТаблицаПриборовУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|			И (ШкалыПриборовУчета.Ссылка = ТаблицаПоказанийПриборовУчета.Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	&Период КАК Период,
		|	&Организация КАК Организация,
		|	&Район КАК Район,
		|	&НовыйДоговор КАК Договор,
		|	&ПериодРегистрации КАК ПериодРегистрации,
		|	&ПериодНачисления КАК ПериодНачисления,
		|	ТаблицаПриборовУчета.ТочкаУчета КАК ТочкаУчета,
		|	ТаблицаПриборовУчета.ОбъектРасчета КАК ОбъектРасчета,
		|	ВЫБОР
		|		КОГДА энргВидыУслугСоставляющиеУслуг.Услуга ЕСТЬ NULL
		|			ТОГДА ТаблицаПриборовУчета.Услуга
		|		ИНАЧЕ энргВидыУслугСоставляющиеУслуг.Услуга
		|	КОНЕЦ КАК Услуга
		|ПОМЕСТИТЬ ДоговорыТУ
		|ИЗ
		|	Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ТочкиУчетаЗакрытие КАК ТаблицаПриборовУчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
		|		ПО ТаблицаПриборовУчета.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка";
		
	Запрос.Текст = Текст;
	
	Возврат Запрос.ВыполнитьПакетСПромежуточнымиДанными(); 
КонецФункции

#КонецОбласти 

Функция ДанныеШапки()
	ДанныеШапки = Новый Структура;
	ДанныеШапки.Вставить("Период",						?(ЗначениеЗаполнено(ДатаФактическогоСобытия),КонецДня(ДатаФактическогоСобытия),Дата));
	ДанныеШапки.Вставить("Организация",					Организация);
	ДанныеШапки.Вставить("Район",						Район);
	ДанныеШапки.Вставить("Договор",						Договор);
	ДанныеШапки.Вставить("ОбъектыРасчета",				ОбъектыРасчета);
	ДанныеШапки.Вставить("ОбъектыРасчетаНеОбъектУК",	ОбъектыРасчета.Выгрузить(Новый Структура("ОбъектУК", Ложь)));
	ДанныеШапки.Вставить("ТочкиУчетаЗакрытие",			ТочкиУчетаЗакрытие);
	ДанныеШапки.Вставить("Состояние",					Перечисления.энргСостояниеТочекУчета.Включена);
	ДанныеШапки.Вставить("ПериодРегистрации",			Дата);
	ДанныеШапки.Вставить("Дата",						Дата);
	ДанныеШапки.Вставить("ПериодНачисления",			ПериодНачисления); 	
	ДанныеШапки.Вставить("ВидПлощади",					Перечисления.энргВидыПлощадей.ОбщаяПлощадьНП);
	ДанныеШапки.Вставить("Документ",					Ссылка);
	ДанныеШапки.Вставить("УчитыватьПереплату",			УчитыватьПереплату);
	ДанныеШапки.Вставить("ИмяДокумента",				"бестЗаключениеДоговоровСЮридическимиЛицами");
	ДанныеШапки.Вставить("РассчитыватьПени",			РассчитыватьПени); 	
	ДанныеШапки.Вставить("ГруппаПотребителей",			ГруппаПотребителей);
	ДанныеШапки.Вставить("ВариантРасчета",				ВариантРасчета);
	ДанныеШапки.Вставить("ПроцентПени",					ПроцентПени);
	
	Возврат ДанныеШапки;	
КонецФункции

Функция СоставУзлаКорректен()
	
	Данные = Новый Структура;
	Данные.Вставить("Период",					Новый Граница(МоментВремени(),ВидГраницы.Исключая));
	Данные.Вставить("Район",					Район);
	Данные.Вставить("Организация",			    Организация);		
	Данные.Вставить("Договор",					Договор); 
	Данные.Вставить("Ссылка",					Ссылка);
	
	Возврат энргРаботаСприборамиУчетаСервер.СоставУзлаКорректенНП(Данные);
	 	
КонецФункции

Процедура УстановитьСостояниеДоговоров(ДанныеШапки,Движения,Состояние) 
	Набор				= Движения.бестСостояниеДоговоров;
	Запись				= Набор.добавить(); 
	ЗаполнитьЗначенияСвойств(Запись, ДанныеШапки);
	Запись.Состояние	= Состояние;
КонецПроцедуры

#КонецОбласти

