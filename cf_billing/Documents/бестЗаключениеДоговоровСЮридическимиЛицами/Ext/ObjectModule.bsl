#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Вставляет в дополнительные свойсва массив приборов.
//
Процедура МассивПриборов() Экспорт 
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ссылка",				Ссылка);
	Запрос.УстановитьПараметр("ВыводПрибораУчета",	?(ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗакрытиеДоговора,Истина,ложь));
	
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗакрытиеДоговора Тогда 
		Запрос.Текст  	= 
		"ВЫБРАТЬ
		|	ТаблицаТочкиУчета.ПриборУчета КАК ПриборУчета,
		|	&ВыводПрибораУчета КАК ВыводПрибораУчета,
		|	""ПоказанияПриборовУчета"" КАК ИмяТабЧасти,
		|	0 КАК Разделитель,
		|	ТаблицаОбъектыРасчета.ОбъектРасчета КАК ОбъектРасчета,
		|	ТаблицаОбъектыРасчета.МКД КАК МКД
		|ИЗ
		|	Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ТочкиУчета КАК ТаблицаТочкиУчета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ОбъектыРасчета КАК ТаблицаОбъектыРасчета
		|		ПО ТаблицаТочкиУчета.IDСтрокиВладельца = ТаблицаОбъектыРасчета.IDСтроки
		|			И (НЕ ТаблицаОбъектыРасчета.ОбъектРасчета = ЗНАЧЕНИЕ(Справочник.бестОбъектыРасчета.ПустаяСсылка))
		|			И (НЕ ТаблицаТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|			И (ТаблицаОбъектыРасчета.Ссылка = &Ссылка)
		|			И (ТаблицаТочкиУчета.Ссылка = &Ссылка)" ;
		
	иначе
		Запрос.Текст  	=
		"ВЫБРАТЬ
		|	&ВыводПрибораУчета КАК ВыводПрибораУчета,
		|	ТаблицаОбъектыРасчета.ОбъектРасчета КАК ОбъектРасчета,
		|	""ПоказанияПриборовУчета"" КАК ИмяТабЧасти,
		|	0 КАК Разделитель,
		|	ТаблицаТочкиУчета.ПриборУчета КАК ПриборУчета,
		|	ТаблицаОбъектыРасчета.МКД КАК МКД
		|ИЗ
		|	Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ОбъектыРасчета КАК ТаблицаОбъектыРасчета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ТочкиУчета КАК ТаблицаТочкиУчета
		|		ПО ТаблицаОбъектыРасчета.Ссылка = ТаблицаТочкиУчета.Ссылка
		|			И ТаблицаОбъектыРасчета.IDСтроки = ТаблицаТочкиУчета.IDСтрокиВладельца
		|			И (ТаблицаОбъектыРасчета.Ссылка = &ссылка)
		|			И (ТаблицаТочкиУчета.Ссылка = &Ссылка)
		|			И (НЕ ТаблицаОбъектыРасчета.ОбъектРасчета = ЗНАЧЕНИЕ(Справочник.бестОбъектыРасчета.ПустаяСсылка)
		|				И НЕ ТаблицаТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))";
		
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("МассивПриборов",Запрос.Выполнить());

КонецПроцедуры

// Вставляет в дополнительные свойсва массив объектов расчета.
//
Функция МассивОбъектовРасчета() Экспорт 
		
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ссылка",Ссылка);
	Запрос.Текст  	= 
	"ВЫБРАТЬ
	|	бестЗаключениеДоговоровСЮридическимиЛицамиОбъектыРасчета.ОбъектРасчета КАК ОбъектРасчета,
	|	бестЗаключениеДоговоровСЮридическимиЛицами.Дата КАК Период,
	|	бестЗаключениеДоговоровСЮридическимиЛицами.Организация КАК Организация,
	|	бестЗаключениеДоговоровСЮридическимиЛицами.Район КАК Район,
	|	бестЗаключениеДоговоровСЮридическимиЛицами.ПериодНачисления КАК ПериодНачисления,
	|	бестЗаключениеДоговоровСЮридическимиЛицами.Дата КАК ПериодРегистрации,
	|	бестЗаключениеДоговоровСЮридическимиЛицамиОбъектыРасчета.МКД КАК МКД
	|ИЗ
	|	Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ОбъектыРасчета КАК бестЗаключениеДоговоровСЮридическимиЛицамиОбъектыРасчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестЗаключениеДоговоровСЮридическимиЛицами КАК бестЗаключениеДоговоровСЮридическимиЛицами
	|		ПО бестЗаключениеДоговоровСЮридическимиЛицамиОбъектыРасчета.Ссылка = бестЗаключениеДоговоровСЮридическимиЛицами.Ссылка
	|ГДЕ
	|	бестЗаключениеДоговоровСЮридическимиЛицами.Ссылка = &Ссылка";
	
	ДополнительныеСвойства.Вставить("МассивОбъектов",Запрос.Выполнить());
	
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли; 	
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	ДополнительныеСвойства.Вставить("МассивОбъектовРасчета",Истина);
	
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение Тогда
		ДополнительныеСвойства.Вставить("РегистрироватьСтабильныеПериоды",Ложь);
	КонецЕсли;
	
	Ответственный = Пользователи.ТекущийПользователь();
		
	бестПроведениеСерверНП.ПередЗаписьюОбъекта(ЭтотОбъект);	

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	
	бестПроведениеСерверНП.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	Если ЗначениеЗаполнено(ДатаФактическогоСобытия) тогда
		Момент 			= Новый Граница(Новый МоментВремени(КонецДня(ДатаФактическогоСобытия),Ссылка), ВидГраницы.Исключая) ;
		СтрокаОтказа 	= "На дату фактического события";
	иначе
		Момент 			= Новый Граница(МоментВремени(), ВидГраницы.Исключая);
		СтрокаОтказа 	= "На дату операции";
	КонецЕсли;
	
	Если ВидОперации <> Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение Тогда
		ДоговорЗаключен		= РегистрыСведений.бестСостояниеДоговоров.ДоговорЗаключен(Момент, Организация, Район, Договор); 
	КонецЕсли;
	
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ОткрытиеДоговора
		ИЛИ ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_РегистрацияОбъекта Тогда
		
		Если ДоговорЗаключен Тогда
			Отказ			= истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + СтрокаОтказа + " договор уже заключен!");
		КонецЕсли;
		
		Если не СоставУзлаКорректен() тогда
			Отказ = Истина;
		КонецЕсли;
		
		Если Отказ тогда
			Возврат;
		КонецЕсли;
		
		ЗаключениеДоговора();
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗакрытиеДоговора 
		ИЛИ ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ПерезаключениеДоговора Тогда
		Если Не ДоговорЗаключен Тогда
			Отказ			= истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + СтрокаОтказа + " договор не заключен!");
		КонецЕсли;
		
		Для Каждого СтрокаТЧ из ПоказанияПриборовУчета цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ТекущиеПоказания) Тогда
				Отказ 		= истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнены текущие показания",ЭтотОбъект,"ПоказанияПриборовУчета["+(СтрокаТЧ.НомерСтроки-1)+"].ТекущиеПоказания");				
			КонецЕсли;	
		КонецЦикла;

		
		Если Отказ тогда
			Возврат;
		КонецЕсли;
		
		РасторжениеПерезаключениеДоговора(ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ПерезаключениеДоговора);			
		
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение или ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_АктБездоговорногоПотребления Тогда
		
		Если Не ЗначениеЗаполнено(Ссылка) Тогда
			УстановитьСсылкуНового(Документы.бестЗаключениеДоговоровСЮридическимиЛицами.ПолучитьСсылку(Новый УникальныйИдентификатор));
			ТекущаяСсылка	= ПолучитьСсылкуНового();
		Иначе
			ТекущаяСсылка	= Ссылка;
		КонецЕсли;
	
		БизнесПроцессы.бестЗаключениеДоговора.ИнициализироватьБППоДоговору(Организация, Район, Договор, ТекущаяСсылка);
		
	КонецЕсли;
	
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	Договор		= Справочники.энргДоговорыКонтрагентов.ПустаяСсылка();
	Контрагент	= Справочники.энргКонтрагенты.ПустаяСсылка();
	
	ГарантированныеОбъемы.Очистить();
	ТемпературныеГрафикиОбъектов.Очистить();
	МаксимальныеНагрузки.Очистить();
	НастройкиОплаты.Очистить();
	РаспределениеПоступившейОплаты.Очистить();
	НастройкиФормированияАвансовыхСФПоУслугамДоговоровКонтрагентов.Очистить();
	ЭтапыПИД.Очистить();
	УслугиРаспределенияПотерь.Очистить();
	ОбъемыРаспределенияПотерь.Очистить();
	
	Для Каждого стр из ОбъектыРасчета Цикл 
		стр.ОбъектРасчета = Справочники.бестОбъектыРасчета.ПустаяСсылка();
		стр.НаименованиеОбъектаРасчета = "";
		стр.Площадь		= 0;
		стр.МКД			= Справочники.энргСтроения.ПустаяСсылка();
		
	КонецЦикла;	
	Для Каждого стр из ТочкиУчета цикл
		стр.ТочкаУчета	 	= Справочники.энргТочкиУчета.ПустаяСсылка();
		стр.ПриборУчета 	= Справочники.энргПриборыУчетаАбонента.ПустаяСсылка();		
	КонецЦикла;
	Для Каждого стр из ПриборыУзловУчета цикл		
		стр.ПриборУчета 	= Справочники.энргПриборыУчетаАбонента.ПустаяСсылка();		
	КонецЦикла;
	Для Каждого стр из ПоказанияПриборовУчета цикл
		стр.ТекущиеПоказания= 0;	
	КонецЦикла;
	Для Каждого стр из УслугиОбъектов Цикл
		стр.Нагрузка = 0;	
	КонецЦикла;
	Для Каждого стр из ТарифныеКатегорииУслуги Цикл
		стр.ВидБлагоустройства = Справочники.энргВидыБлагоустройств.ПустаяСсылка();
		стр.ТарифнаяКатегория = Справочники.энргГруппыПотребителей.ПустаяСсылка();
		стр.РасчетПоФактическомуПотреблению = Ложь;
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	ПроверяемыеРеквизиты.добавить("Организация");
	ПроверяемыеРеквизиты.добавить("Контрагент");
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ПерезаключениеДоговора ИЛИ ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗаменаДоговораУОбъекта Тогда 
		ПроверяемыеРеквизиты.добавить("ТекущийДоговор");
		ПроверяемыеРеквизиты.добавить("Район");
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_РегистрацияОбъекта Тогда	
		Если РассчитыватьПени И ВариантРасчета = ПредопределенноеЗначение("Перечисление.бестВариантыРасчетаПени.ОтСтавкиРефинансирования") Тогда
			ПроверяемыеРеквизиты.добавить("ГруппаПотребителей");	
		КонецЕсли; 
		Если РассчитыватьПени Тогда 
			ПроверяемыеРеквизиты.добавить("ВариантРасчета");
        КонецЕсли;	
	ИначеЕсли ВидОперации <> Перечисления.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение Тогда
		ПроверяемыеРеквизиты.добавить("Договор");
	КонецЕсли;
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСДоговором_ОткрытиеДоговора Тогда 
		ПроверяемыеРеквизиты.добавить("Район");
		
		Если Не ЗначениеЗаполнено(ОбъектыРасчета) Тогда
			Отказ = Истина;
		    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не введено ни одной строки в список ""Объект расчета""", ЭтотОбъект, "ОбъектыРасчета");
		КонецЕсли;
		Для Каждого СтрокаТЧ из ОбъектыРасчета цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.НаименованиеОбъектаРасчета) и НЕ ЗначениеЗаполнено(СтрокаТЧ.ОбъектРасчета) Тогда
				Отказ 		= истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле ""Объект расчета""",ЭтотОбъект,"ОбъектыРасчета["+(СтрокаТЧ.НомерСтроки-1)+"].ОбъектРасчета");				
			КонецЕсли;			
		КонецЦикла;
		Если Не ЗначениеЗаполнено(ТочкиУчета) Тогда
			Отказ = Истина;
		    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не введено ни одной строки в список ""Услуги""", ЭтотОбъект, "ТочкиУчета");
		КонецЕсли;
		Для Каждого СтрокаТЧ из ТарифныеКатегорииУслуги цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ТарифнаяКатегория) Тогда
				Отказ 		= истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле ""Тарифная категория""",ЭтотОбъект,"ТарифныеКатегорииУслуги["+(СтрокаТЧ.НомерСтроки-1)+"].ТарифнаяКатегория");				
			КонецЕсли;			
		КонецЦикла;
		Для Каждого СтрокаТЧ из УслугиОбъектов цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Услуга) Тогда
				Отказ 		= истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле ""Услуга""",ЭтотОбъект,"УслугиОбъектов["+(СтрокаТЧ.НомерСтроки-1)+"].Услуга");				
			КонецЕсли;			
		КонецЦикла;
		
	КонецЕсли;

	Для Каждого СтрокаТЧ из ТочкиУчета цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Услуга) Тогда
			Отказ 		= истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле Услуга",ЭтотОбъект,"ТочкиУчета["+(СтрокаТЧ.НомерСтроки-1)+"].Услуга");				
		КонецЕсли;
		Если Константы.бестИспользоватьДанныеДляРасчетаТепловойЭнергииТеплоносителяИХВСЮЛ.Получить() Тогда
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.СтруктураСети) Тогда
				Отказ 		= истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле Структура Сети",ЭтотОбъект,"ТочкиУчета["+(СтрокаТЧ.НомерСтроки-1)+"].СтруктураСети");
			КонецЕсли;
		КонецЕсли;  
		Если энргОбщегоНазначения.ЗначениеКонстанты("бестНезависимыйСбыт") Тогда
			Если Не ЗначениеЗаполнено(СтрокаТЧ.ТипТарифа) Тогда
				Отказ 		= Истина;
