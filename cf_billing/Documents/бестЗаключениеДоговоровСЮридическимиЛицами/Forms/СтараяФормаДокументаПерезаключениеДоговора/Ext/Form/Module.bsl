&НаКлиенте
Процедура ПотребителиГВСПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекДанныеПотребители = Элементы.ПотребителиГВС.ТекущиеДанные;
	Если ТекДанныеПотребители = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекДанныеПотребители.IDСтроки = ТекДанные.IDСтроки;
	Если Не ЗначениеЗаполнено(ТекДанныеПотребители.ТипНормы) Тогда
		ТекДанныеПотребители.ТипНормы = ПредопределенноеЗначение("Перечисление.бестВидыПериодов.Сутки");	
	КонецЕсли;
	Если ТекДанныеПотребители.КоличествоРабочихЧасовВДень = 0 Тогда
		ТекДанныеПотребители.КоличествоРабочихЧасовВДень = 24;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаФормулыРасчетаЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт 
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТипЗнч(РезультатЗакрытия) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не РезультатЗакрытия.Свойство("ПредставлениеФормулы") ИЛИ Не РезультатЗакрытия.Свойство("ФормулаРасчета") Тогда
		Возврат;
	КонецЕсли;
	
	КлючСтроки  								= ДополнительныеПараметры.КлючСтроки;
