&НаКлиенте
Процедура МаксимальныеНагрузкиНагрузкаПриИзменении(Элемент)
	ТекСтрока = Элементы.МаксимальныеНагрузки.ТекущиеДанные;
	Если Объект.УслугиОбъектов.Количество() > 0 Тогда
		ПроверкаЗначенияНагрузки("УслугиОбъектов", "Нагрузки",ТекСтрока.Услуга, ТекСтрока.Нагрузка, ТекСтрока.IDСтроки);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаЗначенияНагрузки(ИмяТЧ, ИмяТЧСиноним,ТекУслуга, ТекНагрузка, ТекIDСтроки)
	Отбор 		= Новый Структура("IDСтроки, Услуга", ТекIDСтроки, ТекУслуга);
	ИщемСтроку	= Объект[ИмяТЧ].НайтиСтроки(Отбор);
	Если ИщемСтроку.Количество() > 0 Тогда
		ТекСумма= ИщемСтроку[0].Нагрузка;
	КонецЕсли;
	Если ТекСумма > ТекНагрузка Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Максимальная нагрузка не может быть меньше нагрузки в ТЧ '" + ИмяТЧСиноним + "'! Необходимо скорректировать нагрузку!");
		ТекНагрузка	= ТекСумма; 
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаЗначенияОбычнойНагрузки(ИмяТЧ, ИмяТЧСиноним, ТекУслуга, ТекНагрузка, ТекIDСтроки, ТекНомерСтроки)
	Отбор 		 = Новый Структура("IDСтроки, Услуга", ТекIDСтроки, ТекУслуга);
	ИщемСтроку	 = Объект[ИмяТЧ].НайтиСтроки(Отбор);
	ТекСумма	 = Неопределено;
	Если ИщемСтроку.Количество() > 0 Тогда
		ТекСумма = ИщемСтроку[0].Нагрузка;
	КонецЕсли;
	Отбор.Вставить("ИмяТЧСиноним", ИмяТЧСиноним);
	Отбор.Вставить("ТекНагрузка", ТекНагрузка);
	Отбор.Вставить("ТекСумма", ТекСумма);
	Отбор.Вставить("ИщемСтроку", ИщемСтроку);
	Отбор.Вставить("ТекНомерСтроки", ТекНомерСтроки);
	ПроверкаИзмененияНагрузки(Отбор);
КонецПроцедуры


&НаКлиенте
Процедура ПроверкаИзмененияНагрузки(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросИзмененияНагрузки", ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Изменение нагрузки изменит значение Максимальной нагрузки по данной услуге у текущего объекта. Изменить нагрузку?", РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросИзмененияНагрузки(РезультатВопроса,ДополнительныеПараметры) Экспорт
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			ДополнительныеПараметры.Вставить("Изменяем", Истина);
			ИзменитьМаксимальнуюНагрузку(ДополнительныеПараметры);
		Иначе
			ДополнительныеПараметры.Вставить("Изменяем", Ложь);
			ИзменитьМаксимальнуюНагрузку(ДополнительныеПараметры);
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьМаксимальнуюНагрузку(ДополнительныеПараметры)
	Если ДополнительныеПараметры.Изменяем Тогда
		Если Не ДополнительныеПараметры.ТекСумма = Неопределено Тогда
			НоваяСТрока = ДополнительныеПараметры.ИщемСтроку[0];
		Иначе
			НоваяСтрока = Объект.МаксимальныеНагрузки.Добавить();
		КонецЕсли;
		
		НоваяСтрока.IDСтроки 	= ДополнительныеПараметры.IDСтроки;
		НоваяСтрока.Услуга 		= ДополнительныеПараметры.Услуга;
		НоваяСтрока.Нагрузка 	= ДополнительныеПараметры.ТекНагрузка;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Данная нагрузка добавлена в ТЧ '" + ДополнительныеПараметры.ИмяТЧСиноним + "'! Скорректируйте значение в ТЧ '" + ДополнительныеПараметры.ИмяТЧСиноним + "', если необходимо!");	
	Иначе
		Если ДополнительныеПараметры.ИщемСтроку <> Неопределено Тогда
			ИзменяемаяСтрока = Объект.УслугиОбъектов[ДополнительныеПараметры.ТекНомерСтроки - 1];
			ИзменяемаяСтрока.Нагрузка =  ДополнительныеПараметры.ИщемСтроку[0].Нагрузка;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ГарантированныеОбъемыУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;	
	
	ТекДанные = Элементы.ГарантированныеОбъемы.ТекущиеДанные;
	
	СписокУслуг = ПолучитьСписокУслугДляВыбора(ТекДанные.IDСтроки);
	ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", Новый Структура("СписокУслуг", СписокУслуг), Элемент);
КонецПроцедуры

&НаКлиенте
Процедура ДоговорКонтрагентаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	бестПользовательскийВводКлиент.НачалоВыбораДоговора(Элемент,Объект.Организация,Объект.Контрагент,СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ПереключениеИтоговДоговорныхИтогов(Команда)
	ИтогиПоДоговору = Не ИтогиПоДоговору;
	ОбновитьЗаголовокКнопкиПереключенияИтогов();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗаголовокКнопкиПереключенияИтогов()
	Если ИтогиПоДоговору Тогда
		Элементы.ПереключениеИтоговДоговорныхИтогов.Заголовок = "Показать итоги по объекту";
		Элементы.ИтогиДоговорныхОбъемовПоДоговору.Видимость = Истина;
		Элементы.ИтогиДоговорныхОбъемов.Видимость = ложь;
	Иначе	
		Элементы.ПереключениеИтоговДоговорныхИтогов.Заголовок = "Показать итоги по договору";
		Элементы.ИтогиДоговорныхОбъемовПоДоговору.Видимость = Ложь;
		Элементы.ИтогиДоговорныхОбъемов.Видимость = Истина;
	КонецЕсли;	              
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПриборыУчета(Команда)
	ТекущиеДанные = Элементы["ТочкиУчета"].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.ТипУзлаУчета) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить тип узла учета!");
		Возврат;		
	КонецЕсли;
	
	СтруктураОтвета = энргРаботаСПриборамиУчетаКлиент.ВернутьНачальныеПараметрыПередачиДляУзлов(ЭтаФорма, ТекущиеДанные, Объект);
	ПолучитьДанныеТабЧастей(СтруктураОтвета.ПараметрыПередачи,ТекущиеДанные.IDСтроки,ТекущиеДанные.ТипУзлаУчета,ТекущиеДанные.НачалоДействияКоммерскогоУчета,ТекущиеДанные.КонецДействияКоммерскогоУчета);
	энргРаботаСПриборамиУчетаКлиент.ДобавитьПриборыУчета(СтруктураОтвета);
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеТабЧастей(ПараметрыПередачи,IDСтроки,ТипУзлаУчета,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета) 	
	энргРаботаСприборамиУчетаСервер.ПолучитьДанныеТабЧастейУзла(ПараметрыПередачи, IDСтроки, Объект,ТипУзлаУчета,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета);
КонецПроцедуры

&НаКлиенте
Процедура ДоговорПриИзменении(Элемент)
	НастроитьВидимостьРеквизитовДоговора();
КонецПроцедуры

&НаКлиенте
Процедура НастроитьВидимостьРеквизитовДоговора()
	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		Элементы.Группа19.Видимость = Ложь;
	Иначе
		Элементы.Группа19.Видимость = Истина;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьСпособРасчетаНорматива(Услуга, Выборка)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСпособНачисленияНормативаНПСрезПоследних.СпособРасчетаНорматива КАК СпособРасчетаНорматива
		|ИЗ
		|	РегистрСведений.бестСпособНачисленияНормативаНП.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ТочкаУчета = &ТочкаУчета
		|				И Услуга = &Услуга
		|				И ОбъектРасчета = &ОбъектРасчета) КАК бестСпособНачисленияНормативаНПСрезПоследних";
	
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Запрос.УстановитьПараметр("Район", Объект.Район);
	Запрос.УстановитьПараметр("ТочкаУчета", Выборка.ТочкаУчета);
	Запрос.УстановитьПараметр("Услуга", Услуга);
	Запрос.УстановитьПараметр("ОбъектРасчета", Выборка.ОбъектРасчета);

	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.СпособРасчетаНорматива;
	КонецЦикла;

	Возврат Неопределено;
КонецФункции

&НаКлиенте
Процедура ГарантированныеОбъемыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока И Не Копирование Тогда
		Элемент.ТекущиеДанные.Год = Объект.Дата;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДоговорНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	бестПользовательскийВводКлиент.НачалоВыбораДоговора(Элемент,Объект.Организация,Объект.Контрагент,СтандартнаяОбработка);
КонецПроцедуры


#КонецОбласти

#Область НОВАЯ_РАБОТА_С_УЗЛАМИ

&НаСервере
Процедура ОбновитьДанныеПоУслугамСервер(ПераметрыОбновления) Экспорт 
	энргРаботаСТочкамиУчетаСервер.ЗаполнитьДанныеТаблицРезультатаСредствИзмерений(Объект, ПераметрыОбновления.IDСтроки, ПераметрыОбновления.Результат, ПераметрыОбновления.ДанныеПУ);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекстовыеПоля()	
	Для Каждого ТекСтрока ИЗ Объект.ТочкиУчета Цикл
		ДанныеИзмерителей = Новый Структура("Измерители", Объект.Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекСтрока.IDСтроки)));
		энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстСредствИзмерений(ТекСтрока, ДанныеИзмерителей);
		ТекСтрока.ТехническиеСвойстваТУ = энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстТехническихСвойств(ТекСтрока, Объект.Потери,"ЮЛ");
		энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстДанныеРасположения(ТекСтрока);
		ТекСтрока.ДанныеРасположения = Справочники.бестСтруктураСети.ПолучитьСхемуПрисоединения(ТекСтрока.СтруктураСети);
	КонецЦикла;	
	
	Для Каждого ТекСтрока ИЗ Объект.ОбъектыРасчета Цикл
		ТекСтрока.ДополнительнаяИнформация = бестРаботаСОбъектамиНПСервер.ЗаполнитьТекстИнформацииОбъекта(ТекСтрока);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваПриборовУчета(Знач ТекущийОбъект)
	
	Перем мПриборыУчета, ПолучаемыеСвойстваПриборовУчета, СвойстваПриборовУчета;
	       	
	ПолучаемыеСвойстваПриборовУчета = энргРаботаСприборамиУчетаСервер.ПолучаемыеСвойстваПриборовУчета();	
	мПриборыУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.ТочкиУчета.Выгрузить().ВыгрузитьКолонку("ПриборУчета"));
	СвойстваПриборовУчета 			= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектов(мПриборыУчета, ПолучаемыеСвойстваПриборовУчета);
	ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Объект.ТочкиУчета,СвойстваПриборовУчета);
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваИзмерителей(Знач ТекущийОбъект)
	
	Перем мПриборыУчета, ПолучаемыеСвойстваПриборовУчета, СвойстваПриборовУчета;
	       	
	ПолучаемыеСвойстваПриборовУчета = энргРаботаСприборамиУчетаСервер.ПолучаемыеСвойстваПриборовУчета();	
	мПриборыУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.Измерители.Выгрузить().ВыгрузитьКолонку("ПриборУчета"));
	СвойстваПриборовУчета 			= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектов(мПриборыУчета, ПолучаемыеСвойстваПриборовУчета);
	ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Объект.Измерители, СвойстваПриборовУчета);
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Коллекция,СвойстваПриборовУчета) 
	
	СоотвествиеРеквизитовСвойств 								= энргРаботаСприборамиУчетаСервер.СоотвествиеРеквизитовСвойствамПрибораУчета();
	
	Для Каждого СтрокаКоллекции Из Коллекция Цикл
		
		Если ЗначениеЗаполнено(СтрокаКоллекции.ПриборУчета) Тогда
			СвойстваПрибора 									= СвойстваПриборовУчета[СтрокаКоллекции.ПриборУчета];		
		Иначе
			СвойстваПрибора 									= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(СтрокаКоллекции.ОписаниеПрибора);
		КонецЕсли;
			
		Если СвойстваПрибора = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого КлючЗначение Из СоотвествиеРеквизитовСвойств Цикл
			Если СтрокаКоллекции.Свойство(КлючЗначение.Ключ) И СвойстваПрибора.Свойство(КлючЗначение.Значение) Тогда
				СтрокаКоллекции[КлючЗначение.Ключ] 	= СвойстваПрибора[КлючЗначение.Значение];
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла; 	
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "ТочкиУчетаСредстваИзмерения" Тогда
		СтруктураЗаполнения = энргРаботаСТочкамиУчетаКлиент.ПолучитьВходныеДанныеДляЗаполненияСредствИзмерений(ЭтотОбъект);
		СтруктураЗаполнения.ПараметрыПередачи.ВходныеПараметры.Вставить("ВызывающаяПодсистема", "ЮЛ");
		энргРаботаСТочкамиУчетаКлиент.ОткрытьФормуЗаполненияСредствИзмерений(СтруктураЗаполнения);
	ИначеЕсли Поле.Имя = "ТочкиУчетаТехническиеСвойстваТУ" Тогда
		ОткрытьФормуТехническихСвойствТУ();	
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаписатьПараметрыТочекИПриборовУчета(ТекущийОбъект, СоответствиеСтрок)
	
	Сч 														= 0;
	Для Каждого СтрокаТочки Из Объект.ТочкиУчета Цикл
		ЗаписываемаяСтрока  								= ТекущийОбъект.ТочкиУчета[Сч];
		
		ДанныеТочкиУчета 									= Новый Структура(бестРаботаСТочкамиУчетаНПСервер.ПолучаемыеСвойстваТочекУчета());
		СоотвествиеРеквизитов 								= бестРаботаСТочкамиУчетаНПСервер.СоотвествиеРеквизитовСвойствамТочкиУчета(); 		
		Для Каждого КлючЗначение Из СоотвествиеРеквизитов Цикл			
			ДанныеТочкиУчета[КлючЗначение.Значение] 		= СтрокаТочки[КлючЗначение.Ключ];			
		КонецЦикла; 		
		ЗаписываемаяСтрока.ОписаниеТочки 					= Обработки.энргТочкиУчетаМенеджер.ЗначенияРеквизитовОбъектаВСтрокуJSON(ДанныеТочкиУчета);			
				
		СвойстваПрибора 									= энргРаботаСприборамиУчетаСервер.ПолучаемыеСвойстваПриборовУчета();
		ДанныеПрибораУчета 									= Новый Структура(СвойстваПрибора);
		СоотвествиеРеквизитов 								= энргРаботаСприборамиУчетаСервер.СоотвествиеРеквизитовСвойствамПрибораУчета();
		Для Каждого КлючЗначение Из СоотвествиеРеквизитов Цикл
			Если НЕ СтрокаТочки.Свойство(КлючЗначение.Ключ) Тогда
				Продолжить;
			КонецЕсли;
			
			ДанныеПрибораУчета[КлючЗначение.Значение] 		= СтрокаТочки[КлючЗначение.Ключ];						
		КонецЦикла;
		ЗаписываемаяСтрока.ОписаниеПрибора 					= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектаВСтрокуJSON(ДанныеПрибораУчета);
		
		СоответствиеСтрок.Вставить(СтрокаТочки.IDСтроки, СтрокаТочки.ЗаводскойНомер);
		Сч 													= Сч + 1;		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,Знач НовыеПриборыУчета, Знач ПриборУчета, Знач ОписаниеПрибора, Знач НомерСтроки)
		
	ЭтоНовыйПриборУчета									= НЕ НовыеПриборыУчета.Найти(НомерСтроки) = Неопределено;			
	ОписаниеОбъектаПриборУчета 							= Обработки.энргПриборыУчетаАбонентаМенеджер.ОписаниеОбъекта();
	ЗначенияРеквизитовПриборУчета						= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(ОписаниеПрибора);
	Для Каждого КлючЗначение Из ЗначенияРеквизитовПриборУчета Цикл
		Если ОписаниеОбъектаПриборУчета.Свойство(КлючЗначение.Ключ) Тогда
			ОписаниеОбъектаПриборУчета[КлючЗначение.Ключ] = КлючЗначение.Значение;
		КонецЕсли;				
	КонецЦикла;
	ОписаниеОбъектаПриборУчета.Ссылка 					= ПриборУчета;
	Если Не Обработки.энргПриборыУчетаАбонентаМенеджер.УдалосьЗаполнитьОбъектПоОписанию(ОписаниеОбъектаПриборУчета,ЭтоНовыйПриборУчета) Тогда
		Отказ											= Истина;
	КонецЕсли;	

КонецПроцедуры

#Область РаботаСТехническимиСвойствамиТУ

&НаКлиенте
Процедура ОткрытьФормуТехническихСвойствТУ()
	ТекущиеДанные		= Элементы.ТочкиУчета.ТекущиеДанные;
	КлючиДанных			= ПолучитьКлючиДанныхТехСвойств();
	
	ОписаниеОповещения 	= Новый ОписаниеОповещения("ТехническиеСвойстваТУЗавершение", ЭтотОбъект, Новый Структура("ТекущиеДанные, КлючиДанных", ТекущиеДанные, КлючиДанных));
	ОткрытьФорму("Обработка.энргОперацияУзламиУчета.Форма.ФормаТехническиеСвойстваТУ", ПолучитьВходныеДанныеТехническихСвойствТУ(ТекущиеДанные, КлючиДанных),,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры


/////////////////////////////////////////////
// Получение входных данных

&НаКлиенте
Функция ПолучитьВходныеДанныеТехническихСвойствТУ(ТекущиеДанные, КлючиДанных)
	ТехническиеСвойстваТУ 	= Новый Структура(КлючиДанных.Реквизиты + ", " + КлючиДанных.Таблицы);	
	ЗаполнитьЗначенияСвойств(ТехническиеСвойстваТУ, ТекущиеДанные, КлючиДанных.Реквизиты);
		
	ДополнитьТаблицыВВходныеДанныеТехСвойств(ТехническиеСвойстваТУ, ТекущиеДанные.IDСтроки);
	ТехническиеСвойстваТУ.Вставить("ВызывающаяПодсистема", "ЮЛ");
	
	Возврат Новый Структура("ВходныеПараметры", ТехническиеСвойстваТУ);
КонецФункции

&НаСервере
Процедура ДополнитьТаблицыВВходныеДанныеТехСвойств(ТехническиеСвойстваТУ, IDСтроки)
	ИдентификаторФормы 				= ЭтаФорма.УникальныйИдентификатор;	
	ТехническиеСвойстваТУ.Потери 	= ПоместитьВоВременноеХранилище(Объект.Потери.Выгрузить(Новый Структура("IDСтроки", IDСтроки)), ИдентификаторФормы);
КонецПроцедуры

&НаСервере
Функция ПолучитьКлючиДанныхТехСвойств()
	Возврат Обработки.энргОперацияУзламиУчета.ПолучитьКлючиЗаполненияТехническихСвойствТУ("ЮЛ");
КонецФункции


/////////////////////////////////////////////
// Обработка возврата результата

&НаКлиенте
Процедура ТехническиеСвойстваТУЗавершение(Результат, ДополнительныеПараметры) Экспорт	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 	= ДополнительныеПараметры.ТекущиеДанные;
	КлючиДанных 	= ДополнительныеПараметры.КлючиДанных;
	
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, Результат, КлючиДанных.Реквизиты);
	ТехническиеСвойстваТУ = "";
	ЗаполнитьПотериИзРезультата(ТекущиеДанные.IDСтроки, Результат, ТехническиеСвойстваТУ);
	ТекущиеДанные.ТехническиеСвойстваТУ 		= ТехническиеСвойстваТУ;//энргРаботаСТочкамиУчетаКлиент.ЗаполнитьТекстТехническихСвойств(Результат, Результат.Потери);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПотериИзРезультата(IDСтроки, Результат, ТехническиеСвойстваТУ)
	энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.Потери, Новый Структура("IDСтроки", IDСтроки));
	
	ПотериРезультат = ПолучитьИзВременногоХранилища(Результат.Потери);
	ПотериРезультат.Колонки.Добавить("IDСтроки");
	ПотериРезультат.ЗаполнитьЗначения(IDСтроки, "IDСтроки");
	Объект.Потери.Загрузить(ПотериРезультат); 	
	
	ТехническиеСвойстваТУ = энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстТехническихСвойств(Результат, ПотериРезультат,"ЮЛ");	
КонецПроцедуры


