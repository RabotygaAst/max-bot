	ТЧПотребителиГВС			= Объект.ПотребителиГВС;
	ТЧТемпГрафик				= Объект.ТемпературныеГрафикиОбъектов;
	ТЧДоговорныеОбъемы			= Объект.ГарантированныеОбъемы;
	ТЧМаксимНагрузки			= Объект.МаксимальныеНагрузки;
	ТЧТарифКатегории			= Объект.ТарифныеКатегорииУслуги;
	ТЧЭтапыПИД					= Объект.ЭтапыПИД;
	ТЧСрокиОплаты				= Объект.НастройкиОплаты;
	ТЧСпособРасперОплаты		= Объект.РаспределениеПоступившейОплаты;
	
	Объект.ТочкиУчета.Очистить();
	Объект.ПоказанияПриборовУчета.Очистить();
	Объект.ШкалыПриборовУчета.Очистить();
