	Результат 					= Запрос.ВыполнитьПакет();
	ВыборкаОбъекты				= Результат[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаПотребителиГВС		= Результат[5].Выгрузить();
	ВыборкаТемператГрафик		= Результат[6].Выгрузить();
