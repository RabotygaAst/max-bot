&НаКлиенте
Процедура ОбъектыРасчетаПриАктивизацииСтроки(Элемент)
		
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	//энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.УслугиОбъектов,						Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПотребителиГВС,						Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы["ТочкиУчета"	],	Неопределено,		ТекДанные.IDСтроки,, "Владельца");
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ТемпературныеГрафикиОбъектов,			Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.МаксимальныеНагрузки,					Неопределено,		ТекДанные.IDСтроки);
	//энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны,				Неопределено,		ТекДанные.IDСтроки); 
	//энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ФормулыРасчетаУслугЕстьШкалыЕстьТарифныеЗоны,					Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ТарифныеКатегорииУслуги,				Неопределено,		ТекДанные.IDСтроки);

	Если Объект.ОбъемыИНагрузкиВРазрезеДоговора И ТекДанные.НомерСтроки > 1 Тогда
		Элементы.ГарантированныеОбъемы.ТолькоПросмотр = Истина;
		Элементы.УслугиОбъектов.ТолькоПросмотр = Истина;
	Иначе
		Элементы.ГарантированныеОбъемы.ТолькоПросмотр = Ложь;
		энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ГарантированныеОбъемы,					Неопределено,		ТекДанные.IDСтроки);
		энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.УслугиОбъектов,						Неопределено,		ТекДанные.IDСтроки);
		энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ИтогиДоговорныхОбъемов,				Неопределено,		ТекДанные.IDСтроки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаНаименованиеОбъектаРасчетаПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекДанные.НаименованиеОбъектаРасчета) Тогда
		ТекДанные.ОбъектРасчета = ПредопределенноеЗначение("Справочник.бестОбъектыРасчета.ПустаяСсылка");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаОбъектРасчетаПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекДанные.ОбъектРасчета) Тогда 
		// Ищем строки по индентификатору
		ТаблицыФормы				= Новый Массив;	
		ТаблицыФормы.Добавить("УслугиОбъектов");
		ТаблицыФормы.Добавить("ПотребителиГВС");
		ТаблицыФормы.Добавить("ГарантированныеОбъемы");
		ТаблицыФормы.Добавить("ТарифныеКатегорииУслуги");

		энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(Элементы.ОбъектыРасчета.ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы);
			
		ДанныеОбъекта = бестРаботаСОбъектамиНПСервер.ПолучитьИнформациюПоОбъекту(ТекДанные.ОбъектРасчета);
		ЗаполнитьЗначенияСвойств(ТекДанные, ДанныеОбъекта.СтруктураОбъекта);
		
		СоответствиеНагрузок = ДанныеОбъекта.СоответствиеНагрузок;
		Для Каждого ТекНагрузка Из СоответствиеНагрузок Цикл
			НовСтрока = Объект.УслугиОбъектов.Добавить();
			НовСтрока.IDСтроки	= ТекДанные.IDСтроки;
			НовСтрока.Услуга	= ТекНагрузка.Ключ;
			НовСтрока.Нагрузка	= ТекНагрузка.Значение;
		КонецЦикла;
		
		СоответствиеПотребителей = ДанныеОбъекта.СоответствиеПотребителей;
		Для Каждого ТекПотребитель Из СоответствиеПотребителей Цикл
			НовСтрока = Объект.ПотребителиГВС.Добавить();
			НовСтрока.IDСтроки	= ТекДанные.IDСтроки;
			НовСтрока.Тип	= ТекПотребитель.Ключ;
			ЗаполнитьЗначенияСвойств(НовСтрока, ТекПотребитель.Значение);
		КонецЦикла;
		
		МассивОбъемов = ДанныеОбъекта.МассивОбъемов;
		Для Каждого ТекОбъем Из МассивОбъемов Цикл
			НовСтрока = Объект.ГарантированныеОбъемы.Добавить();
			НовСтрока.IDСтроки	= ТекДанные.IDСтроки;
			ЗаполнитьЗначенияСвойств(НовСтрока, ТекОбъем);
		КонецЦикла;
		
		СоответствиеТарифныхКатегорий = ДанныеОбъекта.СоответствиеТарифныхКатегорий;
		Для Каждого ТекТарифнаяКатегория Из СоответствиеТарифныхКатегорий Цикл
			НовСтрока = Объект.УслугиОбъектов.Добавить();
			НовСтрока.IDСтроки	= ТекДанные.IDСтроки;
			НовСтрока.Услуга	= ТекНагрузка.Ключ;
			НовСтрока.Нагрузка	= ТекНагрузка.Значение;
		КонецЦикла;

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаПередУдалением(Элемент, Отказ)
	ТаблицыФормы				= Новый Массив;	
	ТаблицыФормы.Добавить("УслугиОбъектов");
	ТаблицыФормы.Добавить("ПотребителиГВС");
	ТаблицыФормы.Добавить("ГарантированныеОбъемы");
	ТаблицыФормы.Добавить("ТемпературныеГрафикиОбъектов");
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(Элементы.ОбъектыРасчета.ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы);

	
	ТаблицыФормы.Очистить();
	ТаблицыФормы.Добавить("ТочкиУчета");
	ТаблицыФормыВторогоУровня	= Новый Массив;
	ТаблицыФормыВторогоУровня.Добавить("ПоказанияПриборовУчета");
	ТаблицыФормыВторогоУровня.Добавить("ФормулыРасчетаУслуг");
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(Элементы.ОбъектыРасчета.ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы,"Владельца", ТаблицыФормыВторогоУровня);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Если Копирование Тогда
		Отказ = Истина;	
		НоваяСтрока = Объект.ОбъектыРасчета.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент.ТекущиеДанные);
		НоваяСтрока.idСтроки = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	КонецЕсли; 
КонецПроцедуры

#КонецОбласти

#Область СобытияТабличнойЧастиГарантированныеОбъемы

&НаКлиенте
Процедура ГарантированныеОбъемыПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекДанныеОбъемы = Элементы.ГарантированныеОбъемы.ТекущиеДанные;
	Если ТекДанныеОбъемы = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	
	ТекДанныеОбъемы.IDСтроки = ТекДанные.IDСтроки;

	ЗаполнитьИтогиДоговорныхОбъемов();
	ЗаполнитьИтогиДоговорныхОбъемовПоДоговору();
	
КонецПроцедуры

#КонецОбласти

#Область СобытияТабличнойЧастиТочкиУчета

&НаКлиенте
Процедура ТочкиУчетаПриАктивизацииСтроки(Элемент)
	
	//ТекДанные = Элементы.ТочкиУчетаЕстьШкалыЕстьТарифныеЗоны.ТекущиеДанные;
	//энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны, Элементы.ФормулыРасчетаУслуг, ТекДанные.IDСтроки); 

	ТекущиеДанные			= Элементы["ТочкиУчета"				].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаФормыШкал		= Элементы["ШкалыПриборовУчета"		];
	ТаблицаФормыФормул		= Элементы["ФормулыРасчетаУслуг"	];
	ТаблицаФормыШкалУслуг	= Элементы["ШкалыУслуг"				];
	
	// энргРаботаСВидомКанальности {
	энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаФормыШкал,		"IDСтрокиТочкиУчета",	ТекущиеДанные.IDСтроки); 
	энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаФормыФормул,		"IDСтроки",				ТекущиеДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаФормыШкалУслуг,	"IDСтроки",				ТекущиеДанные.IDСтроки);
	// энргРаботаСВидомКанальности }
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаНетШкалыЕстьТарифныеЗоныПриАктивизацииСтроки(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета" ;
	ИмяТаблицыПоказания						= "ПоказанияПриборовУчета" ;
	ТаблицаФормыПоказания 					= Элементы[ИмяТаблицыПоказания];
	
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
		ТекущиеДанные.IDСтроки 				= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	// энргРаботаСВидомДифференцированности {
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(ТаблицаФормыПоказания,Неопределено,ТекущиеДанные.IDСтрокиШкалы); 
	// энргРаботаСВидомДифференцированности }

КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаВидКанальностиПриИзменении(Элемент)
	
	ИмяТаблицыТочек 						= "ТочкиУчета" ;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	ВидКанальности 							= ТекущиеДанные.ВидКанальности;
	СоставКанальности 						= энргРаботаСТочкамиУчетаСервер.СоставКанальности(ВидКанальности);
	// энргРаботаСВидомКанальности {
	энргРаботаСТочкамиУчетаКлиент.ПриИзмененииВидаКанальности(ЭтаФорма,ТекущиеДанные.IDСтроки,СоставКанальности,"ШкалыПриборовУчета","ПоказанияПриборовУчета"); 
	// энргРаботаСВидомКанальности }
	
	СоставУслуги = энргРаботаСПоставщикамиСервер.ПолучитьСоставУслугиСоШкалами(ТекущиеДанные.Услуга, ВидКанальности);
	бестРаботаСТочкамиУчетаНПКлиент.ПриИзмененииВидаКанальности(ЭтаФорма, ТекущиеДанные, СоставУслуги, "ШкалыУслуг");	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаВидДифференцированностиПриИзменении(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета" ;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	ВидДифференцированности 				= ТекущиеДанные.ВидДифференцированности;
	// энргРаботаСВидомДифференцированности {
	энргРаботаСТочкамиУчетаКлиент.ПриИзмененииВидаДифференцированности(ЭтаФорма,ТекущиеДанные.IDСтрокиШкалы,энргРаботаСТочкамиУчетаСервер.СоставВидаДифференцированности(ВидДифференцированности,ТекущиеДанные.услуга),"ПоказанияПриборовУчета",Неопределено); 
	// энргРаботаСВидомДифференцированности }	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаУслугаПриИзменении(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	
	энргРаботаСТочкамиУчетаКлиент.СозданиеНаименованияТУ(ТекущиеДанные);
	
	ОписаниеУслуги = энргРаботаСПоставщикамиСервер.ОписаниеУслуги(ТекущиеДанные.Услуга);
	
	// энргРаботаСПоставщиками {
	бестРаботаСПоставщикамиКлиент.ПриИзмененииУслуги(ЭтаФорма,ТекущиеДанные,ОписаниеУслуги); 	
	// энргРаботаСПоставщиками } 
	
	УстановитьУсловноеОФормлениеФормыКлиент("Поставщик","ПараметрыПоставщиков");
	// энргРаботаСоСпособамиРасчетаНорматива {
	бестРаботаСоСпособомРасчетаНормативаКлиент.ПриИзмененииУслуги(ЭтаФорма,ТекущиеДанные,ОписаниеУслуги); 	
	// энргРаботаСоСпособамиРасчетаНорматива }
	
	Если ИспользоватьШкалыПриборовУчета Тогда
		СоставУслуги = энргРаботаСПоставщикамиСервер.ПолучитьСоставУслугиСоШкалами(ТекущиеДанные.Услуга, ТекущиеДанные.ВидКанальности);
		бестРаботаСТочкамиУчетаНПКлиент.ПриИзмененииВидаКанальности(ЭтаФорма, ТекущиеДанные, СоставУслуги, "ШкалыУслуг");	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПоставщикАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	энргРаботаСПоставщикамиКлиент.ПоставщикАвтоПодбор(ЭтаФорма,ТекущиеДанные);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЗаводскойНомерПриИзменении(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;	
	ЗаполнитьКоэфициент(ТекущиеДанные);
	
	ТекущиеДанные.ВладелецПрибораУчета = Объект.Контрагент;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТипПрибораУчетаПриИзменении(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;	
	ЗаполнитьКоэфициент(ТекущиеДанные);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЕстьШкалыЕстьТарифныеЗоныПередУдалением(Элемент, Отказ)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	// энргРаботаСПоставщиками {
	энргРаботаСПоставщикамиКлиент.ПередУдалением(ЭтаФорма,ТекущиеДанные);
	// энргРаботаСПоставщиками }
	
	// энргРаботаСоСпособамиРасчетаНорматива {
	бестРаботаСоСпособомРасчетаНормативаКлиент.ПередУдалением(ЭтаФорма,ТекущиеДанные);
	// энргРаботаСоСпособамиРасчетаНорматива }
	
	ТаблицыФормы				= Новый Массив;	
	ТаблицыФормы.Добавить("ШкалыПриборовУчета");
	ТаблицыФормы.Добавить("ФормулыРасчетаУслуг");
	ТаблицыФормы.Добавить("ШкалыУслуг");
	
	ТаблицыФормыВторогоУровня	= Новый Массив;
	ТаблицыФормыВторогоУровня.Добавить("ПоказанияПриборовУчета");

	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы,,ТаблицыФормыВторогоУровня);
КонецПроцедуры  

&НаКлиенте
Процедура ТочкиУчетаНетШкалыЕстьТарифныеЗоныПередУдалением(Элемент, Отказ)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	// энргРаботаСПоставщиками {
	энргРаботаСПоставщикамиКлиент.ПередУдалением(ЭтаФорма,ТекущиеДанные);
	// энргРаботаСПоставщиками }
	
	// энргРаботаСоСпособамиРасчетаНорматива {
	бестРаботаСоСпособомРасчетаНормативаКлиент.ПередУдалением(ЭтаФорма,ТекущиеДанные);
	// энргРаботаСоСпособамиРасчетаНорматива }
	
	ТаблицыФормы				= Новый Массив;	
	ТаблицыФормы.Добавить("ПоказанияПриборовУчета");

	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(ТекущиеДанные.IDСтрокиШкалы, Объект, ТаблицыФормы);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЕстьШкалыНетТарифныхЗонПередУдалением(Элемент, Отказ)
	ИмяТаблицыТочек 						= "ТочкиУчета";
