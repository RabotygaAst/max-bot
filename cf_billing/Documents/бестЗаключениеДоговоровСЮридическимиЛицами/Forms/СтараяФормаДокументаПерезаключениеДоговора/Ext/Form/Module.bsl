			// Запрет на создание пустых строк
			Если Не ЗначениеЗаполнено(ВыборкаНагрузки.Услуга) Тогда
				Продолжить;
			КонецЕсли;
			
			// Объекты расчета
			ЗаполнитьЗначенияСвойств(НовСтрокаОбъекты, ВыборкаНагрузки);
			
			//Нагрузка
			НовСтрокаУслугиОбъектов	= ТЧОУслугиОбъектов.Добавить();
			НовСтрокаУслугиОбъектов.IDСтроки = IDСтроки;
			ЗаполнитьЗначенияСвойств(НовСтрокаУслугиОбъектов, ВыборкаНагрузки);
			
			
		КонецЦикла;	
		//////////////////////////
		Если Объект.ТекущийДоговор.ТипДоговора = Перечисления.бестТипыДоговоров.УправляющаяКомпания Тогда
			ЗаполнитьТочками(НовСтрокаОбъекты.IDСтроки,НовСтрокаОбъекты.МКД,ТекОбъект);
			
			энргРаботаСПоказаниямиПриборовУчетаСервер.ОбновитьПоказанияПриборовУчетаМКД(Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Дата,Объект.Организация, Объект.Район,НовСтрокаОбъекты.МКД,Ложь);
			
		ИначеЕсли Объект.ТекущийДоговор.ТипДоговора = Перечисления.бестТипыДоговоров.РСО Тогда
			
			ЗаполнитьТочками(НовСтрокаОбъекты.IDСтроки,,ТекОбъект);
			
			бестРаботаСПоказаниямиПриборовУчетаНПСервер.ОбновитьТЧПоказанияПрибораУчета(Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Дата,Объект.Организация,Объект.Район,Ложь);			

		КонецЕсли;	
		
		энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект,Объект,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета, "ТочкиУчета");
		//////////////////////////
		// Потребители ГВС
		ИщемПотребителяГВС		= ВыборкаПотребителиГВС.НайтиСтроки(Новый Структура("ОбъектРасчета", ТекОбъект));
		Для н = 0 по ИщемПотребителяГВС.Вграница() Цикл
			НовСтрокаПотребителиГВС	= ТЧПотребителиГВС.Добавить();	
			НовСтрокаПотребителиГВС.IDСтроки	= IDСтроки;	 
			ЗаполнитьЗначенияСвойств(НовСтрокаПотребителиГВС, ИщемПотребителяГВС[н]);
		КонецЦикла;
		
		// Температурные графики
		ИщемТемпГрафик		= ВыборкаТемператГрафик.НайтиСтроки(Новый Структура("ОбъектРасчета", ТекОбъект));
		Для н = 0 по ИщемТемпГрафик.Вграница() Цикл
			НовСтрокаТемпГрафик	= ТЧТемпГрафик.Добавить();	
			НовСтрокаТемпГрафик.IDСтроки	= IDСтроки;	 
			ЗаполнитьЗначенияСвойств(НовСтрокаТемпГрафик, ИщемТемпГрафик[н]);
		КонецЦикла;  
		
		// Договорные объемы
		ИщемДоговорныеОбъемы		= ВыборкаДоговорныеОбъемы.НайтиСтроки(Новый Структура("ОбъектРасчета", ТекОбъект));
		Для н = 0 по ИщемДоговорныеОбъемы.Вграница() Цикл
			НовСтрокаДогОбъемы	= ТЧДоговорныеОбъемы.Добавить();	
			НовСтрокаДогОбъемы.IDСтроки	= IDСтроки;	 
			ЗаполнитьЗначенияСвойств(НовСтрокаДогОбъемы, ИщемДоговорныеОбъемы[н]);
		КонецЦикла;
		
		// Максимальные нагрузки
		ИщемМаксНагрузки		= ВыборкаМаксимНагрузки.НайтиСтроки(Новый Структура("ОбъектРасчета", ТекОбъект));
		Для н = 0 по ИщемМаксНагрузки.Вграница() Цикл
			НовСтрокаМаксНагрузка	= ТЧМаксимНагрузки.Добавить();	
			НовСтрокаМаксНагрузка.IDСтроки	= IDСтроки;	 
			ЗаполнитьЗначенияСвойств(НовСтрокаМаксНагрузка, ИщемМаксНагрузки[н]);
		КонецЦикла;		
		
		// Тарифные категории
		ИщемТарифныеКатегории		= ВыборкаТарифнеКатегории.НайтиСтроки(Новый Структура("ОбъектРасчета", ТекОбъект));
		Для н = 0 по ИщемТарифныеКатегории.Вграница() Цикл
			НовСтрокаТарифнКатег	= ТЧТарифКатегории.Добавить();	
			НовСтрокаТарифнКатег.IDСтроки	= IDСтроки;	 
			ЗаполнитьЗначенияСвойств(НовСтрокаТарифнКатег, ИщемТарифныеКатегории[н]);
		КонецЦикла;	
		
	КонецЦикла;
	
	// В случе если тарифные категории не заполнились, заполняем их из точек учета
	Если Не ЗначениеЗаполнено(Объект.ТарифныеКатегорииУслуги) Тогда
		Для каждого ТекСтрока Из Объект.ТочкиУчета Цикл
			бестРаботаСТочкамиУчетаНПСервер.ОбновитьГруппыПотребителейУслуги(ЭтотОбъект, ТекСтрока.IDСтрокиВладельца);
		КонецЦикла;
	КонецЕсли;
	
	// Способы распределения оплаты
	ТЧСпособРасперОплаты.Загрузить(ВыборкаСпособРаспрОплаты);
	
	// Сроки оплаты
	ТЧСрокиОплаты.Загрузить(ВыборкаСрокиОплаты);
	
	// Этапы ПИД
	ТЧЭтапыПИД.Загрузить(ВыборкаЭтапыПИД);
	
	энргРаботаСПоставщикамиСервер.УстановитьУсловноеОФормлениеФормы(ЭтаФорма,"Поставщик","ПараметрыПоставщиков");
	//энргРаботаСТочкамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
	//энргРаботаСприборамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма,"СпособРасчетаНорматива","СпособыРасчетаНормативаСоставныхУслуг","ПараметрыСпособовРасчетаНорматива");
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТочками(IDСтрокиВладельца,МКД = Неопределено, ОбъектРасчета)
	
	
	
	Если МКД = Неопределено Тогда
		Результат 							= бестРаботаСприборамиУчетаСервер.ПриборыВсехТочекУчетаПоДоговору(Объект.Дата,Объект.Организация,Объект.Район,Объект.ТекущийДоговор,ОбъектРасчета);
	Иначе
		Результат 							= энргРаботаСприборамиУчетаСервер.ПриборыВсехТочекУчетаМКД(Объект.Дата,Объект.Организация,Объект.Район,МКД);
	КонецЕсли;
	Выборка  									= Результат.выбрать();
	ТекТочкаУчета 								= Неопределено;
	ТекПрибор 									= Неопределено;
	ТекШкала 									= Неопределено;
	IDСтрокиТочки 								= Неопределено;
	IDСтрокиШкалы 								= Неопределено;
	ПоставщикПоУмолчанию	= ЭтаФорма.ПараметрыПоставщиков.ПоставщикПоУмолчанию;
	Пока Выборка.следующий() цикл		
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда 			
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
			IDСтрокиТочки 						= Новый УникальныйИдентификатор;
			ЗаполнитьЗначенияСвойств(СтрокаТочкиУчета, Выборка);
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;			
			СтрокаТочкиУчета.IDСтрокиВладельца	= IDСтрокиВладельца;
			СтрокаТочкиУчета.Поставщик			= ПоставщикПоУмолчанию;
			СтрокаТочкиУчета.Расположение		= Выборка.ТочкаУчета.Расположение;
			СтрокаТочкиУчета.Головная			= Выборка.ТочкаУчета.Головная;
			СтрокаТочкиУчета.ЗаводскойНомер		= СтрокаТочкиУчета.ПриборУчета.Код;
			СтрокаТочкиУчета.ТипПрибораУчета	= СтрокаТочкиУчета.ПриборУчета.ТипПрибораУчета;
			СтрокаТочкиУчета.ВидКанальности		= СтрокаТочкиУчета.ПриборУчета.ВидКанальности;
			СтрокаТочкиУчета.НаименованиеТочки  = Выборка.ТочкаУчета.Наименование;
			
			ОписаниеУслуги = энргРаботаСПоставщикамиСервер.ОписаниеУслуги(Выборка.Услуга);
			СтрокаТочкиУчета.ЭтоСоставнаяУслуга = ОписаниеУслуги.ЭтоСоставнаяУслуга;
			
			Если СтрокаТочкиУчета.ЭтоСоставнаяУслуга Тогда
				ПредставлениеПоставщика  			= "";
				ПредставлениеСпособРасчета  		= "";
				Для Каждого Строка из ОписаниеУслуги.Услуги Цикл
					СтрокаТЧ  						= ЭтаФорма.Объект.ПоставщикиСоставныхУслуг.Добавить();
					СтрокаТЧ.IDСтроки 				= СтрокаТочкиУчета.IDСтроки;
					СтрокаТЧ.ЧастьСоставнойУслуги 	= Строка;
					СтрокаТЧ.Поставщик 				= ПоставщикПоУмолчанию;
					ПредставлениеПоставщика 		= ПредставлениеПоставщика + ?(ЗначениеЗаполнено(ПредставлениеПоставщика),"/","") +  ПоставщикПоУмолчанию;
					
					СтрокаТЧСпособРасчета  							= ЭтаФорма.Объект.СпособыРасчетаНормативаСоставныхУслуг.Добавить();
					СтрокаТЧСпособРасчета.IDСтроки 					= СтрокаТочкиУчета.IDСтроки;
					СтрокаТЧСпособРасчета.ЧастьСоставнойУслуги 		= Строка;
					СтрокаТЧСпособРасчета.СпособРасчетаНорматива 	= ПолучитьСпособРасчетаНорматива(Строка,Выборка);
					ПредставлениеСпособРасчета 		= ПредставлениеСпособРасчета + ?(ЗначениеЗаполнено(ПредставлениеСпособРасчета),"/","") +  СтрокаТЧСпособРасчета.СпособРасчетаНорматива;
				КонецЦикла;
				
				ДанныеСоставныхУслуг	= ЭтаФорма.ПараметрыПоставщиков.ДанныеСоставныхУслуг;
				IDСтрока				= СтрЗаменить(СтрокаТочкиУчета.IDСтроки,Символы.НПП,"");
				ИмяПоля					= "Поставщик";
				Если ДанныеСоставныхУслуг.Получить(IDСтрока) = Неопределено Тогда
					ДанныеСоставныхУслуг.Вставить(IDСтрока,Новый Структура(ИмяПоля,ПредставлениеПоставщика));
				ИначеЕсли ДанныеСоставныхУслуг[IDСтрока][ИмяПоля] = Неопределено Тогда
					ДанныеСоставныхУслуг[IDСтрока].Вставить(ИмяПоля,ПредставлениеПоставщика);
				Иначе
					ДанныеСоставныхУслуг[IDСтрока][ИмяПоля] 	= ПредставлениеПоставщика; 
				КонецЕсли;
				
				ДанныеСоставныхУслуг	= ЭтаФорма.ПараметрыСпособовРасчетаНорматива.ДанныеСоставныхУслуг;
				IDСтрока				= СтрЗаменить(СтрокаТочкиУчета.IDСтроки,Символы.НПП,"");
				ИмяПоля					= "СпособРасчетаНорматива";
				Если ДанныеСоставныхУслуг.Получить(IDСтрока) = Неопределено Тогда
					ДанныеСоставныхУслуг.Вставить(IDСтрока,Новый Структура(ИмяПоля,ПредставлениеСпособРасчета));
				ИначеЕсли ДанныеСоставныхУслуг[IDСтрока][ИмяПоля] = Неопределено Тогда
					ДанныеСоставныхУслуг[IDСтрока].Вставить(ИмяПоля,ПредставлениеСпособРасчета);
				Иначе
					ДанныеСоставныхУслуг[IDСтрока][ИмяПоля] 	= ПредставлениеСпособРасчета; 
				КонецЕсли;

			Иначе
				СтрокаТочкиУчета.Поставщик 				= ПоставщикПоУмолчанию; 
				СтрокаТочкиУчета.СпособРасчетаНорматива = ПолучитьСпособРасчетаНорматива(Выборка.Услуга, Выборка);
			КонецЕсли;

			Если ЗначениеЗаполнено( Выборка.УзелУчета) Тогда
				СтрокаТочкиУчета.ТипУзлаУчета		= Выборка.УзелУчета.ТипУзлаУчета;
				СтрокаТочкиУчета.ВладелецУзлаУчета = Объект.Контрагент; 
				
			КонецЕсли;
			
			бестРаботаСприборамиУчетаСервер.ПолучитьбестСпособНачисленияНорматива(Объект.Организация,Объект.Район,Объект.Дата,СтрокаТочкиУчета,ОбъектРасчета);
			
			Если МКД = Неопределено Тогда
				бестРаботаСприборамиУчетаСервер.ПолучитьНачалоКонецДействияКоммерческогоУчета(Объект.Организация,Объект.Район,Объект.Дата,СтрокаТочкиУчета,,Объект.ТекущийДоговор,ОбъектРасчета);
			иначе
				бестРаботаСприборамиУчетаСервер.ПолучитьНачалоКонецДействияКоммерческогоУчета(Объект.Организация,Объект.Район,Объект.Дата,СтрокаТочкиУчета,МКД);
			КонецЕсли;
			
			
			//ЗаполнитьДанныеТочки(Выборка.ТочкаУчета);
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) и НЕ ТекПрибор = Выборка.ПриборУчета Тогда 			
			
			СтрокаПриборов  					= Объект.ПриборыУзловУчета.Добавить();
			IDСтрокиШкалы						= Новый УникальныйИдентификатор;
			ЗаполнитьЗначенияСвойств(СтрокаПриборов, Выборка);
			СтрокаПриборов.IDСтроки 			= IDСтрокиТочки;
			СтрокаПриборов.IDСтрокиШкалы 		= IDСтрокиШкалы;
			
			СтрокаПриборов.ЗаводскойНомер		= СтрокаПриборов.ПриборУчета.Код;
			СтрокаПриборов.ТипПрибораУчета		= СтрокаПриборов.ПриборУчета.ТипПрибораУчета;
			СтрокаПриборов.ВидКанальности		= СтрокаПриборов.ПриборУчета.ВидКанальности;
			
			ЗаполнитьДанныеПрибора(СтрокаПриборов,Выборка.ПриборУчета,МКД, Выборка);
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) Тогда //НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиТарифнаяЗона				= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.IDСтрокиТарифнаяЗона 	= IDСтрокиТарифнаяЗона;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидПараметра 			= Выборка.ВидПараметра;			
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
			
			СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
			СтрокаПоказаний.IDСтрокиТочкиУчета		= IDСтрокиТочки;
			СтрокаПоказаний.IDСтроки 				= IDСтрокиТарифнаяЗона;
			СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		КонецЕсли; 		
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекШкала 								= Выборка.Шкала;
		ТекПрибор 								= Выборка.ПриборУчета;
		
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеПрибора(ТекСтрока, ПриборУчета, МКД, Выборка)
	Запрос = Новый Запрос;
	Запрос.Текст =	
	"ВЫБРАТЬ
	|	энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ПриборУчета.Код КАК ЗаводскойНомер,
	|	энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ПриборУчета.ТипПрибораУчета КАК ТипПрибораУчета,
	|	энргДатыПоверкиПрибораУчетаСрезПоследних.ПериодРегистрации КАК ДатаВыпуска,
	|	энргДатыПоверкиПрибораУчетаСрезПоследних.ДатаПоверки КАК ДатаПоверкиСчетчика,
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.НомерПломбы КАК НомерПломбы,
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.Период КАК ДатаУстановкиПломбы
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовУзловУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И ПриборУчета = &ПриборУчета) КАК энргСостояниеПриборовУзловУчетаМКДСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргДатыПоверкиПрибораУчета.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район
	|					И КлючПомещения.Строение = &МКД
	|					И ПриборУчета = &ПриборУчета) КАК энргДатыПоверкиПрибораУчетаСрезПоследних
	|		ПО энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ПриборУчета = энргДатыПоверкиПрибораУчетаСрезПоследних.ПриборУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргНомерПломбПриборовУчетаМКД.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район
	|					И МКД = &МКД
	|					И ПриборУчета = &ПриборУчета) КАК энргНомерПломбПриборовУчетаМКДСрезПоследних
	|		ПО энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ПриборУчета = энргНомерПломбПриборовУчетаМКДСрезПоследних.ПриборУчета
	|ГДЕ
	|	энргСостояниеПриборовУзловУчетаМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)";
	
	Если НЕ ЗначениеЗаполнено(МКД) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "МКД = &МКД", "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "КлючПомещения.Строение = &МКД", "ИСТИНА");
	Иначе
		Запрос.УстановитьПараметр("МКД"				, МКД);
	КонецЕсли;
	Запрос.УстановитьПараметр("Организация"		, Объект.Организация);
	Запрос.УстановитьПараметр("Период"			, Новый Граница(Объект.Дата,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Район"			, Объект.Район);
	Запрос.УстановитьПараметр("ПриборУчета"		, ПриборУчета);
	
	РезультатЗапроса 	= Запрос.Выполнить();	
	ВыборкаТочкиУчета	= РезультатЗапроса.Выбрать();
	Пока  ВыборкаТочкиУчета.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ТекСтрока, ВыборкаТочкиУчета);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(МКД) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргДопускПриборовУчетаККоммерческомуУчетуМКДСрезПоследних.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
		|	энргДопускПриборовУчетаККоммерческомуУчетуМКДСрезПоследних.КонецПериодаКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета
		|ИЗ
		|	РегистрСведений.энргДопускПриборовУчетаККоммерческомуУчетуМКД.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ТочкаУчета = &ТочкаУчета
		|				И ПриборУчета = &ПриборУчета
		|				И МКД = &МКД) КАК энргДопускПриборовУчетаККоммерческомуУчетуМКДСрезПоследних";
		
		Запрос.УстановитьПараметр("Дата", Объект.Дата);
		Запрос.УстановитьПараметр("МКД", МКД);
		Запрос.УстановитьПараметр("Организация", Объект.Организация);
		Запрос.УстановитьПараметр("ПриборУчета", Выборка.ПриборУчета);
		Запрос.УстановитьПараметр("Район", Объект.Район);
		Запрос.УстановитьПараметр("ТочкаУчета", Выборка.ТочкаУчета);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ТекСтрока.НачалоДействияКоммерскогоУчета = ВыборкаДетальныеЗаписи.НачалоДействияКоммерскогоУчета;
			ТекСтрока.КонецПериодаКоммерскогоУчета = ВыборкаДетальныеЗаписи.КонецПериодаКоммерскогоУчета;
		КонецЦикла;
		
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестДопускПриборовУчетаККоммерческомуУчетуСрезПоследних.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
		|	бестДопускПриборовУчетаККоммерческомуУчетуСрезПоследних.КонецПериодаКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета
		|ИЗ
		|	РегистрСведений.бестДопускПриборовУчетаККоммерческомуУчету.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ТочкаУчета = &ТочкаУчета
		|				И ПриборУчета = &ПриборУчета
		|				И ОбъектРасчета = &ОбъектРасчета) КАК бестДопускПриборовУчетаККоммерческомуУчетуСрезПоследних";
		
		Запрос.УстановитьПараметр("Дата", Объект.Дата);
		Запрос.УстановитьПараметр("ОбъектРасчета", Выборка.ОбъектРасчета);
		Запрос.УстановитьПараметр("Организация", Объект.Организация);
		Запрос.УстановитьПараметр("ПриборУчета", Выборка.ПриборУчета);
		Запрос.УстановитьПараметр("Район", Объект.Район);
		Запрос.УстановитьПараметр("ТочкаУчета", Выборка.ТочкаУчета);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ТекСтрока.НачалоДействияКоммерскогоУчета = ВыборкаДетальныеЗаписи.НачалоДействияКоммерскогоУчета;
			ТекСтрока.КонецДействияКоммерскогоУчета = ВыборкаДетальныеЗаписи.КонецПериодаКоммерскогоУчета;
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры
