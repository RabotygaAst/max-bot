&НаКлиенте
Процедура ПроверкаЗначенияОбычнойНагрузки(ИмяТЧ, ИмяТЧСиноним, ТекУслуга, ТекНагрузка, ТекIDСтроки, ТекНомерСтроки)
	Отбор 		 = Новый Структура("IDСтроки, Услуга", ТекIDСтроки, ТекУслуга);
	ИщемСтроку	 = Объект[ИмяТЧ].НайтиСтроки(Отбор);
	ТекСумма	 = Неопределено;
	Если ИщемСтроку.Количество() > 0 Тогда
		ТекСумма = ИщемСтроку[0].Нагрузка;
	КонецЕсли;
	Отбор.Вставить("ИмяТЧСиноним", ИмяТЧСиноним);
	Отбор.Вставить("ТекНагрузка", ТекНагрузка);
	Отбор.Вставить("ТекСумма", ТекСумма);
	Отбор.Вставить("ИщемСтроку", ИщемСтроку);
	Отбор.Вставить("ТекНомерСтроки", ТекНомерСтроки);
	ПроверкаИзмененияНагрузки(Отбор);
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьМаксимальнуюНагрузку(ДополнительныеПараметры)
	Если ДополнительныеПараметры.Изменяем Тогда
		Если Не ДополнительныеПараметры.ТекСумма = Неопределено Тогда
			НоваяСТрока = ДополнительныеПараметры.ИщемСтроку[0];
		Иначе
			НоваяСтрока = Объект.МаксимальныеНагрузки.Добавить();
		КонецЕсли;
		
		НоваяСтрока.IDСтроки 	= ДополнительныеПараметры.IDСтроки;
		НоваяСтрока.Услуга 		= ДополнительныеПараметры.Услуга;
		НоваяСтрока.Нагрузка 	= ДополнительныеПараметры.ТекНагрузка;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Данная нагрузка добавлена в ТЧ '" + ДополнительныеПараметры.ИмяТЧСиноним + "'! Скорректируйте значение в ТЧ '" + ДополнительныеПараметры.ИмяТЧСиноним + "', если необходимо!");	
	Иначе
		Если ДополнительныеПараметры.ИщемСтроку <> Неопределено Тогда
			ИзменяемаяСтрока = Объект.УслугиОбъектов[ДополнительныеПараметры.ТекНомерСтроки - 1];
			ИзменяемаяСтрока.Нагрузка =  ДополнительныеПараметры.ИщемСтроку[0].Нагрузка;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаИзмененияНагрузки(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросИзмененияНагрузки", ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Изменение нагрузки изменит значение Максимальной нагрузки по данной услуге у текущего объекта. Изменить нагрузку?", РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросИзмененияНагрузки(РезультатВопроса,ДополнительныеПараметры) Экспорт
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			ДополнительныеПараметры.Вставить("Изменяем", Истина);
			ИзменитьМаксимальнуюНагрузку(ДополнительныеПараметры);
		Иначе
			ДополнительныеПараметры.Вставить("Изменяем", Ложь);
			ИзменитьМаксимальнуюНагрузку(ДополнительныеПараметры);
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаЗначенияНагрузки(ИмяТЧ, ИмяТЧСиноним,ТекУслуга, ТекНагрузка, ТекIDСтроки)
	Отбор 		= Новый Структура("IDСтроки, Услуга", ТекIDСтроки, ТекУслуга);
	ИщемСтроку	= Объект[ИмяТЧ].НайтиСтроки(Отбор);
	Если ИщемСтроку.Количество() > 0 Тогда
		ТекСумма= ИщемСтроку[0].Нагрузка;
	КонецЕсли;
	Если ТекСумма > ТекНагрузка Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Максимальная нагрузка не может быть меньше нагрузки в ТЧ '" + ИмяТЧСиноним + "'! Необходимо скорректировать нагрузку!");
		ТекНагрузка	= ТекСумма; 
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПереключениеИтоговДоговорныхИтогов(Команда)
	ИтогиПоДоговору = Не ИтогиПоДоговору;
	ОбновитьЗаголовокКнопкиПереключенияИтогов();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗаголовокКнопкиПереключенияИтогов()
	Если ИтогиПоДоговору Тогда
		Элементы.ПереключениеИтоговДоговорныхИтогов.Заголовок = "Показать итоги по объекту";
		Элементы.ИтогиДоговорныхОбъемовПоДоговору.Видимость = Истина;
		Элементы.ИтогиДоговорныхОбъемов.Видимость = ложь;
	Иначе	
		Элементы.ПереключениеИтоговДоговорныхИтогов.Заголовок = "Показать итоги по договору";
		Элементы.ИтогиДоговорныхОбъемовПоДоговору.Видимость = Ложь;
		Элементы.ИтогиДоговорныхОбъемов.Видимость = Истина;
	КонецЕсли;	              
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИтогиДоговорныхОбъемов()
	ТЧ				= Объект.ГарантированныеОбъемы;
	ТЗ				= ИтогиДоговорныхОбъемов.Выгрузить();
	ТЗ.Очистить(); 
	Для каждого стр из ТЧ Цикл
		НовСтрока = ТЗ.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, стр);
		НовСтрока.ЕдиницаИзмерения = стр.Услуга.ЕдиницаИзмерения;
		НовСтрока.ИтогПервыйКвартал = стр.Январь + стр.Февраль + стр.Март;
		НовСтрока.ИтогВторойКвартал = стр.Апрель + стр.Май + стр.Июнь;
		НовСтрока.ИтогТретийКвартал = стр.Июль + стр.Август + стр.Сентябрь;
		НовСтрока.ИтогГод = стр.Январь + стр.Февраль + стр.Март + стр.Апрель + стр.Май + стр.Июнь + стр.Июль + стр.Август + стр.Сентябрь 
						+ стр.Октябрь + стр.Ноябрь + стр.Декабрь;
	КонецЦикла;
	ТЗ.Свернуть("IDСтроки, ЕдиницаИзмерения", "Январь,Февраль,Март,Апрель,Май,Июнь,Июль,Август,Сентябрь,Октябрь,Ноябрь,Декабрь, ИтогПервыйКвартал, ИтогВторойКвартал, ИтогТретийКвартал, ИтогГод");
	ИтогиДоговорныхОбъемов.Загрузить(ТЗ);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИтогиДоговорныхОбъемовПоДоговору()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.Текст = "ВЫБРАТЬ
	|	бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Услуга.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Январь) КАК Январь,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Февраль) КАК Февраль,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Март) КАК Март,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Апрель) КАК Апрель,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Май) КАК Май,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Июнь) КАК Июнь,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Июль) КАК Июль,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Август) КАК Август,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Сентябрь) КАК Сентябрь,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Октябрь) КАК Октябрь,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Ноябрь) КАК Ноябрь,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Декабрь) КАК Декабрь,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Январь + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Февраль + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Март + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Апрель + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Май + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Июнь + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Июль + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Август + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Сентябрь + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Октябрь + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Ноябрь + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Декабрь) КАК ИтогГод,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Январь + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Февраль + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Март) КАК ИтогПервыйКвартал,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Апрель + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Май + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Июнь) КАК ИтогВторойКвартал,
	|	СУММА(бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Июль + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Август + бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Сентябрь) КАК ИтогТретийКвартал
	|ИЗ
	|	Документ.бестЗаключениеДоговоровСЮридическимиЛицами.ГарантированныеОбъемы КАК бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы
	|ГДЕ
	|	бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	бестЗаключениеДоговоровСЮридическимиЛицамиГарантированныеОбъемы.Услуга.ЕдиницаИзмерения";
	
	Результат = Запрос.Выполнить();
	Выгрузка	= Результат.Выгрузить();

	ИтогиДоговорныхОбъемовПоДоговору.Загрузить(Выгрузка);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСуммуПоКварталу()
	Для каждого ТекСтрока из Объект.ГарантированныеОбъемы Цикл
		ИтогПервыйКвартал 		= ТекСтрока.Январь + ТекСтрока.Февраль + ТекСтрока.Март;
		ИтогВторойКвартал 		= ТекСтрока.Апрель + ТекСтрока.Май + ТекСтрока.Июнь;
		ИтогТретийКвартал 		= ТекСтрока.Июль + ТекСтрока.Август + ТекСтрока.Сентябрь;
		ИтогЧетвертыйКвартал 	= ТекСтрока.Октябрь + ТекСтрока.Ноябрь + ТекСтрока.Декабрь;
		//ИтогГод 				= ИтогПервыйКвартал + ИтогВторойКвартал + ИтогТретийКвартал + ИтогЧетвертыйКвартал;
		
		ТекСтрока.ГарантированныйОбъемИтогПервыйКвартал 	= ИтогПервыйКвартал;
		ТекСтрока.ГарантированныйОбъемИтогВторойКвартал 	= ИтогВторойКвартал;
		ТекСтрока.ГарантированныйОбъемИтогТретийКвартал 	= ИтогТретийКвартал;
		ТекСтрока.ГарантированныйОбъемИтогЧетвертыйКвартал 	= ИтогЧетвертыйКвартал;
		ТекСтрока.ГарантированныйОбъемИтогГод				= ИтогПервыйКвартал+ИтогВторойКвартал +ИтогТретийКвартал + ИтогЧетвертыйКвартал;	
	КонецЦикла;
КонецПроцедуры

