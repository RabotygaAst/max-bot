#Область ДобавлениеПУКУзлам

&НаКлиенте
Процедура ДобавитьПриборыУчета(Команда) 
	
	ТекущиеДанные = Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.ТипУзлаУчета) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить тип узла учета!");
		Возврат;		
	КонецЕсли;
	
	СтруктураОтвета = энргРаботаСПриборамиУчетаКлиент.ВернутьНачальныеПараметрыПередачиДляУзлов(ЭтаФорма, ТекущиеДанные, Объект);
	ПолучитьДанныеТабЧастей(СтруктураОтвета.ПараметрыПередачи,ТекущиеДанные.IDСтроки,ТекущиеДанные.ТипУзлаУчета,ТекущиеДанные.НачалоДействияКоммерскогоУчета,ТекущиеДанные.КонецДействияКоммерскогоУчета);	
	энргРаботаСПриборамиУчетаКлиент.ДобавитьПриборыУчета(СтруктураОтвета);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеТабЧастей(ПараметрыПередачи,IDСтроки,ТипУзлаУчета,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета) 	
	энргРаботаСприборамиУчетаСервер.ПолучитьДанныеТабЧастейУзла(ПараметрыПередачи, IDСтроки, Объект,ТипУзлаУчета,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета);
КонецПроцедуры

#КонецОбласти

#Область ПереопределенныеПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаПриИзменении(Элемент)
	ЗаполнитьИтогиДоговорныхОбъемов();
	ЗаполнитьИтогиДоговорныхОбъемовПоДоговору();
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Для каждого стр из Объект.ОбъектыРасчета Цикл
		ОповеститьОбИзменении(стр.ОбъектРасчета);		
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДоговорныеОбъемы(Команда)
	ТекОбъект = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекОбъект = Неопределено Тогда
		Возврат;
	КонецЕсли;
	IDСтроки = ТекОбъект.IDСтроки;
	
	Модифицированность = Истина;
	Если ЗначениеЗаполнено(Объект.ГарантированныеОбъемы) Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ОтветНаОчисткуТаблицы", ЭтотОбъект, Новый Структура("IDСтроки", IDСтроки));
		ПоказатьВопрос(ОписаниеОповещения, "Очистить договорные объемы?", РежимДиалогаВопрос.ДаНет);
	Иначе
		ЗаполнитьДоговорныеОбъемыНаСервере(, IDСтроки);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтветНаОчисткуТаблицы(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ОчиститьТЧ = РезультатВопроса = КодВозвратаДиалога.Да;
	ЗаполнитьДоговорныеОбъемыНаСервере(ОчиститьТЧ, ДополнительныеПараметры.IDСтроки);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДоговорныеОбъемыНаСервере(ОчиститьТЧ = Ложь, IDСтроки)

	Если ОчиститьТЧ Тогда
		МассивУдвления = Объект.ГарантированныеОбъемы.НайтиСтроки(Новый Структура("IDСтроки", IDСтроки));
		
		Для каждого СтрокаТЧ Из МассивУдвления Цикл
			Объект.ГарантированныеОбъемы.Удалить(СтрокаТЧ);
		КонецЦикла;
	КонецЕсли;
	
	СтрокаОбъекта = Объект.ОбъектыРасчета.НайтиСтроки(Новый Структура("IDСтроки", IDСтроки));
	
	Запрос = Новый Запрос;
	МВТ  = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестТемпературыВКатегорияхОбъектовСрезПоследних.ТемператураОптимальная КАК ТемператураОптимальная
		|ПОМЕСТИТЬ ВТ_ОптимальнаяТемпература
		|ИЗ
		|	РегистрСведений.бестТемпературыВКатегорияхОбъектов.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КатегорияПомещения = &КатегорияПомещения) КАК бестТемпературыВКатегорияхОбъектовСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестРасчетнаяТемператураНаружногоВоздухаДляПроектированияСрезПоследних.ПроектнаяТемпература КАК ПроектнаяТемпература
		|ПОМЕСТИТЬ ВТ_ПроектнаяТемпература
		|ИЗ
		|	РегистрСведений.бестРасчетнаяТемператураНаружногоВоздухаДляПроектирования.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район) КАК бестРасчетнаяТемператураНаружногоВоздухаДляПроектированияСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МаксимальныеНагрузки.Услуга КАК Услуга,
		|	МаксимальныеНагрузки.Нагрузка КАК Нагрузка,
		|	МаксимальныеНагрузки.IDСтроки КАК IDСтроки
		|ПОМЕСТИТЬ ВТ_МаксимальныеНагрузки
		|ИЗ
		|	&МаксимальныеНагрузки КАК МаксимальныеНагрузки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц КАК ПорядокМесяц,
		|	бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.РасчетТепловойЭнергии КАК РасчетТепловойЭнергии,
		|	бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.КоличествоДней КАК КоличествоДней,
		|	ВЫБОР
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 1
		|			ТОГДА ""Январь""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 2
		|			ТОГДА ""Февраль""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 3
		|			ТОГДА ""Март""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 4
		|			ТОГДА ""Апрель""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 5
		|			ТОГДА ""Май""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 6
		|			ТОГДА ""Июнь""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 7
		|			ТОГДА ""Июль""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 8
		|			ТОГДА ""Август""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 9
		|			ТОГДА ""Сентябрь""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 10
		|			ТОГДА ""Октябрь""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 11
		|			ТОГДА ""Ноябрь""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц = 12
		|			ТОГДА ""Декабрь""
		|	КОНЕЦ КАК Месяц,
		|	ВЫБОР
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц <= 3
		|			ТОГДА ""ГарантированныйОбъемИтогПервыйКвартал""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц <= 6
		|			ТОГДА ""ГарантированныйОбъемИтогВторойКвартал""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц <= 9
		|			ТОГДА ""ГарантированныйОбъемИтогТретийКвартал""
		|		КОГДА бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних.Месяц <= 12
		|			ТОГДА ""ГарантированныйОбъемИтогЧетвертыйКвартал""
		|	КОНЕЦ КАК Квартл
		|ПОМЕСТИТЬ ВТ_Месяцы
		|ИЗ
		|	РегистрСведений.бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемов.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район) КАК бестНастройкаКоличестваДнейДляРасчетаДоговорныхОбъемовСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргВидыУслуг.Ссылка КАК Услуга,
		|	ВТ_МаксимальныеНагрузки.Нагрузка КАК Нагрузка,
		|	энргВидыУслуг.ЗависитОтУслуги КАК ЗависитОтУслуги,
		|	энргВидыУслуг.бестИспользоватьТемпературныйКоэффициентПоВоздуху КАК бестИспользоватьТемпературныйКоэффициентПоВоздуху,
		|	ВТ_Месяцы.Месяц КАК Месяц,
		|	ВТ_Месяцы.КоличествоДней КАК КоличествоДней,
		|	ВТ_Месяцы.ПорядокМесяц КАК ПорядокМесяц,
		|	ЕСТЬNULL(ВТ_ПроектнаяТемпература.ПроектнаяТемпература, 0) КАК ПроектнаяТемпература,
		|	ЕСТЬNULL(ВТ_ОптимальнаяТемпература.ТемператураОптимальная, 0) КАК ТемператураВнутриПомещения,
		|	24 КАК КоличествоЧасов,
		|	ВТ_Месяцы.Квартл КАК Квартл
		|ПОМЕСТИТЬ ВТ_Услуги
		|ИЗ
		|	ВТ_МаксимальныеНагрузки КАК ВТ_МаксимальныеНагрузки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Месяцы КАК ВТ_Месяцы
		|			ПО энргВидыУслуг.бестИспользоватьТемпературныйКоэффициентПоВоздуху = ВТ_Месяцы.РасчетТепловойЭнергии
		|		ПО ВТ_МаксимальныеНагрузки.Услуга = энргВидыУслуг.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОптимальнаяТемпература КАК ВТ_ОптимальнаяТемпература
		|		ПО (ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПроектнаяТемпература КАК ВТ_ПроектнаяТемпература
		|		ПО (ИСТИНА)
		|ГДЕ
		|	ВТ_МаксимальныеНагрузки.IDСтроки = &IDСтроки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(бестСредегодоваяРазницаТемпературДляДоговорныхОбъемовСрезПоследних.Температура) КАК Температура,
		|	ВТ_Месяцы.Месяц КАК Месяц,
		|	ВТ_Месяцы.ПорядокМесяц КАК ПорядокМесяц
		|ПОМЕСТИТЬ ВТ_СреднегодоваяРазница
		|ИЗ
		|	РегистрСведений.бестСредегодоваяРазницаТемпературДляДоговорныхОбъемов.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район) КАК бестСредегодоваяРазницаТемпературДляДоговорныхОбъемовСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Месяцы КАК ВТ_Месяцы
		|		ПО (ИСТИНА)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Месяцы.Месяц,
		|	ВТ_Месяцы.ПорядокМесяц
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(бестСреднемесячнаяТемператураВоздухаДляДоговорныхОбъемовСрезПоследних.Температура) КАК Температура,
		|	ВТ_Месяцы.Месяц КАК Месяц,
		|	ВТ_Месяцы.ПорядокМесяц КАК ПорядокМесяц
		|ПОМЕСТИТЬ ВТ_СреднемесячнаяТемпература
		|ИЗ
		|	РегистрСведений.бестСреднемесячнаяТемператураВоздухаДляДоговорныхОбъемов.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район) КАК бестСреднемесячнаяТемператураВоздухаДляДоговорныхОбъемовСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Месяцы КАК ВТ_Месяцы
		|		ПО (МЕСЯЦ(бестСреднемесячнаяТемператураВоздухаДляДоговорныхОбъемовСрезПоследних.Месяц) = ВТ_Месяцы.ПорядокМесяц)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Месяцы.Месяц,
		|	ВТ_Месяцы.ПорядокМесяц
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Услуги.Услуга КАК Услуга,
		|	ВТ_Услуги.Месяц КАК Месяц,
		|	ВТ_Услуги.ЗависитОтУслуги КАК ЗависитОтУслуги,
		|	ВТ_Услуги.бестИспользоватьТемпературныйКоэффициентПоВоздуху КАК бестИспользоватьТемпературныйКоэффициентПоВоздуху,
		|	ВТ_Услуги.КоличествоДней КАК КоличествоДней,
		|	ВТ_СреднегодоваяРазница.Температура КАК СреднегодоваяРазница,
		|	ВТ_СреднемесячнаяТемпература.Температура КАК СреднемесячнаяТемпература,
		|	ВТ_Услуги.ПроектнаяТемпература КАК ПроектнаяТемпература,
		|	ВТ_Услуги.ТемператураВнутриПомещения КАК ТемператураВнутриПомещения,
		|	ВТ_Услуги.КоличествоЧасов КАК КоличествоЧасов,
		|	ВТ_Услуги.Нагрузка КАК Нагрузка,
		|	ВТ_Услуги.ПорядокМесяц КАК ПорядокМесяц,
		|	ВТ_Услуги.Квартл КАК Квартл
		|ПОМЕСТИТЬ ВТ_ДанныеРасчета
		|ИЗ
		|	ВТ_Услуги КАК ВТ_Услуги
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СреднегодоваяРазница КАК ВТ_СреднегодоваяРазница
		|		ПО ВТ_Услуги.ПорядокМесяц = ВТ_СреднегодоваяРазница.ПорядокМесяц
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СреднемесячнаяТемпература КАК ВТ_СреднемесячнаяТемпература
		|		ПО ВТ_Услуги.ПорядокМесяц = ВТ_СреднемесячнаяТемпература.ПорядокМесяц
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ДанныеРасчета.Услуга КАК Услуга,
		|	ВТ_ДанныеРасчета.Месяц КАК Месяц,
		|	ВЫБОР
		|		КОГДА ВТ_ДанныеРасчета.СреднемесячнаяТемпература ЕСТЬ NULL
		|				ИЛИ ВТ_ДанныеРасчета.ПроектнаяТемпература = ВТ_ДанныеРасчета.ТемператураВнутриПомещения
		|			ТОГДА 0
		|		ИНАЧЕ ВТ_ДанныеРасчета.Нагрузка * ВТ_ДанныеРасчета.КоличествоДней * ВТ_ДанныеРасчета.КоличествоЧасов * (ВТ_ДанныеРасчета.ТемператураВнутриПомещения - ВТ_ДанныеРасчета.СреднемесячнаяТемпература) / (ВТ_ДанныеРасчета.ТемператураВнутриПомещения - ВТ_ДанныеРасчета.ПроектнаяТемпература)
		|	КОНЕЦ КАК Объем,
		|	NULL КАК ЗависитОтУслуги,
		|	NULL КАК бестИспользоватьТемпературныйКоэффициентПоВоздуху,
		|	ВТ_ДанныеРасчета.ПорядокМесяц КАК ПорядокМесяц,
		|	ВТ_ДанныеРасчета.Квартл КАК Квартл
		|ПОМЕСТИТЬ ВТ_ОбъемыБезОсновныхУслуг
		|ИЗ
		|	ВТ_ДанныеРасчета КАК ВТ_ДанныеРасчета
		|ГДЕ
		|	ВТ_ДанныеРасчета.бестИспользоватьТемпературныйКоэффициентПоВоздуху
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТ_ДанныеРасчета.Услуга,
		|	ВТ_ДанныеРасчета.Месяц,
		|	ВТ_ДанныеРасчета.Нагрузка * ВТ_ДанныеРасчета.КоличествоДней * ВТ_ДанныеРасчета.КоличествоЧасов,
		|	ВТ_ДанныеРасчета.ЗависитОтУслуги,
		|	ВТ_ДанныеРасчета.бестИспользоватьТемпературныйКоэффициентПоВоздуху,
		|	ВТ_ДанныеРасчета.ПорядокМесяц,
		|	ВТ_ДанныеРасчета.Квартл
		|ИЗ
		|	ВТ_ДанныеРасчета КАК ВТ_ДанныеРасчета
		|ГДЕ
		|	НЕ ВТ_ДанныеРасчета.бестИспользоватьТемпературныйКоэффициентПоВоздуху
		|	И ВТ_ДанныеРасчета.ЗависитОтУслуги <> ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВТ_ОбъемыБезОсновныхУслуг.Объем) КАК ОбъемПодчинённых,
		|	энргВидыУслуг.Ссылка КАК ОсновнаяУслуга,
		|	ВТ_ОбъемыБезОсновныхУслуг.Месяц КАК Месяц,
		|	ВТ_СреднегодоваяРазница.ПорядокМесяц КАК ПорядокМесяц,
		|	ВТ_СреднегодоваяРазница.Температура КАК СреднегодоваяРазницаТемператур,
		|	ВТ_ОбъемыБезОсновныхУслуг.Квартл КАК Квартл
		|ПОМЕСТИТЬ ВТ_ОсновныеУслуги
		|ИЗ
		|	ВТ_ОбъемыБезОсновныхУслуг КАК ВТ_ОбъемыБезОсновныхУслуг
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
		|		ПО ВТ_ОбъемыБезОсновныхУслуг.ЗависитОтУслуги = энргВидыУслуг.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СреднегодоваяРазница КАК ВТ_СреднегодоваяРазница
		|		ПО ВТ_ОбъемыБезОсновныхУслуг.ПорядокМесяц = ВТ_СреднегодоваяРазница.ПорядокМесяц
		|ГДЕ
		|	НЕ ВТ_ОбъемыБезОсновныхУслуг.бестИспользоватьТемпературныйКоэффициентПоВоздуху
		|	И НЕ энргВидыУслуг.бестИспользоватьТемпературныйКоэффициентПоВоздуху
		|
		|СГРУППИРОВАТЬ ПО
		|	энргВидыУслуг.Ссылка,
		|	ВТ_ОбъемыБезОсновныхУслуг.Месяц,
		|	ВТ_СреднегодоваяРазница.ПорядокМесяц,
		|	ВТ_СреднегодоваяРазница.Температура,
		|	ВТ_ОбъемыБезОсновныхУслуг.Квартл
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ОсновныеУслуги.ОсновнаяУслуга КАК Услуга,
		|	ВТ_ОсновныеУслуги.Месяц КАК Месяц,
		|	ВЫБОР
		|		КОГДА ВТ_ОсновныеУслуги.СреднегодоваяРазницаТемператур ЕСТЬ NULL
		|				ИЛИ ВТ_ОсновныеУслуги.СреднегодоваяРазницаТемператур = 0
		|			ТОГДА 0
		|		ИНАЧЕ ВТ_ОсновныеУслуги.ОбъемПодчинённых / ВТ_ОсновныеУслуги.СреднегодоваяРазницаТемператур
		|	КОНЕЦ КАК Объем,
		|	ВТ_ОсновныеУслуги.ПорядокМесяц КАК ПорядокМесяц,
		|	ВТ_ОсновныеУслуги.Квартл КАК Квартл
		|ИЗ
		|	ВТ_ОсновныеУслуги КАК ВТ_ОсновныеУслуги
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТ_ОбъемыБезОсновныхУслуг.Услуга,
		|	ВТ_ОбъемыБезОсновныхУслуг.Месяц,
		|	ВТ_ОбъемыБезОсновныхУслуг.Объем,
		|	ВТ_ОбъемыБезОсновныхУслуг.ПорядокМесяц,
		|	ВТ_ОбъемыБезОсновныхУслуг.Квартл
		|ИЗ
		|	ВТ_ОбъемыБезОсновныхУслуг КАК ВТ_ОбъемыБезОсновныхУслуг
		|
		|УПОРЯДОЧИТЬ ПО
		|	Услуга,
		|	ПорядокМесяц
		|ИТОГИ
		|	СУММА(Объем)
		|ПО
		|	Услуга,
		|	Квартл";
	
	Запрос.УстановитьПараметр("Дата", 					Объект.Дата);
	Запрос.УстановитьПараметр("Организация", 			Объект.Организация);
	Запрос.УстановитьПараметр("Район",					Объект.Район);
	Запрос.УстановитьПараметр("МаксимальныеНагрузки", 	Объект.МаксимальныеНагрузки.Выгрузить());
	Запрос.УстановитьПараметр("IDСтроки",				IDСтроки);
	Запрос.УстановитьПараметр("КатегорияПомещения",		СтрокаОбъекта[0].КатегорияОбъекта);
	
	
	//РезультатЗапроса = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	РезультатЗапроса = Запрос.Выполнить();
	
	//ВыборкаУслуга = РезультатЗапроса[9].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаУслуга = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаУслуга.Следующий() Цикл
		НайденныеСтроки = Объект.ГарантированныеОбъемы.НайтиСтроки(Новый Структура("Услуга, IDСтроки", ВыборкаУслуга.Услуга, IDСтроки));
		Если НайденныеСтроки.Количество() = 0 Тогда
			СтрокаТЧ = Объект.ГарантированныеОбъемы.Добавить();
			СтрокаТЧ.Услуга = ВыборкаУслуга.Услуга;
			СтрокаТЧ.Год = Объект.Дата;
			СтрокаТЧ.IDСтроки = IDСтроки;
		Иначе
			СтрокаТЧ = НайденныеСтроки[0];
		КонецЕсли;
		
		ВыборкаКвартл = ВыборкаУслуга.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаКвартл.Следующий() Цикл
			СтрокаТЧ[ВыборкаКвартл.Квартл] = ВыборкаКвартл.Объем;
			
			Выборка = ВыборкаКвартл.Выбрать();
			Пока Выборка.Следующий() Цикл
				СтрокаТЧ[Выборка.Месяц] = Выборка.Объем;
			КонецЦикла;
			
		КонецЦикла;
		
		СтрокаТЧ.ГарантированныйОбъемИтогГод = ВыборкаУслуга.Объем;
		
	КонецЦикла;
	
	ЗаполнитьИтогиДоговорныхОбъемов();
	ЗаполнитьИтогиДоговорныхОбъемовПоДоговору();
КонецПроцедуры 

