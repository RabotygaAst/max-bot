&НаКлиенте
Процедура СформироватьДанныеВыбораУслуги(Текст, ДанныеВыбора, СтандартнаяОбработка)
	    СтандартнаяОбработка = Ложь;
		ТекДанные = Элементы.УслугиОбъектов.ТекущиеДанные;	
		Если НЕ ТекДанные = Неопределено Тогда
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("IDСтрокиВладельца", ТекДанные.IDСтроки);
			
			НайденныеСтроки = Объект.ТочкиУчета.НайтиСтроки(ПараметрыОтбора);	
			
			СписокУслуг = Новый СписокЗначений;
			
			Для Каждого Стр Из НайденныеСтроки Цикл
				СписокУслуг.Добавить(Стр.Услуга);
			КонецЦикла;
			
			ДанныеВыбора = ПолучитьСписокУслугДляВыбораНаСервере(СписокУслуг, Текст);
		КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСписокУслугДляВыбораНаСервере(СписокУслуг, Текст)			
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргВидыУслугСоставляющиеУслуг.Услуга КАК Услуга
	|ИЗ
	|	Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|ГДЕ
	|	энргВидыУслугСоставляющиеУслуг.Ссылка В(&СписокУслуг)
	|	И энргВидыУслугСоставляющиеУслуг.Услуга.Наименование ПОДОБНО &Текст
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргВидыУслугСоставляющиеУслуг.Ссылка
	|ИЗ
	|	Справочник.энргВидыУслуг КАК энргВидыУслугСоставляющиеУслуг
	|ГДЕ
	|	энргВидыУслугСоставляющиеУслуг.Ссылка В(&СписокУслуг)
	|	И энргВидыУслугСоставляющиеУслуг.Наименование ПОДОБНО &Текст";
	
	Запрос.УстановитьПараметр("СписокУслуг", СписокУслуг);	
	Запрос.УстановитьПараметр("Текст", Текст + "%");	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	СписокУслуг.Очистить();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СписокУслуг.Добавить(ВыборкаДетальныеЗаписи.Услуга);
	КонецЦикла;
	
	Возврат СписокУслуг;
КонецФункции

