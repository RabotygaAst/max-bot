#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
	
	ПараметрыЗапроса = Новый Структура;
	Схема = Неопределено;
	
	ДобавитьТекстЗапросаЗначенияТарифнойСтавки(Схема, Регистры);
	
	КлючиТаблицДвижений = энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	Запрос = Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("мДокументы", ДокументСсылка);
	
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		Запрос.ВыполнитьПакет());
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьТекстЗапросаЗначенияТарифнойСтавки(Схема, Регистры)
	
	ИмяРегистра = "бестЗначенияТарифнойСетки";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема = Новый СхемаЗапроса;
		Пакет = Схема.ПакетЗапросов[0];
	Иначе
		Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	бестИзменениеТарифнойСетки.Дата КАК Период,
	|	бестИзменениеТарифнойСетки.Организация КАК Организация,
	|	бестИзменениеТарифнойСетки.ТарифнаяСетка КАК ТарифнаяСетка,
	|	НАЧАЛОПЕРИОДА(бестИзменениеТарифнойСеткиТарифныеКоэффициенты.Месяц, МЕСЯЦ) КАК Месяц,
	|	бестИзменениеТарифнойСеткиТарифныеКоэффициенты.Услуга КАК Услуга,
	|	бестИзменениеТарифнойСеткиТарифныеКоэффициенты.Значение КАК Значение
	|ИЗ
	|	Документ.бестИзменениеТарифнойСетки.ТарифныеКоэффициенты КАК бестИзменениеТарифнойСеткиТарифныеКоэффициенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестИзменениеТарифнойСетки КАК бестИзменениеТарифнойСетки
	|		ПО бестИзменениеТарифнойСеткиТарифныеКоэффициенты.Ссылка = бестИзменениеТарифнойСетки.Ссылка
	|ГДЕ
	|	бестИзменениеТарифнойСетки.Ссылка В(&мДокументы)";		
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли