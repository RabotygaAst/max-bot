#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ЭтоПрочиеНачисления = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.бестВидыОпераций.ИзменитьДанныеДляДополнительногоРасчета_ПрочиеДополнительныеНачисления");
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.бестВидыОпераций.ИзменитьДанныеДляДополнительногоРасчета_ПревышениеПДК") Тогда
		Элементы.ПериодыЗначенийКоэффициент.МаксимальноеЗначение = 10;
		Элементы.ПериодыЗначенийКоэффициент.Заголовок = "Количество загрязняющих веществ";
	ИначеЕсли ЭтоПрочиеНачисления Тогда
		Элементы.ПериодыЗначенийКоэффициент.Заголовок = "Процент"; 
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.бестВидыОпераций.ИзменитьДанныеДляДополнительногоРасчета_НегативноеВоздействие") Тогда
		Элементы.ПериодыЗначенийКоэффициент.Заголовок = "Коэффициент компенсации";
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеДляРасчетаТарифнаяКатегория", "Видимость", ЭтоПрочиеНачисления);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеДляРасчетаТипДополнительногоНачисления", "Видимость", ЭтоПрочиеНачисления);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПериодыЗначенийСезонность", "Видимость", ЭтоПрочиеНачисления);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПериодыЗначенийПериод", "Видимость", Не ЭтоПрочиеНачисления);
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	бестЛокализацияСервер.ПриСозданииНаСервере_бестИзменитьДанныеДляДополнительногоРасчета(ЭтотОбъект);	
КонецПроцедуры

#Конецобласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	Объект.Организация = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Район,"Организация");
КонецПроцедуры

#Конецобласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДанныеДляРасчета

&НаКлиенте
Процедура ДанныеДляРасчетаТочкаУчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекДанные = Элементы.ДанныеДляРасчета.ТекущиеДанные;
	ВыборПростыеУслугиИТочкиУчета(ТекДанные, Элемент);
КонецПроцедуры

&НаКлиенте
Процедура ДанныеДляРасчетаУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекДанные = Элементы.ДанныеДляРасчета.ТекущиеДанные;
	ВыборПростыеУслугиИТочкиУчета(ТекДанные, Элемент);
КонецПроцедуры

&НаКлиенте
Процедура ДанныеДляРасчетаПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.ДанныеДляРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПериодыЗначений, Неопределено, ТекДанные.IDСтроки);
КонецПроцедуры

&НаКлиенте
Процедура ДанныеДляРасчетаПередУдалением(Элемент, Отказ)
	ТаблицыФормы = Новый Массив;	
	ТаблицыФормы.Добавить("ПериодыЗначений");
	
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(Элементы.ДанныеДляРасчета.ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы);
КонецПроцедуры

&НаКлиенте
Процедура ДанныеДляРасчетаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока ИЛИ Копирование Тогда
		ТекущиеДанные 							= Элементы["ДанныеДляРасчета"].ТекущиеДанные;		
		ТекущиеДанные.IDСтроки					= Новый УникальныйИдентификатор;
	КонецЕсли;
КонецПроцедуры

#Конецобласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПериодыЗначений

&НаКлиенте
Процедура ПериодыЗначенийПриИзменении(Элемент)
	ТекДанные = Элементы.ДанныеДляРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ИмяТаблицыТочек 						= "ПериодыЗначений";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ТекущиеДанные.IDСтроки = ТекДанные.IDСтроки;
КонецПроцедуры

&НаКлиенте
Процедура ПериодыЗначенийПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	ТекДанные = Элементы.ДанныеДляРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПериодыЗначений, Неопределено, ТекДанные.IDСтроки);
КонецПроцедуры

#Конецобласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ВыборПростыеУслугиИТочкиУчета(ТекДанные, Элемент)
	СтруктураОтбора = Новый Структура("Период,Организация,Район,ОбъектРасчета, ПростыеУслуги",КонецДня(Объект.Дата));
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,Объект);
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,ТекДанные);
	
	
	СтруктураОтбора.ПростыеУслуги = Истина;	
	
	ПараметрыВыбораФормы	= Новый Структура("СтруктураОтбора,ТипВладельца", СтруктураОтбора, "НП");
	ОписаниеОповещения 		= Новый ОписаниеОповещения("ТочкаУчетаОкончаниеВыбора",ЭтаФорма,Новый Структура("ТекДанные", ТекДанные));
	
	ОткрытьФорму("ОбщаяФорма.бестФормаВыбораТочкиУчета",ПараметрыВыбораФормы, ЭтаФорма,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

&НаКлиенте
Процедура ТочкаУчетаОкончаниеВыбора(РезультатЗакрытия,ДополнительныеПараметры) Экспорт  
	
	Если РезультатЗакрытия <> Неопределено Тогда 
		Модифицированность		= Истина;
		ТекДанные				= ДополнительныеПараметры.ТекДанные;
		
		ТекДанные.ТочкаУчета 	= РезультатЗакрытия.ТочкаУчета;
		ТекДанные.Услуга 		= РезультатЗакрытия.Услуга;
	КонецЕсли;
КонецПроцедуры

#Конецобласти