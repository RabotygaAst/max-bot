#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	Ответственный 				= Пользователи.ТекущийПользователь();		  
	
	бестПроведениеСерверНП.ПередЗаписьюОбъекта(ЭтотОбъект);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	бестПроведениеСерверНП.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	Результат = ПолучитьДанныеДляПроведения();
		
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(Результат,	Движения.бестЗначенияСбытовойНадбавки);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьДанныеДляПроведения()
	Запрос  	= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",				Ссылка);
	
	Текст 		= "ВЫБРАТЬ
	      		  |	бестИзменитьЗначениеСбытовойНадбавки.Дата КАК Период,
	      		  |	бестИзменитьЗначениеСбытовойНадбавки.Организация КАК Организация,
	      		  |	бестИзменитьЗначениеСбытовойНадбавкиЗначения.Поставщик КАК Поставщик,
	      		  |	бестИзменитьЗначениеСбытовойНадбавкиЗначения.Услуга КАК Услуга,
	      		  |	бестИзменитьЗначениеСбытовойНадбавкиЗначения.ДиапазонМощности КАК ДиапазонМощности,
	      		  |	бестИзменитьЗначениеСбытовойНадбавкиЗначения.НДСВнутри КАК НДСВнутри,
	      		  |	бестИзменитьЗначениеСбытовойНадбавкиЗначения.Значение КАК Значение,
	      		  |	бестИзменитьЗначениеСбытовойНадбавки.Район КАК Район
	      		  |ИЗ
	      		  |	Документ.бестИзменитьЗначениеСбытовойНадбавки.Значения КАК бестИзменитьЗначениеСбытовойНадбавкиЗначения
	      		  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестИзменитьЗначениеСбытовойНадбавки КАК бестИзменитьЗначениеСбытовойНадбавки
	      		  |		ПО бестИзменитьЗначениеСбытовойНадбавкиЗначения.Ссылка = бестИзменитьЗначениеСбытовойНадбавки.Ссылка
	      		  |ГДЕ
	      		  |	бестИзменитьЗначениеСбытовойНадбавки.Ссылка = &Ссылка";
	
	Запрос.Текст = Текст;
	
	Возврат Запрос.Выполнить(); 
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли