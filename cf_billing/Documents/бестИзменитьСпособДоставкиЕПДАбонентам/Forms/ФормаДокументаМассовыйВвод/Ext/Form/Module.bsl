#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура МКДНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	// ОТЭК, 21.05.2020, 000202897.
	энргПользовательскийВводКлиент.отэкНачалоВыбораСтроения(Элемент, Объект.Организация, 
																Объект.Район, СтандартнаяОбработка);
	отэкОчиститьСвязанныеРеквизиты();
	// ОТЭК, 21.05.2020, 000202897.
КонецПроцедуры

&НаКлиенте
Процедура МКДПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.МКД) тогда
		энргПользовательскийВводКлиент.ПриИзмененииМКД(Объект);
	иначе
		Объект.Район 			= ПредопределенноеЗначение("Справочник.энргЗоныОтвественности.ПустаяСсылка");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	РайонПриИзмененииНаСервере();
	
	// ОТЭК, 21.05.2020, 000202897.
	отэкОчиститьСвязанныеРеквизиты();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// ОТЭК, 21.05.2020, 000202897.
&НаКлиенте
Процедура отэкОчиститьСвязанныеРеквизиты()
	Объект.МКД = ПредопределенноеЗначение("Справочник.энргАбоненты.ПустаяСсылка");
	Объект.Абоненты.Очистить();
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ВыборСпособаДоставкиЕПД_Завершение(Результат, Параметры) Экспорт
	Для каждого стр из Объект.Абоненты Цикл
		стр.СпособДоставкиЕПД = Результат;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСпособДоставки(Команда)
	ОткрытьФорму("Справочник.бестСпособыДоставкиЕПД.ФормаВыбора", ,ТекСпособДоставкиЕПД,,,, Новый ОписаниеОповещения(
											"ВыборСпособаДоставкиЕПД_Завершение", ЭтотОбъект, Параметры));	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАбонентов(Команда)
	Отказ = Ложь;
	Если Не ЗначениеЗаполнено(Объект.Организация) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить организацию!");
		Отказ = Истина;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Район) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить район!");
		Отказ = Истина;
	КонецЕсли;
	Если НЕ Отказ Тогда
		ЗаполнитьАбонентовНаСервере();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАбонентовНаСервере()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", 			Объект.Дата);
	Запрос.УстановитьПараметр("Организация", 	Объект.Организация);
	Запрос.УстановитьПараметр("Район", 			Объект.Район);
	Запрос.УстановитьПараметр("МКД", 			Объект.МКД);
	
	Текст = "ВЫБРАТЬ
	        |	ВложенныйЗапрос.Абонент КАК Абонент
	        |ИЗ
	        |	(ВЫБРАТЬ
	        |		энргАбоненты.Ссылка КАК Абонент
	        |	ИЗ
	        |		(ВЫБРАТЬ
	        |			энргКлючиПомещений.КлючПомещения КАК Ссылка
	        |		ИЗ
	        |			РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	        |				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения КАК энргПомещения
	        |				ПО энргКлючиПомещений.Помещение = энргПомещения.Ссылка
	        |					И (НЕ энргПомещения.ПометкаУдаления)
	        |					И энргКлючиПомещений.Строение = энргПомещения.Строение
	        |		ГДЕ
	        |			энргКлючиПомещений.Строение = &МКД
	        |		
	        |		СГРУППИРОВАТЬ ПО
	        |			энргКлючиПомещений.КлючПомещения) КАК ВложенныйЗапрос
	        |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	        |			ПО ВложенныйЗапрос.Ссылка = энргАбоненты.КлючПомещения
	        |				И (НЕ энргАбоненты.ПометкаУдаления)
	        |				И (НЕ энргАбоненты.ЭтоГруппа)
	        |	ГДЕ
	        |		энргАбоненты.Район = &Район
	        |		И энргАбоненты.Организация = &Организация
	        |	
	        |	СГРУППИРОВАТЬ ПО
	        |		энргАбоненты.Ссылка) КАК ВложенныйЗапрос
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСостояниеЛС.СрезПоследних(
	        |				&Дата,
	        |				Организация = &Организация
	        |					И Район = &Район) КАК энргСостояниеЛССрезПоследних
	        |		ПО ВложенныйЗапрос.Абонент = энргСостояниеЛССрезПоследних.Абонент
	        |			И (энргСостояниеЛССрезПоследних.Состояние)
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ВложенныйЗапрос.Абонент";

	Если Не ЗначениеЗаполнено(Объект.МКД) Тогда
		Текст	= СтрЗаменить(Текст, "		где энргКлючиПомещений.Строение = &МКД", "");		
	КонецЕсли;	
	Запрос.Текст 	= Текст;
	Результат 		= Запрос.Выполнить();
	Выгрузка		= Результат.Выгрузить();
	Объект.Абоненты.Загрузить(Выгрузка);	
КонецПроцедуры

&НаКлиенте
Процедура АбонентыПередУдалением(Элемент, Отказ)
	Отказ 			= Истина;
	ДопПараметры	= Новый Структура;
	ДопПараметры.Вставить("ТекущийОбъект", 	Объект.Ссылка);
	ДопПараметры.Вставить("ТЧ", 			"Абоненты");
	ДопПараметры.Вставить("НомерСтроки", 	Элемент.ТекущиеДанные.НомерСтроки-1);
	ПроверкаУдаленияСтроки(ДопПараметры);
КонецПроцедуры             

&НаКлиенте
Процедура ПроверкаУдаленияСтроки(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросУдаленияСтроки",ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Удалить всю строку вместо значения ячейки?",РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросУдаленияСтроки(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			УдалитьСтроку(ДополнительныеПараметры);			
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура УдалитьСтроку(ДополнительныеПараметры)
	Объект[ДополнительныеПараметры.ТЧ].Удалить(ДополнительныеПараметры.НомерСтроки);	
КонецПроцедуры

&НаСервере
Процедура РайонПриИзмененииНаСервере()
	Объект.Организация = Объект.Район.Организация;
КонецПроцедуры

&НаКлиенте
Процедура АбонентыАбонентНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	// ОТЭК, 21.05.2020, 000202897.
	энргПользовательскийВводКлиент.НачалоВыбораАбонента(Элемент, Объект.Организация, Объект.Район,,
															СтандартнаяОбработка, Новый Структура("Строение", Объект.МКД));
КонецПроцедуры
