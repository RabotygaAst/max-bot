
#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
 
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	бестЛокализацияСервер.ПриСозданииНаСервере_бестКорректировкаЗадолженности(ЭтотОбъект);
КонецПроцедуры   

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовШапки

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	ЗаполнитьПериодНачисленияСервер();
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	ЗаполнитьПериодНачисленияСервер();
КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	ЗаполнитьПериодНачисленияСервер();
КонецПроцедуры

#КонецОбласти
#Область ОбработчикиКомандФормы

// ВводНаОсновании
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуСоздатьНаОсновании(Команда)
	
	ВводНаОснованииКлиент.ВыполнитьПодключаемуюКомандуСоздатьНаОсновании(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры
// Конец ВводНаОсновании

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат)
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец ВводНаОсновании

// МенюОтчеты
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуОтчет(Команда)
	
	МенюОтчетыКлиент.ВыполнитьПодключаемуюКомандуОтчет(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

&НаКлиенте
Процедура ПодобратьДокументОплаты(Команда)
	СписокТипов = Новый СписокЗначений;
	СписокТипов.Добавить(Тип("ДокументСсылка.бестПлатежноеПоручениеВходящееЭЭЮрЛица"));
	СписокТипов.Добавить(Тип("ДокументСсылка.бестКорректировкаЗадолженности"));
	
	Оповещение = Новый ОписаниеОповещения("ОбработкаВыбораТипаДанных", ЭтотОбъект);
	
	
	СписокТипов.ПоказатьВыборЭлемента(Оповещение, "Выбор типа данных");
КонецПроцедуры

#КонецОбласти

#Область СобытияТЧ_ВозвратОплаты

&НаКлиенте
Процедура ВозвратОплатыСуммаВозвратаПриИзменении(Элемент)
	ТекДанные = Элементы.ВозвратОплаты.ТекущиеДанные;
	
	ТекДанные.СуммаВозвратаНДС = ПолучитьСуммуНДС(Объект.Дата, Объект.Организация,  ТекДанные.СуммаВозврата);
КонецПроцедуры

&НаКлиенте
Процедура ВозвратОплатыДокументОплатыОткрытие(Элемент, СтандартнаяОбработка)
	ТекДанные = Элементы.ВозвратОплаты.ТекущиеДанные;

	Если ТипЗнч(ТекДанные.ДокументОплаты) = Тип("ДокументСсылка.бестПлатежноеПоручениеВходящееЭЭЮрЛица") Тогда
		СтандартнаяОбработка = Ложь;
		ОткрытьФорму("Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица.ФормаОбъекта",Новый Структура("IDСтрокиОплаты,Ключ",ТекДанные.IDСтроки, ТекДанные.ДокументОплаты));
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьПериодНачисленияСервер()
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Объект.ПериодНачисления = Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораТипаДанных(ВыбранныйЭлемент, СписокПараметров) Экспорт
	
	Если ВыбранныйЭлемент <> Неопределено Тогда
		
		ФормаВыбора = "";
		
		Если ВыбранныйЭлемент.Значение = Тип("ДокументСсылка.бестПлатежноеПоручениеВходящееЭЭЮрЛица") Тогда
			ФормаВыбора 			= "Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица.ФормаВыбора";
			ОтборСсылки = Новый Структура("Ссылка",ПолучитьМассивДоступныхПоручений(Объект.Договор));
			Отбор 		= Новый Структура("Отбор",ОтборСсылки);
		ИначеЕсли ВыбранныйЭлемент.Значение = Тип("ДокументСсылка.бестКорректировкаЗадолженности") Тогда
			ФормаВыбора 			= "Документ.бестКорректировкаЗадолженности.ФормаВыбора";
			ОтборДоговор 	= Новый Структура("Договор",Объект.Договор);
			Отбор 			= Новый Структура("Отбор",ОтборДоговор);
		КонецЕсли;
		
		Оповещение = Новый ОписаниеОповещения("ОписаниеЗакрытияФормыВыбора", ЭтотОбъект);
		
		ОткрытьФорму(ФормаВыбора,Отбор , ЭтаФорма, , , , Оповещение);
				
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьМассивДоступныхПоручений(Договор)
	Возврат Документы.бестПлатежноеПоручениеВходящееЭЭЮрЛица.ПолучитьСписокПорученийСОтборомПоДоговору(Договор);
КонецФункции

&НаКлиенте
Процедура ОписаниеЗакрытияФормыВыбора(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия <> Неопределено Тогда
		ЗаполнитьСтрокиОплаты(РезультатЗакрытия);
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтрокиОплаты(ВыбранныйДокумент)
	Документы.бестКорректировкаЗадолженности.ЗаполнитьСтрокиОплаты(ВыбранныйДокумент, Объект.Договор, Объект.ВозвратОплаты);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСуммуНДС(Дата, Организация, СуммаВозврата)
	Возврат  РегистрыСведений.бестСтавкиНДС.ПолучитьСуммуНДС(Дата, Организация, СуммаВозврата);
КонецФункции

#КонецОбласти
