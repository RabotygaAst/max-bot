#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	Ответственный = Пользователи.ТекущийПользователь();
	энргДатаПоследнегоИзменения	= ТекущаяДата();

	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	бестПроведениеСерверНП.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);  	
	
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,НачалоМесяца(От),Ложь);
	
	НачалоПериодаРасчета							= ГраницыПериода.НачалоОП;
	
	ГраницыПериода  								= Обработки.бестГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,До,Ложь);
	
	КонецПериодаРасчета  							= ГраницыПериода.ЗавершениеОП;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестВзаиморасчетыПоПениОбороты.СуммаПриход - бестВзаиморасчетыПоПениОбороты.СуммаРасход КАК Сумма,
		|	бестВзаиморасчетыПоПениОбороты.Договор КАК Договор,
		|	бестВзаиморасчетыПоПениОбороты.Район КАК Район,
		|	бестВзаиморасчетыПоПениОбороты.Организация КАК Организация
		|ИЗ
		|	РегистрНакопления.бестВзаиморасчетыПоПени.Обороты(
		|			&От,
		|			&До,
		|			,
		|			Договор = &Договор
		|				И Район = &Район
		|				И Организация = &Организация) КАК бестВзаиморасчетыПоПениОбороты";
	
	Запрос.УстановитьПараметр("До", КонецПериодаРасчета);
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("От", НачалоПериодаРасчета);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Запись  						= Движения.бестВзаиморасчетыПоПени.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, ВыборкаДетальныеЗаписи);
		Запись.Период					= Дата;
		Запись.ВидДвижения				= ВидДвиженияНакопления.Расход;
		Запись.ВидОперации				= Перечисления.энргВидыОперацийНачисления.СудебноеРешение;
	КонецЦикла;

	Если НЕ ДоначислятьПени Тогда
		бестРаботаСПараметрамиРасчетаКонтрагентовСервер.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеОстановки(),		Движения.бестОстановленныеРасчетыПени);
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестКорректировкаПениПоСудебномуРешению.Дата КАК Период,
		|	бестКорректировкаПениПоСудебномуРешению.Организация КАК Организация,
		|	бестКорректировкаПениПоСудебномуРешению.Район КАК Район,
		|	бестКорректировкаПениПоСудебномуРешению.Договор КАК Договор,
		|	бестКорректировкаПениПоСудебномуРешению.Сумма КАК Сумма,
		|	бестКорректировкаПениПоСудебномуРешению.УчитыватьВБУ КАК УчитыватьВБУ
		|ИЗ
		|	Документ.бестКорректировкаПениПоСудебномуРешению КАК бестКорректировкаПениПоСудебномуРешению
		|ГДЕ
		|	бестКорректировкаПениПоСудебномуРешению.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Запись  						= Движения.бестВзаиморасчетыПоПени.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, ВыборкаДетальныеЗаписи);
		Запись.ВидДвижения				= ВидДвиженияНакопления.Приход;
		Запись.ВидОперации				= Перечисления.энргВидыОперацийНачисления.СудебноеРешение;
	КонецЦикла;

	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДанныеОстановки()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестКорректировкаПениПоСудебномуРешению.Договор КАК Договор,
	|	бестКорректировкаПениПоСудебномуРешению.Организация КАК Организация,
	|	бестКорректировкаПениПоСудебномуРешению.От КАК От,
	|	бестКорректировкаПениПоСудебномуРешению.До КАК До,
	|	бестКорректировкаПениПоСудебномуРешению.Район КАК Район
	|ИЗ
	|	Документ.бестКорректировкаПениПоСудебномуРешению КАК бестКорректировкаПениПоСудебномуРешению
	|ГДЕ
	|	бестКорректировкаПениПоСудебномуРешению.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить();
	
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли