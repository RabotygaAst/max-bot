#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область СлужебныеПроцедурыИФункции
	
#Область РеализацияИнтерфейса_Проведение
	
Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
		
		ПараметрыЗапроса  	= Новый Структура;
		Схема 				= Неопределено;
		
		ДобавитьТекстЗапросаОтветственныйПИР(Схема,Регистры);
		
		Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
			ВспомогательныеПараметры 	= Новый Структура;
			энргФормированиеТекстовЗапроса.УстановитьПерехватОбращенияКТаблицам(Схема, ДополнительныеСвойства.ТаблицыПодмены, ВспомогательныеПараметры); 
		КонецЕсли;
		
		КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
		
		ПараметрыЗапроса 				= Новый Структура;
		ПараметрыЗапроса.Вставить("мДокументы",	ДокументСсылка);
		
		ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		энргСхемаЗапросаСервер.ВыполнитьПакет(Схема,ПараметрыЗапроса));
		ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
		
	КонецПроцедуры
	
Процедура ДобавитьТекстЗапросаОтветственныйПИР(Схема, Регистры)
		
		ИмяРегистра = "бестОтветственныйПИР";
		
		Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
			Возврат;
		КонецЕсли;
		
		Если Схема = Неопределено Тогда
			Схема 	= Новый СхемаЗапроса;
			Пакет 	= Схема.ПакетЗапросов[0];
		Иначе
			Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
		КонецЕсли;
		
		Текст  		= 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	бестНазначениеОтветственногоПИР.Дата КАК Период,
		|	бестНазначениеОтветственногоПИР.Организация КАК Организация,
		|	бестНазначениеОтветственногоПИР.Район КАК Район,
		|	бестНазначениеОтветственногоПИРСписокСтроений.КлючПомещения КАК КлючПомещения,
		|	бестНазначениеОтветственногоПИР.ОтветственныйПИР КАК Ответственный
		|ИЗ
		|	Документ.бестНазначениеОтветственногоПИР КАК бестНазначениеОтветственногоПИР
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестНазначениеОтветственногоПИР.СписокСтроений КАК бестНазначениеОтветственногоПИРСписокСтроений
		|		ПО бестНазначениеОтветственногоПИР.Ссылка = бестНазначениеОтветственногоПИРСписокСтроений.Ссылка
		|			И (бестНазначениеОтветственногоПИР.Ссылка В (&мДокументы))
		|			И (бестНазначениеОтветственногоПИРСписокСтроений.Ссылка В (&мДокументы))";	
		
		Пакет.УстановитьТекстЗапроса(Текст);
		Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
		
	КонецПроцедуры
	
#КонецОбласти
	
#Область ЗаполнениеДанных

Процедура ЗаполнитьТаблицуДанными(СписокСтроений, Отборы) Экспорт 
	ДанныеДляЗаполнения = ПолучитьДанныеДляЗаполнения(Отборы);
	ДополнитьНовымиДанными(ДанныеДляЗаполнения, СписокСтроений, Отборы);
КонецПроцедуры

Процедура ДополнитьНовымиДанными(ДанныеДляЗаполнения, СписокСтроений, Отборы)
	ФильтрПоАдресу 				= ПолучитьФильтрПоАдресу(Отборы);
	ЕстьОтборПоАдресу 			= НЕ ФильтрПоАдресу.Количество() = 0;
	ЕстьЧисловыеДанныеАдреса 	= ПолучитьФильтрПоАдресу(Отборы);
	
	Выборка = ДанныеДляЗаполнения.Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если ЕстьОтборПоАдресу И ПолучитьПризнакПропускаСтроки(Выборка, ФильтрПоАдресу) Тогда 
			Продолжить;			
		КонецЕсли;
		
		НСтрока = СписокСтроений.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, Выборка);
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьПризнакПропускаСтроки(Выборка, ФильтрПоАдресу)
	ПропускатьСтроку		= Истина;
	АдресСтруктурой	 		= УправлениеКонтактнойИнформациейСлужебный.СтрокуJSONВСтруктуру(Выборка.АдресСтроенияJSON);
	Если АдресСтруктурой.Количество() = 0 Тогда 
		Возврат ПропускатьСтроку;
	КонецЕсли;	
	
	ЭтоАдресВСвободнойФорме	= УправлениеКонтактнойИнформациейКлиентСервер.ЭтоАдресВСвободнойФорме(АдресСтруктурой.addressType);	
	Улица 					= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ФильтрПоАдресу, "Улица", Неопределено);
	ЕстьОтборПоУлице		= Ложь;
	Если НЕ Улица = Неопределено Тогда
		ЕстьОтборПоУлице	= Истина;
		
		Если ЭтоАдресВСвободнойФорме Тогда
			ПропускатьСтроку = СтрНайти(НРег(Выборка.АдресСтроенияJSON), НРег(Улица)) = 0;
		Иначе
			ПропускатьСтроку = СтрНайти(НРег(АдресСтруктурой.Street), НРег(Улица)) = 0;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтоАдресВСвободнойФорме ИЛИ (ЕстьОтборПоУлице И ПропускатьСтроку) Тогда
		// Нет необходимости проверять числовые значения у строки адреса
		Возврат ПропускатьСтроку;
	КонецЕсли;
	
	
	// Проверяем числовые значения по полученной структуре адреса
	НомерДома				= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ФильтрПоАдресу, "НомерДома", Неопределено);
	Если НЕ НомерДома = Неопределено Тогда
		ПропускатьСтроку = НЕ Строка(НомерДома) = АдресСтруктурой.houseNumber;	
		Если ПропускатьСтроку Тогда 
			Возврат ПропускатьСтроку;
		КонецЕсли;		
	КонецЕсли;
	
	НомерКвОт				= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ФильтрПоАдресу, "НомерКвОт", Неопределено);
	НомерКвДо				= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ФильтрПоАдресу, "НомерКвДо", Неопределено);
	Если НЕ НомерКвОт = Неопределено И НЕ НомерКвДо = Неопределено Тогда
		apartments = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(АдресСтруктурой, "apartments", Новый Массив);
		Если apartments.Количество() = 0 Тогда
			Возврат Истина;
		КонецЕсли;
		НомерКвартиры 		= Число(apartments[0].number);
		ПропускатьСтроку 	= НЕ (НомерКвартиры >= НомерКвОт И НомерКвартиры <= НомерКвДо);
	КонецЕсли;
	
	Возврат ПропускатьСтроку;
КонецФункции

#КонецОбласти

#Область ПолучениеДанныхДляЗаполнения

Функция ПолучитьДанныеДляЗаполнения(Отборы)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	энргАбонентыПомещенийСрезПоследних.Организация КАК Организация,
	|	энргАбонентыПомещенийСрезПоследних.Район КАК Район,
	|	энргАбонентыПомещенийСрезПоследних.КлючПомещения КАК КлючПомещения,
	|	энргАбонентыПомещенийСрезПоследних.Абонент КАК Абонент
	|ПОМЕСТИТЬ АбонентыПомещения
	|ИЗ
	|	РегистрСведений.энргАбонентыПомещений.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район) КАК энргАбонентыПомещенийСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АбонентыПомещения.Организация КАК Организация,
	|	АбонентыПомещения.Район КАК Район,
	|	АбонентыПомещения.КлючПомещения КАК КлючПомещения,
	|	АбонентыПомещения.Абонент КАК Абонент,
	|	энргКлючиПомещений.Строение КАК Строение,
	|	энргКлючиПомещений.Помещение КАК Помещение,
	|	энргКлючиПомещений.ЧастныйСектор КАК ЧастныйСектор
	|ПОМЕСТИТЬ АбонентыПомещенийИДанныеСтроения
	|ИЗ
	|	АбонентыПомещения КАК АбонентыПомещения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО АбонентыПомещения.КлючПомещения = энргКлючиПомещений.Ссылка
	|			И (энргКлючиПомещений.Строение = &Строение)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеЛССрезПоследних.Организация КАК Организация,
	|	энргСостояниеЛССрезПоследних.Район КАК Район,
	|	энргСостояниеЛССрезПоследних.Абонент КАК Абонент
	|ПОМЕСТИТЬ АктивныеАбоненты
	|ИЗ
	|	РегистрСведений.энргСостояниеЛС.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (Организация, Район, Абонент) В
	|					(ВЫБРАТЬ
	|						АбонентыПомещенийИДанныеСтроения.Организация КАК Организация,
	|						АбонентыПомещенийИДанныеСтроения.Район КАК Район,
	|						АбонентыПомещенийИДанныеСтроения.Абонент КАК Абонент
	|					ИЗ
	|						АбонентыПомещенийИДанныеСтроения КАК АбонентыПомещенийИДанныеСтроения)) КАК энргСостояниеЛССрезПоследних
	|ГДЕ
	|	энргСостояниеЛССрезПоследних.Состояние
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АбонентыПомещенийИДанныеСтроения.Организация КАК Организация,
	|	АбонентыПомещенийИДанныеСтроения.Район КАК Район,
	|	АбонентыПомещенийИДанныеСтроения.КлючПомещения КАК КлючПомещения,
	|	АбонентыПомещенийИДанныеСтроения.Абонент КАК Абонент,
	|	АбонентыПомещенийИДанныеСтроения.Строение КАК Строение,
	|	АбонентыПомещенийИДанныеСтроения.Помещение КАК Помещение,
	|	АбонентыПомещенийИДанныеСтроения.ЧастныйСектор КАК ЧастныйСектор
	|ПОМЕСТИТЬ АктуальныеАбоненты
	|ИЗ
	|	АбонентыПомещенийИДанныеСтроения КАК АбонентыПомещенийИДанныеСтроения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АктивныеАбоненты КАК АктивныеАбоненты
	|		ПО АбонентыПомещенийИДанныеСтроения.Организация = АктивныеАбоненты.Организация
	|			И АбонентыПомещенийИДанныеСтроения.Район = АктивныеАбоненты.Район
	|			И АбонентыПомещенийИДанныеСтроения.Абонент = АктивныеАбоненты.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестОтветственныйПИРСрезПоследних.Организация КАК Организация,
	|	бестОтветственныйПИРСрезПоследних.Район КАК Район,
	|	бестОтветственныйПИРСрезПоследних.КлючПомещения КАК КлючПомещения,
	|	бестОтветственныйПИРСрезПоследних.Ответственный КАК Ответственный
	|ПОМЕСТИТЬ ОтветственныйПИР
	|ИЗ
	|	РегистрСведений.бестОтветственныйПИР.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (Организация, Район, КлючПомещения) В
	|					(ВЫБРАТЬ
	|						АктуальныеАбоненты.Организация КАК Организация,
	|						АктуальныеАбоненты.Район КАК Район,
	|						АктуальныеАбоненты.КлючПомещения КАК КлючПомещения
	|					ИЗ
	|						АктуальныеАбоненты КАК АктуальныеАбоненты)
	|				И НЕ Ответственный = &ОтветственныйКУстановке
	|				И Ответственный = &ТекущийОтветственный) КАК бестОтветственныйПИРСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктуальныеАбоненты.Организация КАК Организация,
	|	АктуальныеАбоненты.Район КАК Район,
	|	АктуальныеАбоненты.КлючПомещения КАК КлючПомещения,
	|	АктуальныеАбоненты.Абонент КАК Абонент,
	|	ОтветственныйПИР.Ответственный КАК Ответственный,
	|	АктуальныеАбоненты.Строение КАК Строение,
	|	АктуальныеАбоненты.Помещение КАК Помещение,
	|	АктуальныеАбоненты.ЧастныйСектор КАК ЧастныйСектор
	|ПОМЕСТИТЬ АктуальныеОтветственные
	|ИЗ
	|	АктуальныеАбоненты КАК АктуальныеАбоненты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОтветственныйПИР КАК ОтветственныйПИР
	|		ПО АктуальныеАбоненты.Организация = ОтветственныйПИР.Организация
	|			И АктуальныеАбоненты.Район = ОтветственныйПИР.Район
	|			И АктуальныеАбоненты.КлючПомещения = ОтветственныйПИР.КлючПомещения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргАбонентыКонтактнаяИнформация.Ссылка КАК Ссылка,
	|	энргАбонентыКонтактнаяИнформация.Значение КАК Значение
	|ПОМЕСТИТЬ АдресАбонентов
	|ИЗ
	|	Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
	|ГДЕ
	|	энргАбонентыКонтактнаяИнформация.Ссылка В
	|			(ВЫБРАТЬ
	|				АктуальныеОтветственные.Абонент КАК Абонент
	|			ИЗ
	|				АктуальныеОтветственные КАК АктуальныеОтветственные)
	|	И энргАбонентыКонтактнаяИнформация.Тип = &ТипАдреса
	|	И энргАбонентыКонтактнаяИнформация.Вид = &ВидАдреса
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктуальныеОтветственные.Организация КАК Организация,
	|	АктуальныеОтветственные.Район КАК Район,
	|	АктуальныеОтветственные.КлючПомещения КАК КлючПомещения,
	|	АктуальныеОтветственные.Абонент КАК Абонент,
	|	АктуальныеОтветственные.Ответственный КАК Ответственный,
	|	АктуальныеОтветственные.Строение КАК Строение,
	|	АктуальныеОтветственные.Помещение КАК Помещение,
	|	АктуальныеОтветственные.ЧастныйСектор КАК ЧастныйСектор,
	|	ЕСТЬNULL(АдресАбонентов.Значение, """") КАК АдресСтроенияJSON
	|ИЗ
	|	АктуальныеОтветственные КАК АктуальныеОтветственные
	|		ЛЕВОЕ СОЕДИНЕНИЕ АдресАбонентов КАК АдресАбонентов
	|		ПО АктуальныеОтветственные.Абонент = АдресАбонентов.Ссылка";
	
	УстановитьПараметрыЗапроса(Запрос, Отборы);	
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса;	
КонецФункции

Процедура УстановитьПараметрыЗапроса(Запрос, Отборы)
	Запрос.УстановитьПараметр("Период"					, Отборы.Период);
	Запрос.УстановитьПараметр("Организация"				, Отборы.Организация);	
	Запрос.УстановитьПараметр("Район"					, Отборы.Район);
	Запрос.УстановитьПараметр("ОтветственныйКУстановке"	, Отборы.ОтветственныйКУстановке);
	Запрос.УстановитьПараметр("ТипАдреса"				, Перечисления.ТипыКонтактнойИнформации.Адрес);
	Запрос.УстановитьПараметр("ВидАдреса"				, Справочники.ВидыКонтактнойИнформации.АдресОбъекта);
	
	НеобязательныеОтборы = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Отборы, "НеобязательныеОтборы", Неопределено);
	Если НеобязательныеОтборы = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И (энргКлючиПомещений.Строение = &Строение)", "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Ответственный = &ТекущийОтветственный", "");
		
		Возврат;
	КонецЕсли;
	
	ОтборСтроение = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(НеобязательныеОтборы, "Строение", Справочники.энргСтроения.ПустаяСсылка());
	Запрос.УстановитьПараметр("Строение", ОтборСтроение);
	Если НЕ ЗначениеЗаполнено(ОтборСтроение) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И (энргКлючиПомещений.Строение = &Строение)", "");
	КонецЕсли;
	
	ТекущийОтветственный = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(НеобязательныеОтборы, "ТекущийОтветственный", Справочники.Пользователи.ПустаяСсылка());
	Запрос.УстановитьПараметр("ТекущийОтветственный", ТекущийОтветственный);
	Если НЕ ЗначениеЗаполнено(ТекущийОтветственный) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Ответственный = &ТекущийОтветственный", "");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

