&НаКлиентеНаСервереБезКонтекста
Функция УстановитьПараметрыВыбораДоговора(Форма, Элемент, ЭлементДоговор, ЗначениеКонтрагент)

	массивПараметрыВыбора = Новый Массив;
	Если ЗначениеЗаполнено(ЗначениеКонтрагент) Тогда
		массивПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.Контрагент", ЗначениеКонтрагент));
	КонецЕсли;
	ЭлементДоговор.ПараметрыВыбора = Новый ФиксированныйМассив(массивПараметрыВыбора);

КонецФункции //-- gradum 000213955 svb 2020.07.09

// ++ gradum 000213955 2020.07.09
&НаКлиентеНаСервереБезКонтекста
Функция ДоговорПриИзмененииНаКлиентеНаСервере(Форма, Элемент = Неопределено)

	Если ЗначениеЗаполнено(Форма.Объект.Договор) Тогда
		реквДоговор = Форма.Объект.Договор;
		массивОбъектовРасчета = ПолучитьАктивныеОбъектыРасчетаНаСервере(
			?(ЗначениеЗаполнено(Форма.Объект.ДатаФактическогоСобытия), Форма.Объект.ДатаФактическогоСобытия, 
				?(ЗначениеЗаполнено(Форма.Объект.Дата), Форма.Объект.Дата, ТекущаяДата()))
			, реквДоговор.Организация, реквДоговор.Район, Форма.Объект.Договор
		);
		Форма.ПредКонтрагент = реквДоговор.Контрагент;
	Иначе
		реквДоговор = Новый Структура("Контрагент, Организация, Район"
			, Неопределено, Неопределено, Неопределено
		);
		массивОбъектовРасчета = Новый Массив; массивОбъектовРасчета.Добавить(Неопределено);
	КонецЕсли;
	
	массПараметрыВыбора = Новый Массив;
	массПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", массивОбъектовРасчета));
	Форма.Элементы.ОбъектыРасчетаОбъектРасчета.ПараметрыВыбора = Новый ФиксированныйМассив(массПараметрыВыбора);
	
	Если Неопределено = Элемент Тогда
		// Например, ПриЧтенииНаСервере
	Иначе
		// Интерактивно, перезаплняем Объекты расчета
		Форма.Объект.ОбъектыРасчета.Очистить();
		Для Каждого эл Из массивОбъектовРасчета Цикл
			Форма.Объект.ОбъектыРасчета.Добавить().ОбъектРасчета = эл;
		КонецЦикла;
		
	КонецЕсли;
	
	массПараметрыВыбора = Новый Массив;
	Если ЗначениеЗаполнено(Форма.ПредКонтрагент) Тогда
		массПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.Контрагент", Форма.ПредКонтрагент));
	КонецЕсли;
	Форма.Элементы.Договор.ПараметрыВыбора = Новый ФиксированныйМассив(массПараметрыВыбора);
	
КонецФункции //-- gradum 000213955 svb 2020.07.09

