&НаКлиенте
Процедура ОбъектыРасчетаПередУдалением(Элемент, Отказ)
	Отказ 			= Истина;
	ДопПараметры	= Новый Структура;
	ДопПараметры.Вставить("ТекущийОбъект", 	Объект.Ссылка);
	ДопПараметры.Вставить("ТЧ", 			"ОбъектыРасчета");
	ДопПараметры.Вставить("НомерСтроки", 	Элемент.ТекущиеДанные.НомерСтроки-1);
	ПроверкаУдаленияСтроки(ДопПараметры);
КонецПроцедуры             

&НаКлиенте
Процедура ПроверкаУдаленияСтроки(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросУдаленияСтроки",ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Удалить всю строку вместо значения ячейки?",РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросУдаленияСтроки(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			УдалитьСтроку(ДополнительныеПараметры);			
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура УдалитьСтроку(ДополнительныеПараметры)
	Объект[ДополнительныеПараметры.ТЧ].Удалить(ДополнительныеПараметры.НомерСтроки);	
КонецПроцедуры

// ++ gradum 000213955 2020.07.09
&НаСервереБезКонтекста
Функция ПолучитьАктивныеОбъектыРасчетаНаСервере(Период, Организация, Район, Договор)
	индексОбъектРасчета = Новый Соответствие;
	индексОбъектРасчета.Вставить(ПредопределенноеЗначение("Справочник.бестОбъектыРасчета.ПустаяСсылка"), Истина);
	РезультатФункции = Новый Массив;
	МВТ = Новый МенеджерВременныхТаблиц;
	РегистрыСведений.бестВладельцыОбъектовРасчета.ПолучитьВладельцевОбъектовРасчета(МВТ, Период, Организация, Район,,Договор,"ВладельцыОбъектовРасчета");
	РезультатЗапроса	= РегистрыСведений.бестАктивностьОбъектовРасчета.ПолучитьАктивныеОбъектыРасчета(МВТ, Период, Организация, Район,Истина);
	Выборка 			= РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если индексОбъектРасчета.Получить(Выборка.ОбъектРасчета) = Истина Тогда
			Продолжить;
		КонецЕсли;
		РезультатФункции.Добавить(Выборка.ОбъектРасчета);
	КонецЦикла;
	
	Возврат РезультатФункции;
	
КонецФункции	//-- gradum 000213955 2020.07.09

