#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
			
	Если Параметры.Ключ.Пустая() Тогда
		Объект.Дата = ТекущаяДата();
		//Объект.ДатаФактическогоСобытия = Объект.Дата;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			ЗаполнитьПериодНачисленияСервер();
		КонецЕсли;
	КонецЕсли;
 	
	Если ЗначениеЗаполнено(Объект.Договор) и Не ЗначениеЗаполнено(Контрагент) Тогда
		Контрагент = Объект.Договор.Контрагент;
	КонецЕсли;	
	
	// ++ Акимов Д.В.
	// Настройка доступности в зависимости от прав
	энргОбщегоНазначения.УстановитьДоступностьЭлементовПоРолям(ЭтаФорма, Новый Структура("Контрагент"), Метаданные.Документы.бестОперацияСОбъектамиНП);
	// -- Акимов Д.В.	
		
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПериодНачисленияСервер()
	Объект.ПериодНачисления = Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)  	
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	// ++ gradum 000213955 2020.07.09
	ДоговорПриИзмененииНаКлиентеНаСервере(ЭтаФорма, Неопределено);
	// -- gradum 000213955 svb 2020.07.09
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	// ++ gradum 000213955 2020.07.09
	индексОбъекта = Новый Соответствие;
	// Пустые - удаляем, ПОВТОРЫ - так же, оставляя первое упоминание
	индексОбъекта.Вставить(ПредопределенноеЗначение("Справочник.бестОбъектыРасчета.ПустаяСсылка"), Истина);
	ИндексСтроки = 0; былиКорректировки = Ложь;
	Пока ИндексСтроки<Объект.ОбъектыРасчета.Количество() Цикл
		строкаТЧ = Объект.ОбъектыРасчета.Получить(ИндексСтроки);
		Если индексОбъекта.Получить(строкаТЧ.ОбъектРасчета) = Истина Тогда
			Объект.ОбъектыРасчета.Удалить(ИндексСтроки);
			былиКорректировки = Истина;
		Иначе
			индексОбъекта.Вставить(строкаТЧ.ОбъектРасчета, Истина);
			ИндексСтроки = ИндексСтроки + 1;
		КонецЕсли;
	КонецЦикла;
	Если былиКорректировки Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Были удалены повторы Объектов расчета");
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

