&НаКлиентеНаСервереБезКонтекста
//&НаСервере
Функция ДоговорПриИзмененииНаКлиентеНаСервере(Форма, Элемент = Неопределено)

	Если ЗначениеЗаполнено(Форма.Объект.Договор) Тогда
		реквДоговор = Форма.Объект.Договор;
		массивОбъектовРасчета = ПолучитьАктивныеОбъектыРасчетаНаСервере(
			?(ЗначениеЗаполнено(Форма.Объект.ДатаФактическогоСобытия), Форма.Объект.ДатаФактическогоСобытия, 
				?(ЗначениеЗаполнено(Форма.Объект.Дата), Форма.Объект.Дата, ТекущаяДата()))
			, реквДоговор.Организация, реквДоговор.Район, Форма.Объект.Договор
		);
	Иначе
		реквДоговор = Новый Структура("Контрагент, Организация, Район"
			, Неопределено, Неопределено, Неопределено
		);
		массивОбъектовРасчета = Новый Массив; массивОбъектовРасчета.Добавить(Неопределено);
	КонецЕсли;
	
	Форма.Контрагент = реквДоговор.Контрагент;
	
	массПараметрыВыбора = Новый Массив;
	массПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", массивОбъектовРасчета));
	Форма.Элементы.ТочкиУчетаОбъектРасчета.ПараметрыВыбора = Новый ФиксированныйМассив(массПараметрыВыбора);
	
	Если Неопределено = Элемент Тогда
		// Например, ПриЧтенииНаСервере
	Иначе
		// Интерактивно, перезаплняем Объекты расчета
		
		Форма.Объект.Организация = реквДоговор.Организация;
		Форма.Объект.Район = реквДоговор.Район;
		
		Форма.Объект.ОбъектыРасчета.Очистить();
		Для Каждого эл Из массивОбъектовРасчета Цикл
			Форма.Объект.ОбъектыРасчета.Добавить().ОбъектРасчета = эл;
		КонецЦикла;
		
	КонецЕсли;
	
	массПараметрыВыбора = Новый Массив;
	Если ЗначениеЗаполнено(Форма.Контрагент) Тогда
		массПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.Контрагент", Форма.Контрагент));
	КонецЕсли;
	Форма.Элементы.Договор.ПараметрыВыбора = Новый ФиксированныйМассив(массПараметрыВыбора);
	
КонецФункции // УстановитьПараметрыВыбораОбъектаРасчета()	//-- gradum 000213955 svb 2020.07.09

// ++ gradum 000213955 2020.07.09
&НаСервереБезКонтекста
Функция ПолучитьАктивныеОбъектыРасчетаНаСервере(Период, Организация, Район, Договор)
	индексОбъектРасчета = Новый Соответствие;
	индексОбъектРасчета.Вставить(ПредопределенноеЗначение("Справочник.бестОбъектыРасчета.ПустаяСсылка"), Истина);
	РезультатФункции = Новый Массив;
	МВТ = новый МенеджерВременныхТаблиц;
	РегистрыСведений.бестВладельцыОбъектовРасчета.ПолучитьВладельцевОбъектовРасчета(МВТ, Период, Организация, Район,,Договор,"ВладельцыОбъектовРасчета");
	РезультатЗапроса	= РегистрыСведений.бестАктивностьОбъектовРасчета.ПолучитьАктивныеОбъектыРасчета(МВТ, Период, Организация, Район,Истина);
	Выборка 			= РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если индексОбъектРасчета.Получить(Выборка.ОбъектРасчета) = Истина Тогда
			Продолжить;
		КонецЕсли;
		РезультатФункции.Добавить(Выборка.ОбъектРасчета);
	КонецЦикла;
	
	Возврат РезультатФункции;
	
КонецФункции	//-- gradum 000213955 2020.07.09

