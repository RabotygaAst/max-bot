Функция МассивПриборов() Экспорт 
	
	Запрос  			= Новый Запрос;
	Запрос.УстановитьПараметр("ссылка",				Ссылка);
	Запрос.УстановитьПараметр("ОбъектРасчета",		ОбъектРасчета);
	Запрос.УстановитьПараметр("МКД",				ОбъектРасчета.МКД);
	Запрос.УстановитьПараметр("ВыводПрибораУчета",	ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВыводПУ);
	
	Если ВидОперации <> Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ЗаменаПУ тогда 		
		Текст  			= 
		"ВЫБРАТЬ
		|	&ОбъектРасчета КАК ОбъектРасчета,
		|	&МКД КАК МКД,
		|	ТаблицаПриборовУчета.ПриборУчета КАК ПриборУчета,
		|	&ВыводПрибораУчета КАК ВыводПрибораУчета,
		|	""ПоказанияПриборовУчета"" КАК ИмяТабЧасти,
		|	0 КАК Разделитель
		|ИЗ
		|	Документ.бестОперацияСПриборомУчетаНП.ТочкиУчета КАК ТаблицаПриборовУчета
		|ГДЕ
		|	ТаблицаПриборовУчета.Ссылка = &Ссылка";
	иначе
		Текст  			= 
		
		"ВЫБРАТЬ
		|	&ОбъектРасчета КАК ОбъектРасчета,
		|	&МКД КАК МКД,
		|	ТаблицаПриборовУчета.ПриборУчетаВывод КАК ПриборУчета,
		|	ИСТИНА КАК ВыводПрибораУчета,
		|	""ПоказанияПриборовУчета"" КАК ИмяТабЧасти,
		|	0 КАК Разделитель
		|ИЗ
		|	Документ.бестОперацияСПриборомУчетаНП.ТочкиУчета КАК ТаблицаПриборовУчета
		|ГДЕ
		|	ТаблицаПриборовУчета.Ссылка = &Ссылка
		|	И ТаблицаПриборовУчета.ПриборУчета <> ТаблицаПриборовУчета.ПриборУчетаВывод
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	&ОбъектРасчета,
		|	&МКД,
		|	ТаблицаПриборовУчета.ПриборУчета,
		|	ЛОЖЬ,
		|	""ПоказанияПриборовУчета"",
		|	0
		|ИЗ
		|	Документ.бестОперацияСПриборомУчетаНП.ТочкиУчета КАК ТаблицаПриборовУчета
		|ГДЕ
		|	ТаблицаПриборовУчета.Ссылка = &Ссылка
		|	И ТаблицаПриборовУчета.ПриборУчета <> ТаблицаПриборовУчета.ПриборУчетаВывод";

	КонецЕсли;
	
	Запрос.Текст 	= Текст;
	
	ДополнительныеСвойства.Вставить("МассивПриборов",Запрос.Выполнить());	
	
КонецФункции

Функция СоставУзлаКорректен()
	
	Данные = Новый Структура;
	Данные.Вставить("Период",					Новый Граница(МоментВремени(),ВидГраницы.Исключая));
	Данные.Вставить("Район",					Район);
	Данные.Вставить("Организация",			    Организация);		 
	Данные.Вставить("Ссылка",					Ссылка);
	
	Возврат энргРаботаСприборамиУчетаСервер.СоставУзлаКорректенНП(Данные);
	 	
КонецФункции

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВводПУ тогда
		
		Для Каждого СтрокаТЧ из ТочкиУчета цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ТипУзлаУчета)  Тогда
				Отказ 		= истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для услуги " + СтрокаТЧ.НомерСтроки + " не указан тип узла учета",ЭтотОбъект,"ТочкиУчета["+(СтрокаТЧ.НомерСтроки-1)+"].ТипУзлаУчета");				
			КонецЕсли;			
		КонецЦикла;
		
		Для Каждого СтрокаТЧ из ТочкиУчета цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Услуга) и НЕ ЗначениеЗаполнено(СтрокаТЧ.ТочкаУчета) Тогда
				Отказ 		= истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле ""Услуга""",ЭтотОбъект,"ТочкиУчета["+(СтрокаТЧ.НомерСтроки-1)+"].Услуга");				
			КонецЕсли;			
		КонецЦикла;

		Если Не ЗначениеЗаполнено(ТочкиУчета) Тогда
			Отказ = Истина;
		    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не введено ни одной строки в список ""Услуги""", ЭтотОбъект, "ТочкиУчета");
		КонецЕсли;
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВыводПУ тогда
		Если Не ЗначениеЗаполнено(ТочкиУчета) Тогда
			Отказ = Истина;
		    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не введено ни одной строки в список ""Услуги""", ЭтотОбъект, "ТочкиУчета");
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ПоказанияПриборовУчета) Тогда
			Отказ = Истина;
		    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не введено ни одной строки в список ""Показаний""", ЭтотОбъект, "ПоказанияПриборовУчета");
			Возврат;
		КонецЕсли;
		
		//Для каждого СтрокаТЧ из ПоказанияПриборовУчета Цикл
		//	Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ТекущиеПоказания) Тогда
		//		Отказ 		= истина;
		//		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле ""Текущие показания""",ЭтотОбъект,"ПоказанияПриборовУчета["+(СтрокаТЧ.НомерСтроки-1)+"].ТекущиеПоказания");				
		//	КонецЕсли;
		//КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

