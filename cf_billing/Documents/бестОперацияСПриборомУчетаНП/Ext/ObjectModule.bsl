	        |			ВТ_ПУ.ОбъектРасчета,
	        |			ВТ_ПУ.УзелУчета) КАК ВложенныйЗапрос
	        |		ПО ВТ_ТУ.ОбъектРасчета = ВложенныйЗапрос.ОбъектРасчета
	        |			И ВТ_ТУ.ТочкаУчета = ВложенныйЗапрос.ТочкаУчета
	        |			И ВТ_ТУ.ПриборУчета = ВложенныйЗапрос.УзелУчета";
	
	Запрос.Текст = Текст;
	
	Возврат Запрос.ВыполнитьПакетСПромежуточнымиДанными();
КонецФункции

#КонецОбласти

#Область ЗАМЕНА_ПУ

Процедура ОперацииСЗаменойПУ()	
	
	Пакет = ПолучитьДанныеЗамены();
	ДанныеПриборовТУ				= Пакет[0];
	
	ДанныеПриборовТУСостояние		= Пакет[2];
	ДанныеИзмерителей				= Пакет[3];
	ДанныеСостояниеИзмерителей		= Пакет[4];
	ДанныеПоказанийПриборовУчета	= Пакет[5];
	ДанныеВидаДифференцированности	= Пакет[6];
	ДанныеКомУчета					= Пакет[7];
	ДанныеНомераПломб				= Пакет[8];
	
	
	
	СоотвествиеКолонок = Новый Структура;
	СоотвествиеКолонок.Вставить("ПриборУчета", "ПриборУчетаВывод");
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУ,				Движения.бестВыводПриборовУчетаНП, СоотвествиеКолонок);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУ,				Движения.бестПриборыТочекУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУСостояние,		Движения.бестСостояниеПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеИзмерителей,				Движения.бестДатыПоверкиПрибораУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеИзмерителей,				Движения.бестКоэффциентыПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеНомераПломб,				Движения.бестНомерПломбПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеКомУчета,				Движения.бестДопускПриборовУчетаККоммерческомуУчету);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеСостояниеИзмерителей,	Движения.бестПриборыУзловУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПоказанийПриборовУчета,	Движения.бестПоказанияПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеВидаДифференцированности,Движения.бестВидыДифференцированностиПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеВидаДифференцированности,Движения.бестПараметрыИзмерителей);
КонецПроцедуры

Функция ПолучитьДанныеЗамены()
	Запрос  	= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",				Ссылка);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",		ОбъектРасчета);
	Запрос.УстановитьПараметр("МКД",				ОбъектРасчета.МКД);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Период",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия), ДатаФактическогоСобытия,Дата));
	Запрос.УстановитьПараметр("ПериодРегистрации",	Дата);  	
	Текст 		= ВернутьТекстЗапросаЗамена(); 	
	Запрос.Текст = Текст;
	
	Возврат Запрос.ВыполнитьПакетСПромежуточнымиДанными();
КонецФункции

Функция ВернутьТекстЗапросаЗамена()
	
	Текст = "ВЫБРАТЬ
	        |	&Период КАК Период,
	        |	&Организация КАК Организация,
	        |	&Район КАК Район,
	        |	&ОбъектРасчета КАК ОбъектРасчета,
	        |	&ПериодРегистрации КАК ПериодРегистрации,
	        |	&ПериодНачисления КАК ПериодНачисления,
	        |	ТаблицаПриборовУчета.IDСтроки КАК IDСтроки,
	        |	&МКД КАК МКД,
	        |	ТаблицаПриборовУчета.ТочкаУчета КАК ТочкаУчета,
	        |	ТаблицаПриборовУчета.ПриборУчета КАК ПриборУчета,
	        |	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод) КАК Состояние,
	        |	ТаблицаПриборовУчета.ПриборУчета.ТипУзлаУчета КАК ТипУзлаУчета,
	        |	ТаблицаПриборовУчета.ПриборУчетаВывод КАК ПриборУчетаВывод,
	        |	ТаблицаПриборовУчета.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	        |	ТаблицаПриборовУчета.КонецДействияКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета
	        |ПОМЕСТИТЬ ВТ_ТУ
	        |ИЗ
	        |	Документ.бестОперацияСПриборомУчетаНП.ТочкиУчета КАК ТаблицаПриборовУчета
	        |ГДЕ
	        |	ТаблицаПриборовУчета.Ссылка = &ссылка
	        |	И НЕ ТаблицаПриборовУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
	        |	И ТаблицаПриборовУчета.ПриборУчета <> ТаблицаПриборовУчета.ПриборУчетаВывод
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	&Период КАК Период,
	        |	&Организация КАК Организация,
	        |	&Район КАК Район,
	        |	&ОбъектРасчета КАК ОбъектРасчета,
	        |	&ПериодРегистрации КАК ПериодРегистрации,
	        |	&ПериодНачисления КАК ПериодНачисления,
	        |	ТаблицаПриборовУчета.IDСтроки КАК IDСтроки,
	        |	&МКД КАК МКД,
	        |	ТаблицаПриборовУчета.ТочкаУчета КАК ТочкаУчета,
	        |	бестОперацияСПриборомУчетаНПИзмерители.ПриборУчета КАК ПриборУчета,
	        |	бестОперацияСПриборомУчетаНПИзмерители.ТипПрибораУчета КАК ТипПрибораУчета,
	        |	бестОперацияСПриборомУчетаНПИзмерители.НомерПломбы КАК НомерПломбы,
	        |	бестОперацияСПриборомУчетаНПИзмерители.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	        |	бестОперацияСПриборомУчетаНПИзмерители.КоэффициентПУ КАК Коэффициент,
	        |	ТаблицаПриборовУчета.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	        |	ТаблицаПриборовУчета.КонецДействияКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета,
	        |	бестОперацияСПриборомУчетаНПИзмерители.ДатаПоверкиСчетчика КАК ДатаПоверки,
	        |	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод) КАК Состояние,
	        |	ТаблицаПриборовУчета.ПриборУчета КАК УзелУчета,
	        |	ТаблицаПриборовУчета.Ссылка КАК Ссылка,
	        |	бестОперацияСПриборомУчетаНПИзмерители.РасположениеИзмерителя КАК РасположениеИзмерителя,
	        |	бестОперацияСПриборомУчетаНПИзмерители.Вывод КАК Вывод,
	        |	бестОперацияСПриборомУчетаНПИзмерители.Ввод КАК Ввод,
	        |	ТаблицаПриборовУчета.ПриборУчетаВывод КАК УзелВывод,
	        |	бестОперацияСПриборомУчетаНПИзмерители.ТипИзмерителя КАК ТипИзмерителя,
	        |	бестОперацияСПриборомУчетаНПИзмерители.IDСтроки КАК IDСтрокиИзмерителя
	        |ПОМЕСТИТЬ ВТ_ПУ
	        |ИЗ
	        |	Документ.бестОперацияСПриборомУчетаНП.ТочкиУчета КАК ТаблицаПриборовУчета
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.Измерители КАК бестОперацияСПриборомУчетаНПИзмерители
	        |		ПО ТаблицаПриборовУчета.Ссылка = бестОперацияСПриборомУчетаНПИзмерители.Ссылка
	        |			И ТаблицаПриборовУчета.IDСтроки = бестОперацияСПриборомУчетаНПИзмерители.IDСтрокиТочкиУчета
	        |			И (ТаблицаПриборовУчета.Ссылка = &Ссылка)
	        |			И (бестОперацияСПриборомУчетаНПИзмерители.Ссылка = &Ссылка)
	        |			И (НЕ бестОперацияСПриборомУчетаНПИзмерители.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВТ_ТУ.Период КАК Период,
	        |	ВТ_ТУ.Организация КАК Организация,
	        |	ВТ_ТУ.Район КАК Район,
	        |	ВТ_ТУ.ОбъектРасчета КАК ОбъектРасчета,
	        |	ВТ_ТУ.ПериодРегистрации КАК ПериодРегистрации,
	        |	ВТ_ТУ.ПериодНачисления КАК ПериодНачисления,
	        |	ВТ_ТУ.МКД КАК МКД,
	        |	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
	        |	ВТ_ТУ.ПриборУчетаВывод КАК ПриборУчета,
	        |	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Вывод) КАК Состояние
	        |ИЗ
	        |	ВТ_ТУ КАК ВТ_ТУ
	        |
	        |ОБЪЕДИНИТЬ ВСЕ
	        |
	        |ВЫБРАТЬ
	        |	ВТ_ТУ.Период,
	        |	ВТ_ТУ.Организация,
	        |	ВТ_ТУ.Район,
	        |	ВТ_ТУ.ОбъектРасчета,
	        |	ВТ_ТУ.ПериодРегистрации,
	        |	ВТ_ТУ.ПериодНачисления,
	        |	ВТ_ТУ.МКД,
	        |	ВТ_ТУ.ТочкаУчета,
	        |	ВТ_ТУ.ПриборУчета,
	        |	ВТ_ТУ.Состояние
	        |ИЗ
	        |	ВТ_ТУ КАК ВТ_ТУ
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВТ_ПУ.Период КАК Период,
	        |	ВТ_ПУ.Организация КАК Организация,
	        |	ВТ_ПУ.Район КАК Район,
	        |	ВТ_ПУ.ОбъектРасчета КАК ОбъектРасчета,
	        |	ВТ_ПУ.ПериодРегистрации КАК ПериодРегистрации,
	        |	ВТ_ПУ.ПериодНачисления КАК ПериодНачисления,
	        |	ВТ_ПУ.IDСтроки КАК IDСтроки,
	        |	ВТ_ПУ.МКД КАК МКД,
	        |	ВТ_ПУ.ТочкаУчета КАК ТочкаУчета,
	        |	ВТ_ПУ.ПриборУчета КАК ПриборУчета,
	        |	ВТ_ПУ.ТипПрибораУчета КАК ТипПрибораУчета,
	        |	ВТ_ПУ.НомерПломбы КАК НомерПломбы,
	        |	ВТ_ПУ.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	        |	ВТ_ПУ.Коэффициент КАК Коэффициент,
	        |	ВТ_ПУ.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	        |	ВТ_ПУ.КонецПериодаКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета,
	        |	ВТ_ПУ.ДатаПоверки КАК ДатаПоверки,
	        |	ВТ_ПУ.Состояние КАК Состояние,
	        |	ВТ_ПУ.УзелУчета КАК УзелУчета,
	        |	ВТ_ПУ.Ссылка КАК Ссылка,
	        |	ВТ_ПУ.РасположениеИзмерителя КАК РасположениеИзмерителя,
	        |	ВТ_ПУ.ТипИзмерителя КАК ТипИзмерителя,
	        |	ВТ_ПУ.IDСтрокиИзмерителя КАК IDСтрокиИзмерителя
	        |ПОМЕСТИТЬ ВТ_ВведенныеИзмерители
	        |ИЗ
	        |	ВТ_ПУ КАК ВТ_ПУ
	        |ГДЕ
	        |	ВЫБОР
