#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ОбработчикиСобытий
	
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	Ответственный = Пользователи.ТекущийПользователь();
		
	Если ДополнительныеСвойства.свойство("ВосстановлениеПоследовательности") тогда
		Возврат;
	КонецЕсли;
	
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ЗаменаВспомогательногоПУ Тогда	 
		ДополнительныеСвойства.Вставить("РегистрироватьПоказанияПУ", Ложь);   
	КонецЕсли;   

	бестПроведениеСерверНП.ПередЗаписьюОбъекта(ЭтотОбъект);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	
	Если ЗначениеЗаполнено(ДатаФактическогоСобытия) тогда
		Момент 			= Новый Граница(Новый МоментВремени(КонецДня(ДатаФактическогоСобытия),Ссылка), ВидГраницы.Исключая);
		СтрокаОтказа 	= "На дату фактического события";
	иначе
		Момент 			= Новый Граница(МоментВремени(),ВидГраницы.Исключая);
		СтрокаОтказа 	= "На дату операции";
	КонецЕсли;
	
	
	ПриборыВыведены = истина;
	
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВводПУ тогда
		ПриборыВыведены = бестРаботаСприборамиУчетаСервер.ПриборыВыведены(Новый Структура("МоментВремени,Организация,Район,ОбъектРасчета,МассивТочекУчета",Момент,Организация,Район,ОбъектРасчета,ТочкиУчета.ВыгрузитьКолонку("ТочкаУчета"))); 
	КонецЕсли;
	
	Если  Не ПриборыВыведены Тогда 
		Отказ			= истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + СтрокаОтказа + " приборы учета уже введены");
	КонецЕсли;
	
	Если Отказ тогда
		Возврат;
	КонецЕсли;
	
	бестПроведениеСерверНП.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВводПУ Тогда
		
		Если не СоставУзлаКорректен() тогда
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		ОперацииСВводомПУ();		
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВыводПУ Тогда		
		ОперацииСВыводомПУ(); 		
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ЗаменаПУ Тогда				
		ОперацииСЗаменойПУ();
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ЗаменаВспомогательногоПУ Тогда				
		ОперацииСЗаменойВспомогательногоПУ();
	КонецЕсли;		
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Дата, Организация, Район);
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСПриборомУчета_ВыводПУ Тогда
		Документы.бестОперацияСПриборомУчетаНП.ЗаполнитьТабличныеЧастиДляАктаВывода(ЭтотОбъект);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ВВОД_ПУ

Процедура ОперацииСВводомПУ()	
	
	Пакет = ПолучитьДанныеТЧ();
	ВТ_УзлыВРСПриборыТочек			= Пакет[0];
	ДанныеПриборовТУ				= Пакет[1];
	ДанныеПоказанийПриборовУчета	= Пакет[2];
	ДанныеПоШкаламПУ			 	= Пакет[3];
	ДанныеУзловУчета				= Пакет[4];
	ДанныеПриборовУзловУчета		= Пакет[5];
	ДанныеПараметрыИзмерителей		= Пакет[6];
	ДанныеКоМУчета					= Пакет[7];
	ДанныеНомераПломб				= Пакет[8];
	
		
	//// Узлы учета
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ВТ_УзлыВРСПриборыТочек,	Движения.бестПриборыТочекУчетаНП);	
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеУзловУчета,			Движения.бестСостояниеПриборовУчетаНП);
	
	// приборы точек учета
	
	
	//энргРаботаСприборамиУчетаСервер.СброситьРасчетПоФормуле(Движения,ДанныеШапки);
	
	// показания приборов учета 
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПоказанийПриборовУчета,	Движения.бестПоказанияПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПоШкаламПУ,				Движения.бестВидыДифференцированностиПриборовУчетаНП);

	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУ,				Движения.бестКоэффциентыПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУ,				Движения.бестДатыПоверкиПрибораУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеКоМУчета,				Движения.бестДопускПриборовУчетаККоммерческомуУчету);
	
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовУзловУчета,		Движения.бестПриборыУзловУчетаНП);
	
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПараметрыИзмерителей,	Движения.бестПараметрыИзмерителей);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеНомераПломб,				Движения.бестНомерПломбПриборовУчетаНП);
	
	
КонецПроцедуры

Функция ПолучитьДанныеТЧ()  	
	
	Запрос  	= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",				Ссылка);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",		ОбъектРасчета);
	Запрос.УстановитьПараметр("МКД",				ОбъектРасчета.МКД);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Период",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия),ДатаФактическогоСобытия,Дата));
	Запрос.УстановитьПараметр("ПериодРегистрации",	Дата);
	Запрос.УстановитьПараметр("ПериодИскл",			Новый Граница(МоментВремени(),ВидГраницы.Исключая));
	
	Запрос.Текст = ВернутьТекстЗапросаВвода();
	
	Возврат Запрос.ВыполнитьПакетСПромежуточнымиДанными(); 	
КонецФункции 

Функция ВернутьТекстЗапросаВвода()
	
	Текст = "ВЫБРАТЬ
	        |	&Период КАК Период,
	        |	&Организация КАК Организация,
	        |	&Район КАК Район,
	        |	&ОбъектРасчета КАК ОбъектРасчета,
	        |	&ПериодРегистрации КАК ПериодРегистрации,
	        |	&ПериодНачисления КАК ПериодНачисления,
	        |	ТаблицаПриборовУчета.IDСтроки КАК IDСтроки,
	        |	&МКД КАК МКД,
	        |	ТаблицаПриборовУчета.ТочкаУчета КАК ТочкаУчета,
	        |	ТаблицаПриборовУчета.ПриборУчета КАК ПриборУчета,
	        |	ТаблицаПриборовУчета.НомерПломбы КАК НомерПломбы,
	        |	ТаблицаПриборовУчета.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	        |	ТаблицаПриборовУчета.КоэффициентПУ КАК Коэффициент,
	        |	ТаблицаПриборовУчета.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	        |	ТаблицаПриборовУчета.КонецДействияКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета,
	        |	ТаблицаПриборовУчета.ДатаПоверкиСчетчика КАК ДатаПоверки,
	        |	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод) КАК Состояние,
	        |	ТаблицаПриборовУчета.ПриборУчета.ТипУзлаУчета КАК ТипУзлаУчета
	        |ПОМЕСТИТЬ ВТ_ТУ
	        |ИЗ
	        |	Документ.бестОперацияСПриборомУчетаНП.ТочкиУчета КАК ТаблицаПриборовУчета
	        |ГДЕ
	        |	ТаблицаПриборовУчета.Ссылка = &ссылка
	        |	И НЕ ТаблицаПриборовУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	&Период КАК Период,
	        |	&Организация КАК Организация,
	        |	&Район КАК Район,
	        |	&ОбъектРасчета КАК ОбъектРасчета,
	        |	&ПериодРегистрации КАК ПериодРегистрации,
	        |	&ПериодНачисления КАК ПериодНачисления,
	        |	ТаблицаПриборовУчета.IDСтроки КАК IDСтроки,
	        |	&МКД КАК МКД,
	        |	ТаблицаПриборовУчета.ТочкаУчета КАК ТочкаУчета,
	        |	бестОперацияСПриборомУчетаНПИзмерители.ПриборУчета КАК ПриборУчета,
	        |	бестОперацияСПриборомУчетаНПИзмерители.ТипПрибораУчета КАК ТипПрибораУчета,
	        |	бестОперацияСПриборомУчетаНПИзмерители.НомерПломбы КАК НомерПломбы,
	        |	бестОперацияСПриборомУчетаНПИзмерители.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	        |	бестОперацияСПриборомУчетаНПИзмерители.КоэффициентПУ КАК Коэффициент,
	        |	ТаблицаПриборовУчета.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	        |	ТаблицаПриборовУчета.КонецДействияКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета,
	        |	бестОперацияСПриборомУчетаНПИзмерители.ДатаПоверкиСчетчика КАК ДатаПоверки,
	        |	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод) КАК Состояние,
	        |	ТаблицаПриборовУчета.ПриборУчета КАК УзелУчета,
	        |	ТаблицаПриборовУчета.Ссылка КАК Ссылка,
	        |	бестОперацияСПриборомУчетаНПИзмерители.РасположениеИзмерителя КАК РасположениеИзмерителя,
	        |	бестОперацияСПриборомУчетаНПИзмерители.IDСтроки КАК IDСтрокиИзмерителя
	        |ПОМЕСТИТЬ ВТ_ПУ
	        |ИЗ
	        |	Документ.бестОперацияСПриборомУчетаНП.ТочкиУчета КАК ТаблицаПриборовУчета
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.Измерители КАК бестОперацияСПриборомУчетаНПИзмерители
	        |		ПО ТаблицаПриборовУчета.Ссылка = бестОперацияСПриборомУчетаНПИзмерители.Ссылка
	        |			И ТаблицаПриборовУчета.IDСтроки = бестОперацияСПриборомУчетаНПИзмерители.IDСтрокиТочкиУчета
	        |			И (ТаблицаПриборовУчета.Ссылка = &Ссылка)
	        |			И (бестОперацияСПриборомУчетаНПИзмерители.Ссылка = &Ссылка)
	        |			И (НЕ бестОперацияСПриборомУчетаНПИзмерители.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	&Период КАК Период,
	        |	&Организация КАК Организация,
	        |	&Район КАК Район,
	        |	&ОбъектРасчета КАК ОбъектРасчета,
	        |	&ПериодРегистрации КАК ПериодРегистрации,
	        |	&ПериодНачисления КАК ПериодНачисления,
	        |	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
	        |	ВТ_ТУ.ПриборУчета КАК ПриборУчета,
	        |	ТаблицаПоказанийПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	        |	ТаблицаПоказанийПриборовУчета.ТекущиеПоказания КАК Показание,
	        |	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты) КАК СостояниеПоказаний,
	        |	ЗНАЧЕНИЕ(Перечисление.энргПричиныОтклоненияПоказаний.ПустаяСсылка) КАК ПричинаОтклонения,
	        |	ЛОЖЬ КАК КС,
	        |	ЛОЖЬ КАК Переворот,
	        |	ТаблицаПоказанийПриборовУчета.НомерСтроки КАК НомерСтрокиТЧ,
	        |	ШкалыПриборовУчета.Шкала КАК Шкала
	        |ИЗ
	        |	ВТ_ТУ КАК ВТ_ТУ
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.ШкалыПриборовУчета КАК ШкалыПриборовУчета
	        |		ПО (ШкалыПриборовУчета.Ссылка = &ссылка)
	        |			И ВТ_ТУ.IDСтроки = ШкалыПриборовУчета.IDСтрокиТочкиУчета
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.ПоказанияПриборовУчета КАК ТаблицаПоказанийПриборовУчета
	        |		ПО ВТ_ТУ.IDСтроки = ТаблицаПоказанийПриборовУчета.IDСтрокиТочкиУчета
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВТ_ТУ.Организация КАК Организация,
	        |	ВТ_ТУ.Район КАК Район,
	        |	ВТ_ТУ.ОбъектРасчета КАК ОбъектРасчета,
	        |	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
	        |	ВТ_ТУ.ПриборУчета КАК ПриборУчета,
	        |	ТаблицаШкалыПриборов.Шкала КАК Шкала,
	        |	ВЫБОР
	        |		КОГДА ТаблицаШкалыПриборов.ВидДифференцированности = ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка)
	        |			ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)
	        |		ИНАЧЕ ТаблицаШкалыПриборов.ВидДифференцированности
	        |	КОНЕЦ КАК ВидДифференцированности,
	        |	ВТ_ТУ.Период КАК Период
	        |ИЗ
	        |	ВТ_ТУ КАК ВТ_ТУ
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.ШкалыПриборовУчета КАК ТаблицаШкалыПриборов
	        |		ПО (ТаблицаШкалыПриборов.Ссылка = &Ссылка)
	        |			И (ВТ_ТУ.ПриборУчета <> ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	        |			И ВТ_ТУ.IDСтроки = ТаблицаШкалыПриборов.IDСтрокиТочкиУчета
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВТ_ТУ.Период КАК Период,
	        |	ВТ_ТУ.Организация КАК Организация,
	        |	ВТ_ТУ.Район КАК Район,
	        |	ВТ_ТУ.ПериодРегистрации КАК ПериодРегистрации,
	        |	ВТ_ТУ.ПериодНачисления КАК ПериодНачисления,
	        |	ВТ_ТУ.IDСтроки КАК IDСтроки,
	        |	ВТ_ТУ.ОбъектРасчета КАК ОбъектРасчета,
	        |	ВТ_ТУ.МКД КАК МКД,
	        |	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
	        |	ВТ_ТУ.ПриборУчета КАК ПриборУчета,
	        |	ВТ_ТУ.Состояние КАК Состояние,
