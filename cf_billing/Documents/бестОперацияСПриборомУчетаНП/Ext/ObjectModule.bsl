Процедура ОперацииСВыводомПУ()
	
	Пакет = ВернутьДанныеВывода();//ПолучитьДанныеТЧ("Вывод");  	
	ДанныеПриборовТУ				= Пакет[1];
	ДанныеПоказанийПриборовУчета	= Пакет[2];
	ДанныеУзловТУ					= Пакет[4];
	
	//Узлы
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеУзловТУ,				Движения.бестСостояниеПриборовУчетаНП);
	
	//Приборы
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПоказанийПриборовУчета,	Движения.бестПоказанияПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУ,				Движения.бестВыводПриборовУчетаНП);
	
	//энргРаботаСприборамиУчетаСервер.ЗаписатьДанныеВывода(ДанныеШапки,Движения,"ПриборыУчетаВывод",СоотвествиеКолонок);
КонецПроцедуры

Функция ВернутьДанныеВывода()
	Запрос  	= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",				Ссылка);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",		ОбъектРасчета);
	Запрос.УстановитьПараметр("МКД",				ОбъектРасчета.МКД);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Период",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия), ДатаФактическогоСобытия, Дата));
	Запрос.УстановитьПараметр("ПериодРегистрации",	Дата);  	
	
	Текст = "ВЫБРАТЬ
	        |	&Период КАК Период,
	        |	&Организация КАК Организация,
	        |	&Район КАК Район,
	        |	&ОбъектРасчета КАК ОбъектРасчета,
	        |	&ПериодРегистрации КАК ПериодРегистрации,
	        |	&ПериодНачисления КАК ПериодНачисления,
	        |	&МКД КАК МКД,
	        |	ТаблицаПриборовУчета.ТочкаУчета КАК ТочкаУчета,
	        |	ВЫБОР
	        |		КОГДА ТаблицаПриборовУчета.УзелУчета ЕСТЬ NULL
	        |				ИЛИ ТаблицаПриборовУчета.УзелУчета = ЗНАЧЕНИЕ(справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
	        |			ТОГДА ТаблицаПриборовУчета.ПриборУчета
	        |		ИНАЧЕ ТаблицаПриборовУчета.УзелУчета
	        |	КОНЕЦ КАК ПриборУчета,
	        |	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Вывод) КАК Состояние,
	        |	ВЫБОР
	        |		КОГДА ТаблицаПриборовУчета.УзелУчета ЕСТЬ NULL
	        |				ИЛИ ТаблицаПриборовУчета.УзелУчета = ЗНАЧЕНИЕ(справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
	        |			ТОГДА ТаблицаПриборовУчета.ПриборУчета.ТипУзлаУчета
	        |		ИНАЧЕ ТаблицаПриборовУчета.УзелУчета.ТипУзлаУчета
	        |	КОНЕЦ КАК ТипУзлаУчета,
	        |	ТаблицаПриборовУчета.ПриборУчета.ТипУзлаУчета КАК ПриборУчетаТипУзлаУчета
	        |ПОМЕСТИТЬ ВТ_ТУ
	        |ИЗ
	        |	Документ.бестОперацияСПриборомУчетаНП.ТочкиУчета КАК ТаблицаПриборовУчета
	        |ГДЕ
	        |	ТаблицаПриборовУчета.Ссылка = &ссылка
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	&Период КАК Период,
	        |	&Организация КАК Организация,
	        |	&Район КАК Район,
	        |	&ОбъектРасчета КАК ОбъектРасчета,
	        |	&ПериодРегистрации КАК ПериодРегистрации,
	        |	&ПериодНачисления КАК ПериодНачисления,
	        |	ТаблицаПриборовУчета.IDСтроки КАК IDСтроки,
	        |	&МКД КАК МКД,
