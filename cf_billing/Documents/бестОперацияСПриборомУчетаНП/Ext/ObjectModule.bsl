	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.ШкалыПриборовУчета КАК ШкалыПриборовУчета
	        |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.ПоказанияПриборовУчета КАК ТаблицаПоказанийПриборовУчета
	        |			ПО ШкалыПриборовУчета.IDСтроки = ТаблицаПоказанийПриборовУчета.IDСтроки
	        |				И ШкалыПриборовУчета.IDСтрокиТочкиУчета = ТаблицаПоказанийПриборовУчета.IDСтрокиТочкиУчета
	        |				И ШкалыПриборовУчета.Ссылка = ТаблицаПоказанийПриборовУчета.Ссылка
	        |		ПО (ШкалыПриборовУчета.Ссылка = &ссылка)
	        |			И ВТ_ТУ.IDСтроки = ШкалыПриборовУчета.IDСтрокиТочкиУчета
	        |ГДЕ
	        |	ШкалыПриборовУчета.Вывод
	        |
	        |ОБЪЕДИНИТЬ ВСЕ
	        |
	        |ВЫБРАТЬ
	        |	&Период,
	        |	&Организация,
	        |	&Район,
	        |	&ОбъектРасчета,
	        |	&ПериодРегистрации,
	        |	&ПериодНачисления,
	        |	ВТ_ТУ.ТочкаУчета,
	        |	ВТ_ТУ.ПриборУчета,
	        |	ТаблицаПоказанийПриборовУчета.ТарифнаяЗона,
	        |	ТаблицаПоказанийПриборовУчета.ТекущиеПоказания,
	        |	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты),
	        |	ЗНАЧЕНИЕ(Перечисление.энргПричиныОтклоненияПоказаний.ПустаяСсылка),
	        |	ЛОЖЬ,
	        |	ЛОЖЬ,
	        |	ТаблицаПоказанийПриборовУчета.НомерСтроки,
	        |	ШкалыПриборовУчета.Шкала
	        |ИЗ
	        |	ВТ_ТУ КАК ВТ_ТУ
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.ШкалыПриборовУчета КАК ШкалыПриборовУчета
	        |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.ПоказанияПриборовУчета КАК ТаблицаПоказанийПриборовУчета
	        |			ПО ШкалыПриборовУчета.Ссылка = ТаблицаПоказанийПриборовУчета.Ссылка
	        |				И ШкалыПриборовУчета.IDСтроки = ТаблицаПоказанийПриборовУчета.IDСтроки
	        |				И ШкалыПриборовУчета.IDСтрокиТочкиУчета = ТаблицаПоказанийПриборовУчета.IDСтрокиТочкиУчета
	        |		ПО (ШкалыПриборовУчета.Ссылка = &ссылка)
	        |			И ВТ_ТУ.IDСтроки = ШкалыПриборовУчета.IDСтрокиТочкиУчета
	        |ГДЕ
	        |	НЕ ШкалыПриборовУчета.Вывод
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВТ_ТУ.Организация КАК Организация,
	        |	ВТ_ТУ.Район КАК Район,
	        |	ВТ_ТУ.ОбъектРасчета КАК ОбъектРасчета,
	        |	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
	        |	ВТ_ТУ.ПриборУчета КАК ПриборУчета,
	        |	ТаблицаШкалыПриборов.Шкала КАК Шкала,
	        |	ВЫБОР
	        |		КОГДА ТаблицаШкалыПриборов.ВидДифференцированности = ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.ПустаяСсылка)
	        |			ТОГДА ЗНАЧЕНИЕ(Справочник.энргВидыДифференцированности.Однотарифный)
	        |		ИНАЧЕ ТаблицаШкалыПриборов.ВидДифференцированности
	        |	КОНЕЦ КАК ВидДифференцированности,
	        |	ВТ_ТУ.Период КАК Период,
	        |	ТаблицаШкалыПриборов.ВидПараметра КАК ВидПараметра,
	        |	ТаблицаШкалыПриборов.ТипТемпературы КАК ТипТемпературы,
	        |	ВТ_ТУ.ПриборУчета КАК Измеритель
	        |ИЗ
	        |	ВТ_ТУ КАК ВТ_ТУ
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.ШкалыПриборовУчета КАК ТаблицаШкалыПриборов
	        |		ПО (ТаблицаШкалыПриборов.Ссылка = &Ссылка)
	        |			И (ВТ_ТУ.ПриборУчета <> ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	        |			И ВТ_ТУ.IDСтроки = ТаблицаШкалыПриборов.IDСтрокиТочкиУчета
	        |			И (НЕ ТаблицаШкалыПриборов.Вывод)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВТ_ТУ.Период КАК Период,
	        |	ВТ_ТУ.Организация КАК Организация,
	        |	ВТ_ТУ.Район КАК Район,
	        |	ВТ_ТУ.ОбъектРасчета КАК ОбъектРасчета,
	        |	ВТ_ТУ.ПериодРегистрации КАК ПериодРегистрации,
	        |	ВТ_ТУ.ПериодНачисления КАК ПериодНачисления,
	        |	ВТ_ТУ.МКД КАК МКД,
	        |	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
	        |	ВТ_ТУ.ПриборУчета КАК ПриборУчета,
	        |	ВТ_ТУ.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	        |	ВТ_ТУ.КонецПериодаКоммерскогоУчета КАК КонецПериодаКоммерскогоУчета
	        |ИЗ
	        |	ВТ_ТУ КАК ВТ_ТУ
	        |ГДЕ
	        |	ВТ_ТУ.ПриборУчета <> ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.пустаяссылка)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВТ_ПУ.Период КАК Период,
	        |	ВТ_ПУ.Организация КАК Организация,
	        |	ВТ_ПУ.Район КАК Район,
	        |	ВТ_ПУ.ПриборУчета КАК ПриборУчета,
	        |	бестОперацияСПриборомУчетаНПНомераПломб.НомерПломбы КАК НомерПломбы,
	        |	бестОперацияСПриборомУчетаНПНомераПломб.КлючСтроки КАК МестоУстановки,
	        |	бестОперацияСПриборомУчетаНПНомераПломб.ДатаУстановкиПломбы КАК ДатаОперацииСПломбой,
	        |	бестОперацияСПриборомУчетаНПНомераПломб.ЛицоУстановившееПломбу КАК ОтветственноеЛицо,
	        |	бестОперацияСПриборомУчетаНПНомераПломб.ВидПломбы КАК ВидПломбы,
	        |	ИСТИНА КАК Состояние
	        |ИЗ
	        |	ВТ_ПУ КАК ВТ_ПУ
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСПриборомУчетаНП.НомераПломб КАК бестОперацияСПриборомУчетаНПНомераПломб
	        |		ПО ВТ_ПУ.Ссылка = бестОперацияСПриборомУчетаНПНомераПломб.Ссылка
	        |			И ВТ_ПУ.IDСтрокиИзмерителя = бестОперацияСПриборомУчетаНПНомераПломб.IDСтрокиИзмерителя";
	
	Возврат Текст
КонецФункции

#КонецОбласти

#Область ЗАМЕНА_ВСПОМОГАТЕЛЬНОГО_ПУ

Процедура ОперацииСЗаменойВспомогательногоПУ()	
	
	Пакет = ПолучитьДанныеЗаменыВспомогательногоПУ();
	ДанныеПриборовТУ				= Пакет[0];
	
	ДанныеПриборовТУСостояние		= Пакет[1];
	ДанныеИзмерителей				= Пакет[2];
	ДанныеСостояниеИзмерителей		= Пакет[3];
	ДанныеВидаДифференцированности	= Пакет[4];
	ДанныеНомераПломб				= Пакет[5];
	ДанныеКоэффициенты				= Пакет[6];
	
	
	СоотвествиеКолонок = Новый Структура;
	СоотвествиеКолонок.Вставить("ПриборУчета", "ПриборУчетаВывод");
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеИзмерителей,				Движения.бестДатыПоверкиПрибораУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеКоэффициенты,				Движения.бестКоэффциентыПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеНомераПломб,				Движения.бестНомерПломбПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеСостояниеИзмерителей,	Движения.бестПриборыУзловУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеВидаДифференцированности,Движения.бестПараметрыИзмерителей);
КонецПроцедуры

Функция ПолучитьДанныеЗаменыВспомогательногоПУ()
	Запрос  	= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",				Ссылка);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",		ОбъектРасчета);
	Запрос.УстановитьПараметр("МКД",				ОбъектРасчета.МКД);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Период",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия), ДатаФактическогоСобытия,Дата));
	Запрос.УстановитьПараметр("ПериодРегистрации",	Дата);  	
	Текст 		= ВернутьТекстЗапросаЗаменаВспомогательногоПУ(); 	
	Запрос.Текст = Текст;
	
	Возврат Запрос.ВыполнитьПакетСПромежуточнымиДанными();
КонецФункции

Функция ВернутьТекстЗапросаЗаменаВспомогательногоПУ()
	
	Текст = "ВЫБРАТЬ
	        |	&Период КАК Период,
	        |	&Организация КАК Организация,
	        |	&Район КАК Район,
	        |	&ОбъектРасчета КАК ОбъектРасчета,
	        |	&ПериодРегистрации КАК ПериодРегистрации,
	        |	&ПериодНачисления КАК ПериодНачисления,
	        |	ТаблицаПриборовУчета.IDСтроки КАК IDСтроки,
	        |	&МКД КАК МКД,
	        |	ТаблицаПриборовУчета.ТочкаУчета КАК ТочкаУчета,
	        |	ТаблицаПриборовУчета.ПриборУчета КАК ПриборУчета,
	        |	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод) КАК Состояние,
	        |	ТаблицаПриборовУчета.ПриборУчета.ТипУзлаУчета КАК ТипУзлаУчета,
	        |	ТаблицаПриборовУчета.ПриборУчетаВывод КАК ПриборУчетаВывод,
	        |	ТаблицаПриборовУчета.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
