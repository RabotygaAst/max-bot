&НаКлиенте
Процедура ВыборУслугиИТочкиУчета(ТекДанные)
	СтруктураОтбора = Новый Структура("Период,Организация,Район,ОбъектРасчета",Объект.ДатаФактическогоСобытия);
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,Объект);
		
	ПараметрыВыбораФормы	= Новый Структура("СтруктураОтбора,ТипВладельца,ТочкиСПриборами,ВыводитьСоставные", СтруктураОтбора, "НП", Ложь,Истина);
	ОписаниеОповещения 		= Новый ОписаниеОповещения("ТочкаУчетаОкончаниеВыбора",ЭтаФорма,Новый Структура("ТекДанные", ТекДанные));
	
	ОткрытьФорму("ОбщаяФорма.бестФормаВыбораТочкиУчета",ПараметрыВыбораФормы,,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

&НаКлиенте
Процедура ТочкаУчетаОкончаниеВыбора(РезультатЗакрытия,ДополнительныеПараметры) Экспорт  
	
	ТекущиеДанные 				= Элементы.ТочкиУчета.ТекущиеДанные;
	
	
	Если РезультатЗакрытия <> Неопределено Тогда 
		ТекДанные					= ДополнительныеПараметры.ТекДанные;
		ТекДанные.ТочкаУчета		= РезультатЗакрытия.ТочкаУчета;
		ТекДанные.НаименованиеТочки	= Строка(РезультатЗакрытия.ТочкаУчета);
		ТекДанные.Услуга			= РезультатЗакрытия.Услуга;
		
		Если ЗначениеЗаполнено(ТекДанные.ТочкаУчета) Тогда
			СписокСтрок = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("Услуга, ТочкаУчета", ТекДанные.Услуга, ТекДанные.ТочкаУчета));
			Если СписокСтрок.Количество() > 1 Тогда
				ТекДанные.ТочкаУчета = Неопределено;
				ТекДанные.Услуга 	 = Неопределено;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Точка учета уже добавлена в документ");
			КонецЕсли;
		КонецЕсли;

		ДанныеУзлаУчета 			= ВернутьУзелУчета(Объект.ОбъектРасчета,ТекДанные.ТочкаУчета);
		ЗаполнитьЗначенияСвойств(ТекДанные,ДанныеУзлаУчета);
		//ТекДанные.ПриборУчета		= ВернутьУзелУчета(ТекДанные.ОбъектРасчета,ТекДанные.ТочкаУчета);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаПроведения(РезультатВопроса,ДополнительныеПараметры) Экспорт
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если  РезультатВопроса = КодВозвратаДиалога.Нет тогда
			Отказ = Истина;
		КонецЕсли; 		
	КонецЕсли;	
КонецПроцедуры

