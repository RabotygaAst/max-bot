// Возвращает все ТУ с признаком до ТП
// 
// Параметры:
//  Период - Дата
//  Организация - СправочникСсылка.Организации
//  Район - СправочникСсылка.энргЗоныОтвественности
//  ОбъектРасчета - СправочникСсылка.бестОбъектыРасчета
//
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса
//
Функция ТочкиУчетаДоТП(Период, Организация, Район, ОбъектРасчета) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	               |	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга,
	               |	энргТочкиУчета.Расположение КАК Расположение,
	               |	энргТочкиУчета.Головная КАК Головная,
	               |	бестРасположениеТочекУчетаОтносительноГБПСрезПоследних.ГБП КАК ГБП,
	               |	энргВидыУслуг.СоставнаяУслуга КАК ЭтоСоставнаяУслуга
	               |ПОМЕСТИТЬ ВТ_ТУ
	               |ИЗ
	               |	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
	               |			&Период,
	               |			Организация = &Организация
	               |				И Район = &Район
	               |				И ОбъектРасчета = &ОбъектРасчета) КАК бестАктивностьТочекУчетаНПСрезПоследних
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестУслугиТочекУчетаНП.СрезПоследних(
	               |				&Период,
	               |				Организация = &Организация
	               |					И Район = &Район
	               |					И ОбъектРасчета = &ОбъектРасчета) КАК бестУслугиТочекУчетаНПСрезПоследних
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	               |			ПО бестУслугиТочекУчетаНПСрезПоследних.Услуга = энргВидыУслуг.Ссылка
	               |		ПО бестАктивностьТочекУчетаНПСрезПоследних.Организация = бестУслугиТочекУчетаНПСрезПоследних.Организация
	               |			И бестАктивностьТочекУчетаНПСрезПоследних.Район = бестУслугиТочекУчетаНПСрезПоследних.Район
	               |			И бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета = бестУслугиТочекУчетаНПСрезПоследних.ОбъектРасчета
	               |			И бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета = бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТочкиУчета КАК энргТочкиУчета
	               |		ПО бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета = энргТочкиУчета.Ссылка
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестРасположениеТочекУчетаОтносительноГБП.СрезПоследних(
	               |				&Период,
	               |				Организация = &Организация
	               |					И Район = &Район) КАК бестРасположениеТочекУчетаОтносительноГБПСрезПоследних
	               |		ПО бестАктивностьТочекУчетаНПСрезПоследних.Организация = бестРасположениеТочекУчетаОтносительноГБПСрезПоследних.Организация
	               |			И бестАктивностьТочекУчетаНПСрезПоследних.Район = бестРасположениеТочекУчетаОтносительноГБПСрезПоследних.Район
	               |			И бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета = бестРасположениеТочекУчетаОтносительноГБПСрезПоследних.ТочкаУчета
	               |ГДЕ
	               |	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.ДоТП)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
	               |	ВТ_ТУ.Услуга КАК Услуга,
	               |	ВТ_ТУ.Расположение КАК Расположение,
	               |	ВТ_ТУ.Головная КАК Головная,
	               |	ВТ_ТУ.ГБП КАК ГБП,
	               |	ВТ_ТУ.ЭтоСоставнаяУслуга КАК ЭтоСоставнаяУслуга,
	               |	бестПоставщикиУслугНПСрезПоследних.Поставщик КАК Поставщик,
	               |	бестДоговорыТочекУчетаСрезПоследних.Договор КАК Договор
	               |ИЗ
	               |	ВТ_ТУ КАК ВТ_ТУ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестПоставщикиУслугНП.СрезПоследних(
	               |				&Период,
	               |				Организация = &Организация
	               |					И Район = &Район
	               |					И ОбъектРасчета = &ОбъектРасчета
	               |					И ТочкаУчета В
	               |						(ВЫБРАТЬ
	               |							ВТ_ТУ.ТочкаУчета
	               |						ИЗ
	               |							ВТ_ТУ КАК ВТ_ТУ)) КАК бестПоставщикиУслугНПСрезПоследних
	               |		ПО ВТ_ТУ.ТочкаУчета = бестПоставщикиУслугНПСрезПоследних.ТочкаУчета
	               |			И ВТ_ТУ.Услуга = бестПоставщикиУслугНПСрезПоследних.Услуга
	               |			И (НЕ ВТ_ТУ.ЭтоСоставнаяУслуга)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестДоговорыТочекУчета.СрезПоследних(
	               |				&Период,
	               |				Организация = &Организация
	               |					И Район = &Район
	               |					И ОбъектРасчета = &ОбъектРасчета
	               |					И ТочкаУчета В
	               |						(ВЫБРАТЬ
	               |							ВТ_ТУ.ТочкаУчета
	               |						ИЗ
	               |							ВТ_ТУ КАК ВТ_ТУ)) КАК бестДоговорыТочекУчетаСрезПоследних
	               |		ПО ВТ_ТУ.ТочкаУчета = бестДоговорыТочекУчетаСрезПоследних.ТочкаУчета
	               |			И ВТ_ТУ.Услуга = бестДоговорыТочекУчетаСрезПоследних.Услуга
	               |			И (НЕ ВТ_ТУ.ЭтоСоставнаяУслуга)";
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ОбъектРасчета", ОбъектРасчета);
	Запрос.УстановитьПараметр("Период", Период);
	Возврат Запрос.Выполнить().Выбрать();
		
КонецФункции

// Возвращает поставщики услуг
// 
// Параметры:
//  Период - Дата
//  Организация - СправочникСсылка.Организации
//  Район - СправочникСсылка.энргЗоныОтвественности
//  ТочкиУчета - ТаблицаЗначений
//
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса
//
Функция ПоставщикиУслуг(Период, Организация, Район, ТочкиУчета) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТочкиУчета.IDСтроки КАК IDСтроки,
	               |	ТочкиУчета.ТочкаУчета КАК ТочкаУчета
	               |ПОМЕСТИТЬ ВТ_ТУ
	               |ИЗ
	               |	&ТочкиУчета КАК ТочкиУчета
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ТУ.IDСтроки КАК IDСтроки,
	               |	бестПоставщикиУслугНПСрезПоследних.ЧастьСоставной КАК ЧастьСоставнойУслуги,
	               |	бестПоставщикиУслугНПСрезПоследних.Поставщик КАК Поставщик
	               |ИЗ
	               |	ВТ_ТУ КАК ВТ_ТУ
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестПоставщикиУслугНП.СрезПоследних(
	               |				&Период,
	               |				Организация = &Организация
	               |					И Район = &Район
	               |					И ТочкаУчета В
	               |						(ВЫБРАТЬ
	               |							ВТ_ТУ.ТочкаУчета
	               |						ИЗ
	               |							ВТ_ТУ КАК ВТ_ТУ)) КАК бестПоставщикиУслугНПСрезПоследних
	               |		ПО ВТ_ТУ.ТочкаУчета = бестПоставщикиУслугНПСрезПоследних.ТочкаУчета";
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ТочкиУчета", ТочкиУчета);
	Запрос.УстановитьПараметр("Период", Период);
	Возврат Запрос.Выполнить().Выбрать();
		
КонецФункции

