Процедура ДобавитьТекстЗапросабестАктивностьТочекУчетаНП(Схема, ИмяРегистра)
		
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	РеквизитыДокумента.Дата КАК Период,
	|	РеквизитыДокумента.Организация КАК Организация,
	|	РеквизитыДокумента.Район КАК Район,
	|	РеквизитыДокумента.Дата КАК ПериодРегистрации,
	|	РеквизитыДокумента.ПериодНачисления КАК ПериодНачисления,
	|	ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена) КАК Состояние,
	|	ТаблицаТочекУчета.ТочкаУчета КАК ТочкаУчета,
	|	РеквизитыДокумента.ОбъектРасчета КАК ОбъектРасчета
	|ИЗ
	|	РеквизитыДокумента КАК РеквизитыДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК ТаблицаТочекУчета
	|		ПО РеквизитыДокумента.Ссылка = ТаблицаТочекУчета.Ссылка
	|ГДЕ
	|	РеквизитыДокумента.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.ОперацияСУслугами_ПодключениеУслуги), ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.ОперацияСУслугами_ПодключениеУслугиПослеТП))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеквизитыДокумента.Дата,
	|	РеквизитыДокумента.Организация,
	|	РеквизитыДокумента.Район,
	|	РеквизитыДокумента.Дата,
	|	РеквизитыДокумента.ПериодНачисления,
	|	ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Отключена),
	|	ТаблицаТочекУчета.ТочкаУчета,
	|	РеквизитыДокумента.ОбъектРасчета
	|ИЗ
	|	РеквизитыДокумента КАК РеквизитыДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК ТаблицаТочекУчета
	|		ПО РеквизитыДокумента.Ссылка = ТаблицаТочекУчета.Ссылка
	|ГДЕ
	|	РеквизитыДокумента.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.ОперацияСУслугами_ОтключениеУслуги)";		
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
