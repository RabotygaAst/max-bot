		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСУслугамиНП.Потери КАК бестОперацияСУслугамиНППотери
		|		ПО ВТ_ТУ.Ссылка = бестОперацияСУслугамиНППотери.Ссылка
		|			И ВТ_ТУ.IDСтроки = бестОперацияСУслугамиНППотери.IDСтроки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТУ.Период КАК Период,
		|	ВТ_ТУ.Организация КАК Организация,
		|	ВТ_ТУ.Район КАК Район,
		|	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
		|	ВТ_ТУ.Услуга КАК Услуга,
		|	ВЫБОР
		|		КОГДА бестОперацияСУслугамиНППоставщикиСоставныхУслуг.Поставщик ЕСТЬ NULL
		|			ТОГДА ВТ_ТУ.Услуга
		|		ИНАЧЕ бестОперацияСУслугамиНППоставщикиСоставныхУслуг.ЧастьСоставнойУслуги
		|	КОНЕЦ КАК ЧастьСоставной,
		|	ВЫБОР
		|		КОГДА бестОперацияСУслугамиНППоставщикиСоставныхУслуг.Поставщик ЕСТЬ NULL
		|			ТОГДА ВТ_ТУ.Поставщик
		|		ИНАЧЕ бестОперацияСУслугамиНППоставщикиСоставныхУслуг.Поставщик
		|	КОНЕЦ КАК Поставщик,
		|	ВТ_ТУ.ПоставщикПокупатель КАК ПоставщикПокупатель,
		|	ВТ_ТУ.МКД КАК МКД,
		|	ВТ_ТУ.ОбъектРасчета КАК ОбъектРасчета
		|ИЗ
		|	ВТ_ТУ КАК ВТ_ТУ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестОперацияСУслугамиНП.ПоставщикиСоставныхУслуг КАК бестОперацияСУслугамиНППоставщикиСоставныхУслуг
		|		ПО ВТ_ТУ.Ссылка = бестОперацияСУслугамиНППоставщикиСоставныхУслуг.Ссылка
		|			И ВТ_ТУ.IDСтроки = бестОперацияСУслугамиНППоставщикиСоставныхУслуг.IDСтроки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТУ.Период КАК Период,
		|	ВТ_ТУ.Организация КАК Организация,
		|	ВТ_ТУ.Район КАК Район,
		|	ВТ_ТУ.ПериодРегистрации КАК ПериодРегистрации,
		|	ВТ_ТУ.ПериодНачисления КАК ПериодНачисления,
		|	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
		|	ВТ_ТУ.ОбъектРасчета КАК ОбъектРасчета,
		|	ВТ_ТУ.РасчетТолькоПоПоказаниям КАК РасчетТолькоПоПоказаниям
		|ИЗ
		|	ВТ_ТУ КАК ВТ_ТУ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТУ.Период КАК Период,
		|	ВТ_ТУ.Организация КАК Организация,
		|	ВТ_ТУ.Район КАК Район,
		|	ВТ_ТУ.ОбъектРасчета КАК ОбъектРасчета,
		|	МАКСИМУМ(ВТ_ТУ.ТипТарифа) КАК ТипТарифа,
		|	ВТ_ТУ.ПериодРегистрации КАК ПериодРегистрации,
		|	ВТ_ТУ.ПериодНачисления КАК ПериодНачисления,
		|	ВТ_ТУ.МКД КАК МКД
		|ИЗ
		|	ВТ_ТУ КАК ВТ_ТУ
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ТУ.Период,
		|	ВТ_ТУ.Организация,
		|	ВТ_ТУ.Район,
		|	ВТ_ТУ.ОбъектРасчета,
		|	ВТ_ТУ.ПериодРегистрации,
		|	ВТ_ТУ.ПериодНачисления,
		|	ВТ_ТУ.МКД";
		
		
	Запрос.Текст = Текст;
	
	Возврат Запрос.ВыполнитьПакетСПромежуточнымиДанными(); 
КонецФункции

