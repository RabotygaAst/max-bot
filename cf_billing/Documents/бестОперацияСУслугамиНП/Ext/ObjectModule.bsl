	Запрос.Текст  	= 
	"ВЫБРАТЬ
	|	бестОперацияСУслугамиНПТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	""ТочкиУчета"" КАК ИмяТабЧасти,
	|	0 КАК Разделитель,
	|	бестОперацияСУслугамиНПТочкиУчета.ОбъектРасчета КАК ОбъектРасчета
	|ИЗ
	|	Документ.бестОперацияСУслугамиНП.ТочкиУчета КАК бестОперацияСУслугамиНПТочкиУчета";
	
	ДополнительныеСвойства.Вставить("МассивОбъектовРасчета",Запрос.Выполнить());

	
КонецФункции

Функция ДанныеШапки()
	ДанныеШапки = Новый Структура;
	ДанныеШапки.Вставить("Период",					?(ЗначениеЗаполнено(ДатаФактическогоСобытия),КонецДня(ДатаФактическогоСобытия),Дата));
	ДанныеШапки.Вставить("Район",					Район);
	ДанныеШапки.Вставить("Организация",				Организация);
	ДанныеШапки.Вставить("ПериодРегистрации",		Дата);
	ДанныеШапки.Вставить("ПериодНачисления",		ПериодНачисления);
	ДанныеШапки.Вставить("ТочкиУчета",				ТочкиУчета);
	ДанныеШапки.Вставить("Отключение",				?(ВидОперации=Перечисления.бестВидыОпераций.ОперацияСУслугами_ОтключениеУслуги,истина,ложь));
	ДанныеШапки.Вставить("ИмяДокумента",			"бестОперацияСУслугамиНП");
	ДанныеШапки.Вставить("Документ",				Ссылка);
	ДанныеШапки.Вставить("ОбъектРасчета",			ОбъектРасчета);
	//ДанныеШапки.Вставить("Контрагент",				Договор.Контрагент);
 	ДанныеШапки.Вставить("Дата",					Дата);
	
	Возврат ДанныеШапки;	
КонецФункции

Функция ФормулыРасчетаУслуг();
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	ТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	ФормулыРасчетаУслуг.Услуга КАК Услуга,
	|	ФормулыРасчетаУслуг.ФормулаРасчета КАК ФормулаРасчета
	|ИЗ
	|	Документ.бестОперацияСУслугамиНП.ТочкиУчета КАК ТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСУслугамиНП.ФормулыРасчетаУслуг КАК ФормулыРасчетаУслуг
	|		ПО ТочкиУчета.Ссылка = ФормулыРасчетаУслуг.Ссылка
	|			И ТочкиУчета.IDСтроки = ФормулыРасчетаУслуг.IDСтрокиТочкиУчета
	|			И (ТочкиУчета.Ссылка = &Ссылка)
	|			И (ФормулыРасчетаУслуг.Ссылка = &Ссылка)";
	
	Возврат Запрос.Выполнить();	
	
КонецФункции

Функция СоставУзлаКорректен()
	
	Данные = Новый Структура;
	Данные.Вставить("Период",					Новый Граница(МоментВремени(),ВидГраницы.Исключая));
	Данные.Вставить("Район",					Район);
	Данные.Вставить("Организация",			    Организация);		
	Данные.Вставить("ОбъектРасчета",			ОбъектРасчета); 
	Данные.Вставить("Ссылка",					Ссылка);
	
	Возврат энргРаботаСприборамиУчетаСервер.СоставУзлаКорректенНП(Данные);
	 	
КонецФункции

