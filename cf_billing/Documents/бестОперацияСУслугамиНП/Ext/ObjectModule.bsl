#Область Подключение_Услуги

Процедура ОперацииПриПодключенииУслуги(ДанныеШапки)
	Пакет = ПолучитьДанныеТЧ();
	
	ДанныеТочекУчета				= Пакет[0];
	СостоянияУзлов					= Пакет[1];
	ДанныеПриборовУзловУчета		= Пакет[2];
	ДанныеПоказанийПриборовУчета 	= Пакет[3];
	ДанныеКаналовПриборовУчета		= Пакет[4];
	ДанныеСоставныхУслуг			= Пакет[5];
	ДанныеПараметрыИзмерителей		= Пакет[6];	
	ДанныеДоговоров					= Пакет[7];
	ДанныеКомУчета					= Пакет[8];
	ДанныеВведенныеПУУзлов			= Пакет[9];
	ДанныеНомераПломб				= Пакет[10];
	ДанныеПотери					= Пакет[11];
	ДанныеПоставщики				= Пакет[12];
	ДанныеРасчетТолькоПоПоказаниям	= Пакет[13];
	ДанныеТиповТарифа				= Пакет[14];
	
	//Пока СостоянияУзлов.Следующий Цикл
	//	ПУ = СостоянияУсзлов.ПриборУчета;
	//	Запрос = Новый Запрос;
	//	Запрос.Текст = 
	//	"ВЫБРАТЬ
	//	|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
	//	|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние КАК Состояние
	//	|ИЗ
	//	|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
	//	|			,
	//	|			ПриборУчета = &ПриборУчета
	//	|				И Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)) КАК бестСостояниеПриборовУчетаНПСрезПоследних"
	//	Запрос.УстановитьПараметры("ПриборУчета",ПУ);
	//	РезультатЗапроса = Запрос.Выполнить();
	//	Выборка = РезультатЗапроса.Выбрать();
	//	Если Выборка.Следующий() Тогда
	//		ОбщегоНазначения.СообщитьПользователю("Проведение отменено. Прибор учета" + Строка(ПУ) + "Уже активен на другой точке учета / объекте расчета. ");
	//		Возврат;
	//	КонецЕсли;
	//КонецЦикла;
	//
	// точки учета
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.энргВладельцыТочекУчета);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.бестУслугиТочекУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.бестАктивностьТочекУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.бестРасположениеТочекУчетаОтносительноГБП);	
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеСоставныхУслуг,	Движения.бестСпособНачисленияНормативаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.бестСтруктураСетиТочекУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.бестТочкиПоставкиТочекУчетаЮЛ);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.бестЦеновыеКатегорииТочекУчета);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТиповТарифа,		Движения.бестТипыТарифовТочекУчета);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.бестТарифныеСеткиТочекУчета);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.бестЗначенияСкидкиТочекУчета);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,		Движения.бестТехническаяВозможностьУстановкиПУ);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПоставщики,		Движения.бестПоставщикиУслугНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеРасчетТолькоПоПоказаниям, Движения.бестСвойствоРасчетТолькоПоПоказаниямТочекУчета);
	энргРаботаСТочкамиУчетаСервер.УстановитьФормулуРасчетаУслугТочкиУчетаМКД(Движения, ДанныеШапки, ФормулыРасчетаУслуг());
	
	
	
	
	//Узлы
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(СостоянияУзлов,	Движения.бестПриборыТочекУчетаНП);//Теперь это УЗЕЛ!
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(СостоянияУзлов,	Движения.бестСостояниеПриборовУчетаНП);//Теперь это состояние УЗЛА!  		
		
	// приборы учета
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеВведенныеПУУзлов,		Движения.бестПриборыУзловУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПараметрыИзмерителей,	Движения.бестПараметрыИзмерителей);
	
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовУзловУчета,		Движения.бестКоэффциентыПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовУзловУчета,		Движения.бестДатыПоверкиПрибораУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеКомУчета,					Движения.бестДопускПриборовУчетаККоммерческомуУчету);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПоказанийПриборовУчета,	Движения.бестПоказанияПриборовУчетаНП);	
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеКаналовПриборовУчета,		Движения.бестВидыДифференцированностиПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеДоговоров,				Движения.бестДоговорыТочекУчета);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеНомераПломб,				Движения.бестНомерПломбПриборовУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПотери,					Движения.бестПотериТочекУчета);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,				Движения.бестТУРассчитываемыеПоГрафикуГП);

	
	//бестРаботаСПоставщикамиПомещенийСервер.ЗаписатьПоставщикаУслуг(ДанныеШапки,Движения,"Поставщик");
	
КонецПроцедуры

Функция ПолучитьДанныеТЧ()
	Запрос  	= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",				Ссылка);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",		ОбъектРасчета);
	Запрос.УстановитьПараметр("МКД",				ОбъектРасчета.МКД);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Период",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия),ДатаФактическогоСобытия,Дата));
	Запрос.УстановитьПараметр("ПериодРегистрации",	Дата);  	
	Текст 		= 
		"ВЫБРАТЬ
		|	&Период КАК Период,
		|	&Организация КАК Организация,
		|	&Район КАК Район,
		|	&ОбъектРасчета КАК ОбъектРасчета,
		|	&ОбъектРасчета КАК АбонентВладелец,
		|	&МКД КАК МКД,
		|	&ПериодРегистрации КАК ПериодРегистрации,
		|	&ПериодНачисления КАК ПериодНачисления,
		|	ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена) КАК Состояние,
		|	ТаблицаТочкиУчета.ТочкаУчета КАК ТочкаУчета,
		|	ТаблицаТочкиУчета.Услуга КАК Услуга,
		|	ТаблицаТочкиУчета.ПриборУчета КАК ПриборУчета,
		|	ТаблицаТочкиУчета.НомерПломбы КАК НомерПломбы,
		|	ТаблицаТочкиУчета.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
		|	ТаблицаТочкиУчета.КоэффициентПУ КАК Коэффициент,
		|	ТаблицаТочкиУчета.ДатаПоверкиСчетчика КАК ДатаПоверки,
		|	ТаблицаТочкиУчета.СпособРасчетаНорматива КАК СпособРасчетаНорматива,
		|	ТаблицаТочкиУчета.IDСтроки КАК IDСтроки,
		|	ТаблицаТочкиУчета.Ссылка КАК Ссылка,
		|	ТаблицаТочкиУчета.ЭтоСоставнаяУслуга КАК ЭтоСоставнаяУслуга,
		|	ТаблицаТочкиУчета.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
		|	ТаблицаТочкиУчета.КонецДействияКоммерскогоУчета КАК КонецДействияКоммерскогоУчета,
		|	ТаблицаТочкиУчета.ГБП КАК ГБП,
		|	ТаблицаТочкиУчета.Договор КАК Договор,
		|	ТаблицаТочкиУчета.СтруктураСети КАК СтруктураСети,
		|	ТаблицаТочкиУчета.ЦеноваяКатегория КАК ЦеноваяКатегория,
		|	ТаблицаТочкиУчета.НетВозможностьУстановкиПУ КАК НетВозможностьУстановкиПУ,
		|	ТаблицаТочкиУчета.ТочкаПоставки КАК ТочкаПоставки,
		|	ТаблицаТочкиУчета.Поставщик КАК Поставщик,
		|	ТаблицаТочкиУчета.РасчетПоГрафикуГП КАК РасчетПоГрафикуГП,
		|	ТаблицаТочкиУчета.РасчетТолькоПоПоказаниям КАК РасчетТолькоПоПоказаниям,
		|	ТаблицаТочкиУчета.ПоставщикПокупатель КАК ПоставщикПокупатель,
		|	ТаблицаТочкиУчета.Техническая КАК Техническая,
		|	ТаблицаТочкиУчета.ТипТарифа КАК ТипТарифа,
		|	ТаблицаТочкиУчета.ТарифнаяСетка КАК ТарифнаяСетка,
		|	ТаблицаТочкиУчета.ЗначениеСкидки КАК ЗначениеСкидки
		|ПОМЕСТИТЬ ВТ_ТУ
		|ИЗ
		|	Документ.бестОперацияСУслугамиНП.ТочкиУчета КАК ТаблицаТочкиУчета
		|ГДЕ
		|	ТаблицаТочкиУчета.Ссылка = &ссылка
		|;
		|
