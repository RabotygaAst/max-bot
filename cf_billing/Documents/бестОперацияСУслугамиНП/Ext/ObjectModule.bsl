#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	Если ДополнительныеСвойства.свойство("ВосстановлениеПоследовательности") тогда
		Возврат;
	КонецЕсли;	
	
	Ответственный 				= Пользователи.ТекущийПользователь();		  
	
	бестПроведениеСерверНП.ПередЗаписьюОбъекта(ЭтотОбъект);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Если ЗначениеЗаполнено(ДатаФактическогоСобытия) Тогда
		Момент 			= Новый Граница(Новый МоментВремени(КонецДня(ДатаФактическогоСобытия), Ссылка), ВидГраницы.Исключая);
		СтрокаОтказа 	= "На дату фактического события";
	Иначе
		Момент 			= Новый Граница(МоментВремени(), ВидГраницы.Исключая);
		СтрокаОтказа 	= "На дату операции";
	КонецЕсли;	
		
	УслугиТочекОтлючены 	= Истина;
	ПриборыВыведены 		= Истина;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	бестПроведениеСерверНП.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	ДанныеШапки = ДанныеШапки();
	
	Если ВидОперации = Перечисления.бестВидыОпераций.ОперацияСУслугами_ПодключениеУслуги тогда
		Если Не СоставУзлаКорректен() Тогда
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		//ПроверкаНаличияНагрузокДоговора();
		
		// проверка если ПУ Уже активен в регистре бестСостояниеПриборовУчетаНП
		Пакет = ПолучитьДанныеТЧ();
		СостоянияУзлов					= Пакет[1];
		ВыборкаСостоянияУзлов = СостоянияУзлов.Выбрать();
		
		Пока ВыборкаСостоянияУзлов.Следующий() Цикл
			ПУ = ВыборкаСостоянияУзлов.ПриборУчета;
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	бестСостояниеПриборовУчетаНПСрезПоследних.ПриборУчета КАК ПриборУчета,
			|	бестСостояниеПриборовУчетаНПСрезПоследних.Состояние КАК Состояние
			|ИЗ
			|	РегистрСведений.бестСостояниеПриборовУчетаНП.СрезПоследних(
			|			,
			|			ПриборУчета = &ПриборУчета
			|				И Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)) КАК бестСостояниеПриборовУчетаНПСрезПоследних";
			Запрос.УстановитьПараметр("ПриборУчета",ПУ);
			РезультатЗапроса = Запрос.Выполнить();
			Выборка = РезультатЗапроса.Выбрать();
			Если Выборка.Следующий() Тогда
				ОбщегоНазначения.СообщитьПользователю("Проведение отменено. Прибор учета " + Строка(ПУ) + " Уже активен на другой точке учета / объекте расчета. ");
				Отказ = Истина;
				Возврат;
			КонецЕсли;
		КонецЦикла;
		
		ОперацииПриПодключенииУслуги(ДанныеШапки);
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСУслугами_ОтключениеУслуги тогда
		
		Для Каждого СтрокаТЧ Из ПоказанияПриборовУчета Цикл
			Если Не ЗначениеЗаполнено(СтрокаТЧ.ТекущиеПоказания) И Не СтрокаТЧ.ТекущиеПоказания = СтрокаТЧ.ПредыдущиеПоказания  Тогда
				Отказ = Истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнены текущие показания",ЭтотОбъект,"ПоказанияПриборовУчета["+(СтрокаТЧ.НомерСтроки-1)+"].ТекущиеПоказания");				
			КонецЕсли;	
		КонецЦикла;
		
		Если Отказ Тогда 
			Возврат;
		КонецЕсли;
		
		ОперацииПриОтключенииУслуги(ДанныеШапки);	
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСУслугами_ОграничениеУслуги Тогда
		ОперацииПриОграниченииУслуги(ДанныеШапки);
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСУслугами_ВозобновлениеУслуги Тогда
		ОперацииПриВозобновленииУслуги(ДанныеШапки);
	ИначеЕсли ВидОперации = Перечисления.бестВидыОпераций.ОперацияСУслугами_ПодключениеУслугиПослеТП Тогда
		Документы.бестОперацияСУслугамиНП.ИнициализироватьДанныеДокумента(Ссылка, ДополнительныеСвойства);
		бестПроведениеСерверНП.ЗаписатьНаборыЗаписей(ЭтотОбъект);
	КонецЕсли;   	
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
	Организация = Неопределено;
	
КонецПроцедуры

#КонецОбласти

