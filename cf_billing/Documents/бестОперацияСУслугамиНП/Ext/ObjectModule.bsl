#Область Отключение_Услуги

Процедура ОперацииПриОтключенииУслуги(ДанныеШапки)
	
	Пакет = ПолучитьДанныеТЧДляЗакрытия(Истина);
	ДанныеТочекУчета				= Пакет[0];
	ДанныеПриборовТУ				= Пакет[1];
	ДанныеПоказанийПриборовУчета	= Пакет[2];
 
	// Работа с точками учета
	
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,	Движения.бестАктивностьТочекУчетаНП);
	
	// Работа с узлами учета
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУ,	Движения.бестСостояниеПриборовУчетаНП);	

	// Работа с приборами учета
	//бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУ,	Движения.бестПриборыУзловУчетаНП);
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУ,	Движения.бестВыводПриборовУчетаНП);
	
	// показания приборов учета 
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПоказанийПриборовУчета,	Движения.бестПоказанияПриборовУчетаНП);

КонецПроцедуры

Функция ПолучитьДанныеТЧДляЗакрытия(НеУчитыватьФлаг = Истина)
	Запрос  	= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",				Ссылка);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",		ОбъектРасчета);
	Запрос.УстановитьПараметр("МКД",				ОбъектРасчета.МКД);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Период",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия),КонецДня(ДатаФактическогоСобытия),Дата));
	Запрос.УстановитьПараметр("ПериодДо",			Новый Граница(МоментВремени(),ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("ПериодРегистрации",	Дата);  	
	Запрос.УстановитьПараметр("НеУчитыватьФлаг",	НеУчитыватьФлаг);
	Текст 		= 
		"ВЫБРАТЬ
		|	&Период КАК Период,
		|	&Организация КАК Организация,
		|	&Район КАК Район,
		|	&ОбъектРасчета КАК ОбъектРасчета,
		|	&ОбъектРасчета КАК АбонентВладелец,
		|	&МКД КАК МКД,
		|	&ПериодРегистрации КАК ПериодРегистрации,
		|	&ПериодНачисления КАК ПериодНачисления,
		|	ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Отключена) КАК Состояние,
		|	ТаблицаТочкиУчета.Ссылка КАК Ссылка,
		|	ТаблицаТочкиУчета.IDСтроки КАК IDСтроки,
		|	ТаблицаТочкиУчета.ТочкаУчета КАК ТочкаУчета,
		|	ТаблицаТочкиУчета.Услуга КАК Услуга,
		|	ТаблицаТочкиУчета.УзелУчета КАК УзелУчета,
		|	ТаблицаТочкиУчета.УзелУчета.ТипУзлаУчета КАК ТипУзлаУчета,
		|	ТаблицаТочкиУчета.ПриборУчета КАК ПриборУчета,
		|	ТаблицаТочкиУчета.ПриборУчета.ТипПрибораУчета КАК ТипПрибораУчета
		|ПОМЕСТИТЬ ВТ_ТУ
		|ИЗ
		|	Документ.бестОперацияСУслугамиНП.ТочкиУчета КАК ТаблицаТочкиУчета
		|ГДЕ
		|	ТаблицаТочкиУчета.Ссылка = &ссылка
		|	И (ТаблицаТочкиУчета.Флаг
		|			ИЛИ &НеУчитыватьФлаг)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	&Период КАК Период,
		|	&Организация КАК Организация,
		|	&Район КАК Район,
		|	&ПериодРегистрации КАК ПериодРегистрации,
		|	&ПериодНачисления КАК ПериодНачисления,
		|	ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Вывод) КАК Состояние,
		|	ВТ_ТУ.Ссылка КАК Ссылка,
		|	ВТ_ТУ.ТочкаУчета КАК ТочкаУчета,
		|	ВТ_ТУ.АбонентВладелец КАК АбонентВладелец,
		|	ВТ_ТУ.ОбъектРасчета КАК ОбъектРасчета,
		|	ВТ_ТУ.Услуга КАК Услуга,
		|	ВТ_ТУ.ПриборУчета КАК ПриборУчета,
		|	ВТ_ТУ.IDСтроки КАК IDСтроки,
		|	ВТ_ТУ.IDСтроки КАК IDСтрокиШкалы,
		|	ВТ_ТУ.УзелУчета КАК УзелУчета,
		|	ВТ_ТУ.МКД КАК МКД,
		|	ВТ_ТУ.ТипПрибораУчета.Родитель КАК ТипИзмерителя,
		|	ВТ_ТУ.ТипУзлаУчета КАК ТипУзлаУчета
		|ПОМЕСТИТЬ ВТ_ПУ
		|ИЗ
		|	ВТ_ТУ КАК ВТ_ТУ
		|ГДЕ
		|	НЕ ВТ_ТУ.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ПУ.Период КАК Период,
		|	ВТ_ПУ.Организация КАК Организация,
		|	ВТ_ПУ.Район КАК Район,
		|	ВТ_ПУ.ПериодРегистрации КАК ПериодРегистрации,
		|	ВТ_ПУ.ПериодНачисления КАК ПериодНачисления,
		|	ВТ_ПУ.ТочкаУчета КАК ТочкаУчета,
		|	ВТ_ПУ.ПриборУчета КАК ПриборУчета,
		|	ТаблицаПоказанийПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ТаблицаПоказанийПриборовУчета.ТекущиеПоказания КАК Показание,
		|	ТаблицаПоказанийПриборовУчета.СостояниеПоказаний КАК СостояниеПоказаний,
		|	ТаблицаПоказанийПриборовУчета.ПричинаОтклонения КАК ПричинаОтклонения,
		|	ЛОЖЬ КАК КС,
		|	ТаблицаПоказанийПриборовУчета.Переворот КАК Переворот,
		|	ТаблицаПоказанийПриборовУчета.НомерСтроки КАК НомерСтрокиТЧ,
		|	ВТ_ПУ.ОбъектРасчета КАК ОбъектРасчета,
		|	ШкалыПриборовУчета.Шкала КАК Шкала
		|ПОМЕСТИТЬ ВТ_ПоказанияПУ
		|ИЗ
		|	ВТ_ПУ КАК ВТ_ПУ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСУслугамиНП.ШкалыПриборовУчета КАК ШкалыПриборовУчета
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестОперацияСУслугамиНП.ПоказанияПриборовУчета КАК ТаблицаПоказанийПриборовУчета
		|			ПО ШкалыПриборовУчета.Ссылка = ТаблицаПоказанийПриборовУчета.Ссылка
		|				И ШкалыПриборовУчета.IDСтроки = ТаблицаПоказанийПриборовУчета.IDСтроки
		|				И (ТаблицаПоказанийПриборовУчета.Ссылка = &ссылка)
		|		ПО ВТ_ПУ.Ссылка = ШкалыПриборовУчета.Ссылка
		|			И ВТ_ПУ.IDСтрокиШкалы = ШкалыПриборовУчета.IDСтрокиТочкиУчета
		|			И (ШкалыПриборовУчета.Ссылка = &ссылка)";
	
		
	Запрос.Текст = Текст;
	
	Возврат Запрос.ВыполнитьПакетСПромежуточнымиДанными(); 
КонецФункции

