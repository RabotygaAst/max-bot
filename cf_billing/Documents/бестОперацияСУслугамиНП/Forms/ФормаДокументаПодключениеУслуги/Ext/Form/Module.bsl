&НаКлиенте
Процедура ЗаполнитьНастройкиФормированияАвансовыхСФ(Команда)
	ЗаполнитьНаСервере(); 
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере()
	ТекТЧ	= Объект.НастройкиФормированияАвансовыхСФПоУслугамДоговоровКонтрагентов;
	НовТЗ   = Объект.ТочкиУчета.Выгрузить();
	НовТЗ.Свернуть("Услуга");
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(объект.ДатаФактическогоСобытия), объект.ДатаФактическогоСобытия, объект.Дата));
	Запрос.УстановитьПараметр("Организация",Объект.Организация);
	Запрос.УстановитьПараметр("Район",Объект.Район);
	Запрос.УстановитьПараметр("НовТЗ",НовТЗ);
	Запрос.Текст = "ВЫБРАТЬ
	|	НовТЗ.Услуга КАК Услуга
	|ПОМЕСТИТЬ ВрТ0
	|ИЗ
	|	&НовТЗ КАК НовТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВрТ0.Услуга КАК Услуга,
	|	ЕСТЬNULL(бестНастройкиФормированияАвансовыхСФПоУслугамСрезПоследних.Формировать, ЛОЖЬ) КАК Формировать
	|ИЗ
	|	ВрТ0 КАК ВрТ0
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестНастройкиФормированияАвансовыхСФПоУслугам.СрезПоследних(
	|				&Дата,
	|				Организация = &Организация
	|					И Район = &Район) КАК бестНастройкиФормированияАвансовыхСФПоУслугамСрезПоследних
	|		ПО ВрТ0.Услуга = бестНастройкиФормированияАвансовыхСФПоУслугамСрезПоследних.Услуга";
	Результат = Запрос.Выполнить();
	Выгрузка = Результат.Выгрузить();
	ТекТЧ.Загрузить(Выгрузка);
КонецПроцедуры

