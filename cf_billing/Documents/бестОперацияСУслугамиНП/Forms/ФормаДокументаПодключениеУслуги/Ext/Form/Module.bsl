&НаКлиенте
Процедура ТочкиУчетаПриИзменении(Элемент)
	
	ТекущиеДанные 							= Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.IDОбъектаРасчета = ПолучитьГУИДОбъектаРасчета();
	
	ТочкиУчетаПриИзмененииСервер(ТекущиеДанные.IDОбъектаРасчета);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ТарифныеКатегорииУслуги, Неопределено, ТекущиеДанные.IDОбъектаРасчета);
КонецПроцедуры

&НаСервере
Процедура ТочкиУчетаПриИзмененииСервер(IDСтроки)	
	бестРаботаСТочкамиУчетаНПСервер.ОбновитьГруппыПотребителейУслуги(ЭтотОбъект, IDСтроки,,"IDОбъектаРасчета");	
КонецПроцедуры

&НаСервере
Функция ПолучитьГУИДОбъектаРасчета()
	Возврат Объект.ОбъектРасчета.УникальныйИдентификатор();
КонецФункции

&НаКлиенте
Процедура ТочкиУчетаНачалоДействияКоммерскогоУчетаПриИзменении(Элемент)
	ТекСтрока = Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекСтрока.КонецДействияКоммерскогоУчета) И ТекСтрока.КонецДействияКоммерскогоУчета < ТекСтрока.НачалоДействияКоммерскогоУчета  Тогда
		ТекСтрока.НачалоДействияКоммерскогоУчета = Неопределено;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Начало действия не может быть позже конца действия коммерческого учета."); 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаКонецДействияКоммерскогоУчетаПриИзменении(Элемент)
	ТекСтрока = Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекСтрока.НачалоДействияКоммерскогоУчета) И ЗначениеЗаполнено(ТекСтрока.КонецДействияКоммерскогоУчета)
			И ТекСтрока.КонецДействияКоммерскогоУчета < ТекСтрока.НачалоДействияКоммерскогоУчета  Тогда
		ТекСтрока.КонецДействияКоммерскогоУчета = Неопределено;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Конец действия не может быть раньше начала действия коммерческого учета."); 
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаДоговорНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	Если не ТекущиеДанные.ЭтоСоставнаяУслуга тогда
		Возврат
	КонецЕсли;	
	СтандартнаяОбработка 		= Ложь;
	энргРаботаСПоставщикамиКлиент.ПоставщикАвтоПодбор(ЭтаФорма,ТекущиеДанные,Новый Структура("ИмяСвойстваПоставщик","Договор"),"ДоговорыСоставныхУслуг","бестФормаВыбораДоговоров","ПараметрыДоговоров");

КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаДоговорАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	энргРаботаСПоставщикамиКлиент.ПоставщикАвтоПодбор(ЭтаФорма,ТекущиеДанные,Новый Структура("ИмяСвойстваПоставщик","Договор"),"ДоговорыСоставныхУслуг","бестФормаВыбораДоговоров","ПараметрыДоговоров");
КонецПроцедуры

