#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		Объект.Дата = ТекущаяДата();
	КонецЕсли;
  
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		ЗаполнитьПериодНачисленияСервер();
	КонецЕсли;
	
	ЗаполнитьДокумент  = Ложь;
	Если Параметры.Свойство("ЗаполнитьДокумент") Тогда
		ЗаполнитьДокумент = Параметры.ЗаполнитьДокумент;
	КонецЕсли;
	Если ЗаполнитьДокумент И ЗначениеЗаполнено(Объект.ОбъектРасчета) Тогда
		ЗаполнитьТаблицуТочкиУчета();
	КонецЕсли;
	
	// энргРаботаСПоставщиками {
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма);
	// энргРаботаСПоставщиками }
	
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма, "Договор", "ДоговорыСоставныхУслуг", "ПараметрыДоговоров");
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	бестРаботаСФормойДоговораНезависимыйСбыт.УстановитьСвойстваЭлементаРегион(ЭтотОбъект);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДоговорФилиал", "Видимость", Не бестРаботаСНезависимымСбытом.ПолучитьУчетНезависимыйСбыт());

	бестЛокализацияСервер.ПриСозданииНаСервере_бестОперацияСУслугамиНП(ЭтотОбъект, Объект.Ссылка); 
	ПриСозданииНаСервереПереопределяемый(Отказ, СтандартнаяОбработка);  
	
КонецПроцедуры 

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	энргРаботаСТочкамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьПоНП(Объект.Организация, Объект.ПериодНачисления,Объект.Район,Объект.ОбъектРасчета);
	
	энргРаботаСТочкамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
	
	бестЛокализацияСервер.ПослеЗаписиНаСервере_бестОперацияСУслугамиНП(ЭтотОбъект, Объект.Ссылка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия) Тогда
		Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение И НачалоДня(Объект.Дата) <> Объект.ДатаФактическогоСобытия Тогда 
			ОписаниеОповещения  = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПроведения",ЭтотОбъект);
			ПоказатьВопрос(ОписаниеОповещения,"Дата документа отличается от фактической даты! Провести документ?",РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ЗаполнитьАдресОбъекта();
КонецПроцедуры

#Конецобласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		ЗаполнитьПериодНачисленияСервер();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	бестРаботаСВидамиОперацийКлиент.ПриИзмененииВидаОперации("бестОперацияСУслугамиНП",Объект,Параметры.Ключ);
	Модифицированность = Ложь;
	ЭтаФорма.Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	РайонПриИзмененииСервер();
КонецПроцедуры 

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	ЗаполнитьПериодНачисленияСервер();
КонецПроцедуры

&НаКлиенте
Процедура ОбъектРасчетаПриИзменении(Элемент)
	ЗаполнитьАдресОбъекта();
	ЗаполнитьТаблицуТочкиУчета();
	
	ПараметрыЗапроса = Новый Структура("Период, Организация, Район, ОбъектРасчета",Объект.Дата,Объект.Организация,Объект.Район,Объект.ОбъектРасчета);
	мТочекПоставок = бестРаботаСТочкамиУчетаНПСервер.ПолучитьМассивТочекПоставки(ПараметрыЗапроса);
	ТочкиПоставкиОбъекта.Очистить();
	ТочкиПоставкиОбъекта.ЗагрузитьЗначения(мТочекПоставок);
	
	ЗаполнитьПредставлениеПоставщика(); 	
	УстановитьУсловноеОФормлениеФормыКлиент("Поставщик", "ПараметрыПоставщиков");
	ЗаполнитьПредставлениеДоговор(); 	
	УстановитьУсловноеОФормлениеФормыКлиент("Договор", "ПараметрыДоговоров");
	
	ОбъектРасчетаПриИзмененииПереопределяемый(Элемент);
КонецПроцедуры

#Конецобласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТочкиУчета

&НаКлиенте
Процедура ТочкиУчетаТочкаПоставкиПриИзменении(Элемент)
	ТекущиеДанные 						= Элементы.ТочкиУчета.ТекущиеДанные;
	ТочкаПоставки 						= ТекущиеДанные.ТочкаПоставки;
	ТекущиеДанные.СтруктураСети 		= ПолучитьСтруктуруСетиТочкиПоставки(ТочкаПоставки);
	ТекущиеДанные.ДанныеРасположения 	= ПолучитьСхемуПрисоединения(ТекущиеДанные.СтруктураСети);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТочкаПоставкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	Элемент.СписокВыбора.ЗагрузитьЗначения(ТочкиПоставкиОбъекта.ВыгрузитьЗначения());
КонецПроцедуры

#Конецобласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьПериодНачисленияСервер()
	Объект.ПериодНачисления = Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);	
КонецПроцедуры

&НаСервере
Процедура РайонПриИзмененииСервер()
	Объект.Организация = Объект.Район.Организация;
	ЗаполнитьПериодНачисленияСервер();
КонецПроцедуры	

&НаКлиенте
Процедура ПослеЗакрытияВопросаПроведения(РезультатВопроса,ДополнительныеПараметры) Экспорт
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если  РезультатВопроса = КодВозвратаДиалога.Нет тогда
			Отказ = Истина;
		КонецЕсли; 		
	КонецЕсли;	
КонецПроцедуры

// энргРаботаСПоставщиками {
&НаКлиенте
Процедура УстановитьУсловноеОФормлениеФормыКлиент(ИмяСвойства=Неопределено, ИмяРеквизитаФормы="ПараметрыПоставщиков") Экспорт  
	УстановитьУсловноеОФормлениеФормыСервер(ИмяСвойства,ИмяРеквизитаФормы);
КонецПроцедуры
// энргРаботаСПоставщиками }

// энргРаботаСПоставщиками {
&НаСервере
Процедура УстановитьУсловноеОФормлениеФормыСервер(ИмяСвойства, ИмяРеквизитаФормы="ПараметрыПоставщиков")
	энргРаботаСПоставщикамиСервер.УстановитьУсловноеОФормлениеФормы(ЭтаФорма,ИмяСвойства,ИмяРеквизитаФормы);
КонецПроцедуры
// энргРаботаСПоставщиками }

&НаСервере
Функция ПолучитьСхемуПрисоединения(ТекСтруктураСети)
	Возврат Справочники.бестСтруктураСети.ПолучитьСхемуПрисоединения(ТекСтруктураСети);
КонецФункции

&НаСервере
Функция ПолучитьСтруктуруСетиТочкиПоставки(ТекТочка)
	мТочек = Новый Массив;
	мТочек.Добавить(ТекТочка);
	РезультатЗапроса = РегистрыСведений.энргПараметрыТочекПоставки.АктуальныеПараметрыТочкиПоставкиПоСсылке(мТочек);
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.СтруктураСети;
	КонецЦикла;
КонецФункции

&НаКлиенте
Процедура ЗаполнитьАдресОбъекта()
	Если ЗначениеЗаполнено(Объект.ОбъектРасчета) Тогда
		АдресОбъекта = бестРаботаСОбъектамиНПВызовСервера.ВернутьАдресОбъектаРасчета(Объект.ОбъектРасчета);
	КонецЕсли;   
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуТочкиУчета()
	ВыборкаТУ = Документы.бестОперацияСУслугамиНП.ТочкиУчетаДоТП(Объект.Дата, Объект.Организация, Объект.Район, Объект.ОбъектРасчета);
	Объект.ТочкиУчета.Очистить();
	Пока ВыборкаТУ.Следующий() Цикл
		СтрокаТУ = Объект.ТочкиУчета.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТУ, ВыборкаТУ);
		СтрокаТУ.IDСтроки = Новый УникальныйИдентификатор;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПредставлениеПоставщика() 
	
	ПоставщикиУслуг = ЗаполнитьПредставлениеПоставщикаНаСервере();	
	ПредставлениеПоставщика = "";
	Для Каждого СтрокаПоставщики из ПоставщикиУслуг цикл
		СтрокаТЧПоставщики = Объект.ПоставщикиСоставныхУслуг.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧПоставщики, СтрокаПоставщики);
		ПредставлениеПоставщика 		= ПредставлениеПоставщика + ?(ЗначениеЗаполнено(ПредставлениеПоставщика),"/","") +  Строка(СтрокаПоставщики.Поставщик);
		ДанныеСоставныхУслуг	= ПараметрыПоставщиков.ДанныеСоставныхУслуг;
		ИмяПоля					= "Поставщик";
		Если ДанныеСоставныхУслуг.Получить(СтрокаПоставщики.IDСтроки) = Неопределено тогда
			ДанныеСоставныхУслуг.Вставить(СтрокаПоставщики.IDСтроки, Новый Структура(ИмяПоля, ПредставлениеПоставщика));
		ИначеЕсли ДанныеСоставныхУслуг[СтрокаПоставщики.IDСтроки][ИмяПоля] = Неопределено тогда
			ДанныеСоставныхУслуг[СтрокаПоставщики.IDСтроки].вставить(ИмяПоля, ПредставлениеПоставщика);
		иначе
			ДанныеСоставныхУслуг[СтрокаПоставщики.IDСтроки][ИмяПоля] 	= ПредставлениеПоставщика; 
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ЗаполнитьПредставлениеПоставщикаНаСервере() 
	
	ТочкиУчета = Объект.ТочкиУчета.Выгрузить(,"IDСтроки, ТочкаУчета");
	Выборка = Документы.бестОперацияСУслугамиНП.ПоставщикиУслуг(Объект.Дата, Объект.Организация, Объект.Район, ТочкиУчета);
	Поставщики = Новый Массив;
	Пока Выборка.Следующий() Цикл
		Структура = Новый Структура("IDСтроки, ЧастьСоставнойУслуги, Поставщик");
		ЗаполнитьЗначенияСвойств(Структура, Выборка);
		Поставщики.Добавить(Структура);
	КонецЦикла;
	Возврат Поставщики;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьПредставлениеДоговор() 
	
	ДоговорыУслуг = ЗаполнитьПредставлениеДоговораНаСервере();	
	ПредставлениеДоговора = "";
	Для Каждого СтрокаДоговоры из ДоговорыУслуг цикл
		СтрокаТЧДоговоры = Объект.ДоговорыСоставныхУслуг.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧДоговоры, СтрокаДоговоры);
		ПредставлениеДоговора 		= ПредставлениеДоговора + ?(ЗначениеЗаполнено(ПредставлениеДоговора),"/","") +  Строка(СтрокаДоговоры.Договор);
		ДанныеСоставныхУслуг	= ПараметрыДоговоров.ДанныеСоставныхУслуг;
		ИмяПоля					= "Договор";
		Если ДанныеСоставныхУслуг.Получить(СтрокаДоговоры.IDСтроки) = Неопределено тогда
			ДанныеСоставныхУслуг.Вставить(СтрокаДоговоры.IDСтроки, Новый Структура(ИмяПоля, ПредставлениеДоговора));
		ИначеЕсли ДанныеСоставныхУслуг[СтрокаДоговоры.IDСтроки][ИмяПоля] = Неопределено тогда
			ДанныеСоставныхУслуг[СтрокаДоговоры.IDСтроки].вставить(ИмяПоля, ПредставлениеДоговора);
		иначе
			ДанныеСоставныхУслуг[СтрокаДоговоры.IDСтроки][ИмяПоля] 	= ПредставлениеДоговора; 
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ЗаполнитьПредставлениеДоговораНаСервере() 
	
	ТочкиУчета = Объект.ТочкиУчета.Выгрузить(,"IDСтроки, ТочкаУчета");
	Выборка = Документы.бестОперацияСУслугамиНП.ДоговорыУслуг(Объект.Дата, Объект.Организация, Объект.Район, ТочкиУчета);
	Договоры = Новый Массив;
	Пока Выборка.Следующий() Цикл
		Структура = Новый Структура("IDСтроки, ЧастьСоставнойУслуги, Договор");
		ЗаполнитьЗначенияСвойств(Структура, Выборка);
		Договоры.Добавить(Структура);
	КонецЦикла;
	Возврат Договоры;
	
КонецФункции

