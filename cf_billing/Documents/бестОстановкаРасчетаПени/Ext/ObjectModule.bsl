#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	Ответственный = Пользователи.ТекущийПользователь();
	энргДатаПоследнегоИзменения	= ТекущаяДата();

	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	бестПроведениеСерверНП.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);  	
	
	Если ЗначениеЗаполнено(Договоры) Тогда
		бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеОстановки(),		Движения.бестОстановленныеРасчетыПени);
	Иначе
		Запись  						= Движения.бестОстановленныеРасчетыПени.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Ссылка);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДанныеОстановки()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестОстановкаРасчетаПениДоговоры.Договор КАК Договор,
	//|	бестОстановкаРасчетаПениДоговоры.Ссылка.Дата КАК Период,
	|	бестОстановкаРасчетаПениДоговоры.Ссылка.Организация КАК Организация,
	|	бестОстановкаРасчетаПениДоговоры.Ссылка.От КАК От,
	|	бестОстановкаРасчетаПениДоговоры.Ссылка.До КАК До,
	|	бестОстановкаРасчетаПениДоговоры.Ссылка.Район КАК Район
	|ИЗ
	|	Документ.бестОстановкаРасчетаПени.Договоры КАК бестОстановкаРасчетаПениДоговоры
	|ГДЕ
	|	бестОстановкаРасчетаПениДоговоры.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить();
	
КонецФункции

#КонецОбласти

