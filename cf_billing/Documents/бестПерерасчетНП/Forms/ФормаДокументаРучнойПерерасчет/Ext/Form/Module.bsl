#Область ВспомогательныеПроцедурыИФункции


&НаКлиенте
Процедура ВыборУслугиИТочкиУчета(ТекДанные)
	//СтруктураОтбора = Новый Структура("Период,Организация,Район,ОбъектРасчета,IDСтроки,ПриборУчета,ПростыеУслуги,Поставщик",ТекДанные.ПериодНачисления);
	СтруктураОтбора = Новый Структура("Период,Организация,Район,ОбъектРасчета,ПростыеУслуги");
	//ЗаполнитьЗначенияСвойств(СтруктураОтбора,ТекДанные);
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,Объект);
	СтруктураОтбора.ОбъектРасчета 	= ТекДанные.ОбъектРасчета;
	СтруктураОтбора.Период 			= Объект.Дата;
	СтруктураОтбора.ПростыеУслуги	= Истина;
	//СтруктураОтбора.Вставить("ТарифнаяЗона", 		?(ИспользоватьТарифныеЗоны, ТекДанные.ТарифнаяЗона, ПредопределенноеЗначение("Справочник.энргТарифныеЗоны.БезРазбивки")));
	
	ПараметрыВыбораФормы	= Новый Структура("СтруктураОтбора,ТипВладельца,ВыводитьСоставные", СтруктураОтбора, "НП",Ложь);
	ОписаниеОповещения 		= Новый ОписаниеОповещения("ТочкаУчетаОкончаниеВыбора",ЭтаФорма,Новый Структура("СтруктураОтбора, ТекДанные", СтруктураОтбора, ТекДанные));
	
	ОткрытьФорму("ОбщаяФорма.бестФормаВыбораТочкиУчета",ПараметрыВыбораФормы,,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

&НаКлиенте
Процедура ТочкаУчетаОкончаниеВыбора(РезультатЗакрытия,ДополнительныеПараметры) Экспорт  
	
	Если РезультатЗакрытия <> Неопределено Тогда 
		ТекДанные		= ДополнительныеПараметры.ТекДанные;
		СтруктураОтбора	= ДополнительныеПараметры.СтруктураОтбора;
		СтруктураОтбора.Вставить("ТочкаУчета", 	РезультатЗакрытия.ТочкаУчета);
		СтруктураОтбора.Вставить("Услуга", 		РезультатЗакрытия.Услуга);
		
		СтруктураОтбора.Вставить("Поставщик", 	ТекДанные.Поставщик);
		СтруктураОтбора.Вставить("ТарифнаяЗона",ТекДанные.ТарифнаяЗона);
		
		ТочкаУчетаОкончаниеВыбораНаСервере(СтруктураОтбора);
		ЗаполнитьЗначенияСвойств(ТекДанные, СтруктураОтбора);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ТочкаУчетаОкончаниеВыбораНаСервере(СтруктураОтбора)  	
	
		ПараметрыСхемы		= Новый Структура;
		Схема 							= Неопределено;
		ПараметрыВТ 					= Новый Массив;
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("Организация", 		"Организация"), 	Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("Район", 			"Район"), 			Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("ОбъектРасчета", 	"ОбъектРасчета"), 		Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("Услуга",	 		"Услуга"), 			Неопределено));		
		
		ПараметрыСхемы.Вставить("Период", 			Новый Структура("ИмяПараметра", "Период"));
		ПараметрыСхемы.Вставить("ПараметрыВТ", 		ПараметрыВТ);
		
		РегистрыСведений.бестТарифныеКатегорииНП.ТарифнаяКатегорияЮЛ(Схема,ПараметрыСхемы,"");
		ПараметрыЗапроса 				= Новый Структура;
		ПараметрыЗапроса.Вставить("Организация", 	СтруктураОтбора.Организация);
		ПараметрыЗапроса.Вставить("Район", 			СтруктураОтбора.Район);
		ПараметрыЗапроса.Вставить("ОбъектРасчета", 	СтруктураОтбора.ОбъектРасчета);
		ПараметрыЗапроса.Вставить("Услуга", 		СтруктураОтбора.Услуга);
		ПараметрыЗапроса.Вставить("Период", 		СтруктураОтбора.Период);
		
		Результат 						= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
		Выборка 						= Результат.Выбрать();
		
		Если Выборка.Следующий() Тогда
			СтруктураОтбора.Вставить("ТарифнаяГруппа", 		Выборка.ТарифнаяКатегория);
			
		ПараметрыСхемы		= Новый Структура;
		Схема 							= Неопределено;
		ПараметрыВТ 					= Новый Массив;
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("Организация", 		"Организация"), 	Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("Район", 			"Район"), 			Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("ГруппаПотребителей","ГруппаПотребителей"), 		Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("Услуга",	 		"Услуга"), 			Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("Поставщик", 		"Поставщик"), 	Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("ТарифнаяЗона",	 	"ТарифнаяЗона"), 			Неопределено));
		
		ПараметрыСхемы.Вставить("Период", 			Новый Структура("ИмяПараметра", "Период"));
		ПараметрыСхемы.Вставить("ПараметрыВТ", 		ПараметрыВТ);
		
		
		РегистрыСведений.энргЗначенияТарифов.ЗначенияТарифов(Схема,ПараметрыСхемы,"");
		ПараметрыЗапроса 				= Новый Структура;
		ПараметрыЗапроса.Вставить("Организация", 	СтруктураОтбора.Организация);
		ПараметрыЗапроса.Вставить("Район", 			СтруктураОтбора.Район);
		ПараметрыЗапроса.Вставить("ГруппаПотребителей", 		Выборка.ТарифнаяКатегория);
		Если НЕ ЗначениеЗаполнено(СтруктураОтбора.ТарифнаяЗона) Тогда
			СтруктураОтбора.ТарифнаяЗона = Справочники.энргТарифныеЗоны.БезРазбивки;
		КонецЕсли;
		ПараметрыЗапроса.Вставить("ТарифнаяЗона", 	СтруктураОтбора.ТарифнаяЗона);
		ПараметрыЗапроса.Вставить("Услуга", 		СтруктураОтбора.Услуга);
		ПараметрыЗапроса.Вставить("Поставщик", 		СтруктураОтбора.Поставщик);
		ПараметрыЗапроса.Вставить("Период", 		СтруктураОтбора.Период);
		
		Результат 						= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
		Выборка 						= Результат.Выбрать();
		
		Если Выборка.Следующий() Тогда
			СтруктураОтбора.Вставить("ЗначениеТарифа", 	Выборка.Значение);
			СтруктураОтбора.Вставить("СтавкаНДС", 		Выборка.СтавкаНДС);
			СтруктураОтбора.Вставить("НДСВнутри", 		Выборка.НДСВнутри);
		КонецЕсли;
	КонецЕсли;
	
	РезультатЗапроса = РегистрыСведений.бестДоговорыТочекУчета.ПолучитьДанныеДоговоров(СтруктураОтбора.Организация, СтруктураОтбора.Район, СтруктураОтбора.Период,,СтруктураОтбора.ОбъектРасчета,СтруктураОтбора.ТочкаУчета,СтруктураОтбора.Услуга);
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		СтруктураОтбора.Вставить("Договор", 	Выборка.Договор);
	КонецЕсли;
	
	РезультатЗапроса = РегистрыСведений.бестПоставщикиУслугНП.ПолучитьДанныеПоставщиков(СтруктураОтбора.Организация, СтруктураОтбора.Район, СтруктураОтбора.Период,,СтруктураОтбора.ТочкаУчета,СтруктураОтбора.Услуга);
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		СтруктураОтбора.Вставить("Поставщик", 	Выборка.Поставщик);
	КонецЕсли;
	
	РезультатЗапроса = РегистрыСведений.бестПриборыТочекУчетаНП.ПолучитьДанныеПрибораУчета(СтруктураОтбора.Организация, СтруктураОтбора.Район, СтруктураОтбора.Период,,СтруктураОтбора.ОбъектРасчета,СтруктураОтбора.ТочкаУчета);
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		СтруктураОтбора.Вставить("ПриборУчета", 	Выборка.ПриборУчета);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСумму(ТекущиеДанные = Неопределено)
	Если ТекущиеДанные 		= Неопределено Тогда
		ТекущиеДанные		= Элементы.ДвижениябестОбъемНачисленийНП.ТекущиеДанные;
	КонецЕсли;
	ТекЗначениеТарифа 		= ТекущиеДанные.ЗначениеТарифа;
	ТекСтавкаНДС 			= ТекущиеДанные.СтавкаНДС;
	ТекОбъемУслуги 			= ТекущиеДанные.ОбъемУслуги;
	
	ТекущиеДанные.ОбъемУслугиПотребленный =  ТекОбъемУслуги;
	
	Если ТекущиеДанные.НДСВнутри Тогда 
		ТекущиеДанные.Сумма 		= ТекОбъемУслуги * ТекЗначениеТарифа - ТекОбъемУслуги * ТекЗначениеТарифа * ТекСтавкаНДС / (100 + ТекСтавкаНДС);
		ТекущиеДанные.СуммаНДС 	= ТекОбъемУслуги * ТекЗначениеТарифа * ТекСтавкаНДС / (100 + ТекСтавкаНДС);
	Иначе 
		ТекущиеДанные.Сумма 		= ТекОбъемУслуги * ТекЗначениеТарифа;
		ТекущиеДанные.СуммаНДС 	= ТекОбъемУслуги * ТекЗначениеТарифа * ТекСтавкаНДС / 100
	КонецЕсли;
КонецПроцедуры

#КонецОбласти  

