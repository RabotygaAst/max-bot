&НаСервереБезКонтекста
Функция ПолучитьТарифСредневзвешенныйНаСервере(ПериодНачисления, Поставщик, ТарифнаяЗона, Услуга, ЦеноваяКатегория, Район )
	
	Возврат Документы.бестПерерасчетЭЭ.ПолучитьТарифСредневзвешенный(ПериодНачисления, Поставщик, ТарифнаяЗона, Услуга, ЦеноваяКатегория, Район);
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьТарифНаселениеНаСервере(Организация, ПериодНачисления, Поставщик, ТарифнаяЗона, ТарифнаяКатегория, Услуга, Район)

	ПараметрыСхемы		= Новый Структура;
	Схема 							= Неопределено;
	ПараметрыВТ 					= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("Организация",	 		"Организация"), 				Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("Район",	 				"Район"), 					Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("ГруппаПотребителей", 	"ГруппаПотребителей"), 	Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("Услуга", 					"Услуга"), 					Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("Поставщик", 				"Поставщик"), 				Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("ТарифнаяЗона",	 		"ТарифнаяЗона"), 			Неопределено));
	
	ПараметрыСхемы.Вставить("Период", 			Новый Структура("ИмяПараметра", "Период"));
	ПараметрыСхемы.Вставить("ПараметрыВТ", 		ПараметрыВТ);
	
	РегистрыСведений.энргЗначенияТарифов.ЗначенияТарифов(Схема,ПараметрыСхемы,"");
	ПараметрыЗапроса 				= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация", 			Организация);
	ПараметрыЗапроса.Вставить("Район", 					Район);
	ПараметрыЗапроса.Вставить("ГруппаПотребителей", 	ТарифнаяКатегория);
	ПараметрыЗапроса.Вставить("Услуга", 					Услуга);
	ПараметрыЗапроса.Вставить("Поставщик", 				Поставщик); 
	ПараметрыЗапроса.Вставить("ТарифнаяЗона", 			ТарифнаяЗона);
	ПараметрыЗапроса.Вставить("Период", 					ПериодНачисления);
	
	Результат 						= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса);
	Выборка 						= Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Значение;
	КонецЕсли;
	
КонецФункции

