Процедура ДвижениябестОбъемНачисленийЭлектроэнергииПериодНачисленияПриИзмененииПереопределяемый(Элемент)
	// Переопределяется в расширении
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПериод()
	ТекДанные = Элементы.ДвижениябестОбъемНачисленийЭлектроэнергии.ТекущиеДанные;
	ТекДанные.Период = Объект.Дата;
	ТекДанные.ПериодНачисления = НачалоМесяца(Объект.Дата);
	ТекДанные.ПериодРасчета = НачалоМесяца(Объект.Дата);
	ТекДанные.СтавкаНДС = ПолучитьНДСНаДатуНаСервере(ТекДанные.ПериодРасчета, Объект.Организация);
	ТекДанные.НачалоПериода = ТекДанные.ПериодНачисления;
	ТекДанные.КонецПериода  = НачалоМесяца(ДобавитьМесяц(ТекДанные.ПериодНачисления,1));
КонецПроцедуры

&НаКлиенте
Процедура ПерерасчетатьТариф(ТекДанные)
	
	Если ТекДанные.ЦеноваяКатегория <> Неопределено Тогда
		Если ТекДанные.ЦеноваяКатегория <> ЦеноваяКатегорияНаселение() Тогда
			ТекДанные.Тариф = ТекДанные.ТарифСредневзвешенный + ТекДанные.ТарифЗаСбытовуюНадбавку + ТекДанные.ТарифЗаУслугиПоПередачи + ТекДанные.ТарифНаИныеУслуги;
		Иначе
			ТекДанные.Тариф = ПолучитьТарифНаселениеНаСервере(Объект.Организация, ТекДанные.ПериодНачисления, ТекДанные.Поставщик, ТекДанные.ТарифнаяЗона, ТекДанные.ТарифнаяГруппа, ТекДанные.Услуга, Объект.Район);
			ТекДанные.НДСВнутри = Истина;
		КонецЕсли
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПерерасчитатьСуммы()

	ТекДанные 							= Элементы.ДвижениябестОбъемНачисленийЭлектроэнергии.ТекущиеДанные;
	ТекДанные.Сумма 					= ТекДанные.Тариф * ТекДанные.ОбъемУслуги;
	
	Если ЗначениеЗаполнено(ТекДанные.НДСВнутри) Тогда
		Если НЕ ТекДанные.НДСВнутри Тогда
			ТекДанные.СуммаНДС 	= (ТекДанные.Сумма * ТекДанные.СтавкаНДС) / 100;
		Иначе
			ТекДанные.СуммаНДС 	= (ТекДанные.Сумма * ТекДанные.СтавкаНДС) / (100 + ТекДанные.СтавкаНДС);
		КонецЕсли;
	Иначе	
		Если ТекДанные.ЦеноваяКатегория <> Неопределено Тогда
			Если ТекДанные.ЦеноваяКатегория <> ЦеноваяКатегорияНаселение() Тогда
				ТекДанные.СуммаНДС 	= (ТекДанные.Сумма * ТекДанные.СтавкаНДС) / 100;
			Иначе
				ТекДанные.СуммаНДС 	= (ТекДанные.Сумма * ТекДанные.СтавкаНДС) / (100 + ТекДанные.СтавкаНДС);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ТекДанные.СуммаСредневзвешенная 	= ТекДанные.ТарифСредневзвешенный * ТекДанные.ОбъемУслуги;
	ТекДанные.СуммаСредневзвешеннаяНДС 	= (ТекДанные.СуммаСредневзвешенная * ТекДанные.СтавкаНДС) / 100; 
	
	ТекДанные.СуммаЗаУслугиПоПередачи = ТекДанные.ТарифЗаУслугиПоПередачи * ТекДанные.ОбъемУслуги;
	ТекДанные.СуммаЗаУслугиПоПередачиНДС = (ТекДанные.СуммаЗаУслугиПоПередачи * ТекДанные.СтавкаНДС) / 100;
	
	ТекДанные.СуммаЗаСбытовуюНадбавку = ТекДанные.ТарифЗаСбытовуюНадбавку * ТекДанные.ОбъемУслуги;
	ТекДанные.СуммаЗаСбытовуюНадбавкуНДС = (ТекДанные.СуммаЗаСбытовуюНадбавку * ТекДанные.СтавкаНДС) / 100;
	
	ТекДанные.СуммаЗаИныеУслуги = ТекДанные.ТарифНаИныеУслуги * ТекДанные.ОбъемУслуги;
	ТекДанные.СуммаЗаИныеУслугиНДС = (ТекДанные.СуммаЗаИныеУслуги * ТекДанные.СтавкаНДС) / 100;

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаполненияТочкиУчета(ТекДанные)
	
	Если ТекДанные.ОбъектРасчета <> Неопределено Тогда

		ДанныеДляЗаполненияТЧ = ПолучитьДанныеДляЗаполненияТЧНаСервере(ТекДанные.ОбъектРасчета,ТекДанные.ТочкаУчета,ТекДанные.ПериодРасчета,ТекДанные.ПериодНачисления,ТекДанные.ПриборУчета);
		
		ТекДанные.ЦеноваяКатегория 					= ДанныеДляЗаполненияТЧ.ЦеноваяКатегория;
		ТекДанные.ТарифнаяГруппа 					=ДанныеДляЗаполненияТЧ.ТарифнаяКатегория;
		ТекДанные.ВидДифференцированности 		= ДанныеДляЗаполненияТЧ.ВидДифференцированности;

		УровеньНапряженияМощностьТочкаПоставки	= ПолучитьУровеньНапряженияРасчетныйМощностьТочкуПоставкиНаСервере(ТекДанные.ОбъектРасчета, ТекДанные.ТочкаУчета, ТекДанные.ПериодРасчета);
		ТекДанные.УровеньНапряженияРасчетный 		= УровеньНапряженияМощностьТочкаПоставки.УровеньНапряженияРасчетный;
		МаксМощность 								= УровеньНапряженияМощностьТочкаПоставки.МаксимальнаяМощность;
		ТекДанные.ТочкаПоставки 					= УровеньНапряженияМощностьТочкаПоставки.ТочкаПоставки;
		
		ЗаполнитьТарифСредневзвешенный(ТекДанные); // так как услуга заполняется при выборе точки учета
		ЗаполнитьТарифыНеНаселение(ТекДанные, МаксМощность);
		ПерерасчетатьТариф(ТекДанные);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТарифСредневзвешенный(ТекДанные)
	ТекДанные.ТарифСредневзвешенный = ПолучитьТарифСредневзвешенныйНаСервере(ТекДанные.ПериодНачисления, ТекДанные.Поставщик, ТекДанные.ТарифнаяЗона, ТекДанные.Услуга, ТекДанные.ЦеноваяКатегория, Объект.Район );
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТарифыНеНаселение(ТекДанные, МаксМощность)
	Если ТекДанные.ЦеноваяКатегория <> Неопределено Тогда
		Если ТекДанные.ЦеноваяКатегория <> ЦеноваяКатегорияНаселение() Тогда
			ТарифыНеНаселение = ПолучитьТарифыНеНаселениеНаСервере(МаксМощность, Объект.Организация, ТекДанные.ПериодРасчета, ТекДанные.Поставщик, ТекДанные.УровеньНапряженияРасчетный, ТекДанные.Услуга, ТекДанные.ЦеноваяКатегория, Объект.Район);
			ТекДанные.ТарифЗаСбытовуюНадбавку 	= ТарифыНеНаселение.ТарифЗаСбытовуюНадбавку;
			ТекДанные.ТарифЗаУслугиПоПередачи 		= ТарифыНеНаселение.ТарифЗаУслугиПоПередачи;
			ТекДанные.ТарифНаИныеУслуги 			= ТарифыНеНаселение.ТарифНаИныеУслуги;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДвижениябестОбъемНачисленийЭлектроэнергииОбъектРасчетаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	ТекДанные = Элементы.ДвижениябестОбъемНачисленийЭлектроэнергии.ТекущиеДанные;
	Если ТипЗнч(Объект.Договор) = Тип("СправочникСсылка.энргДоговорыКонтрагентов") Тогда
		СтандартнаяОбработка = Ложь;
		
		ОписаниеОповещения 		= Новый ОписаниеОповещения("ОбъектРасчетаОкончаниеВыбора", ЭтотОбъект, Новый Структура("ТекДанные", ТекДанные));
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Организация", Объект.Организация);
		ПараметрыФормы.Вставить("Район", Объект.Район);
		ПараметрыФормы.Вставить("Договор", Объект.Договор);
		ПараметрыФормы.Вставить("Период", Объект.Дата);
		
		ОткрытьФорму("Справочник.бестОбъектыРасчета.ФормаВыбора", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбъектРасчетаОкончаниеВыбора(РезультатЗакрытия, ДополнительныеПараметры) Экспорт  
	
	Если Не РезультатЗакрытия = Неопределено Тогда 
		Модифицированность = Истина;
		ТекДанные = ДополнительныеПараметры.ТекДанные;
		ТекДанные.ОбъектРасчета = РезультатЗакрытия;
	КонецЕсли;
	
КонецПроцедуры

