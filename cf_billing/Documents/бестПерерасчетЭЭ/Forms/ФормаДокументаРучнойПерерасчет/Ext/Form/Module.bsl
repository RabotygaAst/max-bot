#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	
	бестЛокализацияСервер.ПриСозданииНаСервере_бестПерерасчетЭЭ(ЭтотОбъект);
	
	ПриСозданииНаСервереПереопределяемый(Отказ, СтандартнаяОбработка);
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
		Для Каждого СтрокаТЧ Из Объект.Движения.бестОбъемНачисленийЭлектроэнергии Цикл
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Организация) Тогда
				СтрокаТЧ.Организация = Объект.Организация;
			КонецЕсли;
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Район) Тогда
				СтрокаТЧ.Район = Объект.Район;
			КонецЕсли;
		КонецЦикла;
	
		Для Каждого СтрокаТЧ Из Объект.Движения.бестОбъемНачисленийЭлектроэнергии Цикл
		
		СчетчикОшибок = 0;
		Если СтрокаТЧ.Договор <> Объект.Договор Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("Строка "  + строка(СтрокаТЧ.НомерСтроки) + " Договор не соответствует договору в шапке документа"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Период) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "Период"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;
	
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ОбъектРасчета) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "ОбъектРасчета"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ТочкаУчета) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "ТочкаУчета"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ПериодНачисления) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "ПериодНачисления"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Поставщик) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "Поставщик"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Услуга) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "Услуга"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Договор) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "Договор"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.НачалоПериода) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "НачалоПериода"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;

		
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.КонецПериода) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "КонецПериода"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;

		
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ЦеноваяКатегория) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "ЦеноваяКатегория"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.УровеньНапряженияРасчетный) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка "  + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "УровеньНапряженияРасчетный"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Тариф) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "Строка " + строка(СтрокаТЧ.НомерСтроки) + " не заполненно значение " + "Тариф"));
			СчетчикОшибок = СчетчикОшибок + 1;
		КонецЕсли;
		
		Если СчетчикОшибок <> 0 Тогда
			Отказ = Истина
		КонецЕсли;
		
	КонецЦикла;
КонецПроцедуры
#КонецОбласти

#Область СобытияЭлементовШапки

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	ЗаполнитьПериодНачисленияСервер();
	Попытка
		Для Каждого СтрокаТЧ Из Объект.Движения.бестОбъемНачисленийЭлектроэнергии Цикл
			ЗаполнитьПериод();
			
			ТекДанные = Элементы.ДвижениябестОбъемНачисленийЭлектроэнергии.ТекущиеДанные;
			ПослеЗаполненияТочкиУчета(ТекДанные);
			ЗаполнитьТарифСредневзвешенный(ТекДанные);
			ПерерасчетатьТариф(ТекДанные);
			ПерерасчитатьСуммы();
		КонецЦикла
	Исключение
		
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	ЗаполнитьПериодНачисленияСервер();
КонецПроцедуры

