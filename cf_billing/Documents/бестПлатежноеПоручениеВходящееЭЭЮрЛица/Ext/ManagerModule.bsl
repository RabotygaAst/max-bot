#Область ИнициализацияДанныхДокумента

Процедура ИнициализироватьИсходныеДанныеДокумента(Схема) 
	ПолучитьШапкуДокумента(Схема);
	ПолучитьТаблицуОплаты(Схема); 
КонецПроцедуры

Процедура ПолучитьШапкуДокумента(Схема)
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	Шапка.Дата КАК Дата,
	|	Шапка.Организация КАК Организация,
	|	Шапка.ПериодНачисления КАК ПериодНачисления,
	|	Шапка.Район КАК Район,
	|	Шапка.ИсточникПоступления КАК ИсточникПоступления,
	|	Шапка.Ссылка КАК Ссылка,
	|	СтавкаНДСОрганизации.СтавкаНДС КАК СтавкаНДС
	|ПОМЕСТИТЬ РеквизитыДокумента
	|ИЗ
	|	Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица КАК Шапка
	|		ЛЕВОЕ СОЕДИНЕНИЕ СтавкаНДСОрганизации КАК СтавкаНДСОрганизации
	|		ПО Шапка.Организация = СтавкаНДСОрганизации.Организация
	|ГДЕ
	|	Шапка.Ссылка В(&мДокументы)");	
КонецПроцедуры  

Процедура ПолучитьТаблицуОплаты(Схема)
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	РеквизитыДокумента.Дата КАК Дата,
	|	РеквизитыДокумента.Организация КАК Организация,
	|	РеквизитыДокумента.ПериодНачисления КАК ПериодНачисления,
	|	РеквизитыДокумента.Район КАК Район,
	|	РеквизитыДокумента.ИсточникПоступления КАК ИсточникПоступления,
	|	ТаблицаОплаты.Ссылка КАК Ссылка,
	|	ТаблицаОплаты.НомерСтроки КАК НомерСтроки,
	|	ТаблицаОплаты.Контрагент КАК Контрагент,
	|	ТаблицаОплаты.Договор КАК Договор,
	|	ТаблицаОплаты.СуммаОплаты КАК СуммаОплаты,
	|	ТаблицаОплаты.СуммаОплаты * РеквизитыДокумента.СтавкаНДС / (100 + РеквизитыДокумента.СтавкаНДС) КАК СуммаОплатыНДС,
	|	ТаблицаОплаты.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ТаблицаОплаты.ДатаПлатежногоДокумента КАК ДатаПлатежногоДокумента,
	|	ТаблицаОплаты.НомерПлатежногоДокумента КАК НомерПлатежногоДокумента,
	|	ТаблицаОплаты.IDСтроки КАК IDСтроки
	|ПОМЕСТИТЬ ТаблицаОплаты
	|ИЗ
	|	Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица.Оплата КАК ТаблицаОплаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РеквизитыДокумента КАК РеквизитыДокумента
	|		ПО ТаблицаОплаты.Ссылка = РеквизитыДокумента.Ссылка");	
КонецПроцедуры

#КонецОбласти

#Область ТекстыЗапросов

Процедура ДобавитьТекстЗапросабестВзаиморасчетыЭЭ(Схема, ИмяРегистра)
		
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	ТаблицаОплаты.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ТаблицаОплаты.Организация КАК Организация,
	|	ТаблицаОплаты.Район КАК Район,
	|	ТаблицаОплаты.Договор КАК Договор,
	|	СУММА(ТаблицаОплаты.СуммаОплаты) КАК Сумма,
	|	СУММА(ТаблицаОплаты.СуммаОплатыНДС) КАК СуммаНДС
	|ИЗ
	|	ТаблицаОплаты КАК ТаблицаОплаты
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаОплаты.Организация,
	|	ТаблицаОплаты.Договор,
	|	ТаблицаОплаты.Дата,
	|	ТаблицаОплаты.Район";		
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

