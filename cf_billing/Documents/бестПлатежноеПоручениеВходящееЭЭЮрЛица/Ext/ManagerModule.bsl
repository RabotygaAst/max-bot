// Заполняет список поручений с отбором по договору.
//
// Параметры:
//	Договор - Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица.Оплата
//
// Возвращаемое значение:
//	Массив
Функция ПолучитьСписокПорученийСОтборомПоДоговору(Договор) Экспорт
	мПоручений = Новый Массив;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бестПлатежноеПоручениеВходящееЭЭЮрЛица.Оплата КАК бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата
	|ГДЕ
	|	бестПлатежноеПоручениеВходящееЭЭЮрЛицаОплата.Договор = &Договор";
	
	Запрос.УстановитьПараметр("Договор", Договор);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		мПоручений.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	
	Возврат мПоручений;
КонецФункции

// Процедура - Инициализировать данные документа
//
// Параметры:
//  ДокументСсылка			 - ДокументСсылка.бестПлатежноеПоручениеВходящееЭЭЮрЛица 
//  ДополнительныеСвойства	 - Структура 
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства) Экспорт 
	
	ПараметрыЗапроса  			= Новый Структура;
	Схема 						= Неопределено;
	Параметры	= Новый Структура;
	ПараметрыВТ = Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", "Организация"), Неопределено));
		
	Параметры.Вставить("Период"		, Новый Структура("ИмяПараметра, ТипПараметра", "Период" ,"ТипПараметраГраницаИсключая"));
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	РегистрыСведений.бестСтавкиНДС.СтавкаНДСОрганизации(Схема, Параметры);
	
	ИнициализироватьИсходныеДанныеДокумента(Схема);
		
	ДобавитьТекстЗапросабестВзаиморасчетыЭЭ(Схема, "бестВзаиморасчетыЭЭ");  
	ДобавитьТекстЗапросабестСуммыОплатЭЭ(Схема, "бестСуммыОплатЭЭ"); 
	
	ДобавитьТекстЗапросаПереопределяемая(Схема);
	
	КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	Запрос  						= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("Организация", ДополнительныеСвойства.ПараметрыПроведения.Организация);
	Запрос.УстановитьПараметр("мДокументы", ДокументСсылка);
		
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		Запрос.ВыполнитьПакет());
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

#КонецОбласти

