// МенюОтчеты
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуОтчет(Команда)
	
	МенюОтчетыКлиент.ВыполнитьПодключаемуюКомандуОтчет(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.ПодключаемыеКоманды


&НаКлиенте
Процедура ЗагрузитьФайл(Команда)
	Если не ЗначениеЗаполнено(Объект.ФайлДляЧтения) тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите файл для чтения",,"ФайлДляЧтения","ФайлДляЧтения");
		Возврат;
	КонецЕсли;   	
	
	ДвоичныеДанные  	= Новый ДвоичныеДанные(Объект.ФайлДляЧтения); 	
	АдресХранилища  	= ПоместитьВоВременноеХранилище(ДвоичныеДанные,ЭтаФорма.УникальныйИдентификатор);
	
	ЗагрузитьФайлСервер(АдресХранилища);
	ОпределитьНаличиеНазначения();
	ЗаполнитьЗадолженность();
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиВОплату(Команда)
	Для каждого стр из Объект.НеЗагруженныеДанные Цикл
		Если ЗначениеЗаполнено(стр.Контрагент) И стр.Организация = ПредопределенноеЗначение("Справочник.Организации.НашаОрганизация") Тогда
			НовСтр = Объект.Оплата.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтр,стр);
			Объект.НеЗагруженныеДанные.Удалить(стр.НомерСтроки - 1);
		КонецЕсли;
	КонецЦикла;
	ОпределитьНаличиеНазначения();
	ЗаполнитьЗадолженность();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Заполненные строки перенесены в ТЧ Оплата");
КонецПроцедуры

#КонецОбласти

#Область СобытияТЧ_Оплата

&НаКлиенте
Процедура ОплатаПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.Оплата.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ДокументыНачисления,					Неопределено,		ТекДанные.IDСтроки);
КонецПроцедуры

&НаКлиенте
Процедура ОплатаПередУдалением(Элемент, Отказ)
	ТекДанные = Элементы.Оплата.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицыФормы	= Новый Массив;
	ТаблицыФормы.Добавить("ДокументыНачисления");
	
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(ТекДанные.IDСтроки, Объект, ТаблицыФормы);
КонецПроцедуры

#КонецОбласти

#Область СобытияТЧ_НеЗагруженныеДанные

&НаКлиенте
Процедура НеЗагруженныеДанныеПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.НеЗагруженныеДанные.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ДокументыНачисленияНезагруженныеДанные,					Неопределено,		ТекДанные.IDСтроки);
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеПередУдалением(Элемент, Отказ)
	ТекДанные = Элементы.НеЗагруженныеДанные.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ТаблицыФормы	= Новый Массив;
	ТаблицыФормы.Добавить("ДокументыНачисления");
	
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(ТекДанные.IDСтроки, Объект, ТаблицыФормы);
КонецПроцедуры

#КонецОбласти

#Область СобытияТЧ_ДокументыНачисления

&НаКлиенте
Процедура ДокументыНачисленияПриИзменении(Элемент)
	ТекДанные = Элементы.Оплата.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 							= Элементы.ДокументыНачисления.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.IDСтроки = ТекДанные.IDСтроки;
КонецПроцедуры

&НаКлиенте
Процедура ДокументыНачисленияДокументНачисленияПриИзменении(Элемент)
	ТекСтрока = Элементы.ДокументыНачисления.ТекущиеДанные;
	ДокументНачисления = ТекСтрока.ДокументНачисления; 
	ТекСтрока.ПериодНачисления = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументНачисления, "ПериодНачисления");
	мДокументНачисления = Новый Массив;
	мДокументНачисления.Добавить(ДокументНачисления);
	СоответствиеЗадолженности = ПолучитьЗадолженностьПоПД(Объект.Организация, Объект.Район, мДокументНачисления, Объект.Дата);
	Задолженность = СоответствиеЗадолженности.Получить(ДокументНачисления);
	ТекСтрока.Задолженность = ?(Задолженность = Неопределено, 0, Задолженность);
	ТекСтрока.СуммаОплаты = 0;
	СуммыОплат = ПроверитьСуммыОплат(ТекСтрока.IDСтроки);
	МаксСуммаОплаты = СуммыОплат.СуммаОплаты - СуммыОплат.СуммаОплатыНазначений;
	ТекСтрока.СуммаОплаты = Мин(МаксСуммаОплаты, ТекСтрока.Задолженность);
	ПриИзмененииСуммыПроверка(ТекСтрока);
	УстановитьНаличиеНазначения(ТекСтрока.IDСтроки, ЗначениеЗаполнено(ДокументНачисления));
КонецПроцедуры

&НаКлиенте
Процедура ДокументыНачисленияДокументНачисленияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТекСтрока = Элементы.ДокументыНачисления.ТекущиеДанные;
	ОткрытьФормуВыбораПДСОтборами(Элемент, ТекСтрока, Элементы.Оплата.ТекущиеДанные.Договор);
КонецПроцедуры

&НаКлиенте
Процедура ДокументыНачисленияПослеУдаления(Элемент)
	ОпределитьНаличиеНазначения();
КонецПроцедуры

&НаКлиенте
Процедура ДокументыНачисленияПередУдалением(Элемент, Отказ)
	ТекДанные = Элементы.ДокументыНачисления.ТекущиеДанные;
	УстановитьНаличиеНазначения(ТекДанные.IDСтроки, Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ДокументыНачисленияСуммаОплатыПриИзменении(Элемент)
	ТекСтрока = Элементы.ДокументыНачисления.ТекущиеДанные;
	ПриИзмененииСуммыПроверка(ТекСтрока);	
КонецПроцедуры

#КонецОбласти

#Область СобытияТЧ_ДокументыНачисленияНезагруженныеДанные

&НаКлиенте
Процедура ДокументыНачисленияНезагруженныеДанныеДокументНачисленияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТекСтрока = Элементы.ДокументыНачисленияНезагруженныеДанные.ТекущиеДанные;
	ОткрытьФормуВыбораПДСОтборами(Элемент, ТекСтрока, Элементы.НеЗагруженныеДанные.ТекущиеДанные.Договор);
КонецПроцедуры

&НаКлиенте
Процедура ДокументыНачисленияНезагруженныеДанныеДокументНачисленияПриИзменении(Элемент)
	ТекСтрока = Элементы.ДокументыНачисленияНезагруженныеДанные.ТекущиеДанные;
	ДокументНачисления = ТекСтрока.ДокументНачисления;
	ТекСтрока.ПериодНачисления = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументНачисления, "ПериодНачисления");
	МаксСуммаОплаты = ПросуммироватьОплату(ТекСтрока.IDСтроки, "НеЗагруженныеДанные");
	мДокументНачисления = Новый Массив;
	мДокументНачисления.Добавить(ДокументНачисления);
	СоответствиеЗадолженности = ПолучитьЗадолженностьПоПД(Объект.Организация, Объект.Район, мДокументНачисления, Объект.Дата);
	Задолженность = СоответствиеЗадолженности.Получить(ДокументНачисления);
	ТекСтрока.Задолженность = Задолженность;
	ТекСтрока.СуммаОплаты = Мин(МаксСуммаОплаты, ТекСтрока.Задолженность);
КонецПроцедуры

&НаКлиенте
Процедура ДокументыНачисленияНезагруженныеДанныеПриИзменении(Элемент)
	ТекДанные = Элементы.НеЗагруженныеДанные.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 							= Элементы.ДокументыНачисленияНезагруженныеДанные.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.IDСтроки = ТекДанные.IDСтроки;
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеДоговорПриИзменении(Элемент)
	ТекДанные = Элементы.НеЗагруженныеДанные.ТекущиеДанные;
	ТекДанные.Контрагент = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекДанные.Договор, "Контрагент");
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьПериодНачисленияСервер()
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Объект.ПериодНачисления = Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);	
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьФайлСервер(АдресХранилища)
	  бестИнтеграции.ЗагрузитьФайлОплаты(АдресХранилища, Объект);
КонецПроцедуры

&НаСервере
Процедура НастроитьВидимостьЭлементов()
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РООтправитель", "Видимость", Объект.ИсточникПоступления = Справочники.энргИсточникиПоступления.Авизо);
КонецПроцедуры

&НаКлиенте
Процедура ОпределитьНаличиеНазначения()
	Для каждого СтрокаНазначение из Объект.ДокументыНачисления Цикл
		Если ЗначениеЗаполнено(СтрокаНазначение.ДокументНачисления) Тогда
			УстановитьНаличиеНазначения(СтрокаНазначение.IDСтроки, Истина);
		КонецЕсли;
	КонецЦикла;
	
	Для каждого СтрокаОплата из Объект.Оплата Цикл
		СуммыОплат = ПроверитьСуммыОплат(СтрокаОплата.IDСтроки);
		СтрокаОплата.СуммаНеРаспределена = (СуммыОплат.СуммаОплатыНазначений <> 0 И
											СуммыОплат.СуммаОплатыНазначений < СуммыОплат.СуммаОплаты);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНаличиеНазначения(IDСтроки, ДокументНачисленияПрисутствует)
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("IDСтроки", IDСтроки);
	НайденныеСтроки = Объект.Оплата.НайтиСтроки(ПараметрыОтбора);
	Для каждого СтрокаОплата Из НайденныеСтроки Цикл
		СтрокаОплата.ДокументНачисленияПрисутствует = ДокументНачисленияПрисутствует;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Функция ПросуммироватьОплату(IDСтроки, ТЧ)
	Сумма = 0;
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("IDСтроки", IDСтроки);
	НайденныеСтроки = Объект[ТЧ].НайтиСтроки(ПараметрыОтбора);
	Для каждого СтрокаОплата Из НайденныеСтроки Цикл
		Сумма = Сумма + СтрокаОплата.СуммаОплаты;
	КонецЦикла;
	Возврат Сумма;
КонецФункции

&НаКлиенте
Функция ПроверитьСуммыОплат(IDСтроки)
	СуммаОплаты = ПросуммироватьОплату(IDСтроки, "Оплата");
	СуммаОплатыНазначений = ПросуммироватьОплату(IDСтроки, "ДокументыНачисления");
	Возврат Новый Структура("СуммаОплаты, СуммаОплатыНазначений", СуммаОплаты, СуммаОплатыНазначений);
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьЗадолженностьПоПД(Организация, Район, мДокументНачисления, Период)
	  Возврат бестВзаиморасчетыЮрЛицаСервер.ПолучитьЗадолженностьПоПД(Организация, Район, мДокументНачисления, Период);
КонецФункции	

&НаСервере
Процедура ЗаполнитьЗадолженность()
	СоответствиеЗадолженности = ПолучитьЗадолженностьПоПД(Объект.Организация, Объект.Район, 
		Объект.ДокументыНачисления.Выгрузить().ВыгрузитьКолонку("ДокументНачисления"), Объект.Дата);
	Для каждого Строка из Объект.ДокументыНачисления Цикл
		Строка.Задолженность = СоответствиеЗадолженности.Получить(Строка.ДокументНачисления);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Функция ПолучитьПДДляОтбора(ДокументНачисления)
	мПД = Новый Массив;
	Для каждого СтрокаОплата из Объект.Оплата Цикл
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("IDСтроки", СтрокаОплата.IDСтроки);
	НайденныеСтроки = Объект.ДокументыНачисления.НайтиСтроки(ПараметрыОтбора);
	Для каждого Строка из НайденныеСтроки Цикл
		Если ЗначениеЗаполнено(Строка.ДокументНачисления) 
				И Строка.ДокументНачисления <> ДокументНачисления
				И Строка.Задолженность <= Строка.СуммаОплаты Тогда
			мПД.Добавить(Строка.ДокументНачисления);
		КонецЕсли;
	КонецЦикла;
	КонецЦикла;

	Возврат мПД;
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуВыбораПДСОтборами(Элемент, ТекСтрока, ТЧОтбор)
	НастройкиКомпоновки = Новый НастройкиКомпоновкиДанных;

    ГруппаОтбора = НастройкиКомпоновки.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
    ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	
	
	мПД = Новый Массив;
	мПД.Добавить(ТекСтрока.ДокументНачисления);
	
	ЭлементОтбора = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Ссылка");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеВСписке;
	ЭлементОтбора.Использование  = Истина;
	ЭлементОтбора.ПравоеЗначение = ПолучитьПДДляОтбора(ТекСтрока.ДокументНачисления);
	
	ЭлементОтбора = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Договор");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.Использование  = Истина;
	ЭлементОтбора.ПравоеЗначение = ТЧОтбор;
	
	Если ЗначениеЗаполнено(ТекСтрока.ПериодНачисления) Тогда
		
		ЭлементОтбора = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ПериодНачисления");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.Использование  = Истина;
		ЭлементОтбора.ПравоеЗначение = ТекСтрока.ПериодНачисления;
		
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ФиксированныеНастройки", НастройкиКомпоновки);
	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	ПараметрыФормы.Вставить("Период", Объект.Дата);
	
	ОткрытьФорму("Документ.бестПлатежныйДокумент.ФормаВыбора", ПараметрыФормы, Элемент);
				
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииСуммыПроверка(ТекСтрока)
	СуммыОплат = ПроверитьСуммыОплат(ТекСтрока.IDСтроки);
	Если СуммыОплат.СуммаОплатыНазначений > СуммыОплат.СуммаОплаты Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Распределенная сумма больше суммы оплаты.");
		ТекСтрока.СуммаОплаты = 0;
	Иначе
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("IDСтроки", ТекСтрока.IDСтроки);
		НайденныеСтроки = Объект.Оплата.НайтиСтроки(ПараметрыОтбора);
		Для каждого СтрокаОплата Из НайденныеСтроки Цикл
			СтрокаОплата.СуммаНеРаспределена = СуммыОплат.СуммаОплатыНазначений <> 0
												И СуммыОплат.СуммаОплатыНазначений < СуммыОплат.СуммаОплаты;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти