Процедура ЗаполнитьСчетНаОстаток(ТабДок, РезультатЗапроса, Макет, ПараметрыПечати) Экспорт 
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");	
	
	ВыборкаШапка = РезультатЗапроса[1].Выбрать();
	ВыборкаДанные = РезультатЗапроса[2].Выбрать(); 	
	Если ВыборкаШапка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ВыборкаШапка);
		ОбластьШапка.Параметры.ДатаПД = Формат(ВыборкаШапка.ДатаПД, "ДЛФ=D");
		ОбластьШапка.Параметры.ДатаДоговора = Формат(ВыборкаШапка.ДатаДоговора, "ДЛФ=D");
		ТабДок.Вывести(ОбластьШапка);
		
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапка);
	КонецЕсли;
	
	СуммаБезНДС = 0;
	СуммаНДС 	= 0;
	Сумма 	= 0;
	
	Пока ВыборкаДанные.Следующий() Цикл
		ОбластьДанные = Макет.ПолучитьОбласть("Данные");
		ЗаполнитьЗначенияСвойств(ОбластьДанные.Параметры,ВыборкаДанные);
		ОбластьДанные.Параметры.ПД = "№ " + ВыборкаДанные.НомерПД + " от " + Формат(ВыборкаДанные.Дата, "ДЛФ=D") + " за " + Формат(ВыборкаДанные.ПериодНачисления, "ДФ='MMMM yyyy ''г.'''");
		ТабДок.Вывести(ОбластьДанные);
		
		СуммаБезНДС = СуммаБезНДС + ВыборкаДанные.СуммаБезНДС;
		СуммаНДС 	= СуммаНДС + ВыборкаДанные.СуммаНДС;
		Сумма 		= Сумма + ВыборкаДанные.Сумма;
	КонецЦикла;
	
	ОбластьПодвал.Параметры.СуммаБезНДС = СуммаБезНДС;
	ОбластьПодвал.Параметры.СуммаНДС 	= СуммаНДС;
	ОбластьПодвал.Параметры.Сумма 		= Сумма;	
	
	
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.РуководительОрганизации Тогда
			ОбластьПодвал.Параметры.РуководительОрганизацииФИО = эл.Сотрудник;	
		ИначеЕсли эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГлавныйБухгалтер Тогда
			ОбластьПодвал.Параметры.ГлавныйБухгалтерФИО = эл.Сотрудник;
		КонецЕсли;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьПодвал); 	
	
КонецПроцедуры     

