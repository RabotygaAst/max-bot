	|	МАКСИМУМ(ЕСТЬNULL(ОрганизацииКонтактнаяИнформация.Представление, """")) КАК АдресПродавца,
	|	БанковскиеСчета.Банк.Представление КАК Банк,
	|	БанковскиеСчета.Банк.Код КАК БИК,
	|	БанковскиеСчета.Банк.КоррСчет КАК КорСчет,
	|	БанковскиеСчета.НомерСчета КАК Счет
	|ПОМЕСТИТЬ ДанныеОрганизации
	|ИЗ
	|	ДанныеДокумента КАК ДанныеДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
	|			ПО Организации.Ссылка = ОрганизацииКонтактнаяИнформация.Ссылка
	|				И (ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации))
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчета
	|			ПО Организации.ОсновнойБанковскийСчет = БанковскиеСчета.Ссылка
	|		ПО ДанныеДокумента.Организация = Организации.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеДокумента.Организация,
	|	Организации.КПП,
	|	Организации.ИНН,
	|	Организации.Представление,
	|	БанковскиеСчета.Банк.Представление,
	|	БанковскиеСчета.Банк.Код,
	|	БанковскиеСчета.Банк.КоррСчет,
	|	БанковскиеСчета.НомерСчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокумента.Контрагент КАК Контрагент,
	|	энргКонтрагенты.ИНН КАК ПокупательИНН,
