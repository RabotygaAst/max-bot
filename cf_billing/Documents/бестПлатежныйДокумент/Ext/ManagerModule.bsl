	|ИЗ
	|	Итог КАК Итог
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестКонтактныеЛицаКонтрагентов КАК бестКонтактныеЛицаКонтрагентов
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СклоненияПредставленийОбъектов КАК СклоненияПредставленийОбъектов
	|			ПО бестКонтактныеЛицаКонтрагентов.КонтактноеЛицо = СклоненияПредставленийОбъектов.Объект
	|		ПО Итог.Контрагент = бестКонтактныеЛицаКонтрагентов.Владелец
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.Доверенности КАК энргКонтрагентыДоверенности
	|		ПО Итог.Контрагент = энргКонтрагентыДоверенности.Ссылка";
	
	Возврат Запрос;
	
КонецФункции

Процедура ЗаполнитьАктПерерасчета(ТабДок, Выборка, Макет, ПараметрыПечати) Экспорт 
	
	ОбластьАктПерерасчета = Макет.ПолучитьОбласть("АктПерерасчета");
	
	ЗаполнитьЗначенияСвойств(ОбластьАктПерерасчета.Параметры, Выборка);
	ОбластьАктПерерасчета.Параметры.ПериодНачисленияОснования 		= Формат(Выборка.ПериодНачисленияОснования, "ДФ='MMMM yyyy ''г.'''");
	ОбластьАктПерерасчета.Параметры.ПериодНачисленияКорректировки 	= СклонениеПредставленийОбъектов.ПросклонятьПредставление(Формат(Выборка.ПериодНачисленияКорректировки, "ДФ='MMMM'"),6) + " " + Формат(Выборка.ПериодНачисленияКорректировки, "ДФ='yyyy ''г.'''");
	ОбластьАктПерерасчета.Параметры.ДатаДоговора 					= Формат(Выборка.ДатаДоговора, "ДЛФ=D");
	ОбластьАктПерерасчета.Параметры.ДатаПД 							= Формат(Выборка.ДатаПД, "ДЛФ=D");
	ОбластьАктПерерасчета.Параметры.УвеличенияУменьшения            = ?(Выборка.РазницаСумма > 0, "увеличения", "уменьшения");
	ОбластьАктПерерасчета.Параметры.РазницаСумма            		= ?(Выборка.РазницаСумма > 0, Выборка.РазницаСумма, -Выборка.РазницаСумма);
	ОбластьАктПерерасчета.Параметры.РазницаСуммаНДС            		= ?(Выборка.РазницаСуммаНДС > 0, Выборка.РазницаСуммаНДС, -Выборка.РазницаСуммаНДС);
	
	Если ЗначениеЗаполнено(Выборка.НомерДоверенностиКонтактногоЛица) И ЗначениеЗаполнено(Выборка.ДатаДоверенностиКонтактногоЛица) Тогда
		ОбластьАктПерерасчета.Параметры.ДоверенностьКонтактногоЛица = ", действующего на основании доверенности №" + Выборка.НомерДоверенностиКонтактногоЛица + " от " + Формат(Выборка.ДатаДоверенностиКонтактногоЛица, "ДЛФ=D") + ",";
	Иначе
		ОбластьАктПерерасчета.Параметры.ДоверенностьКонтактногоЛица = "";
	КонецЕсли;
	
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГарантирующийПоставщик Тогда
			
			ОбластьАктПерерасчета.Параметры.ГарантирующийПоставщикФИО 		= эл.Сотрудник;
			ОбластьАктПерерасчета.Параметры.ГарантирующийПоставщикДолжность = эл.Должность;
			РезультатСклонения = энргОбщегоНазначения.ПолучитьСклоненияОбъекта(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Сотрудник, "ФизическоеЛицо"));
			ВыборкаСклонения = РезультатСклонения.Выбрать();
			Если ВыборкаСклонения.Следующий() Тогда
				ОбластьАктПерерасчета.Параметры.ГарантирующийПоставщикФИОРП = ВыборкаСклонения.РодительныйПадеж;
			КонецЕсли;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьАктПерерасчета.Параметры.ГарантирующийПоставщикДоверенность = " на основании доверенности дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьАктПерерасчета.Параметры.ГарантирующийПоставщикДоверенность = "";	
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьАктПерерасчета); 	
	
КонецПроцедуры     

#КонецОбласти

#Область АктПриемаПередачи

Функция ПолучитьЗапросАктПриемаПередачи() Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестПлатежныйДокумент.Организация КАК Организация,
	|	бестПлатежныйДокумент.НомерВРазрезеВидаЗадолженности КАК НомерВРазрезеВидаЗадолженности,
	|	бестПлатежныйДокумент.Дата КАК Дата,
	|	бестПлатежныйДокумент.Район КАК Район,
	|	бестПлатежныйДокумент.Договор КАК Договор,
	|	бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета КАК ОбъектРасчета,
	|	СУММА(ВЫБОР
	|			КОГДА бестПлатежныйДокументОсновнаяРеализация.НДСВнутри
	|				ТОГДА бестПлатежныйДокументОсновнаяРеализация.Сумма
	|			ИНАЧЕ бестПлатежныйДокументОсновнаяРеализация.Сумма + бестПлатежныйДокументОсновнаяРеализация.СуммаНДС
	|		КОНЕЦ) КАК СуммаСНДС,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.СуммаНДС) КАК СуммаНДС,
	|	СУММА(ВЫБОР
	|			КОГДА бестПлатежныйДокументОсновнаяРеализация.НДСВнутри
	|				ТОГДА бестПлатежныйДокументОсновнаяРеализация.Сумма - бестПлатежныйДокументОсновнаяРеализация.СуммаНДС
	|			ИНАЧЕ бестПлатежныйДокументОсновнаяРеализация.Сумма
	|		КОНЕЦ) КАК СуммаБезНДС,
	|	бестПлатежныйДокументОсновнаяРеализация.Тариф КАК Тариф,
	|	бестПлатежныйДокументОсновнаяРеализация.СтавкаНДС КАК СтавкаНДС,
	|	бестПлатежныйДокументОсновнаяРеализация.Услуга КАК Услуга,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.ОбъемУслуги) КАК ОбъемУслуги,
	|	бестПлатежныйДокумент.ПериодНачисления КАК ПериодНачисления,
	|	бестПлатежныйДокументОсновнаяРеализация.СпособНачисления КАК СпособНачисления
	|ПОМЕСТИТЬ ДанныеДокумента
	|ИЗ
	|	Документ.бестПлатежныйДокумент.ОсновнаяРеализация КАК бестПлатежныйДокументОсновнаяРеализация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|		ПО бестПлатежныйДокументОсновнаяРеализация.Ссылка = бестПлатежныйДокумент.Ссылка
	|			И (бестПлатежныйДокумент.Ссылка = &Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	бестПлатежныйДокумент.Организация,
	|	бестПлатежныйДокумент.НомерВРазрезеВидаЗадолженности,
	|	бестПлатежныйДокумент.Дата,
	|	бестПлатежныйДокумент.Район,
	|	бестПлатежныйДокумент.Договор,
	|	бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета,
	|	бестПлатежныйДокументОсновнаяРеализация.СтавкаНДС,
	|	бестПлатежныйДокументОсновнаяРеализация.Услуга,
	|	бестПлатежныйДокумент.ПериодНачисления,
	|	бестПлатежныйДокументОсновнаяРеализация.СпособНачисления,
	|	бестПлатежныйДокументОсновнаяРеализация.Тариф
	|
	|ИМЕЮЩИЕ
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.ОбъемУслуги) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокумента.Организация КАК Организация,
	|	ДанныеДокумента.НомерВРазрезеВидаЗадолженности КАК НомерВРазрезеВидаЗадолженности,
	|	ДанныеДокумента.Дата КАК ДатаПД,
	|	ДанныеДокумента.Район КАК Район,
	|	ДанныеДокумента.Договор КАК Договор,
	|	ДанныеДокумента.ОбъектРасчета КАК ОбъектРасчета,
	|	ДанныеДокумента.СуммаСНДС КАК СуммаСНДС,
	|	ДанныеДокумента.СуммаНДС КАК СуммаНДС,
	|	ДанныеДокумента.Тариф КАК Тариф,
	|	ДанныеДокумента.СтавкаНДС КАК СтавкаНДС,
	|	ДанныеДокумента.Услуга КАК Услуга,
	|	ДанныеДокумента.ОбъемУслуги КАК ОбъемУслуги,
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	ДанныеДокумента.СуммаБезНДС КАК СуммаБезНДС,
	|	ДанныеДокумента.ПериодНачисления КАК ПериодНачисления,
	|	энргДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	энргДоговорыКонтрагентов.ЭлектронноеВзаимодействие КАК ЭлектронноеВзаимодействие,
	|	ДанныеДокумента.СпособНачисления КАК СпособНачисления
	|ПОМЕСТИТЬ Итог
	|ИЗ
	|	ДанныеДокумента КАК ДанныеДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|		ПО ДанныеДокумента.Договор = энргДоговорыКонтрагентов.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.НомерВРазрезеВидаЗадолженности КАК НомерВРазрезеВидаЗадолженности,
	|	Итог.ДатаПД КАК ДатаПД,
	|	Итог.НомерДоговора КАК НомерДоговора,
	|	Итог.ДатаДоговора КАК ДатаДоговора,
	|	Итог.Организация КАК Организация,
	|	СУММА(Итог.СуммаСНДС) КАК СуммаСНДС,
	|	СУММА(Итог.СуммаНДС) КАК СуммаНДС,
	|	СУММА(Итог.СуммаБезНДС) КАК СуммаБезНДС,
	|	Итог.Контрагент КАК Контрагент,
	|	Итог.ПериодНачисления КАК ПериодНачисления,
	|	энргКонтрагентыДоверенности.Номер КАК НомерДоверенностиКонтактногоЛица,
	|	энргКонтрагентыДоверенности.Дата КАК ДатаДоверенностиКонтактногоЛица,
	|	ВЫРАЗИТЬ(СклоненияПредставленийОбъектов.РодительныйПадеж КАК СТРОКА(500)) КАК КонтактноеЛицоРП,
	|	СУММА(ВЫБОР
	|			КОГДА энргВидыУслуг.бестИспользоватьРасчетПоМощности
	|				ТОГДА 0
	|			ИНАЧЕ Итог.ОбъемУслуги
	|		КОНЕЦ) КАК ОбъемЭЭ,
	|	Итог.ЭлектронноеВзаимодействие КАК ЭлектронноеВзаимодействие
	|ИЗ
	|	Итог КАК Итог
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО Итог.Услуга = энргВидыУслуг.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестКонтактныеЛицаКонтрагентов КАК бестКонтактныеЛицаКонтрагентов
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СклоненияПредставленийОбъектов КАК СклоненияПредставленийОбъектов
	|			ПО бестКонтактныеЛицаКонтрагентов.КонтактноеЛицо = СклоненияПредставленийОбъектов.Объект
	|		ПО Итог.Контрагент = бестКонтактныеЛицаКонтрагентов.Владелец
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.Доверенности КАК энргКонтрагентыДоверенности
	|		ПО Итог.Контрагент = энргКонтрагентыДоверенности.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Итог.НомерВРазрезеВидаЗадолженности,
	|	Итог.ДатаПД,
	|	Итог.НомерДоговора,
	|	Итог.ДатаДоговора,
	|	Итог.Организация,
	|	Итог.Контрагент,
	|	энргКонтрагентыДоверенности.Номер,
	|	энргКонтрагентыДоверенности.Дата,
	|	ВЫРАЗИТЬ(СклоненияПредставленийОбъектов.РодительныйПадеж КАК СТРОКА(500)),
	|	Итог.ПериодНачисления,
	|	Итог.ЭлектронноеВзаимодействие
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.СуммаСНДС КАК СуммаСНДС,
	|	Итог.СуммаНДС КАК СуммаНДС,
	|	Итог.Тариф КАК Тариф,
	|	Итог.СтавкаНДС КАК СтавкаНДС,
	|	Итог.Услуга КАК Услуга,
	|	Итог.ОбъемУслуги КАК ОбъемУслуги,
	|	Итог.СуммаБезНДС КАК СуммаБезНДС,
	|	Итог.ПериодНачисления КАК ГодМесяц,
	|	Итог.СпособНачисления КАК СпособНачисления
	|ИЗ
	|	Итог КАК Итог";
	
	Возврат Запрос;
	
КонецФункции

Процедура ЗаполнитьАктПриемаПередачи(ТабДок, РезультатЗапроса, Макет, ПараметрыПечати) Экспорт 
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьИтого  = Макет.ПолучитьОбласть("Итого");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	ВыборкаШапка 		= РезультатЗапроса[2].Выбрать();
	ВыборкаИтогУслуга 	= РезультатЗапроса[3].Выбрать();
	Картинка = Новый Картинка();
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГарантирующийПоставщик Тогда
			ОбластьПодвал.Параметры.ГарантирующийПоставщикФИО = эл.Сотрудник;
			Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
			РезультатСклонения = энргОбщегоНазначения.ПолучитьСклоненияОбъекта(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Сотрудник, "ФизическоеЛицо"));
			Выборка = РезультатСклонения.Выбрать();
			Если Выборка.Следующий() Тогда
				ОбластьШапка.Параметры.ГарантирующийПоставщикФИОРП = Выборка.РодительныйПадеж;
			КонецЕсли;
			ОбластьШапка.Параметры.ГарантирующийПоставщикДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьШапка.Параметры.ГарантирующийПоставщикДоверенность = " на основании доверенности дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + "от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьШапка.Параметры.ГарантирующийПоставщикДоверенность = "";	
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;  	
	
	Если ВыборкаШапка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ВыборкаШапка);
		ОбластьШапка.Параметры.ДатаПД = Формат(ВыборкаШапка.ДатаПД, "ДЛФ=D");
		ОбластьШапка.Параметры.МесяцПрописьюГод = Формат(ВыборкаШапка.ПериодНачисления, "ДЛФ=D");
		ОбластьШапка.Параметры.ДатаДоговора = Формат(ВыборкаШапка.ДатаДоговора, "ДЛФ=D");
		
		Если ЗначениеЗаполнено(ВыборкаШапка.НомерДоверенностиКонтактногоЛица) И ЗначениеЗаполнено(ВыборкаШапка.ДатаДоверенностиКонтактногоЛица) Тогда
			ОбластьШапка.Параметры.ДоверенностьКонтактногоЛица = ", действующего на основании доверенности №" + ВыборкаШапка.НомерДоверенностиКонтактногоЛица + " от " + Формат(ВыборкаШапка.ДатаДоверенностиКонтактногоЛица, "ДЛФ=D") + ",";
		Иначе
			ОбластьШапка.Параметры.ДоверенностьКонтактногоЛица = "";
		КонецЕсли;
		
		ТабДок.Вывести(ОбластьШапка);
		
		ЗаполнитьЗначенияСвойств(ОбластьИтого.Параметры,ВыборкаШапка);
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапка);
		ОбластьПодвал.Параметры.МесяцПрописьюГод = Формат(ВыборкаШапка.ПериодНачисления, "ДФ='MMMM yyyy ''г.'''");
		ОбластьПодвал.Параметры.ДатаДоговора = Формат(ВыборкаШапка.ДатаПД, "ДЛФ=D");
		Если ВыборкаШапка.ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда
			ОбластьПодвал.Рисунки.ОбразецПодписиГарантирующегоПоставщика.Картинка = Картинка;
		КонецЕсли;
	КонецЕсли;
	
	НомерСтроки = 1;
	Пока ВыборкаИтогУслуга.Следующий() Цикл
		ОбластьДанныеЗадолженности = Макет.ПолучитьОбласть("ДанныеЗадолженности");
		ЗаполнитьЗначенияСвойств(ОбластьДанныеЗадолженности.Параметры,ВыборкаИтогУслуга);
		ОбластьДанныеЗадолженности.Параметры.Номер = НомерСтроки;
		
		ТабДок.Вывести(ОбластьДанныеЗадолженности);
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьИтого);
	
	ТабДок.Вывести(ОбластьПодвал); 	
	
КонецПроцедуры     

