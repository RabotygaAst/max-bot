Функция СформироватьАктСверки(ИмяМакета, ПараметрыПечати)
	
	Макет 	= УправлениеПечатью.МакетПечатнойФормы("Отчет.бестАктСверки." + ИмяМакета);
	ТабДок 	= Новый ТабличныйДокумент;
	
	ДанныеКонтрагента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПараметрыПечати.Договор, "Контрагент,Номер");
	ПолноеНаименованиеОрганизации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыПечати.Организация, "НаименованиеПолное");
	ДополнительныеПараметры = Новый Структура("ДанныеКонтрагента, ПолноеНаименованиеОрганизации", ДанныеКонтрагента, ПолноеНаименованиеОрганизации);	
