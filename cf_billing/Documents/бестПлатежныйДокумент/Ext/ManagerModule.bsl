Процедура ЗаполнитьАктСверки(Макет, ТабДок, ПараметрыПечати, ДополнительныеПараметры)	
	
	Организация 	= ПараметрыПечати.Организация;
	Район 			= ПараметрыПечати.Район;
	Договор 		= ПараметрыПечати.Договор;
	НачалоПериода	= Дата(1, 1, 1);
	Если ПараметрыПечати.ФормироватьЗаПериод Тогда
		НачалоПериода 	= ПараметрыПечати.НачалоПериода;
	КонецЕсли;
	КонецПериода 	= ПараметрыПечати.КонецПериода;
	Контрагент 		= ДополнительныеПараметры.ДанныеКонтрагента.Контрагент;
	Номер 			= ДополнительныеПараметры.ДанныеКонтрагента.Номер;	
	ПолноеНаименованиеОрганизации = ДополнительныеПараметры.ПолноеНаименованиеОрганизации;
	
	//////////////////
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	
	ОбластьШапка.Параметры.ПолноеНаименованиеОрганизации 	= ПолноеНаименованиеОрганизации;
	ОбластьШапка.Параметры.Контрагент 						= Контрагент;
	ОбластьШапка.Параметры.НомерДоговора 					= Номер;
	
	ТабДок.Вывести(ОбластьШапка);
	//////////////////
	
	Постфикс = "";
	
	Если ПараметрыПечати.ФормироватьЗаПериод Тогда
		
		ОбластьШапкаЗаПериод  = Макет.ПолучитьОбласть("ШапкаЗаПериод");
		
		Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьФактическуюЗадолженностьПоПериодам(Организация, Район, Договор,,, НачалоПериода, Истина);
		
		Выборка = Результат.Выбрать();
		
		ФЗадолженностьНаНачало = 0;
		Если Выборка.Следующий() Тогда
			ФЗадолженностьНаНачало 	= Выборка.Сумма;
		КонецЕсли;
		
		Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьАвансовуюЗадолженностьНаДату(Организация, Район, НачалоПериода, Договор);
		
		Выборка = Результат.Выбрать();
		
		АЗадолженностьНаНачало = 0;
		Если Выборка.Следующий() Тогда
			АЗадолженностьНаНачало 	= Выборка.Сумма;
		КонецЕсли;
		
		Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьПереплатуНаДату(Организация, Район, НачалоПериода, Договор);
		
		Выборка = Результат.Выбрать();
		
		ПереплатаНаНачало = 0;
		Если Выборка.Следующий() Тогда
			ПереплатаНаНачало 	= Выборка.Сумма;
		КонецЕсли;
				
		Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьПенюНаДату(Организация, Район, НачалоПериода, Договор);
		
		Выборка = Результат.Выбрать();
		
		ПеняНаНачало = 0;
		Если Выборка.Следующий() Тогда
			ПеняНаНачало 	= Выборка.Сумма;
		КонецЕсли;
		
		ОбластьШапкаЗаПериод.Параметры.ПолноеНаименованиеОрганизации 	= ПолноеНаименованиеОрганизации;
		ОбластьШапкаЗаПериод.Параметры.Контрагент 						= Контрагент;
		ОбластьШапкаЗаПериод.Параметры.НачалоПериода 					= Формат(НачалоПериода, "ДЛФ=D");
		ОбластьШапкаЗаПериод.Параметры.ФактДолгНаНачало 				= ФЗадолженностьНаНачало;
		ОбластьШапкаЗаПериод.Параметры.АвансДолгНаНачало 				= АЗадолженностьНаНачало;
		ОбластьШапкаЗаПериод.Параметры.ФактПереплатаНаНачало 			= ПереплатаНаНачало;
		ОбластьШапкаЗаПериод.Параметры.ПеняДолгНаНачало                 = ПеняНаНачало;
		ОбластьШапкаЗаПериод.Параметры.СальдоНаНачало 					= ФЗадолженностьНаНачало + ПеняНаНачало - ПереплатаНаНачало;
		
		
		ТабДок.Вывести(ОбластьШапкаЗаПериод);
	Иначе
		
		ОбластьШапкаНаДату  = Макет.ПолучитьОбласть("ШапкаНаДату");
		ОбластьШапкаНаДату.Параметры.ДатаФормирования					= Формат(КонецПериода, "ДЛФ=D");
		ТабДок.Вывести(ОбластьШапкаНаДату);
		Постфикс = "НаДату";
		
	КонецЕсли;
	
	//////////////////
	ИмяШапкаТЧ = СтрШаблон("ШапкаТЧ%1", Постфикс);
	ОбластьШапкаТЧ  = Макет.ПолучитьОбласть(ИмяШапкаТЧ);
	
	ТабДок.Вывести(ОбластьШапкаТЧ);
	//////////////////
	
	Результат = бестВзаиморасчетыЮрЛицаСервер.ОплатыСФЗаПериод(Организация, Район, НачалоПериода, КонецПериода, Договор);
	
	ВыборкаПлатежныйДокумент = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	СуммаДолг 	= 0;
	СуммаОплата = 0;
	
	СтрокаДатыОплатПр 	= "";
	СтрокаНомераОплатПр = "";
	СтрокаСуммаОплатПр 	= "";
	СуммаОплатПоДокументуВнеПериода = 0;
	
	Пока ВыборкаПлатежныйДокумент.Следующий() Цикл
		СтрокаДатыОплат 	= "";
		СтрокаНомераОплат 	= "";
		СтрокаСуммаОплат 	= "";
		
		СуммаОплатПоДокументуВПериоде = 0;
		
		ВыборкаДетальныеЗаписи = ВыборкаПлатежныйДокумент.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если Не ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.СуммаОплаты) Тогда
				Продолжить;
			КонецЕсли;
			Если ВыборкаДетальныеЗаписи.ПериодНачисления >= НачалоПериода Тогда
				СтрокаДатыОплат 	= СтрокаДатыОплат + Символы.ПС + Формат(ВыборкаДетальныеЗаписи.ДатаОплаты, "ДЛФ=D");
				СтрокаНомераОплат 	= СтрокаНомераОплат + Символы.ПС + ВыборкаДетальныеЗаписи.НомерОплаты;
				СтрокаСуммаОплат 	= СтрокаСуммаОплат + Символы.ПС + ВыборкаДетальныеЗаписи.СуммаОплаты;
				
				СуммаОплатПоДокументуВПериоде = СуммаОплатПоДокументуВПериоде + ВыборкаДетальныеЗаписи.СуммаОплаты;
			Иначе
				СтрокаДатыОплатПр 	= СтрокаДатыОплатПр + Символы.ПС + Формат(ВыборкаДетальныеЗаписи.ДатаОплаты, "ДЛФ=D");
				СтрокаНомераОплатПр	= СтрокаНомераОплатПр + Символы.ПС + ВыборкаДетальныеЗаписи.НомерОплаты;
				СтрокаСуммаОплатПр 	= СтрокаСуммаОплатПр + Символы.ПС + ВыборкаДетальныеЗаписи.СуммаОплаты;
				
				СуммаОплатПоДокументуВнеПериода = СуммаОплатПоДокументуВнеПериода + ВыборкаДетальныеЗаписи.СуммаОплаты;
			КонецЕсли;
		КонецЦикла;
		
		//Если ВыборкаПлатежныйДокумент.СуммаДолг = 0 И СуммаОплатПоДокументуВПериоде = 0 Тогда
		//	Продолжить;
		//КонецЕсли;
		
		ИмяСФОплаты 			= СтрШаблон("СФОплаты%1", Постфикс);
		
		ОбластьСФОплаты  		= Макет.ПолучитьОбласть(ИмяСФОплаты);
		ОбластьСФОплаты.Параметры.ДатаСФ 				= Формат(ВыборкаПлатежныйДокумент.ДатаСФ, "ДЛФ=D");
		ОбластьСФОплаты.Параметры.НомерСФ 				= ВыборкаПлатежныйДокумент.НомерСФ;
		ОбластьСФОплаты.Параметры.ПериодНачисления 		= Формат(ВыборкаПлатежныйДокумент.ПериодНачисления, "ДФ='гггг, ММ'");
		ОбластьСФОплаты.Параметры.НачисленоСумма 		= ВыборкаПлатежныйДокумент.СуммаДолг;
		ОбластьСФОплаты.Параметры.ДатыОплат 			= СтрокаДатыОплат;
		ОбластьСФОплаты.Параметры.НомераОплат 			= СтрокаНомераОплат;
		ОбластьСФОплаты.Параметры.СуммаОплат 			= СтрокаСуммаОплат;
		ОбластьСФОплаты.Параметры.Сальдо 				= Формат(ВыборкаПлатежныйДокумент.СуммаДолг - ВыборкаПлатежныйДокумент.СуммаОплаты, "ЧН=0");
		Если ЗначениеЗаполнено(ВыборкаПлатежныйДокумент.ДокументИсточник) Тогда
			ДокументИсточник = ВыборкаПлатежныйДокумент.ДокументИсточник;
			ОбластьСФОплаты.Параметры.НомерСФДатаСФИсточника = ДокументИсточник.НомерПД + " " + Формат(ДокументИсточник.Дата, "ДЛФ=D");
		КонецЕсли;
		
		ТабДок.Вывести(ОбластьСФОплаты);
		
		ИмяИтогПоДокументу 		= СтрШаблон("ИтогПоДокументу%1", Постфикс);
		
		ОбластьИтогПоДокументу  = Макет.ПолучитьОбласть(ИмяИтогПоДокументу);
		ОбластьИтогПоДокументу.Параметры.НачисленоСумма = ВыборкаПлатежныйДокумент.СуммаДолг;
		ОбластьИтогПоДокументу.Параметры.СуммаОплат 	= СуммаОплатПоДокументуВПериоде;
		ОбластьИтогПоДокументу.Параметры.Сальдо 		= Формат(ВыборкаПлатежныйДокумент.СуммаДолг - СуммаОплатПоДокументуВПериоде, "ЧН=0");
		ОбластьИтогПоДокументу.Параметры.ОснРеалПени	= ?(ЗначениеЗаполнено(ВыборкаПлатежныйДокумент.ПлатежныйДокумент) И ВыборкаПлатежныйДокумент.ПлатежныйДокумент.ВидОперации = Перечисления.бестВидыОпераций.ПлатежныйДокумент_Пеня, "Пени", "Осн. реал.");
		
		ТабДок.Вывести(ОбластьИтогПоДокументу);
		
		СуммаДолг 	= СуммаДолг + ВыборкаПлатежныйДокумент.СуммаДолг;
		СуммаОплата = СуммаОплата + СуммаОплатПоДокументуВПериоде;
		
	КонецЦикла;
	                             
	
	//////////////////
	ИмяВсего = СтрШаблон("Всего%1", Постфикс);	
	ОбластьВсего  = Макет.ПолучитьОбласть(ИмяВсего);
	ОбластьВсего.Параметры.СуммаОплат 		= СуммаОплата;
	ОбластьВсего.Параметры.НачисленоСумма 	= СуммаДолг;
	ОбластьВсего.Параметры.Сальдо 			= Формат(СуммаДолг - СуммаОплата, "ЧН=0");
	ТабДок.Вывести(ОбластьВсего);
	//////////////////
	
	Если ЗначениеЗаполнено(СтрокаСуммаОплатПр) Тогда
		
		//////////////////
		ИмяОплатаПрПер = СтрШаблон("ОплатаПрПер%1", Постфикс);
		ОбластьОплатаПрПер = Макет.ПолучитьОбласть(ИмяОплатаПрПер);
		ОбластьОплатаПрПер.Параметры.ДатыОплат 		= СтрокаДатыОплатПр;
		ОбластьОплатаПрПер.Параметры.НомераОплат 	= СтрокаНомераОплатПр;
		ОбластьОплатаПрПер.Параметры.СуммаОплат 	= СтрокаСуммаОплатПр;
		ТабДок.Вывести(ОбластьОплатаПрПер);
		//////////////////
		
		//////////////////
		ИмяИтого = СтрШаблон("Итог%1", Постфикс);
		ОбластьИтого = Макет.ПолучитьОбласть(ИмяИтого);
		ОбластьИтого.Параметры.СуммаОплат = СуммаОплатПоДокументуВнеПериода;
		ТабДок.Вывести(ОбластьИтого);
		//////////////////
		
	КонецЕсли;
	
	РезультатСтруктура = бестВзаиморасчетыЮрЛицаСервер.ПолучитьРасшифровкуАвансовЗаПериод(Организация, Район, НачалоПериода, КонецПериода, Договор);
	РезультатПереплаты = РезультатСтруктура.Переплаты;
	РезультатАвансы = РезультатСтруктура.Авансы;
	
	Если Не РезультатПереплаты.Пустой() Тогда
		
		//////////////////
		СуммаОплат = 0;
		ИмяПереплата = СтрШаблон("Переплаты%1", Постфикс);
		ОбластьПереплата   = Макет.ПолучитьОбласть(ИмяПереплата);
		
		ВыборкаДетальныеЗаписи = РезультатПереплаты.Выбрать();
		
		СтрокаДатыОплат 	= "";
		СтрокаНомераОплат 	= "";
		СтрокаСуммаОплат 	= "";
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтрокаДатыОплат 	= СтрокаДатыОплат + Символы.ПС + Формат(ВыборкаДетальныеЗаписи.ДатаОплаты, "ДЛФ=D");
			СтрокаНомераОплат 	= СтрокаНомераОплат + Символы.ПС + ВыборкаДетальныеЗаписи.НомерОплаты;
			СтрокаСуммаОплат 	= СтрокаСуммаОплат + Символы.ПС + ВыборкаДетальныеЗаписи.СуммаОплаты;
			СуммаОплат 			= СуммаОплат + ВыборкаДетальныеЗаписи.СуммаОплаты; 
		КонецЦикла;
		ОбластьПереплата.Параметры.ДатыОплат 			= СтрокаДатыОплат;
		ОбластьПереплата.Параметры.НомераОплат 			= СтрокаНомераОплат;
		ОбластьПереплата.Параметры.СуммаОплат 			= СтрокаСуммаОплат;
		ТабДок.Вывести(ОбластьПереплата);
		
		ИмяИтогПоПереплате = СтрШаблон("Итог%1", Постфикс);
		ОбластьИтогПоПереплате  = Макет.ПолучитьОбласть(ИмяИтогПоПереплате);
		ОбластьИтогПоПереплате.Параметры.СуммаОплат 	= СуммаОплат;
		ТабДок.Вывести(ОбластьИтогПоПереплате);
		//////////////////
		
	КонецЕсли;
	
	Если Не РезультатАвансы.Пустой() Тогда
		
		//////////////////
		СуммаОплат = 0;
		ИмяАвансы = СтрШаблон("Авансы%1", Постфикс);
		ОбластьАвансы = Макет.ПолучитьОбласть(ИмяАвансы);
		
		ВыборкаДетальныеЗаписи = РезультатАвансы.Выбрать();
		
		СтрокаДатыОплат 	= "";
		СтрокаНомераОплат 	= "";
		СтрокаСуммаОплат 	= "";
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтрокаДатыОплат 	= СтрокаДатыОплат + Символы.ПС + Формат(ВыборкаДетальныеЗаписи.ДатаОплаты, "ДЛФ=D");
			СтрокаНомераОплат 	= СтрокаНомераОплат + Символы.ПС + ВыборкаДетальныеЗаписи.НомерОплаты;
			СтрокаСуммаОплат 	= СтрокаСуммаОплат + Символы.ПС + ВыборкаДетальныеЗаписи.Сумма;
			СуммаОплат 			= СуммаОплат + ВыборкаДетальныеЗаписи.Сумма; 
		КонецЦикла;
		ОбластьАвансы.Параметры.ДатыОплат 				= СтрокаДатыОплат;
		ОбластьАвансы.Параметры.НомераОплат 			= СтрокаНомераОплат;
		ОбластьАвансы.Параметры.СуммаОплат 				= СтрокаСуммаОплат;
		ТабДок.Вывести(ОбластьАвансы);
		
		ИмяИтогПоПереплате = СтрШаблон("Итог%1", Постфикс);
		ОбластьИтогПоПереплате  = Макет.ПолучитьОбласть(ИмяИтогПоПереплате);
		ОбластьИтогПоПереплате.Параметры.СуммаОплат 	= СуммаОплат;
		ТабДок.Вывести(ОбластьИтогПоПереплате);
		//////////////////
		
	КонецЕсли;
	
	//////////////////
	Если Постфикс = "" Тогда
		ОбластьОбъемЭЭ   					= Макет.ПолучитьОбласть("ОбъемЭЭ");
		ОбластьОбъемЭЭ.Параметры.Объем 		= ПолучитьОбъемЭЭ(Организация, Район, НачалоПериода, КонецПериода, Договор);
		ТабДок.Вывести(ОбластьОбъемЭЭ);
	КонецЕсли;	
	//////////////////
	
	Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьФактическуюЗадолженностьПоПериодам(Организация, Район, Договор,,, КонецПериода, Истина);
	
	Выборка = Результат.Выбрать();
	
	ФЗадолженностьНаКонец = 0;
	Если Выборка.Следующий() Тогда
		ФЗадолженностьНаКонец 	= Выборка.Сумма;
	КонецЕсли;
	
	Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьАвансовуюЗадолженностьНаДату(Организация, Район, КонецПериода, Договор);
	
	Выборка = Результат.Выбрать();
	
	АЗадолженностьНаКонец = 0;
	Если Выборка.Следующий() Тогда
		АЗадолженностьНаКонец 	= Выборка.Сумма;
	КонецЕсли;
	
	Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьПереплатуНаДату(Организация, Район, КонецПериода, Договор);
	
	Выборка = Результат.Выбрать();
	
	ПереплатаНаКонец = 0;
	Если Выборка.Следующий() Тогда
		ПереплатаНаКонец 	= Выборка.Сумма;
	КонецЕсли;
		
	Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьПенюНаДату(Организация, Район, КонецПериода, Договор);
	
	Выборка = Результат.Выбрать();
	
	ПеняНаКонец = 0;
	Если Выборка.Следующий() Тогда
		ПеняНаКонец 	= Выборка.Сумма;
	КонецЕсли;
	
	ОбластьПодвал1  = Макет.ПолучитьОбласть("Подвал1");
	ОбластьПодвал1.Параметры.Контрагент 					= Контрагент;
	ОбластьПодвал1.Параметры.КонецПериода 					= Формат(КонецПериода, "ДЛФ=D");
	ОбластьПодвал1.Параметры.ФактДолгНаКонец 				= ФЗадолженностьНаКонец;
	ТабДок.Вывести(ОбластьПодвал1);
	
	Если Постфикс = "" Тогда
		ОбластьПоСчетамЗаТекущееПотребление = Макет.ПолучитьОбласть("ПоСчетамЗаТекущееПотребление");
		ОбластьПоСчетамЗаТекущееПотребление.Параметры.АвансДолгНаКонец = АЗадолженностьНаКонец;
		ТабДок.Вывести(ОбластьПоСчетамЗаТекущееПотребление);
	КонецЕсли;
	
	ОбластьПодвал2 = Макет.ПолучитьОбласть("Подвал2");
	ОбластьПодвал2.Параметры.ФактПереплатаНаКонец 			= ПереплатаНаКонец;
	ОбластьПодвал2.Параметры.ПеняДолгНаКонец 				= ПеняНаКонец;
	ТабДок.Вывести(ОбластьПодвал2);
	
	Если Постфикс = "" Тогда
		ОбластьСальдоНаКонец = Макет.ПолучитьОбласть("СальдоНаКонец");
		ОбластьСальдоНаКонец.Параметры.СальдоНаКонец 			= ФЗадолженностьНаКонец + ПеняНаКонец - ПереплатаНаКонец;
		ОбластьСальдоНаКонец.Параметры.КонецПериода 			= Формат(КонецПериода, "ДЛФ=D");
		ТабДок.Вывести(ОбластьСальдоНаКонец);
	КонецЕсли;	
	
	ОбластьПодвал3 = Макет.ПолучитьОбласть("Подвал3");
	ОбластьПодвал3.Параметры.ПолноеНаименованиеОрганизации 	= ПолноеНаименованиеОрганизации; 
	ОбластьПодвал3.Параметры.Контрагент 					= Контрагент;
	
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.РуководительОрганизации Тогда
			ОбластьПодвал3.Параметры.РуководительОрганизацииФИО = эл.Сотрудник;
			ОбластьПодвал3.Параметры.РуководительОрганизацииДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал3.Параметры.РуководительОрганизацииДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал3.Параметры.РуководительОрганизацииДоверенность = "";
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьПодвал3);
		
КонецПроцедуры

#КонецОбласти

Функция СформироватьСчетНаОплатуЗаПросрочкуПлатежа(ИмяМакета, ПараметрыПечати)
	
	Макет 	= УправлениеПечатью.МакетПечатнойФормы("Документ.бестПлатежныйДокумент." + ИмяМакета);	
	ТабДок  = Новый ТабличныйДокумент;
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабДок.МасштабПечати = 85;
	
	Запрос = ПолучитьЗапросСчетНаОплатуЗаПросрочкуПлатежа();
	Запрос.УстановитьПараметр("Ссылка", ПараметрыПечати.ОбъектПечати);	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ЗаполнитьСчетНаОплатуЗаПросрочкуПлатежа(ТабДок, РезультатЗапроса, Макет, ПараметрыПечати);
	
	Возврат ТабДок;
	
КонецФункции

