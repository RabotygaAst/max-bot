	|			ТОГДА ДанныеДокументаИтог.СуммаСНДС - ЕСТЬNULL(Авансы.СуммаОбщая, 0)
	|		ИНАЧЕ ДанныеДокументаИтог.СуммаСНДС
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(бестВыставлениеПереплатыВАвансовыхСчетахСрезПоследних.УчитыватьПереплату, ЛОЖЬ)
	|			ТОГДА ДанныеДокументаИтог.СуммаНДС - ЕСТЬNULL(Авансы.СуммаНДСОбщая, 0)
	|		ИНАЧЕ ДанныеДокументаИтог.СуммаНДС
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(бестВыставлениеПереплатыВАвансовыхСчетахСрезПоследних.УчитыватьПереплату, ЛОЖЬ)
	|			ТОГДА ДанныеДокументаИтог.СуммаСНДС - ДанныеДокументаИтог.СуммаНДС - ЕСТЬNULL(Авансы.СуммаОбщаяБезНДС, 0)
	|		ИНАЧЕ ДанныеДокументаИтог.СуммаСНДС - ДанныеДокументаИтог.СуммаНДС
	|	КОНЕЦ,
	|	ДанныеДокументаИтог.СуммаСНДС - ДанныеДокументаИтог.СуммаНДС,
	|	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.СрокОплаты,
	|	ДанныеДокументаИтог.ЭлектронноеВзаимодействие,
	|	ДанныеДокументаИтог.Процент,
	|	ВЫБОР
	|		КОГДА МКДвДоговоре.МКД = ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|			ТОГДА ""Н""
	|		ИНАЧЕ ""Г""
	|	КОНЕЦ";
	
	Возврат Запрос;
		
КонецФункции

Процедура ЗаполнитьСчетНаОплатуПред(ТабДок, РезультатЗапроса, Макет, ПараметрыПечати) Экспорт 
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
			
		ОбластьСчетНаОплатуПред  = Макет.ПолучитьОбласть("СчетНаОплатуПред");
		
		ЭлектронноеВзаимодействие = Неопределено;	
		
		ЗаполнитьЗначенияСвойств(ОбластьСчетНаОплатуПред.Параметры,Выборка);
		ОбластьСчетНаОплатуПред.Параметры.ДатаПД 						= Формат(Выборка.ДатаПД, "ДЛФ=D");
		ОбластьСчетНаОплатуПред.Параметры.ДатаДоговора 					= Формат(Выборка.ДатаДоговора, "ДЛФ=D");
		ОбластьСчетНаОплатуПред.Параметры.ГодМесяц 						= Формат(Выборка.ПериодНачисления, "ДФ=yyyy.MM");
		ОбластьСчетНаОплатуПред.Параметры.СуммаБезНДССАвансом        	= ?(Выборка.СуммаБезНДССАвансом > 0, Выборка.СуммаБезНДССАвансом,0);
		ОбластьСчетНаОплатуПред.Параметры.СуммаНДССАвансом        		= ?(Выборка.СуммаНДССАвансом > 0, Выборка.СуммаНДССАвансом,0);
		ОбластьСчетНаОплатуПред.Параметры.СуммаСНДССАвансом        		= ?(Выборка.СуммаСНДССАвансом > 0, Выборка.СуммаСНДССАвансом,0);
		ОбластьСчетНаОплатуПред.Параметры.МесяцГодПериодаРасчета 		= СклонениеПредставленийОбъектов.ПросклонятьПредставление(Формат(Выборка.ПериодНачисления, "ДФ='MMMM'"),2) + " " + Формат(Выборка.ПериодНачисления, "ДФ='yyyy ''г.'''");
		ЭлектронноеВзаимодействие = Выборка.ЭлектронноеВзаимодействие;
		
		
		Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
			Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.РуководительОрганизации Тогда
				ОбластьСчетНаОплатуПред.Параметры.РуководительОрганизацииФИО = эл.Сотрудник;
				ОбластьСчетНаОплатуПред.Параметры.РуководительОрганизацииДолжность = эл.Должность;
				Если ЗначениеЗаполнено(эл.Доверенность) Тогда
					ОбластьСчетНаОплатуПред.Параметры.РуководительОрганизацииДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
				Иначе
					ОбластьСчетНаОплатуПред.Параметры.РуководительОрганизацииДоверенность = "";
				КонецЕсли;
				Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
					Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
					ОбластьСчетНаОплатуПред.Рисунки.ОбразецПодписиРуководителяОрганизации.Картинка         = Картинка;
				КонецЕсли;	
			ИначеЕсли эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГлавныйБухгалтер Тогда
				ОбластьСчетНаОплатуПред.Параметры.ГлавныйБухгалтерФИО = эл.Сотрудник;
				ОбластьСчетНаОплатуПред.Параметры.ГлавныйБухгалтерДолжность = эл.Должность;
				Если ЗначениеЗаполнено(эл.Доверенность) Тогда
					ОбластьСчетНаОплатуПред.Параметры.ГлавныйБухгалтерДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
				Иначе
					ОбластьСчетНаОплатуПред.Параметры.ГлавныйБухгалтерДоверенность = "";
				КонецЕсли;
				Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
					Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
					ОбластьСчетНаОплатуПред.Рисунки.ОбразецПодписиГлавногоБухгалтера.Картинка         = Картинка;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		ТабДок.Вывести(ОбластьСчетНаОплатуПред);
		
	КонецЕсли;
	
КонецПроцедуры     

#КонецОбласти

#Область СчетНаОплатуЗаПросрочкуПлатежа

Функция ПолучитьЗапросСчетНаОплатуЗаПросрочкуПлатежа() Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестПлатежныйДокумент.Организация КАК Организация,
	|	бестПлатежныйДокумент.НомерПД КАК НомерПД,
	|	бестПлатежныйДокумент.Дата КАК Дата,
	|	бестПлатежныйДокумент.Район КАК Район,
	|	бестПлатежныйДокумент.Договор КАК Договор,
	|	бестПлатежныйДокумент.ПериодНачисления КАК ПериодНачисления,
	|	бестПлатежныйДокумент.Ответственный КАК Ответственный,
	|	бестПлатежныйДокументПеня.ДнейПросрочки КАК ДнейПросрочки,
	|	бестПлатежныйДокументПеня.СуммаПени КАК СуммаПени,
	|	бестПлатежныйДокументПеня.КоэффициентЧислитель КАК КоэффициентЧислитель,
	|	бестПлатежныйДокументПеня.КоэффициентЗнаменатель КАК КоэффициентЗнаменатель,
	|	бестПлатежныйДокументПеня.ПроцентПени КАК ПроцентПени,
	|	бестПлатежныйДокументПеня.ПлатежныйДокумент.Номер КАК ПлатежныйДокументНомер,
	|	бестПлатежныйДокументПеня.ДатаНачалаНачисленияПени КАК ДатаНачалаНачисленияПени,
	|	бестПлатежныйДокументПеня.ИзначальнаяДатаНачисленияПени КАК ИзначальнаяДатаНачисленияПени,
	|	бестПлатежныйДокументПеня.СуммаЗадолженности КАК СуммаЗадолженности,
	|	бестПлатежныйДокументПеня.СтавкаРефинансирования КАК СтавкаРефинансирования,
	|	бестПлатежныйДокументПеня.ПлатежныйДокумент.Дата КАК ПлатежныйДокументДата,
	|	бестПлатежныйДокументПеня.ПлатежныйДокумент.НомерПД КАК ПлатежныйДокументНомерПД
	|ПОМЕСТИТЬ ДанныеДокумента
	|ИЗ
	|	Документ.бестПлатежныйДокумент.Пеня КАК бестПлатежныйДокументПеня
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|		ПО бестПлатежныйДокументПеня.Ссылка = бестПлатежныйДокумент.Ссылка
	|ГДЕ
	|	бестПлатежныйДокумент.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
