#Область ПрограммныйИнтерфейс

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ИмяМакета 				= КоллекцияПечатныхФорм[0].ИмяМакета;
	СинонимМакета 			= КоллекцияПечатныхФорм[0].СинонимМакета;
	
	Если ИмяМакета = "ПФ_MXL_СчетФактураНаРеализацию" Тогда
		ТабличныйДокумент 		= СформироватьСчетФактураНаРеализацию(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_АктПриемаПередачи" Тогда
		ТабличныйДокумент 		= СформироватьАктПриемаПередачи(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_АктПриемаПередачиПоЭЭ" Тогда
		ТабличныйДокумент 		= СформироватьАктПриемаПередачиПоЭЭ(ИмяМакета, ПараметрыПечати);	
	ИначеЕсли ИмяМакета = "ПФ_MXL_СоглашениеНаКорректировку" Тогда
		ТабличныйДокумент 		= СформироватьСоглашениеНаКорректировку(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_ПерерасчетЭлектроэнергии" Тогда
		ТабличныйДокумент 		= СформироватьАктПерерасчета(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_СчетНаОстаток" Тогда
		ТабличныйДокумент 		= СформироватьСчетНаОстаток(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_СчетНаОплатуПост" Тогда
		ТабличныйДокумент 		= СформироватьСчетНаОплатуПост(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_СчетНаОплатуПред" Тогда
		ТабличныйДокумент 		= СформироватьСчетНаОплатуПред(ИмяМакета, ПараметрыПечати);	
	ИначеЕсли ИмяМакета = "ПФ_MXL_КорректировочнаяСчетФактура" Тогда
		ТабличныйДокумент 		= СформироватьКорректировочнуюСФ(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_ИсправительнаяСчетФактура" Тогда
		ТабличныйДокумент 		= СформироватьИсправительнуюСФ(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_АктСверки" Тогда
		ТабличныйДокумент 		= СформироватьАктСверки(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_СчетНаОплатуЗаПросрочкуПлатежа" Тогда
		ТабличныйДокумент 		= СформироватьСчетНаОплатуЗаПросрочкуПлатежа(ИмяМакета, ПараметрыПечати);
	ИначеЕсли ИмяМакета = "ПФ_MXL_СчетНаПредварительнуюОплатуЭЭ" Тогда
		ТабличныйДокумент 		= СформироватьСчетНаПредварительнуюОплатуЭЭ(ИмяМакета, ПараметрыПечати);
	КонецЕсли;
	
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, ИмяМакета) Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		ИмяМакета, СинонимМакета,
		ТабличныйДокумент, ,
		"Документ.бестПлатежныйДокумент." + ИмяМакета);
	КонецЕсли;
	
КонецПроцедуры

Функция ВернутьКартинкуОбъекта(ОбъектСКартинкой, РеквизитОбъекта) Экспорт
	ДвоичныеДанныеФайла 			      = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектСКартинкой, РеквизитОбъекта).Получить();
	Если ЗначениеЗаполнено(ДвоичныеДанныеФайла) И ТипЗнч(ДвоичныеДанныеФайла) = Тип("ДвоичныеДанные") Тогда
		Картинка                          = Новый Картинка(ДвоичныеДанныеФайла, Истина);
	Иначе
		Картинка                          = Новый Картинка();
	КонецЕсли;
	Возврат Картинка;
КонецФункции

 // Заполняет табличную часть ОсновнаяРеализация документа при корректировке
//
// Параметры:
//  ДокументОбъект  - ДокументОбъект.бестПлатежныйДокумент, ДанныеФормыСтруктура - Документ бестПлатежныйДокумент
//
Процедура ЗаполнитьДанныеКорректировки(ДокументОбъект) Экспорт
	
	ДокументОбъект.ОсновнаяРеализация.Очистить();
	
	Если ЗначениеЗаполнено(ДокументОбъект.ДокументОснование) Тогда
		Документы.бестПерерасчетЭЭ.ЗаполнитьДанныеКорректировки(ДокументОбъект.Договор,
			ДокументОбъект.ДокументОснование,
			ДокументОбъект.ОсновнаяРеализация,
			ДокументОбъект.ДокументИсточник);
			
	ИначеЕсли Не ДокументОбъект.ДокументИсточник.Пустая() Тогда
			
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета КАК ОбъектРасчета,
		               |	бестПлатежныйДокументОсновнаяРеализация.ТочкаУчета КАК ТочкаУчета,
		               |	бестПлатежныйДокументОсновнаяРеализация.Услуга КАК Услуга,
		               |	бестПлатежныйДокументОсновнаяРеализация.ОбъемУслуги КАК ОбъемУслуги,
		               |	бестПлатежныйДокументОсновнаяРеализация.СуммаСредневзвешенная КАК СуммаСредневзвешенная,
		               |	бестПлатежныйДокументОсновнаяРеализация.СуммаЗаСбытовуюНадбавку КАК СуммаЗаСбытовуюНадбавку,
		               |	бестПлатежныйДокументОсновнаяРеализация.СуммаЗаУслугиПоПередачи КАК СуммаЗаУслугиПоПередачи,
		               |	бестПлатежныйДокументОсновнаяРеализация.СуммаЗаИныеУслуги КАК СуммаЗаИныеУслуги,
		               |	бестПлатежныйДокументОсновнаяРеализация.Сумма КАК Сумма,
		               |	бестПлатежныйДокументОсновнаяРеализация.СуммаСредневзвешеннаяНДС КАК СуммаСредневзвешеннаяНДС,
		               |	бестПлатежныйДокументОсновнаяРеализация.СуммаЗаСбытовуюНадбавкуНДС КАК СуммаЗаСбытовуюНадбавкуНДС,
		               |	бестПлатежныйДокументОсновнаяРеализация.СуммаЗаУслугиПоПередачиНДС КАК СуммаЗаУслугиПоПередачиНДС,
		               |	бестПлатежныйДокументОсновнаяРеализация.СуммаЗаИныеУслугиНДС КАК СуммаЗаИныеУслугиНДС,
		               |	бестПлатежныйДокументОсновнаяРеализация.СуммаНДС КАК СуммаНДС,
		               |	бестПлатежныйДокументОсновнаяРеализация.ТарифНаИныеУслуги КАК ТарифНаИныеУслуги,
		               |	бестПлатежныйДокументОсновнаяРеализация.ТарифЗаСбытовуюНадбавку КАК ТарифЗаСбытовуюНадбавку,
		               |	бестПлатежныйДокументОсновнаяРеализация.ТарифЗаУслугиПоПередачи КАК ТарифЗаУслугиПоПередачи,
		               |	бестПлатежныйДокументОсновнаяРеализация.ТарифНаСредневзвешанную КАК ТарифНаСредневзвешанную,
		               |	бестПлатежныйДокументОсновнаяРеализация.Тариф КАК Тариф,
		               |	бестПлатежныйДокументОсновнаяРеализация.СтавкаНДС КАК СтавкаНДС,
		               |	бестПлатежныйДокументОсновнаяРеализация.СпособНачисления КАК СпособНачисления,
		               |	бестПлатежныйДокументОсновнаяРеализация.НДСВнутри КАК НДСВнутри
		               |ИЗ
		               |	Документ.бестПлатежныйДокумент.ОсновнаяРеализация КАК бестПлатежныйДокументОсновнаяРеализация
		               |ГДЕ
		               |	бестПлатежныйДокументОсновнаяРеализация.Ссылка = &Ссылка
		               |	И НЕ бестПлатежныйДокументОсновнаяРеализация.ИсходныеДанные";
		
		Запрос.УстановитьПараметр("Ссылка", ДокументОбъект.ДокументИсточник);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаРеализации = ДокументОбъект.ОсновнаяРеализация.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаРеализации, Выборка);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если Параметры.свойство("Основание") Тогда
		СтандартнаяОбработка 	= Ложь;
		ВыбраннаяФорма = "ФормаДокументаРасчетный";
		Возврат;
	КонецЕсли;
	
	ЕстьЗначенияЗаполнения  	= Параметры.свойство("ЗначенияЗаполнения");
	
	ВидОперацииВыбран  			= Ложь;
	
	Если ЕстьЗначенияЗаполнения тогда
		ВидОперацииВыбран 		= Параметры.ЗначенияЗаполнения.свойство("видоперации");
	КонецЕсли;	
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка 	= Ложь;
		Если Параметры.свойство("Ключ") тогда
			ВидОперации 		=  Параметры.ключ.Видоперации;
			ПрефиксФормы  		= бестРаботаСВидамиОперацийСервер.ПрефиксФормы("бестПлатежныйДокумент",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		ИначеЕсли  Параметры.свойство("ЗначениеКопирования") тогда
			ВидОперации 		= Параметры.ЗначениеКопирования.видоперации;
			ПрефиксФормы  		= бестРаботаСВидамиОперацийСервер.ПрефиксФормы("бестПлатежныйДокумент",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		ИначеЕсли  ЕстьЗначенияЗАполнения и ВидОперацииВыбран тогда
			ВидОперации 		= Параметры.ЗначенияЗаполнения.видоперации;
			ПрефиксФормы  		= бестРаботаСВидамиОперацийСервер.ПрефиксФормы("бестПлатежныйДокумент",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;	
		Иначе
			ВыбраннаяФорма 		= "ОбщаяФорма.бестФормаВыбораОперации";
			Параметры.вставить("ИмяДокумента","бестПлатежныйДокумент");
			Параметры.вставить("ВыборОперации",Истина);
		КонецЕсли; 		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область СчетФактураНаРеализацию

Функция ПолучитьЗапросСчетФактураНаРеализацию() Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестПлатежныйДокумент.Организация КАК Организация,
	|	бестПлатежныйДокумент.НомерПД КАК НомерПД,
	|	бестПлатежныйДокумент.Дата КАК Дата,
	|	бестПлатежныйДокумент.Район КАК Район,
	|	бестПлатежныйДокумент.Договор КАК Договор,
	|	бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета КАК ОбъектРасчета,
	|	бестПлатежныйДокументОсновнаяРеализация.ТочкаУчета КАК ТочкаУчета,
	|	СУММА(ВЫБОР
	|			КОГДА бестПлатежныйДокументОсновнаяРеализация.НДСВнутри
	|				ТОГДА бестПлатежныйДокументОсновнаяРеализация.Сумма
	|			ИНАЧЕ бестПлатежныйДокументОсновнаяРеализация.Сумма + бестПлатежныйДокументОсновнаяРеализация.СуммаНДС
	|		КОНЕЦ) КАК СуммаСНДС,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.СуммаНДС) КАК СуммаНДС,
	|	СУММА(ВЫБОР
	|			КОГДА бестПлатежныйДокументОсновнаяРеализация.НДСВнутри
	|				ТОГДА бестПлатежныйДокументОсновнаяРеализация.Сумма - бестПлатежныйДокументОсновнаяРеализация.СуммаНДС
	|			ИНАЧЕ бестПлатежныйДокументОсновнаяРеализация.Сумма
	|		КОНЕЦ) КАК СуммаБезНДС,
	|	бестПлатежныйДокументОсновнаяРеализация.Тариф КАК Тариф,
	|	бестПлатежныйДокументОсновнаяРеализация.СтавкаНДС КАК СтавкаНДС,
	|	бестПлатежныйДокументОсновнаяРеализация.Услуга КАК Услуга,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.ОбъемУслуги) КАК ОбъемУслуги,
	|	бестПлатежныйДокумент.ПериодНачисления КАК ПериодНачисления,
	|	бестПлатежныйДокумент.Ответственный КАК Ответственный,
	|	бестПлатежныйДокументОсновнаяРеализация.СпособНачисления КАК СпособНачисления,
	|	бестПлатежныйДокументОсновнаяРеализация.Тариф КАК ЗначениеТарифа
	|ПОМЕСТИТЬ ДанныеДокумента
	|ИЗ
	|	Документ.бестПлатежныйДокумент.ОсновнаяРеализация КАК бестПлатежныйДокументОсновнаяРеализация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|		ПО бестПлатежныйДокументОсновнаяРеализация.Ссылка = бестПлатежныйДокумент.Ссылка
	|ГДЕ
	|	бестПлатежныйДокумент.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	бестПлатежныйДокумент.Договор,
	|	бестПлатежныйДокумент.НомерПД,
	|	бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета,
	|	бестПлатежныйДокументОсновнаяРеализация.ТочкаУчета,
	|	бестПлатежныйДокумент.Организация,
	|	бестПлатежныйДокумент.Район,
	|	бестПлатежныйДокумент.Дата,
	|	бестПлатежныйДокументОсновнаяРеализация.СпособНачисления,
	|	бестПлатежныйДокумент.Ответственный,
	|	бестПлатежныйДокумент.ПериодНачисления,
	|	бестПлатежныйДокументОсновнаяРеализация.Услуга,
	|	бестПлатежныйДокументОсновнаяРеализация.Тариф,
	|	бестПлатежныйДокументОсновнаяРеализация.СтавкаНДС,
	|	бестПлатежныйДокументОсновнаяРеализация.Тариф
	|
	|ИМЕЮЩИЕ
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.ОбъемУслуги) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокумента.Организация КАК Организация,
	|	ДанныеДокумента.НомерПД КАК НомерПД,
	|	ДанныеДокумента.Дата КАК ДатаПД,
	|	ДанныеДокумента.Район КАК Район,
	|	ДанныеДокумента.Договор КАК Договор,
	|	ДанныеДокумента.ОбъектРасчета КАК ОбъектРасчета,
	|	ДанныеДокумента.СуммаСНДС КАК СуммаСНДС,
	|	ДанныеДокумента.СуммаНДС КАК СуммаНДС,
	|	ДанныеДокумента.Тариф КАК Тариф,
	|	ДанныеДокумента.СтавкаНДС КАК СтавкаНДС,
	|	ДанныеДокумента.Услуга КАК Услуга,
	|	ДанныеДокумента.ОбъемУслуги КАК ОбъемУслуги,
	|	Организации.ИНН КАК ИННОрг,
	|	Организации.КПП КАК КППОрг,
	|	Организации.НаименованиеПолное КАК ПолноеНаименованиеОрганизации,
	|	ОрганизацииКонтактнаяИнформация.Представление КАК ФактическийАдресОрг,
	|	ОрганизацииКонтактнаяИнформация1.Представление КАК ЮридическийАдресОрг,
	|	энргКонтрагентыКонтактнаяИнформация.Представление КАК ФактическийАдресКонтрагента,
	|	энргКонтрагентыКонтактнаяИнформация1.Представление КАК ТелефонКонтрагента,
	|	энргКонтрагенты.Ссылка КАК Контрагент,
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	энргЕдиницыИзмерения.Ссылка КАК ЕдИзм,
	|	энргЕдиницыИзмерения.КодПоОКЕИ КАК КодОКЕИ,
	|	энргЗоныОтвественности.КодРайона КАК КодРайона,
	|	ДанныеДокумента.СуммаБезНДС КАК СуммаБезНДС,
	|	ДанныеДокумента.ПериодНачисления КАК ПериодНачисления,
	|	энргКонтрагенты.ИНН КАК ИННКон,
	|	энргКонтрагенты.КПП КАК КППКон,
	|	ПользователиКонтактнаяИнформация.Представление КАК ОтветственныйТелефон,
	|	ПользователиКонтактнаяИнформация1.Представление КАК ОтветственныйПочта,
	|	ДанныеДокумента.Ответственный КАК Ответственный,
	|	энргДоговорыКонтрагентов.ЭлектронноеВзаимодействие КАК ЭлектронноеВзаимодействие,
	|	ДанныеДокумента.СпособНачисления КАК СпособНачисления,
	|	ДанныеДокумента.ЗначениеТарифа КАК ЗначениеТарифа,
	|	бестЦеновыеКатегорииТочекУчетаСрезПоследних.ЦеноваяКатегория КАК ЦеноваяКатегория
	|ПОМЕСТИТЬ Итог
	|ИЗ
	|	ДанныеДокумента КАК ДанныеДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргЗоныОтвественности КАК энргЗоныОтвественности
	|		ПО ДанныеДокумента.Район = энргЗоныОтвественности.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО ДанныеДокумента.Организация = Организации.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
	|		ПО ДанныеДокумента.Организация = ОрганизацииКонтактнаяИнформация.Ссылка
	|			И (ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресОрганизации))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация1
	|		ПО ДанныеДокумента.Организация = ОрганизацииКонтактнаяИнформация1.Ссылка
	|			И (ОрганизацииКонтактнаяИнформация1.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации))
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
	|				ПО (энргКонтрагентыКонтактнаяИнформация.Ссылка = энргКонтрагенты.Ссылка)
	|					И (энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация1
	|				ПО энргКонтрагенты.Ссылка = энргКонтрагентыКонтактнаяИнформация1.Ссылка
	|					И (энргКонтрагентыКонтактнаяИнформация1.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента))
	|			ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагенты.Ссылка
	|		ПО ДанныеДокумента.Договор = энргДоговорыКонтрагентов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргЕдиницыИзмерения КАК энргЕдиницыИзмерения
	|		ПО ДанныеДокумента.Услуга.ЕдиницаИзмерения = энргЕдиницыИзмерения.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
	|		ПО ДанныеДокумента.Ответственный = ПользователиКонтактнаяИнформация.Ссылка
	|			И (ПользователиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПользователя))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация1
	|		ПО ДанныеДокумента.Ответственный = ПользователиКонтактнаяИнформация1.Ссылка
	|			И (ПользователиКонтактнаяИнформация1.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПользователя))
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестЦеновыеКатегорииТочекУчета.СрезПоследних(
	|				&Период,
	|				(Организация, Район, ОбъектРасчета, ТочкаУчета) В
	|					(ВЫБРАТЬ
	|						ДанныеДокумента.Организация,
	|						ДанныеДокумента.Район,
	|						ДанныеДокумента.ОбъектРасчета,
	|						ДанныеДокумента.ТочкаУчета
	|					ИЗ
	|						ДанныеДокумента КАК ДанныеДокумента)) КАК бестЦеновыеКатегорииТочекУчетаСрезПоследних
	|		ПО ДанныеДокумента.Организация = бестЦеновыеКатегорииТочекУчетаСрезПоследних.Организация
	|			И ДанныеДокумента.Район = бестЦеновыеКатегорииТочекУчетаСрезПоследних.Район
	|			И ДанныеДокумента.ОбъектРасчета = бестЦеновыеКатегорииТочекУчетаСрезПоследних.ОбъектРасчета
	|			И ДанныеДокумента.ТочкаУчета = бестЦеновыеКатегорииТочекУчетаСрезПоследних.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.НомерПД КАК НомерПД,
	|	Итог.ДатаПД КАК ДатаПД,
	|	Итог.ИННОрг КАК ИННОрг,
	|	Итог.КППОрг КАК КППОрг,
	|	Итог.ПолноеНаименованиеОрганизации КАК ПолноеНаименованиеОрганизации,
	|	Итог.ФактическийАдресОрг КАК ФактическийАдресОрг,
	|	Итог.ЮридическийАдресОрг КАК ЮридическийАдресОрг,
	|	Итог.ФактическийАдресКонтрагента КАК ФактическийАдресКонтрагента,
	|	Итог.ТелефонКонтрагента КАК ТелефонКонтрагента,
	|	Итог.Контрагент КАК Контрагент,
	|	Итог.НомерДоговора КАК НомерДоговора,
	|	Итог.ДатаДоговора КАК ДатаДоговора,
	|	Итог.КодРайона КАК КодРайона,
	|	Итог.ИННКон КАК ИННКон,
	|	Итог.КППКон КАК КППКон,
	|	Итог.ОтветственныйТелефон КАК ОтветственныйТелефон,
	|	Итог.ОтветственныйПочта КАК ОтветственныйПочта,
	|	Итог.Ответственный КАК Ответственный,
	|	Итог.ЭлектронноеВзаимодействие КАК ЭлектронноеВзаимодействие,
	|	Итог.ЗначениеТарифа КАК ЗначениеТарифа
	|ИЗ
	|	Итог КАК Итог
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.ОбъектРасчета КАК ОбъектРасчета,
	|	Итог.СуммаСНДС КАК СуммаСНДС,
	|	Итог.СуммаНДС КАК СуммаНДС,
	|	Итог.Тариф КАК Тариф,
	|	Итог.СтавкаНДС КАК СтавкаНДС,
	|	Итог.Услуга КАК Услуга,
	|	Итог.ОбъемУслуги КАК ОбъемУслуги,
	|	Итог.ЕдИзм КАК ЕдИзм,
	|	Итог.КодОКЕИ КАК КодОКЕИ,
	|	Итог.СуммаБезНДС КАК СуммаБезНДС,
	|	Итог.ПериодНачисления КАК ГодМесяц,
	|	Итог.СпособНачисления КАК СпособНачисления,
	|	энргВидыУслуг.ИспользоватьРасчетРеактивнойЭнергии КАК ИспользоватьРасчетРеактивнойЭнергии,
	|	энргВидыУслуг.Наименование КАК Наименование,
	|	Итог.ЗначениеТарифа КАК ЗначениеТарифа,
	|	ПРЕДСТАВЛЕНИЕ(Итог.Услуга) КАК УслугаПредставление,
	|	Итог.ЦеноваяКатегория КАК ЦеноваяКатегория
	|ИЗ
	|	Итог КАК Итог
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО Итог.Услуга = энргВидыУслуг.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование УБЫВ
	|ИТОГИ
	|	СУММА(СуммаСНДС),
	|	СУММА(СуммаНДС),
	|	СУММА(СуммаБезНДС)
	|ПО
	|	ОбъектРасчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Итог.СуммаСНДС) КАК СуммаСНДС,
	|	СУММА(Итог.СуммаНДС) КАК СуммаНДС,
	|	СУММА(Итог.ОбъемУслуги) КАК ОбъемУслуги,
	|	Итог.ЕдИзм КАК ЕдИзм,
	|	Итог.КодОКЕИ КАК КодОКЕИ,
	|	СУММА(Итог.СуммаБезНДС) КАК СуммаБезНДС
	|ИЗ
	|	Итог КАК Итог
	|
	|СГРУППИРОВАТЬ ПО
	|	Итог.ЕдИзм,
	|	Итог.КодОКЕИ";
	
	Возврат Запрос;
	
КонецФункции

Процедура ЗаполнитьСчетФактуруНаРеализацию(ТабДок, РезультатЗапроса, Макет, ПараметрыПечати) Экспорт 
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	ВыборкаШапка 			= РезультатЗапроса[2].Выбрать();
	ВыборкаОбъектРасчета 	= РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИтогПоЕдИзм 		= РезультатЗапроса[4].Выбрать();
	ЭлектронноеВзаимодействие = Неопределено;
	Если ВыборкаШапка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ВыборкаШапка);
		ОбластьШапка.Параметры.ДатаПД = Формат(ВыборкаШапка.ДатаПД, "ДЛФ=D");
		ОбластьШапка.Параметры.ДатаДоговора = Формат(ВыборкаШапка.ДатаДоговора, "ДЛФ=D");
		ТабДок.Вывести(ОбластьШапка);
		ЭлектронноеВзаимодействие = ВыборкаШапка.ЭлектронноеВзаимодействие;
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапка);
	КонецЕсли;	
	
	Пока ВыборкаОбъектРасчета.Следующий() Цикл
		ОбластьОбъектРасчета = Макет.ПолучитьОбласть("ОбъектРасчета");
		ОбластьОбъектРасчета.Параметры.ОбъектРасчета = ВыборкаОбъектРасчета.ОбъектРасчета;
		ТабДок.Вывести(ОбластьОбъектРасчета);
		НомерСтроки = 1;
		
		ВыборкаДетальныеЗаписи = ВыборкаОбъектРасчета.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ОбластьДанныеЗадолженности = Макет.ПолучитьОбласть("ДанныеЗадолженности");
			ЗаполнитьЗначенияСвойств(ОбластьДанныеЗадолженности.Параметры,ВыборкаДетальныеЗаписи);
			
			//Если ВыборкаДетальныеЗаписи.ИспользоватьРасчетРеактивнойЭнергии Тогда
			//	ОбластьДанныеЗадолженности.Параметры.ТекстНаименованиеТовара = "Надбавка за потребление Реактивной энергии"
			//	//+ ПолучитьСклоненияСтроки(Строка(ВыборкаДетальныеЗаписи.Услуга),, "Творительный");
			//Иначе
			//	ОбластьДанныеЗадолженности.Параметры.ТекстНаименованиеТовара = "Потребленная" + Строка(ВыборкаДетальныеЗаписи.Услуга) + " по нерегулируемым ценам по приборам учета";
			//КонецЕсли;
			
			
			Если ВыборкаДетальныеЗаписи.ИспользоватьРасчетРеактивнойЭнергии Тогда	
				ОбластьДанныеЗадолженности.Параметры.ТекстНаименованиеТовара = "Надбавка за потребление Реактивной энергии"
			Иначе
				Если ВыборкаДетальныеЗаписи.УслугаПредставление = "Электроэнергия" И ВыборкаДетальныеЗаписи.ЦеноваяКатегория = Перечисления.бестЦеновыеКатегории.Население Тогда
					ОбластьДанныеЗадолженности.Параметры.ТекстНаименованиеТовара = "Электроэнергия, отпущенная населению по приборам учета";	
				Иначе
					ОбластьДанныеЗадолженности.Параметры.ТекстНаименованиеТовара = "Потребленная " + ВыборкаДетальныеЗаписи.УслугаПредставление + " по нерегулируемым ценам по приборам учета";				
				КонецЕсли;
			КонецЕсли;
			
			ОбластьДанныеЗадолженности.Параметры.ГодМесяц = Формат(ВыборкаДетальныеЗаписи.ГодМесяц, "ДФ=yyyy.MM");
			ОбластьДанныеЗадолженности.Параметры.Номер = НомерСтроки;
			
			ТабДок.Вывести(ОбластьДанныеЗадолженности);
			НомерСтроки = НомерСтроки + 1;
		КонецЦикла;
		
		ОбластьИтогПоОбъектуРасчета = Макет.ПолучитьОбласть("ИтогПоОбъектуРасчета");
		ЗаполнитьЗначенияСвойств(ОбластьИтогПоОбъектуРасчета.Параметры,ВыборкаОбъектРасчета);
		ТабДок.Вывести(ОбластьИтогПоОбъектуРасчета);
		
	КонецЦикла;
	
	СуммаБезНДС = 0;
	СуммаНДС 	= 0;
	СуммаСНДС 	= 0;
	
	Пока ВыборкаИтогПоЕдИзм.Следующий() Цикл
		ОбластьИтогиПоЕдИзм = Макет.ПолучитьОбласть("ИтогиПоЕдИзм");
		ЗаполнитьЗначенияСвойств(ОбластьИтогиПоЕдИзм.Параметры,ВыборкаИтогПоЕдИзм);
		ТабДок.Вывести(ОбластьИтогиПоЕдИзм);
		
		СуммаБезНДС = СуммаБезНДС + ВыборкаИтогПоЕдИзм.СуммаБезНДС;
		СуммаНДС 	= СуммаНДС + ВыборкаИтогПоЕдИзм.СуммаНДС;
		СуммаСНДС 	= СуммаСНДС + ВыборкаИтогПоЕдИзм.СуммаСНДС;
	КонецЦикла;
	
	ОбластьОбщиеИтоги = Макет.ПолучитьОбласть("ОбщиеИтоги");
	ОбластьОбщиеИтоги.Параметры.СуммаБезНДС = СуммаБезНДС;
	ОбластьОбщиеИтоги.Параметры.СуммаНДС = СуммаНДС;
	ОбластьОбщиеИтоги.Параметры.СуммаСНДС = СуммаСНДС;
	ТабДок.Вывести(ОбластьОбщиеИтоги);	
	
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.РуководительОрганизации Тогда
			ОбластьПодвал.Параметры.РуководительОрганизацииФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.РуководительОрганизацииДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиРуководителяОрганизации.Картинка         = Картинка;
			КонецЕсли;
		ИначеЕсли эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГлавныйБухгалтер Тогда
			ОбластьПодвал.Параметры.ГлавныйБухгалтерФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.ГлавныйБухгалтерДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиГлавногоБухгалтера.Картинка         = Картинка;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьПодвал);
	
КонецПроцедуры     

#КонецОбласти

#Область ИсправительнаяСчетФактура

Функция ПолучитьЗапросИсправительнаяСчетФактура() Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестПлатежныйДокумент.Организация КАК Организация,
	|	бестПлатежныйДокумент.НомерПД КАК НомерПД,
	|	бестПлатежныйДокумент.Дата КАК Дата,
	|	бестПлатежныйДокумент.Район КАК Район,
	|	бестПлатежныйДокумент.Договор КАК Договор,
	|	бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета КАК ОбъектРасчета,
	|	СУММА(ВЫБОР
	|			КОГДА бестПлатежныйДокументОсновнаяРеализация.НДСВнутри
	|				ТОГДА бестПлатежныйДокументОсновнаяРеализация.Сумма
	|			ИНАЧЕ бестПлатежныйДокументОсновнаяРеализация.Сумма + бестПлатежныйДокументОсновнаяРеализация.СуммаНДС
	|		КОНЕЦ) КАК СуммаСНДС,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.СуммаНДС) КАК СуммаНДС,
	|	ВЫБОР
	|		КОГДА бестПлатежныйДокументОсновнаяРеализация.НДСВнутри
	|			ТОГДА бестПлатежныйДокументОсновнаяРеализация.Сумма - бестПлатежныйДокументОсновнаяРеализация.СуммаНДС
	|		ИНАЧЕ бестПлатежныйДокументОсновнаяРеализация.Сумма
	|	КОНЕЦ КАК СуммаБезНДС,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.Тариф) КАК Тариф,
	|	бестПлатежныйДокументОсновнаяРеализация.СтавкаНДС КАК СтавкаНДС,
	|	бестПлатежныйДокументОсновнаяРеализация.Услуга КАК Услуга,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.ОбъемУслуги) КАК ОбъемУслуги,
	|	бестПлатежныйДокумент.ПериодНачисления КАК ПериодНачисления,
	|	бестПлатежныйДокумент.Ответственный КАК Ответственный,
	|	ВЫБОР
	|		КОГДА НЕ энргВидыУслуг.бестИспользоватьРасчетПоМощности
	|			ТОГДА ""Потребленная электроэнергия по нерегулируемым ценам""
	|		КОГДА бестЦеновыеКатегорииТочекУчетаСрезПоследних.ЦеноваяКатегория В (ЗНАЧЕНИЕ(Перечисление.бестЦеновыеКатегории.ЧетвертаяЦК), ЗНАЧЕНИЕ(Перечисление.бестЦеновыеКатегории.ШестаяЦК))
	|			ТОГДА ""Мощность оплачиваемая на розничном рынке""
	|		ИНАЧЕ ""Мощность оплачиваемая в части услуг по передаче""
	|	КОНЕЦ КАК УслугаТекст,
	|	бестПлатежныйДокумент1.НомерПД КАК НомерПДИсточник,
	|	бестПлатежныйДокумент1.Дата КАК ДатаИсточник
	|ПОМЕСТИТЬ ДанныеДокумента
	|ИЗ
	|	Документ.бестПлатежныйДокумент.ОсновнаяРеализация КАК бестПлатежныйДокументОсновнаяРеализация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент1
	|			ПО бестПлатежныйДокумент.ДокументИсточник = бестПлатежныйДокумент1.Ссылка
	|		ПО бестПлатежныйДокументОсновнаяРеализация.Ссылка = бестПлатежныйДокумент.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестЦеновыеКатегорииТочекУчета.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район) КАК бестЦеновыеКатегорииТочекУчетаСрезПоследних
	|		ПО бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета = бестЦеновыеКатегорииТочекУчетаСрезПоследних.ОбъектРасчета
	|			И бестПлатежныйДокументОсновнаяРеализация.ТочкаУчета = бестЦеновыеКатегорииТочекУчетаСрезПоследних.ТочкаУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО бестПлатежныйДокументОсновнаяРеализация.Услуга = энргВидыУслуг.Ссылка
	|ГДЕ
	|	бестПлатежныйДокумент.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	бестПлатежныйДокумент.Организация,
	|	бестПлатежныйДокумент.НомерПД,
	|	бестПлатежныйДокумент.Дата,
	|	бестПлатежныйДокумент.Район,
	|	бестПлатежныйДокумент.Договор,
	|	бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета,
	|	бестПлатежныйДокументОсновнаяРеализация.СтавкаНДС,
	|	бестПлатежныйДокументОсновнаяРеализация.Услуга,
	|	бестПлатежныйДокумент.ПериодНачисления,
	|	бестПлатежныйДокумент.Ответственный,
	|	ВЫБОР
	|		КОГДА НЕ энргВидыУслуг.бестИспользоватьРасчетПоМощности
	|			ТОГДА ""Потребленная электроэнергия по нерегулируемым ценам""
	|		КОГДА бестЦеновыеКатегорииТочекУчетаСрезПоследних.ЦеноваяКатегория В (ЗНАЧЕНИЕ(Перечисление.бестЦеновыеКатегории.ЧетвертаяЦК), ЗНАЧЕНИЕ(Перечисление.бестЦеновыеКатегории.ШестаяЦК))
	|			ТОГДА ""Мощность оплачиваемая на розничном рынке""
	|		ИНАЧЕ ""Мощность оплачиваемая в части услуг по передаче""
	|	КОНЕЦ,
	|	бестПлатежныйДокумент1.НомерПД,
	|	бестПлатежныйДокумент1.Дата,
	|	ВЫБОР
	|		КОГДА бестПлатежныйДокументОсновнаяРеализация.НДСВнутри
	|			ТОГДА бестПлатежныйДокументОсновнаяРеализация.Сумма - бестПлатежныйДокументОсновнаяРеализация.СуммаНДС
	|		ИНАЧЕ бестПлатежныйДокументОсновнаяРеализация.Сумма
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокумента.Организация КАК Организация,
	|	ДанныеДокумента.НомерПД КАК НомерПД,
	|	ДанныеДокумента.Дата КАК ДатаПД,
	|	ДанныеДокумента.Район КАК Район,
	|	ДанныеДокумента.Договор КАК Договор,
	|	ДанныеДокумента.ОбъектРасчета КАК ОбъектРасчета,
	|	ДанныеДокумента.СуммаСНДС КАК СуммаСНДС,
	|	ДанныеДокумента.СуммаНДС КАК СуммаНДС,
	|	ДанныеДокумента.Тариф КАК Тариф,
	|	ДанныеДокумента.СтавкаНДС КАК СтавкаНДС,
	|	ДанныеДокумента.Услуга КАК Услуга,
	|	ДанныеДокумента.ОбъемУслуги КАК ОбъемУслуги,
	|	Организации.ИНН КАК ИННОрг,
	|	Организации.КПП КАК КППОрг,
	|	Организации.НаименованиеПолное КАК ПолноеНаименованиеОрганизации,
	|	ОрганизацииКонтактнаяИнформация.Представление КАК ФактическийАдресОрг,
	|	ОрганизацииКонтактнаяИнформация1.Представление КАК ЮридическийАдресОрг,
	|	энргКонтрагентыКонтактнаяИнформация.Представление КАК ФактическийАдресКонтрагента,
	|	энргКонтрагентыКонтактнаяИнформация1.Представление КАК ТелефонКонтрагента,
	|	энргКонтрагенты.Ссылка КАК Контрагент,
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	энргЕдиницыИзмерения.Ссылка КАК ЕдИзм,
	|	энргЕдиницыИзмерения.КодПоОКЕИ КАК КодОКЕИ,
	|	энргЗоныОтвественности.КодРайона КАК КодРайона,
	|	ДанныеДокумента.СуммаБезНДС КАК СуммаБезНДС,
	|	ДанныеДокумента.ПериодНачисления КАК ПериодНачисления,
	|	энргКонтрагенты.ИНН КАК ИННКон,
	|	энргКонтрагенты.КПП КАК КППКон,
	|	ПользователиКонтактнаяИнформация.Представление КАК ОтветственныйТелефон,
	|	ПользователиКонтактнаяИнформация1.Представление КАК ОтветственныйПочта,
	|	ДанныеДокумента.Ответственный КАК Ответственный,
	|	энргДоговорыКонтрагентов.ЭлектронноеВзаимодействие КАК ЭлектронноеВзаимодействие,
	|	ДанныеДокумента.УслугаТекст КАК УслугаТекст,
	|	ДанныеДокумента.НомерПДИсточник КАК НомерПДИсточник,
	|	ДанныеДокумента.ДатаИсточник КАК ДатаИсточник
	|ПОМЕСТИТЬ Итог
	|ИЗ
	|	ДанныеДокумента КАК ДанныеДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргЗоныОтвественности КАК энргЗоныОтвественности
	|		ПО ДанныеДокумента.Район = энргЗоныОтвественности.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО ДанныеДокумента.Организация = Организации.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
	|		ПО ДанныеДокумента.Организация = ОрганизацииКонтактнаяИнформация.Ссылка
	|			И (ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресОрганизации))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация1
	|		ПО ДанныеДокумента.Организация = ОрганизацииКонтактнаяИнформация1.Ссылка
	|			И (ОрганизацииКонтактнаяИнформация1.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации))
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
	|				ПО (энргКонтрагентыКонтактнаяИнформация.Ссылка = энргКонтрагенты.Ссылка)
	|					И (энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация1
	|				ПО энргКонтрагенты.Ссылка = энргКонтрагентыКонтактнаяИнформация1.Ссылка
	|					И (энргКонтрагентыКонтактнаяИнформация1.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента))
	|			ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагенты.Ссылка
	|		ПО ДанныеДокумента.Договор = энргДоговорыКонтрагентов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргЕдиницыИзмерения КАК энргЕдиницыИзмерения
	|		ПО ДанныеДокумента.Услуга.ЕдиницаИзмерения = энргЕдиницыИзмерения.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
	|		ПО ДанныеДокумента.Ответственный = ПользователиКонтактнаяИнформация.Ссылка
	|			И (ПользователиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПользователя))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация1
	|		ПО ДанныеДокумента.Ответственный = ПользователиКонтактнаяИнформация1.Ссылка
	|			И (ПользователиКонтактнаяИнформация1.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПользователя))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.НомерПД КАК НомерПД,
	|	Итог.ДатаПД КАК ДатаПД,
	|	Итог.ИННОрг КАК ИННОрг,
	|	Итог.КППОрг КАК КППОрг,
	|	Итог.ПолноеНаименованиеОрганизации КАК ПолноеНаименованиеОрганизации,
	|	Итог.ФактическийАдресОрг КАК ФактическийАдресОрг,
	|	Итог.ЮридическийАдресОрг КАК ЮридическийАдресОрг,
	|	Итог.ФактическийАдресКонтрагента КАК ФактическийАдресКонтрагента,
	|	Итог.ТелефонКонтрагента КАК ТелефонКонтрагента,
	|	Итог.Контрагент КАК Контрагент,
	|	Итог.НомерДоговора КАК НомерДоговора,
	|	Итог.ДатаДоговора КАК ДатаДоговора,
	|	Итог.КодРайона КАК КодРайона,
	|	Итог.ИННКон КАК ИННКон,
	|	Итог.КППКон КАК КППКон,
	|	Итог.ОтветственныйТелефон КАК ОтветственныйТелефон,
	|	Итог.ОтветственныйПочта КАК ОтветственныйПочта,
	|	Итог.Ответственный КАК Ответственный,
	|	Итог.ЭлектронноеВзаимодействие КАК ЭлектронноеВзаимодействие,
	|	Итог.НомерПДИсточник КАК НомерПДИсточник,
	|	Итог.ДатаИсточник КАК ДатаПДИсточник
	|ИЗ
	|	Итог КАК Итог
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.ОбъектРасчета КАК ОбъектРасчета,
	|	Итог.СуммаСНДС КАК СуммаСНДС,
	|	Итог.СуммаНДС КАК СуммаНДС,
	|	Итог.Тариф КАК Тариф,
	|	Итог.СтавкаНДС КАК СтавкаНДС,
	|	Итог.Услуга КАК Услуга,
	|	Итог.ОбъемУслуги КАК ОбъемУслуги,
	|	Итог.ЕдИзм КАК ЕдИзм,
	|	Итог.КодОКЕИ КАК КодОКЕИ,
	|	Итог.СуммаБезНДС КАК СуммаБезНДС,
	|	Итог.ПериодНачисления КАК ГодМесяц,
	|	Итог.УслугаТекст КАК УслугаТекст
	|ИЗ
	|	Итог КАК Итог
	|ИТОГИ
	|	СУММА(СуммаСНДС),
	|	СУММА(СуммаНДС),
	|	СУММА(СуммаБезНДС)
	|ПО
	|	ОбъектРасчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.ЕдИзм КАК ЕдИзм,
	|	Итог.КодОКЕИ КАК КодОКЕИ,
	|	СУММА(Итог.СуммаСНДС) КАК СуммаСНДС,
	|	СУММА(Итог.СуммаНДС) КАК СуммаНДС,
	|	СУММА(Итог.СуммаБезНДС) КАК СуммаБезНДС,
	|	СУММА(Итог.ОбъемУслуги) КАК ОбъемУслуги
	|ИЗ
	|	Итог КАК Итог
	|
	|СГРУППИРОВАТЬ ПО
	|	Итог.ЕдИзм,
	|	Итог.КодОКЕИ";
	
	Возврат Запрос;
	
КонецФункции

Процедура ЗаполнитьИсправительнуюСчетФактуру(ТабДок, РезультатЗапроса, Макет, ПараметрыПечати) Экспорт 
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	ВыборкаШапка 			= РезультатЗапроса[2].Выбрать();
	ВыборкаОбъектРасчета 	= РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИтогПоЕдИзм 		= РезультатЗапроса[4].Выбрать();
	ЭлектронноеВзаимодействие = Неопределено;
	Если ВыборкаШапка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ВыборкаШапка);
		ОбластьШапка.Параметры.ДатаПД = Формат(ВыборкаШапка.ДатаПД, "ДЛФ=D");
		ОбластьШапка.Параметры.ДатаПДИсточник 	= Формат(ВыборкаШапка.ДатаПДИсточник, "ДЛФ=D");
		ОбластьШапка.Параметры.ДатаДоговора = Формат(ВыборкаШапка.ДатаДоговора, "ДЛФ=D");
		ТабДок.Вывести(ОбластьШапка);
		ЭлектронноеВзаимодействие = ВыборкаШапка.ЭлектронноеВзаимодействие;
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапка);
	КонецЕсли;
	
	
	Пока ВыборкаОбъектРасчета.Следующий() Цикл
		ОбластьОбъектРасчета = Макет.ПолучитьОбласть("ОбъектРасчета");
		ОбластьОбъектРасчета.Параметры.ОбъектРасчета = ВыборкаОбъектРасчета.ОбъектРасчета;
		ТабДок.Вывести(ОбластьОбъектРасчета);
		НомерСтроки = 1;
		
		ВыборкаДетальныеЗаписи = ВыборкаОбъектРасчета.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ОбластьДанныеЗадолженности = Макет.ПолучитьОбласть("ДанныеЗадолженности");
			ЗаполнитьЗначенияСвойств(ОбластьДанныеЗадолженности.Параметры,ВыборкаДетальныеЗаписи);
			ОбластьДанныеЗадолженности.Параметры.ГодМесяц 						= Формат(ВыборкаДетальныеЗаписи.ГодМесяц, "ДФ=yyyy.MM");
						
			ТабДок.Вывести(ОбластьДанныеЗадолженности);
			НомерСтроки = НомерСтроки + 1;
		КонецЦикла;
		
		ОбластьИтогПоОбъектуРасчета = Макет.ПолучитьОбласть("ИтогПоОбъектуРасчета");
		ЗаполнитьЗначенияСвойств(ОбластьИтогПоОбъектуРасчета.Параметры,ВыборкаОбъектРасчета);
		ТабДок.Вывести(ОбластьИтогПоОбъектуРасчета);
		
	КонецЦикла;
	
	СуммаБезНДС = 0;
	СуммаНДС 	= 0;
	СуммаСНДС 	= 0;
	
	Пока ВыборкаИтогПоЕдИзм.Следующий() Цикл
		ОбластьИтогиПоЕдИзм = Макет.ПолучитьОбласть("ИтогиПоЕдИзм");
		ЗаполнитьЗначенияСвойств(ОбластьИтогиПоЕдИзм.Параметры,ВыборкаИтогПоЕдИзм);
		ТабДок.Вывести(ОбластьИтогиПоЕдИзм);
		
		СуммаБезНДС = СуммаБезНДС + ВыборкаИтогПоЕдИзм.СуммаБезНДС;
		СуммаНДС 	= СуммаНДС + ВыборкаИтогПоЕдИзм.СуммаНДС;
		СуммаСНДС 	= СуммаСНДС + ВыборкаИтогПоЕдИзм.СуммаСНДС;
	КонецЦикла;
	
	ОбластьОбщиеИтоги = Макет.ПолучитьОбласть("ОбщиеИтоги");
	ОбластьОбщиеИтоги.Параметры.СуммаБезНДС = СуммаБезНДС;
	ОбластьОбщиеИтоги.Параметры.СуммаНДС = СуммаНДС;
	ОбластьОбщиеИтоги.Параметры.СуммаСНДС = СуммаСНДС;
	ТабДок.Вывести(ОбластьОбщиеИтоги);	
	
	
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.РуководительОрганизации Тогда
			ОбластьПодвал.Параметры.РуководительОрганизацииФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.РуководительОрганизацииДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиРуководителяОрганизации.Картинка         = Картинка;
			КонецЕсли;
		ИначеЕсли эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГлавныйБухгалтер Тогда
			ОбластьПодвал.Параметры.ГлавныйБухгалтерФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.ГлавныйБухгалтерДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиГлавногоБухгалтера.Картинка         = Картинка;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьПодвал);
	
КонецПроцедуры     
	
#КонецОбласти

#Область КорректировочнаяСчетФактура

Функция ПолучитьЗапросКорректировочнаяСчетФактура() Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестПлатежныйДокумент.Организация КАК Организация,
	|	бестПлатежныйДокумент.НомерПД КАК НомерПД,
	|	бестПлатежныйДокумент.Дата КАК Дата,
	|	бестПлатежныйДокумент.Район КАК Район,
	|	бестПлатежныйДокумент.Договор КАК Договор,
	|	бестПлатежныйДокумент.ПериодНачисления КАК ПериодНачисления,
	|	бестПлатежныйДокумент.Ответственный КАК Ответственный,
	|	бестПлатежныйДокумент1.НомерПД КАК НомерПДИсточник,
	|	бестПлатежныйДокумент1.Дата КАК ДатаИсточник,
	|	бестПлатежныйДокумент.ДокументИсточник КАК ДокументИсточник,
	|	бестПлатежныйДокумент.Ссылка КАК ПД
	|ПОМЕСТИТЬ ДанныеШапки
	|ИЗ
	|	Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент1
	|		ПО бестПлатежныйДокумент.ДокументИсточник = бестПлатежныйДокумент1.Ссылка,
	|	Справочник.энргВидыУслуг КАК энргВидыУслуг
	|ГДЕ
	|	бестПлатежныйДокумент.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	бестПлатежныйДокумент.Организация,
	|	бестПлатежныйДокумент.НомерПД,
	|	бестПлатежныйДокумент.Дата,
	|	бестПлатежныйДокумент.Район,
	|	бестПлатежныйДокумент.Договор,
	|	бестПлатежныйДокумент.ПериодНачисления,
	|	бестПлатежныйДокумент.Ответственный,
	|	бестПлатежныйДокумент1.НомерПД,
	|	бестПлатежныйДокумент1.Дата,
	|	бестПлатежныйДокумент.ДокументИсточник,
	|	бестПлатежныйДокумент.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеШапки.Организация КАК Организация,
	|	ДанныеШапки.НомерПД КАК НомерПД,
	|	ДанныеШапки.Дата КАК ДатаПД,
	|	ДанныеШапки.Район КАК Район,
	|	ДанныеШапки.Договор КАК Договор,
	|	Организации.ИНН КАК ИННОрг,
	|	Организации.КПП КАК КППОрг,
	|	Организации.НаименованиеПолное КАК ПолноеНаименованиеОрганизации,
	|	ОрганизацииКонтактнаяИнформация.Представление КАК ФактическийАдресОрг,
	|	ОрганизацииКонтактнаяИнформация1.Представление КАК ЮридическийАдресОрг,
	|	энргКонтрагентыКонтактнаяИнформация.Представление КАК ФактическийАдресКонтрагента,
	|	энргКонтрагентыКонтактнаяИнформация1.Представление КАК ТелефонКонтрагента,
	|	энргКонтрагенты.Ссылка КАК Контрагент,
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	энргЗоныОтвественности.КодРайона КАК КодРайона,
	|	ДанныеШапки.ПериодНачисления КАК ПериодНачисления,
	|	энргКонтрагенты.ИНН КАК ИННКон,
	|	энргКонтрагенты.КПП КАК КППКон,
	|	ПользователиКонтактнаяИнформация.Представление КАК ОтветственныйТелефон,
	|	ПользователиКонтактнаяИнформация1.Представление КАК ОтветственныйПочта,
	|	ДанныеШапки.Ответственный КАК Ответственный,
	|	энргДоговорыКонтрагентов.ЭлектронноеВзаимодействие КАК ЭлектронноеВзаимодействие,
	|	ДанныеШапки.НомерПДИсточник КАК НомерПДИсточник,
	|	ДанныеШапки.ДатаИсточник КАК ДатаИсточник
	|ПОМЕСТИТЬ ИтогШапка
	|ИЗ
	|	ДанныеШапки КАК ДанныеШапки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргЗоныОтвественности КАК энргЗоныОтвественности
	|		ПО ДанныеШапки.Район = энргЗоныОтвественности.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО ДанныеШапки.Организация = Организации.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
	|		ПО ДанныеШапки.Организация = ОрганизацииКонтактнаяИнформация.Ссылка
	|			И (ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресОрганизации))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация1
	|		ПО ДанныеШапки.Организация = ОрганизацииКонтактнаяИнформация1.Ссылка
	|			И (ОрганизацииКонтактнаяИнформация1.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации))
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
	|				ПО (энргКонтрагентыКонтактнаяИнформация.Ссылка = энргКонтрагенты.Ссылка)
	|					И (энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация1
	|				ПО энргКонтрагенты.Ссылка = энргКонтрагентыКонтактнаяИнформация1.Ссылка
	|					И (энргКонтрагентыКонтактнаяИнформация1.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента))
	|			ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагенты.Ссылка
	|		ПО ДанныеШапки.Договор = энргДоговорыКонтрагентов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
	|		ПО ДанныеШапки.Ответственный = ПользователиКонтактнаяИнформация.Ссылка
	|			И (ПользователиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПользователя))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация1
	|		ПО ДанныеШапки.Ответственный = ПользователиКонтактнаяИнформация1.Ссылка
	|			И (ПользователиКонтактнаяИнформация1.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПользователя))
	|;
