Процедура ЗаполнитьСчетНаОплатуЗаПросрочкуПлатежа(ТабДок, РезультатЗапроса, Макет, ПараметрыПечати) Экспорт 
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	ВыборкаШапка 			= РезультатЗапроса[2].Выбрать();
	ВыборкаОбъектРасчета 	= РезультатЗапроса[3].Выбрать();
	ВыборкаИтог 			= РезультатЗапроса[4].Выбрать();
	ЭлектронноеВзаимодействие = Неопределено;
	Если ВыборкаШапка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ВыборкаШапка);
		ОбластьШапка.Параметры.ДатаПД = Формат(ВыборкаШапка.ДатаДоговора, "ДЛФ=D");
		ОбластьШапка.Параметры.ДатаДоговора = Формат(ВыборкаШапка.ДатаДоговора, "ДЛФ=D");
		ТабДок.Вывести(ОбластьШапка);
		ЭлектронноеВзаимодействие = ВыборкаШапка.ЭлектронноеВзаимодействие;
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапка);
	КонецЕсли;
	
	
	Пока ВыборкаОбъектРасчета.Следующий() Цикл
		ОбластьОбъектРасчета = Макет.ПолучитьОбласть("ОбластьРасчета");
		ЗаполнитьЗначенияСвойств(ОбластьОбъектРасчета.Параметры,ВыборкаОбъектРасчета);
		ОбластьОбъектРасчета.Параметры.ДатаНачалаРасчетаПени = Формат (ВыборкаОбъектРасчета.ДатаНачалаРасчетаПени, "ДФ=dd.MM.yyyy"); 
		ОбластьОбъектРасчета.Параметры.ДатаОкончанияРасчетаПени = Формат(КонецМесяца(ВыборкаОбъектРасчета.ДатаНачалаНачисленияПени), "ДФ=dd.MM.yyyy");
		ОбластьОбъектРасчета.Параметры.ПериодНачисления = Формат(ВыборкаОбъектРасчета.ПериодНачисления, "ДФ=dd.MM.yyyy");
		Если не ЗначениеЗаполнено(ВыборкаОбъектРасчета.ДоговорнаяСтавка) Тогда
			Ставка = ВыборкаОбъектРасчета.Числитель /ВыборкаОбъектРасчета.Знаменатель * ВыборкаОбъектРасчета.СтавкаРефинансирования;
			ОбластьОбъектРасчета.Параметры.ДоговорнаяСтавка = Формат(Ставка,"ЧЦ=5; ЧДЦ=2");
		КонецЕсли;
		ТабДок.Вывести(ОбластьОбъектРасчета);
		
	КонецЦикла;
	Пока ВыборкаИтог.Следующий() Цикл
		ОбластьИтогПоОбъектуРасчета = Макет.ПолучитьОбласть("ОбщиеИтоги");
		ЗаполнитьЗначенияСвойств(ОбластьИтогПоОбъектуРасчета.Параметры, ВыборкаИтог);
		ТабДок.Вывести(ОбластьИтогПоОбъектуРасчета);
	КонецЦикла;	
	
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.РуководительОрганизации Тогда
			ОбластьПодвал.Параметры.РуководительОрганизацииФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.РуководительОрганизацииДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиРуководителяОрганизации.Картинка         = Картинка;
			КонецЕсли;
		ИначеЕсли эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГлавныйБухгалтер Тогда
			ОбластьПодвал.Параметры.ГлавныйБухгалтерФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.ГлавныйБухгалтерДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиГлавногоБухгалтера.Картинка         = Картинка;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьПодвал); 	
	
КонецПроцедуры     

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СформироватьСчетФактураНаРеализацию(ИмяМакета, ПараметрыПечати)
	
	Макет 									= УправлениеПечатью.МакетПечатнойФормы("Документ.бестПлатежныйДокумент." +ИмяМакета);
	
	ТабДок 									= Новый ТабличныйДокумент;
	ТабДок.ОриентацияСтраницы				= ОриентацияСтраницы.Ландшафт;
	ТабДок.МасштабПечати					= 55;
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал"); 	
	
	Запрос = ПолучитьЗапросСчетФактураНаРеализацию();
	Запрос.УстановитьПараметр("Ссылка", ПараметрыПечати.ОбъектПечати);
	Период = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыПечати.ОбъектПечати, "Дата");
	Если Не ЗначениеЗаполнено(Период) Тогда
		Период = ТекущаяДатаСеанса();
	КонецЕсли;
	Запрос.УстановитьПараметр("Период", Период);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ЗаполнитьСчетФактуруНаРеализацию(ТабДок, РезультатЗапроса, Макет, ПараметрыПечати);
	
	Возврат ТабДок;
	
	ВыборкаШапка 			= РезультатЗапроса[2].Выбрать();
	ВыборкаОбъектРасчета 	= РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИтогПоЕдИзм 		= РезультатЗапроса[4].Выбрать();
	ЭлектронноеВзаимодействие = Неопределено;
	Если ВыборкаШапка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ВыборкаШапка);
		ОбластьШапка.Параметры.ДатаПД = Формат(ВыборкаШапка.ДатаПД, "ДЛФ=D");
		ОбластьШапка.Параметры.ДатаДоговора = Формат(ВыборкаШапка.ДатаДоговора, "ДЛФ=D");
		ТабДок.Вывести(ОбластьШапка);
		ЭлектронноеВзаимодействие = ВыборкаШапка.ЭлектронноеВзаимодействие;
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапка);
	КонецЕсли;
	
	
	Пока ВыборкаОбъектРасчета.Следующий() Цикл
		ОбластьОбъектРасчета = Макет.ПолучитьОбласть("ОбъектРасчета");
		ОбластьОбъектРасчета.Параметры.ОбъектРасчета = ВыборкаОбъектРасчета.ОбъектРасчета;
		ТабДок.Вывести(ОбластьОбъектРасчета);
		НомерСтроки = 1;
		
		ВыборкаДетальныеЗаписи = ВыборкаОбъектРасчета.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ОбластьДанныеЗадолженности = Макет.ПолучитьОбласть("ДанныеЗадолженности");
			ЗаполнитьЗначенияСвойств(ОбластьДанныеЗадолженности.Параметры,ВыборкаДетальныеЗаписи);
			ОбластьДанныеЗадолженности.Параметры.ГодМесяц = Формат(ВыборкаДетальныеЗаписи.ГодМесяц, "ДФ=yyyy.MM");
						
			ОбластьДанныеЗадолженности.Параметры.Номер = НомерСтроки;
			
			ТабДок.Вывести(ОбластьДанныеЗадолженности);
			НомерСтроки = НомерСтроки + 1;
		КонецЦикла;
		
		ОбластьИтогПоОбъектуРасчета = Макет.ПолучитьОбласть("ИтогПоОбъектуРасчета");
		ЗаполнитьЗначенияСвойств(ОбластьИтогПоОбъектуРасчета.Параметры,ВыборкаОбъектРасчета);
		ТабДок.Вывести(ОбластьИтогПоОбъектуРасчета);
		
	КонецЦикла;
	
	СуммаБезНДС = 0;
	СуммаНДС 	= 0;
	СуммаСНДС 	= 0;
	
	Пока ВыборкаИтогПоЕдИзм.Следующий() Цикл
		ОбластьИтогиПоЕдИзм = Макет.ПолучитьОбласть("ИтогиПоЕдИзм");
		ЗаполнитьЗначенияСвойств(ОбластьИтогиПоЕдИзм.Параметры,ВыборкаИтогПоЕдИзм);
		ТабДок.Вывести(ОбластьИтогиПоЕдИзм);
		
		СуммаБезНДС = СуммаБезНДС + ВыборкаИтогПоЕдИзм.СуммаБезНДС;
		СуммаНДС 	= СуммаНДС + ВыборкаИтогПоЕдИзм.СуммаНДС;
		СуммаСНДС 	= СуммаСНДС + ВыборкаИтогПоЕдИзм.СуммаСНДС;
	КонецЦикла;
	
	ОбластьОбщиеИтоги = Макет.ПолучитьОбласть("ОбщиеИтоги");
	ОбластьОбщиеИтоги.Параметры.СуммаБезНДС = СуммаБезНДС;
	ОбластьОбщиеИтоги.Параметры.СуммаНДС = СуммаНДС;
	ОбластьОбщиеИтоги.Параметры.СуммаСНДС = СуммаСНДС;
	ТабДок.Вывести(ОбластьОбщиеИтоги); 	
	
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.РуководительОрганизации Тогда
			ОбластьПодвал.Параметры.РуководительОрганизацииФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.РуководительОрганизацииДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиРуководителяОрганизации.Картинка         = Картинка;
			КонецЕсли;
		ИначеЕсли эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГлавныйБухгалтер Тогда
			ОбластьПодвал.Параметры.ГлавныйБухгалтерФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.ГлавныйБухгалтерДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиГлавногоБухгалтера.Картинка         = Картинка;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	ТабДок.Вывести(ОбластьПодвал);
	
	
	Возврат ТабДок;
	
КонецФункции

