Процедура ЗаполнитьСчетНаОплатуПост(ТабДок, РезультатЗапроса, Макет, ПараметрыПечати) Экспорт 
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал"); 
	
	ВыборкаШапка 			= РезультатЗапроса[2].Выбрать();
	ВыборкаОбъектРасчета 	= РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИтогПоЕдИзм 		= РезультатЗапроса[4].Выбрать();
	ВыборкаАванс 			= РезультатЗапроса[5].Выбрать();
	ЭлектронноеВзаимодействие = Неопределено;
	Если ВыборкаШапка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры, ВыборкаШапка);
		ОбластьШапка.Параметры.ДатаПД = Формат(ВыборкаШапка.ДатаПД, "ДЛФ=D");
		ОбластьШапка.Параметры.ДатаДоговора = Формат(ВыборкаШапка.ДатаДоговора, "ДЛФ=D");
		ЭлектронноеВзаимодействие = ВыборкаШапка.ЭлектронноеВзаимодействие;
		ТабДок.Вывести(ОбластьШапка);
		
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры, ВыборкаШапка);
	КонецЕсли;
	
	Пока ВыборкаОбъектРасчета.Следующий() Цикл
		ОбластьОбъектРасчета = Макет.ПолучитьОбласть("ОбъектРасчета");
		ОбластьОбъектРасчета.Параметры.ОбъектРасчета = ВыборкаОбъектРасчета.ОбъектРасчета;
		ТабДок.Вывести(ОбластьОбъектРасчета);
		
		ВыборкаДетальныеЗаписи = ВыборкаОбъектРасчета.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ГодМесяц = Формат(ВыборкаДетальныеЗаписи.ГодМесяц, "ДФ=yyyy.MM");
			
			ОбластьДанныеЗадолженности = Макет.ПолучитьОбласть("ДанныеЗадолженности");
			ЗаполнитьЗначенияСвойств(ОбластьДанныеЗадолженности.Параметры, ВыборкаДетальныеЗаписи);
			ОбластьДанныеЗадолженности.Параметры.ГодМесяц = ГодМесяц;
			ТабДок.Вывести(ОбластьДанныеЗадолженности);
			
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ТарифНаСредневзвешанную) Тогда
				ОбластьДанныеСредневзвешеннойЗадолженности = Макет.ПолучитьОбласть("ДанныеСредневзвешеннойЗадолженности");
				ЗаполнитьЗначенияСвойств(ОбластьДанныеСредневзвешеннойЗадолженности.Параметры, ВыборкаДетальныеЗаписи);
				ОбластьДанныеСредневзвешеннойЗадолженности.Параметры.ГодМесяц = ГодМесяц;
				ТабДок.Вывести(ОбластьДанныеСредневзвешеннойЗадолженности);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ТарифНаИныеУслуги) Тогда
				ОбластьДанныеЗадолженностиЗаИныеУслуги = Макет.ПолучитьОбласть("ДанныеЗадолженностиЗаИныеУслуги");
				ЗаполнитьЗначенияСвойств(ОбластьДанныеЗадолженностиЗаИныеУслуги.Параметры, ВыборкаДетальныеЗаписи);
				ОбластьДанныеЗадолженностиЗаИныеУслуги.Параметры.ГодМесяц = ГодМесяц;
				ТабДок.Вывести(ОбластьДанныеЗадолженностиЗаИныеУслуги);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ТарифЗаУслугиПоПередачи) Тогда
				ОбластьДанныеЗадолженностиЗаУслугиПоПередаче = Макет.ПолучитьОбласть("ДанныеЗадолженностиЗаУслугиПоПередаче");
				ЗаполнитьЗначенияСвойств(ОбластьДанныеЗадолженностиЗаУслугиПоПередаче.Параметры, ВыборкаДетальныеЗаписи);
				ОбластьДанныеЗадолженностиЗаУслугиПоПередаче.Параметры.ГодМесяц = ГодМесяц;
				ТабДок.Вывести(ОбластьДанныеЗадолженностиЗаУслугиПоПередаче);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ТарифЗаСбытовуюНадбавку) Тогда
				ОбластьДанныеЗадолженностиЗаСбытовуюНадбавку = Макет.ПолучитьОбласть("ДанныеЗадолженностиЗаСбытовуюНадбавку");
				ЗаполнитьЗначенияСвойств(ОбластьДанныеЗадолженностиЗаСбытовуюНадбавку.Параметры, ВыборкаДетальныеЗаписи);
				ОбластьДанныеЗадолженностиЗаСбытовуюНадбавку.Параметры.ГодМесяц = ГодМесяц;
				ТабДок.Вывести(ОбластьДанныеЗадолженностиЗаСбытовуюНадбавку);
			КонецЕсли;
			
		КонецЦикла;
		
		ОбластьИтогПоОбъектуРасчета = Макет.ПолучитьОбласть("ИтогПоОбъектуРасчета");
		ЗаполнитьЗначенияСвойств(ОбластьИтогПоОбъектуРасчета.Параметры, ВыборкаОбъектРасчета);
		ТабДок.Вывести(ОбластьИтогПоОбъектуРасчета);
		
	КонецЦикла;
	
	СуммаБезНДС = 0;
	СуммаНДС 	= 0;
	СуммаСНДС 	= 0;
	
	Пока ВыборкаИтогПоЕдИзм.Следующий() Цикл
		ОбластьИтогиПоЕдИзм = Макет.ПолучитьОбласть("ИтогиПоЕдИзм");
		ЗаполнитьЗначенияСвойств(ОбластьИтогиПоЕдИзм.Параметры, ВыборкаИтогПоЕдИзм);
		ОбластьИтогиПоЕдИзм.Параметры.СуммаНДСОбщая = ВыборкаИтогПоЕдИзм.СуммаНДС;
		ОбластьИтогиПоЕдИзм.Параметры.СуммаОбщаяБезНДС = ВыборкаИтогПоЕдИзм.СуммаБезНДС;
		ОбластьИтогиПоЕдИзм.Параметры.СуммаОбщая = ВыборкаИтогПоЕдИзм.СуммаСНДС;
		ТабДок.Вывести(ОбластьИтогиПоЕдИзм);
		
		СуммаБезНДС = СуммаБезНДС + ВыборкаИтогПоЕдИзм.СуммаБезНДС;
		СуммаНДС 	= СуммаНДС + ВыборкаИтогПоЕдИзм.СуммаНДС;
		СуммаСНДС 	= СуммаСНДС + ВыборкаИтогПоЕдИзм.СуммаСНДС;
	КонецЦикла;
	
	ОбластьОбщиеИтоги = Макет.ПолучитьОбласть("ОбщиеИтоги");
	ОбластьОбщиеИтоги.Параметры.СуммаОбщаяБезНДС 	= СуммаБезНДС;
	ОбластьОбщиеИтоги.Параметры.СуммаНДСОбщая 		= СуммаНДС;
	ОбластьОбщиеИтоги.Параметры.СуммаОбщая 			= СуммаСНДС;
	ТабДок.Вывести(ОбластьОбщиеИтоги);
	
	Если ВыборкаАванс.Следующий() Тогда
		ОбластьАванс = Макет.ПолучитьОбласть("Аванс");
		ЗаполнитьЗначенияСвойств(ОбластьАванс.Параметры,ВыборкаАванс);
		ТабДок.Вывести(ОбластьАванс);
		
		СуммаБезНДС = СуммаБезНДС - ВыборкаАванс.СуммаОбщаяБезНДС;
		СуммаНДС 	= СуммаНДС - ВыборкаАванс.СуммаНДСОбщая;
		СуммаСНДС 	= СуммаСНДС - ВыборкаАванс.СуммаОбщая;
	КонецЕсли;
	
	ОбластьОбщиеИтогиСУчетомАванса 								= Макет.ПолучитьОбласть("ОбщиеИтогиСУчетомАванса");
	ОбластьОбщиеИтогиСУчетомАванса.Параметры.СуммаОбщаяБезНДС 	= ?(СуммаБезНДС < 0,0,СуммаБезНДС);
	ОбластьОбщиеИтогиСУчетомАванса.Параметры.СуммаНДСОбщая 		= ?(СуммаНДС < 0,0,СуммаНДС);
	ОбластьОбщиеИтогиСУчетомАванса.Параметры.СуммаОбщая 		= ?(СуммаСНДС < 0,0,СуммаСНДС);
	ТабДок.Вывести(ОбластьОбщиеИтогиСУчетомАванса);
	
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.РуководительОрганизации Тогда
			ОбластьПодвал.Параметры.РуководительОрганизацииФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.РуководительОрганизацииДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.РуководительОрганизацииДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиРуководителяОрганизации.Картинка         = Картинка;
			КонецЕсли;	
		ИначеЕсли эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГлавныйБухгалтер Тогда
			ОбластьПодвал.Параметры.ГлавныйБухгалтерФИО = эл.Сотрудник;
			ОбластьПодвал.Параметры.ГлавныйБухгалтерДолжность = эл.Должность;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьПодвал.Параметры.ГлавныйБухгалтерДоверенность = "";
			КонецЕсли;
			Если ЭлектронноеВзаимодействие = Перечисления.бестВидыЭлектронногоВзаимодействия.ЭлектроннаяПочта Тогда 
				Картинка 			             = ВернутьКартинкуОбъекта(эл.Сотрудник, "ОбразецПодписи");
				ОбластьПодвал.Рисунки.ОбразецПодписиГлавногоБухгалтера.Картинка         = Картинка;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьПодвал);
	
КонецПроцедуры     

#КонецОбласти

#Область СчетНаОплатуПред

Функция ПолучитьЗапросСчетНаОплатуПред() Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестПлатежныйДокумент.Организация КАК Организация,
	|	бестПлатежныйДокумент.НомерПД КАК НомерПД,
	|	бестПлатежныйДокумент.Дата КАК Дата,
	|	бестПлатежныйДокумент.Район КАК Район,
	|	бестПлатежныйДокумент.Договор КАК Договор,
	|	СУММА(ВЫБОР
	|			КОГДА бестПлатежныйДокументОсновнаяРеализация.НДСВнутри
	|				ТОГДА бестПлатежныйДокументОсновнаяРеализация.Сумма
	|			ИНАЧЕ бестПлатежныйДокументОсновнаяРеализация.Сумма + бестПлатежныйДокументОсновнаяРеализация.СуммаНДС
	|		КОНЕЦ) КАК СуммаСНДС,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.СуммаНДС) КАК СуммаНДС,
	|	бестПлатежныйДокументОсновнаяРеализация.СтавкаНДС КАК СтавкаНДС,
	|	бестПлатежныйДокумент.ПериодНачисления КАК ПериодНачисления,
	|	бестПлатежныйДокумент.Ответственный КАК Ответственный,
	|	бестПлатежныйДокумент.Процент КАК Процент,
	|	энргДоговорыКонтрагентов.Филиал КАК АбонентскийОтдел,
	|	энргДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	энргДоговорыКонтрагентов.ЭлектронноеВзаимодействие КАК ЭлектронноеВзаимодействие,
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора
	|ПОМЕСТИТЬ ДанныеДокументаИтог
	|ИЗ
	|	Документ.бестПлатежныйДокумент.ОсновнаяРеализация КАК бестПлатежныйДокументОсновнаяРеализация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|			ПО бестПлатежныйДокумент.Договор = энргДоговорыКонтрагентов.Ссылка
	|		ПО бестПлатежныйДокументОсновнаяРеализация.Ссылка = бестПлатежныйДокумент.Ссылка
	|ГДЕ
	|	бестПлатежныйДокумент.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	бестПлатежныйДокумент.Организация,
	|	бестПлатежныйДокумент.НомерПД,
	|	бестПлатежныйДокумент.Дата,
	|	бестПлатежныйДокумент.Район,
	|	бестПлатежныйДокумент.Договор,
	|	бестПлатежныйДокументОсновнаяРеализация.СтавкаНДС,
	|	бестПлатежныйДокумент.ПериодНачисления,
	|	бестПлатежныйДокумент.Ответственный,
	|	бестПлатежныйДокумент.Процент,
	|	энргДоговорыКонтрагентов.Филиал,
	|	энргДоговорыКонтрагентов.Контрагент,
	|	энргДоговорыКонтрагентов.ЭлектронноеВзаимодействие,
	|	энргДоговорыКонтрагентов.Номер,
	|	энргДоговорыКонтрагентов.Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(бестАвансыЭЭОстатки.СуммаОстаток) КАК СуммаОбщая,
	|	СУММА(бестАвансыЭЭОстатки.СуммаНДСОстаток) КАК СуммаНДСОбщая,
	|	СУММА(бестАвансыЭЭОстатки.СуммаОстаток - бестАвансыЭЭОстатки.СуммаНДСОстаток) КАК СуммаОбщаяБезНДС,
	|	бестАвансыЭЭОстатки.Договор КАК Договор
	|ПОМЕСТИТЬ Авансы
	|ИЗ
	|	РегистрНакопления.бестАвансыЭЭ.Остатки(
	|			&Период,
	|			(Организация, Район, Договор) В
	|				(ВЫБРАТЬ
	|					ДанныеДокументаИтог.Организация КАК Организация,
	|					ДанныеДокументаИтог.Район КАК Район,
	|					ДанныеДокументаИтог.Договор КАК Договор
	|				ИЗ
	|					ДанныеДокументаИтог КАК ДанныеДокументаИтог)) КАК бестАвансыЭЭОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	бестАвансыЭЭОстатки.Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестОбъектыРасчета.МКД КАК МКД,
	|	бестДоговорыТочекУчетаСрезПоследних.Договор КАК Договор
	|ПОМЕСТИТЬ МКДвДоговоре
	|ИЗ
	|	РегистрСведений.бестДоговорыТочекУчета.СрезПоследних(
	|			&Период,
	|			(Организация, Район) В
	|				(ВЫБРАТЬ
	|					ДанныеДокументаИтог.Организация КАК Организация,
	|					ДанныеДокументаИтог.Район КАК Район
	|				ИЗ
	|					ДанныеДокументаИтог КАК ДанныеДокументаИтог)) КАК бестДоговорыТочекУчетаСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ПО бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета = бестОбъектыРасчета.Ссылка
	|ГДЕ
	|	бестДоговорыТочекУчетаСрезПоследних.Договор В
	|			(ВЫБРАТЬ
	|				ДанныеДокументаИтог.Договор КАК Договор
	|			ИЗ
	|				ДанныеДокументаИтог КАК ДанныеДокументаИтог)
	|
	|СГРУППИРОВАТЬ ПО
	|	бестОбъектыРасчета.МКД,
	|	бестДоговорыТочекУчетаСрезПоследних.Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокументаИтог.Организация КАК Организация,
	|	ДанныеДокументаИтог.НомерПД КАК НомерПД,
	|	ДанныеДокументаИтог.Дата КАК ДатаПД,
	|	ДанныеДокументаИтог.Район КАК Район,
	|	ДанныеДокументаИтог.Договор КАК Договор,
	|	ДанныеДокументаИтог.СуммаСНДС КАК СуммаСНДС,
	|	ДанныеДокументаИтог.СуммаНДС КАК СуммаНДС,
	|	ДанныеДокументаИтог.СтавкаНДС КАК СтавкаНДС,
	|	Организации.ИНН КАК ИННОрг,
	|	энргЗоныОтвественности.КПП КАК КППОрг,
	|	Организации.НаименованиеПолное КАК ПолноеНаименованиеОрганизации,
	|	МАКСИМУМ(ОрганизацииКонтактнаяИнформация.Представление) КАК ЮридическийАдресОрг,
	|	МАКСИМУМ(энргФилиалыКонтактнаяИнформация.Представление) КАК ТелефонОгранизации,
	|	МАКСИМУМ(энргКонтрагентыКонтактнаяИнформация.Представление) КАК ФактическийАдресКонтрагента,
	|	МАКСИМУМ(энргКонтрагентыКонтактнаяИнформацияТелефон.Представление) КАК ТелефонКонтрагента,
	|	энргКонтрагенты.Ссылка КАК Контрагент,
	|	ДанныеДокументаИтог.НомерДоговора КАК НомерДоговора,
	|	ДанныеДокументаИтог.ДатаДоговора КАК ДатаДоговора,
	|	энргЗоныОтвественности.КодРайона КАК КодРайона,
	|	ДанныеДокументаИтог.ПериодНачисления КАК ПериодНачисления,
	|	энргКонтрагенты.ИНН КАК ИННКон,
	|	энргКонтрагенты.КПП КАК КППКон,
	|	МАКСИМУМ(ПользователиКонтактнаяИнформация.Представление) КАК ОтветственныйТелефон,
	|	МАКСИМУМ(ПользователиКонтактнаяИнформация1.Представление) КАК ОтветственныйПочта,
	|	ДанныеДокументаИтог.Ответственный КАК Ответственный,
	|	БанковскиеСчета.Банк КАК БанкОрг,
	|	БанковскиеСчета.НомерСчета КАК РасчетныйСчетОрг,
	|	КлассификаторБанков.Код КАК БИКОрг,
	|	КлассификаторБанков.КоррСчет КАК КорСчетОрг,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(бестВыставлениеПереплатыВАвансовыхСчетахСрезПоследних.УчитыватьПереплату, ЛОЖЬ)
	|			ТОГДА ДанныеДокументаИтог.СуммаСНДС - ЕСТЬNULL(Авансы.СуммаОбщая, 0)
	|		ИНАЧЕ ДанныеДокументаИтог.СуммаСНДС
	|	КОНЕЦ КАК СуммаСНДССАвансом,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(бестВыставлениеПереплатыВАвансовыхСчетахСрезПоследних.УчитыватьПереплату, ЛОЖЬ)
	|			ТОГДА ДанныеДокументаИтог.СуммаНДС - ЕСТЬNULL(Авансы.СуммаНДСОбщая, 0)
	|		ИНАЧЕ ДанныеДокументаИтог.СуммаНДС
	|	КОНЕЦ КАК СуммаНДССАвансом,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(бестВыставлениеПереплатыВАвансовыхСчетахСрезПоследних.УчитыватьПереплату, ЛОЖЬ)
	|			ТОГДА ДанныеДокументаИтог.СуммаСНДС - ДанныеДокументаИтог.СуммаНДС - ЕСТЬNULL(Авансы.СуммаОбщаяБезНДС, 0)
	|		ИНАЧЕ ДанныеДокументаИтог.СуммаСНДС - ДанныеДокументаИтог.СуммаНДС
	|	КОНЕЦ КАК СуммаБезНДССАвансом,
	|	ДанныеДокументаИтог.СуммаСНДС - ДанныеДокументаИтог.СуммаНДС КАК СуммаБезНДС,
	|	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.СрокОплаты КАК СрокОплаты,
	|	ДанныеДокументаИтог.ЭлектронноеВзаимодействие КАК ЭлектронноеВзаимодействие,
	|	ДанныеДокументаИтог.Процент КАК Процент,
	|	ВЫБОР
