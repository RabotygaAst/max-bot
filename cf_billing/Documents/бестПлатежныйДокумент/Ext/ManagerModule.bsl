#Область СоглашениеНаКорректировку

Функция ПолучитьЗапросСоглашениеНаКорректировку() Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестПлатежныйДокумент.Организация КАК Организация,
	|	бестПлатежныйДокумент.НомерПД КАК НомерПД,
	|	бестПлатежныйДокумент.Дата КАК Дата,
	|	бестПлатежныйДокумент.Район КАК Район,
	|	бестПлатежныйДокумент.Договор КАК Договор,
	|	бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета КАК ОбъектРасчета,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.СуммаСредневзвешенная + бестПлатежныйДокументОсновнаяРеализация.СуммаЗаСбытовуюНадбавку + бестПлатежныйДокументОсновнаяРеализация.СуммаЗаУслугиПоПередачи + бестПлатежныйДокументОсновнаяРеализация.СуммаЗаИныеУслуги) КАК СуммаСНДС,
	|	СУММА(бестПлатежныйДокументОсновнаяРеализация.СуммаСредневзвешеннаяНДС + бестПлатежныйДокументОсновнаяРеализация.СуммаЗаСбытовуюНадбавкуНДС + бестПлатежныйДокументОсновнаяРеализация.СуммаЗаУслугиПоПередачиНДС + бестПлатежныйДокументОсновнаяРеализация.СуммаЗаИныеУслугиНДС) КАК СуммаНДС,
	|	бестПлатежныйДокумент1.ПериодНачисления КАК ПериодНачисления
	|ПОМЕСТИТЬ ДанныеДокумента
	|ИЗ
	|	Документ.бестПлатежныйДокумент.ОсновнаяРеализация КАК бестПлатежныйДокументОсновнаяРеализация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент1
	|			ПО бестПлатежныйДокумент.ДокументИсточник = бестПлатежныйДокумент1.Ссылка
	|		ПО бестПлатежныйДокументОсновнаяРеализация.Ссылка = бестПлатежныйДокумент.Ссылка
	|			И (НЕ бестПлатежныйДокументОсновнаяРеализация.ИсходныеДанные)
	|ГДЕ
	|	бестПлатежныйДокумент.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	бестПлатежныйДокумент.Организация,
	|	бестПлатежныйДокумент.НомерПД,
	|	бестПлатежныйДокумент.Дата,
	|	бестПлатежныйДокумент.Район,
	|	бестПлатежныйДокумент.Договор,
	|	бестПлатежныйДокументОсновнаяРеализация.ОбъектРасчета,
	|	бестПлатежныйДокумент1.ПериодНачисления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокумента.Организация КАК Организация,
	|	ДанныеДокумента.НомерПД КАК НомерПД,
	|	ДанныеДокумента.Дата КАК ДатаПД,
	|	ДанныеДокумента.Район КАК Район,
	|	ДанныеДокумента.Договор КАК Договор,
	|	СУММА(ДанныеДокумента.СуммаСНДС) КАК СуммаСНДС,
	|	СУММА(ДанныеДокумента.СуммаНДС) КАК СуммаНДС,
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	СУММА(ДанныеДокумента.СуммаСНДС - ДанныеДокумента.СуммаНДС) КАК СуммаБезНДС,
	|	ДанныеДокумента.ПериодНачисления КАК ПериодНачисления,
	|	энргДоговорыКонтрагентов.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ Итог
	|ИЗ
	|	ДанныеДокумента КАК ДанныеДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|		ПО ДанныеДокумента.Договор = энргДоговорыКонтрагентов.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеДокумента.Организация,
	|	ДанныеДокумента.НомерПД,
	|	ДанныеДокумента.Дата,
	|	ДанныеДокумента.Район,
	|	ДанныеДокумента.Договор,
	|	энргДоговорыКонтрагентов.Номер,
	|	энргДоговорыКонтрагентов.Дата,
	|	ДанныеДокумента.ПериодНачисления,
	|	энргДоговорыКонтрагентов.Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.НомерПД КАК НомерПД,
	|	Итог.ДатаПД КАК ДатаПД,
	|	Итог.НомерДоговора КАК НомерДоговора,
	|	Итог.ДатаДоговора КАК ДатаДоговора,
	|	Итог.Организация КАК Организация,
	|	Итог.СуммаСНДС КАК СуммаСНДС,
	|	Итог.СуммаНДС КАК СуммаНДС,
	|	Итог.СуммаБезНДС КАК СуммаБезНДС,
	|	Итог.Контрагент КАК Контрагент,
	|	Итог.ПериодНачисления КАК ПериодНачисления,
	|	энргКонтрагентыДоверенности.Номер КАК НомерДоверенностиКонтактногоЛица,
	|	энргКонтрагентыДоверенности.Дата КАК ДатаДоверенностиКонтактногоЛица,
	|	СклоненияПредставленийОбъектов.РодительныйПадеж КАК КонтактноеЛицоРП,
	|	Итог.Договор КАК Договор
	|ИЗ
	|	Итог КАК Итог
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестКонтактныеЛицаКонтрагентов КАК бестКонтактныеЛицаКонтрагентов
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СклоненияПредставленийОбъектов КАК СклоненияПредставленийОбъектов
	|			ПО бестКонтактныеЛицаКонтрагентов.КонтактноеЛицо = СклоненияПредставленийОбъектов.Объект
	|		ПО Итог.Контрагент = бестКонтактныеЛицаКонтрагентов.Владелец
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.Доверенности КАК энргКонтрагентыДоверенности
	|		ПО Итог.Контрагент = энргКонтрагентыДоверенности.Ссылка";
	
	Возврат Запрос;
	
КонецФункции

Процедура ЗаполнитьСоглашениеНаКорректировку(ТабДок, Выборка, Макет, ПараметрыПечати) Экспорт 
	
	ОбластьСоглашение = Макет.ПолучитьОбласть("Соглашение"); 	
	
	ЗаполнитьЗначенияСвойств(ОбластьСоглашение.Параметры, Выборка);
	ОбластьСоглашение.Параметры.ПериодНачисления 	= Формат(Выборка.ПериодНачисления, "ДЛФ=D");
	ОбластьСоглашение.Параметры.ДатаДоговора 		= Формат(Выборка.ДатаДоговора, "ДЛФ=D");
	ОбластьСоглашение.Параметры.ДатаПД 				= Формат(Выборка.ДатаПД, "ДЛФ=D");
	
	Если ЗначениеЗаполнено(Выборка.НомерДоверенностиКонтактногоЛица) И ЗначениеЗаполнено(Выборка.ДатаДоверенностиКонтактногоЛица) Тогда
		ОбластьСоглашение.Параметры.ДоверенностьКонтактногоЛица = ", действующего на основании доверенности №" + Выборка.НомерДоверенностиКонтактногоЛица + " от " + Формат(Выборка.ДатаДоверенностиКонтактногоЛица, "ДЛФ=D") + ",";
	Иначе
		ОбластьСоглашение.Параметры.ДоверенностьКонтактногоЛица = "";
	КонецЕсли;
	
	Для каждого эл из ПараметрыПечати.ДанныеПодписантов Цикл
		Если эл.ВидПодписанта = Перечисления.энргВидыПодписантов.ГарантирующийПоставщик Тогда
			РезультатСклонения = энргОбщегоНазначения.ПолучитьСклоненияОбъекта(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Сотрудник, "ФизическоеЛицо"));
			ВыборкаСклонения = РезультатСклонения.Выбрать();
			Если ВыборкаСклонения.Следующий() Тогда
				ОбластьСоглашение.Параметры.ГарантирующийПоставщикФИОРП = ВыборкаСклонения.РодительныйПадеж;
			КонецЕсли;
			Если ЗначениеЗаполнено(эл.Доверенность) Тогда
				ОбластьСоглашение.Параметры.ГарантирующийПоставщикДоверенность = " на основании доверенности дов. №" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Номер") + " от " + Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(эл.Доверенность, "Дата"), "ДЛФ=D");
			Иначе
				ОбластьСоглашение.Параметры.ГарантирующийПоставщикДоверенность = "";	
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьСоглашение); 	
	
КонецПроцедуры     

#КонецОбласти

