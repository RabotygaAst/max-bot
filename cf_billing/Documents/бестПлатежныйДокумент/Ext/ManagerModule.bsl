Функция ПолучитьОбъемЭЭ(Организация, Район, НачалоПериода, КонецПериода, Договор)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестОбъемНачисленийЭлектроэнергииОбороты.ОбъемУслугиОборот КАК ОбъемУслугиОборот
	|ИЗ
	|	РегистрНакопления.бестОбъемНачисленийЭлектроэнергии.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор) КАК бестОбъемНачисленийЭлектроэнергииОбороты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО бестОбъемНачисленийЭлектроэнергииОбороты.Услуга = энргВидыУслуг.Ссылка
	|			И (энргВидыУслуг.бестИспользоватьРасчетЭлектроэнергии
	|				И НЕ энргВидыУслуг.бестИспользоватьРасчетПоМощности
	|				И НЕ энргВидыУслуг.ИспользоватьРасчетРеактивнойЭнергии)";
	
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.ОбъемУслугиОборот;
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

