	|		БанковскиеСчета.Банк,
	|		БанковскиеСчета.НомерСчета,
	|		ВрТ4.ОрганизацияНаименованиеСокр,
	|		ВрТ4.ИННПоставщик,
	|		ВрТ4.КПППоставщик,
	|		ВрТ4.ОрганизацияНаименование) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Банки КАК Банки
	|		ПО ВложенныйЗапрос.БанкПолучателяПредставление = Банки.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Банки.КоррСчет,
	|	ВложенныйЗапрос.НомерСчета,
	|	ВложенныйЗапрос.КПППолучателя,
	|	ВложенныйЗапрос.Организация,
	|	Банки.Наименование,
	|	Банки.Код,
	|	ВложенныйЗапрос.ОрганизацияНаименованиеСокр,
	|	ВложенныйЗапрос.ИННПолучателя";
	
	Реализация = Запрос.ВыполнитьПакет();
	
	Возврат Реализация;
КонецФункции

Функция ПолучениеДанныхСчетаФактурыВыданный(МассивДок, ДатаПечати)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивДок", 	МассивДок);
	Запрос.УстановитьПараметр("Дата", 		ДатаПечати);
	Запрос.Текст = "ВЫБРАТЬ
	|	бестРеализацияЮрЛица.Организация КАК Организация,
	|	бестРеализацияЮрЛица.Район КАК Район,
	|	бестРеализацияЮрЛица.Договор КАК Договор,
	|	бестРеализацияЮрЛица.Контрагент КАК Контрагент,
	|	бестРеализацияЮрЛицаУслуги.Услуга КАК Услуга,
	|	бестРеализацияЮрЛицаУслуги.Количество КАК Количество,
	|	бестРеализацияЮрЛицаУслуги.Цена КАК Цена,
	|	бестРеализацияЮрЛицаУслуги.Сумма КАК Сумма,
	|	ВЫБОР
	|		КОГДА бестРеализацияЮрЛицаУслуги.НДС = ЗНАЧЕНИЕ(Перечисление.бестСтавкиНДС.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.бестСтавкиНДС.НДС20)
	|		ИНАЧЕ бестРеализацияЮрЛицаУслуги.НДС
	|	КОНЕЦ КАК НДС,
	|	бестРеализацияЮрЛицаУслуги.СуммаНДС КАК СуммаНДС,
	|	бестРеализацияЮрЛица.Ссылка КАК Ссылка,
	|	бестРеализацияЮрЛицаУслуги.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ПОМЕСТИТЬ ВрТ0
	|ИЗ
	|	Документ.бестРеализацияЮрЛица.Услуги КАК бестРеализацияЮрЛицаУслуги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестРеализацияЮрЛица КАК бестРеализацияЮрЛица
	|		ПО бестРеализацияЮрЛицаУслуги.Ссылка = бестРеализацияЮрЛица.Ссылка
	|ГДЕ
	|	бестРеализацияЮрЛица.Ссылка В(&МассивДок)
	|;
