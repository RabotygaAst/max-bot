Процедура ФормированиеПечатнойФормыАктаВыполненныхРабот(МассивДок, ТабДок, ДатаПечати) Экспорт
	Макет						= УправлениеПечатью.МакетПечатнойФормы("Документ.бестРеализацияЮрЛица.ПФ_MXL_Акт");
	НаборДанных					= ПолучениеДанныхАктаВыполненныхРабот(МассивДок, ДатаПечати);
	
	ВЫборкаШапка 				= НаборДанных[5].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВЫборкаТЧ 					= НаборДанных[6].Выгрузить();
	ВЫборкаОтветственные 		= НаборДанных[7].Выгрузить();
	
	Пока ВЫборкаШапка.Следующий() Цикл
		ТеДок			= ВЫборкаШапка.Ссылка;
		ВыборкаДанные 	= ВЫборкаШапка.Выбрать();
		Пока ВыборкаДанные.Следующий() Цикл
			ТекДоговор 	= ВыборкаДанные.Договор;
			
			ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
			ОбластьЗаголовок.Параметры.ТекстЗаголовка = "Акт №" + ВыборкаДанные.НомерДок + " от " + Формат(ВыборкаДанные.ДатаДок, "ДЛФ=DD");
			ТабДок.Вывести(ОбластьЗаголовок);
			
			ОбластьПоставщик = Макет.ПолучитьОбласть("Поставщик");
			ОбластьПоставщик.Параметры.Заполнить(ВыборкаДанные);
			ТабДок.Вывести(ОбластьПоставщик);
			
			ОбластьПолучатель = Макет.ПолучитьОбласть("Получатель");
			ОбластьПолучатель.Параметры.Заполнить(ВыборкаДанные);
			ТабДок.Вывести(ОбластьПолучатель);
			
			ОбластьШапкаТЧ = Макет.ПолучитьОбласть("ШапкаТаблицы");
			ТабДок.Вывести(ОбластьШапкаТЧ);
			
			СуммаВсего	= 0;
			СуммаНДСВсего	= 0;
			ИщемСтроки = ВЫборкаТЧ.НайтиСтроки(Новый Структура("Ссылка", ТеДок));
			Для строка = 0 по ИщемСтроки.ВГраница() Цикл
				ОбластьСтрокаТЧ = Макет.ПолучитьОбласть("Строка");
				ОбластьСтрокаТЧ.Параметры.Заполнить(ИщемСтроки[строка]);
				ОбластьСтрокаТЧ.Параметры.НоменклатураНаименование = Строка(ИщемСтроки[строка].НоменклатураНаименование) + " по договору '" + Строка(ТекДоговор) + "'";
				ТабДок.Вывести(ОбластьСтрокаТЧ);
				
				СуммаВсего = СуммаВсего + ИщемСтроки[строка].Сумма;
				СуммаНДСВсего = СуммаНДСВсего + ИщемСтроки[строка].СуммаНДС;
			КонецЦикла;
			
			ОбластьИтого = Макет.ПолучитьОбласть("Итого");
			ОбластьИтого.Параметры.Всего = СуммаВсего;
			ТабДок.Вывести(ОбластьИтого);	
			
			ОбластьИтогоНДС = Макет.ПолучитьОбласть("ИтогоНДС");
			ОбластьИтогоНДС.Параметры.НДС		= "Сумма НДС ";
			ОбластьИтогоНДС.Параметры.ВсегоНДС	= СуммаНДСВсего;
			ТабДок.Вывести(ОбластьИтогоНДС);
			
			ОбластьСуммаПрописью = Макет.ПолучитьОбласть("СуммаПрописью");
			ОбщаяСумма = СуммаВсего + СуммаНДСВсего;
			ОбластьСуммаПрописью.Параметры.ИтоговаяСтрока		= "Всего оказано услуг " + ИщемСтроки.Количество() + ", на сумму " + Строка(ОбщаяСумма) + " руб.";
			ФормСтрока = "Л = ru_RU; ДП = Истина";
			ПарПредмета= "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2";
			ОбластьСуммаПрописью.Параметры.СуммаПрописью		= ЧислоПрописью(ОбщаяСумма, ФормСтрока, ПарПредмета);;
			ТабДок.Вывести(ОбластьСуммаПрописью);
			
			ИщемОтвЛиц = ВЫборкаОтветственные.НайтиСтроки(Новый Структура("Организация", ВыборкаДанные.Организация));
			Для строка = 0 по ИщемОтвЛиц.ВГраница() Цикл
				ОбластьПодписи = Макет.ПолучитьОбласть("Подписи");
				ОбластьПодписи.Параметры.ДолжностьИНазваниеОрганизации = Строка(ИщемОтвЛиц[строка].Должность) + " " + Строка(ВыборкаДанные.ПредставлениеПоставщика);
				ОбластьПодписи.Параметры.ФизЛицо = Строка(ИщемОтвЛиц[строка].ФизЛицо);
				ТабДок.Вывести(ОбластьПодписи);
			КонецЦикла;
		КонецЦикла;
		ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();		
	КонецЦикла;
КонецПроцедуры	

Процедура ФормированиеПечатнойФормыСчетаНаОплату(МассивДок, ТабДок, ДатаПечати) Экспорт
	Макет					= УправлениеПечатью.МакетПечатнойФормы("Документ.бестРеализацияЮрЛица.ПФ_MXL_СчетЗаказ");
	НаборДанных				= ПолучениеДанныхСчетаНаОплату(МассивДок, ДатаПечати);
	
	ВЫборкаШапка 			= НаборДанных[5].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВЫборкаТЧ 				= НаборДанных[6].Выгрузить();
	ВЫборкаОтветственные 	= НаборДанных[7].Выгрузить();
	ВЫборкаБанкРекв			= НаборДанных[8].Выгрузить();
	
	Пока ВЫборкаШапка.Следующий() Цикл
		ТеДок			= ВЫборкаШапка.Ссылка;
		ВыборкаДанные 	= ВЫборкаШапка.Выбрать();
		Пока ВыборкаДанные.Следующий() Цикл
			ТекДоговор 	= ВыборкаДанные.Договор;
			
			ОбластьВнимание = Макет.ПолучитьОбласть("Внимание");
			ТабДок.Вывести(ОбластьВнимание);
			
			ИщемБанкРеквизиты = ВЫборкаБанкРекв.НайтиСтроки(Новый Структура("Организация", ВыборкаДанные.Организация));
			Для строка = 0 по ИщемБанкРеквизиты.ВГРаница() Цикл
				ОбластьЗаголовокСчета = Макет.ПолучитьОбласть("ЗаголовокСчета");
				ОбластьЗаголовокСчета.Параметры.Заполнить(ИщемБанкРеквизиты[строка]);
				ТабДок.Вывести(ОбластьЗаголовокСчета);
			КонецЦикла;
			
			ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
			ОбластьЗаголовок.Параметры.ТекстЗаголовка = "Счет на оплату №" + ВыборкаДанные.НомерДок + " от " + Формат(ВыборкаДанные.ДатаДок, "ДЛФ=DD");
			ТабДок.Вывести(ОбластьЗаголовок);
			
			ОбластьПоставщик = Макет.ПолучитьОбласть("Поставщик");
			ОбластьПоставщик.Параметры.Заполнить(ВыборкаДанные);
			ТабДок.Вывести(ОбластьПоставщик);
			
			ОбластьПолучатель = Макет.ПолучитьОбласть("Покупатель");
			ОбластьПолучатель.Параметры.Заполнить(ВыборкаДанные);
			ТабДок.Вывести(ОбластьПолучатель);
			
			ОбластьШапкаТЧ = Макет.ПолучитьОбласть("ШапкаТаблицы");
			ТабДок.Вывести(ОбластьШапкаТЧ);
			
			СуммаВсего	= 0;
			СуммаНДСВсего	= 0;
			ИщемСтроки = ВЫборкаТЧ.НайтиСтроки(Новый Структура("Ссылка", ТеДок));
			Для строка = 0 по ИщемСтроки.ВГраница() Цикл
				ОбластьСтрокаТЧ = Макет.ПолучитьОбласть("Строка");
				ОбластьСтрокаТЧ.Параметры.Заполнить(ИщемСтроки[строка]);
				ОбластьСтрокаТЧ.Параметры.НомерСтроки = строка + 1;
				ОбластьСтрокаТЧ.Параметры.НоменклатураНаименование = Строка(ИщемСтроки[строка].НоменклатураНаименование) 
				+ " по договору '" + Строка(ТекДоговор) + "'" + " за " + Строка(Формат(ТеДок.ПериодНачисления, "ДФ='ММММ ггг'"));
				ТабДок.Вывести(ОбластьСтрокаТЧ);
				
				СуммаВсего = СуммаВсего + ИщемСтроки[строка].Сумма;
				СуммаНДСВсего = СуммаНДСВсего + ИщемСтроки[строка].СуммаНДС;
			КонецЦикла;
			
			ОбластьИтого = Макет.ПолучитьОбласть("Итого");
			ОбластьИтого.Параметры.Всего = СуммаВсего;
			ТабДок.Вывести(ОбластьИтого);	
			
			ОбластьИтогоНДС = Макет.ПолучитьОбласть("ИтогоНДС");
			ОбластьИтогоНДС.Параметры.НДС		= "Сумма НДС";
			ОбластьИтогоНДС.Параметры.ВсегоНДС	= СуммаНДСВсего;
			ТабДок.Вывести(ОбластьИтогоНДС);
			
			ОбщаяСумма = СуммаВсего + СуммаНДСВсего;
			
			ОбластьИтогоКОплате = Макет.ПолучитьОбласть("ИтогоКОплате");
			ОбластьИтогоКОплате.Параметры.ИтогоКОплате = ОбщаяСумма;
			ТабДок.Вывести(ОбластьИтогоКОплате);
			
			ОбластьСуммаПрописью = Макет.ПолучитьОбласть("СуммаПрописью");
			
			ОбластьСуммаПрописью.Параметры.ИтоговаяСтрока		= "Всего наименований " + ИщемСтроки.Количество() + ", на сумму " + Строка(ОбщаяСумма) + " руб.";
			ФормСтрока = "Л = ru_RU; ДП = Истина";
			ПарПредмета= "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2";
			ОбластьСуммаПрописью.Параметры.СуммаПрописью		= ЧислоПрописью(ОбщаяСумма, ФормСтрока, ПарПредмета);;
			ТабДок.Вывести(ОбластьСуммаПрописью);
			
			ИщемОтвЛиц = ВЫборкаОтветственные.НайтиСтроки(Новый Структура("Организация", ВыборкаДанные.Организация));
			Для строка = 0 по ИщемОтвЛиц.ВГраница() Цикл
				ОбластьПодписи = Макет.ПолучитьОбласть("ПодвалСчета");
				ОбластьПодписи.Параметры.Должность = Строка(ИщемОтвЛиц[строка].Должность);
				ОбластьПодписи.Параметры.ФизЛицо = Строка(ИщемОтвЛиц[строка].ФизЛицо);
				ТабДок.Вывести(ОбластьПодписи);
			КонецЦикла;
		КонецЦикла;
		ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();		
	КонецЦикла;	
КонецПроцедуры

Процедура ФормированиеПечатнойФормыСчетаФактурыВыданный(МассивДок, ТабДок, ДатаПечати) Экспорт
	Макет															= УправлениеПечатью.МакетПечатнойФормы("Документ.бестРеализацияЮрЛица.ПФ_MXL_СчетФактура981");
	НаборДанных														= ПолучениеДанныхСчетаФактурыВыданный(МассивДок, ДатаПечати);
	
	ВЫборкаШапка 													= НаборДанных[5].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВЫборкаТЧ 														= НаборДанных[6].Выгрузить();
	ВЫборкаОтветственные 											= НаборДанных[7].Выгрузить();
	ВЫборкаБанкРекв													= НаборДанных[8].Выгрузить();
	
	Пока ВЫборкаШапка.Следующий() Цикл
		ТеДок														= ВЫборкаШапка.Ссылка;
		ОбластьШапка 												= Макет.ПолучитьОбласть("Шапка");		
		ВыборкаДанные 												= ВЫборкаШапка.Выбрать();
		
		Пока ВыборкаДанные.Следующий() Цикл
			ТекДоговор 												= ВыборкаДанные.Договор;
			
			ОбластьШапка.Параметры.НомерДок 						= ВыборкаДанные.НомерДок;
			ОбластьШапка.Параметры.НомерДок 						= Формат(ВыборкаДанные.ДатаДок, "ДЛФ=DD");
			ОбластьШапка.Параметры.ДатаДокИспр 						= "--";
			ОбластьШапка.Параметры.НомерДокИспр						= "--";
			ОбластьШапка.Параметры.ПредставлениеПоставщика 			= "Продавец: " + ВыборкаДанные.ПредставлениеПоставщика;
			ОбластьШапка.Параметры.АдресПоставщика 					= "Адрес: " + ВыборкаДанные.АдресПоставщик;
			ОбластьШапка.Параметры.ИННПоставщика 					= "ИНН/КПП продавца:" + ВыборкаДанные.ИННПоставщик + "/" + ВыборкаДанные.КПППоставщик;
			ОбластьШапка.Параметры.ПредставлениеГрузоотправителя	= "Грузоотправитель и его адрес: --";
			ОбластьШапка.Параметры.ПредставлениеГрузополучателя 	= "Грузополучатель и его адрес: --";
			ОбластьШапка.Параметры.ПоДокументу 						= "К платежно-расчетному документу № " + ВыборкаДанные.НомерАкта + " от " + Формат(ВыборкаДанные.ДатаАкта, "ДЛФ=DD");
			ОбластьШапка.Параметры.ПредставлениеПокупателя 			= "Покупатель: " + ВыборкаДанные.ПредставлениеПолучателя;
			ОбластьШапка.Параметры.АдресПокупателя 					= "Адрес: "  + ВыборкаДанные.АдресПокупатель;
			ОбластьШапка.Параметры.ИННПокупателя 					= "ИНН/КПП покупателя: " + ВыборкаДанные.ИННПокупатель + "/" + ВыборкаДанные.КПППокупатель;
			ОбластьШапка.Параметры.Валюта 							= "Валюта: наименование, код Российский рубль, 643";
			ТабДок.Вывести(ОбластьШапка);
			
			ОбластьИдентификаторГК 									= Макет.ПолучитьОбласть("ИдентификаторГосКонтракта");
			ОбластьИдентификаторГК.Параметры.ИдентификаторГосКонтракта = "Идентификатор государственного контракта, договора (соглашения) (при наличии):";
			ТабДок.Вывести(ОбластьИдентификаторГК);
			
			ОбластьШапкаТЧ 											= Макет.ПолучитьОбласть("ШапкаТаблицы");
			ТабДок.Вывести(ОбластьШапкаТЧ);
			
			СуммаВсего												= 0;
			СуммаНДСВсего											= 0;
			ИщемСтроки 												= ВЫборкаТЧ.НайтиСтроки(Новый Структура("Ссылка", ТеДок));
			Для строка = 0 по ИщемСтроки.ВГраница() Цикл
				ОбластьСтрокаТЧ 									= Макет.ПолучитьОбласть("Строка");
				ОбластьСтрокаТЧ.Параметры.Заполнить(ИщемСтроки[строка]);
				ОбластьСтрокаТЧ.Параметры.ТоварНаименование 		= Строка(ИщемСтроки[строка].НоменклатураНаименование) 
				+ " по договору '" + Строка(ТекДоговор) + "'" + " за " + Строка(Формат(ТеДок.ПериодНачисления, "ДФ='ММММ гггг'"));
				ТабДок.Вывести(ОбластьСтрокаТЧ);
				
				СуммаВсего 											= СуммаВсего + ИщемСтроки[строка].Стоимость;
				СуммаНДСВсего 										= СуммаНДСВсего + ИщемСтроки[строка].СуммаНДС;
			КонецЦикла;
			
			ОбластьИтого 											= Макет.ПолучитьОбласть("Итого");
			ОбластьИтого.Параметры.ИтогоСтоимость 					= СуммаВсего;
			ОбластьИтого.Параметры.ИтогоСуммаНДС 					= СуммаНДСВсего;
			ОбластьИтого.Параметры.ИтогоВсего 						= СуммаВсего;
			ТабДок.Вывести(ОбластьИтого);	
			
			ИщемОтвЛиц = ВЫборкаОтветственные.НайтиСтроки(Новый Структура("Организация", ВыборкаДанные.Организация));
			Для строка = 0 по ИщемОтвЛиц.ВГраница() Цикл
				ОбластьПодписи 										= Макет.ПолучитьОбласть("Подвал");
				ОбластьПодписи.Параметры.ФИОРуководителя			= Строка(ИщемОтвЛиц[строка].ФИОРуководителя);
				ОбластьПодписи.Параметры.ФИОГлавногоБухгалтера		= Строка(ИщемОтвЛиц[строка].ФИОГлавногоБухгалтера);
				ТабДок.Вывести(ОбластьПодписи);
			КонецЦикла;
		КонецЦикла;
		ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЦикла;	
КонецПроцедуры

