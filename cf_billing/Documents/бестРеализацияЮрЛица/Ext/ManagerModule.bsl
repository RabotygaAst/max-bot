	|		ПО ВрТ0.Организация = бестНомераСчетовФактурНачисленийЮрЛиц.Организация
	|			И ВрТ0.Ссылка = бестНомераСчетовФактурНачисленийЮрЛиц.Начисление
	|
	|СГРУППИРОВАТЬ ПО
	|	ВрТ0.НДС,
	|	ВрТ0.Договор,
	|	ВрТ0.Услуга,
	|	ВрТ0.Контрагент,
	|	ВрТ0.Организация,
	|	ВрТ0.Район,
	|	бестНомераСчетовФактурНачисленийЮрЛиц.ДатаСчетаНаОплату,
	|	бестНомераСчетовФактурНачисленийЮрЛиц.НомерСФ,
	|	бестНомераСчетовФактурНачисленийЮрЛиц.НомерСчетаНаОплату,
	|	бестНомераСчетовФактурНачисленийЮрЛиц.ДатаСФ,
	|	бестНомераСчетовФактурНачисленийЮрЛиц.НомерАктаВыполненныхРабот,
	|	бестНомераСчетовФактурНачисленийЮрЛиц.IDАктаВыполненныхРабот,
	|	бестНомераСчетовФактурНачисленийЮрЛиц.ДатаАктаВыполненныхРабот,
	|	ВрТ0.Цена,
	|	ВрТ0.ЕдиницаИзмерения,
	|	ВрТ0.Ссылка
	|;
