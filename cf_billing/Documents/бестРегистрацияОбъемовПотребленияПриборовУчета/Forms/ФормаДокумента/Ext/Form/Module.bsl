	               |		ПО ВрТ1.ОбъектРасчета = ВрТ1ЗависимойУслуги.ОбъектРасчета
	               |			И ВрТ1.ТочкаУчета = ВрТ1ЗависимойУслуги.ТочкаУчета
	               |			И ВрТ1.Услуга = ВрТ1ЗависимойУслуги.ЗависитОтУслуги
	               |		ЛЕВОЕ СОЕДИНЕНИЕ СпособыРасчетаНорматива КАК СпособыРасчетаНорматива
	               |		ПО ВрТ1.ОбъектРасчета = СпособыРасчетаНорматива.ОбъектРасчета
	               |			И ВрТ1.Услуга = СпособыРасчетаНорматива.Услуга
	               |			И ВрТ1.ТочкаУчета = СпособыРасчетаНорматива.ТочкаУчета
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ПриоритетРасчетаЗависимыхУслуг КАК ПриоритетРасчетаЗависимыхУслуг
	               |		ПО ВрТ1.ОбъектРасчета = ПриоритетРасчетаЗависимыхУслуг.ОбъектРасчета
	               |			И ВрТ1.Услуга = ПриоритетРасчетаЗависимыхУслуг.Услуга
	               |			И ВрТ1.ТочкаУчета = ПриоритетРасчетаЗависимыхУслуг.ТочкаУчета
	               |		ЛЕВОЕ СОЕДИНЕНИЕ СреднемесячнаяТемпПредМесяц КАК СреднемесячнаяТемпПредМесяц
	               |		ПО ВрТ1.ВидСезонностУслуги = СреднемесячнаяТемпПредМесяц.ВидПериода
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестРасчетнаяТемператураНаружногоВоздухаДляПроектирования.СрезПоследних(
	               |				&Дата,
	               |				Организация = &Организация
	               |					И Район = &Район) КАК бестРасчетнаяТемператураНаружногоВоздухаДляПроектированияСрезПоследних
	               |		ПО ВрТ1.Организация = бестРасчетнаяТемператураНаружногоВоздухаДляПроектированияСрезПоследних.Организация
	               |			И ВрТ1.Район = бестРасчетнаяТемператураНаружногоВоздухаДляПроектированияСрезПоследних.Район
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Приоритет,
	               |	НомерСтроки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЗависимыеУслугиТЧ.Услуга КАК Услуга,
	               |	ЗависимыеУслугиТЧ.НомерСтроки КАК НомерСтроки,
	               |	ЗависимыеУслугиТЧ.УслугаЗависитОт КАК УслугаЗависитОт
	               |ИЗ
	               |	ЗависимыеУслугиТЧ КАК ЗависимыеУслугиТЧ";
	
	Результат = Запрос.ВыполнитьПакет();
	
	Возврат Результат;	
КонецФункции

&НаСервере
Функция ПолучитьОбъемыПредыдущегоМесяца(ТекСтрока)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестОбъемНачисленийНП.ОбъемПоПрибору КАК ОбъемПоПрибору,
		|	бестОбъемНачисленийНП.КоличествоЧасовШтатнойРаботыПУ КАК Q_гв_пп,
		|	бестОбъемНачисленийНП.ОбъемМГВ КАК ОбъемМГВ,
		|	бестОбъемНачисленийНП.КоличествоЧасовРаботыТУ КАК КоличествоЧасовРаботыТУ
		|ИЗ
		|	РегистрНакопления.бестОбъемНачисленийНП КАК бестОбъемНачисленийНП
		|ГДЕ
		|	бестОбъемНачисленийНП.Организация = &Организация
		|	И бестОбъемНачисленийНП.Район = &Район
		|	И бестОбъемНачисленийНП.Договор = &Договор
		|	И бестОбъемНачисленийНП.ОбъектРасчета = &ОбъектРасчета
		|	И бестОбъемНачисленийНП.Услуга = &Услуга
		|	И бестОбъемНачисленийНП.ТочкаУчета = &ТочкаУчета
		|	И бестОбъемНачисленийНП.ВидНачисления = &ВидНачисления
		|	И бестОбъемНачисленийНП.СпособНачисления = &СпособНачисления
		|	И бестОбъемНачисленийНП.ПриборУчета = &ПриборУчета
		|	И бестОбъемНачисленийНП.ТарифнаяЗона = &ТарифнаяЗона
		|	И бестОбъемНачисленийНП.ПериодНачисления = &ПериодНачисления";
	
	Запрос.УстановитьПараметр("ВидНачисления"		, Перечисления.энргВидыНачислений.Начисление);
	Запрос.УстановитьПараметр("Договор"				, ТекСтрока.Договор);
	Запрос.УстановитьПараметр("ОбъектРасчета"		, ТекСтрока.ОбъектРасчета);
	Запрос.УстановитьПараметр("Организация"			, Объект.Организация);
	Запрос.УстановитьПараметр("ПериодНачисления"	, ДобавитьМесяц(Объект.ПериодНачисления,-1));
	Запрос.УстановитьПараметр("ПриборУчета"			, ТекСтрока.ПриборУчета);
	Запрос.УстановитьПараметр("Район"				, Объект.Район);
	Запрос.УстановитьПараметр("СпособНачисления"	, Перечисления.энргСпособНачислений.ПоПриборам);
	Запрос.УстановитьПараметр("ТарифнаяЗона"		, ТекСтрока.ТарифнаяЗона);
	Запрос.УстановитьПараметр("ТочкаУчета"			, ТекСтрока.ТочкаУчета);
	Запрос.УстановитьПараметр("Услуга"				, ТекСтрока.Услуга);
	
	РезультатЗапроса 	= Запрос.Выполнить(); 	
	Выборка 			= РезультатЗапроса.Выбрать();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;  
	
	СтруктураОтвета = новый Структура("ОбъемПоПрибору,Q_гв_пп,ОбъемМГВ,КоличествоЧасовРаботыТУ",0,0,0,0);
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураОтвета,Выборка);		
	КонецЕсли;     	
	
	Возврат СтруктураОтвета;
	
КонецФункции

&НаСервере
Функция ПолучитьДанныеПоУслуге(Услуга)
	 Возврат Новый Структура("СпособДосчётаРесурса, СодержитПотери", Услуга.СпособДосчётаРесурса, Услуга.СодержитПотери);
КонецФункции

&НаСервере
Функция Получить_t_под__t_хв(ТекСтрока)
	
	Температуры = новый Структура("t_под,t_хв",0,0);
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	бестСтруктураСетиТочекУчетаНПСрезПоследних.СтруктураСети КАК СтруктураСети
		|ПОМЕСТИТЬ ВТ_Источник
		|ИЗ
		|	РегистрСведений.бестСтруктураСетиТочекУчетаНП.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ОбъектРасчета = &ОбъектРасчета
		|				И ТочкаУчета = &ТочкаУчета) КАК бестСтруктураСетиТочекУчетаНПСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	бестТемператураИсточникаСрезПоследних.ТемператураПодачиИсточника КАК t_под,
		|	бестТемператураИсточникаСрезПоследних.ТемператураХолоднойВодыИсточника КАК t_хв
		|ИЗ
		|	РегистрСведений.бестТемператураИсточника.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И Источник В
		|					(ВЫБРАТЬ
		|						ВТ_Источник.СтруктураСети КАК СтруктураСети
		|					ИЗ
		|						ВТ_Источник КАК ВТ_Источник)) КАК бестТемператураИсточникаСрезПоследних";
	
	Запрос.УстановитьПараметр("Дата"				, Объект.Дата); 	
	Запрос.УстановитьПараметр("Организация"			, Объект.Организация);
	Запрос.УстановитьПараметр("Район"				, Объект.Район);
	Запрос.УстановитьПараметр("Договор"				, ТекСтрока.Договор);
	Запрос.УстановитьПараметр("ОбъектРасчета"		, ТекСтрока.ОбъектРасчета);
	Запрос.УстановитьПараметр("ТочкаУчета"			, ТекСтрока.ТочкаУчета);
	
	РезультатЗапроса 	= Запрос.Выполнить();	
	Выборка 			= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Температуры,Выборка);
	КонецЦикла;
	
	Возврат Температуры;
	
КонецФункции

