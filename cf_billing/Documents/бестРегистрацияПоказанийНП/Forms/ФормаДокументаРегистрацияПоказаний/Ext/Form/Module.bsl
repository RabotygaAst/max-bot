&НаСервере
Процедура ОтборДоговора()

	МассивСвязей = Новый Массив(Элементы.Договор.СвязиПараметровВыбора);
	НоваяСвязь = Новый СвязьПараметраВыбора("Отбор.Район", "Объект.Район");
	Индекс = МассивСвязей.Найти(НоваяСвязь);
	Если Индекс = Неопределено И ЗначениеЗаполнено(Объект.Район) Тогда
		МассивСвязей.Добавить(НоваяСвязь);
	ИначеЕсли Не Индекс = Неопределено И Не ЗначениеЗаполнено(Объект.Район) Тогда
		МассивСвязей.Удалить(Индекс);
	КонецЕсли;
	Элементы.Договор.СвязиПараметровВыбора = Новый ФиксированныйМассив(МассивСвязей);

КонецПроцедуры

