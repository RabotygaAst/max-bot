#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Объект.Договор) И НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗаполнитьТЧ();
	КонецЕсли;
	
	бестЛокализацияСервер.ПриСозданииНаСервере_бестРеструктуризацияЗадолженности(ЭтотОбъект);
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПересчитатьСуммуКРаспределению();
	НастроитьЭлементыФормы();
КонецПроцедуры

#КонецОбласти 

#Область СобытияЭлементовФормы

&НаКлиенте
Процедура ДатаОперацииПриИзменении(Элемент)
	ЗаполнитьТЧ();
КонецПроцедуры

&НаКлиенте
Процедура ДоговорПриИзменении(Элемент)
	ЗаполнитьТЧ();
КонецПроцедуры

&НаКлиенте
Процедура ДанныеЗадолженностиВключитьВПланПриИзменении(Элемент)
	ПересчитатьСуммуКРаспределению();
КонецПроцедуры

#КонецОбласти 

#Область ВспомогательныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьТЧ()
	Объект.ДанныеЗадолженности.Очистить();
	
	Если Объект.ВидОперации = Перечисления.бестВидыОпераций.РеструктуризацияЗадолженности_РегистрацияРеструктуризации Тогда
		
		Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьФактическуюЗадолженностьПоПериодам(Объект.Организация,Объект.Район,Объект.Договор,,,Объект.ДатаОперации);
		Выборка = Результат.выбрать();
		Пока Выборка.Следующий() Цикл 
			НовСтр = Объект.ДанныеЗадолженности.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтр, Выборка);
			НовСтр.Сумма = Выборка.Задолженность;
		КонецЦикла;
		
	ИначеЕсли Объект.ВидОперации = Перечисления.бестВидыОпераций.РеструктуризацияЗадолженности_ОтменаРеструктуризации Тогда
		Результат = бестВзаиморасчетыЮрЛицаСервер.ПолучитьРеструктуризированнуюЗадолженность(Объект.Организация,Объект.Район,Объект.Договор,Объект.ДатаОперации);
		Выборка = Результат.выбрать();
		Пока Выборка.Следующий() Цикл 
			НовСтр = Объект.ДанныеЗадолженности.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтр, Выборка);
			НовСтр.ВключитьВПлан = Истина;
		КонецЦикла;
		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура НастроитьЭлементыФормы()
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.бестВидыОпераций.РеструктуризацияЗадолженности_ОтменаРеструктуризации") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Группа2", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаПланПогашения", "Видимость", Ложь);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСуммуКРаспределению()
	СуммаКРаспределению = 0;
	Для каждого Строка Из Объект.ДанныеЗадолженности Цикл
		Если НЕ Строка.ВключитьВПлан Тогда
			Продолжить;
		КонецЕсли;
		СуммаКРаспределению = СуммаКРаспределению + Строка.Сумма;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиКомандФормы

// ВводНаОсновании
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуСоздатьНаОсновании(Команда)
	
	ВводНаОснованииКлиент.ВыполнитьПодключаемуюКомандуСоздатьНаОсновании(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры
// Конец ВводНаОсновании

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат) Экспорт
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры

#КонецОбласти