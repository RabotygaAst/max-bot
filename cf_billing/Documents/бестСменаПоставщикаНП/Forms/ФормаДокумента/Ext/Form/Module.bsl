	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	энргРаботаСПоставщикамиКлиент.ПоставщикАвтоПодбор(ЭтаФорма,ТекущиеДанные, Новый Структура("ИмяСвойстваПоставщикПосле,ИмяСвойстваПоставщик","ПоставщикПосле", "Поставщик"));
	//энргРаботаСПоставщикамиКлиент.ПриИзмененииУслуги(ЭтаФорма,ТекущиеДанные,энргРаботаСПоставщикамиСервер.ОписаниеУслуги(ТекущиеДанные.Услуга)); 
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЕстьШкалыЕстьТарифныеЗоныПриАктивизацииСтроки(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчетаЕстьШкалыЕстьТарифныеЗоны";
	ИмяТаблицыШкал							= "ШкалыПриборовУчетаЕстьШкалыЕстьТарифныеЗоны";
	ТаблицаФормыШкал	 					= Элементы[ИмяТаблицыШкал];
	
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

		
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ИмяТаблицыПоказания						= "ПоказанияПриборовУчета" + ПрефиксТочекУчета;
	ТаблицаФормыПоказания 					= Элементы[ИмяТаблицыПоказания];
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.ПриборУчета) Тогда 
		энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(ТаблицаФормыПоказания,Неопределено,Неопределено); 
	КонецЕсли;
	
	энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаФормыШкал,"IDСтрокиТочкиУчета",ТекущиеДанные.IDСтроки);	
	
	РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные);
	
	// Активизируем первую строку в таблице шкал
	СтрокиШкал = Объект.ШкалыПриборовУчета.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекущиеДанные.IDСтроки));
	Если ЗначениеЗаполнено(СтрокиШкал) Тогда
		Элементы[ИмяТаблицыШкал].ТекущаяСтрока = СтрокиШкал[0].ПолучитьИдентификатор();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ТочкиУчета) Тогда 
		ОписаниеУслуги = энргРаботаСПоставщикамиСервер.ОписаниеУслуги(ТекущиеДанные.Услуга);
		//бестРаботаСПоставщикамиКлиент.ПриИзмененииУслугиПосле(ЭтаФорма,ТекущиеДанные,ОписаниеУслуги); 	
		УстановитьУсловноеОФормлениеФормыКлиент("ПоставщикПосле","ПараметрыПоставщиков");
	КонецЕсли;

КонецПроцедуры

