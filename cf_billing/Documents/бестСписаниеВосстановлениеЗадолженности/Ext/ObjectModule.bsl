#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	Ответственный = Пользователи.ТекущийПользователь();
	
	бестПроведениеСерверНП.ПередЗаписьюОбъекта(ЭтотОбъект);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	бестПроведениеСерверНП.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	Результат = ПолучитьДанныеДляПроведения();
	
	Выборка 			= Результат[0].Выбрать();
	СвернутаяВыборка 	= Результат[1].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.СписаниеПени Тогда
			Менедж = Движения.бестВзаиморасчетыПоПениЭЭ;
		Иначе 
			Менедж = Движения.бестВзаиморасчетыПоМесяцамЭЭ;
		КонецЕсли;
		
		ЗаписьВзаиморасчеты 			= Менедж.ДобавитьПриход();
		ЗаписьСписаннойЗадолженности 	= Движения.бестСписаннаяЗадолженность.Добавить();
		
		
		ЗаполнитьЗначенияСвойств(ЗаписьВзаиморасчеты,Выборка);
		ЗаполнитьЗначенияСвойств(ЗаписьСписаннойЗадолженности,Выборка);
		
		Если Выборка.ВидОперации = Перечисления.бестВидыОпераций.СписаниеВосстановлениеЗадолженности_СписаниеЗадолженности Тогда
			ЗаписьВзаиморасчеты.Сумма 	 = -Выборка.Сумма;
			ЗаписьВзаиморасчеты.СуммаНДС = -Выборка.СуммаНДС;
		ИначеЕсли Выборка.ВидОперации = Перечисления.бестВидыОпераций.СписаниеВосстановлениеЗадолженности_ВосстановлениеЗадолженности Тогда
			ЗаписьСписаннойЗадолженности.Сумма 	  = -Выборка.Сумма;
			ЗаписьСписаннойЗадолженности.СуммаНДС = -Выборка.СуммаНДС;
		КонецЕсли;
	
	КонецЦикла;
	
	
	Пока СвернутаяВыборка.Следующий() Цикл
		ЗаписьВзаиморасчетыЭЭ = Движения.бестВзаиморасчетыЭЭ.ДобавитьПриход();
		ЗаполнитьЗначенияСвойств(ЗаписьВзаиморасчетыЭЭ,СвернутаяВыборка);
		
		Если Выборка.ВидОперации = Перечисления.бестВидыОпераций.СписаниеВосстановлениеЗадолженности_СписаниеЗадолженности Тогда
			ЗаписьВзаиморасчетыЭЭ.Сумма 	 	= -СвернутаяВыборка.Сумма;
			ЗаписьВзаиморасчетыЭЭ.СуммаНДС 		= -СвернутаяВыборка.СуммаНДС;
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

Функция ПолучитьДанныеДляПроведения()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСписаниеВосстановлениеЗадолженностиДанныеЗадолженности.ПлатежныйДокумент КАК ПлатежныйДокумент,
		|	бестСписаниеВосстановлениеЗадолженностиДанныеЗадолженности.ПериодНачисления КАК ПериодНачисления,
		|	бестСписаниеВосстановлениеЗадолженностиДанныеЗадолженности.Сумма КАК Сумма,
		|	бестСписаниеВосстановлениеЗадолженности.Организация КАК Организация,
		|	бестСписаниеВосстановлениеЗадолженности.Район КАК Район,
		|	бестПлатежныйДокумент.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бестВидыОпераций.ПлатежныйДокумент_Пеня) КАК СписаниеПени,
		|	бестПлатежныйДокумент.ПериодНачисления КАК ПериодРасчета,
		|	бестСписаниеВосстановлениеЗадолженности.ДатаОперации КАК Период,
		|	бестПлатежныйДокумент.Договор КАК Договор,
		|	бестСписаниеВосстановлениеЗадолженностиДанныеЗадолженности.СуммаНДС КАК СуммаНДС,
		|	бестСписаниеВосстановлениеЗадолженности.ВидОперации КАК ВидОперации
		|ПОМЕСТИТЬ ДанныеДокумента
		|ИЗ
		|	Документ.бестСписаниеВосстановлениеЗадолженности.ДанныеЗадолженности КАК бестСписаниеВосстановлениеЗадолженностиДанныеЗадолженности
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестСписаниеВосстановлениеЗадолженности КАК бестСписаниеВосстановлениеЗадолженности
		|		ПО бестСписаниеВосстановлениеЗадолженностиДанныеЗадолженности.Ссылка = бестСписаниеВосстановлениеЗадолженности.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
		|		ПО бестСписаниеВосстановлениеЗадолженностиДанныеЗадолженности.ПлатежныйДокумент = бестПлатежныйДокумент.Ссылка
		|ГДЕ
		|	бестСписаниеВосстановлениеЗадолженности.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ДанныеДокумента.Сумма) КАК Сумма,
		|	ДанныеДокумента.Организация КАК Организация,
		|	ДанныеДокумента.Район КАК Район,
		|	ДанныеДокумента.Договор КАК Договор,
		|	СУММА(ДанныеДокумента.СуммаНДС) КАК СуммаНДС,
		|	ДанныеДокумента.СписаниеПени КАК СписаниеПени,
		|	ДанныеДокумента.ВидОперации КАК ВидОперации,
		|	ДанныеДокумента.Период КАК Период
		|ИЗ
		|	ДанныеДокумента КАК ДанныеДокумента
		|ГДЕ
		|	НЕ ДанныеДокумента.СписаниеПени
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеДокумента.Организация,
		|	ДанныеДокумента.Район,
		|	ДанныеДокумента.Договор,
		|	ДанныеДокумента.СписаниеПени,
		|	ДанныеДокумента.ВидОперации,
		|	ДанныеДокумента.Период";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли