#Область СлужебныеПроцедурыИФункции

Функция ПреобразоватьМассивВТаблицу(ДанныеДляЗагрузки)	
	ТЗ 	= новый ТаблицаЗначений;
	
	Для Каждого ТекСтр из ДанныеДляЗагрузки Цикл
		Для Каждого ТекЭлем Из ТекСтр Цикл			
			ТЗ.Колонки.Добавить(ТекЭлем.Ключ,,СтрЗаменить(ТекЭлем.Ключ,"Колонка",""));
		КонецЦикла;
		
		Прервать; //из 1 строки забрали колонки. Дальше нет нужды двигаться по циклу
	КонецЦикла;
	
	Для Каждого ТекСтр из ДанныеДляЗагрузки Цикл
		НоваяСтрока = ТЗ.Добавить();
		
		Для Каждого ТекЭлем Из ТекСтр Цикл
			НоваяСтрока[ТекЭлем.Ключ] = ТекЭлем.Значение;			
		КонецЦикла; 		
		
	КонецЦикла;
	
	Возврат ТЗ;
КонецФункции

Функция ПолучитьДату(ДатаСтрока) 
	Возврат СтроковыеФункцииКлиентСервер.СтрокаВДату(Лев(ДатаСтрока,10));
КонецФункции

Функция ЗаполнитьСтатическиеРеквизиты(СтатическиеКолонки,Статика,Колонки,ТекСтрока)
	
	ЗначенияСтатическихКолонок = новый Структура;
	ЗначенияСтатическихКолонок.Вставить("IDСтроки",Новый УникальныйИдентификатор);
	
	Для Каждого ТекСоот из Статика Цикл
		СтатКолонка = СтатическиеКолонки.Получить(ТекСоот.Значение);
		Если СтатКолонка = Неопределено Тогда
			Продолжить;
		КонецЕсли; 		
			
		Если СтатКолонка.ТипЗнч = Тип("Дата") Тогда
			Значение = ПолучитьДату(ТекСтрока["Колонка" + ТекСоот.Ключ]);
		Иначе
			Значение = ТекСтрока["Колонка" + ТекСоот.Ключ];
		КонецЕсли;
		
		ЗначенияСтатическихКолонок.Вставить(ТекСоот.Значение,Значение);
	КонецЦикла;
	
	Возврат ЗначенияСтатическихКолонок
КонецФункции

