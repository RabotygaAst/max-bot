#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗаполнитьПоРегистру(ТаблицаПараметрыИзмерителя,ПриборУчета) Экспорт 
	
	РезультатЗапроса 	= РегистрыСведений.бестПараметрыИзмерителей.ВернутьПараметрыИзмерителя(ПриборУчета);
	
	ТипДляКолонки 		= Новый ОписаниеТипов("СправочникСсылка.бестВидыПараметровИзмерителей");
	Выборка 			= РезультатЗапроса.Выбрать();
	МодульДок			= Документы.бестСуточнаяВедомость; 	
	
	Пока Выборка.Следующий() Цикл
		ИмяКолонки 	= МодульДок.СформироватьИмяКолонки(Выборка.ВидПараметра); 		
		 
		ТаблицаПараметрыИзмерителя.Колонки.Добавить(ИмяКолонки,ТипДляКолонки,Выборка.ВидПараметра);
	КонецЦикла;
	           
КонецПроцедуры

#Область РАБОТА_С_КОЛОНКАМИ

Функция СформироватьИмяКолонки(ВидПараметра) Экспорт 
	ИмяКолонки 	= "Колонка";//СтрЗаменить(ВидПараметра," ","");
	ИденКолонки = СтрЗаменить(Строка(ВидПараметра.УникальныйИдентификатор()),"-","_");
	
	ИмяКолонки 	= ИмяКолонки + "_1_" + ИденКолонки;
	
	Возврат ИмяКолонки;
КонецФункции

// Описание полей
// ВыводитьВТЧ - необходим для справочника с настройками шаблонов
Функция ПолучитьСтатическиеКолонки() Экспорт
	
	МассивКолонок 		= ПолучитьМассивСтатическихКолонок();
	СтатическиеКолонки 	= Новый Соответствие;	
	
	Для Каждого ТекСтрока Из МассивКолонок Цикл
		СтруктураСтроки = Новый Структура("Имя,Тип,ТипЗнч,Заголовок,ВыводитьВТЧ");
		ЗаполнитьЗначенияСвойств(СтруктураСтроки,ТекСтрока);
		СтатическиеКолонки.Вставить(ТекСтрока.Имя,СтруктураСтроки);
	КонецЦикла;
	
	Возврат СтатическиеКолонки;
КонецФункции

Функция ПолучитьМассивСтатическихКолонок() Экспорт
	
	СтатическиеКолонки = Новый Массив;	
	СтатическиеКолонки.Добавить(Новый Структура("Имя,Тип,ТипЗнч,Заголовок,ВыводитьВТЧ","IDСтроки"	,ОбщегоНазначения.ОписаниеТипаСтрока(36)				,Тип("УникальныйИдентификатор")	,"IDСтроки" 	,Ложь));
	СтатическиеКолонки.Добавить(Новый Структура("Имя,Тип,ТипЗнч,Заголовок,ВыводитьВТЧ","ДатаВремя"	,ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя)	,Тип("Дата")					,"Дата время"	,Истина));
	СтатическиеКолонки.Добавить(Новый Структура("Имя,Тип,ТипЗнч,Заголовок,ВыводитьВТЧ","BНP"		,ОбщегоНазначения.ОписаниеТипаЧисло(15)					,Тип("Число")					,"BНP"			,Истина));
	СтатическиеКолонки.Добавить(Новый Структура("Имя,Тип,ТипЗнч,Заголовок,ВыводитьВТЧ","BOC"		,ОбщегоНазначения.ОписаниеТипаЧисло(15)					,Тип("Число")					,"BOC"			,Истина));
	
	Возврат СтатическиеКолонки;
КонецФункции

Функция ПолучитьЭлементСправочникаПоКолонке(Имя,ПустойПараметр,МодульСпр) Экспорт
	МассивПодстрок 	= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Имя,"_1_",Истина);
	ВидПараметра  	= ПустойПараметр;
	Если МассивПодстрок.количество() > 0 Тогда
		Попытка
			ВидПараметра = МодульСпр.ПолучитьСсылку(новый УникальныйИдентификатор(СтрЗаменить(МассивПодстрок[1],"_","-")));
		Исключение
			ВидПараметра  	= ПустойПараметр;
		КонецПопытки; 
	КонецЕсли;
	
	Возврат ВидПараметра
КонецФункции
	
#КонецОбласти

Функция ПолучитьСоотвествияКолонок(Шаблон) Экспорт 	
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестШаблоныЗагрузокСуточнойВедомостиСтатическиеКолонки.РеквизитТЧ КАК РеквизитТЧ,
		|	бестШаблоныЗагрузокСуточнойВедомостиСтатическиеКолонки.НомерКолонки КАК НомерКолонки,
		|	""Статика"" КАК ВидКолонки
		|ПОМЕСТИТЬ ВТ_НастройкиЗаполнения
		|ИЗ
		|	Справочник.бестШаблоныЗагрузокСуточнойВедомости.СтатическиеКолонки КАК бестШаблоныЗагрузокСуточнойВедомостиСтатическиеКолонки
		|ГДЕ
		|	бестШаблоныЗагрузокСуточнойВедомостиСтатическиеКолонки.Ссылка = &Шаблон
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бестШаблоныЗагрузокСуточнойВедомостиДинамическиеКолонки.РеквизитТЧ,
		|	бестШаблоныЗагрузокСуточнойВедомостиДинамическиеКолонки.НомерКолонки,
		|	""Динамика""
		|ИЗ
		|	Справочник.бестШаблоныЗагрузокСуточнойВедомости.ДинамическиеКолонки КАК бестШаблоныЗагрузокСуточнойВедомостиДинамическиеКолонки
		|ГДЕ
		|	бестШаблоныЗагрузокСуточнойВедомостиДинамическиеКолонки.Ссылка = &Шаблон
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_НастройкиЗаполнения.РеквизитТЧ КАК РеквизитТЧ,
		|	ВТ_НастройкиЗаполнения.НомерКолонки КАК НомерКолонки,
		|	ВТ_НастройкиЗаполнения.ВидКолонки КАК ВидКолонки
		|ИЗ
		|	ВТ_НастройкиЗаполнения КАК ВТ_НастройкиЗаполнения
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВидКолонки,
		|	НомерКолонки
		|ИТОГИ ПО
		|	ВидКолонки";
	
	Запрос.УстановитьПараметр("Шаблон",Шаблон);
	
	РезультатЗапроса 	= Запрос.Выполнить();
	
	Статика 			= Новый Соответствие;
	Динамика 			= Новый Соответствие;
	
	ВыборкаВидКолонки = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаВидКолонки.Следующий() Цикл		
	
		Детальные = ВыборкаВидКолонки.Выбрать();
		
		ЭтоСтатика = ВыборкаВидКолонки.ВидКолонки = "Статика";
		
		Пока Детальные.Следующий() Цикл
			Если ЭтоСтатика Тогда
				Статика.Вставить(Детальные.НомерКолонки,Детальные.РеквизитТЧ);
			Иначе				
				Динамика.Вставить(Детальные.НомерКолонки,Детальные.РеквизитТЧ);
			КонецЕсли;		
		КонецЦикла;
	КонецЦикла;
	
	
	Возврат Новый Структура("Статика,Динамика",Статика,Динамика);
	
КонецФункции

#Область ЗАГРУЗКА_ИЗ_ФАЙЛОВ

//ПОЛУЧЕНИЕ ДАННЫХ ИЗ ФАЙЛА
#Область EXEL

Функция ВернутьДанныеИзФайла(ПутьКФайлу,ШаблонНастроекЗагрузки) Экспорт
	
	Таблица = новый ТаблицаЗначений;
	
	// Попытка открытия файла Excel
	Попытка
		Excel = Новый COMОбъект("Excel.Application");
		Excel.WorkBooks.Open(ПутьКФайлу);
	Исключение
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru='При открытии файла произошла ошибка! Операция прервана!'"));
		ОбщегоНазначения.СообщитьПользователю(ОписаниеОшибки());
		Возврат Таблица;
	КонецПопытки;
	
	// Попытка выбрать первый лист
	Попытка 
		Excel.Sheets(1).Select();    
	Исключение
		// Закрытие файла в том случае, если первый лист не найден
		Excel.ActiveWorkbook.Close(); 	
		Excel = 0;
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru='Первый лист не найден!'"));
		ОтменитьТранзакцию();
		Возврат Таблица;
	КонецПопытки;
	
	// Получим количество строк и колонок.
	// В разных версиях Excel получаются по-разному, поэтому сначала определим версию Excel
	Версия = Лев(Excel.Version,Найти(Excel.Version,".")-1);
	Если Версия = "8" тогда
		ФайлСтрок 	= Excel.Cells.CurrentRegion.Rows.Count;
		ФайлКолонок = Макс(Excel.Cells.CurrentRegion.Columns.Count, 13);
	Иначе
		ФайлСтрок 	= Excel.Cells(1,1).SpecialCells(11).Row;
		ФайлКолонок = Excel.Cells(1,1).SpecialCells(11).Column;
	Конецесли;
	
	Сч = 1;
	Пока ЗначениеЗаполнено(Excel.Cells(1, Сч).Text) Цикл
		ИмяКолонки 		= Excel.Cells(1, Сч).Text;
		ИмяБезПробелов 	= "Колонка" + Сч; //СтрЗаменить(ИмяКолонки," ",""); 
		Таблица.Колонки.Добавить(ИмяБезПробелов,,Строка(Сч));		
		Сч = Сч + 1;
	КонецЦикла;
	
	НачальнаяСтрока = ?(ШаблонНастроекЗагрузки.НачальнаяСтрока > 0 ,ШаблонНастроекЗагрузки.НачальнаяСтрока,2); 
	ФайлСтрок 		= ?(ШаблонНастроекЗагрузки.КонечнаяСтрока > 0  ,ШаблонНастроекЗагрузки.КонечнаяСтрока ,ФайлСтрок);
	
	Для НС = НачальнаяСтрока по ФайлСтрок Цикл 	
		
		НоваяСтрока = Таблица.Добавить();
		
		Для НомерКолонки = 1 по Таблица.Колонки.Количество() Цикл
			// заполняем строку значениями
			ТекущееЗначение 		= Excel.Cells(НС, НомерКолонки).Text;
			ИмяКолонки 				= Таблица.Колонки[НомерКолонки-1].Имя;
			НоваяСтрока[ИмяКолонки] = ТекущееЗначение;
		КонецЦикла;
		
	КонецЦикла;
	
	Excel.DisplayAlerts = 0; 
	Excel.Quit();
	Excel.DisplayAlerts = 1;
	
	Возврат Таблица;
КонецФункции

Процедура ЗагрузитьДанныеИзФайла(ПутьКФайлу, Шаблон, ТабЧасть) Экспорт
	ДанныеДляЗагрузки  	= ВернутьДанныеИзФайла(ПутьКФайлу,Шаблон);
	
	ЗаполнитьДанныеИзФайлаВТЧ(ДанныеДляЗагрузки, Шаблон, ТабЧасть);	
КонецПроцедуры

#КонецОбласти

#Область TXT

Функция ВернутьДанныеИзTXTФайла(ПутьКФайлу,ШаблонНастроекЗагрузки) Экспорт
	
	Текст = Новый ТекстовыйДокумент;	
	Текст.Прочитать(ПутьКФайлу);
	
	Таблица 		= Новый ТаблицаЗначений;
	СоздатьКолонки 	= Истина;
	
	НачальнаяСтрока = ?(ШаблонНастроекЗагрузки.НачальнаяСтрока > 0 ,ШаблонНастроекЗагрузки.НачальнаяСтрока,2); 
	ФайлСтрок 		= ?(ШаблонНастроекЗагрузки.КонечнаяСтрока > 0  ,ШаблонНастроекЗагрузки.КонечнаяСтрока ,Текст.КоличествоСтрок());
	
	Для НомерСтроки = НачальнаяСтрока По ФайлСтрок Цикл		
		
		СтрокаДляПарсинга = Текст.ПолучитьСтроку(НомерСтроки);
		Если СоздатьКолонки Тогда
			// Первая строка должна быть первой строкой данных!
			// При первом заходе формируем по первой строке колонки таблицы!
			СтрокаДляКолонок = СтрокаДляПарсинга;
			Сч = 1;
			Пока СтрокаДляКолонок <> "" Цикл	
				Позиция			= Найти(СтрокаДляКолонок, "|");
				Если Позиция = 0 Тогда
					Прервать;
				КонецЕсли;			
				СтрокаДляКолонок = СокрЛП(Сред(СтрокаДляКолонок, Позиция + 1));
				
				ИмяБезПробелов 	= "Колонка" + Сч; 
				Таблица.Колонки.Добавить(ИмяБезПробелов,,Строка(Сч));		
				Сч = Сч + 1;
			КонецЦикла;
		КонецЕсли;		
		
		СоздатьКолонки 	= Ложь;
		НомерКолонки 	= 1;
		
		Пока СтрокаДляПарсинга <> "" Цикл 			
			Позиция			= Найти(СтрокаДляПарсинга, "|");
			Если Позиция = 0 Тогда
				// В данной строке нет колонок
				Прервать;
			ИначеЕсли НомерКолонки = 1 Тогда
				// В этом условии потому что есть строки с промежуточными итогами и они отделены ненужной строкой
				НоваяСтрока 	= Таблица.Добавить();
			КонецЕсли;
			
			// Обрезаем строку
			ДанныеКолонки 		= Сред(СтрокаДляПарсинга, 1, Позиция-1);	
			СтрокаДляПарсинга	= СокрЛП(Сред(СтрокаДляПарсинга, Позиция + 1));
			
			// Получаем имя колонки
			ИмяКолонки 				= Таблица.Колонки[НомерКолонки-1].Имя;
			НоваяСтрока[ИмяКолонки] = ДанныеКолонки;			
			
			НомерКолонки 	= НомерКолонки + 1;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Таблица;
	
КонецФункции

Процедура ЗагрузитьДанныеИзФайлаTXT(ПутьКФайлу, Шаблон, ТабЧасть) Экспорт
	ДанныеДляЗагрузки  	= ВернутьДанныеИзTXTФайла(ПутьКФайлу,Шаблон);
	
	ЗаполнитьДанныеИзФайлаВТЧ(ДанныеДляЗагрузки, Шаблон, ТабЧасть);	
КонецПроцедуры

#КонецОбласти

//ЗАПОЛНЕНИЕ ДАННЫХ ИЗ ФАЙЛА
Процедура ЗаполнитьДанныеИзФайлаВТЧ(Данные, Шаблон, ТабЧасть) Экспорт
	
	Если Данные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;	
	
	Если ТипЗнч(Данные) = тип("Массив") Тогда
		ДанныеДляЗагрузки = ПреобразоватьМассивВТаблицу(Данные);
	Иначе 
		ДанныеДляЗагрузки = Данные;
	КонецЕсли;	
	
	СоотвествияКолонок 	= ПолучитьСоотвествияКолонок(Шаблон);
	СтатическиеКолонки 	= Документы.бестСуточнаяВедомость.ПолучитьСтатическиеКолонки();
	МодульСпр			= Справочники.бестВидыПараметровИзмерителей;
	ПустойВидПараметра	= МодульСпр.ПустаяСсылка();
	
	Статика  			= СоотвествияКолонок.Статика;
	Динамика 			= СоотвествияКолонок.Динамика;
	
	Колонки 			= ДанныеДляЗагрузки.Колонки;
	
	Для Каждого ТекСтрока из ДанныеДляЗагрузки Цикл
		
		ЗначенияСтатическихКолонок 	= ЗаполнитьСтатическиеРеквизиты(СтатическиеКолонки,Статика,Колонки,ТекСтрока);	
		
		// Заполняем динамические данные
		Для Каждого ТекСоответДин из Динамика Цикл
			Попытка
				Значение = ТекСтрока["Колонка" + ТекСоответДин.Ключ];
				
				НоваяСтрока 				= ТабЧасть.Добавить();
				
				ЗаполнитьЗначенияСвойств(НоваяСтрока,ЗначенияСтатическихКолонок);				
				НоваяСтрока.ВидПараметра 	= ТекСоответДин.Значение;
				НоваяСтрока.Значение 		= Значение;
			Исключение
			КонецПопытки; 			
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры 

#КонецОбласти

