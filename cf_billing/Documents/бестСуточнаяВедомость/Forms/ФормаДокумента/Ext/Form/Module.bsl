#Область События_Заполнения 

&НаСервере
Процедура ЗаполнитьКолонкиТаблицыИзРегистра()
		
	РезультатЗапроса 	= РегистрыСведений.бестПараметрыИзмерителей.ВернутьПараметрыИзмерителя(Объект.Дата,Объект.ПриборУчета);
	Ошибка 				= Ложь;
	ЗаполненПУ			= ЗначениеЗаполнено(Объект.ПриборУчета);
	
	Если РезультатЗапроса.Пустой() Тогда
		Если ЗаполненПУ Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По данному прибору учета не указаны виды параметров");
		КонецЕсли;
		ОчиститьТЧ();
		Ошибка = Истина; 		
	КонецЕсли; 	
	
	ОписаниеЧисла 		= Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3));   
	
	Выборка 					= РезультатЗапроса.Выбрать();
	МодульДок					= Документы.бестСуточнаяВедомость;
	СтатическиеКолонки 			= МодульДок.ПолучитьСтатическиеКолонки();
	СтатическиеКолонкиМассив 	= МодульДок.ПолучитьМассивСтатическихКолонок(); //Заполнены в необходимом порядке колонок
		
	ТаблицаРезультат = новый ТаблицаЗначений;
	Для Каждого ТекСтрЗначение из СтатическиеКолонкиМассив Цикл 		
		ТаблицаРезультат.Колонки.Добавить(ТекСтрЗначение.Имя, ТекСтрЗначение.Тип, ТекСтрЗначение.Заголовок);
	КонецЦикла;

	Пока Выборка.Следующий() Цикл
		ИмяКолонки 	= МодульДок.СформироватьИмяКолонки(Выборка.ВидПараметра); 		
		 
		ТаблицаРезультат.Колонки.Добавить(ИмяКолонки,ОписаниеЧисла,Выборка.ВидПараметра);
	КонецЦикла;	
	
	Таблица 			= РеквизитФормыВЗначение("ПараметрыИзмерителя");
	МассивРеквизитов 	= Новый Массив;	
		
	Для Каждого Колонка Из Таблица.Колонки Цикл
		МассивРеквизитов.Добавить("ПараметрыИзмерителя." + Колонка.Имя);       
	КонецЦикла;	
	
	ИзменитьРеквизиты(,МассивРеквизитов); 	
	
	ЭлементТаблица = Элементы.Найти("ПараметрыИзмерителя");
	Если ЭлементТаблица <> Неопределено Тогда
		Элементы.Удалить(ЭлементТаблица);       
	КонецЕсли;    
	
	ЭлементТаблица				= Элементы.Добавить("ПараметрыИзмерителя", Тип("ТаблицаФормы"),Элементы.ДинамическаяТаблица);
	ЭлементТаблица.ПутьКДанным 	= "ПараметрыИзмерителя";
	ЭлементТаблица.Отображение 	= ОтображениеТаблицы.Список;  
	                                                         	
	
	МассивРеквизитов.Очистить();		
	Для Каждого Колонка ИЗ ТаблицаРезультат.Колонки Цикл
		МассивТипов = Новый Массив;
		МассивТипов.Добавить(Колонка.ТипЗначения);
		НоваяКолонка = Новый РеквизитФормы(Колонка.Имя,
		Колонка.ТипЗначения, "ПараметрыИзмерителя",Колонка.Заголовок);
		МассивРеквизитов.Добавить(НоваяКолонка);
	КонецЦикла;
	
	ИзменитьРеквизиты(МассивРеквизитов); 
	ЗначениеВРеквизитФормы(ТаблицаРезультат, "ПараметрыИзмерителя");	
	
	ЭлементТЗ = Элементы.ПараметрыИзмерителя; 	
	Для Каждого Колонка ИЗ ТаблицаРезультат.Колонки Цикл
		НовыйЭлементФормы = Элементы.Добавить("ПараметрыИзмерителя" + Колонка.Имя,
		Тип("ПолеФормы"), ЭлементТЗ);
		НовыйЭлементФормы.Вид 			= ВидПоляФормы.ПолеВвода;
		НовыйЭлементФормы.ПутьКДанным 	= "ПараметрыИзмерителя." + Колонка.Имя;
		
		СтатКолонка = СтатическиеКолонки.Получить(Колонка.Имя);
		Если не СтатКолонка = Неопределено Тогда
			НовыйЭлементФормы.Видимость = СтатКолонка.ВыводитьВТЧ;
		КонецЕсли;
		
	КонецЦикла;
	
	ЭлементТЗ.УстановитьДействие("ПриНачалеРедактирования", "ПараметрыИзмерителяПриНачалеРедактирования");
		
	Если не ЗаполненПУ или Ошибка Тогда
		ЭлементТЗ.видимость = Ложь;
	КонецЕсли; 
	
	УстановитьУсловноеОформление(ЭлементТЗ);
	
	Если Объект.ПараметрыИзмерителя.Количество() > 0 Тогда
		ЗаполнитьТаблицуДаннымиТЧ();
	КонецЕсли; 	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуДаннымиТЧ()
	ПараметрыИзмерителя.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСуточнаяВедомостьПараметрыИзмерителя.ВидПараметра КАК ВидПараметра,
		|	бестСуточнаяВедомостьПараметрыИзмерителя.IDСтроки КАК IDСтроки,
		|	бестСуточнаяВедомостьПараметрыИзмерителя.BНP КАК BНP,
		|	бестСуточнаяВедомостьПараметрыИзмерителя.BOC КАК BOC,
		|	бестСуточнаяВедомостьПараметрыИзмерителя.Значение КАК Значение,
		|	бестСуточнаяВедомостьПараметрыИзмерителя.ДатаВремя КАК ДатаВремя
		|ПОМЕСТИТЬ ВТ_Данные
		|ИЗ
		|	&ТаблицаДанных КАК бестСуточнаяВедомостьПараметрыИзмерителя
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Данные.ВидПараметра КАК ВидПараметра,
		|	ВТ_Данные.IDСтроки КАК IDСтроки,
		|	ВТ_Данные.Значение КАК Значение,
		|	ВТ_Данные.ДатаВремя КАК ДатаВремя,
		|	ВТ_Данные.BНP КАК BНP,
		|	ВТ_Данные.BOC КАК BOC
		|ИЗ
		|	ВТ_Данные КАК ВТ_Данные
		|ИТОГИ
		|	МАКСИМУМ(ДатаВремя),
		|	МАКСИМУМ(BНP),
		|	МАКСИМУМ(BOC)
		|ПО
		|	IDСтроки";
	
	Запрос.УстановитьПараметр("ТаблицаДанных", Объект.ПараметрыИзмерителя.Выгрузить());
	
	РезультатЗапроса 	= Запрос.Выполнить();
	
	ВыборкаIDСтроки	= РезультатЗапроса.выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	МодульДок		= Документы.бестСуточнаяВедомость;     
	
	Пока ВыборкаIDСтроки.Следующий() Цикл
		НоваяСтрока  = ПараметрыИзмерителя.Добавить();
		
		НоваяСтрока.IDСтроки 	= ВыборкаIDСтроки.IDСтроки;
		НоваяСтрока.ДатаВремя 	= ВыборкаIDСтроки.ДатаВремя;
		НоваяСтрока.BНP 		= ВыборкаIDСтроки.BНP;
		НоваяСтрока.BOC 		= ВыборкаIDСтроки.BOC;
		
		Выборка = ВыборкаIDСтроки.Выбрать();
		Пока Выборка.Следующий() Цикл
			ИмяКолонки 				= МодульДок.СформироватьИмяКолонки(Выборка.ВидПараметра);			
			НоваяСтрока[ИмяКолонки] = Выборка.Значение;
		КонецЦикла;
		
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти

#Область События_Выбора 

&НаКлиенте
Процедура ОбъектРасчетаПриИзменении(Элемент)
	Объект.ПриборУчета = ПредопределенноеЗначение("Справочник.энргПриборыУчетаАбонента.ПустаяСсылка");
	ОчиститьТЧ();
	ЗаполнитьАдрессОбъекта();
КонецПроцедуры


&НаКлиенте
Процедура ПриборУчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка 	= Ложь;
	ПараметрыФормы 			= Новый Структура("Отбор", Новый Структура("Ссылка", бестРаботаСприборамиУчетаСервер.ПолучитьМассивДействующихПриборовУчета(Объект.Дата,Объект.Организация,Объект.Район,Объект.ОбъектРасчета)));
	ОткрытьФорму("Справочник.энргПриборыУчетаАбонента.ФормаВыбора", ПараметрыФормы, Элемент);
	
КонецПроцедуры

#КонецОбласти

#Область События_Обработки 

&НаКлиенте
Процедура ПараметрыИзмерителяПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если Копирование Тогда
		Элемент.ТекущиеДанные.IDСтроки = Строка(Новый УникальныйИдентификатор());
	иначе
		Если не ЗначениеЗаполнено(Элемент.ТекущиеДанные.IDСтроки) Тогда
			Элемент.ТекущиеДанные.IDСтроки = Строка(Новый УникальныйИдентификатор());
		КонецЕсли;   		
	КонецЕсли;
	
КонецПроцедуры


#КонецОбласти

#Область СтандартныеПодсистемы_ПодключаемыеКоманды
 
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат)
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ЗаполнитьАдрессОбъекта();
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ЗаполнитьАдрессОбъекта()
	Если ЗначениеЗаполнено(Объект.ОбъектРасчета) Тогда
		АдресОбъекта = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ОбъектРасчета, "Строение");
	КонецЕсли;
КонецПроцедуры









