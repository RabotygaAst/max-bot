&НаКлиенте
Функция ВернутьОшибки()
	
	МассивОшибок = Новый Массив;
	Если не ЗначениеЗаполнено(Объект.ШаблонНастроекЗагрузки) Тогда
		МассивОшибок.Добавить(Новый Структура("ТекстОшибки,Поле,Объект",НСтр("ru = 'Выберите шаблон настроек загрузки'"),"ШаблонНастроекЗагрузки","Объект"));
	КонецЕсли;
	Если не ЗначениеЗаполнено(Объект.ПриборУчета) Тогда
		МассивОшибок.Добавить(Новый Структура("ТекстОшибки,Поле,Объект",НСтр("ru = 'Выберите прибор учета'"),"ПриборУчета","Объект"));
	КонецЕсли;
	
	Возврат МассивОшибок;
	
КонецФункции

&НаСервере
Функция ПолучитьДанныеШаблона()	
	Возврат Новый Структура("НачальнаяСтрока,КонечнаяСтрока",Объект.ШаблонНастроекЗагрузки.НачальнаяСтрока,Объект.ШаблонНастроекЗагрузки.КонечнаяСтрока);
КонецФункции

