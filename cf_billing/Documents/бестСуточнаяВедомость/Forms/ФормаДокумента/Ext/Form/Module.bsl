
#Область События_Формы 

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			ЗаполнитьПериодНачисленияСервер();
		КонецЕсли;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ПриборУчета) Тогда
		ЗаполнитьКолонкиТаблицыИзРегистра(); 		
	КонецЕсли;
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	бестЛокализацияСервер.ПриСозданииНаСервере_бестСуточнаяВедомость(ЭтотОбъект, Объект.Ссылка);
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	ПередЗаписьюНаСервере(Отказ);
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ)
	ОчиститьТЧ();
	
	ТаблицаДляСохранения 	= ПараметрыИзмерителя.Выгрузить();
	Если ТаблицаДляСохранения.Количество() = 0 Тогда 		
		Возврат;
	КонецЕсли;
	
	Колонки 			= ТаблицаДляСохранения.Колонки;	
	МодульСпр 			= Справочники.бестВидыПараметровИзмерителей;
	МодульДок 			= Документы.бестСуточнаяВедомость;
	ПустаяСсылкаСпр 	= МодульСпр.ПустаяСсылка();
	
	СтатическиеКолонки 	= МодульДок.ПолучитьСтатическиеКолонки();	
	
	Для Каждого Колонка из Колонки Цикл
		Если не СтатическиеКолонки.Получить(Колонка.Имя) = Неопределено Тогда
			Продолжить;
		КонецЕсли;		
		
		ВидПараметра = МодульДок.ПолучитьЭлементСправочникаПоКолонке(Колонка.Имя,ПустаяСсылкаСпр,МодульСпр);
		
		Если ВидПараметра = ПустаяСсылкаСпр Тогда
			Отказ = Истина;
			Прервать;
		КонецЕсли;	
		
		Для Каждого Стр из ТаблицаДляСохранения Цикл
			НоваяСтрока = Объект.ПараметрыИзмерителя.Добавить();
		
			ЗаполнитьЗначенияСвойств(НоваяСтрока,Стр);
			НоваяСтрока.ВидПараметра 	= ВидПараметра;
			НоваяСтрока.Значение 		= Стр[Колонка.Имя];		 			
		КонецЦикла;
		
	КонецЦикла;
	бестЛокализацияСервер.ПослеЗаписиНаСервере_бестСуточнаяВедомость(ЭтотОбъект, Объект.Ссылка);

КонецПроцедуры

Процедура УстановитьУсловноеОформление(ЭлементТЗ)
	
    ЭлементОформления = УсловноеОформление.Элементы.Добавить();
	
    ПолеОформления 					= ЭлементОформления.Поля.Элементы.Добавить();	
    ПолеОформления.Поле 			= Новый ПолеКомпоновкиДанных(ЭлементТЗ.Имя); 
    ПолеОформления.Использование	= Истина;
	
    ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
    ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ПараметрыИзмерителя.ДатаВремя");   
    ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;    
    ЭлементОтбора.ПравоеЗначение = Дата(1,1,1,0,0,0);
    ЭлементОтбора.Использование  = Истина;
	
    ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.БледноЗеленый);
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт("Arial",11,Истина,,,,));

КонецПроцедуры

#КонецОбласти

#Область ЗАГРУЗКА_ИЗ_ФАЙЛА 

#Область EXEL

&НаКлиенте
Процедура ЗагрузитьИзФайла(Команда)
	
	Ошибки = ВернутьОшибки();
	Если Ошибки.Количество() = 0 Тогда
		
		Модифицированность = Истина;
		
		Диалог 					= Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		Диалог.Заголовок 		= "Выберите excel - файл";		
		Диалог.Фильтр 			= "Таблицы (*.xls,*.xlsx)|*.xls;*.xlsx;|Microsoft Excel 97/2000/XP/2003 (*.xls)|*.xls|Microsoft Excel 2007/2010 (*.xlsx)|*.xlsx";
		
		Если Диалог.Выбрать() Тогда
			ПолноеИмяФайла 	= Диалог.ПолноеИмяФайла;
			ДлинаКаталога	= СтрДлина(Диалог.каталог);
			ПолнаяДлина		= СтрДлина(ПолноеИмяФайла);
			СокрИмяФайла	= Прав(ПолноеИмяФайла,ПолнаяДлина - ДлинаКаталога);
			
			Удалось 				= Ложь;
			ДанныеИзФайлаСКлиента 	= ПопробоватьПолучитьДанныеНаКлиенте(ПолноеИмяФайла,Удалось);
			
			Если Удалось Тогда
				ЗагрузитьИзФайлаНаСервере("","",ДанныеИзФайлаСКлиента);
			Иначе 				
				Файл 			= Новый ДвоичныеДанные(ПолноеИмяФайла);
				Адрес 			= ПоместитьВоВременноеХранилище(Файл, ЭтаФорма.УникальныйИдентификатор);
				
				ЗагрузитьИзФайлаНаСервере(Адрес,СокрИмяФайла);	
			КонецЕсли;
		КонецЕсли;		
		
	Иначе
		Для Каждого ТекСтрока из Ошибки Цикл
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекСтрока.ТекстОшибки,,ТекСтрока.Поле,ТекСтрока.Объект);
		КонецЦикла; 		
	КонецЕсли;
	
	ЗаполнитьТаблицуДаннымиТЧ();
КонецПроцедуры

#Если НЕ МобильныйКлиент Тогда

&НаКлиенте
Функция ПопробоватьПолучитьДанныеНаКлиенте(ПутьКФайлу,Удалось)
	Таблица = новый Массив;
	
	// Попытка открытия файла Excel
	Попытка
		Excel = Новый COMОбъект("Excel.Application");
		Excel.WorkBooks.Open(ПутьКФайлу);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='При открытии файла произошла ошибка! Операция прервана!'"));
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр(ОписаниеОшибки()));
		Возврат Таблица;
	КонецПопытки;
	
	// Попытка выбрать первый лист
	Попытка 
		Excel.Sheets(1).Select();    
	Исключение
		// Закрытие файла в том случае, если первый лист не найден
		Excel.ActiveWorkbook.Close(); 	
		Excel = 0;
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Первый лист не найден!'"));
		Возврат Таблица;
	КонецПопытки;
	
	// Получим количество строк и колонок.
	// В разных версиях Excel получаются по-разному, поэтому сначала определим версию Excel
	Версия = Лев(Excel.Version,Найти(Excel.Version,".")-1);
	Если Версия = "8" тогда
		ФайлСтрок 	= Excel.Cells.CurrentRegion.Rows.Count;
		ФайлКолонок = Макс(Excel.Cells.CurrentRegion.Columns.Count, 13);
	Иначе
		ФайлСтрок 	= Excel.Cells(1,1).SpecialCells(11).Row;
		ФайлКолонок = Excel.Cells(1,1).SpecialCells(11).Column;
	Конецесли;
	
	//Сч = 1;	
	//Соответствие = Новый Соответствие;
	//Пока ЗначениеЗаполнено(Excel.Cells(1, Сч).Text) Цикл
	//	//ИмяКолонки 		= Excel.Cells(1, Сч).Text;
	//	//ИмяБезПробелов 	= СтрЗаменить(ИмяКолонки," ","");
	//	Соответствие.Вставить(Сч,"Колонка" + Сч);		
	//	Сч = Сч + 1;
	//КонецЦикла;
	
	ДанныеШаблона 	= ПолучитьДанныеШаблона();
	НачальнаяСтрока = ?(ДанныеШаблона.НачальнаяСтрока > 0 ,ДанныеШаблона.НачальнаяСтрока,2); 
	ФайлСтрок 		= ?(ДанныеШаблона.КонечнаяСтрока > 0  ,ДанныеШаблона.КонечнаяСтрока ,ФайлСтрок);
	
	Для НС = НачальнаяСтрока по ФайлСтрок Цикл 	
		
		СтруктураДанных = Новый Структура;
		
		Сч = 1;	
		Пока Сч <= ФайлКолонок Цикл
			// заполняем строку значениями
			ТекущееЗначение 		= Excel.Cells(НС, Сч).Text;
			СтруктураДанных.Вставить("Колонка" + Сч,ТекущееЗначение); 
			Сч = Сч + 1;
		КонецЦикла;
		
		//Для Каждого Колонка Из Соответствие Цикл
		//	// заполняем строку значениями
		//	ТекущееЗначение 		= Excel.Cells(НС, Колонка.Ключ).Text;
		//	СтруктураДанных.Вставить(Колонка.Значение,ТекущееЗначение); 			
		//КонецЦикла;
		
		Таблица.Добавить(СтруктураДанных);

	КонецЦикла;
	
	Excel.DisplayAlerts = 0; 
	Excel.Quit();
	Excel.DisplayAlerts = 1;
	
	Удалось = Истина;
	
	Возврат Таблица;
КонецФункции

#КонецЕсли

&НаСервере
Процедура ЗагрузитьИзФайлаНаСервере(ФайлВХранилище, СокрИмяФайла, ДанныеИзФайлаСКлиента = Неопределено)
	Объект.ПараметрыИзмерителя.Очистить();
	
	Если ДанныеИзФайлаСКлиента = Неопределено Тогда
		ДвоичныеДанные 	= ПолучитьИзВременногоХранилища(ФайлВХранилище);	
		ПутьКФайлу 		= КаталогВременныхФайлов() + СокрИмяФайла;
		ДвоичныеДанные.Записать(ПутьКФайлу);	
		
		Документы.бестСуточнаяВедомость.ЗагрузитьДанныеИзФайла(ПутьКФайлу, Объект.ШаблонНастроекЗагрузки, Объект.ПараметрыИзмерителя);
	Иначе
		Документы.бестСуточнаяВедомость.ЗаполнитьДанныеИзФайлаВТЧ(ДанныеИзФайлаСКлиента, Объект.ШаблонНастроекЗагрузки, Объект.ПараметрыИзмерителя);
	КонецЕсли;
	
КонецПроцедуры  

&НаСервере
Процедура ЗаполнитьПериодНачисленияСервер()
	Объект.ПериодНачисления = Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);	
КонецПроцедуры

#КонецОбласти

#Область TXT

&НаКлиенте
Процедура ФорматTXT(Команда)
	Модифицированность = Истина;
	
	Диалог 					= Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок 		= "Выберите TXT - файл";		
	Диалог.Фильтр 			= "Текстовый файл (*.txt)|*.txt|";
	
	Если Диалог.Выбрать() Тогда
		ПолноеИмяФайла 	= Диалог.ПолноеИмяФайла;
		ДлинаКаталога	= СтрДлина(Диалог.каталог);
		ПолнаяДлина		= СтрДлина(ПолноеИмяФайла);
		СокрИмяФайла	= Прав(ПолноеИмяФайла,ПолнаяДлина - ДлинаКаталога);
		
		
		Файл 			= Новый ДвоичныеДанные(ПолноеИмяФайла);
		Адрес 			= ПоместитьВоВременноеХранилище(Файл, ЭтаФорма.УникальныйИдентификатор);
		
		ФорматTXTНаСервере(Адрес,СокрИмяФайла);
		
		Если Объект.ПараметрыИзмерителя.Количество() > 0 Тогда
			ЗаполнитьТаблицуДаннымиТЧ();
		КонецЕсли;
		
	КонецЕсли; 	
	
КонецПроцедуры  

&НаСервере
Процедура ФорматTXTНаСервере(ФайлВХранилище, СокрИмяФайла)
	Объект.ПараметрыИзмерителя.Очистить();
	
	ДвоичныеДанные 	= ПолучитьИзВременногоХранилища(ФайлВХранилище);	
	ПутьКФайлу 		= КаталогВременныхФайлов() + СокрИмяФайла;
	ДвоичныеДанные.Записать(ПутьКФайлу);	
	
	Документы.бестСуточнаяВедомость.ЗагрузитьДанныеИзФайлаTXT(ПутьКФайлу, Объект.ШаблонНастроекЗагрузки, Объект.ПараметрыИзмерителя);
КонецПроцедуры
	
#КонецОбласти

