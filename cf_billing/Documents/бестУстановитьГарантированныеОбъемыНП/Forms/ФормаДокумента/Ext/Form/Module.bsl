КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьУслугиОбъектаСервер()
	
	Результат 								= бестРаботаСОбъектамиНПСервер.ДействующиеУслугиПоОбъектуСДоговорнымиОбъемами(?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия), КонецДня(Объект.ДатаФактическогоСобытия), КонецДня(Объект.Дата)),Объект.Организация,Объект.Район, Объект.ОбъектРасчета); 
	Выборка  								= Результат.Выбрать();
	
	объект.ГарантированныеОбъемы.Очистить();
	ТекУслуга = Неопределено;
	Пока Выборка.следующий() Цикл 
		Если ТекУслуга <> Выборка.Услуга Тогда
			СтрокаПриборов  					= Объект.ГарантированныеОбъемы.Добавить();
		КонецЕсли;
		Если Выборка.Месяц = 1 Тогда
			СтрокаПриборов.ЯнварьДо = Выборка.ОбъемУслуги;
			СтрокаПриборов.Услуга 		        = Выборка.Услуга;	
		ИначеЕсли Выборка.Месяц = 2 Тогда
			СтрокаПриборов.ФевральДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 3 Тогда
			СтрокаПриборов.МартДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 4 Тогда
			СтрокаПриборов.АпрельДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 5 Тогда
			СтрокаПриборов.МайДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 6 Тогда
			СтрокаПриборов.ИюньДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 7 Тогда
			СтрокаПриборов.ИюльДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 8 Тогда
			СтрокаПриборов.АвгустДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 9 Тогда
			СтрокаПриборов.СентябрьДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 10 Тогда
			СтрокаПриборов.ОктябрьДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 11 Тогда
			СтрокаПриборов.НоябрьДо = Выборка.ОбъемУслуги;
		ИначеЕсли Выборка.Месяц = 12 Тогда
			СтрокаПриборов.ДекабрьДо = Выборка.ОбъемУслуги;
		КонецЕсли;
		ТекУслуга = Выборка.Услуга;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаполнениеДанных(Отказ)
	
	Если Объект.Организация <> Объект.Район.Организация Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Проверьте данные организации и района");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ГарантированныеОбъемыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАдрессОбъекта()
	Если ЗначениеЗаполнено(Объект.ОбъектРасчета) Тогда
		МКД = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ОбъектРасчета, "МКД");
		Если ЗначениеЗаполнено(МКД) Тогда
			АдресОбъекта = МКД;
		Иначе
			АдресОбъекта = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ОбъектРасчета, "Строение");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

