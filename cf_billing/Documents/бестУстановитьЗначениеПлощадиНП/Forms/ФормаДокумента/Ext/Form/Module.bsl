&НаСервере
Процедура ОбъектРасчетаПриИзмененииНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	бестЗначенияПлощадейНПСрезПоследних.ВидПлощади КАК ВидПлощади,
	               |	бестЗначенияПлощадейНПСрезПоследних.Площадь КАК ПлощадьБыло
	               |ИЗ
	               |	РегистрСведений.бестЗначенияПлощадейНП.СрезПоследних(
	               |			&ГраницаДокумента,
	               |			Организация = &Организация
	               |				И Район = &Район
	               |				И ОбъектРасчета = &ОбъектРасчета) КАК бестЗначенияПлощадейНПСрезПоследних";
	ДатаДокумента = ?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия), Объект.ДатаФактическогоСобытия, Объект.Дата);
	ГраницаДокумента = Новый Граница(ДатаДокумента, ВидГраницы.Исключая);
	Запрос.УстановитьПараметр("ГраницаДокумента", ГраницаДокумента);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Район", Объект.Район);
	Запрос.УстановитьПараметр("ОбъектРасчета", Объект.ОбъектРасчета);
	ТЗПлощади = Запрос.Выполнить().Выгрузить();
	Объект.Площади.Загрузить(ТЗПлощади);
	
КонецПроцедуры 

&НаКлиенте
Процедура ЗаполнитьАдресОбъекта()
	Если ЗначениеЗаполнено(Объект.ОбъектРасчета) Тогда
		АдресОбъекта = бестРаботаСОбъектамиНПВызовСервера.ВернутьАдресОбъектаРасчета(Объект.ОбъектРасчета);
	КонецЕсли;
КонецПроцедуры

