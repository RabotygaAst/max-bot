		СписокУслуг.Добавить(Стр);
	КонецЦикла;
	// Макшанцев Был поправлен запрос в общем модуле. Резальтут приходит уже с простымии услугами
	//////Запрос = Новый Запрос;
	//////Запрос.Текст = 
	//////"ВЫБРАТЬ
	//////|	энргВидыУслугСоставляющиеУслуг.Услуга КАК Услуга
	//////|ИЗ
	//////|	Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	//////|ГДЕ
	//////|	энргВидыУслугСоставляющиеУслуг.Ссылка В(&СписокУслуг)";
	//////
	//////Запрос.УстановитьПараметр("СписокУслуг", СписокУслуг);
	//////
	//////РезультатЗапроса = Запрос.Выполнить();
	//////
	//////ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	//////
	//////Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	//////	СписокУслуг.Добавить(ВыборкаДетальныеЗаписи.Услуга);
	//////КонецЦикла;
	//Макшанцев
	
	Возврат СписокУслуг;
	
КонецФункции

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	Объект.Организация = ПолучитьЗначениеРеквизита(Объект.Район, "Организация");
КонецПроцедуры

&НаСервере
Функция ПолучитьЗначениеРеквизита(ТекОбъект, ИмяРеквизита)
	Возврат ТекОбъект[ИмяРеквизита];	
КонецФункции


&НаКлиенте
Процедура НагрузкаУслугаПриИзменении(Элемент)
	ТекДанные = Элементы.Нагрузка.ТекущиеДанные;
	НагрузкаУслугаПриИзмененииКлиент(ТекДанные);
КонецПроцедуры

&НаКлиенте
Процедура НагрузкаУслугаПриИзмененииКлиент(ТекДанные)
	Услуга = ТекДанные.Услуга;
	НомерСтроки = ТекДанные.НомерСтроки;	
	НагрузкаУслугаПриИзмененииНаСервере(Услуга, НомерСтроки);
КонецПроцедуры

&НаСервере
Процедура НагрузкаУслугаПриИзмененииНаСервере(Услуга, НомерСтроки)
		
	ЗаполняемаяТаблица = Объект.Нагрузки;
	МассивСтрок = ЗаполняемаяТаблица.НайтиСтроки(новый Структура("Услуга",Услуга));
	


	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("услуга", Услуга);
	Запрос.УстановитьПараметр("Период",					Объект.Дата);
	Запрос.УстановитьПараметр("Организация",			Объект.Организация);
	Запрос.УстановитьПараметр("Район",					Объект.Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",			Объект.ОбъектРасчета);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	               |	бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	               |ПОМЕСТИТЬ АктивныеТочкиУчетаОбъекта
	               |ИЗ
	               |	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
	               |			&Период,
	               |			Организация = &Организация
	               |				И Район = &Район
	               |				И ОбъектРасчета = &ОбъектРасчета) КАК бестАктивностьТочекУчетаНПСрезПоследних
	               |ГДЕ
	               |	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	               |	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга,
	               |	бестУслугиТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	               |ПОМЕСТИТЬ АктивныеТочкиУслуги
	               |ИЗ
	               |	АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестУслугиТочекУчетаНП.СрезПоследних(
	               |				&Период,
	               |				Организация = &Организация
	               |					И Район = &Район
	               |					И ОбъектРасчета = &ОбъектРасчета
	               |					И ТочкаУчета В
	               |						(ВЫБРАТЬ
	               |							АктивныеТочкиУчетаОбъекта.ТочкаУчета
	               |						ИЗ
	               |							АктивныеТочкиУчетаОбъекта)) КАК бестУслугиТочекУчетаНПСрезПоследних
	               |		ПО АктивныеТочкиУчетаОбъекта.ОбъектРасчета = бестУслугиТочекУчетаНПСрезПоследних.ОбъектРасчета
	               |			И АктивныеТочкиУчетаОбъекта.ТочкаУчета = бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	АктивныеТочкиУслуги.ОбъектРасчета КАК ОбъектРасчета,
	               |	АктивныеТочкиУслуги.ТочкаУчета КАК ТочкаУчета,
	               |	ВЫБОР
	               |		КОГДА АктивныеТочкиУслуги.Услуга.СоставнаяУслуга
	               |			ТОГДА энргВидыУслугСоставляющиеУслуг.Услуга
	               |		ИНАЧЕ АктивныеТочкиУслуги.Услуга
	               |	КОНЕЦ КАК Услуга
	               |ПОМЕСТИТЬ ВТ_ТочкиИУслуги
	               |ИЗ
	               |	АктивныеТочкиУслуги КАК АктивныеТочкиУслуги
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	               |		ПО АктивныеТочкиУслуги.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	бестНагрузкаПоУслугамНПСрезПоследних.ВидНагрузки КАК ВидНагрузкиДо,
	               |	бестНагрузкаПоУслугамНПСрезПоследних.Нагрузка КАК НагрузкаДо,
	               |	ВТ_ТочкиИУслуги.Услуга КАК Услуга,
	               |	ВТ_ТочкиИУслуги.ОбъектРасчета КАК ОбъектРасчета
	               |ИЗ
	               |	ВТ_ТочкиИУслуги КАК ВТ_ТочкиИУслуги
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестНагрузкаПоУслугамНП.СрезПоследних(
	               |				&Период,
	               |				Организация = &Организация
	               |					И Район = &Район
	               |					И ОбъектРасчета = &ОбъектРасчета) КАК бестНагрузкаПоУслугамНПСрезПоследних
	               |		ПО ВТ_ТочкиИУслуги.Услуга = бестНагрузкаПоУслугамНПСрезПоследних.Услуга
	               |ГДЕ
	               |	ВТ_ТочкиИУслуги.Услуга = &Услуга
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ_ТочкиИУслуги.Услуга,
	               |	бестНагрузкаПоУслугамНПСрезПоследних.ВидНагрузки,
	               |	бестНагрузкаПоУслугамНПСрезПоследних.Нагрузка,
	               |	ВТ_ТочкиИУслуги.ОбъектРасчета";
	Результат  = Запрос.Выполнить();
	
	Если не Результат.Пустой() Тогда
		Для Каждого ТекСтр из МассивСтрок  Цикл
			ЗаполняемаяТаблица.Удалить(ТекСтр);
		КонецЦикла;
		
	Выборка = Результат.Выбрать();
	
	Пока  Выборка.Следующий() Цикл 
		Новаястрока =  ЗаполняемаяТаблица.Добавить();
		ЗаполнитьЗначенияСвойств(Новаястрока, Выборка);	
	КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НагрузкаВидНагрузкиПриИзменении(Элемент)
	ТекДанные = Элементы.Нагрузка.ТекущиеДанные;
	
	Если ТекДанные.ВидНагрузки = ТекДанные.ВидНагрузкиДО Тогда 
		ТекДанные.ВидНагрузки = Неопределено;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Вид нагрузки не изменился");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НагрузкаНагрузкаПриИзменении(Элемент)
	ТекДанные = Элементы.Нагрузка.ТекущиеДанные;
	
	Если ТекДанные.нагрузка = ТекДанные.нагрузкаДО Тогда 
		 ТекДанные.нагрузка = Неопределено;
		 ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нагрузка не изменилась");
	 КонецЕсли;
	 
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАдрессОбъекта()
	Если ЗначениеЗаполнено(Объект.ОбъектРасчета) Тогда
		АдресОбъекта = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ОбъектРасчета, "Строение");
	КонецЕсли;
КонецПроцедуры


&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	бестЛокализацияСервер.ПослеЗаписиНаСервере_бестУстановитьНагрузкуПоУслугам(ЭтотОбъект, Объект.Ссылка);
КонецПроцедуры

