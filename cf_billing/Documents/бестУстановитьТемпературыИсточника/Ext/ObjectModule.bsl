#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;

	ТекДата	= ТекущаяДата();	
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	Если ДополнительныеСвойства.свойство("ВосстановлениеПоследовательности") тогда
		Возврат;
	КонецЕсли;	
	
	Ответственный = Пользователи.ТекущийПользователь();
		
	бестПроведениеСерверНП.ПередЗаписьюОбъекта(ЭтотОбъект);

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	бестПроведениеСерверНП.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	//ДанныеШапки = ДанныеШапки();
	//
	//Если ЗначениеЗаполнено(Источник) Тогда
	//	бестПроведениеСерверНП.ВыполнитьДвижение(ДанныеШапки, Движения.бестТемператураИсточника);
	//КонецЕсли;
	
	ПроверкаДублированияВТЧ(Отказ);
	ПроверитьНаличиеСуществующихЗаписей(Отказ);
	ТаблицаПроведения = ПолучитьТаблицуПроведения();
	
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ТаблицаПроведения, Движения.бестТемператураИсточника, Неопределено);
	
КонецПроцедуры

Функция ПолучитьТаблицуПроведения()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("Период",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия), ДатаФактическогоСобытия, Дата));
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	Запрос.УстановитьПараметр("ПериодРегистрации", 	Дата);
	Запрос.Текст = "ВЫБРАТЬ
	|	&Период КАК Период,
	|	&Организация КАК Организация,
	|	&Ссылка КАК Регистратор,
	|	&Район КАК Район,
	|	бестУстановитьТемпературыИсточникаИсточники.Источник КАК Источник,
	|	бестУстановитьТемпературыИсточникаИсточники.ТемператураПодачиИсточника КАК ТемператураПодачиИсточника,
	|	бестУстановитьТемпературыИсточникаИсточники.ТемператураХолоднойВодыИсточника КАК ТемператураХолоднойВодыИсточника,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	&ПериодРегистрации КАК ПериодРегистрации
	|ИЗ
	|	Документ.бестУстановитьТемпературыИсточника.Источники КАК бестУстановитьТемпературыИсточникаИсточники
	|ГДЕ
	|	бестУстановитьТемпературыИсточникаИсточники.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	бестУстановитьТемпературыИсточникаИсточники.Источник,
	|	бестУстановитьТемпературыИсточникаИсточники.ТемператураПодачиИсточника,
	|	бестУстановитьТемпературыИсточникаИсточники.ТемператураХолоднойВодыИсточника";
	Результат = ЗАпрос.Выполнить();
	
	Возврат Результат;
КонецФункции

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
			
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПроверкаДублированияВТЧ(Отказ) 
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст = "ВЫБРАТЬ
	|	бестУстановитьТемпературыИсточникаИсточники.Источник КАК Источник,
	|	бестУстановитьТемпературыИсточникаИсточники.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	Документ.бестУстановитьТемпературыИсточника.Источники КАК бестУстановитьТемпературыИсточникаИсточники
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестУстановитьТемпературыИсточника.Источники КАК бестУстановитьТемпературыИсточникаИсточники1
	|		ПО (бестУстановитьТемпературыИсточникаИсточники.Ссылка = &Ссылка)
	|			И бестУстановитьТемпературыИсточникаИсточники.Источник = бестУстановитьТемпературыИсточникаИсточники1.Источник
	|			И бестУстановитьТемпературыИсточникаИсточники.НомерСтроки <> бестУстановитьТемпературыИсточникаИсточники1.НомерСтроки
	|			И (бестУстановитьТемпературыИсточникаИсточники1.Ссылка = &Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	бестУстановитьТемпературыИсточникаИсточники.Источник,
	|	бестУстановитьТемпературыИсточникаИсточники.НомерСтроки
	|
	|УПОРЯДОЧИТЬ ПО
	|	Источник
	|ИТОГИ ПО
	|	Источник";
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока Выборка.Следующий() Цикл
		ТекстСбщ = "";
		Если ЗначениеЗаполнено(Выборка.Источник) Тогда
			ТекстСбщ	= "По источнику " + Выборка.Источник + " обнаружены дубли в строках: ";
			ВыборкаДетали = Выборка.Выбрать();
			Пока ВыборкаДетали.Следующий() Цикл
				ТекстСбщ	= ТекстСбщ + ВыборкаДетали.НомерСтроки + ";"	
			КонецЦикла;				
		КонецЕсли;
		Если НЕ ТекстСбщ = "" Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСбщ);
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры

// доработать 
Процедура ПроверитьНаличиеСуществующихЗаписей(Отказ)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", 				?(ЗначениеЗаполнено(Дата), КонецДня(Дата),энргДатаПоследнегоИзменения));
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);

	Запрос.Текст = "ВЫБРАТЬ
	               |	бестУстановитьТемпературыИсточникаИсточники.Источник КАК Источник,
	               |	бестУстановитьТемпературыИсточникаИсточники.ТемператураПодачиИсточника КАК ТемператураПодачиИсточника,
	               |	бестУстановитьТемпературыИсточникаИсточники.ТемператураХолоднойВодыИсточника КАК ТемператураХолоднойВодыИсточника
	               |ПОМЕСТИТЬ ВТ_Услуги
	               |ИЗ
	               |	Документ.бестУстановитьТемпературыИсточника.Источники КАК бестУстановитьТемпературыИсточникаИсточники
	               |ГДЕ
	               |	бестУстановитьТемпературыИсточникаИсточники.Ссылка = &Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	бестТемператураИсточника.Регистратор КАК Регистратор
	               |ИЗ
	               |	РегистрСведений.бестТемператураИсточника КАК бестТемператураИсточника
	               |ГДЕ
	               |	бестТемператураИсточника.Период <= &Дата
	               |	И бестТемператураИсточника.Организация = &Организация
	               |	И бестТемператураИсточника.Район = &Район
	               |	И бестТемператураИсточника.Источник В
	               |			(ВЫБРАТЬ
	               |				ВТ_Услуги.Источник
	               |			ИЗ
	               |				ВТ_Услуги)
	               |	И бестТемператураИсточника.ТемператураПодачиИсточника В
	               |			(ВЫБРАТЬ
	               |				ВТ_Услуги.ТемператураПодачиИсточника
	               |			ИЗ
	               |				ВТ_Услуги)
	               |	И бестТемператураИсточника.ТемператураХолоднойВодыИсточника В
	               |			(ВЫБРАТЬ
	               |				ВТ_Услуги.ТемператураХолоднойВодыИсточника
	               |			ИЗ
	               |				ВТ_Услуги)";
	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Данные по источнику уже введены! Документ " + Выборка.Регистратор);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

