Функция РазбитьПериоды()
	
	МесяцНач = Месяц(НачалоПотребления);
	МесяцКон = Месяц(ОкончаниеПотребления);
	ГодНач	= Год(НачалоПотребления);
	ГодКон	= Год(ОкончаниеПотребления);
	
	МассивПериодов = Новый Массив;
	
	Для СчГод = ГодНач По ГодКон Цикл
		Для СчМесяц = МесяцНач По МесяцКон Цикл
			ТекДата = Дата(СчГод,СчМесяц,1);
			НовПериод = Новый Структура("НачалоПериода,КонецПериода",НачалоМесяца(ТекДата),КонецМесяца(ТекДата));
			Если СчГод	= Год(НачалоПотребления) И СчМесяц = Месяц(НачалоПотребления) Тогда
				НовПериод.НачалоПериода = НачалоПотребления;	
			КонецЕсли; 
			Если СчГод	= Год(ОкончаниеПотребления) И СчМесяц = Месяц(ОкончаниеПотребления) Тогда
				НовПериод.КонецПериода = КонецДня(ОкончаниеПотребления);	
			КонецЕсли;
			МассивПериодов.Добавить(НовПериод);
		КонецЦикла; 
	КонецЦикла;
	
	Возврат МассивПериодов;
		
КонецФункции

