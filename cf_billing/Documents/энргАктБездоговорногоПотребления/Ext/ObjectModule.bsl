#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	//ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	Если ДополнительныеСвойства.свойство("ВосстановлениеПоследовательности") тогда
		Возврат;
	КонецЕсли;	
	
	Ответственный 		= Пользователи.ТекущийПользователь();	
	
	ГраницыПериода  		= Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления);
	НачалоПериодаРасчета	= ГраницыПериода.НачалоОП;
	ДополнительныеСвойства.Вставить("НачалоПериодаРасчета",	НачалоПериодаРасчета);
	ДополнительныеСвойства.Вставить("ДанныеОплаты",			ДанныеОплаты(НачалоПериодаРасчета));
	ДополнительныеСвойства.Вставить("Кассир",				Справочники.Пользователи.ПустаяСсылка());
	ДополнительныеСвойства.Вставить("ИсточникПоступления",	Справочники.энргИсточникиПоступления.ПустаяСсылка());
	ДополнительныеСвойства.Вставить("ЭтоОплата",	Ложь);	

	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);  	
	
	ДанныеШапки = ДанныеШапки();
	
	энргРаботаСТочкамиУчетаСервер.УстановитьБездоговорноеПотребление(ДанныеШапки,Движения,"Услуги");
	энргРаботаСПараметрамиРасчетаАбонентаСервер.ЗаполнитьВидБлагоустроства(ДанныеШапки, Движения);
	энргРаботаСПараметрамиРасчетаАбонентаСервер.УстановитьГруппуПотребителей(Движения, ДанныеШапки);

	Движения.энргОбъемНачислений.Записывать = Ложь;
	Движения.Записать();
	
	РассчитатьОбъемНачислений(ДанныеШапки);
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
			
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДанныеШапки()
		
	ДанныеШапки = Новый Структура;
	ДанныеШапки.Вставить("Дата",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия),КонецДня(ДатаФактическогоСобытия),Дата));
	ДанныеШапки.Вставить("Период",				?(ЗначениеЗаполнено(ДатаФактическогоСобытия),КонецДня(ДатаФактическогоСобытия),Дата));
	ДанныеШапки.Вставить("Район",				Район);
	ДанныеШапки.Вставить("Организация",			Организация); 
	ДанныеШапки.Вставить("КлючПомещения",		КлючПомещения);
	ДанныеШапки.Вставить("ПериодРегистрации",	Дата);
	ДанныеШапки.Вставить("ПериодНачисления",	ПериодНачисления);  
	ДанныеШапки.Вставить("Абонент",				Абонент);                   	
	ДанныеШапки.Вставить("Услуги",				Услуги);
	ДанныеШапки.Вставить("ИмяДокумента",		"энргАктБездоговорногоПотребления");
	ДанныеШапки.Вставить("Документ",			Ссылка);
	ДанныеШапки.Вставить("КоличествоДней",		(ОкончаниеПотребления - НачалоПотребления)/(24*3600) + 1);
	ДанныеШапки.Вставить("ВидыБлагоустройстваТарифныеКатегории", Услуги);
	
	Возврат ДанныеШапки;	

КонецФункции

Процедура РассчитатьОбъемНачислений(ДанныеШапки)
	
	ГраницыПериода  											= Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ПериодНачисления,Ложь);
	
	НачалоПериодаРасчета										= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  										= ГраницыПериода.ЗавершениеОП;
	ДнейВПериоде  												= ГраницыПериода.ДнейВПериоде; 
	ПериодНовогоТарифа 											= энргОбщегоНазначения.ЗначениеКонстанты("энргДеньНачалаПримененияНовогоТарифа");
	КонецПериода  												= КонецМесяца(ПериодНачисления);

	МВТ = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	
	Запрос.УстановитьПараметр("КонецПериодаРасчета", КонецПериодаРасчета);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", ПериодНачисления);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("АктПотребления", Ссылка);  
	Запрос.УстановитьПараметр("КлючПомещения", КлючПомещения);
	Запрос.УстановитьПараметр("ГодПостройки", КлючПомещения.Строение.ГодПостройки);
	Запрос.УстановитьПараметр("КоличествоЭтажей", КлючПомещения.Строение.КоличествоЭтажей);
	Запрос.УстановитьПараметр("МоментВремени", МоментВремени());
	Запрос.УстановитьПараметр("ТипНачисления", Перечисления.энргТипыНачислений.ИндивидуальныеНачисления);
	
	Запрос.УстановитьПараметр("ПериодРасчета", ПериодНачисления); 
	Запрос.УстановитьПараметр("Помещение", КлючПомещения.Помещение);
	Запрос.УстановитьПараметр("Строение", КлючПомещения.Строение); 
	
	Запрос.Текст = ТекстЗапросаНачисленияБездоговорногоПодключения();
	Запрос.Выполнить();
	
	Набор = Движения.энргОбъемНачислений;
	
	Запрос.Текст = ТекстЗапросаДанныеДляНачисления();
	
	МассивПериодов = РазбитьПериоды();
	Для Каждого ТекПериод Из МассивПериодов Цикл
		РассчитатьОбъемНачисленийПериод(ДанныеШапки,ТекПериод,Набор,Запрос,КонецПериодаРасчета);	
	КонецЦикла;
	
	Набор.Записать();
	
КонецПроцедуры

Процедура РассчитатьОбъемНачисленийПериод(ДанныеШапки,ТекПериод,Набор,Запрос,КонецПериодаРасчетаОбщий)
	
	// КонецПериодаРасчета
	// ПериодРасчета
	// НачалоПериода,КонецПериода  НачалоПодключения, &КонецПодключения

	ГраницыПериода  											= Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(Организация,Район,ТекПериод.КонецПериода,Ложь);
	
	НачалоПериодаРасчета										= ГраницыПериода.НачалоОП;
	КонецПериодаРасчета  										= ГраницыПериода.ЗавершениеОП;
	ДнейВПериоде  												= ГраницыПериода.ДнейВПериоде;
	
	Запрос.УстановитьПараметр("КонецПериодаРасчета", КонецПериодаРасчета);
	Запрос.УстановитьПараметр("ПериодНачисления", Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ТекПериод.КонецПериода, Организация, Район));
	Запрос.УстановитьПараметр("НачалоПодключения", ТекПериод.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПодключения", ТекПериод.КонецПериода);
	
	ПИ = 3.141592653589793238462643;
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
 
	Пока Выборка.Следующий() Цикл
		
		СтрокаНабора = Набор.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНабора,Выборка);
		
		//СтрокаНабора.Период				= КонецПериодаРасчетаОбщий - 1;
		СтрокаНабора.Период				= Дата;
		СтрокаНабора.ВидНачисления		= Перечисления.энргВидыНачислений.Перерасчет;
		СтрокаНабора.СпособНачисления 	= Перечисления.энргСпособНачислений.БездоговорноеПотребление;
		
		Если Не ЗначениеЗаполнено(Выборка.ДиаметрСечения) И Не ЗначениеЗаполнено(Выборка.МощностьПодключаемогоОборудования) Тогда
			СтрокаНабора.ОбъемУслуги	= Выборка.НормаПотребления * Выборка.КоличествоПрописанных * 10 * (Выборка.КоличествоДней/ДнейВПериоде);
		ИначеЕсли ЗначениеЗаполнено(Выборка.ДиаметрСечения) Тогда
			СтрокаНабора.ОбъемУслуги	= Выборка.СкоростьДвижения * ((ПИ * Pow(Выборка.ДиаметрСечения, 2))/4) * 0.0036 * Выборка.КоличествоДней * 24;
		ИначеЕсли  ЗначениеЗаполнено(Выборка.МощностьПодключаемогоОборудования) Тогда
			СтрокаНабора.ОбъемУслуги	= Выборка.КоличествоДней * Выборка.МощностьПодключаемогоОборудования;
		КонецЕсли; 
		
		СтрокаНабора.ОбъемУслугиПотребленный = СтрокаНабора.ОбъемУслуги;
		СтрокаНабора.Сумма = СтрокаНабора.ОбъемУслуги * Выборка.ЗначениеТарифа;
		
	КонецЦикла;
	
КонецПроцедуры
 
Функция ТекстЗапросаНачисленияБездоговорногоПодключения()
	
	Текст  =  
		"ВЫБРАТЬ
		|	энргВидБлагоустройствАбонентаСрезПоследних.ВидБлагоустройства КАК ВидБлагоустройства,
		|	энргВидБлагоустройствАбонентаСрезПоследних.Услуга КАК Услуга,
		|	энргВидБлагоустройствАбонентаСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргВидБлагоустройствАбонентаСрезПоследних.Район КАК Район,
		|	энргВидБлагоустройствАбонентаСрезПоследних.Организация КАК Организация
		|ПОМЕСТИТЬ ВидБлагоустройствАбонента
		|ИЗ
		|	РегистрСведений.энргВидБлагоустройствАбонента.СрезПоследних(
		|			&КонецПериодаРасчета,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргВидБлагоустройствАбонентаСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргГруппыПотребителейАбонентовСрезПоследних.Организация КАК Организация,
		|	энргГруппыПотребителейАбонентовСрезПоследних.Район КАК Район,
		|	энргГруппыПотребителейАбонентовСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргГруппыПотребителейАбонентовСрезПоследних.Услуга КАК Услуга,
		|	энргГруппыПотребителейАбонентовСрезПоследних.ГруппаПотребителей КАК ГруппаПотребителей
		|ПОМЕСТИТЬ ТарифныеКатегории
		|ИЗ
		|	РегистрСведений.энргГруппыПотребителейАбонентов.СрезПоследних КАК энргГруппыПотребителейАбонентовСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргБездоговорноеПотребление.Организация КАК Организация,
		|	энргБездоговорноеПотребление.Район КАК Район,
		|	энргБездоговорноеПотребление.КлючПомещения КАК КлючПомещения,
		|	энргБездоговорноеПотребление.Услуга КАК Услуга,
		|	энргБездоговорноеПотребление.ПериодНачисления КАК ПериодНачисления,
		|	энргБездоговорноеПотребление.КоличествоДней КАК КоличествоДней,
		|	энргБездоговорноеПотребление.ДиаметрСечения КАК ДиаметрСечения,
		|	энргБездоговорноеПотребление.МощностьПодключаемогоОборудования КАК МощностьПодключаемогоОборудования,
		|	энргБездоговорноеПотребление.Абонент КАК Абонент,
		|	ЕСТЬNULL(энргНормаСкоростиДвиженияВодыСрезПоследних.СкоростьДвижения, 0) КАК СкоростьДвижения,
		|	энргБездоговорноеПотребление.КлючПомещения.Строение КАК Строение,
		|	энргБездоговорноеПотребление.КлючПомещения.Помещение КАК Помещение,
		|	энргБездоговорноеПотребление.КлючПомещения.ЧастныйСектор КАК ЧастныйСектор
		|ПОМЕСТИТЬ БездоговорноеПотребление
		|ИЗ
		|	РегистрСведений.энргБездоговорноеПотребление КАК энргБездоговорноеПотребление
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргНормаСкоростиДвиженияВоды.СрезПоследних(&КонецПериодаРасчета, ) КАК энргНормаСкоростиДвиженияВодыСрезПоследних
		|		ПО (ИСТИНА)
		|ГДЕ
		|	энргБездоговорноеПотребление.Регистратор = &АктПотребления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргКоличествоПроживающихСрезПоследних.Организация КАК Организация,
		|	энргКоличествоПроживающихСрезПоследних.Район КАК Район,
		|	энргКоличествоПроживающихСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргКоличествоПроживающихСрезПоследних.Количество КАК Количество
		|ПОМЕСТИТЬ КоличествоПроживающих
		|ИЗ
		|	РегистрСведений.энргКоличествоПроживающих.СрезПоследних(
		|			&КонецПериодаРасчета,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргКоличествоПроживающихСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргКоличествоСобственниковСрезПоследних.Организация КАК Организация,
		|	энргКоличествоСобственниковСрезПоследних.Район КАК Район,
		|	энргКоличествоСобственниковСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргКоличествоСобственниковСрезПоследних.Количество КАК Количество
		|ПОМЕСТИТЬ КоличествоСобственников
		|ИЗ
		|	РегистрСведений.энргКоличествоСобственников.СрезПоследних(
		|			&КонецПериодаРасчета,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргКоличествоСобственниковСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргТипСобственностиАбонентовСрезПоследних.Организация КАК Организация,
		|	энргТипСобственностиАбонентовСрезПоследних.Район КАК Район,
		|	энргТипСобственностиАбонентовСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргТипСобственностиАбонентовСрезПоследних.ТипСобственности КАК ТипСобственности
		|ПОМЕСТИТЬ ВидыСобственности
		|ИЗ
		|	РегистрСведений.энргТипСобственностиАбонентов.СрезПоследних(
		|			&КонецПериодаРасчета,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргТипСобственностиАбонентовСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргКоличествоКомнатСрезПервых.Организация КАК Организация,
		|	энргКоличествоКомнатСрезПервых.Район КАК Район,
		|	энргКоличествоКомнатСрезПервых.КлючПомещения КАК КлючПомещения,
		|	энргКоличествоКомнатСрезПервых.Количество КАК Количество
		|ПОМЕСТИТЬ КоличествоКомнат
		|ИЗ
		|	РегистрСведений.энргКоличествоКомнат.СрезПервых(
		|			&КонецПериодаРасчета,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргКоличествоКомнатСрезПервых
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргКоличествоПрописанныхСрезПоследних.Организация КАК Организация,
		|	энргКоличествоПрописанныхСрезПоследних.Район КАК Район,
