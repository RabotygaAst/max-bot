Функция ОпределитьНачалоПериода(КонецПериода, Организация, Район, КлючПомещения) Экспорт	
	
	НачалоПериода = ДобавитьМесяц(КонецПериода, -3);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(энргДатыПоверкиПрибораУчета.ДатаПоверки) КАК ДатаПоверки,
		|	энргДатыПоверкиПрибораУчета.КлючПомещения КАК КлючПомещения
		|ПОМЕСТИТЬ ДанныеДопускаВПомещения
		|ИЗ
		|	РегистрСведений.энргДатыПоверкиПрибораУчета КАК энргДатыПоверкиПрибораУчета
		|ГДЕ
		|	энргДатыПоверкиПрибораУчета.Период МЕЖДУ &НачалоПериода И &КонецПериода
		|	И энргДатыПоверкиПрибораУчета.Организация = &Организация
		|	И энргДатыПоверкиПрибораУчета.Район = &Район
		|	И энргДатыПоверкиПрибораУчета.КлючПомещения = &КлючПомещения
		|
		|СГРУППИРОВАТЬ ПО
		|	энргДатыПоверкиПрибораУчета.КлючПомещения
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МАКСИМУМ(энргСостояниеПриборовУчетаАбонента.Период),
		|	энргСостояниеПриборовУчетаАбонента.КлючПомещения
		|ИЗ
		|	РегистрСведений.энргСостояниеПриборовУчетаАбонента КАК энргСостояниеПриборовУчетаАбонента
		|ГДЕ
		|	энргСостояниеПриборовУчетаАбонента.Период МЕЖДУ &НачалоПериода И &КонецПериода
		|	И энргСостояниеПриборовУчетаАбонента.Организация = &Организация
		|	И энргСостояниеПриборовУчетаАбонента.Район = &Район
		|	И энргСостояниеПриборовУчетаАбонента.КлючПомещения = &КлючПомещения
		|
		|СГРУППИРОВАТЬ ПО
		|	энргСостояниеПриборовУчетаАбонента.КлючПомещения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ДанныеДопускаВПомещения.ДатаПоверки) КАК ДатаПоверки
		|ИЗ
		|	ДанныеДопускаВПомещения КАК ДанныеДопускаВПомещения";
	
	Запрос.УстановитьПараметр("КонецПериода"	, КонецПериода);
	Запрос.УстановитьПараметр("НачалоПериода"	, НачалоПериода);
	Запрос.УстановитьПараметр("Организация"		, Организация);
	Запрос.УстановитьПараметр("Район"			, Район);
	Запрос.УстановитьПараметр("КлючПомещения"	, КлючПомещения);
	
	РезультатЗапроса 	= Запрос.Выполнить();	
	Выборка 			= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НачалоПериода = Выборка.ДатаПоверки;
	КонецЦикла;
	
	Возврат НачалоПериода;
			
КонецФункции

Процедура ЗаполнитьПриборыУчетаСервер(Объект, ТекущиеДанные, УслугиТочекУчета, ПоставщикиУслугТочекУчета) Экспорт 
	
	Результат 							= Обработки.энргСостояниеТочекУчетаМенеджер.ДействующиеТочкиИИхПриборы(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения, ТекущиеДанные.ТочкаУчета); 
	СоставнаяУслуга 					= Неопределено;
	ЭтоСоставнаяУслуга					= Ложь;
	мТарифныеЗоны 						= Новый Массив;
	
	Если Не Результат.Пустой() Тогда
		Выборка 						= Результат.Выбрать();
		ЕстьСледующий 					= Выборка.Следующий();
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, Выборка);//,"ПриборУчета, НаправлениеИспользованияТУ");		
		Если ЗначениеЗаполнено(Выборка.Услуга) Тогда			
			Если Выборка.СоставнаяУслуга Тогда
				СоставнаяУслуга 		= Выборка.Услуга;
				ЭтоСоставнаяУслуга		= Истина;
			Иначе
				СоотвествиеТочкаУчета 	= Новый Соответствие;
				мУслуги 				= Новый Массив;
				мУслуги.Добавить(Выборка.Услуга);
				СоотвествиеТочкаУчета.Вставить(ТекущиеДанные.ТочкаУчета, мУслуги); 		
				УслугиТочекУчета.Вставить(ТекущиеДанные.ПериодНачисления, СоотвествиеТочкаУчета);
				ТекущиеДанные.Услуга 	= Выборка.Услуга;
			КонецЕсли;			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.Поставщик) и Не ЭтоСоставнаяУслуга Тогда
			КлючЗначение  				= Новый Соответствие;
			КлючЗначение.Вставить(Выборка.Услуга, Выборка.Поставщик);
			СоотвествиеТочкаУчета 		= Новый Соответствие;
			СоотвествиеТочкаУчета.Вставить(ТекущиеДанные.ТочкаУчета, КлючЗначение); 
			ПоставщикиУслугТочекУчета.Вставить(ТекущиеДанные.ПериодНачисления, СоотвествиеТочкаУчета);
			ТекущиеДанные.Поставщик 	= Выборка.Поставщик;
		КонецЕсли;
		
		Пока ЕстьСледующий Цикл
			мТарифныеЗоны.Добавить(Выборка.ТарифнаяЗона);
			ЕстьСледующий 				= Выборка.Следующий();
		КонецЦикла;	
		
		Если мТарифныеЗоны.Количество() = 1 Тогда
			ТекущиеДанные.тарифнаяЗона 	= мТарифныеЗоны[0];
		КонецЕсли; 	
		
	КонецЕсли; 	
	
	Если НЕ СоставнаяУслуга = Неопределено Тогда
		
		ПараметрыСоставнойУслуги		= Новый Структура;
		Схема 							= Неопределено;
		ПараметрыВТ 					= Новый Массив;
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("Организация", 	"Организация"), 	Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно",	Новый Структура("Район", 			"Район"), 			Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("КлючПомещения", 	"КлючПомещения"), 	Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", 	Новый Структура("ТочкаУчета", 		"ТочкаУчета"), 		Неопределено));
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраВСписке", 	Новый Структура("Услуга",	 		"Услуги"), 			Неопределено));		
		
		ПараметрыСоставнойУслуги.Вставить("Период", 			Новый Структура("ИмяПараметра", "Период"));
		ПараметрыСоставнойУслуги.Вставить("ПараметрыВТ", 		ПараметрыВТ);
		
		мЧастиУслуг 					= Новый Массив;
		СоставляющиеУслуги 				= СоставнаяУслуга.СоставляющиеУслуг;
		Для Каждого СтрокаТабЧасти Из  СоставляющиеУслуги Цикл
			мЧастиУслуг.Добавить(СтрокаТабЧасти.Услуга);
		КонецЦикла;
		
		РегистрыСведений.энргПоставщикиУслугАбонента.ПоставщикиСоставнойУслуги(Схема,ПараметрыСоставнойУслуги,"");
		Запрос  						= Новый Запрос(Схема.ПолучитьТекстЗапроса());
		Запрос.УстановитьПараметр("Организация", 	Объект.Организация);
		Запрос.УстановитьПараметр("Район", 			Объект.Район);
		Запрос.УстановитьПараметр("КлючПомещения", 	Объект.КлючПомещения);
		Запрос.УстановитьПараметр("ТочкаУчета", 	ТекущиеДанные.ТочкаУчета);
		Запрос.УстановитьПараметр("Услуги", 		мЧастиУслуг);
		Запрос.УстановитьПараметр("Период", 		ТекущиеДанные.ПериодНачисления);		
		Результат 						= Запрос.Выполнить();
		Выборка 						= Результат.Выбрать();
		мУслуги 						= Новый Массив;
		КлючЗначение  					= Новый Соответствие;
		Пока Выборка.Следующий() Цикл
			мУслуги.Добавить(Выборка.Услуга);			
			КлючЗначение.Вставить(Выборка.Услуга, Выборка.Поставщик);			
		КонецЦикла; 
		СоотвествиеТочкаУчета 		= Новый Соответствие;
		СоотвествиеТочкаУчета.Вставить(ТекущиеДанные.ТочкаУчета, КлючЗначение);
		ПоставщикиУслугТочекУчета.Вставить(ТекущиеДанные.ПериодНачисления, СоотвествиеТочкаУчета);
		
		СоотвествиеТочкаУчета 	= Новый Соответствие; 
		СоотвествиеТочкаУчета.Вставить(ТекущиеДанные.ТочкаУчета, мУслуги);
		УслугиТочекУчета.Вставить(ТекущиеДанные.ПериодНачисления, СоотвествиеТочкаУчета);		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучатьОбъемыДляВычета(ИсточникДанных) Экспорт 
	ЭтоВмешательство = Перечисления.энргВидыОпераций.энргАктНесанкционированногоПодключенияВмешательства_Вмешательство;	
	Возврат ИсточникДанных.ВидОперации = ЭтоВмешательство;
КонецФункции 

Процедура ЗаполнитьОбластьЗаголовок(ОбластьЗаголовок, Объект)
	Результат 	  = ПолучитьДанныеБанка(Объект);
	Выборка  	  = Результат.Выбрать();
	Выборка.Следующий(); 	
	
	ДанныеБанка 	= "Получатель платежа: %1 ИНН %2
	|р/с %3 в %4, 
	|к/с %5 БИК %6";
	
	АдресОтделения  = "Адрес отделения: %1
	|тел, %2
	|%3";

	
	ОбластьДанныеБанка = СтрШаблон(
		ДанныеБанка, Выборка.ОрганизацияПредставление, Выборка.ИНН, Выборка.РасчетныйСчет, СклонениеПредставленийОбъектов.ПросклонятьПредставление(Выборка.Банк, 6),
		Выборка.КоррСчет, Выборка.Бик); 
		
	ОбластьАдресОтделения = СтрШаблон(АдресОтделения, Выборка.АдресРайона, Выборка.ТелефонРайона, Выборка.СайтОрганизации); 

	
	ОбластьЗаголовок.Параметры.ДанныеБанка 	  = ОбластьДанныеБанка;
	ОбластьЗаголовок.Параметры.АдресОтделения = ОбластьАдресОтделения;
	ОбластьЗаголовок.Параметры.НомерАкта      = Объект.НомерАкта;
	ОбластьЗаголовок.Параметры.ДатаАкта 	  = Формат(Объект.ДатаАкта,"ДФ=dd.MM.yyyy");
КонецПроцедуры

Функция ПолучитьДанныеБанка(Объект)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Организации.Ссылка КАК Организация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
		|					И ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ """"
		|		КОНЕЦ) КАК ПочтовыйАдресОрганизации,
		|	Организации.ИНН КАК ИННОрганизации,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.ВебСтраница)
		|					И ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.СайтОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ """"
		|		КОНЕЦ) КАК СайтОрганизации,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
		|					И ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ """"
		|		КОНЕЦ) КАК ТелефонОрганизации,
		|	Организации.ОсновнойБанковскийСчет КАК СчетОрганизации,
		|	КлассификаторБанков.Код КАК БИК,
		|	БанковскиеСчета.НомерСчета КАК НомерСчета,
		|	БанковскиеСчета.Банк КАК Банк,
		|	Организации.Представление КАК Представление
		|ПОМЕСТИТЬ ДанныеОрганизации
		|ИЗ
		|	Справочник.Организации КАК Организации
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
		|		ПО Организации.Ссылка = ОрганизацииКонтактнаяИнформация.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчета
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторБанков КАК КлассификаторБанков
		|			ПО БанковскиеСчета.Банк = КлассификаторБанков.Ссылка
		|		ПО Организации.ОсновнойБанковскийСчет = БанковскиеСчета.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.рксОрганизацииДополнительныеРеквизиты КАК рксОрганизацииДополнительныеРеквизиты
		|		ПО Организации.Ссылка = рксОрганизацииДополнительныеРеквизиты.Организация
		|ГДЕ
		|	Организации.Ссылка = &Организация
		|
		|СГРУППИРОВАТЬ ПО
		|	Организации.ИНН,
		|	Организации.Ссылка,
		|	КлассификаторБанков.Код,
		|	Организации.ОсновнойБанковскийСчет,
		|	БанковскиеСчета.НомерСчета,
		|	БанковскиеСчета.Банк,
		|	Организации.Представление
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗоныОтвественностиКонтактнаяИнформация.Ссылка КАК Ссылка,
		|	энргЗоныОтвественностиКонтактнаяИнформация.Представление КАК Значение
		|ПОМЕСТИТЬ АдресРайона
		|ИЗ
		|	Справочник.энргЗоныОтвественности.КонтактнаяИнформация КАК энргЗоныОтвественностиКонтактнаяИнформация
		|ГДЕ
		|	энргЗоныОтвественностиКонтактнаяИнформация.Ссылка = &Район
		|	И энргЗоныОтвественностиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
		|	И энргЗоныОтвественностиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресРайона)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗоныОтвественности.Ссылка КАК Район,
		|	КлассификаторБанков.Наименование КАК НаименованиеБанка,
		|	БанковскиеСчета.НомерСчета КАК НомерСчета,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗоныОтвественностиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
		|					И энргЗоныОтвественностиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(справочник.ВидыКонтактнойИнформации.ТелефонРайона)
		|				ТОГДА энргЗоныОтвественностиКонтактнаяИнформация.Представление
		|			ИНАЧЕ """"
		|		КОНЕЦ) КАК ТелефонРайона,
		|	МАКСИМУМ(энргЗоныОтвественности.КодРайона) КАК КодРайона,
		|	энргЗоныОтвественности.Организация КАК Организация
		|ПОМЕСТИТЬ ДанныеРайона
		|ИЗ
		|	Справочник.энргЗоныОтвественности КАК энргЗоныОтвественности
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргЗоныОтвественности.КонтактнаяИнформация КАК энргЗоныОтвественностиКонтактнаяИнформация
		|		ПО энргЗоныОтвественности.Ссылка = энргЗоныОтвественностиКонтактнаяИнформация.Ссылка,
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторБанков КАК КлассификаторБанков
		|		ПО БанковскиеСчета.Банк = КлассификаторБанков.Ссылка
		|ГДЕ
		|	энргЗоныОтвественности.Ссылка = &Район
		|
		|СГРУППИРОВАТЬ ПО
		|	энргЗоныОтвественности.Ссылка,
		|	КлассификаторБанков.Наименование,
		|	БанковскиеСчета.НомерСчета,
		|	энргЗоныОтвественности.Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеРайона.Район КАК Район,
		|	ДанныеРайона.Организация КАК Организация,
		|	МАКСИМУМ(ДанныеОрганизации.ТелефонОрганизации) КАК ТелефонОрганизации,
		|	МАКСИМУМ(ДанныеОрганизации.СайтОрганизации) КАК СайтОрганизации,
		|	МАКСИМУМ(ДанныеОрганизации.ПочтовыйАдресОрганизации) КАК ПочтовыйАдресОрганизации,
		|	ДанныеОрганизации.ИННОрганизации КАК ИНН,
		|	ДанныеРайона.НомерСчета КАК РасчетныйСчет,
		|	ДанныеРайона.НаименованиеБанка КАК НаименованиеБанка,
		|	ДанныеОрганизации.НомерСчета КАК КоррСчет,
		|	ДанныеОрганизации.БИК КАК БИК,
		|	ДанныеРайона.КодРайона КАК КодРайона,
		|	ДанныеРайона.ТелефонРайона КАК ТелефонРайона,
		|	ДанныеОрганизации.Банк КАК Банк,
		|	ДанныеОрганизации.Представление КАК Представление
		|ПОМЕСТИТЬ ОбщаяИнформацияПоОрганизацииИПоРайону
		|ИЗ
		|	ДанныеОрганизации КАК ДанныеОрганизации
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеРайона КАК ДанныеРайона
		|		ПО ДанныеОрганизации.Организация = ДанныеРайона.Организация
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеОрганизации.ИННОрганизации,
		|	ДанныеОрганизации.БИК,
		|	ДанныеОрганизации.НомерСчета,
		|	ДанныеРайона.НаименованиеБанка,
		|	ДанныеРайона.НомерСчета,
		|	ДанныеРайона.КодРайона,
		|	ДанныеРайона.Организация,
		|	ДанныеРайона.Район,
		|	ДанныеРайона.ТелефонРайона,
		|	ДанныеОрганизации.Банк,
		|	ДанныеОрганизации.Представление
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(АдресРайона.Значение, """") КАК АдресРайона,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.Район КАК Район,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.Организация КАК Организация,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.ТелефонОрганизации КАК ТелефонОрганизации,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.СайтОрганизации КАК СайтОрганизации,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.ПочтовыйАдресОрганизации КАК ПочтовыйАдресОрганизации,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.ИНН КАК ИНН,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.РасчетныйСчет КАК РасчетныйСчет,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.НаименованиеБанка КАК НаименованиеБанка,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.КоррСчет КАК КоррСчет,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.БИК КАК БИК,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.КодРайона КАК КодРайона,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.ТелефонРайона КАК ТелефонРайона,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.Банк КАК Банк,
		|	ОбщаяИнформацияПоОрганизацииИПоРайону.Представление КАК ОрганизацияПредставление
		|ИЗ
		|	ОбщаяИнформацияПоОрганизацииИПоРайону КАК ОбщаяИнформацияПоОрганизацииИПоРайону
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АдресРайона КАК АдресРайона
		|		ПО ОбщаяИнформацияПоОрганизацииИПоРайону.Район = АдресРайона.Ссылка";
	
	Запрос.УстановитьПараметр("Район"		, Объект.Район);
	Запрос.УстановитьПараметр("Организация" , Объект.Организация);
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса;	
КонецФункции	

