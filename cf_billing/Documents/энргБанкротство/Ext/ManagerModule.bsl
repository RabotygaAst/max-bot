	|			И (НЕ энргБанкротствоДанныеСписания.СуммаСписания = 0)";		
			
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаЗабалансоваяЗадолженность(Схема, Регистры)
	
	ИмяРегистра = "энргЗабалансоваяЗадолженность";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(энргБанкротствоДанныеСписания.ПериодЗадолженности, МЕСЯЦ) КАК ПериодНачисления,
	|	Шапка.Дата КАК Период,
	|	Шапка.Организация КАК Организация,
	|	Шапка.Район КАК Район,
	|	Шапка.Абонент КАК Абонент,
	|	энргБанкротствоДанныеСписания.Услуга КАК Услуга,
	|	энргБанкротствоДанныеСписания.Поставщик КАК Поставщик,
	|	энргБанкротствоДанныеСписания.СуммаСписания КАК СуммаЗадолженности,
	|	&МКД КАК МКД,
	|	ВЫБОР
	|		КОГДА Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргБанкротство_СписаниеНаЗабалансФЛ)
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	КОНЕЦ КАК ВидДвижения,
	|	ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.МораторнаяЗадолженность) КАК ВидЗадолженности
	|ИЗ
	|	Документ.энргБанкротство.ДанныеСписания КАК энргБанкротствоДанныеСписания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргБанкротство КАК Шапка
	|		ПО энргБанкротствоДанныеСписания.Ссылка = Шапка.Ссылка
	|			И (Шапка.Ссылка В (&мДокументы))
	|			И (энргБанкротствоДанныеСписания.Ссылка В (&мДокументы))
	|			И (НЕ энргБанкротствоДанныеСписания.СуммаСписания = 0)";		
			
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

