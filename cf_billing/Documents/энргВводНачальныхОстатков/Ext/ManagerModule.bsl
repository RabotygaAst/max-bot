    СтруктураЛицевойСчетСДоговоромДоТП.Вставить("ШкалыПриборовУчета", Пакет[9]);
    СтруктураЛицевойСчетСДоговоромДоТП.Вставить("ПоказанияПриборовУчета", Пакет[10]);
    СтруктураЛицевойСчетСДоговоромДоТП.Вставить("НомераПломб", Пакет[11]);
    
