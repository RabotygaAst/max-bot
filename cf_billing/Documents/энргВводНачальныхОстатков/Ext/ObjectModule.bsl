	|	энргВладельцыТочекУчета.ДатаПриемки,
	|	энргВладельцыТочекУчета.КоэффициентПУ,
	|	энргВладельцыТочекУчета.КоэффициентПУ,
	|	энргВладельцыТочекУчета.ДатаПоверки,
	|	энргВладельцыТочекУчета.ДатаПоверки";
	
	Пакеты	= Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	ТЗ		= Пакеты[0].Выгрузить();
	Движения.энргВладельцыТочекУчета.Загрузить(ТЗ);
	Движения.энргАктивностьТочекУчета.Загрузить(ТЗ);
	Движения.энргУслугиТочекУчета.Загрузить(ТЗ);
	Движения.энргНаправлениеИспользованияТочекУчета.Загрузить(ТЗ);
	Движения.энргТехническаяВозможностьУстановкиПУ.Загрузить(ТЗ);
	Движения.бестТУНаСтруктуреСети.Загрузить(ТЗ);
	
	ТЗ		= Пакеты[1].Выгрузить();
	Движения.энргРодительТочкиУчета.Загрузить(ТЗ);
	
	ТЗ		= Пакеты[2].Выгрузить();
	Движения.энргАбонентыПомещений.Загрузить(ТЗ);
	
	ТЗ		= Пакеты[3].Выгрузить();
	Движения.энргПриборыТочекУчета.Загрузить(ТЗ);
	Движения.энргКоэффциентыПриборовУчета.Загрузить(ТЗ);
	Движения.энргДатыПоверкиПрибораУчета.Загрузить(ТЗ);
	Движения.энргСостояниеПриборовУчетаАбонента.Загрузить(ТЗ);
		
КонецПроцедуры

Процедура ЗаписатьНомераПломбПУ(МВТ)      
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст 	= 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ таблицаНомераПломб.ДатаУстановкиПломбы = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА таблицаНомераПломб.ДатаУстановкиПломбы
	|		ИНАЧЕ ВложенныйЗапрос.Период
	|	КОНЕЦ КАК Период,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	таблицаНомераПломб.КлючСтроки КАК МестоУстановки,
	|	таблицаНомераПломб.НомерПломбы КАК НомерПломбы,
	|	ВложенныйЗапрос.ПериодРегистрации КАК ПериодРегистрации,
	|	ИСТИНА КАК Состояние,
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	таблицаНомераПломб.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	|	таблицаНомераПломб.ЛицоУстановившееПломбу КАК ЛицоУстановившееПломбу
	|ИЗ
	|	(ВЫБРАТЬ
	|		табШапка.Дата КАК Период,
	|		табШапка.Организация КАК Организация,
	|		табШапка.Район КАК Район,
	|		табАбоненты.КлючПомещения КАК КлючПомещения,
	|		табТочкиУчета.ПриборУчета КАК ПриборУчета,
	|		табШапка.Дата КАК ПериодРегистрации,
	|		НАЧАЛОПЕРИОДА(табШапка.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления,
	|		табШапка.Ссылка КАК Ссылка,
	|		табТочкиУчета.IDСтроки КАК IDСтроки
	|	ИЗ
	|		ШапкаДокумента КАК табШапка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК табТочкиУчета
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК табАбоненты
	|				ПО табТочкиУчета.Ссылка = табАбоненты.Ссылка
	|					И табТочкиУчета.IDСтрокиАбонента = табАбоненты.IDСтроки
	|					И (табТочкиУчета.Ссылка = &Ссылка)
	|					И (табАбоненты.Ссылка = &Ссылка)
	|			ПО табШапка.Ссылка = табТочкиУчета.Ссылка
	|				И (табШапка.Ссылка = &Ссылка)
	|				И (табТочкиУчета.Ссылка = &Ссылка)
	|				И (НЕ табТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВложенныйЗапрос.Период,
	|		ВложенныйЗапрос.Организация,
	|		ВложенныйЗапрос.Район,
	|		ВложенныйЗапрос.КлючПомещения,
	|		табИзмерители.ПриборУчета,
	|		ВложенныйЗапрос.ПериодРегистрации,
	|		ВложенныйЗапрос.ПериодНачисления,
	|		ВложенныйЗапрос.Ссылка,
	|		табИзмерители.IDСтроки
	|	ИЗ
	|		(ВЫБРАТЬ
	|			табШапка.Дата КАК Период,
	|			табШапка.Организация КАК Организация,
	|			табШапка.Район КАК Район,
	|			табАбоненты.КлючПомещения КАК КлючПомещения,
	|			табШапка.Дата КАК ПериодРегистрации,
	|			НАЧАЛОПЕРИОДА(табШапка.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления,
	|			табШапка.Ссылка КАК Ссылка,
	|			табТочкиУчета.IDСтроки КАК IDСтроки
	|		ИЗ
	|			ШапкаДокумента КАК табШапка
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК табТочкиУчета
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК табАбоненты
	|					ПО табТочкиУчета.Ссылка = табАбоненты.Ссылка
	|						И табТочкиУчета.IDСтрокиАбонента = табАбоненты.IDСтроки
	|						И (табТочкиУчета.Ссылка = &Ссылка)
	|						И (табАбоненты.Ссылка = &Ссылка)
	|				ПО табШапка.Ссылка = табТочкиУчета.Ссылка
	|					И (табШапка.Ссылка = &Ссылка)
	|					И (табТочкиУчета.Ссылка = &Ссылка)
	|					И (НЕ табТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатков.Измерители КАК табИзмерители
	|			ПО ВложенныйЗапрос.Ссылка = табИзмерители.Ссылка
	|				И ВложенныйЗапрос.IDСтроки = табИзмерители.IDСтрокиТочкиУчета
	|				И (табИзмерители.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатков.НомераПломб КАК таблицаНомераПломб
	|		ПО ВложенныйЗапрос.Ссылка = таблицаНомераПломб.Ссылка
	|			И ВложенныйЗапрос.IDСтроки = таблицаНомераПломб.IDСтрокиИзмерителя
	|			И (таблицаНомераПломб.Ссылка = &Ссылка)";

	
	Результат 				= Запрос.Выполнить();
	Выборка  				= Результат.Выбрать();
		
	Пока Выборка.Следующий() Цикл 		
		УстановитьНомерПломбыПрибораУчета(Выборка);	
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьЗначенияНаправленийИзмеренийТУ(МВТ)
	
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПериодРегистрации КАК ПериодРегистрации,
	|	энргВводНачальныхОстатковЗначенияИзмерителей.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	ВложенныйЗапрос.IDСтроки КАК IDСтроки,
	|	энргВводНачальныхОстатковЗначенияИзмерителей.Значение КАК Значение,
	|	ВложенныйЗапрос.ПериодУслуги КАК ПериодУслуги
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргВводНачальныхОстатков.Организация КАК Организация,
	|		энргВводНачальныхОстатков.ПериодНачисления КАК ПериодНачисления,
	|		энргВводНачальныхОстатков.Район КАК Район,
	|		энргВводНачальныхОстатков.МКД КАК МКД,
	|		ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|		ВложенныйЗапрос.Абонент КАК Абонент,
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		энргВводНачальныхОстатков.Дата КАК ПериодРегистрации,
	|		ВложенныйЗапрос.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|		ВложенныйЗапрос.IDСтроки КАК IDСтроки,
	|		энргВводНачальныхОстатков.Ссылка КАК Ссылка,
	|		ВложенныйЗапрос.ПериодУслуги КАК ПериодУслуги
	|	ИЗ
	|		(ВЫБРАТЬ
	|			энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
	|			энргВводНачальныхОстатковАбоненты.Абонент КАК Абонент,
	|			энргВводНачальныхОстатковТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|			энргВводНачальныхОстатковТочкиУчета.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|			энргВводНачальныхОстатковТочкиУчета.IDСтроки КАК IDСтроки,
	|			ВЫБОР
	|				КОГДА энргВводНачальныхОстатковТочкиУчета.ДатаПодключенияУслуги < энргВводНачальныхОстатковАбоненты.ДатаОткрытияЛС
	|					ТОГДА энргВводНачальныхОстатковАбоненты.ДатаОткрытияЛС
	|				ИНАЧЕ энргВводНачальныхОстатковТочкиУчета.ДатаПодключенияУслуги
	|			КОНЕЦ КАК ПериодУслуги
	|		ИЗ
	|			ТаблицаТочекУчета КАК энргВводНачальныхОстатковТочкиУчета
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
	|				ПО энргВводНачальныхОстатковТочкиУчета.IDСтрокиАбонента = энргВводНачальныхОстатковАбоненты.IDСтроки
	|					И (энргВводНачальныхОстатковТочкиУчета.Ссылка = &Ссылка)
	|					И (энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|			ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатков.ЗначенияИзмерителей КАК энргВводНачальныхОстатковЗначенияИзмерителей
	|		ПО ВложенныйЗапрос.IDСтроки = энргВводНачальныхОстатковЗначенияИзмерителей.IDСтроки
	|			И (НЕ ВложенныйЗапрос.НаправлениеИспользованияТУ = ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление))
	|			И (энргВводНачальныхОстатковЗначенияИзмерителей.Значение > 0)
	|			И (энргВводНачальныхОстатковЗначенияИзмерителей.Ссылка = &Ссылка)
	|			И ВложенныйЗапрос.Ссылка = энргВводНачальныхОстатковЗначенияИзмерителей.Ссылка";
	
	Результат 		= Запрос.Выполнить();
	Выборка  		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 		
		УстановитьЗначенияНаправленийИзмерителейТУ(Выборка);
	КонецЦикла;
	
КонецПроцедуры  

