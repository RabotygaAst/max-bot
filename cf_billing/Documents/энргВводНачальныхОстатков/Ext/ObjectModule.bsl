Процедура ЗаписатьЗначенияПлощадей(МВТ)
	
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатков.Организация КАК Организация,
	|	энргВводНачальныхОстатков.ПериодНачисления КАК ПериодНачисления,
	|	энргВводНачальныхОстатков.Район КАК Район,
	|	энргВводНачальныхОстатков.МКД КАК МКД,
	|	ВложенныйЗапрос.Период КАК Период,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.ВидПлощади КАК ВидПлощади,
	|	ВложенныйЗапрос.ЗначениеПлощади КАК Площадь,
	|	энргВводНачальныхОстатков.Дата КАК ПериодРегистрации
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргВводНачальныхОстатковЗначениеПлощадей.Период КАК Период,
	|		энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
	|		энргВводНачальныхОстатковАбоненты.Абонент КАК Абонент,
	|		энргВводНачальныхОстатковЗначениеПлощадей.ВидПлощади КАК ВидПлощади,
	|		энргВводНачальныхОстатковЗначениеПлощадей.ЗначениеПлощади КАК ЗначениеПлощади
	|	ИЗ
	|		Документ.энргВводНачальныхОстатков.ЗначениеПлощадей КАК энргВводНачальныхОстатковЗначениеПлощадей
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
	|			ПО энргВводНачальныхОстатковЗначениеПлощадей.IDСтрокиАбонента = энргВводНачальныхОстатковАбоненты.IDСтроки
	|				И (энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка)
	|				И (энргВводНачальныхОстатковЗначениеПлощадей.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|		ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)";
	
	Результат  						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 		
		Запись 						= Движения.энргЗначенияПлощадей.Добавить();
		Запись.Период 				= Выборка.Период;
		Запись.Организация 			= Выборка.Организация;
		Запись.Район 				= Выборка.Район;
		Запись.КлючПомещения		= Выборка.КлючПомещения;
		Запись.ВидПлощади 			= Выборка.ВидПлощади;
		Запись.Площадь 				= Выборка.Площадь;
		Запись.ПериодРегистрации 	= Выборка.ПериодРегистрации;
		Запись.ПериодНачисления 	= Выборка.ПериодНачисления;		
	КонецЦикла;	
	
