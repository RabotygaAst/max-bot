Процедура ЗаписатьОрганизациюПоставщикаСтроений(МВТ)
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	ИСТИНА КАК Активна,
	|	энргВводНачальныхОстатков.Дата КАК Период,
	|	ВложенныйЗапрос.Строение КАК Строение,
	|	энргВводНачальныхОстатков.Поставщик КАК Поставщик
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргКлючиПомещений.Строение КАК Строение
	|	ИЗ
	|		ТаблицаАбонентов КАК ТаблицаАбонентов
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	|			ПО ТаблицаАбонентов.КлючПомещения = энргКлючиПомещений.Ссылка
	|	ГДЕ
	|		энргКлючиПомещений.ЧастныйСектор
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргКлючиПомещений.Строение) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|		ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)";
	
	Результат  						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 		
		Запись 						= Движения.энргОрганизацииПоставщикиСтроений.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Выборка);		
	КонецЦикла;
	

КонецПроцедуры 

#КонецОбласти

#Область РаботаСДаннымиТочекПоставок

Процедура ЗаписатьДанныеТочекПоставок(МВТ)
	
	Если ЗначениеЗаполнено(МКД) Тогда 
		Возврат;
	КонецЕсли;
	
	
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатков.Дата КАК Период,
	|	энргВводНачальныхОстатков.Организация КАК Организация,
	|	энргВводНачальныхОстатков.Район КАК Район,
	|	энргКлючиПомещений.Строение КАК Строение,
	|	энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
	|	энргВводНачальныхОстатковТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	энргВводНачальныхОстатковТочкиПоставки.МаксимальнаяМощность КАК МаксимальнаяМощность,
	|	энргВводНачальныхОстатковТочкиПоставки.ПрисоединеннаяМощность КАК ПрисоединеннаяМощность,
	|	энргВводНачальныхОстатковТочкиПоставки.СетеваяОрганизация КАК СетеваяОрганизация,
	|	энргВводНачальныхОстатковТочкиПоставки.СтруктураСети КАК СтруктураСети,
	|	энргВводНачальныхОстатковТочкиПоставки.УровеньНапряжения КАК УровеньНапряжения,
	|	энргВводНачальныхОстатковТочкиПоставки.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный,
	|	энргВводНачальныхОстатковТочкиПоставки.КатегорияНадежности КАК КатегорияНадежности,
	|	энргВводНачальныхОстатковТочкиПоставки.ДоговорТП КАК ДоговорТП,
	|	энргВводНачальныхОстатковТочкиПоставки.АктТП КАК АктТП,
	|	энргВводНачальныхОстатковТочкиПоставки.ТочкаПоставки КАК ТочкаПоставки
	|ПОМЕСТИТЬ ДанныеТочекПоставок
	|ИЗ
	|	ТаблицаТочекУчета КАК энргВводНачальныхОстатковТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	|			ПО энргВводНачальныхОстатковАбоненты.КлючПомещения = энргКлючиПомещений.Ссылка
	|		ПО энргВводНачальныхОстатковТочкиУчета.IDСтрокиАбонента = энргВводНачальныхОстатковАбоненты.IDСтроки
	|			И (энргВводНачальныхОстатковТочкиУчета.Ссылка = &Ссылка)
	|			И (энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка)
	|			И энргВводНачальныхОстатковТочкиУчета.Ссылка = энргВводНачальныхОстатковАбоненты.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|		ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)
	|			И энргВводНачальныхОстатковТочкиУчета.Ссылка = энргВводНачальныхОстатков.Ссылка
	|			И (энргВводНачальныхОстатков.Ссылка = &Ссылка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатков.ТочкиПоставки КАК энргВводНачальныхОстатковТочкиПоставки
	|		ПО энргВводНачальныхОстатковТочкиУчета.Ссылка = энргВводНачальныхОстатковТочкиПоставки.Ссылка
	|			И энргВводНачальныхОстатковТочкиУчета.IDСтроки = энргВводНачальныхОстатковТочкиПоставки.IDСтрокиТочкиУчета
	|			И (энргВводНачальныхОстатковТочкиПоставки.Ссылка = &Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДанныеТочекПоставок.Период КАК Период,
	|	ДанныеТочекПоставок.ТочкаПоставки КАК ТочкаПоставки,
	|	МАКСИМУМ(ДанныеТочекПоставок.МаксимальнаяМощность) КАК МаксимальнаяМощность,
	|	МАКСИМУМ(ДанныеТочекПоставок.ПрисоединеннаяМощность) КАК ПрисоединеннаяМощность,
	|	МАКСИМУМ(ДанныеТочекПоставок.СетеваяОрганизация) КАК СетеваяОрганизация,
	|	МАКСИМУМ(ДанныеТочекПоставок.СтруктураСети) КАК СтруктураСети,
	|	МАКСИМУМ(ДанныеТочекПоставок.УровеньНапряжения) КАК УровеньНапряжения,
	|	МАКСИМУМ(ДанныеТочекПоставок.УровеньНапряженияРасчетный) КАК УровеньНапряженияРасчетный,
	|	МАКСИМУМ(ДанныеТочекПоставок.КатегорияНадежности) КАК КатегорияНадежности,
	|	МАКСИМУМ(ДанныеТочекПоставок.ДоговорТП) КАК ДоговорТП,
	|	МАКСИМУМ(ДанныеТочекПоставок.АктТП) КАК АктТП,
	|	ИСТИНА КАК Состояние
	|ИЗ
	|	ДанныеТочекПоставок КАК ДанныеТочекПоставок
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеТочекПоставок.Период,
	|	ДанныеТочекПоставок.ТочкаПоставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеТочекПоставок.Период КАК Период,
	|	ДанныеТочекПоставок.Организация КАК Организация,
	|	ДанныеТочекПоставок.Район КАК Район,
	|	ДанныеТочекПоставок.Строение КАК Строение,
	|	ДанныеТочекПоставок.КлючПомещения КАК КлючПомещения,
	|	ДанныеТочекПоставок.ТочкаУчета КАК ТочкаУчета,
	|	ДанныеТочекПоставок.ТочкаПоставки КАК ТочкаПоставки
	|ИЗ
	|	ДанныеТочекПоставок КАК ДанныеТочекПоставок
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Район,
	|	Строение,
	|	ТочкаПоставки";
	
	Результат 				= Запрос.ВыполнитьПакет();
	КоличествоПакетов		= Результат.Количество();
	ВыборкаТочкиПоставок	= Результат[КоличествоПакетов - 2].Выбрать(); 
	Пока ВыборкаТочкиПоставок.Следующий() Цикл
		НСтрока = Движения.энргАктивностьТочекПоставки.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, ВыборкаТочкиПоставок);
		
		НСтрока = Движения.энргПараметрыТочекПоставки.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, ВыборкаТочкиПоставок);	
	КонецЦикла;
	
	
	ТекОрганизация 			= Неопределено;
	ТекРайон			 	= Неопределено;
	ТекСтроение			 	= Неопределено;
	ТекТочкаПоставки		= Неопределено;
	
	ВыборкаТочкиПоставокСтроений = Результат[КоличествоПакетов - 1].Выбрать(); 
	Пока ВыборкаТочкиПоставокСтроений.Следующий() Цикл
		
		НСтрока = Движения.энргТочкиПоставкиТочекУчета.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, ВыборкаТочкиПоставокСтроений);
		
		Если НЕ ТекОрганизация = ВыборкаТочкиПоставокСтроений.Организация
			ИЛИ НЕ ТекРайон = ВыборкаТочкиПоставокСтроений.Район
			ИЛИ НЕ ТекСтроение = ВыборкаТочкиПоставокСтроений.Строение
			ИЛИ НЕ ТекТочкаПоставки = ВыборкаТочкиПоставокСтроений.ТочкаПоставки Тогда			
			
			НСтрока = Движения.энргТочкиПоставкиСтроений.Добавить();
			ЗаполнитьЗначенияСвойств(НСтрока, ВыборкаТочкиПоставокСтроений);			
		КонецЕсли; 		
		
		ТекОрганизация 		= ВыборкаТочкиПоставокСтроений.Организация;
		ТекРайон			= ВыборкаТочкиПоставокСтроений.Район;
		ТекСтроение			= ВыборкаТочкиПоставокСтроений.Строение;
		ТекТочкаПоставки	= ВыборкаТочкиПоставокСтроений.ТочкаПоставки;
	КонецЦикла;	
КонецПроцедуры

#КонецОбласти

#Область РаботаСоШкаламиТарифнымиЗонами

Процедура ЗаписатьВидДифференцированностиПриборовУчета(МВТ)
	
	Запрос  = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатков.Организация КАК Организация,
	|	энргВводНачальныхОстатков.ПериодНачисления КАК ПериодНачисления,
	|	энргВводНачальныхОстатков.Район КАК Район,
	|	энргВводНачальныхОстатков.МКД КАК МКД,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВводНачальныхОстатков.Дата КАК Дата,
	|	энргВводНачальныхОстатков.Дата КАК ПериодРегистрации,
	|	ВложенныйЗапрос.ДатаПриемки КАК ДатаПриемки
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
	|		энргВводНачальныхОстатковАбоненты.Абонент КАК Абонент,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		ВложенныйЗапрос.Шкала КАК Шкала,
	|		ВложенныйЗапрос.ВидДифференцированности КАК ВидДифференцированности,
	|		ВложенныйЗапрос.ДатаПриемки КАК ДатаПриемки
	|	ИЗ
	|		(ВЫБРАТЬ
	|			энргВводНачальныхОстатковТочкиУчета.ПриборУчета КАК ПриборУчета,
	|			энргВводНачальныхОстатковШкалыПриборовУчета.Шкала КАК Шкала,
	|			энргВводНачальныхОстатковШкалыПриборовУчета.ВидДифференцированности КАК ВидДифференцированности,
	|			энргВводНачальныхОстатковТочкиУчета.IDСтрокиАбонента КАК IDСтрокиАбонента,
	|			энргВводНачальныхОстатковТочкиУчета.ДатаПриемки КАК ДатаПриемки
	|		ИЗ
	|			ТаблицаТочекУчета КАК энргВводНачальныхОстатковТочкиУчета
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаШкалТочекУчета КАК энргВводНачальныхОстатковШкалыПриборовУчета
	|				ПО энргВводНачальныхОстатковТочкиУчета.IDСтроки = энргВводНачальныхОстатковШкалыПриборовУчета.IDСтрокиТочкиУчета
	|					И (энргВводНачальныхОстатковТочкиУчета.Ссылка = &Ссылка)
	|					И (энргВводНачальныхОстатковШкалыПриборовУчета.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
	|			ПО (энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка)
	|				И ВложенныйЗапрос.IDСтрокиАбонента = энргВводНачальныхОстатковАбоненты.IDСтроки) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|		ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)
	|ГДЕ
	|	ВложенныйЗапрос.ПриборУчета <> ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)";
	
	Результат  							= Запрос.Выполнить();
	Выборка  							= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл		
		Запись 							= Движения.энргВидыДифференцированностиПриборовУчета.Добавить();
		Запись.Период  					= Выборка.ДатаПриемки;
		Запись.Район  					= Выборка.Район;
		Запись.Организация				= Выборка.Организация;
		Запись.КлючПомещения			= Выборка.КлючПомещения;
		Запись.ПриборУчета 				= Выборка.ПриборУчета;
		Запись.Шкала 					= Выборка.Шкала;
		Запись.ВидДифференцированности	= ?(НЕ ЗначениеЗаполнено(Выборка.ВидДифференцированности),Справочники.энргВидыДифференцированности.Однотарифный,Выборка.ВидДифференцированности);
		Запись.ПериодРегистрации		= Выборка.ПериодРегистрации;
		Запись.ПериодНачисления			= Выборка.ПериодНачисления;		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьПоказанияПриборовУчета(МВТ)
	
	Запрос 			= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.IDСтрокиАбонента КАК IDСтрокиАбонента,
	|	ВложенныйЗапрос.ПериодПоказаний КАК ПериодПоказаний,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ВложенныйЗапрос.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ВложенныйЗапрос.ИсточникПоказаний КАК ИсточникПоказаний,
	|	энргВводНачальныхОстатков.Организация КАК Организация,
	|	энргВводНачальныхОстатков.Район КАК Район,
	|	энргВводНачальныхОстатков.МКД КАК МКД,
	|	энргВводНачальныхОстатков.Дата КАК ПериодРегистрации,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	энргВводНачальныхОстатков.ПериодНачисления КАК ПериодНачисления
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.IDСтрокиАбонента КАК IDСтрокиАбонента,
	|		ВложенныйЗапрос.ПериодПоказаний КАК ПериодПоказаний,
	|		энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
	|		энргВводНачальныхОстатковАбоненты.Абонент КАК Абонент,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		ВложенныйЗапрос.Шкала КАК Шкала,
	|		ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|		ВложенныйЗапрос.ТекущиеПоказания КАК ТекущиеПоказания,
	|		ВложенныйЗапрос.ИсточникПоказаний КАК ИсточникПоказаний,
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета
	|	ИЗ
	|		(ВЫБРАТЬ
	|			энргВводНачальныхОстатковТочкиУчета.IDСтрокиАбонента КАК IDСтрокиАбонента,
	|			ВложенныйЗапрос.ПериодПоказаний КАК ПериодПоказаний,
	|			энргВводНачальныхОстатковТочкиУчета.ПриборУчета КАК ПриборУчета,
	|			ВложенныйЗапрос.Шкала КАК Шкала,
	|			ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|			ВложенныйЗапрос.ТекущиеПоказания КАК ТекущиеПоказания,
	|			ВложенныйЗапрос.ИсточникПоказаний КАК ИсточникПоказаний,
	|			энргВводНачальныхОстатковТочкиУчета.ТочкаУчета КАК ТочкаУчета
	|		ИЗ
	|			(ВЫБРАТЬ
	|				энргВводНачальныхОстатковШкалыПриборовУчета.IDСтрокиТочкиУчета КАК IDСтрокиТочкиУчета,
	|				энргВводНачальныхОстатковПоказанияПриборовУчета.ДатаПоказаний КАК ПериодПоказаний,
	|				энргВводНачальныхОстатковШкалыПриборовУчета.Шкала КАК Шкала,
	|				энргВводНачальныхОстатковПоказанияПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	|				энргВводНачальныхОстатковПоказанияПриборовУчета.ТекущиеПоказания КАК ТекущиеПоказания,
	|				энргВводНачальныхОстатковПоказанияПриборовУчета.ИсточникПоказаний КАК ИсточникПоказаний
	|			ИЗ
	|				Документ.энргВводНачальныхОстатков.ПоказанияПриборовУчета КАК энргВводНачальныхОстатковПоказанияПриборовУчета
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаШкалТочекУчета КАК энргВводНачальныхОстатковШкалыПриборовУчета
	|					ПО энргВводНачальныхОстатковПоказанияПриборовУчета.IDСтроки = энргВводНачальныхОстатковШкалыПриборовУчета.IDСтроки
	|						И энргВводНачальныхОстатковПоказанияПриборовУчета.Ссылка = энргВводНачальныхОстатковШкалыПриборовУчета.Ссылка
	|						И (энргВводНачальныхОстатковПоказанияПриборовУчета.Ссылка = &Ссылка)
	|						И (энргВводНачальныхОстатковШкалыПриборовУчета.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК энргВводНачальныхОстатковТочкиУчета
	|				ПО ВложенныйЗапрос.IDСтрокиТочкиУчета = энргВводНачальныхОстатковТочкиУчета.IDСтроки
	|					И (энргВводНачальныхОстатковТочкиУчета.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
	|			ПО ВложенныйЗапрос.IDСтрокиАбонента = энргВводНачальныхОстатковАбоненты.IDСтроки
	|				И (энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|		ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)";
	
	Результат  						= Запрос.Выполнить();
	Выборка 						= Результат.Выбрать();
	
	МенеджерМаксимальныеПоказания = РегистрыСведений.энргМаксимальныеПоказания;
	НаборЗаписейМП = МенеджерМаксимальныеПоказания.СоздатьНаборЗаписей();
	НаборЗаписейМП.Отбор.ДокРегистратор.Установить(Ссылка);
	
	Пока Выборка.Следующий() Цикл
		
		Запись 						= Движения.энргПоказанияПриборовУчета.Добавить();
		Запись.Период 				= Выборка.ПериодПоказаний;
		Запись.Организация			= Выборка.Организация;
		Запись.Район				= Выборка.Район;
		Запись.КлючПомещения		= Выборка.КлючПомещения;
		Запись.ПриборУчета			= Выборка.ПриборУчета;
		Запись.Шкала				= Выборка.Шкала;
		Запись.ТарифнаяЗона			= Выборка.ТарифнаяЗона;
		Запись.Разделитель			= 0;
		Запись.Показание			= Выборка.ТекущиеПоказания;
		Запись.СостояниеПоказаний	= Перечисления.энргСостояниеПоказаний.Приняты;
		Запись.КС					= Ложь;
		Запись.ИсточникПоказаний	= Выборка.ИсточникПоказаний;
		Запись.Переворот			= Ложь;
		Запись.ПериодНачисления		= Выборка.ПериодНачисления;
		Запись.ПериодРегистрации	= Выборка.ПериодРегистрации;
		Запись.ТочкаУчета			= Выборка.ТочкаУчета;
		
		
		//Запись 						= Движения.энргМаксимальныеПоказания.Добавить();
		Запись						= НаборЗаписейМП.Добавить();
		Запись.ДокРегистратор 		= Ссылка;
		Запись.Период 				= Выборка.ПериодПоказаний;
		Запись.Организация			= Выборка.Организация;
		Запись.Район				= Выборка.Район;
		Запись.КлючПомещения		= Выборка.КлючПомещения;
		Запись.ПриборУчета			= Выборка.ПриборУчета;
		Запись.Шкала				= Выборка.Шкала;
		Запись.ТарифнаяЗона			= Выборка.ТарифнаяЗона;
		Запись.Разделитель			= 0;
		Запись.Показание			= Выборка.ТекущиеПоказания;
		Запись.ДатаРегистратора 	= Выборка.ПериодПоказаний;   
		
		Если Не ЗначениеЗаполнено(Выборка.ПериодПоказаний) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена дата показаний " + Выборка.Абонент + " для прибора " + Выборка.ПриборУчета);	
		КонецЕсли;
	КонецЦикла;
	
	НаборЗаписейМП.Записать();
	
КонецПроцедуры 

Процедура ЗаписатьАдресВМаршрутКонтролера(МВТ)  	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
		|	энргВводНачальныхОстатковАбоненты.МаршрутКонтролера КАК МаршрутКонтролера
		|ИЗ
		|	ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещенийМаршрутовКонтролеров КАК энргКлючиПомещенийМаршрутовКонтролеров
		|		ПО энргВводНачальныхОстатковАбоненты.МаршрутКонтролера = энргКлючиПомещенийМаршрутовКонтролеров.МаршрутКонтролера
		|			И энргВводНачальныхОстатковАбоненты.КлючПомещения = энргКлючиПомещенийМаршрутовКонтролеров.КлючПомещения
		|ГДЕ
		|	энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка
		|	И НЕ энргВводНачальныхОстатковАбоненты.МаршрутКонтролера = ЗНАЧЕНИЕ(Справочник.энргМаршрутыКонтроллеров.ПустаяСсылка)
		|	И энргКлючиПомещенийМаршрутовКонтролеров.КлючПомещения ЕСТЬ NULL
		|ИТОГИ ПО
		|	МаршрутКонтролера";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса 			= Запрос.Выполнить();	
	ВыборкаМаршрутКонтролера 	= РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	МенеджерРегистра			= РегистрыСведений.энргКлючиПомещенийМаршрутовКонтролеров;
	
	Пока ВыборкаМаршрутКонтролера.Следующий() Цикл
		НаборМаршрута = МенеджерРегистра.СоздатьНаборЗаписей();
		НаборМаршрута.Отбор.МаршрутКонтролера.Установить(ВыборкаМаршрутКонтролера.МаршрутКонтролера);
	
		ВыборкаДетальныеЗаписи = ВыборкаМаршрутКонтролера.Выбрать();	
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НоваяЗапись = НаборМаршрута.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, ВыборкаДетальныеЗаписи);
		КонецЦикла;
		
		НаборМаршрута.Записать(Ложь);
	КонецЦикла;  	
КонецПроцедуры

