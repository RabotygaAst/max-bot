#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
		
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
	
	энргРаботаСТочкамиУчетаСервер.УстановитьНаправлениеИспользованияТочекУчетаПоУмолчанию(ТочкиУчета);
	
	Ответственный 				= Пользователи.ТекущийПользователь();
		
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	ОчиститьВспомогательныеДанные();
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	МВТ = Новый МенеджерВременныхТаблиц;
	ИнициализироватьИсходныеДанныеДокумента(МВТ);	
	
	ЗаписатьДанныеАбонентов(МВТ);
	ЗаписатьАдресВМаршрутКонтролера(МВТ);
	ЗаписатьДанныеТочекУчета(МВТ);
	ЗаписатьДанныеТочекПоставок(МВТ);
	ЗаписатьНомераПломбПУ(МВТ);
	ЗаписатьВидДифференцированностиПриборовУчета(МВТ);
	ЗаписатьПоказанияПриборовУчета(МВТ);
	ЗаписатьЗначенияПлощадей(МВТ);
	ЗаписатьЛьготников(МВТ);
	ЗаписатьЖильцов(МВТ);
	ЗаписатьВзаиморасчеты(МВТ);
	ЗаписатьЗначенияНаправленийИзмеренийТУ(МВТ);
	ЗаписатьЗначенияФормулРасчетаТУ(МВТ);
	ЗаписатьПоставщикаУслуг(МВТ);	
	ЗаписатьПлательшикаУслуг(МВТ);
	ЗаписатьОрганизациюПоставщикаСтроений(МВТ);
	ЗаписатьВспомогательныеДанные();
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
	
КонецПроцедуры  

Процедура ОбработкаУдаленияПроведения(Отказ)
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст 	= 
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатковВзаиморасчеты.ДокументОплаты КАК ДокументОплаты
	|ИЗ
	|	Документ.энргВводНачальныхОстатков.Взаиморасчеты КАК энргВводНачальныхОстатковВзаиморасчеты
	|ГДЕ
	|	энргВводНачальныхОстатковВзаиморасчеты.Ссылка = &Ссылка
	|	И энргВводНачальныхОстатковВзаиморасчеты.Задолженность < 0
	|
	|СГРУППИРОВАТЬ ПО
	|	энргВводНачальныхОстатковВзаиморасчеты.ДокументОплаты";
	
	Результат 		= Запрос.Выполнить();
	Выборка 		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ДокументОплаты) Тогда
			ДокОб =  Выборка.ДокументОплаты.ПолучитьОбъект();
			ДокОб.Движения.энргАвансы.Очистить();
			ДокОб.Движения.энргАвансы.Записать();
			
			ДокОб.Движения.энргАвансыПоступившие.Очистить();
			ДокОб.Движения.энргАвансыПоступившие.Записать();
			
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияИсходныхДанныхДокумента

Процедура ИнициализироватьИсходныеДанныеДокумента(МВТ)
	ПараметрыЗапроса  	= Новый Структура("Ссылка", Ссылка);
	Схема 				= Неопределено;
	
	ПолучитьШапкуДокумента(Схема);
	ПолучитьТаблицуАбонентов(Схема);
	ПолучитьТаблицуТочекУчета(Схема);
	ПолучитьТаблицуШкалТочекУчета(Схема);
	
	энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса, МВТ);
КонецПроцедуры

Процедура ПолучитьШапкуДокумента(Схема)
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатков.Дата КАК Дата,
	|	энргВводНачальныхОстатков.Организация КАК Организация,
	|	энргВводНачальныхОстатков.Район КАК Район,
	|	энргВводНачальныхОстатков.МКД КАК МКД,
	|	энргВводНачальныхОстатков.ПериодНачисления КАК ПериодНачисления,
	|	энргВводНачальныхОстатков.Ссылка КАК Ссылка,
	|	энргВводНачальныхОстатков.Ответственный КАК Ответственный,
	|	энргВводНачальныхОстатков.Примечание КАК Примечание,
	|	энргВводНачальныхОстатков.Поставщик КАК Поставщик
	|ПОМЕСТИТЬ ШапкаДокумента
	|ИЗ
	|	Документ.энргВводНачальныхОстатков КАК энргВводНачальныхОстатков
	|ГДЕ
	|	энргВводНачальныхОстатков.Ссылка = &Ссылка");	
КонецПроцедуры  

Процедура ПолучитьТаблицуАбонентов(Схема)
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатковАбоненты.Ссылка КАК Ссылка,
	|	энргВводНачальныхОстатковАбоненты.IDСтроки КАК IDСтроки,
	|	энргВводНачальныхОстатковАбоненты.IDСтрокиРодитель КАК IDСтрокиРодитель,
	|	энргВводНачальныхОстатковАбоненты.Абонент КАК Абонент,
	|	энргВводНачальныхОстатковАбоненты.ГруппаАбонентов КАК ГруппаАбонентов,
	|	энргВводНачальныхОстатковАбоненты.ДатаОткрытияЛС КАК ДатаОткрытияЛС,
	|	энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
	|	энргВводНачальныхОстатковАбоненты.КоличествоКомнат КАК КоличествоКомнат,
	|	энргВводНачальныхОстатковАбоненты.КоличествоПроживающих КАК КоличествоПроживающих,
	|	энргВводНачальныхОстатковАбоненты.КоличествоПрописанных КАК КоличествоПрописанных,
	|	энргВводНачальныхОстатковАбоненты.КоличествоСобственников КАК КоличествоСобственников,
	|	энргВводНачальныхОстатковАбоненты.ТипСобственностиЖилья КАК ТипСобственностиЖилья,
	|	энргВводНачальныхОстатковАбоненты.Договор КАК Договор,
	|	энргВводНачальныхОстатковАбоненты.МаршрутКонтролера КАК МаршрутКонтролера,
	|	энргВводНачальныхОстатковАбоненты.СпособДоставкиЕПД КАК СпособДоставкиЕПД
	|ПОМЕСТИТЬ ТаблицаАбонентов
	|ИЗ
	|	Документ.энргВводНачальныхОстатков.Абоненты КАК энргВводНачальныхОстатковАбоненты
	|ГДЕ
	|	энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка");	
КонецПроцедуры

