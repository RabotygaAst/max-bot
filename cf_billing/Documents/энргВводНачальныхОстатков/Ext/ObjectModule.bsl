	|	ВложенныйЗапрос.СолидарнаяОплата КАК СолидарнаяОплата,
	|	ИСТИНА КАК Активна,
	|	энргВводНачальныхОстатков.Дата КАК Период
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргВводНачальныхОстатковЖильцы.ДатаНачалаДействия КАК Период,
	|		энргВводНачальныхОстатковЖильцы.Жилец КАК Жилец,
	|		энргВводНачальныхОстатковАбоненты.Абонент КАК Абонент,
	|		энргВводНачальныхОстатковЖильцы.ЛьготнаяКатегория КАК ЛьготнаяКатегория,
	|		энргВводНачальныхОстатковЖильцы.ПроцентЛьготы КАК ПроцентЛьготы,
	|		энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
	|		энргВводНачальныхОстатковЖильцы.СолидарнаяОплата КАК СолидарнаяОплата
	|	ИЗ
	|		Документ.энргВводНачальныхОстатков.Жильцы КАК энргВводНачальныхОстатковЖильцы
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
	|			ПО энргВводНачальныхОстатковЖильцы.IDСтрокиАбонента = энргВводНачальныхОстатковАбоненты.IDСтроки
	|				И (энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка)
	|				И (энргВводНачальныхОстатковЖильцы.Ссылка = &Ссылка)
	|				И (энргВводНачальныхОстатковЖильцы.СолидарнаяОплата)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|		ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)";
	
	Результат  						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 		
		Запись 						= Движения.энргСобственникиПомещений.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Выборка);		
	КонецЦикла;		
КонецПроцедуры

Процедура ЗаписатьВзаиморасчеты(МВТ)
	
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст 	= 
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатков.Организация КАК Организация,
	|	энргВводНачальныхОстатков.Район КАК Район,
	|	энргВводНачальныхОстатков.МКД КАК МКД,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.ПериодНачисления КАК Период,
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Поставщик КАК Поставщик,
	|	ВложенныйЗапрос.Задолженность КАК Сумма,
	|	энргВводНачальныхОстатков.Дата КАК ПериодРегистрации,
	|	энргВводНачальныхОстатков.Дата КАК Дата,
	|	ВложенныйЗапрос.ИсточникОплаты КАК ИсточникОплаты,
	|	ВложенныйЗапрос.ДокументОплаты КАК ДокументОплаты,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения
	|ПОМЕСТИТЬ ВТ_ВзаиморасчетыДляПроведения
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргВводНачальныхОстатковАбоненты.Абонент КАК Абонент,
	|		энргВводНачальныхОстатковВзаиморасчеты.ПериодНачисления КАК ПериодНачисления,
	|		энргВводНачальныхОстатковВзаиморасчеты.Поставщик КАК Поставщик,
	|		энргВводНачальныхОстатковВзаиморасчеты.Задолженность КАК Задолженность,
	|		энргВводНачальныхОстатковВзаиморасчеты.Услуга КАК Услуга,
	|		энргВводНачальныхОстатковВзаиморасчеты.ИсточникОплаты КАК ИсточникОплаты,
	|		энргВводНачальныхОстатковВзаиморасчеты.ДокументОплаты КАК ДокументОплаты
	|	ИЗ
	|		Документ.энргВводНачальныхОстатков.Взаиморасчеты КАК энргВводНачальныхОстатковВзаиморасчеты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
	|			ПО энргВводНачальныхОстатковВзаиморасчеты.IDСтрокиАбонента = энргВводНачальныхОстатковАбоненты.IDСтроки
	|				И энргВводНачальныхОстатковВзаиморасчеты.Ссылка = энргВводНачальныхОстатковАбоненты.Ссылка
	|				И (энргВводНачальныхОстатковВзаиморасчеты.Ссылка = &Ссылка)
	|				И (энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|		ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВзаиморасчетыДляПроведения.Организация КАК Организация,
	|	ВТ_ВзаиморасчетыДляПроведения.Район КАК Район,
	|	ВТ_ВзаиморасчетыДляПроведения.МКД КАК МКД,
	|	ВТ_ВзаиморасчетыДляПроведения.Абонент КАК Абонент,
	|	ВТ_ВзаиморасчетыДляПроведения.Услуга КАК Услуга,
	|	ВТ_ВзаиморасчетыДляПроведения.ПериодНачисления КАК Период,
	|	ВТ_ВзаиморасчетыДляПроведения.ПериодНачисления КАК ПериодНачисления,
	|	ВТ_ВзаиморасчетыДляПроведения.Поставщик КАК Поставщик,
	|	ВТ_ВзаиморасчетыДляПроведения.Сумма КАК Сумма,
	|	ВТ_ВзаиморасчетыДляПроведения.ПериодРегистрации КАК ПериодРегистрации,
	|	ВТ_ВзаиморасчетыДляПроведения.Дата КАК Дата,
	|	ВТ_ВзаиморасчетыДляПроведения.ИсточникОплаты КАК ИсточникОплаты,
	|	ВТ_ВзаиморасчетыДляПроведения.ДокументОплаты КАК ДокументОплаты,
	|	ВТ_ВзаиморасчетыДляПроведения.ВидДвижения КАК ВидДвижения
	|ИЗ
	|	ВТ_ВзаиморасчетыДляПроведения КАК ВТ_ВзаиморасчетыДляПроведения
	|ГДЕ
	|	ВТ_ВзаиморасчетыДляПроведения.Сумма > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВзаиморасчетыДляПроведения.Организация КАК Организация,
	|	ВТ_ВзаиморасчетыДляПроведения.Район КАК Район,
	|	ВТ_ВзаиморасчетыДляПроведения.МКД КАК МКД,
	|	ВТ_ВзаиморасчетыДляПроведения.Абонент КАК Абонент,
	|	ВТ_ВзаиморасчетыДляПроведения.Услуга КАК Услуга,
	|	ВТ_ВзаиморасчетыДляПроведения.ПериодНачисления КАК Период,
	|	ВТ_ВзаиморасчетыДляПроведения.ПериодНачисления КАК ПериодНачисления,
	|	ВТ_ВзаиморасчетыДляПроведения.Поставщик КАК Поставщик,
	|	-ВТ_ВзаиморасчетыДляПроведения.Сумма КАК Сумма,
	|	ВТ_ВзаиморасчетыДляПроведения.ПериодРегистрации КАК ПериодРегистрации,
	|	ВТ_ВзаиморасчетыДляПроведения.Дата КАК Дата,
	|	ВТ_ВзаиморасчетыДляПроведения.ИсточникОплаты КАК ИсточникОплаты,
	|	ВТ_ВзаиморасчетыДляПроведения.ДокументОплаты КАК ДокументОплаты,
	|	ВТ_ВзаиморасчетыДляПроведения.ВидДвижения КАК ВидДвижения
	|ИЗ
	|	ВТ_ВзаиморасчетыДляПроведения КАК ВТ_ВзаиморасчетыДляПроведения
	|ГДЕ
	|	ВТ_ВзаиморасчетыДляПроведения.Сумма < 0";
	
	Пакет 		= Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	Движения.энргВзаиморасчеты.Загрузить(Пакет[0].Выгрузить());
	Движения.энргВзаиморасчетыПоМесяцам.Загрузить(Пакет[1].Выгрузить());
	
	ЗаписатьАвансы(Пакет[2].Выгрузить());
	
КонецПроцедуры

