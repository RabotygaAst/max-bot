КонецПроцедуры

Процедура ЗаписатьПоставщикаУслуг(МВТ)
	Запрос  		= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатков.Организация КАК Организация,
	|	энргВводНачальныхОстатков.ПериодНачисления КАК ПериодНачисления,
	|	энргВводНачальныхОстатков.Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.ПериодУслуги КАК ПериодУслуги,
	|	энргВводНачальныхОстатков.Ссылка КАК Ссылка,
	|	ВложенныйЗапрос.ЭтоСоставнаяУслуга КАК ЭтоСоставнаяУслуга,
	|	ВложенныйЗапрос.IDСтроки КАК IDСтроки,
	|	ВложенныйЗапрос.Поставщик КАК Поставщик
	|ПОМЕСТИТЬ ДанныеТочекУчета
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
	|		энргВводНачальныхОстатковТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|		энргВводНачальныхОстатковТочкиУчета.Услуга КАК Услуга,
	|		энргВводНачальныхОстатковТочкиУчета.ЭтоСоставнаяУслуга КАК ЭтоСоставнаяУслуга,
	|		энргВводНачальныхОстатковТочкиУчета.IDСтроки КАК IDСтроки,
	|		энргВводНачальныхОстатковТочкиУчета.Поставщик КАК Поставщик,
	|		ВЫБОР
	|			КОГДА энргВводНачальныхОстатковТочкиУчета.ДатаПодключенияУслуги < энргВводНачальныхОстатковАбоненты.ДатаОткрытияЛС
	|				ТОГДА энргВводНачальныхОстатковАбоненты.ДатаОткрытияЛС
	|			ИНАЧЕ энргВводНачальныхОстатковТочкиУчета.ДатаПодключенияУслуги
	|		КОНЕЦ КАК ПериодУслуги
	|	ИЗ
	|		ТаблицаТочекУчета КАК энргВводНачальныхОстатковТочкиУчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
	|			ПО энргВводНачальныхОстатковТочкиУчета.IDСтрокиАбонента = энргВводНачальныхОстатковАбоненты.IDСтроки
	|				И (энргВводНачальныхОстатковТочкиУчета.Ссылка = &Ссылка)
	|				И (энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|		ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеТочекУчета.ПериодУслуги КАК Период,
	|	ДанныеТочекУчета.Организация КАК Организация,
	|	ДанныеТочекУчета.Район КАК Район,
	|	ДанныеТочекУчета.КлючПомещения КАК КлючПомещения,
	|	ДанныеТочекУчета.ТочкаУчета КАК ТочкаУчета,
	|	ВЫБОР
	|		КОГДА ДанныеТабличнойЧастиПоставщики.Ссылка ЕСТЬ NULL
	|			ТОГДА ДанныеТочекУчета.Услуга
	|		ИНАЧЕ ДанныеТабличнойЧастиПоставщики.ЧастьСоставнойУслуги
	|	КОНЕЦ КАК Услуга,
	|	ВЫБОР
	|		КОГДА ДанныеТабличнойЧастиПоставщики.Ссылка ЕСТЬ NULL
	|			ТОГДА ДанныеТочекУчета.Поставщик
	|		ИНАЧЕ ДанныеТабличнойЧастиПоставщики.Поставщик
	|	КОНЕЦ КАК Поставщик,
	|	ВЫБОР
	|		КОГДА ДанныеТабличнойЧастиПоставщики.Ссылка ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЧастьСоставной
	|ИЗ
	|	ДанныеТочекУчета КАК ДанныеТочекУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатков.ПоставщикиСоставныхУслуг КАК ДанныеТабличнойЧастиПоставщики
	|		ПО ДанныеТочекУчета.Ссылка = ДанныеТабличнойЧастиПоставщики.Ссылка
	|			И (ДанныеТочекУчета.ЭтоСоставнаяУслуга)
	|			И ДанныеТочекУчета.IDСтроки = ДанныеТабличнойЧастиПоставщики.IDСтроки";
	
	Результат  						= Запрос.Выполнить();
	Выборка  						= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		Запись 						= Движения.энргПоставщикиУслугАбонента.добавить();
		ЗаполнитьЗначенияСвойств(Запись,Выборка);
		Запись.Период 				= Выборка.Период;
		Запись.ПериодРегистрации	= Дата;
		Запись.ПериодНачисления		= ПериодНачисления;
	КонецЦикла; 	

КонецПроцедуры

Процедура ЗаписатьПлательшикаУслуг(МВТ)
