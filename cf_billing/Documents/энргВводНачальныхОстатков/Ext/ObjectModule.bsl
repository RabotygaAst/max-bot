	|	энргВводНачальныхОстатковФормулыРасчета.Коэффициент КАК Коэффициент,
	|	энргВводНачальныхОстатковФормулыРасчета.ТочкаУчета КАК ТочкаИсточник,
	|	энргВводНачальныхОстатковФормулыРасчета.Услуга КАК Услуга
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргВводНачальныхОстатков.Организация КАК Организация,
	|		энргВводНачальныхОстатков.ПериодНачисления КАК ПериодНачисления,
	|		энргВводНачальныхОстатков.Район КАК Район,
	|		энргВводНачальныхОстатков.МКД КАК МКД,
	|		ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|		ВложенныйЗапрос.Абонент КАК Абонент,
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		ВложенныйЗапрос.ПрименятьФормулуВсегда КАК ПрименятьФормулуВсегда,
	|		энргВводНачальныхОстатков.Дата КАК ПериодРегистрации,
	|		ВложенныйЗапрос.IDСтроки КАК IDСтроки,
	|		энргВводНачальныхОстатков.Ссылка КАК Ссылка,
	|		ВложенныйЗапрос.ПериодУслуги КАК ПериодУслуги
	|	ИЗ
	|		(ВЫБРАТЬ
	|			энргВводНачальныхОстатковАбоненты.КлючПомещения КАК КлючПомещения,
	|			энргВводНачальныхОстатковАбоненты.Абонент КАК Абонент,
	|			энргВводНачальныхОстатковТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|			энргВводНачальныхОстатковТочкиУчета.ПрименятьФормулуВсегда КАК ПрименятьФормулуВсегда,
	|			энргВводНачальныхОстатковТочкиУчета.IDСтроки КАК IDСтроки,
	|			ВЫБОР
	|				КОГДА энргВводНачальныхОстатковТочкиУчета.ДатаПодключенияУслуги < энргВводНачальныхОстатковАбоненты.ДатаОткрытияЛС
	|					ТОГДА энргВводНачальныхОстатковАбоненты.ДатаОткрытияЛС
	|				ИНАЧЕ энргВводНачальныхОстатковТочкиУчета.ДатаПодключенияУслуги
	|			КОНЕЦ КАК ПериодУслуги
	|		ИЗ
	|			ТаблицаТочекУчета КАК энргВводНачальныхОстатковТочкиУчета
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАбонентов КАК энргВводНачальныхОстатковАбоненты
	|				ПО энргВводНачальныхОстатковТочкиУчета.IDСтрокиАбонента = энргВводНачальныхОстатковАбоненты.IDСтроки
	|					И (энргВводНачальныхОстатковТочкиУчета.Ссылка = &Ссылка)
	|					И (энргВводНачальныхОстатковАбоненты.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ШапкаДокумента КАК энргВводНачальныхОстатков
	|			ПО (энргВводНачальныхОстатков.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатков.ФормулыРасчета КАК энргВводНачальныхОстатковФормулыРасчета
	|		ПО ВложенныйЗапрос.IDСтроки = энргВводНачальныхОстатковФормулыРасчета.IDСтрокиТочкиУчета
	|			И (энргВводНачальныхОстатковФормулыРасчета.Ссылка = &Ссылка)
	|			И ВложенныйЗапрос.Ссылка = энргВводНачальныхОстатковФормулыРасчета.Ссылка
	|ИТОГИ
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(ПериодНачисления),
	|	МАКСИМУМ(Район),
	|	МАКСИМУМ(КлючПомещения),
	|	МАКСИМУМ(ПериодРегистрации),
	|	МАКСИМУМ(Период)
	|ПО
	|	РассчитываемаяТочкаУчета";
	
	Результат 		= Запрос.Выполнить();
	ВыборкаРассчитываемаяТочкаУчета  		= Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаРассчитываемаяТочкаУчета.Следующий() Цикл 
		Выборка = ВыборкаРассчитываемаяТочкаУчета.Выбрать();
		Пока Выборка.Следующий() Цикл
			УстановитьЗначенияФормулыТУ(Выборка);
		КонецЦикла;
		
		Запись  						= Движения.энргРасчетныеСпособыТочекУчета.Добавить();
		Запись.Период  					= ВыборкаРассчитываемаяТочкаУчета.Период;
		Запись.Район					= ВыборкаРассчитываемаяТочкаУчета.Район;
		Запись.Организация				= ВыборкаРассчитываемаяТочкаУчета.Организация;
		Запись.КлючПомещения			= ВыборкаРассчитываемаяТочкаУчета.КлючПомещения;
		Запись.РасчетныйСпособ			= Истина;
		Запись.ПрименятьФормулуВсегда	= ВыборкаРассчитываемаяТочкаУчета.ПрименятьФормулуВсегда;
		Запись.ТочкаУчета 				= ВыборкаРассчитываемаяТочкаУчета.РассчитываемаяТочкаУчета; 
		Запись.ПериодРегистрации		= ВыборкаРассчитываемаяТочкаУчета.ПериодРегистрации;
		Запись.ПериодНачисления			= ВыборкаРассчитываемаяТочкаУчета.ПериодНачисления;
	КонецЦикла;
КонецПроцедуры

