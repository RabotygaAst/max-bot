// Эту переменную необходимо вставить в модуль
&НаКлиенте
Перем ДанныеДляПоискаВДеревьях;

&НаКлиенте
Перем МодифицировалиТУ;

&НаКлиенте 
Перем МодифицировалиТЧ;

#Область ПредопределенныеПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	энргЛокализацияСервер.ПриСозданииНаСервере_энргВводНачальныхОстатков(ЭтотОбъект);

	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
		КонецЕсли;
	КонецЕсли;
		
	// энргРаботаСПоставщиками {
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма,,,,"ДеревоТочекУчета");
	// энргРаботаСПоставщиками }

	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	Если Параметры.Свойство("Абонент") Тогда
		Элементы.Абоненты.ТекущаяСтрока = Объект.Абоненты.НайтиСтроки(Новый Структура("Абонент", Параметры.Абонент))[0].НомерСтроки - 1;
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
		яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
		энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета); 			
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"Абоненты");
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ФормулыРасчета");
	 
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервере(ЭтотОбъект, "Абоненты");	
	ЗаполнитьСвойстваТочекУчета(ТекущийОбъект);
	ЗаполнитьСвойстваПриборовУчета(ТекущийОбъект);
	
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета,ТекущийОбъект);	
	
	ПрочитатьДанныеУслугМКД(ТекущийОбъект.Организация, ТекущийОбъект.Район, ТекущийОбъект.МКД);
	
	ПустойКлючСтроки  = Новый ОписаниеТипов("УникальныйИдентификатор");
	ЗаполнитьДеревоНаОснованииОбъектаНаСервере("Абоненты", АбонентыДерево, ПустойКлючСтроки.ПривестиЗначение());
	
	ПустойКлючСтроки  = Новый ОписаниеТипов("УникальныйИдентификатор");
	ЗаполнитьДеревоНаОснованииОбъектаНаСервере("ТочкиУчета", ДеревоПоискаТочекУчета, ПустойКлючСтроки.ПривестиЗначение());
	
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("ЗначениеПлощадей",			ДеревоПоискаЗначениеПлощадей);
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("Взаиморасчеты",			ДеревоПоискаВзаиморасчеты);
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("ВидыБлагоустройстваТарифныеКатегории",	ДеревоПоискаВидыБлагоустройства);
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("Жильцы",					ДеревоПоискаЛьготники);
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("ШкалыПриборовУчета",		ДеревоПоискаШкалыПриборовУчета, "IDСтрокиТочкиУчета");
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("ПоказанияПриборовУчета",	ДеревоПоискаПоказанияПриборовУчета, "IDСтроки");
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("ЗначенияИзмерителей",		ДеревоПоискаЗначенияИзмерителей, "IDСтроки");
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("Измерители",				ДеревоПоискаИзмерители, "IDСтрокиТочкиУчета");
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("НомераПломб",				ДеревоПоискаНомераПломб, "IDСтрокиИзмерителя");
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("ФормулыРасчета",			ДеревоПоискаФормулыРасчета, "IDСтрокиТочкиУчета");
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("ПоставщикиСоставныхУслуг",	ДеревоПоискаПоставщикиСоставныхУслуг, "IDСтроки");
	ЗаполнитьДеревоПоискаНаОснованииОбъекта("РасчетСреднегоОбъема",		ДеревоПоискаРасчетСреднегоОбъема, "IDСтроки");
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьВидимостьСтроения(НЕ ЗначениеЗаполнено(Объект.МКД));
	Если ТипЗнч(ДанныеДляПоискаВДеревьях) <> Тип("Структура") Тогда
		ИндексироватьДерево();
	КонецЕсли;
	МодифицировалиТУ = Ложь;
	МодифицировалиТЧ = Новый Структура;
	МодифицировалиТЧ.Вставить("Абоненты",					Ложь);
	МодифицировалиТЧ.Вставить("Взаиморасчеты",				Ложь);
	МодифицировалиТЧ.Вставить("ТочкиУчета",					Ложь);
	МодифицировалиТЧ.Вставить("ЗначениеПлощадей",			Ложь);
	МодифицировалиТЧ.Вставить("ВидыБлагоустройства",		Ложь);
	МодифицировалиТЧ.Вставить("Жильцы",						Ложь);
	МодифицировалиТЧ.Вставить("ШкалыПриборовУчета",			Ложь);
	МодифицировалиТЧ.Вставить("ПоказанияПриборовУчета",		Ложь);
	МодифицировалиТЧ.Вставить("ЗначенияИзмерителей",		Ложь);
	МодифицировалиТЧ.Вставить("ФормулыРасчета",				Ложь);
	МодифицировалиТЧ.Вставить("ПоставщикиСоставныхУслуг",	Ложь);
	МодифицировалиТЧ.Вставить("РасчетСреднегоОбъема",		Ложь);
	МодифицировалиТЧ.Вставить("Измерители",					Ложь);
	МодифицировалиТЧ.Вставить("НомераПломб",				Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	//	Объект.ТочкиУчета.Очистить();
	Если МодифицировалиТЧ.Абоненты Тогда
		Объект.Абоненты.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("Абоненты", АбонентыДерево.ПолучитьЭлементы(), Неопределено);
	КонецЕсли;
	
	Если МодифицировалиТЧ.ЗначениеПлощадей Тогда
		Объект.ЗначениеПлощадей.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("ЗначениеПлощадей", ДеревоПоискаЗначениеПлощадей.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.Взаиморасчеты Тогда
		Объект.Взаиморасчеты.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("Взаиморасчеты", ДеревоПоискаВзаиморасчеты.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.ВидыБлагоустройства Тогда
		Объект.ВидыБлагоустройстваТарифныеКатегории.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("ВидыБлагоустройстваТарифныеКатегории", ДеревоПоискаВидыБлагоустройства.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.Жильцы Тогда
		Объект.Жильцы.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("Жильцы", ДеревоПоискаЛьготники.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.ШкалыПриборовУчета Тогда
		Объект.ШкалыПриборовУчета.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("ШкалыПриборовУчета", ДеревоПоискаШкалыПриборовУчета.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.ПоказанияПриборовУчета Тогда
		Объект.ПоказанияПриборовУчета.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("ПоказанияПриборовУчета", ДеревоПоискаПоказанияПриборовУчета.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.ЗначенияИзмерителей Тогда
		Объект.ЗначенияИзмерителей.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("ЗначенияИзмерителей", ДеревоПоискаЗначенияИзмерителей.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.Измерители Тогда
		Объект.Измерители.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("Измерители", ДеревоПоискаИзмерители.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.НомераПломб Тогда
		Объект.НомераПломб.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("НомераПломб", ДеревоПоискаНомераПломб.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.ФормулыРасчета Тогда
		Объект.ФормулыРасчета.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("ФормулыРасчета", ДеревоПоискаФормулыРасчета.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.ПоставщикиСоставныхУслуг Тогда
		Объект.ПоставщикиСоставныхУслуг.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("ПоставщикиСоставныхУслуг", ДеревоПоискаПоставщикиСоставныхУслуг.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТЧ.РасчетСреднегоОбъема Тогда
		Объект.РасчетСреднегоОбъема.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("РасчетСреднегоОбъема", ДеревоПоискаРасчетСреднегоОбъема.ПолучитьЭлементы(), Неопределено, Истина);
	КонецЕсли;
	
	Если МодифицировалиТУ Тогда		
		// удаляем старые строки
		ПустойКлючСтроки  = Новый ОписаниеТипов("УникальныйИдентификатор");
		отб = Новый Структура("IDСтрокиАбонента,IDСтрокиРодитель", ТекIDАбонента, ПустойКлючСтроки.ПривестиЗначение());
		ВершиныДляУдаления = НайтиСтрокиДерева("ДеревоПоискаТочекУчета", отб);
		
		Если ЗначениеЗаполнено(ВершиныДляУдаления) Тогда
			ВсеВершины = ДеревоПоискаТочекУчета.ПолучитьЭлементы();
			Для Каждого ТекВершина Из ВершиныДляУдаления Цикл
				Если ВсеВершины.Индекс(ТекВершина) <> -1 Тогда
					ВсеВершины.Удалить(ВсеВершины.Индекс(ТекВершина));
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		// добавляем новые строки
		ДобавитьСтрокиВДеревоПоискаТочекУчета(ДеревоТочекУчета, ДеревоПоискаТочекУчета);
		
		мИмёнПолей = Новый Массив;
		мИмёнПолей.Добавить("IDСтрокиАбонента");
		мИмёнПолей.Добавить("IDСтрокиРодитель");
		соотИ = Новый Соответствие;
		ИндексироватьВетку("ДеревоПоискаТочекУчета",	мИмёнПолей,	соотИ); // основная рабочая
		
		МодифицировалиТУ = Ложь;
	КонецЕсли;
	
	Если МодифицировалиТЧ.ТочкиУчета Тогда
		Объект.ТочкиУчета.Очистить();
		ЗаполнитьОбъектНаОснованииДерева("ТочкиУчета", ДеревоПоискаТочекУчета.ПолучитьЭлементы(), Неопределено);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	энргПользовательскийВводСервер.ЗаписатьПараметрыАбонента(Объект.Абоненты, ТекущийОбъект);	
	//энргПользовательскийВводСервер.ЗаписатьПараметрыТочекИПриборовУчета(Объект.ТочкиУчета, ТекущийОбъект);
	ЗаписатьПараметрыТочекИПриборовУчета(ТекущийОбъект);
	энргШкалыТарифныеЗоныСервер.ЗаполнитьОбъектПоПредставлениюФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 		
		// создаем абонента
		НовыеАбоненты 						= Новый Массив;
		//МаршрутыДляЗаписи					= Новый Соответствие;
		Для Каждого СтрокаАбонента Из ТекущийОбъект.Абоненты Цикл
			Если Не ЗначениеЗаполнено(СтрокаАбонента.Абонент) И ТекущийОбъект.Абоненты.НайтиСтроки(Новый Структура("IDСтрокиРодитель", СтрокаАбонента.IDСтроки)).Количество() = 0 Тогда
				Индекс  					= СтрокаАбонента.НомерСтроки;
				СтрокаАбонента.Абонент 		= Справочники.энргАбоненты.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеАбоненты.Добавить(Индекс);
			КонецЕсли;
			// заполнить Маршрут
			//Если ЗначениеЗаполнено(СтрокаАбонента.МаршрутКонтролера) Тогда
			//	МаршрутСсылка = СтрокаАбонента.МаршрутКонтролера;
			//	Если МаршрутСсылка.КлючПомещений.Найти(СтрокаАбонента.КлючПомещения, "КлючПомещения") = Неопределено Тогда
			//		
			//		МаршрутОбъект = МаршрутыДляЗаписи.Получить(МаршрутСсылка);
			//		Если МаршрутОбъект = Неопределено Тогда
			//			МаршрутОбъект	= МаршрутСсылка.ПолучитьОбъект();
			//		КонецЕсли;
			//		
			//		СтрокаМаршрута	= МаршрутОбъект.КлючПомещений.Добавить();
			//		СтрокаМаршрута.КлючПомещения	= СтрокаАбонента.КлючПомещения;
			//		МаршрутыДляЗаписи.Вставить(МаршрутСсылка, МаршрутОбъект);
			//	КонецЕсли;
			//	
			//КонецЕсли;
		КонецЦикла;					
		
		//Для Каждого ТекМаршрут Из МаршрутыДляЗаписи Цикл
		//	ТекМаршрут.Значение.Записать();
		//КонецЦикла;
	//	энргРаботаСприборамиУчетаСервер.НайтиПриборыУчетаПоПараметрам(ТекущийОбъект,"ТочкиУчета",Отказ);
		
		НовыеТочкиУчета						= Новый Массив;
		НовыеПриборыУчета 					= Новый Массив;
		
		Для Каждого СтрокаТочкиУчета Из ТекущийОбъект.ТочкиУчета Цикл
			Если Не ЗначениеЗаполнено(СтрокаТочкиУчета.ТочкаУчета) Тогда
				СтрокаТочкиУчета.ТочкаУчета = Справочники.энргТочкиУчета.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеТочкиУчета.Добавить(СтрокаТочкиУчета.НомерСтроки); 
				ТекущийОбъект.ДополнительныеСвойства.ИзмененныеТУ.Добавить(СтрокаТочкиУчета.ТочкаУчета);
			КонецЕсли;
			
			Если Не ПустаяСтрока(СтрокаТочкиУчета.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаТочкиУчета.ПриборУчета) Тогда
				СтрокаТочкиУчета.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеПриборыУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
			КонецЕсли;			
		КонецЦикла;
		
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеАбоненты", 		НовыеАбоненты);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеТочкиУчета", 	НовыеТочкиУчета);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеПриборыУчета", 	НовыеПриборыУчета);		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Не Отказ и ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		// создаем абонента
		энргРаботаСЛицевымСчетомСервер.ПроверитьИСоздатьАбонентаИзКоллекции(ТекущийОбъект,"Абоненты",отказ);
		энргРаботаСТочкамиУчетаСервер.СоздатьТочкиУчета(ТекущийОбъект,"ТочкиУчета" ,Отказ);
		энргРаботаСприборамиУчетаСервер.СоздатьПриборыУчета(ТекущийОбъект,"ТочкиУчета", Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"Абоненты");
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервере(ЭтотОбъект, "Абоненты");	
	энргРаботаСТочкамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета"); 	
	//энргРаботаСприборамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
	ЗаполнитьСвойстваТочекУчета(ТекущийОбъект);
	ЗаполнитьСвойстваПриборовУчета(ТекущийОбъект);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
КонецПроцедуры

#КонецОбласти

