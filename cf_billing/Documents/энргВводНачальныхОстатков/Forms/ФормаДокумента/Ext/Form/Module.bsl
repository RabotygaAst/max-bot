&НаСервере
Процедура ЗаписатьПараметрыТочекИПриборовУчета(ТекущийОбъект)
	
	Сч 														= 0;
	ИзмененныеТУ = Новый Массив;
	Для Каждого СтрокаТочки Из Объект.ТочкиУчета Цикл
		ЗаписываемаяСтрока  								= ТекущийОбъект.ТочкиУчета[Сч];
		
		ДанныеТочкиУчета 									= Новый Структура(ПолучаемыеСвойстваТочекУчета());
		СоотвествиеРеквизитов 								= СоотвествиеРеквизитовСвойствамТочкиУчета(); 		
		Для Каждого КлючЗначение Из СоотвествиеРеквизитов Цикл			
			ДанныеТочкиУчета[КлючЗначение.Значение] 		= СтрокаТочки[КлючЗначение.Ключ];			
		КонецЦикла; 		
		ЗаписываемаяСтрока.ОписаниеТочки 					= Обработки.энргТочкиУчетаМенеджер.ЗначенияРеквизитовОбъектаВСтрокуJSON(ДанныеТочкиУчета);			
				
		СвойстваПрибора 									= ПолучаемыеСвойстваПриборовУчета();
		ДанныеПрибораУчета 									= Новый Структура(СвойстваПрибора);
		СоотвествиеРеквизитов 								= СоотвествиеРеквизитовСвойствамПрибораУчета();
		Для Каждого КлючЗначение Из СоотвествиеРеквизитов Цикл			
			ДанныеПрибораУчета[КлючЗначение.Значение] 		= СтрокаТочки[КлючЗначение.Ключ];						
		КонецЦикла;
		ДанныеПрибораУчета.Вставить("ДополнительныеСвойства",	Новый Структура("НеОтправлятьВГИСЖКХ", Истина));
		
		ЗаписываемаяСтрока.ОписаниеПрибора 					= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектаВСтрокуJSON(ДанныеПрибораУчета);		
		
		Если СтрокаТочки.СтрокаИзменена И ЗначениеЗаполнено(СтрокаТочки.ТочкаУчета) Тогда
			ИзмененныеТУ.Добавить(СтрокаТочки.ТочкаУчета);
		КонецЕсли; 
		Сч 													= Сч + 1;		
	КонецЦикла;
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ИзмененныеТУ", 		ИзмененныеТУ);
КонецПроцедуры


&НаСервере
Функция ПолучаемыеСвойстваПриборовУчета() 
	ПолучаемыеСвойстваПриборовУчета = "
	|Код,ТипПрибораУчета,ВидКанальности,ТипУзлаУчета,РегистрируетОбъем,
	|КодАСКУЭ,СобственникАСКУЭ,СобственникСИ";	
	Возврат ПолучаемыеСвойстваПриборовУчета;
КонецФункции

&НаСервере
Функция ПолучаемыеСвойстваТочекУчета() 
	ПолучаемыеСвойстваТочекУчета 	= "
	|Наименование,Расположение";	
	Возврат ПолучаемыеСвойстваТочекУчета;
КонецФункции

&НаСервере
Процедура ЗаполнитьСвойстваТочекУчета(Знач ТекущийОбъект)
	
	ПолучаемыеСвойстваТочекУчета 	= ПолучаемыеСвойстваТочекУчета();
	мТочкиУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.ТочкиУчета.Выгрузить().ВыгрузитьКолонку("ТочкаУчета"));	
	СвойстваТочекУчета 				= Обработки.энргТочкиУчетаМенеджер.ЗначенияРеквизитовОбъектов(мТочкиУчета, ПолучаемыеСвойстваТочекУчета);
	ЗаполнитьДанныеФормыПоСвойствамТочекУчета(Объект.ТочкиУчета, СвойстваТочекУчета);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеФормыПоСвойствамТочекУчета(Коллекция, СвойстваТочекУчета)
	
	СоотвествиеРеквизитовСвойств 								= СоотвествиеРеквизитовСвойствамТочкиУчета();
	
	Для Каждого СтрокаКоллекции Из Коллекция Цикл
		
		Если ЗначениеЗаполнено(СтрокаКоллекции.ТочкаУчета) Тогда
			СвойстваТочкиУчета 									= СвойстваТочекУчета[СтрокаКоллекции.ТочкаУчета];		
		Иначе
			СвойстваТочкиУчета 									= Обработки.энргТочкиУчетаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(СтрокаКоллекции.ОписаниеТочки);
		КонецЕсли; 
		
		Если СвойстваТочкиУчета = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого КлючЗначение Из СоотвествиеРеквизитовСвойств Цикл
			Если СвойстваТочкиУчета.Свойство(КлючЗначение.Значение) Тогда
				СтрокаКоллекции[КлючЗначение.Ключ] 	= СвойстваТочкиУчета[КлючЗначение.Значение];
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваПриборовУчета(Знач ТекущийОбъект)
	
	Перем мПриборыУчета, ПолучаемыеСвойстваПриборовУчета, СвойстваПриборовУчета;
	       	
	ПолучаемыеСвойстваПриборовУчета = ПолучаемыеСвойстваПриборовУчета();	
	мПриборыУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.ТочкиУчета.Выгрузить().ВыгрузитьКолонку("ПриборУчета"));
	СвойстваПриборовУчета 			= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектов(мПриборыУчета, ПолучаемыеСвойстваПриборовУчета);
	ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Объект.ТочкиУчета,СвойстваПриборовУчета);
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Коллекция,СвойстваПриборовУчета) 
	
	СоотвествиеРеквизитовСвойств 								= СоотвествиеРеквизитовСвойствамПрибораУчета();
	
	Для Каждого СтрокаКоллекции Из Коллекция Цикл
		
		Если ЗначениеЗаполнено(СтрокаКоллекции.ПриборУчета) Тогда
			СвойстваПрибора 									= СвойстваПриборовУчета[СтрокаКоллекции.ПриборУчета];		
		Иначе
			СвойстваПрибора 									= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(СтрокаКоллекции.ОписаниеПрибора);
		КонецЕсли;
			
		Если СвойстваПрибора = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого КлючЗначение Из СоотвествиеРеквизитовСвойств Цикл
			Если СвойстваПрибора.Свойство(КлючЗначение.Значение) Тогда
				СтрокаКоллекции[КлючЗначение.Ключ] 	= СвойстваПрибора[КлючЗначение.Значение];
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла; 	
	
КонецПроцедуры


&НаСервере
Функция СоотвествиеРеквизитовСвойствамТочкиУчета()
	Возврат Новый Структура("НаименованиеТочки,Расположение","Наименование","Расположение");
КонецФункции

&НаСервере
Функция СоотвествиеРеквизитовСвойствамПрибораУчета()
	Возврат Новый Структура("ЗаводскойНомер, ТипПрибораУчета, ВидКанальности, РегистрируетОбъем", "Код", "ТипПрибораУчета", "ВидКанальности", "РегистрируетОбъем");
КонецФункции

#КонецОбласти

#Область РаботаСДеревьями

#Область ЗаполнениеТЧИзДанныхФормы

&НаКлиенте
Процедура ЗаполнитьОбъектНаОснованииДерева(НазваниеТЧ, Строки, Родитель, ТолькоПервыйУровень = Ложь)
	
	Для Каждого Строка Из Строки Цикл 		
		СтрокаТочки  						= Объект[НазваниеТЧ].Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТочки, Строка);
		Если Не Родитель = Неопределено Тогда
			СтрокаТочки.IDСтрокиРодитель	= Родитель;
		КонецЕсли;
		Если Не ТолькоПервыйУровень Тогда
			ЗаполнитьОбъектНаОснованииДерева(НазваниеТЧ, Строка.ПолучитьЭлементы(), Строка.IDСтроки, ТолькоПервыйУровень);
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАбонентовНаОснованииДереваАбонентов(Строки, Родитель)
	
	Для Каждого Строка Из Строки Цикл 		
		СтрокаТочки  						= Объект.Абоненты.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТочки, Строка);
		Если Не Родитель = Неопределено Тогда
			СтрокаТочки.IDСтрокиРодитель	= Родитель;			
		КонецЕсли;
		ЗаполнитьАбонентовНаОснованииДереваАбонентов(Строка.ПолучитьЭлементы(), Строка.IDСтроки);
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти

#Область ЗаполнениеДеревьев
&НаСервере
Процедура ЗаполнитьДеревоНаОснованииОбъектаНаСервере(НазваниеТЧ, СтрокаРодитель, Родитель)
	//пАбоненты = РеквизитФормыВЗначение("Объект").Абоненты;
	пАбоненты = Объект[НазваниеТЧ].Выгрузить();
	пАбоненты.Индексы.Добавить("IDСтрокиРодитель");
	ЗаполнитьДеревоНаОснованииОбъектаРекурсивно(пАбоненты, СтрокаРодитель, Родитель)
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоНаОснованииОбъектаРекурсивно(ТекущийОбъект, СтрокаРодитель, Родитель)
	//пАбоненты = РеквизитФормыВЗначение("Объект").Абоненты;
	Вершины 			= ТекущийОбъект.НайтиСтроки(Новый Структура("IDСтрокиРодитель", Родитель));
	//Вершины 			= ТекущийОбъект.Абоненты.НайтиСтроки(Новый Структура("IDСтрокиРодитель", Родитель));
	Строки  			= СтрокаРодитель.ПолучитьЭлементы();
	
	Для Сч = 0 По Вершины.ВГраница() Цикл
		Если ЗначениеЗаполнено(Вершины[Сч].IDСтроки) Тогда
			СтрокаДерева  	= Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДерева, Вершины[Сч]);
			ЗаполнитьДеревоНаОснованииОбъектаРекурсивно(ТекущийОбъект, СтрокаДерева, Вершины[Сч].IDСтроки);
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

&Наклиенте
Процедура ЗаполнитьДеревоУслугНаОснованииТочекУчетаНаКлиенте(ТекущийОбъект, СтрокаРодитель, Родитель, IDСтрокиАбонента)
	
	отб = Новый Структура("IDСтрокиАбонента,IDСтрокиРодитель", IDСтрокиАбонента, Родитель);
	Вершины = НайтиСтрокиДерева("ДеревоПоискаТочекУчета", отб);
	
	Строки	= СтрокаРодитель.ПолучитьЭлементы();
	
	Если Вершины <> Неопределено Тогда
		Для Сч = 0 По Вершины.ВГраница() Цикл
			Если ЗначениеЗаполнено(Вершины[Сч].IDСтроки) Тогда
				СтрокаДерева  	= Строки.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаДерева, Вершины[Сч]);
				ЗаполнитьДеревоУслугНаОснованииТочекУчетаНаКлиенте(ТекущийОбъект, СтрокаДерева, Вершины[Сч].IDСтроки, IDСтрокиАбонента);
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
КонецПроцедуры

&Наклиенте
Процедура ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте(НазваниеДерева, Строки, IDСтроки, НазваниеIDСтроки = "IDСтрокиАбонента")
	
	отб = Новый Структура(НазваниеIDСтроки, IDСтроки);
	Вершины = НайтиСтрокиДерева(НазваниеДерева, отб);
		
	Если Вершины <> Неопределено Тогда
		Для Сч = 0 По Вершины.ВГраница() Цикл
			Если ЗначениеЗаполнено(Вершины[Сч][НазваниеIDСтроки]) Тогда
				СтрокаТЗ  	= Строки.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЗ, Вершины[Сч]);
				СтрокаТЗ.ИдентификаторСтроки = Вершины[Сч].ПолучитьИдентификатор();	// для удаления 
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоПоискаНаОснованииОбъекта(НазваниеТЧ, СтрокаРодитель, НазваниеIDСтроки = "IDСтрокиАбонента")
	ТЗТекущийОбъект = Объект[НазваниеТЧ].Выгрузить();
	
	Строки	= СтрокаРодитель.ПолучитьЭлементы();
	
	Для Каждого ТекСтрока Из ТЗТекущийОбъект Цикл
		Если ЗначениеЗаполнено(ТекСтрока[НазваниеIDСтроки]) Тогда
			СтрокаДерева  	= Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДерева, ТекСтрока);
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтрокуВДеревеПоиска(ДеревоПоиска, НазваниеДереваПоиска, IDСтроки, ИдентификаторСтроки)
	// Надо удалить в ДеревеПоиска
	ВеткаДляУдаления = ДеревоПоиска.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если ВеткаДляУдаления <> Неопределено Тогда 
		ДеревоПоиска.ПолучитьЭлементы().Удалить(ВеткаДляУдаления);
	КонецЕсли;
	
	// Надо удалить в Структуре поиска
	соотДанных	= ДанныеДляПоискаВДеревьях[НазваниеДереваПоиска];
	рИмеющееся	= соотДанных.Получить(IDСтроки);
	Если рИмеющееся <> Неопределено Тогда 
		Для сч = 0 по рИмеющееся.ВГраница() Цикл
			Если рИмеющееся[сч].ПолучитьИдентификатор() = ИдентификаторСтроки Тогда
				рИмеющееся.Удалить(сч);
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	ДанныеДляПоискаВДеревьях.Вставить(НазваниеДереваПоиска,соотДанных);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСтрокуВДеревоПоиска(ДеревоПоиска, НазваниеДереваПоиска, ТекущиеДанные, НазваниеIDСтроки = "IDСтрокиАбонента")
	
	НовВетка = ДеревоПоиска.ПолучитьЭлементы().Добавить();
	ЗаполнитьЗначенияСвойств(НовВетка, ТекущиеДанные);
	ТекущиеДанные.ИдентификаторСтроки = НовВетка.ПолучитьИдентификатор();
	
	// добавляем текущую ветку к имеющимся
	рКлючПолей	= НовВетка[НазваниеIDСтроки];
	соотДанных	= ДанныеДляПоискаВДеревьях[НазваниеДереваПоиска];
	рИмеющееся	= соотДанных.Получить(рКлючПолей);
	Если рИмеющееся = Неопределено Тогда 
		рИмеющееся	= Новый Массив; 
	КонецЕсли;
	
	рИмеющееся.Добавить(НовВетка);
	соотДанных.Вставить(рКлючПолей,рИмеющееся);
	ДанныеДляПоискаВДеревьях.Вставить(НазваниеДереваПоиска,соотДанных);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСтрокиВДеревоПоискаТочекУчета(ТекущийОбъект, СтрокаРодитель)
	
	ВершиныДляДобавления = ТекущийОбъект.ПолучитьЭлементы();
	Строки = СтрокаРодитель.ПолучитьЭлементы();
	Для Каждого ТекВершина Из ВершиныДляДобавления Цикл
		Если ЗначениеЗаполнено(ТекВершина.IDСтроки) Тогда
			СтрокаДерева  	= Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДерева, ТекВершина);
			ДобавитьСтрокиВДеревоПоискаТочекУчета(ТекВершина, СтрокаДерева);
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры

