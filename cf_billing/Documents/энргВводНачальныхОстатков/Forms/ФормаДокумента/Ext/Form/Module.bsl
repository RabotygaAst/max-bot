&НаКлиенте
Процедура ТочкиУчетаВидКанальностиПриИзменении(Элемент)
	
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	ВидКанальности 							= ТекущиеДанные.ВидКанальности;
	СоставКанальности 						= энргРаботаСТочкамиУчетаСервер.СоставКанальности(ВидКанальности);
	
	Для Каждого ТекСтрока Из ТЗШкалыПриборовУчета Цикл
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаШкалыПриборовУчета, "ДеревоПоискаШкалыПриборовУчета", ТекСтрока.IDСтроки, ТекСтрока.ИдентификаторСтроки);
	КонецЦикла;
	
	ТЗШкалыПриборовУчета.Очистить();
	для Каждого Шкала из СоставКанальности цикл		
		СтрокаШкалы 						= ТЗШкалыПриборовУчета.Добавить();
		СтрокаШкалы["IDСтрокиТочкиУчета"]	= ТекущиеДанные.IDСтроки;
		СтрокаШкалы.Шкала		 			= Шкала;
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаШкалыПриборовУчета, "ДеревоПоискаШкалыПриборовУчета", СтрокаШкалы, "IDСтрокиТочкиУчета");
	КонецЦикла;

	
КонецПроцедуры

