&НаКлиенте
Процедура ШкалыПриборовУчетаПриАктивизацииСтроки(Элемент)
	
 	ТекущиеДанные  									= Элементы["ШкалыПриборовУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ТЗПоказанияПриборовУчета.Очистить();
		Возврат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
		ТекущиеДанные.IDСтроки 						= Новый УникальныйИдентификатор;
	КонецЕсли;
			
	ТЗПоказанияПриборовУчета.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаПоказанияПриборовУчета", ТЗПоказанияПриборовУчета, ТекущиеДанные.IDСтроки, "IDСтроки");
	
	ТЗРасчетСреднегоОбъема.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаРасчетСреднегоОбъема", ТЗРасчетСреднегоОбъема, ТекущиеДанные.IDСтроки, "IDСтроки");

КонецПроцедуры

