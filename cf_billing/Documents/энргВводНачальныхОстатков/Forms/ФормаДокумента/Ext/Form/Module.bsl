&НаКлиенте
Процедура МКДПриИзменении(Элемент)
	
	УстановитьВидимостьСтроения(НЕ ЗначениеЗаполнено(Объект.МКД));
	
	ПустоеПомещение 							= ПредопределенноеЗначение("Справочник.энргПомещения.ПустаяСсылка");
	ПустойКлючПомещения 						= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
	Для Каждого СтрокаАбонента Из Объект.Абоненты Цикл
		Если ЗначениеЗаполнено(Объект.МКД) Тогда
			Если НЕ СтрокаАбонента.Строение  = Объект.МКД Тогда
				СтрокаАбонента.Строение  		= Объект.МКД;
				СтрокаАбонента.Помещение 		= ПустоеПомещение;
				СтрокаАбонента.КлючПомещения 	= ПустойКлючПомещения; 
			КонецЕсли;			
		КонецЕсли;		
	КонецЦикла;
	
	ПрочитатьДанныеУслугМКД(Объект.Организация, Объект.Район, Объект.МКД);
	
КонецПроцедуры

#КонецОбласти

#Область СобытияТЧ_Абоненты

&НаКлиенте
Процедура АбонентыСтроениеПриИзменении(Элемент)
	
	ТекущиеДанные 				= Элементы.Абоненты.ТекущиеДанные;
