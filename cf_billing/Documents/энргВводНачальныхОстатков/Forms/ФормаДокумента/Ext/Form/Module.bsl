		Возврат;
	КонецЕсли;
		
	Строение 					= ТекущиеДанные.Строение;
	Помещение 					= ТекущиеДанные.Помещение;
	ДанныеСтроения				= энргПользовательскийВводСервер.ПрочитатьКлючПомещения(Строение,Помещение);
	ТекущиеДанные.КлючПомещения	= ДанныеСтроения.КлючПомещения;
	
КонецПроцедуры

&НаКлиенте
Процедура АбонентыПомещениеПриИзменении(Элемент)
	ТекущиеДанные 				= Элементы.Абоненты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Строение 					= ТекущиеДанные.Строение;
	Помещение 					= ТекущиеДанные.Помещение;
	ДанныеСтроения				= энргПользовательскийВводСервер.ПрочитатьКлючПомещения(Строение, Помещение);
	ТекущиеДанные.КлючПомещения	= ДанныеСтроения.КлючПомещения;
	
КонецПроцедуры

&НаКлиенте
Процедура АбонентыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда
		ТекущиеДанные  				= Элементы.Абоненты.ТекущиеДанные;
		ТекущиеДанные.IDСтроки 		= Новый УникальныйИдентификатор;
		
		Если ЗначениеЗаполнено(Объект.МКД) Тогда
			 ТекущиеДанные.Строение = Объект.МКД;
		КонецЕсли;		
	КонецЕсли;
	
