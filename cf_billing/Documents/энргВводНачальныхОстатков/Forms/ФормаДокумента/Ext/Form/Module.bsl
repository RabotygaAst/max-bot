&НаКлиенте
Процедура АбонентыПередУдалением(Элемент, Отказ)
	МодифицировалиТЧ.Абоненты = Истина;
КонецПроцедуры

&НаКлиенте
Процедура АбонентыПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные  = Элементы.Абоненты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
		ТекущиеДанные.IDСтроки 				= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	Если ТекIDАбонента = ТекущиеДанные.IDСтроки Тогда
		Возврат;
	КонецЕсли;		
	
	Если ТипЗнч(ДанныеДляПоискаВДеревьях) <> Тип("Структура") Тогда
		ИндексироватьДерево();
		МодифицировалиТУ = Ложь;
		МодифицировалиТЧ = Новый Структура;
		МодифицировалиТЧ.Вставить("Абоненты", Ложь);
		МодифицировалиТЧ.Вставить("Взаиморасчеты", Ложь);
		МодифицировалиТЧ.Вставить("ТочкиУчета", Ложь);
		МодифицировалиТЧ.Вставить("ЗначениеПлощадей", Ложь);
		МодифицировалиТЧ.Вставить("ВидыБлагоустройства", Ложь);
		МодифицировалиТЧ.Вставить("Жильцы", Ложь);
		МодифицировалиТЧ.Вставить("ШкалыПриборовУчета", Ложь);
		МодифицировалиТЧ.Вставить("ЗначенияИзмерителей", Ложь);
		МодифицировалиТЧ.Вставить("Измерители", Ложь);
		МодифицировалиТЧ.Вставить("НомераПломб", Ложь);
		МодифицировалиТЧ.Вставить("ФормулыРасчета", Ложь);
		МодифицировалиТЧ.Вставить("ПоставщикиСоставныхУслуг", Ложь);
		МодифицировалиТЧ.Вставить("РасчетСреднегоОбъема", Ложь);
	КонецЕсли;
	
	Если МодифицировалиТУ Тогда		
		// удаляем старые строки
		ПустойКлючСтроки  = Новый ОписаниеТипов("УникальныйИдентификатор");
		отб = Новый Структура("IDСтрокиАбонента,IDСтрокиРодитель", ТекIDАбонента, ПустойКлючСтроки.ПривестиЗначение());
		ВершиныДляУдаления = НайтиСтрокиДерева("ДеревоПоискаТочекУчета", отб);
		
		Если ЗначениеЗаполнено(ВершиныДляУдаления) Тогда
			ВсеВершины = ДеревоПоискаТочекУчета.ПолучитьЭлементы();
			Для Каждого ТекВершина Из ВершиныДляУдаления Цикл
				Если ВсеВершины.Индекс(ТекВершина) <> -1 Тогда
					ВсеВершины.Удалить(ВсеВершины.Индекс(ТекВершина));
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		// добавляем новые строки
		ДобавитьСтрокиВДеревоПоискаТочекУчета(ДеревоТочекУчета, ДеревоПоискаТочекУчета);
		
		мИмёнПолей = Новый Массив;
		мИмёнПолей.Добавить("IDСтрокиАбонента");
		мИмёнПолей.Добавить("IDСтрокиРодитель");
		соотИ = Новый Соответствие;
		ИндексироватьВетку("ДеревоПоискаТочекУчета",	мИмёнПолей,	соотИ); // основная рабочая
		
		МодифицировалиТУ = Ложь;
	КонецЕсли;
	
	ТекIDАбонента = ТекущиеДанные.IDСтроки;
	
	
		
	ДеревоТочекУчета.ПолучитьЭлементы().Очистить();
	ПустойКлючСтроки  = Новый ОписаниеТипов("УникальныйИдентификатор");
	ЗаполнитьДеревоУслугНаОснованииТочекУчетаНаКлиенте(Объект, ДеревоТочекУчета, ПустойКлючСтроки.ПривестиЗначение(), ТекущиеДанные.IDСтроки);
	
	ТЗЗначенияПлощадей.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаЗначениеПлощадей", ТЗЗначенияПлощадей, ТекущиеДанные.IDСтроки);
	
	ТЗВзаиморасчеты.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаВзаиморасчеты", ТЗВзаиморасчеты, ТекущиеДанные.IDСтроки);
	
	ТЗВидыБлагоустройства.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаВидыБлагоустройства", ТЗВидыБлагоустройства, ТекущиеДанные.IDСтроки);
	
	ТЗЛьготники.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаЛьготники", ТЗЛьготники, ТекущиеДанные.IDСтроки);
	
	
КонецПроцедуры

&НаКлиенте
Процедура АбонентыПриИзменении(Элемент)
	Модифицированность = Истина;
	МодифицировалиТЧ.Абоненты = Истина;
	ТекДанные = Элементы.Абоненты.ТекущиеДанные;
	ТекДанные.СтрокаИзменена = Истина;
	Если Не ЗначениеЗаполнено(ТекДанные.IDСтроки) Тогда
		ТекДанные.IDСтроки = Новый УникальныйИдентификатор;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.МКД) Тогда
		Если НЕ ТекДанные.Строение  = Объект.МКД Тогда
			ТекДанные.Строение  		= Объект.МКД;
			ТекДанные.Помещение 		= ПредопределенноеЗначение("Справочник.энргПомещения.ПустаяСсылка");
			ТекДанные.КлючПомещения 	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка"); 
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СобытияТЧ_Взаиморасчеты

&НаКлиенте
Процедура ВзаиморасчетыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	МодифицировалиТЧ.Взаиморасчеты = Истина;
	Если НоваяСтрока Тогда
		ТекущиеДанные  					= Элементы.ТЗВзаиморасчеты.ТекущиеДанные;
		ТекущиеДанные.IDСтрокиАбонента 	= Элементы.Абоненты.ТекущиеДанные.IDСтроки;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВзаиморасчетыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Если НоваяСтрока И Не ОтменаРедактирования Тогда
		ТекущиеДанные  					= Элементы.ТЗВзаиморасчеты.ТекущиеДанные;
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаВзаиморасчеты, "ДеревоПоискаВзаиморасчеты", ТекущиеДанные);	
	Иначе
		
		ТекущиеДанные	= Элементы.ТЗВзаиморасчеты.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаВзаиморасчеты, "ДеревоПоискаВзаиморасчеты", ТекущиеДанные.IDСтрокиАбонента, ТекущиеДанные.ИдентификаторСтроки);
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаВзаиморасчеты, "ДеревоПоискаВзаиморасчеты", ТекущиеДанные);	
		
КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТЗВзаиморасчетыПередУдалением(Элемент, Отказ)
	ТекущиеДанные 							= Элементы.ТЗВзаиморасчеты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УдалитьСтрокуВДеревеПоиска(ДеревоПоискаВзаиморасчеты, "ДеревоПоискаВзаиморасчеты", ТекущиеДанные.IDСтрокиАбонента, ТекущиеДанные.ИдентификаторСтроки);
	МодифицировалиТЧ.Взаиморасчеты = Истина;
КонецПроцедуры

#КонецОбласти

#Область СобытияТЧ_ТочкиУчета

&НаКлиенте
Процедура ТочкиУчетаНаправлениеИспользованияТУПриИзменении(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета; 
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	//ОбновитьНаправленияИспользованияТУ(ТекущиеДанные.IDСтроки,ТекущиеДанные.НаправлениеИспользованияТУ);
	
	
	Для Каждого ТекСтрока Из ТЗЗначенияИзмерителей Цикл
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаЗначенияИзмерителей, "ДеревоПоискаЗначенияИзмерителей", ТекСтрока.IDСтроки, ТекСтрока.ИдентификаторСтроки);
	КонецЦикла;
	
	МассивИзмерителей 	= ПолучитьНаправленияИспользованияТУ(ТекущиеДанные.НаправлениеИспользованияТУ);
	
	ТЗЗначенияИзмерителей.Очистить();
	Для Каждого ТекИзмеритель Из МассивИзмерителей Цикл 		
		СтрокаИзмерителя 			= ТЗЗначенияИзмерителей.Добавить();
		СтрокаИзмерителя.IDСтроки	= ТекущиеДанные.IDСтроки;
		СтрокаИзмерителя.НаправлениеИспользованияТУ = ТекИзмеритель;
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаЗначенияИзмерителей, "ДеревоПоискаЗначенияИзмерителей", СтрокаИзмерителя,"IDСтроки");
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаНаправлениеИспользованияТУНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ОткрытьФормуВыбораНаправленийИзмерителейТУ(Элемент, ДанныеВыбора, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПриАктивизацииСтроки(Элемент)
	
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
		ТекущиеДанные.IDСтроки 				= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	ТЗШкалыПриборовУчета.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаШкалыПриборовУчета", ТЗШкалыПриборовУчета, ТекущиеДанные.IDСтроки, "IDСтрокиТочкиУчета");	
	
	ТЗПоказанияПриборовУчета.Очистить();
	ТЗРасчетСреднегоОбъема.Очистить();
	Если ТЗШкалыПриборовУчета.Количество() > 0 Тогда
		Элементы["ШкалыПриборовУчета" + ПрефиксТочекУчета].ТекущаяСтрока = ТЗШкалыПриборовУчета[0].ПолучитьИдентификатор();
	КонецЕсли;
	
	ТЗИзмерители.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаИзмерители", ТЗИзмерители, ТекущиеДанные.IDСтроки, "IDСтрокиТочкиУчета");
	
	ТЗЗначенияИзмерителей.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаЗначенияИзмерителей", ТЗЗначенияИзмерителей, ТекущиеДанные.IDСтроки, "IDСтроки");
	
	ТЗФормулыРасчета.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаФормулыРасчета", ТЗФормулыРасчета, ТекущиеДанные.IDСтроки, "IDСтрокиТочкиУчета");
	
	ТЗПоставщикиСоставныхУслуг.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаПоставщикиСоставныхУслуг", ТЗПоставщикиСоставныхУслуг, ТекущиеДанные.IDСтроки, "IDСтроки");	

КонецПроцедуры

