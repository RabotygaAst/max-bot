#Область СобытияТЧ_РасчетСреднегоОбъема

&НаКлиенте
Процедура РасчетСреднегоОбъемаЕстьШкалыНетТарифныхЗонПередУдалением(Элемент, Отказ)
	ТекущиеДанные 							= Элементы["РасчетСреднегоОбъема" + ПрефиксТочекУчета].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УдалитьСтрокуВДеревеПоиска(ДеревоПоискаРасчетСреднегоОбъема, "ДеревоПоискаРасчетСреднегоОбъема", ТекущиеДанные.IDСтроки, ТекущиеДанные.ИдентификаторСтроки);
	МодифицировалиТЧ.РасчетСреднегоОбъема = Истина;
КонецПроцедуры

&НаКлиенте
Процедура РасчетСреднегоОбъемаЕстьШкалыНетТарифныхЗонПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТаблицаТочкиУчета 		= Элементы["ШкалыПриборовУчета" + ПрефиксТочекУчета];
	Если НоваяСтрока И ТаблицаТочкиУчета.ТекущиеДанные <> Неопределено Тогда
		ТекущиеДанные  			= Элементы["РасчетСреднегоОбъема" + ПрефиксТочекУчета].ТекущиеДанные;
		ТекущиеДанные.IDСтроки	= ТаблицаТочкиУчета.ТекущиеДанные.IDСтроки;
	КонецЕсли;
	МодифицировалиТЧ.РасчетСреднегоОбъема = Истина;
КонецПроцедуры

&НаКлиенте
Процедура РасчетСреднегоОбъемаЕстьШкалыНетТарифныхЗонПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Если НоваяСтрока И Не ОтменаРедактирования Тогда
		ТекущиеДанные  					= Элементы["РасчетСреднегоОбъема" + ПрефиксТочекУчета].ТекущиеДанные;
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаРасчетСреднегоОбъема, "ДеревоПоискаРасчетСреднегоОбъема", ТекущиеДанные, "IDСтроки");
	Иначе
		
		ТекущиеДанные	= Элементы["РасчетСреднегоОбъема" + ПрефиксТочекУчета].ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаРасчетСреднегоОбъема, "ДеревоПоискаРасчетСреднегоОбъема", ТекущиеДанные.IDСтроки, ТекущиеДанные.ИдентификаторСтроки);
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаРасчетСреднегоОбъема, "ДеревоПоискаРасчетСреднегоОбъема", ТекущиеДанные, "IDСтроки");	
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьСтроения(ЧастныйСектор)
	
	Элементы.АбонентыСтроение.Видимость = ЧастныйСектор;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораНаправленийИзмерителейТУ(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка 	= Ложь;
	ПараметрыФормы 			= Новый Структура("Отбор", Новый Структура("Родитель", ПредопределенноеЗначение("Справочник.энргНаправлениеИспользованияТочекУчета.ПустаяСсылка")));
	ОткрытьФорму("Справочник.энргНаправлениеИспользованияТочекУчета.ФормаВыбора", ПараметрыФормы, Элемент);
КонецПроцедуры

&НаСервере
Процедура ОбновитьНаправленияИспользованияТУ(IDСтроки,РодительскийЭлемент)
	
	Справочники.энргНаправлениеИспользованияТочекУчета.ОбновитьТЧЗначенияИзмерителей(Объект.ЗначенияИзмерителей,IDСтроки,РодительскийЭлемент,Истина);
		
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьНаправленияИспользованияТУ(РодительскийЭлемент)
	
	РезультатЗапроса = Справочники.энргНаправлениеИспользованияТочекУчета.ВернутьПодчиненныеЭлементы(РодительскийЭлемент);
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("НаправлениеИспользованияТУ");

КонецФункции

&НаКлиенте
Процедура ЗаполнитьНаименование(ТекДанные)
	Если ТекДанные.Головная Тогда 
		ТекДанные.НаименованиеТочки = "" + ТекДанные.Расположение + "_" + ТекДанные.Услуга + "_Головная";
	Иначе
		ТекДанные.НаименованиеТочки = "" + ТекДанные.Расположение + "_" + ТекДанные.Услуга;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПрочитатьДанныеУслугМКД(Организация, Район, МКД)
	
	АдресВременногоХранилищаУслугиМКД  	= ПоместитьВоВременноеХранилище(Неопределено, ЭтаФорма.УникальныйИдентификатор); 	
	УслугиМКД 							= энргРаботаСТочкамиУчетаСервер.УслугиМКД(Организация, Район, МКД);	
	ПоместитьВоВременноеХранилище(УслугиМКД, АдресВременногоХранилищаУслугиМКД);
	
КонецПроцедуры

// энргРаботаСПоставщиками {
&НаКлиенте
Процедура УстановитьУсловноеОФормлениеФормыКлиент(ИмяСвойства=Неопределено, ИмяРеквизитаФормы="ПараметрыПоставщиков", IDСтроки = Неопределено, СоотвествиеУслуг = Неопределено) Экспорт  
	УстановитьУсловноеОФормлениеФормыСервер(ИмяСвойства,ИмяРеквизитаФормы);
	УстановитьПоставщиковВТЗ(IDСтроки, СоотвествиеУслуг);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПоставщиковВТЗ(IDСтроки, СоотвествиеУслуг)   
	Для Каждого ТекСтрока Из ТЗПоставщикиСоставныхУслуг Цикл
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаПоставщикиСоставныхУслуг, "ДеревоПоискаПоставщикиСоставныхУслуг", ТекСтрока.IDСтроки, ТекСтрока.ИдентификаторСтроки);
	КонецЦикла;
	
	ТЗПоставщикиСоставныхУслуг.Очистить();
	
	Для Каждого КлючЗначение Из СоотвествиеУслуг Цикл
		СтрокаТЗ						= ТЗПоставщикиСоставныхУслуг.Добавить();
		СтрокаТЗ.IDСтроки				= IDСтроки;
		СтрокаТЗ.ЧастьСоставнойУслуги	= КлючЗначение.Ключ;
		СтрокаТЗ.Поставщик				= КлючЗначение.Значение["Поставщик"];
		СтрокаТЗ.Плательщик 			= КлючЗначение.Значение["Плательщик"];		
		
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаПоставщикиСоставныхУслуг, "ДеревоПоискаПоставщикиСоставныхУслуг", СтрокаТЗ, "IDСтроки");
	КонецЦикла;
КонецПроцедуры

// энргРаботаСПоставщиками }

// энргРаботаСПоставщиками {
&НаСервере
Процедура УстановитьУсловноеОФормлениеФормыСервер(ИмяСвойства, ИмяРеквизитаФормы="ПараметрыПоставщиков")
	энргРаботаСПоставщикамиСервер.УстановитьУсловноеОФормлениеФормы(ЭтаФорма,ИмяСвойства,ИмяРеквизитаФормы,"ДеревоТочекУчета");
КонецПроцедуры
