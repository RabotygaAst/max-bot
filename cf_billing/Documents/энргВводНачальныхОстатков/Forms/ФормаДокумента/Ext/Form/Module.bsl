&НаКлиенте
Процедура ТочкиУчетаПередУдалением(Элемент, Отказ)
		// энргРаботаСПоставщиками {
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	МодифицировалиТЧ.ТочкиУчета = Истина;
	
	//энргРаботаСТочкамиУчетаКлиент.ТочкаУчетаПередУдалением(Объект.ЗначенияИзмерителей, ТекущиеДанные);
	//энргРаботаСТочкамиУчетаКлиент.ТочкаУчетаПередУдалением(Объект.ФормулыРасчета, ТекущиеДанные, "IDСтрокиТочкиУчета");
	
	Для Каждого ТекСтрока Из ТЗШкалыПриборовУчета Цикл
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаШкалыПриборовУчета, "ДеревоПоискаШкалыПриборовУчета", ТекСтрока.IDСтроки, ТекСтрока.ИдентификаторСтроки);
	КонецЦикла;
	
	ТЗРасчетСреднегоОбъема.Очистить();
	ТЗПоказанияПриборовУчета.Очистить();
	ТЗНомераПломб.Очистить();
	
	Для Каждого ТекСтрока Из ТЗЗначенияИзмерителей Цикл
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаЗначенияИзмерителей, "ДеревоПоискаЗначенияИзмерителей", ТекСтрока.IDСтроки, ТекСтрока.ИдентификаторСтроки);
	КонецЦикла;
	
	Для Каждого ТекСтрока Из ТЗИзмерители Цикл
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаИзмерители, "ДеревоПоискаИзмерители", ТекСтрока.IDСтроки, ТекСтрока.ИдентификаторСтроки);
	КонецЦикла;

	Для Каждого ТекСтрока Из ТЗФормулыРасчета Цикл
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаФормулыРасчета, "ДеревоПоискаФормулыРасчета", ТекСтрока.IDСтроки, ТекСтрока.ИдентификаторСтроки);
	КонецЦикла;
	
	Для Каждого ТекСтрока Из ТЗПоставщикиСоставныхУслуг Цикл
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаПоставщикиСоставныхУслуг, "ДеревоПоискаПоставщикиСоставныхУслуг", ТекСтрока.IDСтроки, ТекСтрока.ИдентификаторСтроки);
	КонецЦикла;
КонецПроцедуры

