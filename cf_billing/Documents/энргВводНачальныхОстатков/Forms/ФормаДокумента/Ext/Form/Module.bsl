&НаКлиенте
Процедура ДобавитьУслугу(Команда)
	ТаблицаФормы 				= Элементы["ТочкиУчета" + ПрефиксТочекУчета];
	НоваяСтрока  				= ДеревоТочекУчета.ПолучитьЭлементы().Добавить();
	НоваяСтрока.IDСтрокиАбонента	= Элементы.Абоненты.ТекущиеДанные.IDСтроки;
	ТаблицаФормы.ТекущаяСтрока 	= НоваяСтрока.ПолучитьИдентификатор();
	ТаблицаФормы.ИзменитьСтроку();

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПодчиненнуюУслугу(Команда)
	Отказ 						= Истина;
	ТаблицаФормы 				= Элементы["ТочкиУчета" + ПрефиксТочекУчета];
	Родитель  					= ДеревоТочекУчета.НайтиПоИдентификатору(ТаблицаФормы.ТекущаяСтрока);
	НоваяСтрока  					= Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.IDСтрокиРодитель	= ТаблицаФормы.ТекущиеДанные.IDСтроки;
	НоваяСтрока.IDСтрокиАбонента	= ТаблицаФормы.ТекущиеДанные.IDСтрокиАбонента;
	ТаблицаФормы.ТекущаяСтрока 	= НоваяСтрока.ПолучитьИдентификатор();
	ТаблицаФормы.ИзменитьСтроку();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьАбонента(Команда)
	Если МодифицировалиТУ Тогда		
		// удаляем старые строки
		ПустойКлючСтроки  = Новый ОписаниеТипов("УникальныйИдентификатор");
		отб = Новый Структура("IDСтрокиАбонента,IDСтрокиРодитель", ТекIDАбонента, ПустойКлючСтроки.ПривестиЗначение());
		ВершиныДляУдаления = НайтиСтрокиДерева("ДеревоПоискаТочекУчета", отб);
		
		Если ЗначениеЗаполнено(ВершиныДляУдаления) Тогда
			ВсеВершины = ДеревоПоискаТочекУчета.ПолучитьЭлементы();
			Для Каждого ТекВершина Из ВершиныДляУдаления Цикл
				Если ВсеВершины.Индекс(ТекВершина) <> -1 Тогда
					ВсеВершины.Удалить(ВсеВершины.Индекс(ТекВершина));
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		// добавляем новые строки
		ДобавитьСтрокиВДеревоПоискаТочекУчета(ДеревоТочекУчета, ДеревоПоискаТочекУчета);
		
		мИмёнПолей = Новый Массив;
		мИмёнПолей.Добавить("IDСтрокиАбонента");
		мИмёнПолей.Добавить("IDСтрокиРодитель");
		соотИ = Новый Соответствие;
		ИндексироватьВетку("ДеревоПоискаТочекУчета",	мИмёнПолей,	соотИ); // основная рабочая
		
		МодифицировалиТУ = Ложь;
	КонецЕсли;
	
	ТаблицаФормы 				= Элементы["Абоненты"];
	НоваяСтрока  				= АбонентыДерево.ПолучитьЭлементы().Добавить();
	ТаблицаФормы.ТекущаяСтрока 	= НоваяСтрока.ПолучитьИдентификатор();
	ТаблицаФормы.ИзменитьСтроку();
	
	ТекIDАбонента = НоваяСтрока.IDСтроки;
			
	ДеревоТочекУчета.ПолучитьЭлементы().Очистить();
	
	ТЗЗначенияПлощадей.Очистить();
	
	ТЗВзаиморасчеты.Очистить();
	
	ТЗВидыБлагоустройства.Очистить();
	
	ТЗЛьготники.Очистить();

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьКомнату(Команда)
	Отказ 						= Истина;
	ТаблицаФормы 				= Элементы["Абоненты"];
	Родитель  					= АбонентыДерево.НайтиПоИдентификатору(ТаблицаФормы.ТекущаяСтрока);
	НоваяСтрока  					= Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.IDСтрокиРодитель	= ТаблицаФормы.ТекущиеДанные.IDСтроки;
	НоваяСтрока.Строение			= ТаблицаФормы.ТекущиеДанные.Строение;
	НоваяСтрока.ДатаОткрытияЛС		= ТаблицаФормы.ТекущиеДанные.ДатаОткрытияЛС;
	НоваяСтрока.МаршрутКонтролера	= ТаблицаФормы.ТекущиеДанные.МаршрутКонтролера;
	ТаблицаФормы.ТекущаяСтрока 	= НоваяСтрока.ПолучитьИдентификатор();
	ТаблицаФормы.ИзменитьСтроку();
	ТЗИзмерители.Очистить();
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияИзмерителейЕстьШкалыНетТарифныхЗонПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияИзмерителейЕстьШкалыНетТарифныхЗонПриИзменении(Элемент)
	МодифицировалиТЧ.ЗначенияИзмерителей = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияИзмерителейЕстьШкалыНетТарифныхЗонПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Если НоваяСтрока И Не ОтменаРедактирования Тогда
		ТекущиеДанные  					= Элементы["ЗначенияИзмерителей" + ПрефиксТочекУчета].ТекущиеДанные;
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаЗначенияИзмерителей, "ДеревоПоискаЗначенияИзмерителей", ТекущиеДанные, "IDСтроки");
	Иначе
		
		ТекущиеДанные	= Элементы["ЗначенияИзмерителей" + ПрефиксТочекУчета].ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаЗначенияИзмерителей, "ДеревоПоискаЗначенияИзмерителей", ТекущиеДанные.IDСтроки, ТекущиеДанные.ИдентификаторСтроки);
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаЗначенияИзмерителей, "ДеревоПоискаЗначенияИзмерителей", ТекущиеДанные, "IDСтроки");	
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ТЗИзмерителиПриИзменении(Элемент)
	МодифицировалиТЧ.Измерители = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ТЗНомераПломбПриИзменении(Элемент)
	МодифицировалиТЧ.НомераПломб = Истина;
	
	ТекущиеДанные 							= Элементы["ТЗНомераПломб"].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.IDСтрокиИзмерителя) Тогда
		ТекущиеДанные.IDСтрокиИзмерителя 				= Элементы.ТЗИзмерители.ТекущиеДанные.IDСтроки;
		ТекущиеДанные.IDСтрокиТочкиУчета 				= Элементы.ТочкиУчетаНетШкалЕстьТарифныеЗоны.ТекущиеДанные.IDСтроки;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ТЗИзмерителиПриАктивизацииСтроки(Элемент)
			
	ТекущиеДанные 							= Элементы["ТЗИзмерители"].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
		ТекущиеДанные.IDСтроки 				= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.IDСтрокиТочкиУчета) Тогда
		ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
		ТекущиеДанныеТУ 						= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
		ТекущиеДанные.IDСтрокиТочкиУчета 		= ТекущиеДанныеТУ.IDСтроки;
	КонецЕсли;
	
	
	
	ТЗНомераПломб.Очистить();
	ЗаполнитьТЗНаОснованииДереваПоискаНаКлиенте("ДеревоПоискаНомераПломб", ТЗНомераПломб, ТекущиеДанные.IDСтроки, "IDСтрокиИзмерителя");
	
КонецПроцедуры

&НаКлиенте
Процедура ТЗИзмерителиПередУдалением(Элемент, Отказ)
	ТекущиеДанные 							= Элементы["ТЗИзмерители"].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ТекСтрока Из ТЗНомераПломб Цикл
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаНомераПломб, "ДеревоПоискаНомераПломб", ТекСтрока.IDСтрокиИзмерителя, ТекСтрока.ИдентификаторСтроки);
	КонецЦикла;
	
	УдалитьСтрокуВДеревеПоиска(ДеревоПоискаИзмерители, "ДеревоПоискаИзмерители", ТекущиеДанные.IDСтроки, ТекущиеДанные.ИдентификаторСтроки);
	МодифицировалиТЧ.Измерители = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьТочкуУчета(Команда)
	ТаблицаФормы 				= Элементы["ТочкиУчетаНетШкалЕстьТарифныеЗоны"];
	НоваяСтрока  				= ДеревоТочекУчета.ПолучитьЭлементы().Добавить();
	НоваяСтрока.IDСтрокиАбонента	= ТекIDАбонента;
	ТаблицаФормы.ТекущаяСтрока 	= НоваяСтрока.ПолучитьИдентификатор();
	ТаблицаФормы.ИзменитьСтроку();
	
	МодифицировалиТУ = Истина;
	
	ТЗШкалыПриборовУчета.Очистить();
	СтрокаШкалы 						= ТЗШкалыПриборовУчета.Добавить();
	СтрокаШкалы.IDСтроки 				= Новый УникальныйИдентификатор;
	СтрокаШкалы["IDСтрокиТочкиУчета"]	= НоваяСтрока.IDСтроки;
	СтрокаШкалы.Шкала		 			= ПредопределенноеЗначение("Справочник.энргВидыКанальности.Одноканальный");
	ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаШкалыПриборовУчета, "ДеревоПоискаШкалыПриборовУчета", СтрокаШкалы, "IDСтрокиТочкиУчета");
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПодчиненнуюТУ(Команда)
	ТаблицаФормы 					= Элементы["ТочкиУчетаНетШкалЕстьТарифныеЗоны"];
	Родитель  						= ДеревоТочекУчета.НайтиПоИдентификатору(ТаблицаФормы.ТекущаяСтрока);
	НоваяСтрока  					= Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.IDСтрокиАбонента	= ТекIDАбонента;
	НоваяСтрока.IDСтрокиРодитель	= ТаблицаФормы.ТекущиеДанные.IDСтроки;
	ТаблицаФормы.ТекущаяСтрока 		= НоваяСтрока.ПолучитьИдентификатор();
	ТаблицаФормы.ИзменитьСтроку();
КонецПроцедуры

&НаКлиенте
Процедура ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоныПередУдалением(Элемент, Отказ)
	ТекущиеДанные 							= Элементы.ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоны.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УдалитьСтрокуВДеревеПоиска(ДеревоПоискаПоказанияПриборовУчета, "ДеревоПоискаПоказанияПриборовУчета", ТекущиеДанные.IDСтроки, ТекущиеДанные.ИдентификаторСтроки);
	МодифицировалиТЧ.ПоказанияПриборовУчета = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ТЗИзмерителиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	МодифицировалиТЧ.Измерители = Истина;
	Если НоваяСтрока Тогда
		ТекущиеДанные  						= Элементы.ТЗИзмерители.ТекущиеДанные;
		ТекущиеДанные.IDСтрокиТочкиУчета 	= Элементы.ТочкиУчетаНетШкалЕстьТарифныеЗоны.ТекущиеДанные.IDСтроки;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ТЗИзмерителиПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Если НоваяСтрока И Не ОтменаРедактирования Тогда
		ТекущиеДанные  					= Элементы.ТЗИзмерители.ТекущиеДанные;
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаИзмерители, "ДеревоПоискаИзмерители", ТекущиеДанные, "IDСтрокиТочкиУчета");	
	Иначе
		
		ТекущиеДанные	= Элементы.ТЗИзмерители.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаИзмерители, "ДеревоПоискаИзмерители", ТекущиеДанные.IDСтрокиТочкиУчета, ТекущиеДанные.ИдентификаторСтроки);
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаИзмерители, "ДеревоПоискаИзмерители", ТекущиеДанные, "IDСтрокиТочкиУчета");	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТЗНомераПломбПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	МодифицировалиТЧ.НомераПломб = Истина;
	Если НоваяСтрока Тогда
		ТекущиеДанные  						= Элементы.ТЗНомераПломб.ТекущиеДанные;
		ТекущиеДанные.IDСтрокиТочкиУчета 	= Элементы.ТочкиУчетаНетШкалЕстьТарифныеЗоны.ТекущиеДанные.IDСтроки;
		ТекущиеДанные.IDСтрокиИзмерителя 	= Элементы.ТЗИзмерители.ТекущиеДанные.IDСтроки;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ТЗНомераПломбПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Если НоваяСтрока И Не ОтменаРедактирования Тогда
		ТекущиеДанные  					= Элементы.ТЗНомераПломб.ТекущиеДанные;
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаНомераПломб, "ДеревоПоискаНомераПломб", ТекущиеДанные, "IDСтрокиИзмерителя");	
	Иначе
		
		ТекущиеДанные	= Элементы.ТЗНомераПломб.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		УдалитьСтрокуВДеревеПоиска(ДеревоПоискаНомераПломб, "ДеревоПоискаНомераПломб", ТекущиеДанные.IDСтрокиИзмерителя, ТекущиеДанные.ИдентификаторСтроки);
		ДобавитьСтрокуВДеревоПоиска(ДеревоПоискаНомераПломб, "ДеревоПоискаНомераПломб", ТекущиеДанные, "IDСтрокиИзмерителя");	
		
	КонецЕсли;
КонецПроцедуры

