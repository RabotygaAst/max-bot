&НаКлиенте
Процедура ФормулыРасчетаСтроениеПриИзменении(Элемент)
	ТекущиеДанные 				= Элементы["ФормулыРасчета" + ПрефиксТочекУчета].ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Строение) Тогда
		ДанныеСтроения				= энргПользовательскийВводСервер.ПрочитатьКлючПомещения(ТекущиеДанные.Строение,ТекущиеДанные.Помещение);
		ТекущиеДанные.КлючПомещения	= ДанныеСтроения.КлючПомещения;
	Иначе
		ТекущиеДанные.Помещение 	= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
		ТекущиеДанные.КлючПомещения = ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
		ТекущиеДанные.ТочкаУчета 	= ПредопределенноеЗначение("Справочник.энргТочкиУчета.ПустаяСсылка");
		ТекущиеДанные.Услуга		= ПредопределенноеЗначение("Справочник.энргВидыУслуг.ПустаяСсылка");
	КонецЕсли;
	
