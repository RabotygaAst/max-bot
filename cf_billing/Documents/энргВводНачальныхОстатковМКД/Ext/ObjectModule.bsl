Процедура ЗаписьВРСОтложенныеДвиженияДокументов()
	
	НаборЗаписей 						= РегистрыСведений.энргОтложенныеДвиженияДокументов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ДокРегистратор.Установить(Ссылка);
	НаборЗаписей.Записать();   
	
	Запрос  							= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Запрос.Текст 						=
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	энргВводНачальныхОстатковМКДДома.МКД
	|ИЗ
	|	Документ.энргВводНачальныхОстатковМКД.Дома КАК энргВводНачальныхОстатковМКДДома
	|ГДЕ
	|	энргВводНачальныхОстатковМКДДома.Ссылка = &Ссылка";
	
	Результат 							= Запрос.Выполнить();
	Выборка  							= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		НоваяЗапись 					= НаборЗаписей.Добавить();	
		НоваяЗапись.ПериодНачисления 	= ПериодНачисления;
		НоваяЗапись.Район 				= Район;
		НоваяЗапись.Организация 		= Организация;
		НоваяЗапись.Строение 			= Выборка.МКД;
		НоваяЗапись.РазделЗаписи 		= Перечисления.энргРазделыЗаписи.СтабильныеПериодыМКД;
		НоваяЗапись.ДокРегистратор 		= Ссылка;
		НоваяЗапись.ДатаРегистратора 	= Дата;	
	КонецЦикла;  	
	
	НаборЗаписей.Записать(ложь);
	
КонецПроцедуры

