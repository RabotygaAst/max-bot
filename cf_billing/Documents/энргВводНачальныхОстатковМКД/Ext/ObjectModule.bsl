Процедура ЗаписатьВидДифференцированностиПриборовУчета()
	
	Запрос  = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатковМКД.Организация КАК Организация,
	|	энргВводНачальныхОстатковМКД.ПериодНачисления КАК ПериодНачисления,
	|	энргВводНачальныхОстатковМКД.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	энргВводНачальныхОстатковМКД.Дата КАК Дата,
	|	энргВводНачальныхОстатковМКД.Дата КАК ПериодРегистрации,
	|	ВложенныйЗапрос.ДатаПриемки КАК ДатаПриемки
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргВводНачальныхОстатковМКДДома.МКД КАК МКД,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		ВложенныйЗапрос.Шкала КАК Шкала,
	|		ВложенныйЗапрос.ВидДифференцированности КАК ВидДифференцированности,
	|		ВложенныйЗапрос.ДатаПриемки КАК ДатаПриемки
	|	ИЗ
	|		(ВЫБРАТЬ
	|			энргВводНачальныхОстатковМКДТочкиУчета.ПриборУчета КАК ПриборУчета,
	|			энргВводНачальныхОстатковМКДШкалыПриборовУчета.Шкала КАК Шкала,
	|			энргВводНачальныхОстатковМКДШкалыПриборовУчета.ВидДифференцированности КАК ВидДифференцированности,
	|			энргВводНачальныхОстатковМКДТочкиУчета.IDСтрокиМКД КАК IDСтрокиМКД,
	|			энргВводНачальныхОстатковМКДТочкиУчета.ДатаВводПрибораУчета КАК ДатаПриемки
	|		ИЗ
	|			Документ.энргВводНачальныхОстатковМКД.ТочкиУчета КАК энргВводНачальныхОстатковМКДТочкиУчета
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатковМКД.ШкалыПриборовУчета КАК энргВводНачальныхОстатковМКДШкалыПриборовУчета
	|				ПО энргВводНачальныхОстатковМКДТочкиУчета.IDСтроки = энргВводНачальныхОстатковМКДШкалыПриборовУчета.IDСтрокиТочкиУчета
	|					И (энргВводНачальныхОстатковМКДТочкиУчета.Ссылка = &Ссылка)
	|					И (энргВводНачальныхОстатковМКДШкалыПриборовУчета.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатковМКД.Дома КАК энргВводНачальныхОстатковМКДДома
	|			ПО (энргВводНачальныхОстатковМКДДома.Ссылка = &Ссылка)
	|				И ВложенныйЗапрос.IDСтрокиМКД = энргВводНачальныхОстатковМКДДома.IDСтроки) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатковМКД КАК энргВводНачальныхОстатковМКД
	|		ПО (энргВводНачальныхОстатковМКД.Ссылка = &Ссылка)";
	
	Результат  							= Запрос.Выполнить();
	Выборка  							= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл		
		Запись 							= Движения.энргВидыДифференцированностиПриборовУчетаМКД.Добавить();
		Запись.Период  					= Выборка.ДатаПриемки;
		Запись.Район  					= Выборка.Район;
		Запись.Организация				= Выборка.Организация;
		Запись.МКД		  				= Выборка.МКД;
		Запись.ПриборУчета 				= Выборка.ПриборУчета;
		Запись.Шкала 					= Выборка.Шкала;
		Запись.ВидДифференцированности	= Выборка.ВидДифференцированности;
		Запись.ПериодРегистрации		= Выборка.ПериодРегистрации;
		Запись.ПериодНачисления			= Выборка.ПериодНачисления;		
	КонецЦикла;
	
КонецПроцедуры

