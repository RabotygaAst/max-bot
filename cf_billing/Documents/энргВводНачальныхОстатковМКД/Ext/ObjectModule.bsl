#Область РаботаСДаннымиТочекУчета

Процедура ЗаписатьДанныеТочекУчета()
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатковМКД.Организация КАК Организация,
	|	энргВводНачальныхОстатковМКД.ПериодНачисления КАК ПериодНачисления,
	|	энргВводНачальныхОстатковМКД.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ПериодУслуги КАК ПериодУслуги,
	|	ВложенныйЗапрос.ДатаПриемки КАК ДатаПриемки,
	|	энргВводНачальныхОстатковМКД.Дата КАК ПериодРегистрации,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.НетВозможностьУстановкиПУ КАК НетВозможностьУстановкиПУ,
	|	ВложенныйЗапрос.КоэффициентПУ КАК КоэффициентПУ,
	|	ВложенныйЗапрос.НомерПломбы КАК НомерПломбы,
	|	ВложенныйЗапрос.ДатаПоверки КАК ДатаПоверки
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргВводНачальныхОстатковМКДДома.МКД КАК МКД,
	|		энргВводНачальныхОстатковМКДТочкиУчета.ДатаПодключенияУслуги КАК ПериодУслуги,
	|		энргВводНачальныхОстатковМКДТочкиУчета.ДатаВводПрибораУчета КАК ДатаПриемки,
	|		энргВводНачальныхОстатковМКДТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|		энргВводНачальныхОстатковМКДТочкиУчета.ПриборУчета КАК ПриборУчета,
	|		энргВводНачальныхОстатковМКДТочкиУчета.Услуга КАК Услуга,
	|		энргВводНачальныхОстатковМКДТочкиУчета.НетВозможностьУстановкиПУ КАК НетВозможностьУстановкиПУ,
	|		ВЫБОР
	|			КОГДА энргВводНачальныхОстатковМКДТочкиУчета.КоэффициентПУ = 0
	|				ТОГДА 1
	|			ИНАЧЕ энргВводНачальныхОстатковМКДТочкиУчета.КоэффициентПУ
	|		КОНЕЦ КАК КоэффициентПУ,
	|		энргВводНачальныхОстатковМКДТочкиУчета.НомерПломбы КАК НомерПломбы,
	|		энргВводНачальныхОстатковМКДТочкиУчета.ДатаПоверки КАК ДатаПоверки
	|	ИЗ
	|		Документ.энргВводНачальныхОстатковМКД.ТочкиУчета КАК энргВводНачальныхОстатковМКДТочкиУчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатковМКД.Дома КАК энргВводНачальныхОстатковМКДДома
	|			ПО энргВводНачальныхОстатковМКДТочкиУчета.IDСтрокиМКД = энргВводНачальныхОстатковМКДДома.IDСтроки
	|				И (энргВводНачальныхОстатковМКДТочкиУчета.Ссылка = &Ссылка)
	|				И (энргВводНачальныхОстатковМКДДома.Ссылка = &Ссылка)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатковМКД КАК энргВводНачальныхОстатковМКД
	|		ПО (энргВводНачальныхОстатковМКД.Ссылка = &Ссылка)";
	
	Результат 		= Запрос.Выполнить();
	Выборка  		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 		
		УстановитьВладельцаТочкиУчета(Выборка);
		УстановитьАктивностьТочек(Выборка);
		УстановитьУслугиТочекУчета(Выборка);
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) Тогда
			УстановитьПриборыТочекУчета(Выборка);
			УстановитьСостояниеПрибораУчета(Выборка);
			ЗаписатьКоэффициентПУ(Выборка);
			УстановитьНомерПломбыПрибораУчета(Выборка);		
			ЗаписатьДатуПоверки(Выборка);
		КонецЕсли;
				
	КонецЦикла;
	
КонецПроцедуры

