#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
	
	Ответственный 		= Пользователи.ТекущийПользователь();
		
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	ЗаписатьДанныеМКД();
	
	ЗаписатьДанныеТочекУчета();
	ЗаписатьВидДифференцированностиПриборовУчета();
	ЗаписатьПоказанияПриборовУчета();
	ЗаписатьЗначенияПлощадей();
	
	ЗаписьВРСОтложенныеДвиженияДокументов();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РаботаСДаннымиМКД

Процедура ЗаписатьДанныеМКД()
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Запрос.Текст 	= 
	"ВЫБРАТЬ
	|	энргВводНачальныхОстатковМКД.Организация КАК Организация,
	|	энргВводНачальныхОстатковМКД.ПериодНачисления КАК ПериодНачисления,
	|	энргВводНачальныхОстатковМКД.Район КАК Район,
	|	энргВводНачальныхОстатковМКДДома.МКД КАК МКД,
	|	энргВводНачальныхОстатковМКДДома.ДатаОткрытияМКД КАК Дата,
	|	энргВводНачальныхОстатковМКДДома.ФормаУправления КАК ФормаУправления,
	|	энргВводНачальныхОстатковМКДДома.УК КАК УК,
	|	энргВводНачальныхОстатковМКДДома.бестПостановление КАК бестПостановление,
	|	энргВводНачальныхОстатковМКДДома.ТипСхемыГВС КАК ТипСхемыГВС,
	|	энргВводНачальныхОстатковМКДДома.ВидТепловогоПункта КАК ВидТепловогоПункта,
	|	энргВводНачальныхОстатковМКДДома.ВидБлагоустройства КАК ВидБлагоустройства,
	|	энргВводНачальныхОстатковМКД.Дата КАК ПериодРегистрации,
	|	энргВводНачальныхОстатковМКДДома.КоличествоЭтажей КАК КоличествоЭтажей,
	|	энргВводНачальныхОстатковМКДДома.Бойлер КАК Бойлер
	|ИЗ
	|	Документ.энргВводНачальныхОстатковМКД.Дома КАК энргВводНачальныхОстатковМКДДома
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргВводНачальныхОстатковМКД КАК энргВводНачальныхОстатковМКД
	|		ПО энргВводНачальныхОстатковМКДДома.Ссылка = энргВводНачальныхОстатковМКД.Ссылка
	|			И (энргВводНачальныхОстатковМКДДома.Ссылка = &Ссылка)
	|			И (энргВводНачальныхОстатковМКД.Ссылка = &Ссылка)";
	
	Результат 		= Запрос.Выполнить();
	Выборка 		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		УстановитьФормуУправления(Выборка);
		УстановитьВидБлагоустроства(Выборка);
		УстановитьЭтажность(Выборка);
		УстановитьРабочиеПостановления(Выборка);
		УстановитьТипСхемыГВС(Выборка);				
		УстановитьТипПринадлежности(Выборка);
		УстановитьСостояниеМКД(Выборка);
		УстановитьБойлер(Выборка);
	КонецЦикла;
	
КонецПроцедуры

