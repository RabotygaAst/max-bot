&НаСервере
Функция ПодготовитьНаборЗаписейОплат(НаборыЗаписей)
	
	ОтборЗадолженности = Новый Структура("IDСтроки", Неопределено);
	Для Каждого СтрокаТочкиУчета из Объект.Оплата Цикл 
		
		НоваяСтрокаТУ = НаборыЗаписей.Оплата.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаТУ, СтрокаТочкиУчета);
		
		НоваяСтрокаТУ.ИдентификаторСтроки = "" + Новый УникальныйИдентификатор;
		НоваяСтрокаТУ.ДокументОснование = Объект.Ссылка;
		НоваяСтрокаТУ.ДатаДокумента = Объект.Дата;
		НоваяСтрокаТУ.ПериодНачисления = Объект.ПериодНачисления;
		НоваяСтрокаТУ.Организация = Объект.Организация;
		НоваяСтрокаТУ.Район = Объект.Район;
		
		ОтборЗадолженности.IDСтроки = СтрокаТочкиУчета.IDСтроки;
		СтрокиЗадолженности = Объект.Задолженность.НайтиСтроки(ОтборЗадолженности);
		Разделитель = 0;
		Для Каждого СтрокаЗадолженности из СтрокиЗадолженности Цикл 
			
			НоваяСтрокаЗадолженности = НаборыЗаписей.Задолженность.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаЗадолженности, СтрокаЗадолженности); 
			НоваяСтрокаЗадолженности.ДокументОснование = Объект.Ссылка;
			НоваяСтрокаЗадолженности.ИдентификаторСтроки = НоваяСтрокаТУ.ИдентификаторСтроки; 			
			НоваяСтрокаЗадолженности.Разделитель = Разделитель;
			
			Разделитель = Разделитель + 1;
		КонецЦикла;
				
	КонецЦикла;	
	
КонецФункции

