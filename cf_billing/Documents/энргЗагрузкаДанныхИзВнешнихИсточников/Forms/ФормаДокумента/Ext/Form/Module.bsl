	СуммаОплатПоСозданнымДокументам = СуммаОплатПоСвязаннымДокументам(Объект.Ссылка);
	ОбновитьДинамическиеСпискиСвязанныхДокументов();
	
	Если РезультатВыполнения = Неопределено Тогда 
		Возврат;
	КонецЕсли;
		
	Если РезультатВыполнения.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение( ,РезультатВыполнения.КраткоеПредставлениеОшибки);
		Возврат;
	КонецЕсли; 	
	
	
	ЭтоКнопкаЗагрузки = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ЭтоКнопкаЗагрузки", Ложь);
	ВыполнятьВыборФайла = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ВыполнятьВыборФайла", Ложь);
	Если ЭтоКнопкаЗагрузки Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыполнятьВыборФайла Тогда 
		ФайлДляЧтенияНачалоВыбораКлиент();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ФоновоеВыполнениеЗадачиСменаЗависимыхРеквизитов

&НаКлиенте
Функция ЗапуститьФоновоеЗаданиеСменаЗависимыхРеквизитовОплатКлиент()
	
	// 1. Запуск фонового задания на сервере.
	ЗависимыеРеквизиты = ПолучитьЗависимыеРеквизиты();
	Оповещение = Новый ОписаниеОповещения("ПриЗавершенииФоновогоЗаданияСменаЗависимыхРеквизитовОплат", ЭтотОбъект);
	
	энргМассовыйВводОплатКлиент.ЗапуститьФоновоеЗаданиеСменаЗависимыхРеквизитов(
		ЭтотОбъект,
		Оповещение,
		Объект.Ссылка, 
		ЗависимыеРеквизиты);
	
КонецФункции

