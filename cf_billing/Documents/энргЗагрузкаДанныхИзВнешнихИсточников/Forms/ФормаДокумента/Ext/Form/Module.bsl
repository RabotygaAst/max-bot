КонецПроцедуры

&НаСервере 
Функция УслугиАбонента(Период,ЛицевойСчет)
	Запрос = Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	энргАбоненты.ЛицевойСчет КАК ЛицевойСчет,
	|	энргАбоненты.КлючПомещения КАК КлючПомещения,
	|	энргАбоненты.Район КАК Район,
	|	энргАбоненты.Организация КАК Организация
	|ПОМЕСТИТЬ ВТ_Абонент
	|ИЗ
	|	Справочник.энргАбоненты КАК энргАбоненты
	|ГДЕ
	|	энргАбоненты.ЛицевойСчет = &ЛицевойСчет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга
	|ИЗ
	|	ВТ_Абонент КАК ВТ_Абонент
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргУслугиТочекУчета.СрезПоследних(&Период, ) КАК энргУслугиТочекУчетаСрезПоследних
	|		ПО ВТ_Абонент.КлючПомещения = энргУслугиТочекУчетаСрезПоследних.КлючПомещения
	|			И ВТ_Абонент.Район = энргУслугиТочекУчетаСрезПоследних.Район
	|			И ВТ_Абонент.Организация = энргУслугиТочекУчетаСрезПоследних.Организация";
	Запрос.УстановитьПараметр("ЛицевойСчет", ЛицевойСчет);
	Запрос.УстановитьПараметр("Период", Период);
	
	РезультатЗапроса 	= Запрос.Выполнить();	
	Выборка 			= РезультатЗапроса.Выбрать();
	МассивПриборов 		= новый Массив;
	
	Пока Выборка.Следующий() Цикл
		МассивПриборов.Добавить(Выборка.Услуга);
	КонецЦикла;
	
	Возврат МассивПриборов; 
	
КонецФункции

&НаКлиенте
Процедура НеЗагруженныеДанныеУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные=Элементы.НеЗагруженныеДанные.ТекущиеДанные;
	
	СтандартнаяОбработка 	= Ложь;
	ПараметрыФормы 			= Новый Структура("Отбор", Новый Структура("Ссылка", УслугиАбонента(Объект.Дата,ТекущиеДанные.лицевойсчет)));
	ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", ПараметрыФормы, Элемент);	
	
КонецПроцедуры

&НаСервере
Функция ОбъектОбработкиЗагрузки(ИсточникПоступления) 
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Источник",ИсточникПоступления);
	Запрос.Текст 	="ВЫБРАТЬ
	|	энргНастройкиЗагрузкиОплаты.ОбработкаЗагрузки
	|ИЗ
	|	РегистрСведений.энргНастройкиЗагрузкиОплаты КАК энргНастройкиЗагрузкиОплаты
	|ГДЕ
	|	энргНастройкиЗагрузкиОплаты.Источник = &Источник";
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось определить обработку для загрузки файла");
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка  = Результат.Выбрать();
	Выборка.Следующий();
	
	ВнешняяОбработкаОбъект  = Выборка.ОбработкаЗагрузки.ПолучитьОбъект();
	ИмяФайла  				= ПолучитьИмяВременногоФайла("epf");
	ДвоичныеДанные 			= ВнешняяОбработкаОбъект.ХранилищеОбработки.получить();
	ДвоичныеДанные.записать(ИмяФайла);
	
	Возврат ВнешниеОбработки.Создать(ИмяФайла,Ложь);
КонецФункции

&НаКлиенте
Процедура ФормаЗадолженностьОкончаниеВыбора(РезультатЗакрытия,ДополнительныеПараметры) Экспорт  
	
	Если РезультатЗакрытия <> Неопределено Тогда 
		
		Модифицированность	= Истина;
		
		Для каждого СтрокаДолг Из РезультатЗакрытия Цикл
			
			СтрокаТЗ = Объект.Задолженность.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЗ, СтрокаДолг);
			СтрокаТЗ.IDСтроки = ДополнительныеПараметры.IDСтроки;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СервисПроверкиПоказанийПриборовУчета

&НаСервере
Процедура ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний()
	
	ТаблицаПриборов = энргРаботаСПоказаниямиПриборовУчетаСервер.НоваяТаблицаПриборовДляПроверки();
	Для Каждого ТекСтрока из Объект.ТочкиУчета Цикл
		НСтрока = ТаблицаПриборов.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, ТекСтрока);
		НСтрока.Район 			= ТекСтрока.Район;
		НСтрока.КлючПомещения 	= ТекСтрока.КлючПомещения;
	КонецЦикла;
	
	ПериодЗапроса 		= Новый Граница(Объект.Дата, ВидГраницы.Исключая);
	ВспомогательныеПараметры = энргРаботаСПоказаниямиПриборовУчетаСервер.НовыеВспомогательныеПараметрыПроверкиОтклоненияПоказаний();
	ВспомогательныеПараметры.ПоказанияВСрок = ПоказанияВСрок;
	ВспомогательныеПараметры.ПериодНачисления = Объект.ПериодНачисления;
	
	РезультатЗапроса = энргРаботаСПоказаниямиПриборовУчетаСервер.ПриборыДляОтклоненияПоказаний(ПериодЗапроса, Объект.Организация, ТаблицаПриборов, ВспомогательныеПараметры);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний(ЭтотОбъект, РезультатЗапроса);
	
КонецПроцедуры

&НаСервере
Процедура ПоказанияПредоставляютсяВСрок()
	ПоказанияВСрок = энргРаботаСПоказаниямиПриборовУчетаСервер.ПоказанияПредоставляютсяВСрок(Объект.ПериодНачисления, Объект.Дата, Объект.Организация, Объект.Район);
КонецПроцедуры

&НаСервере
Функция ПолучитьТЗПриборыДляОтклоненияПоказаний()
	
	тзПриборыДляОтклоненияПоказаний 							= Новый ТаблицаЗначений;		
	
	тзПриборыДляОтклоненияПоказаний.Колонки.добавить("ПриборУчета",						Новый ОписаниеТипов("СправочникСсылка.энргПриборыУчетаАбонента"));
	тзПриборыДляОтклоненияПоказаний.Колонки.добавить("СостояниеПоказаний",				Новый ОписаниеТипов("ПеречислениеСсылка.энргСостояниеПоказаний"));
	тзПриборыДляОтклоненияПоказаний.Колонки.добавить("ПричинаОтклонения",				Новый ОписаниеТипов("ПеречислениеСсылка.энргПричиныОтклоненияПоказаний"));
	
	
	
	Для Каждого ТекСтрока из ЭтотОбъект.ПриборыДляОтклоненияПоказаний Цикл
		НСтрока = тзПриборыДляОтклоненияПоказаний.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, ТекСтрока);
		
	КонецЦикла;
	
	Возврат тзПриборыДляОтклоненияПоказаний;
	
КонецФункции

#КонецОбласти


#Область РаботаССвязаннымиДокументами

&НаСервере
Процедура ЗарегистрироватьЗаписиКСозданиюДокументов()
	
	НаборыЗаписей = Новый Структура;
	
	// Показания
	НаборЗаписей = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыСведений.энргЗагрузкаПоказанийТочкиУчета);
	НаборЗаписей.Отбор.ДокументОснование.Установить(Объект.Ссылка);	
	НаборыЗаписей.Вставить("ТочкиУчета", НаборЗаписей);
	
	НаборЗаписей = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыСведений.энргЗагрузкаПоказанийШкалыПриборовУчета);
	НаборЗаписей.Отбор.ДокументОснование.Установить(Объект.Ссылка);
	НаборыЗаписей.Вставить("ШкалыПриборовУчета", НаборЗаписей);
	
	НаборЗаписей = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыСведений.энргЗагрузкаПоказанийПоказанияПриборовУчета);
	НаборЗаписей.Отбор.ДокументОснование.Установить(Объект.Ссылка);
	НаборыЗаписей.Вставить("ПоказанияПриборовУчета", НаборЗаписей);	
	
	Результат = Новый Структура("Статус", Истина);
	ПодготовитьНаборыЗаписейПоказаний(НаборыЗаписей);
	
	// Оплата
	НаборЗаписей = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыСведений.энргЗагрузкаОплат);
	НаборЗаписей.Отбор.ДокументОснование.Установить(Объект.Ссылка);
	НаборыЗаписей.Вставить("Оплата", НаборЗаписей);
	
	НаборЗаписей = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыСведений.энргЗагрузкаОплатЗадолженность);
	НаборЗаписей.Отбор.ДокументОснование.Установить(Объект.Ссылка);
	НаборыЗаписей.Вставить("Задолженность", НаборЗаписей);
	
	ПодготовитьНаборЗаписейОплат(НаборыЗаписей);
	
	НачатьТранзакцию();	
	Попытка
		
		Для Каждого СтрокаНабора из НаборыЗаписей Цикл
			
			ТаблицаЗаписи = СтрокаНабора.Значение;
			ТаблицаЗаписи.Записать();
						
		КонецЦикла;
		
		Объект.ТочкиУчета.Очистить();
		Объект.ШкалыПриборовУчета.Очистить();
		Объект.ПоказанияПриборовУчета.Очистить(); 
		Объект.Оплата.Очистить();
		Объект.Задолженность.Очистить();
		
		ЗафиксироватьТранзакцию();
	Исключение
	
		ОтменитьТранзакцию(); 	
		
		Результат.Статус = Ложь;
		ИнфаОбОшибке 									= ИнформацияОбОшибке();
		ПараметрыЖурнала								= энргОбщегоНазначения.НеобязательныеПараметрыРегистацииОшибки();
		ПараметрыЖурнала.ВыводитьСообщениеПользователю 	= Истина;
		ПараметрыЖурнала.ТекстПользователю 				= "Не удалось данные из внешних источников по причине: " + КраткоеПредставлениеОшибки(ИнфаОбОшибке);
		энргОбщегоНазначения.ЗарегистрироватьОшибку("Загрузка данных из внешних источников", УровеньЖурналаРегистрации.Ошибка, ПодробноеПредставлениеОшибки(ИнфаОбОшибке), ПараметрыЖурнала);
		
	КонецПопытки;
	
	УстановитьОтборСвязанныхДокументов();
		
КонецПроцедуры

