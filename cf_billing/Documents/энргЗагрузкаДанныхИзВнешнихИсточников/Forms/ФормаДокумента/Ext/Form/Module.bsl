#Область ОписаниеПеременных

&НаКлиенте
Перем ПодтвежденоЗакрытие;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	энргЛокализацияСервер.ПриСозданииНаСервере_энргПлатежноеПоручениеВходящие(ЭтотОбъект);	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			ЗаполнитьПериодНачисленияСервер();
		КонецЕсли;
	КонецЕсли; 
	
	ОбновитьКолВоСтрокВТЧ();
	
	Если не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
		яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
		энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета);
	КонецЕсли;
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	//// Фискализация ОФД
	//Если ПодсистемаИнтеграцияОФДСуществует() Тогда
	//	МодульфискОбщегоНазначения = энргОбщегоНазначения.МодульОбщегоНазначенияИнтеграцииОФД();
	//	МодульфискОбщегоНазначения.ПриСозданииНаСервере(ЭтотОбъект);
	//КонецЕсли;
	//// Фискализация ОФД
	
	УстановитьОтборСвязанныхДокументов();
	
КонецПроцедуры   

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗаполнитьКоличествоАктивныхДлительныхОпераций();
	ПоказатьНадписьСозданияДокументов();
	
КонецПроцедуры


&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Возврат;
	КонецЕсли;
	
	
	Если НЕ ПодтвежденоЗакрытие И НЕ ЗавершениеРаботы Тогда			
		СуммаОплат = энргМассовыйВводОплат.СуммаОплатПоСвязаннымДокументам(Объект.Ссылка);
		
		Если НЕ СуммаОплат = Объект.СуммаРеестра Тогда 
			
			Отказ = Истина;
			ТекстВопроса = НСтр("ru = 'Опознанная оплата и сумма реестра не совпадают. Продолжить работу с документом?'");
			ОповещениеОЗакрытии = Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект); 			
			ПоказатьВопрос(
				ОповещениеОЗакрытии, 
				ТекстВопроса, 
				РежимДиалогаВопрос.ДаНетОтмена);
			
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		
		ПодтвежденоЗакрытие = Истина;		
		Закрыть();
				
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоРайонПриЧтении(Объект.ТочкиУчета, ТекущийОбъект);
	
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект, яИспользоватьТарифныеЗоны, яИспользоватьШкалыПриборовУчета, ТекущийОбъект);
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект, "ТочкиУчета");
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект, "Оплата");
	
	энргРаботаСприборамиУчетаСервер.ЗаполнитьСвойствоРегистрируетОбъемПриЧтении(Объект.ТочкиУчета, ТекущийОбъект);
	
	ПоказанияПредоставляютсяВСрок();
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();	
	
	//// Фискализация ОФД
	//Если ПодсистемаИнтеграцияОФДСуществует() Тогда
	//	МодульфискОбщегоНазначения = энргОбщегоНазначения.МодульОбщегоНазначенияИнтеграцииОФД();
	//	ДокументФискализирован = МодульфискОбщегоНазначения.ПлатежныйДокументОтправленВСистемуОФД(Объект.Ссылка);
	//КонецЕсли;
	//// Фискализация ОФД
	
	ОсталосьСоздатьДокументовДлительныхОпераций = КоличествоОсталосьСоздатьДокументовРегистратора(ТекущийОбъект.Ссылка);
	СуммаОплатПоСозданнымДокументам = СуммаОплатПоСвязаннымДокументам(ТекущийОбъект.Ссылка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Объект.СуммаПоДокументу = Объект.Оплата.Итог("СуммаОплаты");
	Если Не ЗначениеЗаполнено(Объект.Примечание) Тогда
		Объект.Примечание = Объект.ФайлДляЧтения;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ЭтоЗаписьПослеЗагрузкиДанных = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ПараметрыЗаписи,
		"ЭтоЗаписьПослеЗагрузкиДанных",
		Ложь);
		
	Если ЭтоЗаписьПослеЗагрузкиДанных Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ОтменитьПроверкуСуммыСвязанныхДокументов", Истина);
	КонецЕсли;		
		
	энргШкалыТарифныеЗоныСервер.ЗаполнитьОбъектПоПредставлениюФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);	
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоРайонПриЧтении(Объект.ТочкиУчета,ТекущийОбъект); 
	
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета,ТекущийОбъект);
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ТочкиУчета");
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"Оплата"); 	
	энргРаботаСприборамиУчетаСервер.ЗаполнитьСвойствоРегистрируетОбъемПриЧтении(Объект.ТочкиУчета,ТекущийОбъект);
	
	//// Фискализация ОФД
	//Если ПодсистемаИнтеграцияОФДСуществует() Тогда
	//	МодульфискОбщегоНазначения = энргОбщегоНазначения.МодульОбщегоНазначенияИнтеграцииОФД();
	//	МодульфискОбщегоНазначения.ПослеЗаписи(ЭтотОбъект);
	//КонецЕсли;
	//// Фискализация ОФД
	
	УстановитьОтборСвязанныхДокументов();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	ЗависимыеРеквизиты = ПолучитьЗависимыеРеквизиты();
	Если ЗначениеЗаполнено(Объект.Ссылка) И НеобходимоСкорректироватьСвязанныеДокументы(Объект.Ссылка, ЗависимыеРеквизиты) Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения(
			"ПослеВопросаОНеобходимостиКорректировкиСвязанныхДокументов",
			ЭтотОбъект);		
			
		ПоказатьВопрос(
			ОписаниеОповещения,
			НСтр("ru = 'Дата документа была изменена. Даты документов созданных на основании будут скорректированы. Продолжить?'"),
			РежимДиалогаВопрос.ДаНет);
			
	КонецЕсли;
	
	ЗаполнитьПериодНачисленияСервер();		
	
КонецПроцедуры


&НаКлиенте
Процедура ФайлДляЧтенияПриИзменении(Элемент)
	ОчиститьСвязанныеДанные();
КонецПроцедуры

&НаКлиенте
Процедура ФайлДляЧтенияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Модифицированность = Истина;
	
	ЕстьПроведенныеСвязанныеДокументы = ЕстьСозданныеРегистрацииПоказанийОтДокументаОснования(Объект.Ссылка) ИЛИ 
		ЕстьСозданныеОплатыОтДокументаОснования(Объект.Ссылка);
		
	Если ЗначениеЗаполнено(Объект.Ссылка) и ЕстьПроведенныеСвязанныеДокументы Тогда
		
		Контекст = Новый Структура("ВыполнятьВыборФайла", Истина);
		ОписаниеОповещения = Новый ОписаниеОповещения(	
			"ПослеВопросаОПометкеСвязанныхДокументов",
			ЭтотОбъект,
			Контекст);
			
		ПоказатьВопрос(
			ОписаниеОповещения,
			НСтр("ru = 'На основании выбранного файла загрузки созданы документы, удалить их?'"),
			РежимДиалогаВопрос.ДаНетОтмена);
		
		Возврат;
		
	КонецЕсли;
	
	ФайлДляЧтенияНачалоВыбораКлиент();
		
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда 		
		ЗаполнитьПериодНачисленияСервер();		
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ПоставщикПриИзменении(Элемент) 	
	ОчиститьСвязанныеДанные();	
КонецПроцедуры

&НаКлиенте
Процедура ПоставщикНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ЕстьПроведенныеСвязанныеДокументы = ЕстьСозданныеРегистрацииПоказанийОтДокументаОснования(Объект.Ссылка) ИЛИ 
		ЕстьСозданныеОплатыОтДокументаОснования(Объект.Ссылка);
		
	Если ЗначениеЗаполнено(Объект.Ссылка) и ЕстьПроведенныеСвязанныеДокументы Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения(	
			"ПослеВопросаОПометкеСвязанныхДокументов",
			ЭтотОбъект);
			
		ПоказатьВопрос(
			ОписаниеОповещения,
			НСтр("ru = 'На основании выбранного источника поступления созданы документы, удалить их?'"),
			РежимДиалогаВопрос.ДаНетОтмена);
			
		СтандартнаяОбработка = Ложь;	
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры


#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОчиститьДанныеРеестра()
	
	Объект.ДатаРеестра = Дата(1, 1, 1);
	Объект.СуммаРеестра = 0;
	
КонецПроцедуры

#КонецОбласти


#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Загрузить(Команда)
	
	Если не ЗначениеЗаполнено(Объект.ФайлДляЧтения) тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите файл для чтения",,"ФайлДляЧтения","ФайлДляЧтения");
		Возврат;
	КонецЕсли;   	
	
	ДвоичныеДанные  	= Новый ДвоичныеДанные(Объект.ФайлДляЧтения); 	
	АдресХранилища  	= ПоместитьВоВременноеХранилище(ДвоичныеДанные,ЭтаФорма.УникальныйИдентификатор);
	
	ОписаниеОшибки  	= ЗагрузитьФайлСервер(АдресХранилища,Объект.ИсточникПоступления);
	ОписаниеОповещения 	= Новый ОписаниеОповещения("ПослеСообщенияОбОшибкеПередЗагрузкой",ЭтотОбъект);
	Если НЕ ПустаяСтрока(ОписаниеОшибки) Тогда
		ПоказатьВопрос(ОписаниеОповещения,ОписаниеОшибки,РежимДиалогаВопрос.ДаНет);
	иначе
		
		ЗарегистрироватьЗаписиКСозданиюДокументов();
		ОбновитьНадписьВыполненияДлительныхОперацийКлиент();		
		Если ОсталосьСоздатьДокументовДлительныхОпераций > 0 Тогда				
			ОткрытьФормуЗапускаСозданияДокументовВФоне();
		КонецЕсли;
		
		Модифицированность = Истина;
		ПараметрыЗаписи = Новый Структура("ЭтоЗаписьПослеЗагрузкиДанных", Истина);
		Записать(ПараметрыЗаписи);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуСоздатьНаОсновании(Команда)
	
	ВводНаОснованииКлиент.ВыполнитьПодключаемуюКомандуСоздатьНаОсновании(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры

&НаКлиенте
Процедура ИсправитьДанные(Команда)
	
	ТарифныеЗоны=ИспользоватьТарифныеЗоны;
	Шкалы=ИспользоватьШкалыПриборовУчета;
	ИсправитьДанныеНаСервере(ТарифныеЗоны, Шкалы);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПоказания(Команда)
	ОбновитьПоказанияНаСервере();
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат) Экспорт
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура ПодборЗадолженности(Команда)
	
	ТекущиеДанные 							= Элементы.Оплата.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;  
	
	СтруктураОтбора = Новый Структура("Период,ПериодНачисления,Организация,Район,Строение,Абонент,Услуга",КонецДня(Объект.Дата));
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,Объект);
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,ТекущиеДанные);
	
	МассивЗагруженныхПериодов = Новый Массив;
	
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
		ТекущиеДанные.IDСтроки 				= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	НайденныеСтроки = Объект.Задолженность.НайтиСтроки(Новый Структура("IDСтроки", ТекущиеДанные.IDСтроки));
	
	Для Каждого Строка Из НайденныеСтроки Цикл
		ЗагруженныеДанные = Новый Структура("ПериодНачисления, ВидЗадолженности", Строка.ПериодНачисления, Строка.ВидЗадолженности);
		МассивЗагруженныхПериодов.Добавить(Новый Структура("ПериодНачисления, ВидЗадолженности", Строка.ПериодНачисления, Строка.ВидЗадолженности));
		
	КонецЦикла;
	
	ПараметрыВыбораФормы	= Новый Структура("СтруктураОтбора, ЗагруженныеПериоды", СтруктураОтбора, МассивЗагруженныхПериодов);
	ОписаниеОповещения 		= Новый ОписаниеОповещения("ФормаЗадолженностьОкончаниеВыбора",ЭтаФорма,Новый Структура("IDСтроки", ТекущиеДанные.IDСтроки));
	
	ОткрытьФорму("Документ.энргПлатежноеПоручениеВходящие.Форма.ФормаВыбораЗадолженности",ПараметрыВыбораФормы, ЭтаФорма,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры


