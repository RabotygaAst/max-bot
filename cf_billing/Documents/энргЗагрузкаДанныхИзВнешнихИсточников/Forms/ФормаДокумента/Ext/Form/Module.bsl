	КонецЕсли;
		
	Если РезультатВыполнения.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение( ,РезультатВыполнения.КраткоеПредставлениеОшибки);
		Возврат;
	КонецЕсли; 	
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецОбласти

#Область РаботаСФоновымСозданиемДокументов

&НаКлиенте
Процедура ОткрытьФормуЗапускаСозданияДокументовВФоне()
	
	Контекст = Новый Структура("ДатаРеестра", Объект.ДатаРеестра);
	ПараметрыПередачи = Новый Структура("ДокументСсылка, Контекст", Объект.Ссылка, Контекст);
	ОповещениеЗакрытия = Новый ОписаниеОповещения("ПослеЗакрытияФормыРаботыВФоне", ЭтотОбъект);
	ОткрытьФорму(
		"Документ.энргЗагрузкаДанныхИзВнешнихИсточников.Форма.ФормаСозданияДокументовВФоне",
		ПараметрыПередачи,,,,,ОповещениеЗакрытия,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры
	
&НаКлиенте
Процедура ПослеЗакрытияФормыРаботыВФоне(РезультатЗакрытия, ДополнительныеПараметры) Экспорт 
	
	ОбновитьНадписьВыполненияДлительныхОперацийКлиент();
	СуммаОплатПоСозданнымДокументам = СуммаОплатПоСвязаннымДокументам(Объект.Ссылка);
	УстановитьОтборСвязанныхДокументов();
	ОбновитьДинамическиеСпискиСвязанныхДокументов();
	
КонецПроцедуры	


&НаКлиенте
Процедура ОткрытьФормуЗапускаСозданияДокументов(Команда)
	ОткрытьФормуЗапускаСозданияДокументовВФоне();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНадписьВыполненияДлительныхОпераций(Команда)
	
	ОбновитьНадписьВыполненияДлительныхОперацийКлиент();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНадписьВыполненияДлительныхОперацийКлиент()
	
	ОсталосьСоздатьДокументовДлительныхОпераций = КоличествоОсталосьСоздатьДокументовРегистратора(Объект.Ссылка);
	ЗаполнитьКоличествоАктивныхДлительныхОпераций();
	ПоказатьНадписьСозданияДокументов();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьНадписьСозданияДокументов()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ГрупппаВыполненияДлительныхОпераций",
		"Видимость",
		Истина);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"НадписьВыполненияДлительныхОпераций",
		"ЦветТекста",
		Новый Цвет(255,0,0));
						
	ЭтоСтараяВерсия = Ложь;
	Если ОсталосьСоздатьДокументовДлительныхОпераций = 0 ИЛИ ЭтоСтараяВерсия Тогда 
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ГрупппаВыполненияДлительныхОпераций",
			"Видимость",
			Ложь);
				
		Возврат;
		
	КонецЕсли;
		
	Если КоличествоАктивныхДлительныхОпераций > 0 Тогда
		
		ШаблонСтроки = "%1 документов осталось создать. Активных фоновых процессов %2";
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"НадписьВыполненияДлительныхОпераций",
			"Заголовок",
			СтрШаблон(ШаблонСтроки, ОсталосьСоздатьДокументовДлительныхОпераций, КоличествоАктивныхДлительныхОпераций));
			
		Возврат;
		
	КонецЕсли;	
	
	ШаблонСтроки = "%1 документов осталось создать. Активных фоновых процессов нет, необходимо повторно запустить процесс создания документов.";
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"НадписьВыполненияДлительныхОпераций",
		"Заголовок",
		СтрШаблон(ШаблонСтроки, ОсталосьСоздатьДокументовДлительныхОпераций));	
	
КонецПроцедуры
	
&НаСервереБезКонтекста
Функция КоличествоОсталосьСоздатьДокументовРегистратора(ДокументСсылка)	
	
	КоличествоПоказаний = РегистрыСведений.энргЗагрузкаПоказанийТочкиУчета.КоличествоОсталосьСоздатьДокументовРегистратора(ДокументСсылка);
	КоличествоОплат		= РегистрыСведений.энргЗагрузкаОплат.КоличествоОсталосьСоздатьДокументовРегистратора(ДокументСсылка);
	Результат = КоличествоПоказаний + КоличествоОплат;
	
	Возврат Результат;
	
КонецФункции	

&НаКлиенте
Процедура ЗаполнитьКоличествоАктивныхДлительныхОпераций()
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Возврат;
	КонецЕсли;
	
	Если ОсталосьСоздатьДокументовДлительныхОпераций = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	КоличествоАктивныхДлительныхОпераций = 0;
	Активные = ДлительныеОперацииКлиент.АктивныеДлительныеОперации();
	
	Для Каждого КлючЗначение Из Активные.Список Цикл
		Попытка
			
			Если КлючЗначение.Значение.ОповещениеОЗавершении.ДополнительныеПараметры.ДокументСсылка = Объект.Ссылка Тогда
				КоличествоАктивныхДлительныхОпераций = КоличествоАктивныхДлительныхОпераций + 1;					
			КонецЕсли; 			
			
		Исключение
			
		КонецПопытки;
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти

#Область СозданиеНовогоДокументаОплаты

&НаКлиенте
Процедура ДобавитьОплату(Команда)
	
	Если НЕ МожноДобавлятьНовыйОплату() Тогда 
		Возврат;
	КонецЕсли;
	
	ОткрытьФормуНовойОплаты();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьОплатуСписком(Команда)
	
	Если НЕ МожноДобавлятьНовыйОплату() Тогда 
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения 		= Новый ОписаниеОповещения("ФормаЗаполенияСпискаОплатОкончаниеВыбора",ЭтаФорма);
	
	ОткрытьФорму("Документ.энргЗагрузкаДанныхИзВнешнихИсточников.Форма.ФормаЗаполенияСпискаОплат",, ЭтаФорма,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

	
	
		
КонецПроцедуры

&НаКлиенте
Процедура ФормаЗаполенияСпискаОплатОкончаниеВыбора(РезультатЗакрытия,ДополнительныеПараметры) Экспорт  
	
	Если РезультатЗакрытия <> Неопределено Тогда 
		
		Модифицированность	= Истина;
		
		Для каждого СтрокаДолг Из РезультатЗакрытия Цикл
			
			СтрокаТЗ = Объект.Оплата.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЗ, СтрокаДолг);
			СтрокаТЗ.ДатаПлатежногоДокумента	 = Объект.Дата;
			
		КонецЦикла;
		
		ЗарегистрироватьЗаписиКСозданиюДокументов();
		ОбновитьНадписьВыполненияДлительныхОперацийКлиент();		
		Если ОсталосьСоздатьДокументовДлительныхОпераций > 0 Тогда				
			ОткрытьФормуЗапускаСозданияДокументовВФоне();
		КонецЕсли;
		
		ПараметрыЗаписи = Новый Структура("ЭтоЗаписьПослеЗагрузкиДанных", Истина);
		Записать(ПараметрыЗаписи);
		
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция МожноДобавлятьНовыйОплату()
	
	Ошибки = Новый Массив;	
	
	Если Параметры.Ключ.Пустая() Тогда		
		Ошибки.Добавить(НСтр("ru = 'Перед добавлением оплаты необходимо записать документ'"));		
	КонецЕсли;
	
	ПроверитьЗаполнениеОбязательныхПолейПереопределяемый(Ошибки);
	
	Если НЕ Ошибки.Количество() = 0 Тогда
		
		ЗаголовокПредупреждения = НСтр("ru = 'Ошибки перед добавлением оплаты'");
		ТекстПредупреждения = СтрСоединить(Ошибки, Символы.ПС);
		ПоказатьПредупреждение(, ТекстПредупреждения,, ЗаголовокПредупреждения);
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаКлиенте
Процедура ПроверитьЗаполнениеОбязательныхПолейПереопределяемый(Ошибки)
	
	Если НЕ ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда		
		Ошибки.Добавить(НСтр("ru = 'Заполните поле Период начисления'"));		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда		
		Ошибки.Добавить(НСтр("ru = 'Заполните поле Организация'"));		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Район) Тогда		
		Ошибки.Добавить(НСтр("ru = 'Заполните поле Район'"));		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.АбонентскийОтдел) Тогда		
		Ошибки.Добавить(НСтр("ru = 'Заполните поле Абонентский отдел'"));		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.ИсточникПоступления) Тогда		
		Ошибки.Добавить(НСтр("ru = 'Заполните поле Источник поступления'"));		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуНовойОплаты()
	
	ДобавлениеЕдиничнойОплаты = Новый Структура("ДобавлениеЕдиничнойОплаты");
	ПоляЗаполнения = Новый Структура(
		"ДокументОснование,Дата,ПериодНачисления,Организация,Район,АбонентскийОтдел,ИсточникПоступления,РазрешеноДобавлятьОплату");
	ЗаполнитьЗначенияСвойств(ПоляЗаполнения, Объект);
	ПоляЗаполнения.ДокументОснование = Объект.Ссылка;
	ПоляЗаполнения.РазрешеноДобавлятьОплату = Истина;
	ДобавлениеЕдиничнойОплаты = Новый Структура("ДобавлениеЕдиничнойОплаты", ПоляЗаполнения);
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ДобавлениеЕдиничнойОплаты);
	
	ОткрытьФорму("Документ.энргПлатежноеПоручениеВходящие.Форма.ФормаДокумента", ПараметрыФормы);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

ПодтвежденоЗакрытие = Ложь;