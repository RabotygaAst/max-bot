#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	энргЛокализацияСервер.ПриСозданииНаСервере_энргОбходнойЛист(ЭтотОбъект);
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если НЕ ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			ОпределитьПериодНачисления();
		КонецЕсли;
	КонецЕсли;
	УстановитьСвойстваЭлементовФормы();
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	УстановитьЗначениеСвойстваСкрытьСтроку();
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьОтборТарифныхЗонПоУмолчанию();
	ЗаполнитьКоличествоАктивныхДлительныхОпераций();
	ПоказатьНадписьСозданияДокументов();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ОбновитьСоответствиеПриборовУчета();
	ОсталосьСоздатьДокументовДлительныхОпераций = КоличествоОсталосьСоздатьДокументовРегистратора(ТекущийОбъект.Ссылка);
	
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда		
		ОпределитьПериодНачисления();
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	
	ОпределитьПериодНачисления();
	
КонецПроцедуры

&НаКлиенте
Процедура ИсточникПоказанийПриИзменении(Элемент)
	УстановитьСвойстваЭлементовФормы();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыНеЗагруженныеДанныеНеЗагруженныеПоказания

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияАбонентСталПриИзменении(Элемент)
	ТекДанные = Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказания.ТекущиеДанные;
	ТекДанные.ЛицевойСчетСтал = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекДанные.АбонентСтал, "ЛицевойСчет");
	ЗаполнитьСтрокуЛицевымСчетом();
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияЛицевойСчетПриИзменении(Элемент)
	ЗаполнитьСтрокуЛицевымСчетом();
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияЛицевойСчетГИСЖКХПриИзменении(Элемент)
	ЗаполнитьСтрокуЛицевымСчетом();
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияЛицевойСчетПолитарифПриИзменении(Элемент)
	ЗаполнитьСтрокуЛицевымСчетом();
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияЛицевойСчетСталПриИзменении(Элемент)
	ЗаполнитьСтрокуЛицевымСчетом();
КонецПроцедуры 

&НаКлиенте
Процедура ЗаполнитьСтрокуЛицевымСчетом()
	ТекДанные 				= Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказания.ТекущиеДанные;
	ПараметрыЛицевогоСчета 	= ОпределитьАктуальныеПараметрыЛицевогоСчета(ТекДанные);
	ЗаполнитьСвязанныеСвойстваЛицевогоСчета(ТекДанные, ПараметрыЛицевогоСчета);
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияПриАктивизацииСтроки(Элемент)
	
	УстановитьОтборСтрокПоказаний();
	
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияНомерПрибораУчетаСталоПриИзменении(Элемент)
	ТекДанные = Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказания.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекДанные.МКД) Тогда 
		ОбновитьДанныеПрибораУчетаМКД(ТекДанные);
	Иначе
		ПараметрыЛицевогоСчета = ОпределитьАктуальныеПараметрыЛицевогоСчета(ТекДанные);
		ОбновитьДанныеПрибораУчета(ТекДанные, ПараметрыЛицевогоСчета); 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НеЗагруженныеДанныеНеЗагруженныеПоказанияНомерПрибораУчетаСталоНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекДанные = Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказания.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекДанные.МКД) Тогда 
		ОпределитьАктуальныеПриборыУчетаМКД(ТекДанные);
	Иначе
		ПараметрыЛицевогоСчета = ОпределитьАктуальныеПараметрыЛицевогоСчета(ТекДанные);
		ОпределитьАктуальныеПриборыУчета(ТекДанные, ПараметрыЛицевогоСчета); 
	КонецЕсли;
	// ОбновитьДанныеПрибораУчета(ТекДанные, ПараметрыЛицевогоСчета); тест закоментил
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗначениеСвойстваСкрытьСтроку()
	
	Для Каждого ТекСтрока Из Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания Цикл		
		ТекСтрока.СкрытьСтроку = ТекСтрока.ОписаниеОшибки = "Не найден прибор учета";
	КонецЦикла;
	
КонецПроцедуры

#Область ОбновлениеДанныхПоЛицевомуСчету

&НаКлиенте
Функция ОпределитьАктуальныеПараметрыЛицевогоСчета(ТекДанные)
	Результат = Новый Структура("ЛицевойСчет, ЭтоПрефиксСтал", ТекДанные.ЛицевойСчет, Ложь);
	Если НЕ ПустаяСтрока(ТекДанные.ЛицевойСчетСтал) Тогда
		Результат.ЛицевойСчет 		= ТекДанные.ЛицевойСчетСтал;	
		Результат.ЭтоПрефиксСтал 	= Истина;	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

&НаКлиенте
Процедура ЗаполнитьСвязанныеСвойстваЛицевогоСчета(ТекДанные, ПараметрыЛицевогоСчета)	
	
	ОтветАбонентИСвязанныеСвойства 	= ОтветАбонентИСвязанныеСвойства();
	ЛицевойСчет						= ПараметрыЛицевогоСчета.ЛицевойСчет;
	Если ПустаяСтрока(ЛицевойСчет) Тогда
		ЗаполнитьСвойстваАбонента(ТекДанные, ОтветАбонентИСвязанныеСвойства, ПараметрыЛицевогоСчета);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан лицевой счет");
		Возврат;
	КонецЕсли;
	
	ОпределитьАбонентаИСвязанныеСвойства(ЛицевойСчет, ОтветАбонентИСвязанныеСвойства);
	ЗаполнитьСвойстваАбонента(ТекДанные, ОтветАбонентИСвязанныеСвойства, ПараметрыЛицевогоСчета);
	ОбновитьДанныеПрибораУчета(ТекДанные, ПараметрыЛицевогоСчета);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСвойстваАбонента(ТекДанные, ОтветАбонентИСвязанныеСвойства, ПараметрыЛицевогоСчета)
	Если ПараметрыЛицевогоСчета.ЭтоПрефиксСтал Тогда
		ТекДанные.АбонентСтал 		= ОтветАбонентИСвязанныеСвойства.Абонент;
		ТекДанные.Район 			= ОтветАбонентИСвязанныеСвойства.Район;
		ТекДанные.КлючПомещенияСтал = ОтветАбонентИСвязанныеСвойства.КлючПомещения;
	Иначе 
		ЗаполнитьЗначенияСвойств(ТекДанные, ОтветАбонентИСвязанныеСвойства);
	КонецЕсли;	
КонецПроцедуры 

&НаСервереБезКонтекста
Процедура ОпределитьАбонентаИСвязанныеСвойства(ЛицевойСчет, Результат)
	Результат.Абонент = Справочники.энргАбоненты.НайтиПоРеквизиту("ЛицевойСчет", ЛицевойСчет);	
	
	РеквизитыАбонента = Обработки.энргАбонентыМенеджер.ЗначенияРеквизитовОбъекта(Результат.Абонент, "Район, КлючПомещения");
	Результат.Район			= РеквизитыАбонента.Район;
	Результат.КлючПомещения	= РеквизитыАбонента.КлючПомещения; 
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОтветАбонентИСвязанныеСвойства()
	Результат = Новый Структура;
	Результат.Вставить("Абонент"		, Справочники.энргАбоненты.ПустаяСсылка());
	Результат.Вставить("Район"			, Справочники.энргЗоныОтвественности.ПустаяСсылка());
	Результат.Вставить("КлючПомещения"	, Справочники.энргКлючиПомещений.ПустаяСсылка());
	
	Возврат Результат;
КонецФункции

#КонецОбласти 

#Область ОбновлениеДанныхПоПриборамУчета

&НаКлиенте
Процедура ОпределитьАктуальныеПриборыУчета(ТекДанные, ПараметрыЛицевогоСчета)
	
	ЛицевойСчет	= ПараметрыЛицевогоСчета.ЛицевойСчет;
	Если ПустаяСтрока(ЛицевойСчет) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан лицевой счет");
		Возврат;
	КонецЕсли;	
	ИдентификаторСтроки = ТекДанные.IDСтроки;
	
	ПараметрыОтбораПрибораУчета = НовыеПараметрыОтбораПрибораУчета();
	ПараметрыОтбораПрибораУчета.Вставить("Организация", Объект.Организация);
	ПараметрыОтбораПрибораУчета.Вставить("Период", Объект.Дата);
	ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало 	= ТекДанные.НомерПрибораУчетаСтало;
	ПараметрыОтбораПрибораУчета.Район 					= ТекДанные.Район;
	Если ПараметрыЛицевогоСчета.ЭтоПрефиксСтал Тогда
		ПараметрыОтбораПрибораУчета.Абонент 		= ТекДанные.АбонентСтал;
		ПараметрыОтбораПрибораУчета.КлючПомещения 	= ТекДанные.КлючПомещенияСтал;
	Иначе		
		ПараметрыОтбораПрибораУчета.Абонент 		= ТекДанные.Абонент;
		ПараметрыОтбораПрибораУчета.КлючПомещения 	= ТекДанные.КлючПомещения;
	КонецЕсли;
	
	мПриборыУчета = Новый Массив;
	ПредставлениеПриборыУчета = Новый СписокЗначений;// Обратная совместимость
	АктуальныеПриборыУчета(ПараметрыОтбораПрибораУчета, мПриборыУчета, ПредставлениеПриборыУчета);
	
	ДополнитьАктуальныеПриборыУчетаКлючаПомещенияКВыбору(ПредставлениеПриборыУчета);
	
КонецПроцедуры

