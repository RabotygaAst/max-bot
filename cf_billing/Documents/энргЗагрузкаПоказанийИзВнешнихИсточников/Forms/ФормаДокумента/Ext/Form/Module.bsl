#Область ЗагрузкаДанных

&НаКлиенте
Процедура ЗаполнитьПоказания(Команда)
	
	Ошибки = ПроверитьВозможностьЗагрузки();
	Если НЕ ПустаяСтрока(Ошибки) Тогда 
		НовоеОписаниеОповощение = Новый ОписаниеОповещения("ЗаполнитьПоказанияПослеВопроса", ЭтотОбъект);
		ПоказатьВопрос(НовоеОписаниеОповощение,Ошибки,РежимДиалогаВопрос.ДаНет,,,,);
		Возврат;
	КонецЕсли;
	Если ЕстьНеЗагруженныеДанные() Тогда 
		НовоеОписаниеОповощение = Новый ОписаниеОповещения("ЗаполнитьПоказанияПослеВопросаОчистки", ЭтотОбъект);
		ПоказатьВопрос(НовоеОписаниеОповощение, "Данные табличных частей документа будут очищены. Продолжить загрузку?", РежимДиалогаВопрос.ДаНет,,, "Очистка данных");
	Иначе 
		ЗагрузитьПоказания();
	КонецЕсли;
	
	//ОбновитьСоответствиеПриборовУчета();
	
КонецПроцедуры

#КонецОбласти  

&НаКлиенте
Процедура ОткрытьФормуЗапускаСозданияДокументов(Команда)
	ОткрытьФормуЗапускаСозданияДокументовВФоне();
КонецПроцедуры

#КонецОбласти   

#Область СлужебныеПроцедурыИФункции

#Область ЗагрузкаДанныхИзВнешнихИсточников

&НаКлиенте
Процедура ЗаполнитьПоказанияПослеВопросаОчистки(Результат, ДопПараметры) Экспорт
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьТЧ();
	ЗагрузитьПоказания();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоказанияПослеВопроса(Результат, ДопПараметры) Экспорт
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Записать();    
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьПоказания()
	
	ЭтотОбъект.Модифицированность = Истина;
	АдресВХ = УпаковатьВоВременноеХранилище(объект.ФайлДляЧтения);
	ОбработатьФайлНаСервере(АдресВХ);
	Записать();
	
	ОбновитьНадписьВыполненияДлительныхОперацийКлиент();
	ОткрытьФормуЗапускаСозданияДокументовВФоне();
	
КонецПроцедуры

&НаКлиенте
Функция УпаковатьВоВременноеХранилище(ФайлДляЧтения)
	Файл 	= Новый ДвоичныеДанные(ФайлДляЧтения);
	Адрес 	= ПоместитьВоВременноеХранилище(Файл, ЭтаФорма.УникальныйИдентификатор);
	
	Возврат Адрес;
КонецФункции 

&НаСервере
Процедура ОбработатьФайлНаСервере(АдресВХ)
	ОбработкаЗагрузки 	= ПолучитьОбработкуЗагрузки();
	ОбработкаЗагрузки.ЗагрузитьПоказания(Объект, АдресВХ);
КонецПроцедуры 

#КонецОбласти

#Область ИсправлениеДанныхЗагруженныхИзВнешнихИсточников

&НаКлиенте
Процедура ИсправитьДанные(Команда)
	Ошибки = ПроверитьВозможностьЗагрузки(Истина);
	Если НЕ ПустаяСтрока(Ошибки) Тогда 
		НовоеОписаниеОповощение = Новый ОписаниеОповещения("ИсправитьДанныеПослеВопроса", ЭтотОбъект);
		ПоказатьВопрос(НовоеОписаниеОповощение,Ошибки,РежимДиалогаВопрос.ДаНет,,,,);
		Возврат;
	КонецЕсли;
	
	ИсправитьДанныеНаСервере();
	ЭтотОбъект.Модифицированность = Истина;
	Записать();
КонецПроцедуры

&НаКлиенте
Процедура ИсправитьДанныеПослеВопроса(Результат, ДопПараметры) Экспорт
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ИсправитьДанныеНаСервере();
	Записать();    
КонецПроцедуры


&НаСервере
Процедура ИсправитьДанныеНаСервере()
	
	ОбработкаЗагрузки = ПолучитьОбработкуЗагрузки();	
	МассивID = Новый Массив;
	Для Каждого СтрокаПрибора из Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания Цикл
		Если ПропуститьСтрокуИсправленияДанных(СтрокаПрибора) Тогда 
			Продолжить;
		КонецЕсли;	
		
		МассивID.Добавить(СтрокаПрибора.IDСтроки);
	КонецЦикла;
	
	Успешно 			= Ложь;
	РезультатЗапроса 	= ТаблицаДанныхКПереносу(МассивID);
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	
	ОбработкаЗагрузки.ОбработатьИсправленныеДанные(Объект, РезультатЗапроса, Успешно, ДополнительныеПараметры);
	
	Если ДополнительныеПараметры.Свойство("МассивID") Тогда 
		УстановитьПризнакИсправленияСтрок(ДополнительныеПараметры.МассивID);
		Возврат;
	КонецЕсли;
		
	Если НЕ Успешно Тогда 
		Возврат;
	КонецЕсли;
	
	УстановитьПризнакИсправленияСтрок(МассивID);
		
КонецПроцедуры

&НаСервере
Процедура УстановитьПризнакИсправленияСтрок(МассивID)
	
	Для Каждого СтрокаИдентификатор из МассивID Цикл
		СвязаныеСтроки = Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания.НайтиСтроки(Новый Структура("IDСтроки", СтрокаИдентификатор)); 			
		Для Каждого СтрокаОшибочныхДанных из СвязаныеСтроки Цикл
			СтрокаОшибочныхДанных.Исправлен = Истина;					
		КонецЦикла;		
	КонецЦикла;
	
КонецПроцедуры


&НаСервере
Функция ПропуститьСтрокуИсправленияДанных(СтрокаПрибора)
	Пропустить = Ложь;
	
	Если СтрокаПрибора.Исправлен Тогда
		Пропустить = Истина;
	ИначеЕсли ПустаяСтрока(СтрокаПрибора.НомерПрибораУчетаСтало) Тогда 
		Пропустить = Истина;
	ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаПрибора.КлючПомещения) И НЕ ЗначениеЗаполнено(СтрокаПрибора.КлючПомещенияСтал) И НЕ ЗначениеЗаполнено(СтрокаПрибора.МКД) Тогда
		Пропустить = Истина;
	КонецЕсли;
	
	Возврат Пропустить;
КонецФункции

&НаСервере
Функция ТаблицаДанныхКПереносу(МассивID)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.IDСтроки КАК IDСтроки,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.Абонент КАК Абонент,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.КлючПомещения КАК КлючПомещения,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.МКД КАК МКД,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.Услуга КАК Услуга,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.ДатаПоказаний КАК ДатаПоказаний
	|ПОМЕСТИТЬ ТаблицаТочкиУчета
	|ИЗ
	|	&ТаблицаТочкиУчета КАК энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета
	|ГДЕ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковТочкиУчета.IDСтроки В(&МассивID)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.IDСтроки КАК IDСтроки,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.IDСтрокиТочкиУчета КАК IDСтрокиТочкиУчета,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.ВидДифференцированности КАК ВидДифференцированности,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.Шкала КАК Шкала
	|ПОМЕСТИТЬ ТаблицаШкалыПриборовУчета
	|ИЗ
	|	&ТаблицаШкалыПриборовУчета КАК энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета
	|ГДЕ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковШкалыПриборовУчета.IDСтрокиТочкиУчета В(&МассивID)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.IDСтроки КАК IDСтроки,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.IDСтрокиТочкиУчета КАК IDСтрокиТочкиУчета,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.ТекущиеПоказания КАК ТекущиеПоказания,
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.ПредыдущиеПоказания КАК ПредыдущиеПоказания
	|ПОМЕСТИТЬ ТаблицаПоказанияПриборовУчета
	|ИЗ
	|	&ТаблицаПоказанияПриборовУчета КАК энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета
	|ГДЕ
	|	энргЗагрузкаПоказанийИзВнешнихИсточниковПоказанияПриборовУчета.IDСтрокиТочкиУчета В(&МассивID)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	ТаблицаТочкиУчета.IDСтроки КАК IDСтроки,
	|	ТаблицаТочкиУчета.Абонент КАК Абонент,
	|	ТаблицаТочкиУчета.КлючПомещения КАК КлючПомещения,
	|	ТаблицаТочкиУчета.МКД КАК МКД,
	|	ТаблицаТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	ТаблицаТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	ТаблицаТочкиУчета.Услуга КАК Услуга,
	|	ТаблицаШкалыПриборовУчета.ВидДифференцированности КАК ВидДифференцированности,
	|	ТаблицаШкалыПриборовУчета.Шкала КАК Шкала,
	|	ТаблицаПоказанияПриборовУчета.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТаблицаПоказанияПриборовУчета.ТекущиеПоказания КАК ТекущиеПоказанияФайла,
	|	ТаблицаПоказанияПриборовУчета.ПредыдущиеПоказания КАК ПредыдущиеПоказания,
	|	ЕСТЬNULL(энргАбоненты.Район, энргСтроения.Район) КАК Район,
	|	ТаблицаТочкиУчета.ДатаПоказаний КАК ДатаПоказаний
	|ИЗ
	|	ТаблицаТочкиУчета КАК ТаблицаТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаШкалыПриборовУчета КАК ТаблицаШкалыПриборовУчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПоказанияПриборовУчета КАК ТаблицаПоказанияПриборовУчета
	|			ПО ТаблицаШкалыПриборовУчета.IDСтроки = ТаблицаПоказанияПриборовУчета.IDСтроки
	|		ПО ТаблицаТочкиУчета.IDСтроки = ТаблицаШкалыПриборовУчета.IDСтрокиТочкиУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|		ПО ТаблицаТочкиУчета.Абонент = энргАбоненты.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения КАК энргСтроения
	|		ПО ТаблицаТочкиУчета.МКД = энргСтроения.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТочкаУчета,
	|	ПриборУчета,
	|	Шкала";
	
	Запрос.УстановитьПараметр("ТаблицаТочкиУчета"				, Объект.ТочкиУчета.Выгрузить());
	Запрос.УстановитьПараметр("ТаблицаШкалыПриборовУчета"		, Объект.ШкалыПриборовУчета.Выгрузить());
	Запрос.УстановитьПараметр("ТаблицаПоказанияПриборовУчета"	, Объект.ПоказанияПриборовУчета.Выгрузить());
	Запрос.УстановитьПараметр("МассивID"						, МассивID);
	Запрос.УстановитьПараметр("Организация"						, Объект.Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса;
КонецФункции

#КонецОбласти

#Область ОперацииСОбработкойЗагрузки

&НаСервереБезКонтекста
Функция СсылкаНаОбработкуЗагрузки(ИсточникПоказаний)
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИсточникПоказаний, "ОбработкаЗагрузки");
КонецФункции

&НаСервере
Функция ПолучитьОбработкуЗагрузки()
	СсылкаНаОбработкуЗагрузки = СсылкаНаОбработкуЗагрузки(Объект.ИсточникПоказаний);
	Возврат Обработки[СсылкаНаОбработкуЗагрузки.Имя].Создать();
КонецФункции

&НаСервере
Функция ПолучитьФильтрФайлов()
	ОбработкаЗагрузки = ПолучитьОбработкуЗагрузки();
	Возврат ОбработкаЗагрузки.ФильтрФайлов();
КонецФункции

#КонецОбласти

#Область ПроверкаДанных

&НаКлиенте
Функция ПроверитьВозможностьЗагрузки(ПроверятьМодифицированность = Ложь)
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Результат.Добавить("Перед загрузкой необходимо записать документ. Записать данный документ?");
	КонецЕсли;
	Если ПроверятьМодифицированность И Модифицированность Тогда 
		Результат.Добавить("Документ изменен. Перед исправлением данных необходимо записать документ. Записать данный документ?");
	КонецЕсли;		
	
	ПроверитьОбработкуЗагрузки(Результат);
	
	Если НЕ ЗначениеЗаполнено(Объект.ФайлДляЧтения) Тогда
		Результат.Добавить("Укажите файл для чтения");
	КонецЕсли; 	
	
	Возврат СтрСоединить(Результат, ". ");
КонецФункции

&НаКлиенте
Функция ПроверитьОбработкуЗагрузки(Результат)
	Если ЗначениеЗаполнено(Объект.ИсточникПоказаний) Тогда 		
		ОбработкаЗагрузки = СсылкаНаОбработкуЗагрузки(Объект.ИсточникПоказаний);
		Если ОбработкаЗагрузки = ПредопределенноеЗначение("Справочник.ИдентификаторыОбъектовМетаданных.ПустаяСсылка") Тогда 
			Результат.Добавить("У источника показаний не указана обработка загрузки");
		КонецЕсли;
	Иначе 
		Результат.Добавить("Укажите источник показаний");
	КонецЕсли;
КонецФункции

#КонецОбласти

#Область УправлениеСвойствамиЭлементовФормы

&НаСервере
Процедура УстановитьСвойстваЭлементовФормы()
	ИмяГруппы = "ДанныеАбонента";
	ПолучитьИмяГруппыДляОтображения(ИмяГруппы);
	
	Если ИмяГруппы = "ДанныеАбонентаЕИРЦ" Тогда 		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаЕИРЦ", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонента", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаПолитариф", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаГИСЖКХ", "Видимость", Ложь);
	ИначеЕсли ИмяГруппы = "ДанныеАбонентаПолитариф"  Тогда 
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонента", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаЕИРЦ", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаПолитариф", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаГИСЖКХ", "Видимость", Ложь);
	ИначеЕсли ИмяГруппы = "ДанныеАбонентаГИСЖКХ"  Тогда 
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонента", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаЕИРЦ", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаПолитариф", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаГИСЖКХ", "Видимость", Истина);
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонента", "Видимость", Истина);		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаЕИРЦ", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаПолитариф", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеАбонентаГИСЖКХ", "Видимость", Ложь);		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПолучитьИмяГруппыДляОтображения(ИмяГруппы)
	ИмяОбработки = Объект.ИсточникПоказаний.ОбработкаЗагрузки.ПолноеИмя;
	
	ОбработкаПолитариф = Метаданные.Обработки.Найти("энргЗагрузкаПоказанийПолитариф");
	ОбработкаГИСЖКХ = Метаданные.Обработки.Найти("энргЗагрузкаПоказанийГИСЖКХ");
		
	Если Не ОбработкаПолитариф = Неопределено И ОбработкаПолитариф.ПолноеИмя() = ИмяОбработки Тогда 	
		ИмяГруппы = "ДанныеАбонентаПолитариф";
	ИначеЕсли Не ОбработкаГИСЖКХ = Неопределено И ОбработкаГИСЖКХ.ПолноеИмя() = ИмяОбработки Тогда 	
		ИмяГруппы = "ДанныеАбонентаГИСЖКХ";
	КонецЕсли; 	
КонецПроцедуры                 

#КонецОбласти

#Область РаботаСОтборами

&НаКлиенте
Процедура УстановитьОтборТарифныхЗонПоУмолчанию() 
	ИмяТаблицыПоказаний						= "НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона";
	ИмяТаблицыОригинальныхЗон				= "ТекущиеПоказанияПриборовУчета";
	ТаблицаФормыПоказаний	 				= Элементы[ИмяТаблицыПоказаний];
	ТаблицаФормыОригинальныхЗон				= Элементы[ИмяТаблицыОригинальныхЗон];
	
	ТаблицаФормыПоказаний.ОтборСтрок		= Новый ФиксированнаяСтруктура("ОригинальнаяТарифнаяЗона", Ложь);
	//	ТаблицаФормыОригинальныхЗон.ОтборСтрок	= Новый ФиксированнаяСтруктура("ОригинальнаяТарифнаяЗона", Истина); 
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборСтрокПоказаний()
	
	ИмяТаблицыТочек 						= "НеЗагруженныеДанныеНеЗагруженныеПоказания";
	ИмяТаблицыПоказаний						= "НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона";
	ИмяТаблицыОригинальныхЗон				= "ТекущиеПоказанияПриборовУчета";
	ТаблицаФормыПоказаний	 				= Элементы[ИмяТаблицыПоказаний];
	ТаблицаФормыОригинальныхЗон				= Элементы[ИмяТаблицыОригинальныхЗон];
	
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаФормыПоказаний.ОтборСтрок		= Новый ФиксированнаяСтруктура("IDСтроки, ОригинальнаяТарифнаяЗона", ТекущиеДанные.IDСтроки, Ложь);
	ТаблицаФормыОригинальныхЗон.ОтборСтрок	= Новый ФиксированнаяСтруктура("IDСтрокиТочкиУчета", ТекущиеДанные.IDСтроки);
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСФоновымСозданиемДокументов

&НаКлиенте
Процедура ОткрытьФормуЗапускаСозданияДокументовВФоне()
	
	Если НЕ ОбработкаРаботаетВФоне() Тогда 
		Возврат;
	КонецЕсли;
	
	ПараметрыПередачи = Новый Структура("ДокументСсылка", Объект.Ссылка);
	ОповещениеЗакрытия = Новый ОписаниеОповещения("ПослеЗакрытияФормыРаботыВФоне", ЭтотОбъект);
	ОткрытьФорму(
		"Документ.энргЗагрузкаПоказанийИзВнешнихИсточников.Форма.ФормаСозданияДокументовВФоне",
		ПараметрыПередачи,,,,,ОповещениеЗакрытия,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры
	
&НаКлиенте
Процедура ПослеЗакрытияФормыРаботыВФоне(РезультатЗакрытия, ДополнительныеПараметры) Экспорт 
	
	ОбновитьНадписьВыполненияДлительныхОперацийКлиент();	
		
КонецПроцедуры	


&НаКлиенте
Процедура ОбновитьНадписьВыполненияДлительныхОпераций(Команда)
	
	ОбновитьНадписьВыполненияДлительныхОперацийКлиент();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНадписьВыполненияДлительныхОперацийКлиент()
	
	ОсталосьСоздатьДокументовДлительныхОпераций = КоличествоОсталосьСоздатьДокументовРегистратора(Объект.Ссылка);
	ЗаполнитьКоличествоАктивныхДлительныхОпераций();
	ПоказатьНадписьСозданияДокументов();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьНадписьСозданияДокументов()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"НадписьВыполненияДлительныхОпераций",
			"ЦветТекста",
			Новый Цвет(255,0,0));
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ОбновитьНадписьВыполненияДлительныхОпераций",
			"Видимость",
			Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ОткрытьФормуЗапускаСозданияДокументов",
			"Видимость",
			Ложь);
			
	Если НЕ ОбработкаРаботаетВФоне() Тогда 
		Возврат;
	КонецЕсли;
			
	Если ОсталосьСоздатьДокументовДлительныхОпераций = 0 Тогда 
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"НадписьВыполненияДлительныхОпераций",
			"Заголовок",
			"Документы созданы");
			
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"НадписьВыполненияДлительныхОпераций",
			"ЦветТекста",
			Новый Цвет(0,150,70));
			
		Возврат;
		
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ОбновитьНадписьВыполненияДлительныхОпераций",
			"Видимость",
			Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ОткрытьФормуЗапускаСозданияДокументов",
			"Видимость",
			Истина);		
	
	Если КоличествоАктивныхДлительныхОпераций > 0 Тогда
		
		ШаблонСтроки = "%1 документов осталось создать. Активных фоновых процессов %2";
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"НадписьВыполненияДлительныхОпераций",
			"Заголовок",
			СтрШаблон(ШаблонСтроки, ОсталосьСоздатьДокументовДлительныхОпераций, КоличествоАктивныхДлительныхОпераций));
			
		Возврат;
		
	КонецЕсли;	
	
	ШаблонСтроки = "%1 документов осталось создать. Активных фоновых процессов нет, необходимо повторно запустить процесс создания документов.";
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"НадписьВыполненияДлительныхОпераций",
		"Заголовок",
		СтрШаблон(ШаблонСтроки, ОсталосьСоздатьДокументовДлительныхОпераций));
	
	
КонецПроцедуры
	
&НаСервереБезКонтекста
Функция КоличествоОсталосьСоздатьДокументовРегистратора(ДокументСсылка)	
	
	Возврат	РегистрыСведений.энргЗагрузкаПоказанийТочкиУчета.КоличествоОсталосьСоздатьДокументовРегистратора(ДокументСсылка);
	
КонецФункции	

&НаКлиенте
Процедура ЗаполнитьКоличествоАктивныхДлительныхОпераций()
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Возврат;
	КонецЕсли;
	
	Если ОсталосьСоздатьДокументовДлительныхОпераций = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	КоличествоАктивныхДлительныхОпераций = 0;
	Активные = ДлительныеОперацииКлиент.АктивныеДлительныеОперации();
	
	Для Каждого КлючЗначение Из Активные.Список Цикл
		Попытка
			
			Если КлючЗначение.Значение.ОповещениеОЗавершении.ДополнительныеПараметры.ДокументСсылка = Объект.Ссылка Тогда
				КоличествоАктивныхДлительныхОпераций = КоличествоАктивныхДлительныхОпераций + 1;					
			КонецЕсли; 			
			
		Исключение
			
		КонецПопытки;
	КонецЦикла;	
	
КонецПроцедуры


&НаКлиенте
Функция ОбработкаРаботаетВФоне()
	
	Результат = Ложь;
	
	Если НЕ ЗначениеЗаполнено(Объект.ИсточникПоказаний) Тогда 
		Возврат Результат;
	КонецЕсли;
	
	ОбработкаЗагрузки = СсылкаНаОбработкуЗагрузки(Объект.ИсточникПоказаний);
	Если НЕ ЗначениеЗаполнено(ОбработкаЗагрузки) Тогда 
		Возврат Результат;
	КонецЕсли; 
	
	ИмяОбработки = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбработкаЗагрузки, "Имя");
	Если ИмяОбработки = "рксИнтеграцияСМобильнымПриложениемКонтролера" 
		Или ИмяОбработки = "рксЗагрузкаПоказанийИнтеллектуальныхПУ"
		Или ИмяОбработки = "энргЗагрузкаПоказанийГИСЖКХ"
		Или ИмяОбработки = "энргЗагрузкаПоказанийПирамидаЧерезExcel" Тогда 
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти


&НаКлиенте
Процедура ФайлДляЧтенияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	Ошибки = Новый Массив;
	ПроверитьОбработкуЗагрузки(Ошибки); 	
	Если Ошибки.Количество() > 0 Тогда
		ТекстПредупреждение = СтрСоединить(Ошибки, ". ");
		ПоказатьПредупреждение(, ТекстПредупреждение);
		Возврат;
	КонецЕсли;
	
	
	СтандартнаяОбработка 		= Ложь;
	Диалог 						= Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр 				= ПолучитьФильтрФайлов();
	Если Диалог.Выбрать() тогда
		Объект.ФайлДляЧтения 	= Диалог.ПолноеИмяФайла;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ОпределитьПериодНачисления()
	Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация, Объект.Район);
КонецПроцедуры

&НаСервере
Процедура ОчиститьТЧ(ИдентификаторСтроки = Неопределено)
	ТаблицаТочек 		= Объект.ТочкиУчета;
	ТаблицаШкалы 		= Объект.ШкалыПриборовУчета;
	ТаблицаПоказания 	= Объект.ПоказанияПриборовУчета;
	
	Если ИдентификаторСтроки = Неопределено Тогда
		ТаблицаТочек.Очистить();
		ТаблицаШкалы.Очистить();
		ТаблицаПоказания.Очистить();
	Иначе
		ОтборыУдаления = Новый Структура("IDСтрокиТочкиУчета", ИдентификаторСтроки);
		энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(ТаблицаТочек		, Новый Структура("IDСтроки", ИдентификаторСтроки));
		энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(ТаблицаШкалы		, ОтборыУдаления);
		энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(ТаблицаПоказания	, ОтборыУдаления);
	КонецЕсли; 	
КонецПроцедуры

&НаСервере
Функция ЕстьНеЗагруженныеДанные()
	Возврат Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания.Количество() > 0;
КонецФункции

#Область РаботаСКомандойЗаменаПриборовУчета

&НаКлиенте
Процедура ЗаменаПриборовУчета(Команда)
	
	ТекДанные = Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказания.ТекущиеДанные;
	ПараметрыЛицевогоСчета = ОпределитьАктуальныеПараметрыЛицевогоСчета(ТекДанные);
	
	Абонент 	= НайтиАбонента(ПараметрыЛицевогоСчета.ЛицевойСчет);
	ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ");
	ЭлементыОтбора = Новый Структура("Абонент, ВидОперации", Абонент, ВидОперации);
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
	ОткрытьФорму("Документ.энргОперацияСПриборомУчета.Форма.ФормаДокументаЗаменаПУ",ПараметрыФормы);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НайтиАбонента(ЛицевойСчет)
	Абонент = Справочники.энргАбоненты.НайтиПоРеквизиту("ЛицевойСчет", ЛицевойСчет);
	Возврат Абонент;
КонецФункции

