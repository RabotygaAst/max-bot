&НаСервереБезКонтекста
Процедура АктуальныеПриборыУчетаМКД(ПараметрыОтбораПрибораУчета, мПриборыУчета, НаборПриборов)
	
	РезультатЗапроса = энргРаботаСПоказаниямиПриборовУчетаСервер.РезультатЗапросаАктуальныхПриборовМКДИхПоказаний(
		КонецДня(ПараметрыОтбораПрибораУчета.Период),
		ПараметрыОтбораПрибораУчета);
		
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ТекПриборУчета 	= Неопределено;
	ТекЗавНомер 	= Неопределено;
	Выборка  		= РезультатЗапроса.Выбрать(); 	
	
	СтрокаПрибора = "";
	ШаблонПоказаний = "%1:%2";	
	
	Пока Выборка.Следующий() цикл		
		
		Если НЕ ТекПриборУчета = Выборка.ПриборУчета Тогда
			
			Если НЕ ТекПриборУчета = Неопределено Тогда
				СтрокаПрибораИтог = СокрЛП(ТекЗавНомер) + " (" + СокрЛП(СтрокаПрибора) + ")" ; 				
				НаборПриборов.Добавить(СокрЛП(ТекЗавНомер), СтрокаПрибораИтог);
			КонецЕсли;
			
			СтрокаПрибора = "";
					
		КонецЕсли;	
		
		СтрокаПрибора 	= СтрокаПрибора + " " + СтрШаблон(ШаблонПоказаний, Выборка.ТарифнаяЗонаИмя, Формат(Выборка.Показание, "ЧГ=0"));
		ТекПриборУчета 	= Выборка.ПриборУчета;
		ТекЗавНомер 	= Выборка.ЗаводскойНомерПриборУчета;
		
	КонецЦикла;
	
	Если НЕ ТекПриборУчета = Неопределено Тогда
		СтрокаПрибораИтог = СокрЛП(ТекЗавНомер) + " (" + СокрЛП(СтрокаПрибора) + ")" ; 				
		НаборПриборов.Добавить(СокрЛП(ТекЗавНомер), СтрокаПрибораИтог);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОпределитьАктуальныеПриборыУчетаМКД(ТекДанные)
	
	МКД	= ТекДанные.МКД;
	
	ИдентификаторСтроки = ТекДанные.IDСтроки;
	
	ПараметрыОтбораПрибораУчета = НовыеПараметрыОтбораПрибораУчетаМКД();
	ПараметрыОтбораПрибораУчета.Вставить("Организация", Объект.Организация);
	ПараметрыОтбораПрибораУчета.Вставить("Период",		Объект.Дата);
	ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало 	= ТекДанные.НомерПрибораУчетаСтало;
	ПараметрыОтбораПрибораУчета.Район 					= ТекДанные.Район;		
	ПараметрыОтбораПрибораУчета.МКД				 		= ТекДанные.МКД;
		
	
	мПриборыУчета = Новый Массив;
	ПредставлениеПриборыУчета = Новый СписокЗначений;// Обратная совместимость
	АктуальныеПриборыУчетаМКД(ПараметрыОтбораПрибораУчета, мПриборыУчета, ПредставлениеПриборыУчета);

	ДополнитьАктуальныеПриборыУчетаКлючаПомещенияКВыбору(ПредставлениеПриборыУчета);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеПрибораУчета(ТекДанные, ПараметрыЛицевогоСчета)
	
	ЛицевойСчет	= ПараметрыЛицевогоСчета.ЛицевойСчет;
	Если ПустаяСтрока(ЛицевойСчет) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан лицевой счет");
		Возврат;
	КонецЕсли;	
	ИдентификаторСтроки = ТекДанные.IDСтроки;
	
	ПараметрыОтбораПрибораУчета = НовыеПараметрыОтбораПрибораУчета();
	ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало 	= ТекДанные.НомерПрибораУчетаСтало;
	ПараметрыОтбораПрибораУчета.Район 					= ТекДанные.Район;
	Если ПараметрыЛицевогоСчета.ЭтоПрефиксСтал Тогда
		ПараметрыОтбораПрибораУчета.Абонент 		= ТекДанные.АбонентСтал;
		ПараметрыОтбораПрибораУчета.КлючПомещения 	= ТекДанные.КлючПомещенияСтал;
	Иначе		
		ПараметрыОтбораПрибораУчета.Абонент 		= ТекДанные.Абонент;
		ПараметрыОтбораПрибораУчета.КлючПомещения 	= ТекДанные.КлючПомещения;
	КонецЕсли;
	
	мПриборыУчета = Новый Массив;	
	ЗаполнитьДанныеПриборовУчета(ИдентификаторСтроки, ПараметрыОтбораПрибораУчета, мПриборыУчета);
	
	УстановитьОтборСтрокПоказаний();
	//ДополнитьАктуальныеПриборыУчетаКлючаПомещенияКВыбору(мПриборыУчета);
	
КонецПроцедуры 
&НаКлиенте
Процедура ОбновитьДанныеПрибораУчетаМКД(ТекДанные)
	
	МКД	= ТекДанные.МКД;
	
	ИдентификаторСтроки = ТекДанные.IDСтроки;
	
	ПараметрыОтбораПрибораУчета = НовыеПараметрыОтбораПрибораУчетаМКД();
	ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало 	= ТекДанные.НомерПрибораУчетаСтало;
	ПараметрыОтбораПрибораУчета.Район 					= ТекДанные.Район;
	ПараметрыОтбораПрибораУчета.МКД 					= ТекДанные.МКД;
	ПараметрыОтбораПрибораУчета.Организация 			= Объект.Организация;
	
	мПриборыУчета = Новый Массив;	
	ЗаполнитьДанныеПриборовУчетаМКД(ИдентификаторСтроки, ПараметрыОтбораПрибораУчета, мПриборыУчета);
	
	УстановитьОтборСтрокПоказаний();
	//ДополнитьАктуальныеПриборыУчетаКлючаПомещенияКВыбору(мПриборыУчета);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НовыеПараметрыОтбораПрибораУчета()
	
	Результат = Новый Структура;
	Результат.Вставить("НомерПрибораУчетаСтало"		, "");
	Результат.Вставить("Район"						, ПредопределенноеЗначение("Справочник.энргЗоныОтвественности.ПустаяСсылка"));
	Результат.Вставить("Абонент"					, ПредопределенноеЗначение("Справочник.энргАбоненты.ПустаяСсылка"));
	Результат.Вставить("КлючПомещения"				, ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка"));
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НовыеПараметрыОтбораПрибораУчетаМКД()
	
	Результат = Новый Структура;
	Результат.Вставить("НомерПрибораУчетаСтало"		, "");
	Результат.Вставить("Район"						, ПредопределенноеЗначение("Справочник.энргЗоныОтвественности.ПустаяСсылка"));
	Результат.Вставить("МКД"						, ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка"));
	Результат.Вставить("Организация"				, ПредопределенноеЗначение("Справочник.Организации.ПустаяСсылка"));

	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьДанныеПриборовУчета(ИдентификаторСтроки, ПараметрыОтбораПрибораУчета, мПриборыУчета)
	
	ОчиститьТЧ(ИдентификаторСтроки);	
	Если НЕ ЗначениеЗаполнено(ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало) Тогда
		Возврат;
	КонецЕсли;  	
	
	ТаблицаТочек 		= Объект.ТочкиУчета;
	ТаблицаШкалы 		= Объект.ШкалыПриборовУчета;
	ТаблицаПоказания 	= Объект.ПоказанияПриборовУчета;		
	
	Результат = Обработки.энргСостояниеПриборовУчетаМенеджер.ДействующиеПриборыУчетаПомещения(
		КонецДня(Объект.Дата), 
		Объект.Организация, 
		ПараметрыОтбораПрибораУчета.Район, 
		ПараметрыОтбораПрибораУчета.КлючПомещения,, 
		Истина, 
		Новый Структура("ТолькоОткрытыеЛС", Истина)); 
		
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;	
	
	ПоказанияИзФайла = Объект.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона.НайтиСтроки(Новый Структура("IDСтроки", ИдентификаторСтроки));
	ПриборУчетаИзФайла = Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания.НайтиСтроки(Новый Структура("IDСтроки", ИдентификаторСтроки));
	Для Каждого ТекСтрокаПриборУчетаБыло из ПриборУчетаИзФайла Цикл
		ПриборУчетаБыло = ТекСтрокаПриборУчетаБыло.НомерПрибораУчетаБыло;
		ПриборУчетаСтало = ТекСтрокаПриборУчетаБыло.НомерПрибораУчетаСтало;
		ДатаПоказаний =    ТекСтрокаПриборУчетаБыло.ДатаПоказаний;
	КонецЦикла;
	
	Выборка  		= Результат.выбрать();
	ТекТочкаУчета 	= Неопределено;
	ТекШкала 		= Неопределено;
	IDСтрокиТочки 	= Неопределено;
	IDСтрокиШкалы 	= Неопределено;
	Пока Выборка.Следующий() цикл
		
		Если мПриборыУчета.Найти(Выборка.ЗаводскойНомерПриборУчета) = Неопределено Тогда
			// Заполняем приборами для отображения выбора из списка пользователю
			мПриборыУчета.Добавить(Выборка.ЗаводскойНомерПриборУчета);
			
		КонецЕсли;
		
		
		Если НЕ ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало = Выборка.ЗаводскойНомерПриборУчета Тогда
			//ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало = Выборка.ЗаводскойНомерПриборУчета;
			Продолжить;
		КонецЕсли;
		
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= ТаблицаТочек.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТочкиУчета, ПараметрыОтбораПрибораУчета); 
			IDСтрокиТочки 						= ИдентификаторСтроки;
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
			СтрокаТочкиУчета.ДатаПоказаний      = ДатаПоказаний;
		КонецЕсли;
		
		Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= ТаблицаШкалы.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
		КонецЕсли;
		
		
		СтрокаПоказаний 						= ТаблицаПоказания.Добавить();
		СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		СтрокаПоказаний.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
		СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		Для Каждого ТекСтрокаПоказанийФайла из ПоказанияИзФайла Цикл 
			Если СтрокаПоказаний.ТарифнаяЗона = ТекСтрокаПоказанийФайла.ТарифнаяЗона Тогда
				СтрокаПоказаний.ТекущиеПоказания = ТекСтрокаПоказанийФайла.ТекущиеПоказания;
				Прервать;
			КонецЕсли;			
		КонецЦикла;
		СоотвествиеКолонок = Новый Структура;
		СоотвествиеКолонок.Вставить("IDСтроки", "IDСтроки");
		
		ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация, Объект.ТочкиУчета, Объект.ШкалыПриборовУчета, Объект.ПоказанияПриборовУчета, ПараметрыОтбораПрибораУчета.Район, ПараметрыОтбораПрибораУчета.КлючПомещения,, СоотвествиеКолонок); 
		РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Объект.Организация, Объект.Район, ТаблицаПоказанийДляЗаполнения, КонецДня(Объект.Дата));
		ВыборкаДанныеЗаполненияПоказаний			= РезультатДанныеЗаполненияПоказаний.Выбрать();	
		Пока ВыборкаДанныеЗаполненияПоказаний.Следующий() цикл
			Если  СтрокаПоказаний.ТарифнаяЗона = ВыборкаДанныеЗаполненияПоказаний.ТарифнаяЗона Тогда				
				СтрокаПоказаний.ПредыдущиеПоказания = ВыборкаДанныеЗаполненияПоказаний.ПредыдущиеПоказания;
			КонецЕсли;	
		КонецЦикла;
		
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
		ТекШкала 								= Выборка.Шкала;
	КонецЦикла; 
	
	//ЗаполнитьСоответствиеПриборовУчетаНаОсновеМассива(ПараметрыОтбораПрибораУчета.КлючПомещения, мПриборыУчета);
КонецПроцедуры

 &НаСервере
Процедура ЗаполнитьДанныеПриборовУчетаМКД(ИдентификаторСтроки, ПараметрыОтбораПрибораУчета, мПриборыУчета)
	
	ОчиститьТЧ(ИдентификаторСтроки);	
	Если НЕ ЗначениеЗаполнено(ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало) Тогда
		Возврат;
	КонецЕсли;  	
	
	ТаблицаТочек 		= Объект.ТочкиУчета;
	ТаблицаШкалы 		= Объект.ШкалыПриборовУчета;
	ТаблицаПоказания 	= Объект.ПоказанияПриборовУчета;		
	
	Результат = энргРаботаСПоказаниямиПриборовУчетаСервер.РезультатЗапросаАктуальныхПриборовМКДИхПоказаний(
		КонецДня(Объект.Дата),
		ПараметрыОтбораПрибораУчета);
		
	//Результат = Обработки.энргСостояниеПриборовУчетаМенеджер.ДействующиеПриборыУчета(
	//	КонецДня(Объект.Дата), 
	//	Объект.Организация, 
	//	ПараметрыОтбораПрибораУчета.Район, 
	//	ПараметрыОтбораПрибораУчета.КлючПомещения,, 
	//	Истина, 
	//	Новый Структура("ТолькоОткрытыеЛС", Истина)); 
	//	
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;	
	
	ПоказанияИзФайла = Объект.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона.НайтиСтроки(Новый Структура("IDСтроки", ИдентификаторСтроки));
	ПриборУчетаИзФайла = Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания.НайтиСтроки(Новый Структура("IDСтроки", ИдентификаторСтроки));
	Для Каждого ТекСтрокаПриборУчетаБыло из ПриборУчетаИзФайла Цикл
		ПриборУчетаБыло = ТекСтрокаПриборУчетаБыло.НомерПрибораУчетаБыло;
		ПриборУчетаСтало = ТекСтрокаПриборУчетаБыло.НомерПрибораУчетаСтало;
		ДатаПоказаний =    ТекСтрокаПриборУчетаБыло.ДатаПоказаний;
	КонецЦикла;
	
	Выборка  		= Результат.выбрать();
	ТекТочкаУчета 	= Неопределено;
	ТекШкала 		= Неопределено;
	IDСтрокиТочки 	= Неопределено;
	IDСтрокиШкалы 	= Неопределено;
	Пока Выборка.Следующий() цикл
		
		Если мПриборыУчета.Найти(Выборка.ЗаводскойНомерПриборУчета) = Неопределено Тогда
			// Заполняем приборами для отображения выбора из списка пользователю
			мПриборыУчета.Добавить(Выборка.ЗаводскойНомерПриборУчета);
			
		КонецЕсли;
		
		
		Если НЕ ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало = Выборка.ЗаводскойНомерПриборУчета Тогда
			//ПараметрыОтбораПрибораУчета.НомерПрибораУчетаСтало = Выборка.ЗаводскойНомерПриборУчета;
			Продолжить;
		КонецЕсли;
		
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= ТаблицаТочек.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТочкиУчета, ПараметрыОтбораПрибораУчета); 
			IDСтрокиТочки 						= ИдентификаторСтроки;
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
			СтрокаТочкиУчета.ДатаПоказаний      = ДатаПоказаний;
		КонецЕсли;
		
		Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= ТаблицаШкалы.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
		КонецЕсли;
		
		
		СтрокаПоказаний 						= ТаблицаПоказания.Добавить();
		СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		СтрокаПоказаний.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
		СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		Для Каждого ТекСтрокаПоказанийФайла из ПоказанияИзФайла Цикл 
			Если СтрокаПоказаний.ТарифнаяЗона = ТекСтрокаПоказанийФайла.ТарифнаяЗона Тогда
				СтрокаПоказаний.ТекущиеПоказания = ТекСтрокаПоказанийФайла.ТекущиеПоказания;
				Прервать;
			КонецЕсли;			
		КонецЦикла; 
		СтрокаПоказаний.ПредыдущиеПоказания = Выборка.Показание;
		//СоотвествиеКолонок = Новый Структура;
		//СоотвествиеКолонок.Вставить("IDСтроки", "IDСтроки");
		//
		//ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация, Объект.ТочкиУчета, Объект.ШкалыПриборовУчета, Объект.ПоказанияПриборовУчета, ПараметрыОтбораПрибораУчета.Район, ПараметрыОтбораПрибораУчета.КлючПомещения,, СоотвествиеКолонок); 
		//РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Объект.Организация, Объект.Район, ТаблицаПоказанийДляЗаполнения, КонецДня(Объект.Дата));
		//ВыборкаДанныеЗаполненияПоказаний			= РезультатДанныеЗаполненияПоказаний.Выбрать();	
		//Пока ВыборкаДанныеЗаполненияПоказаний.Следующий() цикл
		//	Если  СтрокаПоказаний.ТарифнаяЗона = ВыборкаДанныеЗаполненияПоказаний.ТарифнаяЗона Тогда				
		//		СтрокаПоказаний.ПредыдущиеПоказания = ВыборкаДанныеЗаполненияПоказаний.ПредыдущиеПоказания;
		//	КонецЕсли;	
		//КонецЦикла;
		
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
		ТекШкала 								= Выборка.Шкала;
	КонецЦикла; 
	
	//ЗаполнитьСоответствиеПриборовУчетаНаОсновеМассива(ПараметрыОтбораПрибораУчета.КлючПомещения, мПриборыУчета);
КонецПроцедуры

&НаКлиенте
Процедура ДополнитьАктуальныеПриборыУчетаКлючаПомещенияКВыбору(мПриборыУчета)
	
	Если ТипЗнч(мПриборыУчета) = Тип("СписокЗначений") Тогда
		
		ЭлементФомы = Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказанияНомерПрибораУчетаСтало;
		ЭлементФомы.СписокВыбора.Очистить();
		Для Каждого ТекКлючЗначение из мПриборыУчета Цикл
			ЭлементФомы.СписокВыбора.Добавить(ТекКлючЗначение.Значение, ТекКлючЗначение.Представление);
		КонецЦикла;
		
		Возврат;
	КонецЕсли;
	
	мПриборыУчета = ОбщегоНазначенияКлиентСервер.СвернутьМассив(мПриборыУчета);
	Элементы.НеЗагруженныеДанныеНеЗагруженныеПоказанияНомерПрибораУчетаСтало.СписокВыбора.ЗагрузитьЗначения(мПриборыУчета);
	
КонецПроцедуры	

&НаСервере
Процедура ОбновитьСоответствиеПриборовУчета()
	
	Возврат;
	
	сРайоны	= Новый Соответствие;	
	Для Каждого ТекСтрока из Объект.НеЗагруженныеДанныеНеЗагруженныеПоказания Цикл
		Если НЕ ЗначениеЗаполнено(ТекСтрока.Район) Тогда
			Продолжить;
		КонецЕсли;
		
		КлючПомещения = ТекСтрока.КлючПомещения;
		Если ЗначениеЗаполнено(ТекСтрока.КлючПомещенияСтал) Тогда 
			КлючПомещения = ТекСтрока.КлючПомещенияСтал; 
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(КлючПомещения) Тогда
			Продолжить;
		КонецЕсли;
		
		ЗначениеКлюча = сРайоны[ТекСтрока.Район];
		Если ЗначениеКлюча = Неопределено Тогда
			КлючиПомещений = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(КлючПомещения);
			сРайоны.Вставить(ТекСтрока.Район, КлючиПомещений);
		Иначе 
			ЗначениеКлюча.Добавить(КлючПомещения);
		КонецЕсли;		
	КонецЦикла;
	
	СоответствиеПриборов.Очистить();
	Для Каждого ТекРайон из сРайоны Цикл
		ТаблицаПриборов = энргСостояниеПриборовУчета.ДействующиеПриборыУчетаПомещения(Объект.Дата, Объект.Организация, ТекРайон.Ключ, ТекРайон.Значение).Выгрузить();
		ТаблицаПриборов.Свернуть("КлючПомещения, ЗаводскойНомерПриборУчета");
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаПриборов, СоответствиеПриборов);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСоответствиеПриборовУчетаНаОсновеМассива(КлючПомещения, мПриборыУчета)
	ТаблицаИсточник = СоответствиеПриборов;
	энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(ТаблицаИсточник, Новый Структура("КлючПомещения", КлючПомещения));
	
	Для Каждого СтрокаНабора из мПриборыУчета Цикл
		НСтрока = ТаблицаИсточник.Добавить();
		НСтрока.КлючПомещения 				= КлючПомещения;
		НСтрока.ЗаводскойНомерПриборУчета 	= СтрокаНабора;
	КонецЦикла;
КонецПроцедуры

