#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Функция ПолучитьЗадолженность(Параметры) Экспорт 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргВзаиморасчетыПоМесяцамОстатки.Организация КАК Организация,
		|	энргВзаиморасчетыПоМесяцамОстатки.Район КАК Район,
		|	энргВзаиморасчетыПоМесяцамОстатки.МКД КАК МКД,
		|	энргВзаиморасчетыПоМесяцамОстатки.Абонент КАК Абонент,
		|	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
		|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления КАК ПериодНачисления,
		|	энргВзаиморасчетыПоМесяцамОстатки.Поставщик КАК Поставщик,
		|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток КАК СуммаЗадолженности,
		|	ВЫБОР
		|		КОГДА энргПросуженнаяЗадолженностьАбонентовСрезПоследних.Организация ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ПросуженнаяБлокированнаяДо
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(&ДатаОстатков, Абонент = &Абонент) КАК энргВзаиморасчетыПоМесяцамОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргПросуженнаяЗадолженностьАбонентов.СрезПоследних(&ДатаОстатков, Абонент = &Абонент) КАК энргПросуженнаяЗадолженностьАбонентовСрезПоследних
		|		ПО энргВзаиморасчетыПоМесяцамОстатки.Организация = энргПросуженнаяЗадолженностьАбонентовСрезПоследних.Организация
		|			И энргВзаиморасчетыПоМесяцамОстатки.Район = энргПросуженнаяЗадолженностьАбонентовСрезПоследних.Район
		|			И энргВзаиморасчетыПоМесяцамОстатки.МКД = энргПросуженнаяЗадолженностьАбонентовСрезПоследних.МКД
		|			И энргВзаиморасчетыПоМесяцамОстатки.Абонент = энргПросуженнаяЗадолженностьАбонентовСрезПоследних.Абонент
		|			И энргВзаиморасчетыПоМесяцамОстатки.Услуга = энргПросуженнаяЗадолженностьАбонентовСрезПоследних.Услуга
		|			И энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления = энргПросуженнаяЗадолженностьАбонентовСрезПоследних.ПериодНачисления
		|			И энргВзаиморасчетыПоМесяцамОстатки.Поставщик = энргПросуженнаяЗадолженностьАбонентовСрезПоследних.Поставщик
		|ГДЕ
		|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления МЕЖДУ &ПериодНачисленияНачало И &ПериодНачисленияКонец
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПериодНачисления,
		|	Услуга";
	
	Запрос.УстановитьПараметр("Абонент", Параметры.Абонент);
	Запрос.УстановитьПараметр("ДатаОстатков", Новый Граница(Параметры.Дата, ВидГраницы.Исключая));
	Если ЗначениеЗаполнено(Параметры.ПериодЗадолженности.ДатаНачала) И ЗначениеЗаполнено(Параметры.ПериодЗадолженности.ДатаОкончания) Тогда
		Запрос.УстановитьПараметр("ПериодНачисленияНачало", Параметры.ПериодЗадолженности.ДатаНачала);
		Запрос.УстановитьПараметр("ПериодНачисленияКонец", Параметры.ПериодЗадолженности.ДатаОкончания);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления МЕЖДУ &ПериодНачисленияНачало И &ПериодНачисленияКонец", "ИСТИНА");
	КонецЕсли;
			
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
	
	ПараметрыЗапроса  	= Новый Структура;
	Схема 				= Неопределено;
	
	ДобавитьТекстЗапросаПросуженнойЗадолженности(Схема, Регистры);
	
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		ВспомогательныеПараметры 	= Новый Структура;
		энргФормированиеТекстовЗапроса.УстановитьПерехватОбращенияКТаблицам(Схема, ДополнительныеСвойства.ТаблицыПодмены, ВспомогательныеПараметры); 
	КонецЕсли;
	
	КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);	
	
	ПараметрыЗапроса 				= Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы", ДокументСсылка);
	
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		энргСхемаЗапросаСервер.ВыполнитьПакет(Схема, ПараметрыЗапроса));
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьТекстЗапросаПросуженнойЗадолженности(Схема, Регистры) 
	
	ИмяРегистра 	= "энргПросуженнаяЗадолженностьАбонентов";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  		= 
	"ВЫБРАТЬ
	|	Шапка.Дата КАК Период,
	|	Шапка.Ссылка КАК Регистратор,
	|	Шапка.Организация КАК Организация,
	|	Шапка.Район КАК Район,
	|	ВЫБОР
	|		КОГДА энргКлючиПомещений.ЧастныйСектор
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|		ИНАЧЕ энргКлючиПомещений.Строение
	|	КОНЕЦ КАК МКД,
	|	Шапка.Абонент КАК Абонент,
	|	ТаблицаТочки.Услуга КАК Услуга,
	|	ТаблицаТочки.ПериодНачисления КАК ПериодНачисления,
	|	ТаблицаТочки.Поставщик КАК Поставщик,
	|	ТаблицаТочки.ПросуженнаяБлокированная КАК ПросуженнаяБлокированная,
	|	ТаблицаТочки.СуммаЗадолженности КАК Сумма
	|ИЗ
	|	Документ.энргИзменениеВидаЗадолженности КАК Шапка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргИзменениеВидаЗадолженности.РасчетЗадолженности КАК ТаблицаТочки
	|		ПО Шапка.Ссылка = ТаблицаТочки.Ссылка
	|			И (Шапка.Ссылка В (&мДокументы))
	|			И (ТаблицаТочки.Ссылка В (&мДокументы))
	|			И (ТаблицаТочки.ПросуженнаяБлокированная
	|				ИЛИ НЕ ТаблицаТочки.ПросуженнаяБлокированная
	|					И ТаблицаТочки.ПросуженнаяБлокированнаяДо)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО Шапка.КлючПомещения = энргКлючиПомещений.Ссылка"; 	
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли