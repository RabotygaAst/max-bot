#Область ПрограммныйИнтерфейс

Функция ИзменяемыеПараметрыРасчета() Экспорт
	
	ИзменяемыеПараметрыРасчета 	= Новый Соответствие;
	ИзменяемыеПараметры 		= Новый Массив;	
	ИзменяемыеПараметры.Добавить(Новый Структура("Ресурсы","КоличествоПроживающих,КоличествоПрописанных,КоличествоСобственников"));	
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.ПустаяСсылка(), ИзменяемыеПараметры);
	
	ИзменяемыеПараметры 		= Новый Массив;	
	ИзменяемыеПараметры.Добавить(Новый Структура("Ресурсы,СвойстваСоставаЖильцов","СоставЖильцов","КоличествоПроживающих,КоличествоПрописанных,КоличествоСобственников"));	
	ИзменяемыеПараметрыРасчета.Вставить("НЕОПРЕДЕЛЕНО", ИзменяемыеПараметры);
	
	Возврат ИзменяемыеПараметрыРасчета;
	
КонецФункции

Процедура ПолучитьДанныеДляПроведенияПоСтабильнымПериодам(Схема,ВыбираемыеТаблицы) Экспорт	
	перем Пакет;
	
	ИмяТаблицы 											= "ДанныеДокументовИзменениеКоличестваПрописанныхПроживающихСобственников";
	ВыбираемыеТаблицы.Добавить(ИмяТаблицы);
	
	врСхема 											= Новый СхемаЗапроса;
	врСхема.УстановитьТекстЗапроса(ТекстДляПроведенияПоСтабильнымПериодам());
	
	Пакет 												= врСхема.ПакетЗапросов[врСхема.ПакетЗапросов.Количество() - 1];
	Пакет.ТаблицаДляПомещения 							= ИмяТаблицы;
	
	Для Каждого врПакет Из врСхема.ПакетЗапросов Цикл
		Если Схема = Неопределено Тогда
			Схема 										= Новый СхемаЗапроса;
			Пакет 										= Схема.ПакетЗапросов[0];
		Иначе
			Пакет 										= Схема.ПакетЗапросов.Добавить();
		КонецЕсли;
		
		Пакет.УстановитьТекстЗапроса(врПакет.ПолучитьТекстЗапроса()); 		
	КонецЦикла;
	
	Для Каждого врПакет Из врСхема.ПакетЗапросов Цикл				
		Если НЕ врПакет.ТаблицаДляПомещения = ИмяТаблицы Тогда
			ПакетУничтожение 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросУничтоженияТаблицыСхемыЗапроса"));
			ПакетУничтожение.ИмяТаблицы 				= врПакет.ТаблицаДляПомещения;
		КонецЕсли;				
	КонецЦикла; 
	 	
	ИмяТаблицы 											= "ДанныеДокументовИзменениеКоличестваПрописанныхПроживающихСобственниковСвязанныеПомещения";
	ВыбираемыеТаблицы.Добавить(ИмяТаблицы);
	
	врСхема 											= Новый СхемаЗапроса;
	врСхема.УстановитьТекстЗапроса(ТекстДляПроведенияПоСтабильнымПериодамСвязанныеПомещения());
	
	Пакет 												= врСхема.ПакетЗапросов[врСхема.ПакетЗапросов.Количество() - 1];
	Пакет.ТаблицаДляПомещения 							= ИмяТаблицы;
	
	Для Каждого врПакет Из врСхема.ПакетЗапросов Цикл
		Если Схема = Неопределено Тогда
			Схема 										= Новый СхемаЗапроса;
			Пакет 										= Схема.ПакетЗапросов[0];
		Иначе
			Пакет 										= Схема.ПакетЗапросов.Добавить();
		КонецЕсли;
		
		Пакет.УстановитьТекстЗапроса(врПакет.ПолучитьТекстЗапроса()); 		
	КонецЦикла;
	
	Для Каждого врПакет Из врСхема.ПакетЗапросов Цикл				
		Если НЕ врПакет.ТаблицаДляПомещения = ИмяТаблицы Тогда
			ПакетУничтожение 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросУничтоженияТаблицыСхемыЗапроса"));
			ПакетУничтожение.ИмяТаблицы 				= врПакет.ТаблицаДляПомещения;
		КонецЕсли;				
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
	ПараметрыЗапроса  			= Новый Структура;
	Схема 						= Неопределено;
	
	ДобавитьТекстЗапросаКоличествоПроживающих(Схема, Регистры);
	ДобавитьТекстЗапросаКоличествоПрописанных(Схема, Регистры);
	ДобавитьТекстЗапросаКоличествоСобственников(Схема, Регистры);
	ДобавитьТекстЗапросаЖильцыЛьготныхКатегорий(Схема, Регистры);
	ДобавитьТекстЗапросаСобственникиПомещений(Схема, Регистры);
	
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		ВспомогательныеПараметры 	= Новый Структура;
		энргФормированиеТекстовЗапроса.УстановитьПерехватОбращенияКТаблицам(Схема, ДополнительныеСвойства.ТаблицыПодмены, ВспомогательныеПараметры); 
	КонецЕсли;
	
	КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	Запрос  						= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("мДокументы", 					ДокументСсылка);
	Запрос.УстановитьПараметр("ПустаяЛьгота", 					Справочники.энргЛьготныеКатегории.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПустойУникальныйИдентификатор", 	ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		энргФормированиеТекстовЗапроса.УстановитьПараметрыТаблицыПодмены(Запрос, ВспомогательныеПараметры); 
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		Запрос.ВыполнитьПакет());
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

Процедура ИнициализироватьТаблицыДляКонтроля(ДокументСсылка,ДополнительныеСвойства) Экспорт 
	
	Схема  										= Неопределено;
	Параметры 									= Новый Структура;
	
	ДобавитьТекстЗапросаПараметрыКонтроля(Схема);
	ДобавитьТекстЗапросаКонтрольСостояниеМКД(Схема, Параметры);
		
	КлючиТаблицКонтроля  						= Новый Структура;
			
	Для Сч = 0 По Схема.ПакетЗапросов.Количество() - 1  Цикл
		Пакет 									= Схема.ПакетЗапросов[Сч];		
		Если Не ПустаяСтрока(Пакет.ТаблицаДляПомещения) И СтрНачинаетсяС(Пакет.ТаблицаДляПомещения, "Контроль") Тогда			
			КлючиТаблицКонтроля.Вставить(Прав(Пакет.ТаблицаДляПомещения,СтрДлина(Пакет.ТаблицаДляПомещения) - СтрДлина("Контроль")),Сч);			
			Пакет.ТаблицаДляПомещения 			= "";
		КонецЕсли;		
	КонецЦикла;
	ТекстСообщенияМногоквартирныйДомЗакрыт 		= НСтр("ru = 'На дату операции мкд закрыт'"); 
	ДанныеСтроения 								= ДополнительныеСвойства.ДанныеСтроения;
	
	Запрос  									= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("мДокументы", 								ДокументСсылка);
	Запрос.УстановитьПараметр("ЧастныйСектор",								ДанныеСтроения.ЧастныйСектор);
	Запрос.УстановитьПараметр("Строение", 									ДанныеСтроения.Строение);
	Запрос.УстановитьПараметр("ТекстСообщенияМногоквартирныйДомЗакрыт", 	ТекстСообщенияМногоквартирныйДомЗакрыт);
	
	ДополнительныеСвойства.Вставить("ТаблицыДляКонтроля", 					Запрос.ВыполнитьПакет());
	ДополнительныеСвойства.Вставить("КлючиТаблицКонтроля", 					КлючиТаблицКонтроля);
	
КонецПроцедуры

Процедура ЗаполнениеЖильцов(Объект) Экспорт
	
	Период = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргКоличествоПроживающихСрезПоследних.Организация КАК Организация,
		|	энргКоличествоПроживающихСрезПоследних.Район КАК Район,
		|	энргКоличествоПроживающихСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргКоличествоПроживающихСрезПоследних.Количество КАК КоличествоПроживающих,
		|	NULL КАК КоличествоПрописанных,
		|	NULL КАК КоличествоСобственников
		|ПОМЕСТИТЬ ВТ_Количество
		|ИЗ
		|	РегистрСведений.энргКоличествоПроживающих.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргКоличествоПроживающихСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	энргКоличествоПрописанныхСрезПоследних.Организация,
		|	энргКоличествоПрописанныхСрезПоследних.Район,
		|	энргКоличествоПрописанныхСрезПоследних.КлючПомещения,
		|	NULL,
		|	энргКоличествоПрописанныхСрезПоследних.Количество,
		|	NULL
		|ИЗ
		|	РегистрСведений.энргКоличествоПрописанных.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргКоличествоПрописанныхСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	энргКоличествоСобственниковСрезПоследних.Организация,
		|	энргКоличествоСобственниковСрезПоследних.Район,
		|	энргКоличествоСобственниковСрезПоследних.КлючПомещения,
		|	NULL,
		|	NULL,
		|	энргКоличествоСобственниковСрезПоследних.Количество
		|ИЗ
		|	РегистрСведений.энргКоличествоСобственников.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргКоличествоСобственниковСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргСобственникиПомещенийСрезПоследних.Организация КАК Организация,
		|	энргСобственникиПомещенийСрезПоследних.Район КАК Район,
		|	энргСобственникиПомещенийСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргСобственникиПомещенийСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
		|	энргСобственникиПомещенийСрезПоследних.ДолеваяСобственность КАК ДолеваяСобственность,
		|	энргСобственникиПомещенийСрезПоследних.ДоляСобственностиЧислитель КАК ДоляСобственностиЧислитель,
		|	энргСобственникиПомещенийСрезПоследних.ДоляСобственностиЗнаменатель КАК ДоляСобственностиЗнаменатель,
		|	энргСобственникиПомещенийСрезПоследних.СвидетельствоОРегистрацииНомер КАК СвидетельствоОРегистрацииНомер,
		|	энргСобственникиПомещенийСрезПоследних.СвидетельствоОРегистрацииДата КАК СвидетельствоОРегистрацииДата,
		|	энргСобственникиПомещенийСрезПоследних.СвидетельствоОРегистрацииСерия КАК СвидетельствоОРегистрацииСерия,
		|	энргСобственникиПомещенийСрезПоследних.СвидетельствоОРегистрацииКемВыдан КАК СвидетельствоОРегистрацииКемВыдан,
		|	энргСобственникиПомещенийСрезПоследних.Собственник КАК Собственник,
		|	энргСобственникиПомещенийСрезПоследних.Проживаюший КАК Проживаюший,
		|	энргСобственникиПомещенийСрезПоследних.Прописанный КАК Прописанный,
		|	энргСобственникиПомещенийСрезПоследних.РодственныеСвязи КАК РодственныеСвязи,
		|	&Абонент КАК Абонент
		|ПОМЕСТИТЬ ВТ_СобственикиПомещений
		|ИЗ
		|	РегистрСведений.энргСобственникиПомещений.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргСобственникиПомещенийСрезПоследних
		|ГДЕ
		|	энргСобственникиПомещенийСрезПоследних.Активна = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЖильцыЛьготныхКатегорийСрезПоследних.Жилец КАК Жилец,
		|	энргЖильцыЛьготныхКатегорийСрезПоследних.Организация КАК Организация,
		|	энргЖильцыЛьготныхКатегорийСрезПоследних.Район КАК Район,
		|	энргЖильцыЛьготныхКатегорийСрезПоследних.ЛьготнаяКатегория КАК ЛьготнаяКатегория,
		|	энргЖильцыЛьготныхКатегорийСрезПоследних.Период КАК Период
		|ПОМЕСТИТЬ ВТ_ЛьготыЖильца
		|ИЗ
		|	РегистрСведений.энргЖильцыЛьготныхКатегорий.СрезПоследних(
		|			&Период,
		|			(Жилец, Организация, Район) В
		|					(ВЫБРАТЬ
		|						ВТ_СобственикиПомещений.ФизическоеЛицо КАК ФизическоеЛицо,
		|						ВТ_СобственикиПомещений.Организация КАК Организация,
		|						ВТ_СобственикиПомещений.Район КАК Район
		|					ИЗ
		|						ВТ_СобственикиПомещений КАК ВТ_СобственикиПомещений)
		|				И Абонент = &Абонент) КАК энргЖильцыЛьготныхКатегорийСрезПоследних
		|ГДЕ
		|	энргЖильцыЛьготныхКатегорийСрезПоследних.Состояние
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ЛьготыЖильца.Жилец КАК Жилец,
		|	ВТ_ЛьготыЖильца.Организация КАК Организация,
		|	ВТ_ЛьготыЖильца.Район КАК Район,
		|	МАКСИМУМ(ВТ_ЛьготыЖильца.Период) КАК Период
		|ПОМЕСТИТЬ ВТ_ДатаПоследнейЛьготы
		|ИЗ
		|	ВТ_ЛьготыЖильца КАК ВТ_ЛьготыЖильца
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ЛьготыЖильца.Жилец,
		|	ВТ_ЛьготыЖильца.Организация,
		|	ВТ_ЛьготыЖильца.Район
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ЛьготыЖильца.Жилец КАК Жилец,
		|	ВТ_ЛьготыЖильца.Организация КАК Организация,
		|	ВТ_ЛьготыЖильца.Район КАК Район,
		|	ВТ_ЛьготыЖильца.ЛьготнаяКатегория КАК ЛьготнаяКатегория
		|ПОМЕСТИТЬ ВТ_ПоследняяЛьгота
		|ИЗ
		|	ВТ_ЛьготыЖильца КАК ВТ_ЛьготыЖильца
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ДатаПоследнейЛьготы КАК ВТ_ДатаПоследнейЛьготы
		|		ПО ВТ_ЛьготыЖильца.Жилец = ВТ_ДатаПоследнейЛьготы.Жилец
		|			И ВТ_ЛьготыЖильца.Организация = ВТ_ДатаПоследнейЛьготы.Организация
		|			И ВТ_ЛьготыЖильца.Район = ВТ_ДатаПоследнейЛьготы.Район
		|			И ВТ_ЛьготыЖильца.Период = ВТ_ДатаПоследнейЛьготы.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗначенияЛьготныхКатегорийСрезПоследних.Организация КАК Организация,
		|	энргЗначенияЛьготныхКатегорийСрезПоследних.Район КАК Район,
		|	энргЗначенияЛьготныхКатегорийСрезПоследних.ЛьготнаяКатегория КАК ЛьготнаяКатегория,
		|	энргЗначенияЛьготныхКатегорийСрезПоследних.ПроцентОтНачислений КАК ПроцентОтНачислений
		|ПОМЕСТИТЬ ВТ_ПроцентЛьготы
		|ИЗ
		|	РегистрСведений.энргЗначенияЛьготныхКатегорий.СрезПоследних(
		|			&Период,
		|			(Организация, Район, ЛьготнаяКатегория) В
		|				(ВЫБРАТЬ
		|					ВТ_ПоследняяЛьгота.Организация КАК Организация,
		|					ВТ_ПоследняяЛьгота.Район КАК Район,
		|					ВТ_ПоследняяЛьгота.ЛьготнаяКатегория КАК ЛьготнаяКатегория
		|				ИЗ
		|					ВТ_ПоследняяЛьгота КАК ВТ_ПоследняяЛьгота)) КАК энргЗначенияЛьготныхКатегорийСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СобственикиПомещений.КлючПомещения КАК КлючПомещения,
		|	МАКСИМУМ(ВТ_СобственикиПомещений.ДолеваяСобственность) КАК ДолеваяСобственность
		|ИЗ
		|	ВТ_СобственикиПомещений КАК ВТ_СобственикиПомещений
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_СобственикиПомещений.КлючПомещения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Количество.КлючПомещения КАК КлючПомещения,
		|	МАКСИМУМ(ВТ_Количество.КоличествоПроживающих) КАК КоличествоПроживающих,
		|	МАКСИМУМ(ВТ_Количество.КоличествоПрописанных) КАК КоличествоПрописанных,
		|	МАКСИМУМ(ВТ_Количество.КоличествоСобственников) КАК КоличествоСобственников
		|ИЗ
		|	ВТ_Количество КАК ВТ_Количество
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Количество.КлючПомещения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СобственикиПомещений.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТ_СобственикиПомещений.ДоляСобственностиЧислитель КАК ДоляСобственностиЧислитель,
		|	ВТ_СобственикиПомещений.ДоляСобственностиЗнаменатель КАК ДоляСобственностиЗнаменатель,
		|	ВТ_СобственикиПомещений.СвидетельствоОРегистрацииНомер КАК СвидетельствоОРегистрацииНомер,
		|	ВТ_СобственикиПомещений.СвидетельствоОРегистрацииДата КАК СвидетельствоОРегистрацииДата,
		|	ВТ_СобственикиПомещений.СвидетельствоОРегистрацииСерия КАК СвидетельствоОРегистрацииСерия,
		|	ВТ_СобственикиПомещений.СвидетельствоОРегистрацииКемВыдан КАК СвидетельствоОРегистрацииКемВыдан,
		|	ВТ_СобственикиПомещений.Собственник КАК Собственник,
		|	ВТ_СобственикиПомещений.Проживаюший КАК Проживаюший,
		|	ВТ_СобственикиПомещений.Прописанный КАК Прописанный,
		|	ВТ_СобственикиПомещений.РодственныеСвязи КАК РодственныеСвязи,
		|	ВТ_СобственикиПомещений.Абонент КАК Абонент,
		|	ВТ_ПоследняяЛьгота.ЛьготнаяКатегория КАК ЛьготнаяКатегория,
		|	ВТ_ПроцентЛьготы.ПроцентОтНачислений КАК ПроцентЛьготы
		|ИЗ
		|	ВТ_СобственикиПомещений КАК ВТ_СобственикиПомещений
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПоследняяЛьгота КАК ВТ_ПоследняяЛьгота
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПроцентЛьготы КАК ВТ_ПроцентЛьготы
		|			ПО ВТ_ПоследняяЛьгота.Организация = ВТ_ПроцентЛьготы.Организация
		|				И ВТ_ПоследняяЛьгота.Район = ВТ_ПроцентЛьготы.Район
		|				И ВТ_ПоследняяЛьгота.ЛьготнаяКатегория = ВТ_ПроцентЛьготы.ЛьготнаяКатегория
		|		ПО ВТ_СобственикиПомещений.Организация = ВТ_ПоследняяЛьгота.Организация
		|			И ВТ_СобственикиПомещений.Район = ВТ_ПоследняяЛьгота.Район
		|			И ВТ_СобственикиПомещений.ФизическоеЛицо = ВТ_ПоследняяЛьгота.Жилец";
	
	Запрос.УстановитьПараметр("Абонент", 		Объект.Абонент);
	Запрос.УстановитьПараметр("КлючПомещения", 	Объект.КлючПомещения);
	Запрос.УстановитьПараметр("Организация", 	Объект.Организация);
	Запрос.УстановитьПараметр("Период", 		Период);
	Запрос.УстановитьПараметр("Район", 			Объект.Район);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	КолЗапросов		 = РезультатЗапроса.Количество();
	
	ВыборкаДолеваяСоб = РезультатЗапроса[КолЗапросов-3].Выбрать();
	Объект.ДолеваяСобственность = ?(ВыборкаДолеваяСоб.Следующий(), ВыборкаДолеваяСоб.ДолеваяСобственность, Ложь);

	ДанныеКол		 = Новый Структура("КоличествоПроживающих, КоличествоСобственников, КоличествоПрописанных", 0, 0, 0);
	ВыборкаКол = РезультатЗапроса[КолЗапросов-2].Выбрать();
	Если ВыборкаКол.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДанныеКол, ВыборкаКол);
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(Объект, ДанныеКол);
	
	ВыборкаЛьготыЖильцов = РезультатЗапроса[КолЗапросов-1].Выбрать();
	ТекФЛ = Неопределено;
	ТекIDСтроки = Неопределено;
	
	ДанныеЖильцы		 = Новый Структура("ФизическоеЛицо, ДоляСобственностиЧислитель, ДоляСобственностиЗнаменатель, СвидетельствоОРегистрацииНомер,СвидетельствоОРегистрацииДата, СвидетельствоОРегистрацииСерия,СвидетельствоОРегистрацииКемВыдан,Собственник, Проживающий, Прописанный,РодственныеСвязи, Абонент, IDСтроки");
	ДанныеЛьготы		 = Новый Структура("ФизическоеЛицо, Абонент, ЛьготнаяКатегория, ПроцентЛьготы, IDСтроки");
	
	Пока ВыборкаЛьготыЖильцов.Следующий() Цикл 
		
		Если ТекФЛ = Неопределено Или не ТекФЛ = ВыборкаЛьготыЖильцов.ФизическоеЛицо Тогда 
			ТекФЛ = ВыборкаЛьготыЖильцов.ФизическоеЛицо;
			ТекIDСтроки = Новый УникальныйИдентификатор;
			
			ЗаполнитьЗначенияСвойств(ДанныеЖильцы, ВыборкаЛьготыЖильцов);
			ДанныеЖильцы.IDСтроки = текIDСтроки;
			ЗаполнитьЗначенияСвойств(ДанныеЛьготы, ВыборкаЛьготыЖильцов);
			ДанныеЛьготы.IDСтроки = текIDСтроки;
			ЗаполнитьЗначенияСвойств(Объект.Жильцы.Добавить(), ДанныеЖильцы);
			ЗаполнитьЗначенияСвойств(Объект.Льготы.Добавить(), ДанныеЛьготы);
			
		Иначе 
			ЗаполнитьЗначенияСвойств(ДанныеЛьготы, ВыборкаЛьготыЖильцов);
			ДанныеЛьготы.IDСтроки = текIDСтроки;
			ЗаполнитьЗначенияСвойств(Объект.Льготы.Добавить(), ДанныеЛьготы);

		КонецЕсли;
	
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

