		|	Документ.энргИзменениеКоличестваПрописанныхПроживающихСобственников КАК энргИзменениеКоличестваПрописанныхПроживающихСобственников
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргИзменениеКоличестваПрописанныхПроживающихСобственников.Жильцы КАК энргИзменениеКоличестваПрописанныхПроживающихСобственниковЖильцы
		|		ПО энргИзменениеКоличестваПрописанныхПроживающихСобственников.Ссылка = энргИзменениеКоличестваПрописанныхПроживающихСобственниковЖильцы.Ссылка
		|			И (энргИзменениеКоличестваПрописанныхПроживающихСобственников.Ссылка В (&мДокументы))
		|			И (энргИзменениеКоличестваПрописанныхПроживающихСобственниковЖильцы.Ссылка В (&мДокументы))
		|			И (энргИзменениеКоличестваПрописанныхПроживающихСобственниковЖильцы.ФизическоеЛицо ССЫЛКА Справочник.энргКонтрагенты)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргИзменениеКоличестваПрописанныхПроживающихСобственников.Льготы КАК энргИзменениеКоличестваПрописанныхПроживающихСобственниковЛьготы
		|		ПО (энргИзменениеКоличестваПрописанныхПроживающихСобственниковЖильцы.IDСтроки = энргИзменениеКоличестваПрописанныхПроживающихСобственниковЛьготы.IDСтроки)
		|			И (энргИзменениеКоличестваПрописанныхПроживающихСобственниковЛьготы.ЛьготнаяКатегория <> ЗНАЧЕНИЕ(Справочник.энргЛьготныеКатегории.ПустаяСсылка))
		|ГДЕ
		|	НЕ энргИзменениеКоличестваПрописанныхПроживающихСобственниковЛьготы.ЛьготнаяКатегория = &ПустаяЛьгота";	
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаСобственникиПомещений(Схема, Регистры)
	
	ИмяРегистра = "энргСобственникиПомещений";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст 		= 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА Шапка.ДатаФактическогоСобытия
	|		ИНАЧЕ Шапка.Дата
	|	КОНЕЦ КАК Период,
	|	Шапка.Организация КАК Организация,
	|	Шапка.Район КАК Район,
	|	Шапка.КлючПомещения КАК КлючПомещения,
	|	табЖильцы.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ИСТИНА КАК Активна,
	|	Шапка.ДолеваяСобственность КАК ДолеваяСобственность,
	|	ВЫБОР
	|		КОГДА Шапка.ДолеваяСобственность
	|			ТОГДА табЖильцы.ДоляСобственностиЧислитель
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ДоляСобственностиЧислитель,
	|	ВЫБОР
	|		КОГДА Шапка.ДолеваяСобственность
	|			ТОГДА табЖильцы.ДоляСобственностиЗнаменатель
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ДоляСобственностиЗнаменатель,
	|	табЖильцы.СвидетельствоОРегистрацииНомер КАК СвидетельствоОРегистрацииНомер,
	|	табЖильцы.СвидетельствоОРегистрацииДата КАК СвидетельствоОРегистрацииДата,
	|	табЖильцы.СвидетельствоОРегистрацииСерия КАК СвидетельствоОРегистрацииСерия,
	|	табЖильцы.СвидетельствоОРегистрацииКемВыдан КАК СвидетельствоОРегистрацииКемВыдан,
	|	табЖильцы.Собственник КАК Собственник,
	|	табЖильцы.Проживаюший КАК Проживаюший,
	|	табЖильцы.Прописанный КАК Прописанный,
	|	табЖильцы.РодственныеСвязи КАК РодственныеСвязи,
	|	табЖильцы.СолидарнаяОплата КАК СолидарнаяОплата
	|ИЗ
	|	Документ.энргИзменениеКоличестваПрописанныхПроживающихСобственников КАК Шапка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргИзменениеКоличестваПрописанныхПроживающихСобственников.Жильцы КАК табЖильцы
	|		ПО Шапка.Ссылка = табЖильцы.Ссылка
	|ГДЕ
	|	Шапка.Ссылка В(&мДокументы)
	|	И табЖильцы.Ссылка В(&мДокументы)";
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;  	
		
КонецПроцедуры

#КонецОбласти

#Область РеализацияИнтрейфеса_КонтрольПроведения

Процедура ДобавитьТекстЗапросаКонтрольСостояниеМКД(Схема, Параметры)
	
	ПараметрыСостоянияМКД 		= Новый Структура;
	ПараметрыВременнойТаблицы 	= Новый Массив;
	ПараметрыВременнойТаблицы.Добавить(Новый Структура("ИмяПараметра, ТаблицаИсточник, ТипПараметра, СоотвествиеПолей","ПараметрыКонтроля","ПараметрыКонтроля","ТипПараметраВременнаяТаблица", Новый Структура("Организация,Район,МКД","Организация","Район","МКД")));
	ПараметрыСостоянияМКД.Вставить("ПараметрыВТ", ПараметрыВременнойТаблицы);
	РегистрыСведений.энргСостояниеМКД.СостояниеМногоквартирногоДома(Схема,ПараметрыСостоянияМКД,"СостояниеМногоквартирногоДома");
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст 			=
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПРЕДСТАВЛЕНИЕ(ПараметрыКонтроля.Ссылка) КАК ПредставлениеОбъекта,
	|	&ТекстСообщенияМногоквартирныйДомЗакрыт КАК ТекстСообщения
	|ИЗ
	|	ПараметрыКонтроля КАК ПараметрыКонтроля
	|		ЛЕВОЕ СОЕДИНЕНИЕ СостояниеМногоквартирногоДома КАК СостояниеМногоквартирногоДома
	|		ПО ПараметрыКонтроля.Организация = СостояниеМногоквартирногоДома.Организация
	|			И ПараметрыКонтроля.Район = СостояниеМногоквартирногоДома.Район
	|			И ПараметрыКонтроля.МКД = СостояниеМногоквартирногоДома.МКД
	|ГДЕ
	|	НЕ ПараметрыКонтроля.ЧастныйСектор
	|	И (НЕ ЕСТЬNULL(СостояниеМногоквартирногоДома.Состояние, ЛОЖЬ)
	|			ИЛИ КОНЕЦПЕРИОДА(ПараметрыКонтроля.Период, ДЕНЬ) < ЕСТЬNULL(КОНЕЦПЕРИОДА(СостояниеМногоквартирногоДома.Период, ДЕНЬ), ДАТАВРЕМЯ(1, 1, 1)))";
		
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения 			= "КонтрольСостояниеМКД";
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаПараметрыКонтроля(Схема)
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст 		=
		"ВЫБРАТЬ
		|	энргИзменениеКоличестваПрописанныхПроживающихСобственников.Ссылка КАК Ссылка,
		|	энргИзменениеКоличестваПрописанныхПроживающихСобственников.Организация КАК Организация,
		|	энргИзменениеКоличестваПрописанныхПроживающихСобственников.Район КАК Район,
		|	&ЧастныйСектор КАК ЧастныйСектор,
		|	ВЫБОР
		|		КОГДА &ЧастныйСектор
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.пустаяСсылка)
		|		ИНАЧЕ &Строение
		|	КОНЕЦ КАК МКД,
		|	ВЫБОР
		|		КОГДА НЕ энргИзменениеКоличестваПрописанныхПроживающихСобственников.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА энргИзменениеКоличестваПрописанныхПроживающихСобственников.ДатаФактическогоСобытия
		|		ИНАЧЕ энргИзменениеКоличестваПрописанныхПроживающихСобственников.Дата
		|	КОНЕЦ КАК Период
		|ПОМЕСТИТЬ ПараметрыКонтроля
		|ИЗ
		|	Документ.энргИзменениеКоличестваПрописанныхПроживающихСобственников КАК энргИзменениеКоличестваПрописанныхПроживающихСобственников
		|ГДЕ
		|	энргИзменениеКоличестваПрописанныхПроживающихСобственников.Ссылка В(&мДокументы)";
		
	Пакет.УстановитьТекстЗапроса(Текст);
	
КонецПроцедуры

#КонецОбласти

#Область РеализацияИнтерфейса_РаботаСоСтабильнымиПериодыми

Функция ТекстДляПроведенияПоСтабильнымПериодам()
	
	Текст 		=
	"ВЫБРАТЬ
	|	ДокументыДляПроведения.Организация КАК Организация,
	|	ДокументыДляПроведения.ПериодНачисления КАК ПериодНачисления,
	|	ДокументыДляПроведения.Район КАК Район,
	|	ДокументыДляПроведения.ЧастныйСектор КАК ЧастныйСектор,
	|	ДокументыДляПроведения.Строение КАК Строение,
	|	ДокументыДляПроведения.Помещение КАК Помещение,
	|	ДокументыДляПроведения.ПериодРегистрации КАК ПериодРегистрации,
	|	Шапка.Дата КАК ДатаРегистратора,
	|	ДокументыДляПроведения.ДокРегистратор КАК ДокРегистратор,
	|	Шапка.КоличествоПроживающих КАК КоличествоПроживающих,
	|	Шапка.КоличествоСобственников КАК КоличествоСобственников,
	|	Шапка.КоличествоПрописанных КАК КоличествоПрописанных
	|ИЗ
	|	ДокументыДляПроведения КАК ДокументыДляПроведения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргИзменениеКоличестваПрописанныхПроживающихСобственников КАК Шапка
	|		ПО ДокументыДляПроведения.ДокРегистратор = Шапка.Ссылка
	|			И ДокументыДляПроведения.КлючПомещения = Шапка.КлючПомещения";
	
	Возврат Текст;

КонецФункции

Функция ТекстДляПроведенияПоСтабильнымПериодамСвязанныеПомещения() 
	Текст 		=
	"ВЫБРАТЬ
	|	ДокументыДляПроведения.Организация КАК Организация,
	|	ДокументыДляПроведения.ПериодНачисления КАК ПериодНачисления,
	|	ДокументыДляПроведения.Район КАК Район,
	|	ДокументыДляПроведения.ЧастныйСектор КАК ЧастныйСектор,
	|	ДокументыДляПроведения.Строение КАК Строение,
	|	ДокументыДляПроведения.Помещение КАК Помещение,
	|	ДокументыДляПроведения.ПериодРегистрации КАК ПериодРегистрации,
	|	Шапка.Дата КАК ДатаРегистратора,
	|	ДокументыДляПроведения.ДокРегистратор КАК ДокРегистратор,
	|	Шапка.КоличествоПроживающих КАК КоличествоПроживающих,
	|	Шапка.КоличествоСобственников КАК КоличествоСобственников,
	|	Шапка.КоличествоПрописанных КАК КоличествоПрописанных,
	|	Шапка.КлючПомещения КАК КлючПомещения,
	|	""НЕОПРЕДЕЛЕНО"" КАК ВидОперации
	|ИЗ
	|	ДокументыДляПроведения КАК ДокументыДляПроведения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргИзменениеКоличестваПрописанныхПроживающихСобственников КАК Шапка
	|		ПО ДокументыДляПроведения.ДокРегистратор = Шапка.Ссылка
	|			И (НЕ ДокументыДляПроведения.КлючПомещения = Шапка.КлючПомещения)";
	
	Возврат Текст;

КонецФункции

