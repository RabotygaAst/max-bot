		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА НЕ энргИзменениеКоличестваПрописанныхПроживающихСобственников.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
