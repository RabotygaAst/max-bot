Процедура ПолучитьЛьготниковВнеЗоныГП(Схема)
	
	ПараметрыОтбора	 = Новый Структура;       
	ПараметрыВТ 	 = Новый Массив; 
	
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Организация, Район", "Организация", "Район")));	
	
	ПараметрыОтбора.Вставить("Период", энргФормированиеТекстовЗапроса.ПараметрПериодРавно("ПериодИсключая"));
	ПараметрыОтбора.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	РегистрыСведений.энргЛьготникиЕИРЦВнеЗоныГП.ЛьготникиВнеЗоныГП(Схема, ПараметрыОтбора, "ЛьготникиВнеЗоныГП");		
		
КонецПроцедуры

Процедура ПолучитьЗаписываемыхЛьготниковВнеЗоныГП(Схема)
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ЛьготникиВнеЗоныГПДокумента.Период КАК Период,
	|	ЛьготникиВнеЗоныГПДокумента.Организация КАК Организация,
	|	ЛьготникиВнеЗоныГПДокумента.Район КАК Район,
	|	ЛьготникиВнеЗоныГПДокумента.КодСоциальнойЗащиты КАК КодСоциальнойЗащиты,
	|	ЛьготникиВнеЗоныГПДокумента.Состояние КАК Состояние,
	|	ЛьготникиВнеЗоныГПДокумента.ВидРеестра КАК ВидРеестра,
	|	ЛьготникиВнеЗоныГПДокумента.НаселенныйПунктЕИРЦ КАК НаселенныйПунктЕИРЦ,
	|	ЛьготникиВнеЗоныГПДокумента.УлицаЕИРЦ КАК УлицаЕИРЦ,
	|	ЛьготникиВнеЗоныГПДокумента.ДомЕИРЦ КАК ДомЕИРЦ
	|ПОМЕСТИТЬ ЛьготникиКУстановкеПризнакаВнеЗоны
	|ИЗ
	|	ЛьготникиВнеЗоныГПДокумента КАК ЛьготникиВнеЗоныГПДокумента
	|ГДЕ
	|	НЕ (ЛьготникиВнеЗоныГПДокумента.Организация, ЛьготникиВнеЗоныГПДокумента.Район, ЛьготникиВнеЗоныГПДокумента.КодСоциальнойЗащиты, ЛьготникиВнеЗоныГПДокумента.НаселенныйПунктЕИРЦ, ЛьготникиВнеЗоныГПДокумента.УлицаЕИРЦ, ЛьготникиВнеЗоныГПДокумента.ДомЕИРЦ) В
	|				(ВЫБРАТЬ
	|					ЛьготникиВнеЗоныГП.Организация КАК Организация,
	|					ЛьготникиВнеЗоныГП.Район КАК Район,
	|					ЛьготникиВнеЗоныГП.КодСоциальнойЗащиты КАК КодСоциальнойЗащиты,
	|					ЛьготникиВнеЗоныГП.НаселенныйПунктЕИРЦ КАК НаселенныйПунктЕИРЦ,
	|					ЛьготникиВнеЗоныГП.УлицаЕИРЦ КАК УлицаЕИРЦ,
	|					ЛьготникиВнеЗоныГП.ДомЕИРЦ КАК ДомЕИРЦ
	|				ИЗ
	|					ЛьготникиВнеЗоныГП КАК ЛьготникиВнеЗоныГП)");		
		
КонецПроцедуры

