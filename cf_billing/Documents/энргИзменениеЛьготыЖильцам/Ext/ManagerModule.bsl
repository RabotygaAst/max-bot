Процедура ДобавитьТекстЗапросаЛьготникиЕИРЦ(Схема, Регистры)
	
	ИмяРегистра = "энргЛьготникиЕИРЦ";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= Новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст = 
	"ВЫБРАТЬ
	|	КорректныеДанныеЛьготников.Период КАК Период,
	|	КорректныеДанныеЛьготников.Организация КАК Организация,
	|	КорректныеДанныеЛьготников.Район КАК Район,
	|	КорректныеДанныеЛьготников.ПериодРегистрации КАК ПериодРегистрации,
	|	КорректныеДанныеЛьготников.ПериодНачисления КАК ПериодНачисления,
	|	КорректныеДанныеЛьготников.Жилец КАК Жилец,
	|	КорректныеДанныеЛьготников.КлючПомещения КАК КлючПомещения,
	|	КорректныеДанныеЛьготников.Состояние КАК Состояние,
	|	КорректныеДанныеЛьготников.ВидРеестра КАК ВидРеестра,
	|	КорректныеДанныеЛьготников.ТипЛьготы КАК ТипЛьготы,
	|	КорректныеДанныеЛьготников.КодСоциальнойЗащиты КАК КодСоциальнойЗащиты,
	|	КорректныеДанныеЛьготников.ПериодРегистрацииЛьготы КАК ПериодРегистрацииЛьготы
	|ИЗ
	|	КорректныеДанныеЛьготников КАК КорректныеДанныеЛьготников
	|ГДЕ
	|	НЕ (КорректныеДанныеЛьготников.Организация, КорректныеДанныеЛьготников.Район, КорректныеДанныеЛьготников.Жилец) В
	|				(ВЫБРАТЬ
	|					АктивныеЛьготники.Организация КАК Организация,
	|					АктивныеЛьготники.Район КАК Район,
	|					АктивныеЛьготники.Жилец КАК Жилец
	|				ИЗ
	|					АктивныеЛьготники КАК АктивныеЛьготники)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&Период,
	|	АктивныеЛьготники.Организация,
	|	АктивныеЛьготники.Район,
	|	&Период,
	|	&ПериодНачисления,
	|	АктивныеЛьготники.Жилец,
	|	АктивныеЛьготники.КлючПомещения,
	|	ЛОЖЬ,
	|	АктивныеЛьготники.ВидРеестра,
	|	АктивныеЛьготники.ТипЛьготы,
	|	АктивныеЛьготники.КодСоциальнойЗащиты,
	|	АктивныеЛьготники.ПериодРегистрацииЛьготы КАК ПериодРегистрацииЛьготы
	|ИЗ
	|	АктивныеЛьготники КАК АктивныеЛьготники
	|ГДЕ
	|	НЕ (АктивныеЛьготники.Организация, АктивныеЛьготники.Район, АктивныеЛьготники.Жилец) В
	|				(ВЫБРАТЬ
	|					КорректныеДанныеЛьготников.Организация КАК Организация,
	|					КорректныеДанныеЛьготников.Район КАК Район,
	|					КорректныеДанныеЛьготников.Жилец КАК Жилец
	|				ИЗ
	|					КорректныеДанныеЛьготников КАК КорректныеДанныеЛьготников)";		
			
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

