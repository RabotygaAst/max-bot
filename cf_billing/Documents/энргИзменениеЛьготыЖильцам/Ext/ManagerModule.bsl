#Область ОбработчикиСобытий

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	Поля.добавить("Номер");
	Поля.добавить("Дата");
	Поля.добавить("ВидОперации");
	СтандартнаяОбработка = Ложь; 	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	Представление 			="" + Данные.ВидОперации + " №" + Данные.номер + " от " +  Данные.дата;
	СтандартнаяОбработка 	= Ложь;
КонецПроцедуры

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	ЕстьЗначенияЗаполнения  	= Параметры.свойство("ЗначенияЗаполнения");
	
	ВидОперацииВыбран  			= Ложь;
	
	Если ЕстьЗначенияЗАполнения тогда
		ВидОперацииВыбран 		= Параметры.ЗначенияЗаполнения.свойство("видоперации");
	КонецЕсли;
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка 	= Ложь;
		если Параметры.свойство("Ключ") тогда
			ВидОперации 		= Параметры.ключ.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргИзменениеЛьготыЖильцам",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		ИначеЕсли  Параметры.свойство("ЗначениеКопирования") тогда
			ВидОперации 		= Параметры.ЗначениеКопирования.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргИзменениеЛьготыЖильцам",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы; 			
		ИначеЕсли  ЕстьЗначенияЗАполнения и ВидОперацииВыбран тогда
			ВидОперации 		= Параметры.ЗначенияЗаполнения.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргИзменениеЛьготыЖильцам",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;			
		иначе
			ВыбраннаяФорма 		= "ОбщаяФорма.энргФормаВыбораОперации";
			Параметры.вставить("ИмяДокумента","энргИзменениеЛьготыЖильцам");
			Параметры.вставить("ВыборОперации",Истина);
		КонецЕсли; 		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Заполняет список команд отчетов.
//
// Параметры:
//   КомандыОтчетов	-	ТаблицаЗначений	-	состав полей см. в функции МенюОтчеты.СоздатьКоллекциюКомандОтчетов.
//   Параметры		-	Структура.
//
Процедура ДобавитьКомандыОтчетов(КомандыОтчетов, Параметры= Неопределено) Экспорт
			
	энргВариантыОтчетовПереопределяемый.ДобавитьКомандуСтруктураПодчиненности(КомандыОтчетов);
	
КонецПроцедуры

// Инициализирует данные документа.
//
// Параметры:
//  ДокументСсылка			-	ДокументСсылка.энргИзменениеЛьготыЖильцам.
//  ДополнительныеСвойства	-	Структура.
//  Регистры				-	Произвольный.
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
		
	ПараметрыЗапроса = Новый Структура;
	Схема 			 = Неопределено;
	
	ИнициализироватьИсходныеДанныеДокумента(Схема);
	
	ДобавитьТекстЗапросаЛьготникиЕИРЦ(Схема, Регистры);
	ДобавитьТекстЗапросаСобственникиПомещений(Схема, Регистры);
	ДобавитьТекстЗапросаЛьготникиЕИРЦВнеЗоныГП(Схема, Регистры);
	
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		ВспомогательныеПараметры 	= Новый Структура;
		энргФормированиеТекстовЗапроса.УстановитьПерехватОбращенияКТаблицам(Схема, ДополнительныеСвойства.ТаблицыПодмены, ВспомогательныеПараметры); 
	КонецЕсли;
	
	КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	Запрос  						= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("мДокументы"		, ДокументСсылка);
	Запрос.УстановитьПараметр("ПериодИсключая"	, Новый Граница(ДокументСсылка.Дата, ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Период"			, ДокументСсылка.Дата);
	Запрос.УстановитьПараметр("ПериодНачисления", ДокументСсылка.ПериодНачисления);
	Запрос.УстановитьПараметр("Организация"		, ДокументСсылка.Организация);
	Запрос.УстановитьПараметр("Район"			, ДокументСсылка.Район);
	Запрос.УстановитьПараметр("ВидРеестра"		, ДокументСсылка.ВидРеестра);
	
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		энргФормированиеТекстовЗапроса.УстановитьПараметрыТаблицыПодмены(Запрос, ВспомогательныеПараметры); 
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		Запрос.ВыполнитьПакет());
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияДанныхДокумента

Процедура ИнициализироватьИсходныеДанныеДокумента(Схема)
	
	ПолучитьКорректныеДанныеЛьготников(Схема);
	ПолучитьЛьготниковВнеЗоныГПДокумента(Схема);
	ПолучитьАктивныхЛьготников(Схема);
	ПолучитьЛьготниковВнеЗоныГП(Схема);
	ПолучитьЗаписываемыхЛьготниковВнеЗоныГП(Схема);
	
КонецПроцедуры

Процедура ПолучитьКорректныеДанныеЛьготников(Схема)
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ ШапкаДокумента.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ШапкаДокумента.ДатаФактическогоСобытия
	|		ИНАЧЕ ШапкаДокумента.Дата
	|	КОНЕЦ КАК Период,
	|	ШапкаДокумента.Организация КАК Организация,
	|	ТаблицаЗагруженныеДанные.Абонент.Район КАК Район,
	|	ШапкаДокумента.Дата КАК ПериодРегистрации,
	|	НАЧАЛОПЕРИОДА(ШапкаДокумента.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления,
	|	ТаблицаЗагруженныеДанные.Жилец КАК Жилец,
	|	ТаблицаЗагруженныеДанные.Абонент.КлючПомещения КАК КлючПомещения,
	|	ИСТИНА КАК Состояние,
	|	ИСТИНА КАК Активна,
	|	ИСТИНА КАК Проживаюший,
	|	ШапкаДокумента.ВидРеестра КАК ВидРеестра,
	|	ШапкаДокумента.ВидРеестра.ТипЛьготы КАК ТипЛьготы,
	|	ТаблицаЗагруженныеДанные.КодСоциальнойЗащиты КАК КодСоциальнойЗащиты,
	|	ШапкаДокумента.ПериодРегистрацииЛьготы КАК ПериодРегистрацииЛьготы
	|ПОМЕСТИТЬ КорректныеДанныеЛьготников
	|ИЗ
	|	Документ.энргИзменениеЛьготыЖильцам КАК ШапкаДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргИзменениеЛьготыЖильцам.ЗагруженныеДанные КАК ТаблицаЗагруженныеДанные
	|		ПО ШапкаДокумента.Ссылка = ТаблицаЗагруженныеДанные.Ссылка
	|			И (ШапкаДокумента.Ссылка = &мДокументы)
	|			И (ТаблицаЗагруженныеДанные.Ссылка = &мДокументы)");
	
КонецПроцедуры

Процедура ПолучитьЛьготниковВнеЗоныГПДокумента(Схема)
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ ШапкаДокумента.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ШапкаДокумента.ДатаФактическогоСобытия
	|		ИНАЧЕ ШапкаДокумента.Дата
	|	КОНЕЦ КАК Период,
	|	ШапкаДокумента.Организация КАК Организация,
	|	ШапкаДокумента.Район КАК Район,
	|	энргИзменениеЛьготыЖильцамНезагруженныеДанные.КодСоциальнойЗащиты КАК КодСоциальнойЗащиты,
	|	ИСТИНА КАК Состояние,
	|	ШапкаДокумента.ВидРеестра КАК ВидРеестра,
	|	энргИзменениеЛьготыЖильцамНезагруженныеДанные.НаселенныйПунктЕИРЦ КАК НаселенныйПунктЕИРЦ,
	|	энргИзменениеЛьготыЖильцамНезагруженныеДанные.УлицаЕИРЦ КАК УлицаЕИРЦ,
	|	энргИзменениеЛьготыЖильцамНезагруженныеДанные.ДомЕИРЦ КАК ДомЕИРЦ
	|ПОМЕСТИТЬ ЛьготникиВнеЗоныГПДокумента
	|ИЗ
	|	Документ.энргИзменениеЛьготыЖильцам КАК ШапкаДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргИзменениеЛьготыЖильцам.НезагруженныеДанные КАК энргИзменениеЛьготыЖильцамНезагруженныеДанные
	|		ПО ШапкаДокумента.Ссылка = энргИзменениеЛьготыЖильцамНезагруженныеДанные.Ссылка
	|			И (ШапкаДокумента.Ссылка = &мДокументы)
	|			И (энргИзменениеЛьготыЖильцамНезагруженныеДанные.Ссылка = &мДокументы)
	|			И (энргИзменениеЛьготыЖильцамНезагруженныеДанные.ВнеЗоныГП)");
	
КонецПроцедуры

Процедура ПолучитьАктивныхЛьготников(Схема)
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
