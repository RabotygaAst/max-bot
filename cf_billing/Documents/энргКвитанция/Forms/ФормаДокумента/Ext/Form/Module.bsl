&НаКлиенте
Процедура ПересчитатьСтрокуПриборовУчета(ДанныеСтроки  = Неопределено)
	
	текСтрока 								= Элементы.ПоказанияПриборовУчета.ТекущиеДанные;
	
	Если ДанныеСтроки <>Неопределено тогда
		ЗаполнитьЗначенияСвойств(текСтрока,ДанныеСтроки);
	КонецЕсли;
	
	энргРаботаСПоказаниямиПриборовУчетаКлиентСервер.ПересчитатьСтрокуПриборовУчета(текСтрока,Объект.Дата,Ложь);	
	
	Если текСтрока.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Показания отклонены"); 		
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеАбонентаСервер()
	ЗаполнитьДанныеДляОплаты();	
	ЗаполнитьДанныеПриборовУчета();
	ЗаполнитьСведенияОРассрочке();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеДляОплаты()
	// очищаем табличную часть оплаты
	Объект.Услуги.Очистить();
	
	// выводим данные по подключенным услугам и задолженности
	Результат = энргРаботаСТочкамиУчетаСервер.ДанныеДляОплатыАбонента(Объект.Дата,Объект.Организация, Объект.ПериодНачисления,Объект.Район,Объект.МКД,Объект.Абонент);
	Выборка  = Результат.выбрать();
	Пока Выборка.следующий() цикл
		 СтрокаУслуги  								= Объект.Услуги.Добавить();
		 СтрокаУслуги.ПредставлениеПериодаОплаты 	= Формат(Выборка.периодНачисления,"ДФ='ММММ гггг'");
		 ЗаполнитьЗначенияСвойств(СтрокаУслуги,Выборка); 		 
	 КонецЦикла; 
	 
	СуммаКОплате = энргРаботаСТочкамиУчетаСервер.ЗадолженностьАбонента(Объект.Дата,Объект.Организация,Объект.Район,Объект.МКД,Объект.Абонент);		 

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеПриборовУчета()
	
	ТаблицаТЧ 								= Объект.ПоказанияПриборовУчета.Выгрузить();
	Объект.ПоказанияПриборовУчета.Очистить();
	Объект.ТочкиУчета.Очистить();
	
	Результат 								= энргРаботаСприборамиУчетаСервер.ДействующиеПриборыУчетаАбонента(Объект.Дата,Объект.Район,Объект.Организация,Объект.Абонент); 
	Выборка  								= Результат.выбрать();
	Пока Выборка.следующий() цикл
		СтрокаПриборов  					= Объект.ТочкиУчета.Добавить();
		СтрокаПриборов.IDСтроки 			= Новый УникальныйИдентификатор;
		ЗаполнитьЗначенияСвойств(СтрокаПриборов,Выборка); 		 
	КонецЦикла; 
	
	энргРаботаСПоказаниямиПриборовУчетаСервер.ОбновитьПоказанияПриборовУчета(Объект.ТочкиУчета,Объект.ПоказанияПриборовУчета,ТаблицаТЧ,Объект.Дата,Объект.Организация,Объект.Район,Объект.МКД,Объект.Абонент,Ложь);
	
КонецПроцедуры

&НаСервере
Процедура РаспределитьОплатуСервер()
	
	ТекОбъект  		= РеквизитФормыВЗначение("Объект");
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ТекПериодНачисления",	Объект.ПериодНачисления);
	Запрос.УстановитьПараметр("ДанныеТЧ",				ТекОбъект.услуги.выгрузить());
	Запрос.Текст 	="ВЫБРАТЬ
	|	энргКвитанцияУслуги.Услуга,
	|	энргКвитанцияУслуги.ПериодНачисления,
	|	энргКвитанцияУслуги.Задолженность,
	|	энргКвитанцияУслуги.НачисленоПоКвитанции,
	|	энргКвитанцияУслуги.НомерСтроки
	|ПОМЕСТИТЬ ДанныеТЧ
	|ИЗ
	|	&ДанныеТЧ КАК энргКвитанцияУслуги
	|ГДЕ
	|	энргКвитанцияУслуги.Задолженность > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПорядокПогашенияЗадолженности.Услуга,
	|	энргПорядокПогашенияЗадолженности.Порядок
	|ПОМЕСТИТЬ ПорядокРаспределения
	|ИЗ
	|	РегистрСведений.энргПорядокПогашенияЗадолженности КАК энргПорядокПогашенияЗадолженности
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеТЧ.Услуга,
	|	ДанныеТЧ.ПериодНачисления КАК ПериодНачисления,
	|	ДанныеТЧ.Задолженность  КАК Задолженность,
	|	ДанныеТЧ.НомерСтроки,
	|	ПорядокРаспределения.Порядок КАК Порядок,
	|	ВЫБОР
	|		КОГДА ДанныеТЧ.ПериодНачисления = &ТекПериодНачисления
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК ПорядокПериодНачисления
	|ИЗ
	|	ПорядокРаспределения КАК ПорядокРаспределения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеТЧ КАК ДанныеТЧ
	|		ПО ПорядокРаспределения.Услуга = ДанныеТЧ.Услуга
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПорядокПериодНачисления,
	|	ПериодНачисления,
	|	Порядок";
	
	
	НадоРаспределить  					= Объект.СуммаОплаты;
	Результат  							= Запрос.Выполнить();
	Выборка  							= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		СтрокаУслуг 					= Объект.Услуги[Выборка.НомерСтроки - 1];
		Оплачиваем  					= Мин(НадоРаспределить,Выборка.Задолженность);
		СтрокаУслуг.Оплачено 			= Оплачиваем;
		НадоРаспределить 				= НадоРаспределить -  Оплачиваем;		
	КонецЦикла; 	
	
	Если НадоРаспределить > 0 тогда
		для Каждого стр из Объект.ОплатаПоРассрочке цикл
			Оплачиваем  				= Мин(НадоРаспределить,стр.СуммаНеОплаченныхПроцентов);
			СтрокаУслуг.Оплачено 		= Оплачиваем;
			НадоРаспределить 			= НадоРаспределить -  Оплачиваем;
		КонецЦикла;  		
	КонецЕсли;
	
	Если НадоРаспределить > 0 тогда
		Оплачиваем  					= Мин(НадоРаспределить,Объект.СуммаОсновногоДолгаРассрочки);
		ОплатаОсновногоДолгаРассрочки 	= Оплачиваем;
		НадоРаспределить 				= НадоРаспределить -  Оплачиваем; 		
	КонецЕсли; 	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСведенияОРассрочке()
	
	Объект.ОплатаПоРассрочке.Очистить();
	
	Запрос 			= Новый Запрос;
	Запрос.УстановитьПараметр("Период",		Объект.Дата);
	Запрос.УстановитьПараметр("Район",		Объект.Район);
	Запрос.УстановитьПараметр("МКД",		Объект.МКД);
	Запрос.УстановитьПараметр("Абонент",	Объект.Абонент);
	Запрос.Текст 	="ВЫБРАТЬ
	|	энргПроцентыПоРассрочкеОстатки.ПериодНачисления,
	|	энргПроцентыПоРассрочкеОстатки.СуммаЗадолженностиОстаток КАК СуммаНеОплаченныхПроцентов
	|ИЗ
	|	РегистрНакопления.энргПроцентыПоРассрочке.Остатки(
	|			&Период,
	|			Район = &Район
	|				И МКД = &МКД
	|				И Абонент = &Абонент) КАК энргПроцентыПоРассрочкеОстатки";
	Результат  = Запрос.Выполнить();
	Выборка  = Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		СтрокаТЧ 							= Объект.ОплатаПоРассрочке.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ,Выборка);
	КонецЦикла; 
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",		Объект.Дата);
	Запрос.УстановитьПараметр("Район",		Объект.Район);
	Запрос.УстановитьПараметр("МКД",		Объект.МКД);
	Запрос.УстановитьПараметр("Абонент",	Объект.Абонент);
	Запрос.Текст 	="ВЫБРАТЬ
	|	энргЗадолженностьПоРассрочкеОстатки.СуммаЗадолженностиОстаток
	|ИЗ
	|	РегистрНакопления.энргЗадолженностьПоРассрочке.Остатки(
	|			&Период,
	|			Район = &Район
	|				И МКД = &МКД
	|				И Абонент = &Абонент) КАК энргЗадолженностьПоРассрочкеОстатки";
	Результат  								= Запрос.Выполнить();
	Выборка  								= Результат.Выбрать();
	Если не Результат.Пустой() тогда
		Выборка  							= Результат.Выбрать();
		Выборка.Следующий();
		Объект.СуммаОсновногоДолгаРассрочки = Выборка.СуммаЗадолженностиОстаток;
	КонецЕсли;
	
КонецПроцедуры

#Область ФискальнаяОперация

&НаСервере
Процедура ФискальнаяОперацияОбновитьСтатус()
	
	ФискальнаяОперацияПодключенноеОборудование = энргПодключаемоеОборудованиеБиллингВызовСервера.ОборудованиеПодключенноеККассе(Объект.Касса);
	ИмяКоманды = "ПробитьЧек";
	
	Элементы.ФискальнаяОперацияСтатус.Видимость = (ФискальнаяОперацияПодключенноеОборудование <> Неопределено);
	Если ФискальнаяОперацияПодключенноеОборудование = Неопределено Тогда
		ФискальнаяОперацияСтатус = "";
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ФискальнаяОперацияДанныеЖурнала = энргПодключаемоеОборудованиеБиллингВызовСервера.ДанныеЖурналаФискальныхОпераций(Объект.Ссылка);
	Иначе
		ФискальнаяОперацияДанныеЖурнала = Неопределено;
	КонецЕсли;
	
	Строки = Новый Массив;
	Если ФискальнаяОперацияДанныеЖурнала = Неопределено Тогда
		
		Если ЗначениеЗаполнено(ФискальнаяОперацияПодключенноеОборудование.ККТ) Тогда
			
			Строки.Добавить(
			Новый ФорматированнаяСтрока(
			НСтр("ru = 'Пробить чек'"),,
			ЦветаСтиля.энргЦветГиперссылки,,
			ИмяКоманды));
			
		Иначе
			
			Строки.Добавить(
			Новый ФорматированнаяСтрока(
			НСтр("ru = 'Чек не пробит'"),,
			ЦветаСтиля.энргЦветГиперссылки,,
			"НастроитьОборудование"));
			
		КонецЕсли;
		
	Иначе
		
		
		Строки.Добавить(
		Новый ФорматированнаяСтрока(
		СтрШаблон(
		НСтр("ru = 'Пробит чек №%1'"),
		ФискальнаяОперацияДанныеЖурнала.НомерЧекаККМ),,
		ЦветаСтиля.энргЦветГиперссылки,,
		"ОткрытьЗаписьЖурналаФискальныхОпераций"));
		
	КонецЕсли;
	
	ФискальнаяОперацияСтатус = Новый ФорматированнаяСтрока(Строки);
	
КонецПроцедуры

&НаКлиенте
Процедура ФискальнаяОперацияОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	
	ТорговыйОбъект = Объект.Касса;
	
	Если "ПробитьЧек" = НавигационнаяСсылкаФорматированнойСтроки Тогда
		
		ПараметрыОперации = Новый Структура;
		ПараметрыОперации.Вставить("ДокументСсылка",           Объект.Ссылка);
		ПараметрыОперации.Вставить("Партнер",                  Объект.Абонент);
		ПараметрыОперации.Вставить("Организация",              Объект.Организация);
		ПараметрыОперации.Вставить("ТорговыйОбъект",           ТорговыйОбъект);
		ПараметрыОперации.Вставить("ПодключенноеОборудование", ФискальнаяОперацияПодключенноеОборудование);
		
		энргПодключаемоеОборудованиеБиллингКлиент.ПробитьЧек(
		ЭтотОбъект,
		ПараметрыОперации,
		РежимЗаписиДокумента.Проведение,
		Новый ОписаниеОповещения("ФискальнаяОперацияЗавершение", ЭтотОбъект));
		
	ИначеЕсли "ПробитьЧекИнкассация" = НавигационнаяСсылкаФорматированнойСтроки Тогда
		
		ПараметрыОперации = Новый Структура;
		ПараметрыОперации.Вставить("Сумма",                    Объект.СуммаДокумента);
		ПараметрыОперации.Вставить("ДокументСсылка",           Объект.Ссылка);
		ПараметрыОперации.Вставить("Организация",              Объект.Организация);
		ПараметрыОперации.Вставить("ТорговыйОбъект",           ТорговыйОбъект);
		ПараметрыОперации.Вставить("ПодключенноеОборудование", ПараметрыКассыККМ.ИдентификаторУстройства);
		
		ПараметрыОперации.Вставить("ВыемкаДенежныхСредствИзКассыККМ", Неопределено);
		
		энргПодключаемоеОборудованиеБиллингКлиент.ПробитьЧекВыемкаДенежныхСредств(
		ЭтотОбъект,
		ПараметрыОперации,
		РежимЗаписиДокумента.Проведение,
		Новый ОписаниеОповещения("ФискальнаяОперацияЗавершение", ЭтотОбъект));
		
	ИначеЕсли "ОткрытьЗаписьЖурналаФискальныхОпераций" = НавигационнаяСсылкаФорматированнойСтроки Тогда
		
		энргПодключаемоеОборудованиеБиллингКлиент.ОткрытьЗаписьЖурналаФискальныхОпераций(ЭтотОбъект, ФискальнаяОперацияДанныеЖурнала);
		
	ИначеЕсли "НастроитьОборудование" = НавигационнаяСсылкаФорматированнойСтроки Тогда
		
		ОткрытьФорму("Обработка.ПредпросмотрЧека.Форма.ОшибкаПодключенияККТ");
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФискальнаяОперацияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ФискальнаяОперацияОбновитьСтатус();
	
КонецПроцедуры

