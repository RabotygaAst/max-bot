#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	энргОбщегоНазначения.УстановитьСписокРайонов(Объект.Район,Элементы.Район);
		
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			Объект.ПериодНачисления = энргРаботаСПериодомДействия.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация);
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПриЧтенииСозданииНаСервере();
	КонецЕсли;	
	
	ЗаполнитьДокумент  								= Ложь;
	
	Если Параметры.Свойство("ЗаполнитьДокумент") тогда
		Если Параметры.ЗаполнитьДокумент тогда
			ЗаполнитьДокумент 						= истина;
		КонецЕсли;
	ИначеЕсли ЗначениеЗаполнено(Параметры.ЗначениеКопирования) тогда
		ЗаполнитьДокумент 						= истина;		  
	ИначеЕсли Параметры.ЗначенияЗаполнения.Свойство("Абонент") тогда
		ЗаполнитьДокумент 							= истина;
		ДанныеАбонента								= ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Абонент,Новый ФиксированнаяСтруктура("Район,Организация,МКД,ЛицевойСчет"));
		
		Объект.Район 								= ДанныеАбонента.Район;
		Объект.Организация 							= ДанныеАбонента.Организация;
		Объект.МКД 									= ДанныеАбонента.МКД;
		Объект.ЛицевойСчет							= ДанныеАбонента.ЛицевойСчет;
		Объект.АдресОбъекта 						= УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Объект.Абонент,Справочники.ВидыКонтактнойИнформации.АдресОбъекта);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Абонент) и ЗаполнитьДокумент тогда
		Если не ЗначениеЗаполнено(Объект.Дата) тогда
			Объект.Дата 							= ТекущаяДата();
		КонецЕсли;		
		ЗаполнитьДанныеАбонентаСервер();
	КонецЕсли; 		
	
	Если Не ЗначениеЗаполнено(Параметры.Ключ) тогда
		//Объект.ВидОплаты 							= Перечисления.ФормыОплаты.Наличные;
	КонецЕсли;      	
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// МенюОтчеты
	МенюОтчеты.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюОтчеты);
	// Конец МенюОтчеты  
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
		
	ПриЧтенииСозданииНаСервере();
КонецПроцедуры

