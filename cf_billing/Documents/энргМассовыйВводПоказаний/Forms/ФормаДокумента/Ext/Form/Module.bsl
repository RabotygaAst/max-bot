	ПараметрыОтбора.Вставить("IDСтроки", IDСтроки);
	НайденныеСтроки = Объект.ПоказанияПриборовУчета.НайтиСтроки(ПараметрыОтбора);
	
	Возврат НайденныеСтроки.Количество();
		
КонецФункции

#КонецОбласти

#Область ОбработчикиКомандФормы

// ВводНаОсновании
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуСоздатьНаОсновании(Команда)
	
	ВводНаОснованииКлиент.ВыполнитьПодключаемуюКомандуСоздатьНаОсновании(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры
// Конец ВводНаОсновании

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат) Экспорт
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

#Область СервисПроверкиПоказанийПриборовУчета

&НаСервере
Процедура ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний()
	
	ТаблицаПриборов = энргРаботаСПоказаниямиПриборовУчетаСервер.НоваяТаблицаПриборовДляПроверки();
	Для Каждого ТекСтрока из Объект.ТочкиУчета Цикл
		НСтрока = ТаблицаПриборов.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, ТекСтрока);
		НСтрока.Район = Объект.Район;
	КонецЦикла;
	
	ПериодЗапроса = Новый Граница(Объект.Дата, ВидГраницы.Исключая);
	ВспомогательныеПараметры = энргРаботаСПоказаниямиПриборовУчетаСервер.НовыеВспомогательныеПараметрыПроверкиОтклоненияПоказаний();
	ВспомогательныеПараметры.ПоказанияВСрок = ПоказанияВСрок;
	ВспомогательныеПараметры.ПериодНачисления = Объект.ПериодНачисления;
	
	РезультатЗапроса = энргРаботаСПоказаниямиПриборовУчетаСервер.ПриборыДляОтклоненияПоказаний(ПериодЗапроса, Объект.Организация, ТаблицаПриборов, ВспомогательныеПараметры);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний(ЭтотОбъект, РезультатЗапроса);
	
КонецПроцедуры

&НаСервере
Процедура ПоказанияПредоставляютсяВСрок()
	ПоказанияВСрок = энргРаботаСПоказаниямиПриборовУчетаСервер.ПоказанияПредоставляютсяВСрок(Объект.ПериодНачисления, Объект.Дата, Объект.Организация, Объект.Район);
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтрокуСПоказаниями(ТекущиеДанныеТочкиУчета, ТекущиеДанные)
	РезультатПроверки = энргРаботаСПоказаниямиПриборовУчетаКлиент.ОпределитьСостояниеПоказанийПоСтроке(ТекущиеДанныеТочкиУчета.ПриборУчета, ЭтотОбъект, ТекущиеДанные);
	Если РезультатПроверки.СостояниеИзменено Тогда
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, РезультатПроверки);
		Возврат;
	КонецЕсли;
	
	энргРаботаСПоказаниямиПриборовУчетаКлиент.ПересчитатьСтрокуПриборовУчета(ТекущиеДанные, ТекущиеДанныеТочкиУчета.РегистрируетОбъем, Объект.Дата); 
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьДанныеАбонента(Команда)
	
	Модифицированность = Истина;
	ОткрытьФормуПодбораАбонетов();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуПодбораАбонетов(ФИО = "", ИдТекСтроки = Неопределено)
	
	Перем ОписаниеОповещения, Период, ТекПараметры;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьДанныеАбонентаЗавершение",ЭтаФорма);

	ТекПараметры = Новый Структура("Организация, Район, Строение, Контроллер, Маршрут, Период", 
					Объект.Организация,Объект.Район,Объект.Строение, Объект.Контроллер, Объект.Маршрут, Объект.Дата);
 	Если ИдТекСтроки <> Неопределено Тогда 
		ТекПараметры.Вставить("ФИО", ФИО);
		ТекПараметры.Вставить("ИдТекСтроки", ИдТекСтроки);
	КонецЕсли;
	ОткрытьФорму("Документ.энргМассовыйВводПоказаний.Форма.ФормаПоискаЛС",ТекПараметры, ЭтаФорма,,,, ОписаниеОповещения);

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоСтроению(Команда)
	
	Модифицированность = Истина;
	
	КоличествоСтрокПоказанияПУДо = Объект.ПоказанияПриборовУчета.Количество();	
	КоличествоСтрокТочкиУчетаДо = Объект.ТочкиУчета.Количество();	
	ЗаполнитьАбонентовПоСтроениюНаСервере();
	
	КоличествоСтрокПоказанияПУПосле = Объект.ПоказанияПриборовУчета.Количество(); 	
	КоличествоСтрокТочкиУчетаПосле = Объект.ТочкиУчета.Количество();
	
	КоличествоДобавленныхСтрокПУ = КоличествоСтрокПоказанияПУПосле - КоличествоСтрокПоказанияПУДо; 	
	КОличествоДобавленныхСтрокТУ = КоличествоСтрокТочкиУчетаПосле - КоличествоСтрокТочкиУчетаДо;
	
	Если ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаЕстьШкалыЕстьТарифныеЗоны");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоныТекущиеПоказания;
	ИначеЕсли НЕ ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаЕстьШкалыНетТарифныхЗон");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ШкалыПриборовУчетаЕстьШкалыНетТарифныхЗон");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаЕстьШкалыНетТарифныхЗонТекущиеПоказания;
	ИначеЕсли ИспользоватьТарифныеЗоны И НЕ ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалЕстьТарифныеЗоны");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоны");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоныТекущиеПоказания;
	Иначе	
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаНетШкалНетТарифныхЗонТекущиеПоказания;
	КонецЕсли;
	
	Если Объект.ТочкиУчета.Количество() > 0 И КОличествоДобавленныхСтрокТУ > 0 Тогда
		ИмяТаблицыТочкиУчета.ТекущаяСтрока = Объект.ТочкиУчета[Объект.ТочкиУчета.Количество() - КОличествоДобавленныхСтрокТУ].ПолучитьИдентификатор();
	КонецЕсли;
	
	Если Объект.ПоказанияПриборовУчета.Количество() > 0 И КоличествоДобавленныхСтрокПУ > 0 Тогда
		ИмяТаблицыПоказания.ТекущаяСтрока = Объект.ПоказанияПриборовУчета[Объект.ПоказанияПриборовУчета.Количество() - КоличествоДобавленныхСтрокПУ].ПолучитьИдентификатор();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАбонентовПоСтроениюНаСервере()

	РезультатЗапроса = Обработки.энргСостояниеПриборовУчетаМенеджер.ДействующиеПриборыУчетаПоМаршруту(Объект.Дата, Объект.Организация, Объект.Район, Неопределено, Объект.Строение, Истина); 
	ЗаполнитьПоказанияНаСервере(РезультатЗапроса);

КонецПроцедуры

#КонецОбласти

#Область СервисРаботыСМассовымВводом

&НаКлиенте
Процедура ДобавитьДанныеАбонентаЗавершение(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ТипЗнч(Результат) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Результат.Свойство("Абонент") Или НЕ Результат.Свойство("КлючПомещения") Тогда
		Возврат;
	КонецЕсли;
	
	
	// ищем строки по ключу помещения
	мСтроки  = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("КлючПомещения",Результат.КлючПомещения));
	Если НЕ мСтроки.Количество()  = 0 Тогда
		Ответ = Неопределено;
		
		ПоказатьВопрос(Новый ОписаниеОповещения("АнализОтветаНаДублированиеПоказаний", ЭтотОбъект, Новый Структура("мСтроки, Результат", мСтроки, Результат)), "По данному абоненту уже введены показания. Ввести ещё?", РежимДиалогаВопрос.ДаНет);
		
		Возврат;
		
		
	Иначе
		КлючРодителя = ПолучитьКлючПомещенияРодителя(Результат.КлючПомещения);
		Если ЗначениеЗаполнено(КлючРодителя) Тогда
			мСтроки  = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("КлючПомещения",КлючРодителя));
			Если НЕ мСтроки.Количество()  = 0 Тогда
				Ответ = Неопределено;
				
				ПоказатьВопрос(Новый ОписаниеОповещения("АнализОтветаНаДублированиеПоказаний", ЭтотОбъект, Новый Структура("мСтроки, Результат", мСтроки, Результат)), "По данному абоненту уже введены показания. Ввести ещё?", РежимДиалогаВопрос.ДаНет);
				
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	
	ДобавитьПУ_Абонента(Результат);
КонецПроцедуры

&НаКлиенте
Процедура АнализОтветаНаДублированиеПоказаний(РезультатВопроса, ДополнительныеПараметры1) Экспорт
	
	мСтроки = ДополнительныеПараметры1.мСтроки;
	Результат = ДополнительныеПараметры1.Результат;
	
	
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.Нет Тогда 
		Если ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
			ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны");		
		ИначеЕсли НЕ ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
			ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ШкалыПриборовУчетаЕстьШкалыНетТарифныхЗон");
		ИначеЕсли ИспользоватьТарифныеЗоны И НЕ ИспользоватьШкалыПриборовУчета Тогда
			ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоны");
		Иначе	
			ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		КонецЕсли;
		
		Если Объект.ТочкиУчета.Количество() > 0 Тогда
			ИмяТаблицыПоказания.ТекущаяСтрока = Объект.ПоказанияПриборовУчета[Объект.ПоказанияПриборовУчета.Количество() - 1].ПолучитьИдентификатор();
		КонецЕсли;
		
	Иначе
		
			ДобавитьПУ_Абонента(Результат);

		
	КонецЕсли;
	

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПУ_Абонента(Знач Результат)
	
	КоличествоСтрокПоказанияПУДо = Объект.ПоказанияПриборовУчета.Количество();
	
	ЗаполнитьДанныеПриборовУчета(Результат.Абонент, Результат.КлючПомещения);
	
	КоличествоСтрокПоказанияПУПосле = Объект.ПоказанияПриборовУчета.Количество();
	
	КОличествоДобавленныхСтрок = КоличествоСтрокПоказанияПУПосле - КоличествоСтрокПоказанияПУДо;
	
	Если ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаЕстьШкалыЕстьТарифныеЗоны");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоныТекущиеПоказания;
	ИначеЕсли НЕ ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаЕстьШкалыНетТарифныхЗон");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ШкалыПриборовУчетаЕстьШкалыНетТарифныхЗон");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаЕстьШкалыНетТарифныхЗонТекущиеПоказания;
	ИначеЕсли ИспользоватьТарифныеЗоны И НЕ ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалЕстьТарифныеЗоны");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоны");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоныТекущиеПоказания;
	Иначе	
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаНетШкалНетТарифныхЗонТекущиеПоказания;
	КонецЕсли;
	
	
	Если Объект.ТочкиУчета.Количество() > 0 И КОличествоДобавленныхСтрок > 0 Тогда
		ИмяТаблицыТочкиУчета.ТекущаяСтрока = Объект.ТочкиУчета[Объект.ТочкиУчета.Количество() - 1].ПолучитьИдентификатор();

		ИмяТаблицыПоказания.ТекущаяСтрока = Объект.ПоказанияПриборовУчета[Объект.ПоказанияПриборовУчета.Количество() - КОличествоДобавленныхСтрок].ПолучитьИдентификатор();
	КонецЕсли;
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеПриборовУчета(Абонент,КлючПомещения) 
	
	Результат 		= Обработки.энргСостояниеПриборовУчетаМенеджер.ДействующиеПриборыУчетаПомещения(Объект.Дата, Объект.Организация, Объект.Район, КлючПомещения, Неопределено, Истина, Новый Структура("ТолькоОткрытыеЛС", Истина)); 
	Выборка  		= Результат.выбрать();
	ТекТочкаУчета 	= Неопределено;
	ТекШкала 		= Неопределено;
	IDСтрокиТочки 	= Неопределено;
	IDСтрокиШкалы 	= Неопределено;
	Пока Выборка.Следующий() цикл

		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
			IDСтрокиТочки 						= Новый УникальныйИдентификатор;
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.КлючПомещения 		= КлючПомещения;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
			СтрокаТочкиУчета.РегистрируетОбъем 	= Выборка.РегистрируетОбъем;
			
			энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыАбонента(Выборка.Абонент,СтрокаТочкиУчета);
			
			СтрокаТочкиУчета.Абонент 			= Абонент;

		КонецЕсли;
		
		Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
		КонецЕсли;

		СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
		СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
		ТекШкала 								= Выборка.Шкала;
	КонецЦикла; 
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, Объект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета); 
	
	ЗаполнениеПоказанийСУчетомОтклонений(Ложь);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеПоказанийСУчетомОтклонений(КонтрольныйСъем)
	
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();
	
	ВспомогательныеПараметры = энргРаботаСПоказаниямиПриборовУчетаСервер.НовыеВспомогательныеПараметрыПриЗаполненииТабличнойЧастиПоказания();
	ВспомогательныеПараметры.Период = Объект.Дата;

	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Район); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказанийСУчетомОтклонения(Объект.Организация,Объект.Район,ТаблицаПоказанийДляЗаполнения,Объект.Дата, ПриборыДляОтклоненияПоказаний.Выгрузить(), КонтрольныйСъем);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета, ВспомогательныеПараметры);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКлючПомещенияРодителя(КлючПомещения)
	Если НЕ ЗначениеЗаполнено(КлючПомещения.Помещение.Родитель) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргКлючиПомещений.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	|ГДЕ
	|	энргКлючиПомещений.Строение = &Строение
	|	И энргКлючиПомещений.Помещение = &Помещение
	|	И НЕ энргКлючиПомещений.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Помещение", КлючПомещения.Помещение.Родитель);
	Запрос.УстановитьПараметр("Строение", КлючПомещения.Строение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

&НаКлиенте
Процедура ОчиститьТЧ(Команда)
	
	Если Объект.ТочкиУчета.Количество() > 0 Тогда
		
		Модифицированность = Истина;
		
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ТекущийОбъект", 	Объект);
		ДопПараметры.Вставить("ТЧ_Объекта",		Новый Структура("ТочкиУчета, ПоказанияПриборовУчета, ШкалыПриборовУчета"));
		ПроверкаОчисткиТЧ(ДопПараметры);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаОчисткиТЧ(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ПроверкаОчисткиТЧЗавершение",ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Очистить табличную часть?",РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаОчисткиТЧЗавершение(Результат,ДополнительныеПараметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если Результат = КодВозвратаДиалога.Да Тогда
		Модифицированность = Истина;
			
		Если ДополнительныеПараметры.Свойство("ТЧ_Объекта") Тогда
			Для каждого ТекТЧ Из ДополнительныеПараметры.ТЧ_Объекта Цикл
				Объект[ТекТЧ.Ключ].Очистить();
			КонецЦикла;
		КонецЕсли;
		
		энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(ДополнительныеПараметры.ТекущийОбъект, ДополнительныеПараметры.ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);

	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#Область СервисСозданияДокументовРегистрацииПоказаний

&НаКлиенте
Процедура ПослеВопросаПередСозданиемДокументов(Результат, ДополнительныеПараметры) Экспорт 
	
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли; 
	
	РезультатПереноса = Новый Структура("Статус", Истина);
	ЗарегистрироватьПоказанияКСозданиюДокументов(РезультатПереноса);
	Если РезультатПереноса.Статус Тогда 
		
		Записать();
		
		ОбновитьНадписьВыполненияДлительныхОперацийКлиент();	
		Если ОсталосьСоздатьДокументовДлительныхОпераций Тогда 
			ОткрытьФормуЗапускаСозданияДокументовВФоне();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры


&НаСервере
Процедура ЗарегистрироватьПоказанияКСозданиюДокументов(РезультатПереноса)
	
	НаборыЗаписей = Новый Структура;
	НаборЗаписей = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыСведений.энргЗагрузкаПоказанийТочкиУчета);
	//НаборЗаписей.Отбор.ДокументОснование.Установить(Объект.Ссылка);	
	НаборыЗаписей.Вставить("ТочкиУчета", НаборЗаписей);
	
	НаборЗаписей = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыСведений.энргЗагрузкаПоказанийШкалыПриборовУчета);
	//НаборЗаписей.Отбор.ДокументОснование.Установить(Объект.Ссылка);
	НаборыЗаписей.Вставить("ШкалыПриборовУчета", НаборЗаписей);
	
	НаборЗаписей = энргОбщегоНазначения.СоздатьНаборЗаписейСДополнительнымиПараметрами(РегистрыСведений.энргЗагрузкаПоказанийПоказанияПриборовУчета);
	//НаборЗаписей.Отбор.ДокументОснование.Установить(Объект.Ссылка);
	НаборыЗаписей.Вставить("ПоказанияПриборовУчета", НаборЗаписей);		
	
	СтрокиКОчистке = Новый Структура(
		"ТочкиУчета, ШкалыПриборовУчета, ПоказанияПриборовУчета",
		Новый Массив, Новый Массив, Новый Массив);
	ПодготовитьНаборыЗаписейПоказаний(НаборыЗаписей, СтрокиКОчистке);
	
	НачатьТранзакцию();	
	Попытка
		
		Для Каждого СтрокаНабора из НаборыЗаписей Цикл
			
			ТаблицаЗаписи = СтрокаНабора.Значение;
			ТаблицаЗаписи.Записать(Ложь);
						
		КонецЦикла;
		
		ОчиститьЗаписиТЧЗарегистрированныеВОчередь(СтрокиКОчистке);
		
		//Объект.ТочкиУчета.Очистить();
		//Объект.ШкалыПриборовУчета.Очистить();
		//Объект.ПоказанияПриборовУчета.Очистить();
		
		ЗафиксироватьТранзакцию();
	Исключение
	
		ОтменитьТранзакцию(); 	
		
		РезультатПереноса.Статус = Ложь;
		ИнфаОбОшибке 									= ИнформацияОбОшибке();
		ПараметрыЖурнала								= энргОбщегоНазначения.НеобязательныеПараметрыРегистацииОшибки();
		ПараметрыЖурнала.ВыводитьСообщениеПользователю 	= Истина;
		ПараметрыЖурнала.ТекстПользователю 				= "Не удалось зарегистрировать показания в массовом вводе показаний по причине: " + КраткоеПредставлениеОшибки(ИнфаОбОшибке);
		энргОбщегоНазначения.ЗарегистрироватьОшибку(
			"Регистрирация показаний в массовом вводе показаний", 
			УровеньЖурналаРегистрации.Ошибка, 
			ПодробноеПредставлениеОшибки(ИнфаОбОшибке), 
			ПараметрыЖурнала);
		
	КонецПопытки;
	
	УстановитьОтборДокументовРегистрацииПоказаний();
	
КонецПроцедуры

&НаСервере
Функция ПодготовитьНаборыЗаписейПоказаний(НаборыЗаписей, СтрокиКОчистке)
	
	СвойстваАбонента = Новый Соответствие;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаДанных.Абонент КАК Абонент
		|ПОМЕСТИТЬ ТаблицаДанных
		|ИЗ
		|	&ТаблицаДанных КАК ТаблицаДанных
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргАбоненты.Ссылка КАК Абонент,
		|	МАКСИМУМ(энргАбоненты.Организация) КАК Организация,
		|	МАКСИМУМ(энргАбоненты.Район) КАК Район
		|ИЗ
		|	ТаблицаДанных КАК ТаблицаДанных
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		|		ПО ТаблицаДанных.Абонент = энргАбоненты.Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	энргАбоненты.Ссылка";
	
	Запрос.УстановитьПараметр("ТаблицаДанных", Объект.ТочкиУчета.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();	
	Пока Выборка.Следующий() Цикл
		ЗначениеКлюча = Новый Структура("Организация,Район");
		ЗаполнитьЗначенияСвойств(ЗначениеКлюча, Выборка);
		СвойстваАбонента.Вставить(Выборка.Абонент, ЗначениеКлюча);
	КонецЦикла; 	
	
	СтрокиШкалКэш = Новый Массив;
	СтрокиПоказанийКэш = Новый Массив;
	
	СтрокиТЧШкалКэш = Новый Массив;
	СтрокиТЧПоказанийКэш = Новый Массив;
	
	ОтборШкал = Новый Структура("IDСтрокиТочкиУчета", Неопределено);
	ОтборПоказаний = Новый Структура("IDСтроки", Неопределено);
	Для Каждого СтрокаТочкиУчета из Объект.ТочкиУчета Цикл 
		
		ЕстьНеПредоставленные = Ложь;
		СтрокиШкалКэш.Очистить();
		СтрокиПоказанийКэш.Очистить();
		
		СтрокиТЧШкалКэш.Очистить();
		СтрокиТЧПоказанийКэш.Очистить();
		
		СтрокиКОчистке.ТочкиУчета.Добавить(СтрокаТочкиУчета);		
		
		НоваяСтрокаТУ = НаборыЗаписей.ТочкиУчета.Добавить();		
		ЗаполнитьЗначенияСвойств(НоваяСтрокаТУ, СтрокаТочкиУчета);
		ДанныеАбонента = СвойстваАбонента[СтрокаТочкиУчета.Абонент];
		Если ЗначениеЗаполнено(ДанныеАбонента) Тогда
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТУ, ДанныеАбонента); 		
		Иначе 
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТУ, Объект);
		КонецЕсли;
		НоваяСтрокаТУ.ДокументОснование = Объект.Ссылка;
		НоваяСтрокаТУ.ДатаДокумента = Объект.Дата;
		НоваяСтрокаТУ.ПериодНачисления = Объект.ПериодНачисления;
		
		ОтборШкал.IDСтрокиТочкиУчета = СтрокаТочкиУчета.IDСтроки;
		СтрокиШкал = Объект.ШкалыПриборовУчета.НайтиСтроки(ОтборШкал);		
		Для Каждого СтрокаШкалы из СтрокиШкал Цикл 
			
			СтрокиКОчистке.ШкалыПриборовУчета.Добавить(СтрокаШкалы);
			СтрокиТЧШкалКэш.Добавить(СтрокаШкалы);
			
			НоваяСтрокаШкал = НаборыЗаписей.ШкалыПриборовУчета.Добавить();
			СтрокиШкалКэш.Добавить(НоваяСтрокаШкал);
			
			ЗаполнитьЗначенияСвойств(НоваяСтрокаШкал, СтрокаШкалы);
			НоваяСтрокаШкал.ДокументОснование = Объект.Ссылка;
			НоваяСтрокаШкал.IDСтрокиТочкиУчета = СтрокаТочкиУчета.IDСтроки;
			
			ОтборПоказаний.IDСтроки = СтрокаШкалы.IDСтроки;
			СтрокиПоказаний = Объект.ПоказанияПриборовУчета.НайтиСтроки(ОтборПоказаний);
			Для Каждого СтрокаПоказаний из СтрокиПоказаний Цикл 
				
				Если НЕ СтрокаПоказаний.ПоказанияПредоставлены Тогда 
					ЕстьНеПредоставленные = Истина;
					Прервать;
				КонецЕсли;
				
				СтрокиКОчистке.ПоказанияПриборовУчета.Добавить(СтрокаПоказаний);
				СтрокиТЧПоказанийКэш.Добавить(СтрокаПоказаний);
				
				НоваяСтрокаПоказаний = НаборыЗаписей.ПоказанияПриборовУчета.Добавить();
				СтрокиПоказанийКэш.Добавить(НоваяСтрокаПоказаний);
				
				ЗаполнитьЗначенияСвойств(НоваяСтрокаПоказаний, СтрокаПоказаний);
				НоваяСтрокаПоказаний.ДокументОснование = Объект.Ссылка;
				НоваяСтрокаПоказаний.IDСтрокиТочкиУчета = СтрокаТочкиУчета.IDСтроки;		
				
			КонецЦикла;	
			
		КонецЦикла;
		
		Если ЕстьНеПредоставленные Тогда 
			ОчиститьНеПредоставленныеПоказанияНабораЗаписей(НаборыЗаписей, НоваяСтрокаТУ, СтрокиШкалКэш, СтрокиПоказанийКэш);
			ОчиститьНеПредоставленныеПоказанияТЧ(СтрокиКОчистке, СтрокаТочкиУчета, СтрокиТЧШкалКэш, СтрокиТЧПоказанийКэш);
		КонецЕсли;
		
	КонецЦикла;	
	
КонецФункции

&НаСервере
Процедура ОчиститьНеПредоставленныеПоказанияНабораЗаписей(НаборыЗаписей, СтрокаТУКэш, СтрокиШкалКэш, СтрокиПоказанийКэш)
	
	НаборыЗаписей.ТочкиУчета.Удалить(СтрокаТУКэш);
	
	Для Каждого СтрокаДанных из СтрокиШкалКэш Цикл
		НаборыЗаписей.ШкалыПриборовУчета.Удалить(СтрокаДанных);
	КонецЦикла;
	
	Для Каждого СтрокаДанных из СтрокиПоказанийКэш Цикл
		НаборыЗаписей.ПоказанияПриборовУчета.Удалить(СтрокаДанных);
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьНеПредоставленныеПоказанияТЧ(СтрокиКОчистке, СтрокаТУКэш, СтрокиШкалКэш, СтрокиПоказанийКэш)
	
	ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(СтрокиКОчистке.ТочкиУчета, СтрокаТУКэш);
	
	Для Каждого СтрокаДанных из СтрокиШкалКэш Цикл
		ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(СтрокиКОчистке.ШкалыПриборовУчета, СтрокаДанных);
	КонецЦикла;
	
	Для Каждого СтрокаДанных из СтрокиПоказанийКэш Цикл 
		ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(СтрокиКОчистке.ПоказанияПриборовУчета, СтрокаДанных);
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьЗаписиТЧЗарегистрированныеВОчередь(СтрокиКОчистке)
	
	Для Каждого СтрокаДанных из СтрокиКОчистке.ТочкиУчета Цикл
		Объект.ТочкиУчета.Удалить(СтрокаДанных);
	КонецЦикла;
	
	Для Каждого СтрокаДанных из СтрокиКОчистке.ШкалыПриборовУчета Цикл
		Объект.ШкалыПриборовУчета.Удалить(СтрокаДанных);
	КонецЦикла;
	
	Для Каждого СтрокаДанных из СтрокиКОчистке.ПоказанияПриборовУчета Цикл
		Объект.ПоказанияПриборовУчета.Удалить(СтрокаДанных);
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборДокументовРегистрацииПоказаний()
	
	//ДокументОснованиеСсылка = ?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Ссылка, Неопределено);
	ДокументОснованиеСсылка = ?(
		ЗначениеЗаполнено(Объект.Ссылка), 
		Объект.Ссылка, 
		Документы.энргЗагрузкаДанныхИзВнешнихИсточников.ПолучитьСсылку(Новый УникальныйИдентификатор));
		
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
		ДокументыПоказанийПриборовУчета,
		"ДокументОснование",
		ДокументОснованиеСсылка);
		
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
		ДокументыПоказанийПриборовУчета,
		"ПоказыватьОтклоненные",
		Ложь);	
		
КонецПроцедуры

