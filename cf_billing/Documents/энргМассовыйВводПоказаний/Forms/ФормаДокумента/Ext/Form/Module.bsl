&НаКлиенте
Процедура ПровестиДокумент(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		ПоказатьПредупреждение(, НСтр("ru = 'Перед созданием документов необходимо записать документ'"));
		Возврат;
	КонецЕсли;	
	
	ЕстьПредварительныеДанные = Ложь;
	Для Каждого текСтрока из Объект.ТочкиУчета Цикл 
		ЕстьПредварительныеДанные = Истина;
		Прервать;
	КонецЦикла;
	
	Если НЕ ЕстьПредварительныеДанные Тогда
		ЗаголовокЧерновыхДанных = Элементы.ГруппаВводПоказанийПриборовУчета.Заголовок;
		Шаблон = "ru = 'Нет данных для создания регистрации показаний. Вкладка %1 пустая'";
		ПоказатьПредупреждение(, НСтр(СтрШаблон(Шаблон, ЗаголовокЧерновыхДанных)));
		Возврат;
	КонецЕсли;	
	
	Если Модифицированность Тогда 
		ПоказатьПредупреждение(, НСтр("ru = 'Документ изменен. Перед созданием документов необходимо записать документ'"));
		Возврат;
	КонецЕсли;	
	
	Если ОсталосьСоздатьДокументовДлительныхОпераций > 0 И ЕстьПредварительныеДанные Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Перед проведением необходимо создать документы зарегистрированные в очередь'"));
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаПередСозданиемДокументов", ЭтотОбъект);
	ПоказатьВопрос(
		ОписаниеОповещения, 
		НСтр("ru = 'Перед записью документа проверьте корректность заполнения даты документа и реквизитов в шапке документа. Продолжить проведение?'"),
		РежимДиалогаВопрос.ДаНет);
		
КонецПроцедуры

