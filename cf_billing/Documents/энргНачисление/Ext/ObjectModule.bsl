#Область ПрограммныйИнтерфейс

Функция НаборВыполненныхНачислений(Замещать) Экспорт
	
	НаборВыполненные 							= РегистрыСведений.энргДокументыНачислений.СоздатьНаборЗаписей();
	НаборВыполненныеДопСвойства 				= НаборВыполненные.ДополнительныеСвойства;
	НаборВыполненныеДопСвойства.Вставить("Замещать", Замещать);
	
	Если ЭтоНовый() Тогда		
		ЗаписьВыполненные						= НаборВыполненные.Добавить();
		ЗаписьВыполненные.Организация 			= Организация;
		ЗаписьВыполненные.Район		 			= Район;
		ЗаписьВыполненные.ПериодНачисления 		= НачалоМесяца(Дата);
		ЗаписьВыполненные.ВидОперацийНачисления	= Перечисления.энргВидыОперацийНачисления.Индивидуальные;
		ЗаписьВыполненные.МКД 					= МКД;
		ЗаписьВыполненные.ДокументНачисления 	= ЭтотОбъект.ПолучитьСсылкуНового();		 
	Иначе					
		НаборВыполненные.Отбор.Организация.Установить(Организация);
		НаборВыполненные.Отбор.ПериодНачисления.Установить(НачалоМесяца(Дата));
		НаборВыполненные.Отбор.Район.Установить(Район);
		НаборВыполненные.Отбор.ВидОперацийНачисления.Установить(Перечисления.энргВидыОперацийНачисления.Индивидуальные);
		НаборВыполненные.Отбор.МКД.Установить(МКД);
				
		ЗаписьВыполненные						= НаборВыполненные.Добавить();
		ЗаписьВыполненные.Организация 			= Организация;
		ЗаписьВыполненные.Район		 			= Район;
		ЗаписьВыполненные.ПериодНачисления 		= НачалоМесяца(Дата);
		ЗаписьВыполненные.ВидОперацийНачисления = Перечисления.энргВидыОперацийНачисления.Индивидуальные;
		ЗаписьВыполненные.МКД 					= МКД;
		ЗаписьВыполненные.ДокументНачисления 	= Ссылка;
		ЗаписьВыполненные.ПометкаУдаления	 	= Ложь;
	КонецЕсли;
	
	Возврат НаборВыполненные;
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли; 
	
	ПроведениеРазрешено	= Ложь;	
	Если ДополнительныеСвойства.Свойство("ПроведениеРазрешено") И ДополнительныеСвойства.ПроведениеРазрешено  тогда
		ПроведениеРазрешено = Истина;
	КонецЕсли;
	
	Если ПроведениеРазрешено Тогда
		Возврат;
	КонецЕсли;	
	
	Ответственный = Пользователи.ТекущийПользователь();
	
	ДополнительныеСвойства.Вставить("ОтложеннаяЗапись", 			Истина);
	ДополнительныеСвойства.Вставить("НеРегестрироватьВзаиморасчеты",Истина);
	ДополнительныеСвойства.Вставить("ГруппаАбонентов",				Истина);
	ДополнительныеСвойства.Вставить("ПараметрыПроведения",			Новый Структура());
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
	
	Если ПометкаУдаления Тогда
		Для Каждого Набор Из Движения Цикл
			Набор.Записать();
		КонецЦикла;
	КонецЕсли;
	
	Если НЕ ПроведениеРазрешено и НЕ ЭтоНовый() Тогда
		РеквизитыОбъекты 			= ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка,"Организация,Район,МКД,Дата");
		Набор  						= РегистрыСведений.энргДокументыНачислений.СоздатьНаборЗаписей();
		Набор.Отбор.Организация.Установить(РеквизитыОбъекты.Организация);
		Набор.Отбор.ПериодНачисления.Установить(НачалоМесяца(РеквизитыОбъекты.Дата));
		Набор.Отбор.Район.Установить(РеквизитыОбъекты.Район);
		Набор.Отбор.ВидОперацийНачисления.Установить(Перечисления.энргВидыОперацийНачисления.Индивидуальные);
		Набор.Отбор.МКД.Установить(РеквизитыОбъекты.МКД);

		Набор.Прочитать();
		
		Если Набор.Количество() > 0 и Набор[0].ДокументНачисления = Ссылка Тогда
			Набор[0].ПометкаУдаления = ПометкаУдаления;
			Набор.Записать();
		КонецЕсли;		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

