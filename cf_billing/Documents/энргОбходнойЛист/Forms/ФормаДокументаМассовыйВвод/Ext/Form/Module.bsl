&НаСервере
Процедура ЗаполнитьПоказанияНаСервере(Результат)

	Выборка  									= Результат.выбрать();
	ТекКлючПомещения							= Неопределено;
	ТекТочкаУчета 								= Неопределено;
	ТекШкала 									= Неопределено;
	IDСтрокиТочки 								= Неопределено;
	IDСтрокиШкалы 								= Неопределено;
	Пока Выборка.следующий() Цикл 
		НоваяТочка = Ложь;
		Если Не ТекКлючПомещения = Выборка.КлючПомещения Или НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
			IDСтрокиТочки 						= Новый УникальныйИдентификатор;
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.КлючПомещения 		= Выборка.КлючПомещения;
			СтрокаТочкиУчета.Абонент 			= Выборка.Абонент;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
			СтрокаТочкиУчета.РегистрируетОбъем 	= Выборка.РегистрируетОбъем;
		КонецЕсли;
		
		Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
		КонецЕсли;

		СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
		СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона; 
		
		ТекКлючПомещения 						= Выборка.КлючПомещения;
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
	    ТекШкала 								= Выборка.Шкала
	КонецЦикла; 
	
	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Район); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Объект.Организация, Объект.Район,ТаблицаПоказанийДляЗаполнения,Объект.Дата,Истина);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета);
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ТочкиУчета");
	
	Объект.ТочкиУчета.Сортировать("Строение,Помещение");
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект,Объект,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета);
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеАбонентаСервер(КлючПомещения)
	// добавить абонента
	Результат 									= энргСостояниеПриборовУчета.ДействующиеПриборыУчетаПомещения(Объект.Дата,Объект.Организация,Объект.Район,КлючПомещения); 
	Выборка  									= Результат.выбрать();
	ТекТочкаУчета 								= Неопределено;
	ТекШкала 									= Неопределено;
	IDСтрокиТочки 								= Неопределено;
	IDСтрокиШкалы 								= Неопределено;
	Пока Выборка.следующий() цикл
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
			IDСтрокиТочки 						= Новый УникальныйИдентификатор;
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.КлючПомещения	 	= КлючПомещения;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
		КонецЕсли;
		
		Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
		КонецЕсли;

		СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
		СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;   						
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
	КонецЦикла; 
	
	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Район,КлючПомещения); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Объект.Организация,ТаблицаПоказанийДляЗаполнения,Объект.Дата);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета);
		
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект,Объект,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета);
	
КонецПроцедуры

&НаСервере
Функция ДанныеПоОтборуЕсть(ИмяРеквизита, ЗначениеРеквизита)
	Возврат Объект.ТочкиУчета.НайтиСтроки(Новый Структура(ИмяРеквизита, ЗначениеРеквизита)).Количество() > 0;
КонецФункции

&НаСервере
Процедура ОбновитьПериодНачисления()
	
	Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация, Объект.Район);
	ПоказанияПредоставляютсяВСрок();
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКоличествоСтрок(IDСтроки)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("IDСтроки", IDСтроки);
	НайденныеСтроки = Объект.ПоказанияПриборовУчета.НайтиСтроки(ПараметрыОтбора);
	
	Возврат НайденныеСтроки.Количество();
		
КонецФункции

#Область СервисПроверкиПоказанийПриборовУчета

&НаСервере
Процедура ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний()
	
	ТаблицаПриборов = энргРаботаСПоказаниямиПриборовУчетаСервер.НоваяТаблицаПриборовДляПроверки();
	Для Каждого ТекСтрока из Объект.ТочкиУчета Цикл
		НСтрока = ТаблицаПриборов.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, ТекСтрока);
		НСтрока.Район = Объект.Район;
	КонецЦикла;
	
	ПериодЗапроса = Новый Граница(Объект.Дата, ВидГраницы.Исключая);
	ВспомогательныеПараметры = энргРаботаСПоказаниямиПриборовУчетаСервер.НовыеВспомогательныеПараметрыПроверкиОтклоненияПоказаний();
	ВспомогательныеПараметры.ПоказанияВСрок = ПоказанияВСрок;
	ВспомогательныеПараметры.ПериодНачисления = Объект.ПериодНачисления;
	
	РезультатЗапроса = энргРаботаСПоказаниямиПриборовУчетаСервер.ПриборыДляОтклоненияПоказаний(ПериодЗапроса, Объект.Организация, ТаблицаПриборов, ВспомогательныеПараметры);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний(ЭтотОбъект, РезультатЗапроса);
	
КонецПроцедуры

&НаСервере
Процедура ПоказанияПредоставляютсяВСрок()
	ПоказанияВСрок = энргРаботаСПоказаниямиПриборовУчетаСервер.ПоказанияПредоставляютсяВСрок(Объект.ПериодНачисления, Объект.Дата, Объект.Организация, Объект.Район);
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтрокуСПоказаниями(ТекущиеДанныеТочкиУчета, ТекущиеДанные)
	РезультатПроверки = энргРаботаСПоказаниямиПриборовУчетаКлиент.ОпределитьСостояниеПоказанийПоСтроке(ТекущиеДанныеТочкиУчета.ПриборУчета, ЭтотОбъект, ТекущиеДанные);
	Если РезультатПроверки.СостояниеИзменено Тогда
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, РезультатПроверки);
		Возврат;
	КонецЕсли;
	
	энргРаботаСПоказаниямиПриборовУчетаКлиент.ПересчитатьСтрокуПриборовУчета(ТекущиеДанные, ТекущиеДанныеТочкиУчета.РегистрируетОбъем, Объект.Дата); 
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьДанныеАбонента(Команда)
	ОткрытьФормуПодбораАбонетов();
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуПодбораАбонетов(ФИО = "", ИдТекСтроки = Неопределено)
	
	Перем ОписаниеОповещения, Период, ТекПараметры;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьДанныеАбонентаЗавершение",ЭтаФорма);

	ТекПараметры = Новый Структура("Организация, Район, Строение, Контроллер, Маршрут, Период", 
					Объект.Организация,Объект.Район,Объект.Строение, Объект.Контроллер, Объект.Маршрут, Объект.Дата);
 	Если ИдТекСтроки <> Неопределено Тогда 
		ТекПараметры.Вставить("ФИО", ФИО);
		ТекПараметры.Вставить("ИдТекСтроки", ИдТекСтроки);
	КонецЕсли;
	ОткрытьФорму("Документ.энргОбходнойЛист.Форма.ФормаПоискаЛС",ТекПараметры, ЭтаФорма,,,, ОписаниеОповещения);

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоСтроению(Команда)
	
	КоличествоСтрокПоказанияПУДо = Объект.ПоказанияПриборовУчета.Количество();
	
	КоличествоСтрокТочкиУчетаДо = Объект.ТочкиУчета.Количество();
	
	ЗаполнитьАбонентовПоСтроениюНаСервере();
	
	КоличествоСтрокПоказанияПУПосле = Объект.ПоказанияПриборовУчета.Количество();
	
	КоличествоСтрокТочкиУчетаПосле = Объект.ТочкиУчета.Количество();
	
	КоличествоДобавленныхСтрокПУ = КоличествоСтрокПоказанияПУПосле - КоличествоСтрокПоказанияПУДо;
	
	КОличествоДобавленныхСтрокТУ = КоличествоСтрокТочкиУчетаПосле - КоличествоСтрокТочкиУчетаДо;
	
	Если ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаЕстьШкалыЕстьТарифныеЗоны");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоныТекущиеПоказания;
	ИначеЕсли НЕ ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаЕстьШкалыНетТарифныхЗон");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ШкалыПриборовУчетаЕстьШкалыНетТарифныхЗон");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаЕстьШкалыНетТарифныхЗонТекущиеПоказания;
	ИначеЕсли ИспользоватьТарифныеЗоны И НЕ ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалЕстьТарифныеЗоны");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоны");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоныТекущиеПоказания;
	Иначе	
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаНетШкалНетТарифныхЗонТекущиеПоказания;
	КонецЕсли;
	
	Если Объект.ТочкиУчета.Количество() > 0 И КОличествоДобавленныхСтрокТУ > 0 Тогда
		ИмяТаблицыТочкиУчета.ТекущаяСтрока = Объект.ТочкиУчета[Объект.ТочкиУчета.Количество() - КОличествоДобавленныхСтрокТУ].ПолучитьИдентификатор();
	КонецЕсли;

	
	Если Объект.ПоказанияПриборовУчета.Количество() > 0 И КоличествоДобавленныхСтрокПУ > 0 Тогда
		ИмяТаблицыПоказания.ТекущаяСтрока = Объект.ПоказанияПриборовУчета[Объект.ПоказанияПриборовУчета.Количество() - КоличествоДобавленныхСтрокПУ].ПолучитьИдентификатор();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАбонентовПоСтроениюНаСервере()

	РезультатЗапроса = Обработки.энргСостояниеПриборовУчетаМенеджер.ДействующиеПриборыУчетаПоМаршруту(Объект.Дата, Объект.Организация, Объект.Район, Неопределено, Объект.Строение, Истина); 
	ЗаполнитьПоказанияНаСервере(РезультатЗапроса);

КонецПроцедуры

#КонецОбласти

#Область СервисРаботыСМассовымВводом

&НаКлиенте
Процедура ДобавитьДанныеАбонентаЗавершение(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ТипЗнч(Результат) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Результат.Свойство("Абонент") Или НЕ Результат.Свойство("КлючПомещения") Тогда
		Возврат;
	КонецЕсли;
	
	
	// ищем строки по ключу помещения
	мСтроки  = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("КлючПомещения",Результат.КлючПомещения));
	Если НЕ мСтроки.Количество()  = 0 Тогда
		Ответ = Неопределено;
		
		ПоказатьВопрос(Новый ОписаниеОповещения("АнализОтветаНаДублированиеПоказаний", ЭтотОбъект, Новый Структура("мСтроки, Результат", мСтроки, Результат)), "По данному абоненту уже введены показания. Ввести ещё?", РежимДиалогаВопрос.ДаНет);
		
		Возврат;
		
		
	Иначе
		КлючРодителя = ПолучитьКлючПомещенияРодителя(Результат.КлючПомещения);
		Если ЗначениеЗаполнено(КлючРодителя) Тогда
			мСтроки  = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("КлючПомещения",КлючРодителя));
			Если НЕ мСтроки.Количество()  = 0 Тогда
				Ответ = Неопределено;
				
				ПоказатьВопрос(Новый ОписаниеОповещения("АнализОтветаНаДублированиеПоказаний", ЭтотОбъект, Новый Структура("мСтроки, Результат", мСтроки, Результат)), "По данному абоненту уже введены показания. Ввести ещё?", РежимДиалогаВопрос.ДаНет);
				
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	
	ДобавитьПУ_Абонента(Результат);
КонецПроцедуры

&НаКлиенте
Процедура АнализОтветаНаДублированиеПоказаний(РезультатВопроса, ДополнительныеПараметры1) Экспорт
	
	мСтроки = ДополнительныеПараметры1.мСтроки;
	Результат = ДополнительныеПараметры1.Результат;
	
	
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.Нет Тогда 
		Если ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
			ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны");		
		ИначеЕсли НЕ ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
			ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ШкалыПриборовУчетаЕстьШкалыНетТарифныхЗон");
		ИначеЕсли ИспользоватьТарифныеЗоны И НЕ ИспользоватьШкалыПриборовУчета Тогда
			ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоны");
		Иначе	
			ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		КонецЕсли;
		
		Если Объект.ТочкиУчета.Количество() > 0 Тогда
			ИмяТаблицыПоказания.ТекущаяСтрока = Объект.ПоказанияПриборовУчета[Объект.ПоказанияПриборовУчета.Количество() - 1].ПолучитьИдентификатор();
		КонецЕсли;
		
	Иначе
		
			ДобавитьПУ_Абонента(Результат);

		
	КонецЕсли;
	

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПУ_Абонента(Знач Результат)
	
	КоличествоСтрокПоказанияПУДо = Объект.ПоказанияПриборовУчета.Количество();
	
	ЗаполнитьДанныеПриборовУчета(Результат.Абонент, Результат.КлючПомещения);
	
	КоличествоСтрокПоказанияПУПосле = Объект.ПоказанияПриборовУчета.Количество();
	
	КОличествоДобавленныхСтрок = КоличествоСтрокПоказанияПУПосле - КоличествоСтрокПоказанияПУДо;
	
	Если ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаЕстьШкалыЕстьТарифныеЗоны");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоныТекущиеПоказания;
	ИначеЕсли НЕ ИспользоватьТарифныеЗоны И ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаЕстьШкалыНетТарифныхЗон");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ШкалыПриборовУчетаЕстьШкалыНетТарифныхЗон");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаЕстьШкалыНетТарифныхЗонТекущиеПоказания;
	ИначеЕсли ИспользоватьТарифныеЗоны И НЕ ИспользоватьШкалыПриборовУчета Тогда
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалЕстьТарифныеЗоны");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоны");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоныТекущиеПоказания;
	Иначе	
		ИмяТаблицыТочкиУчета = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		ИмяТаблицыПоказания = ЭтаФорма.Элементы.Найти("ТочкиУчетаНетШкалНетТарифныхЗон");
		ТекущийЭлемент = Элементы.ПоказанияПриборовУчетаНетШкалНетТарифныхЗонТекущиеПоказания;
	КонецЕсли;
	
	
	Если Объект.ТочкиУчета.Количество() > 0 И КОличествоДобавленныхСтрок > 0 Тогда
		ИмяТаблицыТочкиУчета.ТекущаяСтрока = Объект.ТочкиУчета[Объект.ТочкиУчета.Количество() - 1].ПолучитьИдентификатор();

		ИмяТаблицыПоказания.ТекущаяСтрока = Объект.ПоказанияПриборовУчета[Объект.ПоказанияПриборовУчета.Количество() - КОличествоДобавленныхСтрок].ПолучитьИдентификатор();
	КонецЕсли;
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеПриборовУчета(Абонент,КлючПомещения) 
	
	Результат 		= Обработки.энргСостояниеПриборовУчетаМенеджер.ДействующиеПриборыУчетаПомещения(Объект.Дата, Объект.Организация, Объект.Район, КлючПомещения, Неопределено, Истина, Новый Структура("ТолькоОткрытыеЛС", Истина)); 
	Выборка  		= Результат.выбрать();
	ТекТочкаУчета 	= Неопределено;
	ТекШкала 		= Неопределено;
	IDСтрокиТочки 	= Неопределено;
	IDСтрокиШкалы 	= Неопределено;
	Пока Выборка.Следующий() цикл

		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
			IDСтрокиТочки 						= Новый УникальныйИдентификатор;
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.Абонент 			= Абонент;
			СтрокаТочкиУчета.КлючПомещения 		= КлючПомещения;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
			СтрокаТочкиУчета.РегистрируетОбъем 	= Выборка.РегистрируетОбъем;
			
			энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыАбонента(Выборка.Абонент,СтрокаТочкиУчета);

		КонецЕсли;
		
		Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
		КонецЕсли;

		СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
		СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
		ТекШкала 								= Выборка.Шкала;
	КонецЦикла; 
	
	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Район); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Объект.Организация,Объект.Район,ТаблицаПоказанийДляЗаполнения,Объект.Дата);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета);
		
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, Объект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета); 
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКлючПомещенияРодителя(КлючПомещения)
	Если НЕ ЗначениеЗаполнено(КлючПомещения.Помещение.Родитель) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргКлючиПомещений.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	|ГДЕ
	|	энргКлючиПомещений.Строение = &Строение
	|	И энргКлючиПомещений.Помещение = &Помещение
	|	И НЕ энргКлючиПомещений.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Помещение", КлючПомещения.Помещение.Родитель);
	Запрос.УстановитьПараметр("Строение", КлючПомещения.Строение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

&НаКлиенте
Процедура ОчиститьТЧ(Команда)
	Если Объект.ТочкиУчета.Количество() > 0 Тогда
		ДопПараметры	= Новый Структура;
		ДопПараметры.Вставить("ТекущийОбъект", 	Объект);
		ДопПараметры.Вставить("ТЧ_Объекта",		Новый Структура("ТочкиУчета, ПоказанияПриборовУчета, ШкалыПриборовУчета"));
		ПроверкаОчисткиТЧ(ДопПараметры);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаОчисткиТЧ(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ПроверкаОчисткиТЧЗавершение",ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Очистить табличную часть?",РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаОчисткиТЧЗавершение(Результат,ДополнительныеПараметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если Результат = КодВозвратаДиалога.Да Тогда
		Модифицированность = Истина;
			
		Если ДополнительныеПараметры.Свойство("ТЧ_Объекта") Тогда
			Для каждого ТекТЧ Из ДополнительныеПараметры.ТЧ_Объекта Цикл
				Объект[ТекТЧ.Ключ].Очистить();
			КонецЦикла;
		КонецЕсли;
		
		энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(ДополнительныеПараметры.ТекущийОбъект, ДополнительныеПараметры.ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);

	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#КонецОбласти