#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("Организация") Тогда
		ТекОрганизация = Параметры.Организация;
	КонецЕсли;
	Если Параметры.Свойство("Район") Тогда
		ТекРайон = Параметры.Район;
	КонецЕсли;
	Если Параметры.Свойство("Строение") Тогда
		ТекСтроение = Параметры.Строение;
	КонецЕсли;
	Если Параметры.Свойство("Контроллер") Тогда
		ТекКонтроллер = Параметры.Контроллер;
	КонецЕсли;
	Если Параметры.Свойство("Маршрут") Тогда
		ТекМаршрут = Параметры.Маршрут;
	КонецЕсли;
	Параметры.Свойство("ФИО", ФИО);
	АвтоВыбор = Параметры.Свойство("ИдТекСтроки", ИдТекСтроки);
	
	Период = Неопределено;
	Параметры.Свойство("Период", Период);
	Период = ?(ЗначениеЗаполнено(Период), Период, ТекущаяДата());
	Абоненты.Параметры.УстановитьЗначениеПараметра("Период", Период);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьОтборВСпискеАбонентов();
	
	Если АвтоВыбор Тогда
		Элементы.ФИО.Видимость			  = Ложь;
		Элементы.ФИО_АвтоПодбор.Видимость = Истина;		

		Результат = ПолучитьДанныеПоСписку();
		Если Результат <> 0 Тогда
			//Отказ = Истина;
			//Оповестить("НайденЛС", Результат);
			ОповеститьОВыборе(Результат);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Закрыть(Новый Структура("Абонент,КлючПомещения",ВыбранноеЗначение.Абонент,ВыбранноеЗначение.КлючПомещения));
КонецПроцедуры

&НаКлиенте
Процедура АбонентыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)	
	Закрыть(Новый Структура("Абонент,КлючПомещения, ИдТекСтроки",ВыбраннаяСтрока.Абонент,ВыбраннаяСтрока.КлючПомещения, ИдТекСтроки));
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

&НаКлиенте
Процедура Выбрать(Команда)
	
	ТекущиеДанные = Элементы.Абоненты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Закрыть(Новый Структура("Абонент,КлючПомещения, ИдТекСтроки",ТекущиеДанные.Абонент,ТекущиеДанные.КлючПомещения, ИдТекСтроки));
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьОтборы(Команда)
	ФИО 		= "";
	Город 		= "";
	Улица 		= "";
	НомерДома 	= "";
	Помещение 	= "";
	Строение 	= "";
	
	ЭтаФорма.Элементы.ФИО.ОбновитьТекстРедактирования();
	ЭтаФорма.Элементы.Строение.ОбновитьТекстРедактирования();
	ЭтаФорма.Элементы.Помещение.ОбновитьТекстРедактирования();

	УстановитьОтборВСпискеАбонентов();
КонецПроцедуры

&НаКлиенте
Процедура ФормаЗакрыть(Команда)
	Закрыть();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьОтборВСпискеАбонентов()
		
	Абоненты.Отбор.Элементы.Очистить();
	
	отборЭтоГруппа 								=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	отборЭтоГруппа.ЛевоеЗначение 				= Новый ПолеКомпоновкиДанных("ЭтоГруппа");
	отборЭтоГруппа.ПравоеЗначение 				= Ложь;
	отборЭтоГруппа.ВидСравнения 				= ВидСравненияКомпоновкиДанных.Равно;
	
	отборЭтоГруппа 								=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	отборЭтоГруппа.ЛевоеЗначение 				= Новый ПолеКомпоновкиДанных("Организация");
	отборЭтоГруппа.ПравоеЗначение 				= ТекОрганизация;
	отборЭтоГруппа.ВидСравнения 				= ВидСравненияКомпоновкиДанных.Равно;	
	
	Если ЗначениеЗаполнено(ТекСтроение) Тогда
		отборЭтоГруппа 							=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		отборЭтоГруппа.ЛевоеЗначение 			= Новый ПолеКомпоновкиДанных("Строение");
		отборЭтоГруппа.ПравоеЗначение 			= ТекСтроение;
		отборЭтоГруппа.ВидСравнения 			= ВидСравненияКомпоновкиДанных.Равно;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекРайон) Тогда 
		отборЭтоГруппа 							=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		отборЭтоГруппа.ЛевоеЗначение 			= Новый ПолеКомпоновкиДанных("Район");
		отборЭтоГруппа.ПравоеЗначение 			= ТекРайон;
		отборЭтоГруппа.ВидСравнения 			= ВидСравненияКомпоновкиДанных.Равно;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ФИО) тогда
		ЭтоЛС 									= СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Лев(ФИО,3),Истина,Истина); 
		Если ЭтоЛС тогда		
			ОтборГруппа  						= Абоненты.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
			ОтборГруппа.ТипГруппы 				= ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
			
			ОтборЛС  							= ОтборГруппа.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборЛС.ЛевоеЗначение 				= Новый ПолеКомпоновкиДанных("ЛицевойСчет");
			ОтборЛС.ПравоеЗначение 				= ФИО;
			ОтборЛС.ВидСравнения 				= ВидСравненияКомпоновкиДанных.Содержит;		
			
			ОтборстарыйЛС  						= ОтборГруппа.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборстарыйЛС.ЛевоеЗначение 		= Новый ПолеКомпоновкиДанных("СтарыйЛС");
			ОтборстарыйЛС.ПравоеЗначение 		= ФИО;
			ОтборстарыйЛС.ВидСравнения 			= ВидСравненияКомпоновкиДанных.Содержит; 		
		иначе
			ОтборНаименование 					=  Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборНаименование.ЛевоеЗначение 	= Новый ПолеКомпоновкиДанных("Наименование");
			ОтборНаименование.ПравоеЗначение	= ФИО;
			ОтборНаименование.ВидСравнения 		= ВидСравненияКомпоновкиДанных.Содержит;
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(Строение) тогда		
			ОтборАдрес 							= Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборАдрес.ЛевоеЗначение 			= Новый ПолеКомпоновкиДанных("СтроениеНаименование");
			ОтборАдрес.ПравоеЗначение			= Строение;
			ОтборАдрес.ВидСравнения 			= ВидСравненияКомпоновкиДанных.Содержит;		
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Помещение) тогда		
		ОтборАдрес 							= Абоненты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборАдрес.ЛевоеЗначение 			= Новый ПолеКомпоновкиДанных("Помещение");
		ОтборАдрес.ПравоеЗначение			= Помещение;
		ОтборАдрес.ВидСравнения 			= ВидСравненияКомпоновкиДанных.Равно;	
	КонецЕсли;		
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеПоСписку()

	Схема = Элементы.Абоненты.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	Настройки = Элементы.Абоненты.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных();
	МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, Настройки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	Результат = ПроцессорВывода.Вывести(ПроцессорКомпоновки);

	Если Результат.Количество() = 0 Тогда
	
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден лицевой счёт.");
		Возврат Неопределено;
	ИначеЕсли Результат.Количество() = 1 Тогда
		Возврат Новый Структура("Абонент,КлючПомещения, ИдТекСтроки", Результат[0].Абонент, Результат[0].Абонент.КлючПомещения, ИдТекСтроки);
	Иначе
		Возврат 0;
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ОбновитьОтбор(Элемент)
	УстановитьОтборВСпискеАбонентов();
КонецПроцедуры

#КонецОбласти