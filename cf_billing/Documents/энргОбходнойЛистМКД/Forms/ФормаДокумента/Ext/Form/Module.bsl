	             	 |	энргМаршрутыКонтроллеровАдресаМаршрута.Ссылка = &Маршрут
	             	 |;
	             	 |
	             	 |////////////////////////////////////////////////////////////////////////////////
	             	 |ВЫБРАТЬ
	             	 |	энргМногоквартирныеДомаКонтактнаяИнформация.Ссылка КАК Ссылка,
	             	 |	энргМногоквартирныеДомаКонтактнаяИнформация.Представление КАК Представление
	             	 |ПОМЕСТИТЬ АдресаМКД
	             	 |ИЗ
	             	 |	Справочник.энргСтроения.КонтактнаяИнформация КАК энргМногоквартирныеДомаКонтактнаяИнформация
	             	 |;
	             	 |
	             	 |////////////////////////////////////////////////////////////////////////////////
	             	 |ВЫБРАТЬ
	             	 |	АдресаМКД.Ссылка КАК МКД,
	             	 |	АдресаМКД.Представление КАК АдресМКД
	             	 |ПОМЕСТИТЬ втМКД
	             	 |ИЗ
	             	 |	СписокАдресов КАК СписокАдресов
	             	 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АдресаМКД КАК АдресаМКД
	             	 |		ПО (АдресаМКД.Представление ПОДОБНО СписокАдресов.Представление + ""%"")";
	Результат  = Запрос.Выполнить();	
