#Область СлужебныеПроцедурыИФункции

Процедура УстановитьСвязиПараметровВыбораТаблицыВидыБлагоустройстваТарифныеКатегории()
		
	мЭлементыФорм 							= Новый Массив;
	мЭлементыФорм.Добавить(Элементы.ВидыБлагоустройстваТарифныеКатегорииВидБлагоустройстваИндивидуальный);
	мЭлементыФорм.Добавить(Элементы.ВидыБлагоустройстваТарифныеКатегорииТарифнаяКатегория);
	Для ИндексЭлемента = 0 По мЭлементыФорм.ВГраница() Цикл
		ЭлементФормы 						= мЭлементыФорм[ИндексЭлемента];
		ТекущиеСвязиПараметровВыбора 		= ЭлементФормы.СвязиПараметровВыбора;
		Связи 								= Новый Массив;
		ИмяТаблицыТочекУчета 				= "ТочкиУчета" + ПрефиксТочекУчета; 
		Для Индекс = 0 По ТекущиеСвязиПараметровВыбора.ВГраница() Цикл
			Если ТекущиеСвязиПараметровВыбора[Индекс].Имя = "ДополнительныеСвойства.Услуга" Тогда
				ПутьКДанным 				= "Элементы." + ИмяТаблицыТочекУчета + ".ТекущиеДанные.Услуга";
				Связь 						= Новый СвязьПараметраВыбора("ДополнительныеСвойства.Услуга",ПутьКДанным,РежимИзмененияСвязанногоЗначения.НеИзменять);
			Иначе
				Связь 						= ТекущиеСвязиПараметровВыбора[Индекс];
			КонецЕсли;
			Связи.Добавить(Связь);
		КонецЦикла;	
		СвязиПараметровВыбора 				= Новый ФиксированныйМассив(Связи);	
		ЭлементФормы.СвязиПараметровВыбора 	= СвязиПараметровВыбора;
	КонецЦикла;
	
КонецПроцедуры

