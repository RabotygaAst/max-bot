&НаСервере
Процедура ЗаполнитьДанныеКлючаПомещения(Знач ДанныеПомещенияРезультат)
	
	Перем ДанныеПомещенияВыборка;
	
	Если Не ДанныеПомещенияРезультат.Пустой() Тогда
		ДанныеПомещенияВыборка  = ДанныеПомещенияРезультат.Выбрать();
		ДанныеПомещенияВыборка.Следующий();
		ЗаполнитьЗначенияСвойств(ЭтаФорма,ДанныеПомещенияВыборка,"Строение,Помещение,ЧастныйСектор");
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииСервер()
	ЗаполнитьПериодНачисления();
	ПерезаполнитьКатегории();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПериодНачисления() 
	
	Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваФормыПоКлючуПомещения()
	Если ЗначениеЗаполнено(Объект.КлючПомещения) Тогда 			
		ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(Объект.КлючПомещения);
		ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);
		
		Если Не ЗначениеЗаполнено(Объект.Район) Тогда
			ОписаниеСтроения 		= Обработки.энргСтроенияМенеджер.ЗначенияСвойствОбъекта(Строение, "Район");			
			Объект.Район 			= ОписаниеСтроения.Район;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваТочекУчета(Знач ТекущийОбъект)
	
	ПолучаемыеСвойстваТочекУчета 	= ПолучаемыеСвойстваТочекУчета();
	мТочкиУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.ТочкиУчета.Выгрузить().ВыгрузитьКолонку("ТочкаУчета"));	
	СвойстваТочекУчета 				= Обработки.энргТочкиУчетаМенеджер.ЗначенияРеквизитовОбъектов(мТочкиУчета, ПолучаемыеСвойстваТочекУчета);
	ЗаполнитьДанныеФормыПоСвойствамТочекУчета(Объект.ТочкиУчета, СвойстваТочекУчета);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеФормыПоСвойствамТочекУчета(Коллекция, СвойстваТочекУчета)
	
	СоотвествиеРеквизитовСвойств 								= СоотвествиеРеквизитовСвойствамТочкиУчета();
	
	Для Каждого СтрокаКоллекции Из Коллекция Цикл
		
		Если ЗначениеЗаполнено(СтрокаКоллекции.ТочкаУчета) Тогда
			СвойстваТочкиУчета 									= СвойстваТочекУчета[СтрокаКоллекции.ТочкаУчета];		
		Иначе
			СвойстваТочкиУчета 									= Обработки.энргТочкиУчетаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(СтрокаКоллекции.ОписаниеТочки);
		КонецЕсли; 
		
		Если СвойстваТочкиУчета = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого КлючЗначение Из СоотвествиеРеквизитовСвойств Цикл
			Если СвойстваТочкиУчета.Свойство(КлючЗначение.Значение) Тогда
				СтрокаКоллекции[КлючЗначение.Ключ] 	= СвойстваТочкиУчета[КлючЗначение.Значение];
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваПриборовУчета(Знач ТекущийОбъект)
	
	Перем мПриборыУчета, ПолучаемыеСвойстваПриборовУчета, СвойстваПриборовУчета;
	       	
	ПолучаемыеСвойстваПриборовУчета = ПолучаемыеСвойстваПриборовУчета();	
	мПриборыУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.ТочкиУчета.Выгрузить().ВыгрузитьКолонку("ПриборУчета"));
	СвойстваПриборовУчета 			= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектов(мПриборыУчета, ПолучаемыеСвойстваПриборовУчета);
	ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Объект.ТочкиУчета,СвойстваПриборовУчета);
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваИзмерителей(Знач ТекущийОбъект)
	
	Перем мПриборыУчета, ПолучаемыеСвойстваПриборовУчета, СвойстваПриборовУчета;
	       	
	ПолучаемыеСвойстваПриборовУчета = ПолучаемыеСвойстваПриборовУчета();	
	мПриборыУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.Измерители.Выгрузить().ВыгрузитьКолонку("ПриборУчета"));
	СвойстваПриборовУчета 			= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектов(мПриборыУчета, ПолучаемыеСвойстваПриборовУчета);
	ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Объект.Измерители, СвойстваПриборовУчета);
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Коллекция,СвойстваПриборовУчета) 
	
	СоотвествиеРеквизитовСвойств 								= СоотвествиеРеквизитовСвойствамПрибораУчета();
	
	Для Каждого СтрокаКоллекции Из Коллекция Цикл
		
		Если ЗначениеЗаполнено(СтрокаКоллекции.ПриборУчета) Тогда
			СвойстваПрибора 									= СвойстваПриборовУчета[СтрокаКоллекции.ПриборУчета];		
		Иначе
			СвойстваПрибора 									= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(СтрокаКоллекции.ОписаниеПрибора);
		КонецЕсли;
			
		Если СвойстваПрибора = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого КлючЗначение Из СоотвествиеРеквизитовСвойств Цикл
			Если СтрокаКоллекции.Свойство(КлючЗначение.Ключ) И СвойстваПрибора.Свойство(КлючЗначение.Значение) Тогда
				СтрокаКоллекции[КлючЗначение.Ключ] 	= СвойстваПрибора[КлючЗначение.Значение];
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла; 	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваАбонента(АбонентСсылка, ОписаниеАбонента)
	перем ЗначенияРеквизитов;
	
	ПолучаемыеСвойстваАбонента  = "Контрагент,ВидОбъекта,МуниципальноеОбразование,Филиал";
	Если ЗначениеЗаполнено(АбонентСсылка) Тогда
		ЗначенияРеквизитов 		= Обработки.энргАбонентыМенеджер.ЗначенияРеквизитовОбъекта(АбонентСсылка,ПолучаемыеСвойстваАбонента);		
	ИначеЕсли НЕ ПустаяСтрока(ОписаниеАбонента) Тогда
		ЗначенияРеквизитов 		= Обработки.энргАбонентыМенеджер.ЗначенияРеквизитовИзСтрокиJSON(ОписаниеАбонента,ПолучаемыеСвойстваАбонента);
	КонецЕсли;
	
	Если ЗначенияРеквизитов = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ФизЛицо 					= ЗначенияРеквизитов.Контрагент;
	ВидОбъекта 					= ЗначенияРеквизитов.ВидОбъекта;
	МуниципальноеОбразование 	= ЗначенияРеквизитов.МуниципальноеОбразование;
	Филиал 						= ЗначенияРеквизитов.Филиал;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваФормыПоДоговору() 
	
	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		ПолучаемыеРеквизитыДоговора = "Контрагент,Филиал";
		ЗначениеРеквизитовДоговора 	= Обработки.энргДоговорыКонтрагентовМенеджер.ЗначенияСвойствОбъекта(Объект.Договор, ПолучаемыеРеквизитыДоговора);
		ЭтаФорма.ФизЛицо 			= ЗначениеРеквизитовДоговора.Контрагент;
		ЭтаФорма.Филиал				= ЗначениеРеквизитовДоговора.Филиал;
	Иначе
		Если Параметры.ЗначенияЗаполнения.Свойство("Контрагент") Тогда
			ЭтаФорма.ФизЛицо 		= Параметры.ЗначенияЗаполнения.Контрагент;
		КонецЕсли;
		
		Если Параметры.ЗначенияЗаполнения.Свойство("Филиал") Тогда
			ЭтаФорма.Филиал 		= Параметры.ЗначенияЗаполнения.Филиал;
		КонецЕсли;		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ЕстьОшибкиЗаполнения(РежимЗаписи)
	
	ЕстьОшибкиЗаполнения = Ложь;
	
	ТаблицаЖильцов 		= Объект.Жильцы;
	КолвоПрописанных 	= Объект.КоличествоПрописанных;
	ЭтоПроведение		= РежимЗаписи = РежимЗаписиДокумента.Проведение;
	Если ЭтоПроведение Тогда
		
		Если НЕ ЗначениеЗаполнено(Филиал) Тогда
			
			ЕстьОшибкиЗаполнения = Истина; 			
			ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Поле ""Абонентский отдел"" не заполнено'"),,
			"Филиал");
			
		КонецЕсли; 
		
		Если ПомещениеНеЗаполненоМКД(Строение, Помещение) Тогда
			ЕстьОшибкиЗаполнения = Истина;
		КонецЕсли;
		
	КонецЕсли;	
	
	Если ЭтоПроведение И ПроверитьКоличествоЖильцов(ТаблицаЖильцов, КолвоПрописанных) Тогда
		ПоказатьОповещениеПользователя("Количество прописанных не соответствует количеству жильцов"); 		
	КонецЕсли;
	
	Если не ЗначениеЗаполнено(Объект.Контроллер) Тогда 
		ЕстьОшибкиЗаполнения = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Поле «Контроллер» не заполнено");
	КонецЕсли;
	
	Если не ЗначениеЗаполнено(Объект.МаршрутКонтроллера) Тогда 
		ЕстьОшибкиЗаполнения = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Поле «Маршрут контроллера» не заполнено");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ТочкиУчета) Тогда 
		ЕстьОшибкиЗаполнения = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните точки учета");
	КонецЕсли;
	
	Если НАЧАЛОМЕСЯЦА(Объект.Дата) = НАЧАЛОМЕСЯЦА(Объект.ДатаФактическогоСобытия) Тогда
		ЕстьОшибкиЗаполнения = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Фактическая и текущая дата не могут находиться в одном периоде");
		Объект.ДатаФактическогоСобытия = Дата(1,1,1);
	КонецЕсли;

	Возврат ЕстьОшибкиЗаполнения;
	
КонецФункции 

&НаСервереБезКонтекста
Функция ПомещениеНеЗаполненоМКД(Строение, Помещение)
	Результат = Ложь;
	СтроениеДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строение, "ТипСтроения");
	Если СтроениеДокумента = Перечисления.энргТипыСтроений.МКД И НЕ ЗначениеЗаполнено(Помещение) Тогда
		
		Результат = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо указать помещение!");
		
	КонецЕсли;                                                                             
	
	Возврат Результат;	
КонецФункции

&НаСервере
Функция СоотвествиеРеквизитовСвойствамПрибораУчета()
	Возврат энргРаботаСприборамиУчетаСервер.СоотвествиеРеквизитовСвойствамПрибораУчета();
КонецФункции

&НаСервере
Функция СоотвествиеРеквизитовСвойствамТочкиУчета()
	Возврат Новый Структура("НаименованиеТочки,Расположение,Головная","Наименование","Расположение","Головная");
КонецФункции

&НаСервере
Функция ПолучаемыеСвойстваПриборовУчета()
	Возврат энргРаботаСприборамиУчетаСервер.ПолучаемыеСвойстваПриборовУчета();
КонецФункции

&НаСервере
Функция ПолучаемыеСвойстваТочекУчета() 
	ПолучаемыеСвойстваТочекУчета 	= "
	|Наименование,Расположение,Головная";	
	Возврат ПолучаемыеСвойстваТочекУчета;
КонецФункции

&НаСервере
Процедура ЗаписатьПараметрыТочекИПриборовУчета(ТекущийОбъект, СоответствиеСтрок)
	
	Сч 														= 0;
	Для Каждого СтрокаТочки Из Объект.ТочкиУчета Цикл
		ЗаписываемаяСтрока  								= ТекущийОбъект.ТочкиУчета[Сч];
		
		ДанныеТочкиУчета 									= Новый Структура(ПолучаемыеСвойстваТочекУчета());
		СоотвествиеРеквизитов 								= СоотвествиеРеквизитовСвойствамТочкиУчета(); 		
		Для Каждого КлючЗначение Из СоотвествиеРеквизитов Цикл			
			ДанныеТочкиУчета[КлючЗначение.Значение] 		= СтрокаТочки[КлючЗначение.Ключ];			
		КонецЦикла; 		
		ЗаписываемаяСтрока.ОписаниеТочки 					= Обработки.энргТочкиУчетаМенеджер.ЗначенияРеквизитовОбъектаВСтрокуJSON(ДанныеТочкиУчета);			
				
		СвойстваПрибора 									= ПолучаемыеСвойстваПриборовУчета();
		ДанныеПрибораУчета 									= Новый Структура(СвойстваПрибора);
		СоотвествиеРеквизитов 								= СоотвествиеРеквизитовСвойствамПрибораУчета();
		Для Каждого КлючЗначение Из СоотвествиеРеквизитов Цикл
			Если НЕ СтрокаТочки.Свойство(КлючЗначение.Ключ) Тогда
				Продолжить;
			КонецЕсли;
			
			ДанныеПрибораУчета[КлючЗначение.Значение] 		= СтрокаТочки[КлючЗначение.Ключ];						
		КонецЦикла;
		ЗаписываемаяСтрока.ОписаниеПрибора 					= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектаВСтрокуJSON(ДанныеПрибораУчета);
		
		СоответствиеСтрок.Вставить(СтрокаТочки.IDСтроки, СтрокаТочки.ЗаводскойНомер);
		Сч 													= Сч + 1;		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеАбонента(Знач ТекущийОбъект)
	
	Перем ОписаниеОбъектаАбонент, ЭтоНовыйАбонент;
	
	ОписаниеОбъектаАбонент 							= Обработки.энргАбонентыМенеджер.ОписаниеОбъекта();
	ОписаниеОбъектаАбонент.Организация 				= ТекущийОбъект.Организация;		
	ОписаниеОбъектаАбонент.Район 					= ТекущийОбъект.Район;
	ОписаниеОбъектаАбонент.КлючПомещения 			= ТекущийОбъект.КлючПомещения;
	ОписаниеОбъектаАбонент.ФизЛицо 					= ФизЛицо;
	ОписаниеОбъектаАбонент.ГруппаАбонента 			= ТекущийОбъект.ГруппаАбонента;
	ОписаниеОбъектаАбонент.ВидОбъекта 				= ВидОбъекта;
	ОписаниеОбъектаАбонент.СтарыйЛС 				= ТекущийОбъект.СтарыйЛС;
	ОписаниеОбъектаАбонент.Филиал 					= Филиал;
	ОписаниеОбъектаАбонент.МуниципальноеОбразование = МуниципальноеОбразование;
	ОписаниеОбъектаАбонент.Ссылка 					= ТекущийОбъект.Абонент;
	ОписаниеОбъектаАбонент.Поставщик				= ТекущийОбъект.Поставщик;
	
	ЭтоНовыйАбонент 								= Ложь;
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ЭтоНовыйАбонент") Тогда
		ЭтоНовыйАбонент 							= ТекущийОбъект.ДополнительныеСвойства.ЭтоНовыйАбонент;
	КонецЕсли;
	
	Обработки.энргАбонентыМенеджер.ЗаполнитьОбъектПоОписанию(ОписаниеОбъектаАбонент, ЭтоНовыйАбонент, ТекущийОбъект.Дата);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеТочкиВСтроке(Отказ,Знач НовыеТочкиУчета, Знач ТочкаУчета, Знач ОписаниеТочки, Знач НомерСтроки)
		
	ЭтоНоваяТочка 										= НЕ НовыеТочкиУчета.Найти(НомерСтроки) = Неопределено;			
	ОписаниеОбъектаТочкиУчета 							= Обработки.энргТочкиУчетаМенеджер.ОписаниеОбъекта();
	ЗначенияРеквизитовТочкиУчета						= Обработки.энргТочкиУчетаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(ОписаниеТочки);
	Для Каждого КлючЗначение Из ЗначенияРеквизитовТочкиУчета Цикл
		Если ОписаниеОбъектаТочкиУчета.Свойство(КлючЗначение.Ключ) Тогда
			ОписаниеОбъектаТочкиУчета[КлючЗначение.Ключ] = КлючЗначение.Значение;
		КонецЕсли;				
	КонецЦикла;
	ОписаниеОбъектаТочкиУчета.Ссылка 					= ТочкаУчета;
	Если НЕ Обработки.энргТочкиУчетаМенеджер.УдалосьЗаполнитьОбъектПоОписанию(ОписаниеОбъектаТочкиУчета,ЭтоНоваяТочка) Тогда
		Отказ											= Истина;
	КонецЕсли; 	

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,Знач НовыеПриборыУчета, Знач ПриборУчета, Знач ОписаниеПрибора, Знач НомерСтроки)
		
	ЭтоНовыйПриборУчета									= НЕ НовыеПриборыУчета.Найти(НомерСтроки) = Неопределено;			
	ОписаниеОбъектаПриборУчета 							= Обработки.энргПриборыУчетаАбонентаМенеджер.ОписаниеОбъекта();
	ЗначенияРеквизитовПриборУчета						= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(ОписаниеПрибора);
	Для Каждого КлючЗначение Из ЗначенияРеквизитовПриборУчета Цикл
		Если ОписаниеОбъектаПриборУчета.Свойство(КлючЗначение.Ключ) Тогда
			ОписаниеОбъектаПриборУчета[КлючЗначение.Ключ] = КлючЗначение.Значение;
		КонецЕсли;				
	КонецЦикла;
	ОписаниеОбъектаПриборУчета.Ссылка 					= ПриборУчета;
	Если Не Обработки.энргПриборыУчетаАбонентаМенеджер.УдалосьЗаполнитьОбъектПоОписанию(ОписаниеОбъектаПриборУчета,ЭтоНовыйПриборУчета) Тогда
		Отказ											= Истина;
	КонецЕсли;	

КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрВыбораПомещения()
	ДоступныеТипыПомещений = Новый Массив;
	ДоступныеТипыПомещений.Добавить(Перечисления.энргТипыПомещений.Квартира);
	ДоступныеТипыПомещений.Добавить(Перечисления.энргТипыПомещений.Комната);	
	
	МассивПараметров 	= Новый Массив;
    НовыйПараметр 		= Новый ПараметрВыбора("Отбор.ТипПомещения", ДоступныеТипыПомещений);
    МассивПараметров.Добавить(НовыйПараметр);
	ЗначениеСвойства = Новый ФиксированныйМассив(МассивПараметров);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Помещение", "ПараметрыВыбора", ЗначениеСвойства);   
КонецПроцедуры

&НаСервере
Процедура УстановитьТехВозможностьОРП()
	
	РС = РегистрыСведений.энргТехническаяВозможностьОРП;
	РезультатЗапроса = РС.ПолучитьВозможностьОРП(Строение, Помещение);
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда 
		ТекТехническаяВозможностьПроведенияОРП = Выборка.ЕстьВозможность;
	Иначе
		ТекТехническаяВозможностьПроведенияОРП = Ложь;
	КонецЕсли;
	
	Если ТекТехническаяВозможностьПроведенияОРП <> ТехническаяВозможностьПроведенияОРП Тогда
		РС.УстановитьВозможностьОРП(Строение, Помещение, Истина);
	КонецЕсли;
	
КонецПроцедуры

