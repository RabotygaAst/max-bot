	Для Каждого Строка Из Строки Цикл 		
		СтрокаТочки  						= Объект.ТочкиУчета.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТочки, Строка);
		Если Не Родитель = Неопределено Тогда
			СтрокаТочки.IDСтрокиРодитель	= Родитель;			
		КонецЕсли;
		ЗаполнитьТочкиНаОснованииДереваУслуг(Строка.ПолучитьЭлементы(), Строка.IDСтроки);
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные)
	ДопПараметры = Новый Структура("ЭтоВводПУ,НеРегистрацияОбъема",Истина,Истина);
	энргРаботаСПриборамиУчетаКлиент.РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные.РегистрируетОбъем,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета,ЭтаФорма,ДопПараметры);
КонецПроцедуры

&НаСервере
Процедура ОбновитьНаправленияИспользованияТУ(IDСтроки,РодительскийЭлемент)
	
	Справочники.энргНаправлениеИспользованияТочекУчета.ОбновитьТЧЗначенияИзмерителей(Объект.ЗначенияИзмерителей,IDСтроки,РодительскийЭлемент,Истина);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоУслугНаОснованииТочекУчета(ТекущийОбъект, СтрокаРодитель, Родитель = Неопределено, ЗаполнятьТекстыГиперссылок = Истина)
	
	Если Родитель = Неопределено Тогда
		ОписаниеТипа  		= Новый ОписаниеТипов("УникальныйИдентификатор");	
		Родитель 			= ОписаниеТипа.ПривестиЗначение();
	КонецЕсли;
	
	Вершины 				= ТекущийОбъект.ТочкиУчета.НайтиСтроки(Новый Структура("IDСтрокиРодитель", Родитель));
	Строки  				= СтрокаРодитель.ПолучитьЭлементы();
		
	Для Сч = 0 По Вершины.ВГраница() Цикл
		Если ЗначениеЗаполнено(Вершины[Сч].IDСтроки) Тогда
			СтрокаДерева  	= Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДерева, Вершины[Сч]);
			
			Если ЗаполнятьТекстыГиперссылок Тогда
				СтрокаДерева.ДанныеУслуги 			= энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстДанныеУслуги(СтрокаДерева);
				СтрокаДерева.ДанныеРасположения 	= энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстДанныеРасположения(СтрокаДерева);
				СтрокаДерева.ТехническиеСвойстваТУ	= энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстТехническихСвойств(СтрокаДерева, Объект.Потери.НайтиСтроки(Новый Структура("IDСтроки", СтрокаДерева.IDСтроки)));
				
				ДанныеИзмерителей = Новый Структура("Измерители", Объект.Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", СтрокаДерева.IDСтроки)));
				энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстСредствИзмерений(СтрокаДерева, ДанныеИзмерителей);
			КонецЕсли;
			
			ЗаполнитьДеревоУслугНаОснованииТочекУчета(ТекущийОбъект, СтрокаДерева, Вершины[Сч].IDСтроки, ЗаполнятьТекстыГиперссылок);
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЧНаОснованииСтроения(ТипСтроения)
	
	Если Не ТипСтроения = Перечисления.энргТипыСтроений.МКД Тогда
		Возврат;
	КонецЕсли;
	Объект.ТочкиУчета.Очистить();
	Объект.ВидыБлагоустройстваТарифныеКатегории.Очистить();
	ЗаполнитьУслугиПомещенияПоУслугамМКД();
	ЗаполнитьВидыБлагоустройстваТарифныеКатегорииНаОснованииУслугСтроения();		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьУслугиПомещенияПоУслугамМКД()
	ПолучаемыеСвойства 								= "СтруктураСети";
	РезультатЗапроса  								= Обработки.энргСостояниеУслугСтроенийМенеджер.ДействующиеУслугиСтроения(Объект.Организация,Объект.Район,Строение,ПолучаемыеСвойства);
	тзУслугиСтроений								= РезультатЗапроса.Выгрузить();
	тзУслугиСтроений.Свернуть("СоставнаяУслуга,Услуга,Поставщик,СтруктураСети");
	тзУслугиСтроений.Сортировать("СоставнаяУслуга");
	текСоставнаяУслуга 								= Неопределено;
	Для Каждого УслугаСтроения Из тзУслугиСтроений Цикл
		Если НЕ текСоставнаяУслуга = УслугаСтроения.СоставнаяУслуга
			ИЛИ НЕ ЗначениеЗаполнено(УслугаСтроения.СоставнаяУслуга) Тогда
			НоваяСтрокаТочки						= Объект.ТочкиУчета.Добавить();
			НоваяСтрокаТочки.IDСтроки 				= Новый УникальныйИдентификатор;
			НоваяСтрокаТочки.Услуга 				= ?(ЗначениеЗаполнено(УслугаСтроения.СоставнаяУслуга),УслугаСтроения.СоставнаяУслуга,УслугаСтроения.Услуга);
			НоваяСтрокаТочки.ЭтоСоставнаяУслуга		= ЗначениеЗаполнено(УслугаСтроения.СоставнаяУслуга);
			НоваяСтрокаТочки.СтруктураСети			= УслугаСтроения.СтруктураСети;
		КонецЕсли;
		
		Если НоваяСтрокаТочки.ЭтоСоставнаяУслуга Тогда
			СтрокаПоствщика 						= Объект.ПоставщикиСоставныхУслуг.Добавить();
			СтрокаПоствщика.IDСтроки 				= НоваяСтрокаТочки.IDСтроки;
			СтрокаПоствщика.ЧастьСоставнойУслуги 	= УслугаСтроения.Услуга;
			СтрокаПоствщика.Поставщик 				= УслугаСтроения.Поставщик;
		Иначе
			НоваяСтрокаТочки.Поставщик 				= УслугаСтроения.Поставщик;
		КонецЕсли;
		
		текСоставнаяУслуга 							= УслугаСтроения.СоставнаяУслуга;
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВидыБлагоустройстваТарифныеКатегорииНаОснованииУслугСтроения()
		
	мУслуги 											= Новый Массив;
	Для Каждого СтрокаТочкиУчета Из Объект.ТочкиУчета Цикл
		Если СтрокаТочкиУчета.ЭтоСоставнаяУслуга Тогда
			Продолжить;
		КонецЕсли;		
		мУслуги.Добавить(СтрокаТочкиУчета.Услуга);		
	КонецЦикла;
	
	Для Каждого СтрокаТочкиУчета Из Объект.ПоставщикиСоставныхУслуг Цикл
		мУслуги.Добавить(СтрокаТочкиУчета.ЧастьСоставнойУслуги);		
	КонецЦикла;
	
	мУникальныеУслуги 									= ОбщегоНазначенияКлиентСервер.СвернутьМассив(мУслуги);
	ВидыБлагоустройстваТарифныеКатегорииСтроения 		= Обработки.энргСтроенияМенеджер.ВидыБлагоустройстваТарифныеКатегорииСтроения(Строение,мУникальныеУслуги);
	Выборка 											= ВидыБлагоустройстваТарифныеКатегорииСтроения.Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока 									= Объект.ВидыБлагоустройстваТарифныеКатегории.Добавить();
		НоваяСтрока.Услуга 								= Выборка.Услуга;
		НоваяСтрока.ВидБлагоустройстваИндивидуальный	= Выборка.ВидБлагоустройстваИндивидуальный;
		НоваяСтрока.ТарифнаяКатегория					= Выборка.ТарифнаяКатегория;
	КонецЦикла;
	
КонецПроцедуры

