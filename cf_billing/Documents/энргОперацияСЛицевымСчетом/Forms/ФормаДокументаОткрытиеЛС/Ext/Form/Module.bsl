&НаСервере
Процедура ПриИзмененииДоговораСервер()
	
	Если Не ЗначениеЗаполнено(Объект.Договор) Тогда
		Возврат;
	КонецЕсли;
	
	ПолучаемыеРеквизиты = "Организация,Район,Контрагент";
	ЗначенияРеквизитов 	= Обработки.энргДоговорыКонтрагентовМенеджер.ЗначенияСвойствОбъекта(Объект.Договор, ПолучаемыеРеквизиты);
			
	Если Объект.Организация <> ЗначенияРеквизитов["Организация"] Тогда
		Объект.Организация = ЗначенияРеквизитов["Организация"];
		ОрганизацияПриИзмененииСервер();
	КонецЕсли;
	
	Если Объект.Район <> ЗначенияРеквизитов["Район"] Тогда
		Объект.Район = ЗначенияРеквизитов["Район"];
		РайонПриИзмененииСервер();
	КонецЕсли;
	
	Если ФизЛицо <> ЗначенияРеквизитов["Контрагент"] Тогда
		ФизЛицо = ЗначенияРеквизитов["Контрагент"];		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СтроениеПомещениеПриИзмененииСервер(СтроениеИзменено)
	
	ДанныеКлючаПомещения 			= Обработки.энргКлючиПомещенийМенеджер.КлючПомещенияПоСтроениюИПомещению(Строение,Помещение);
	 	
	Если НЕ ДанныеКлючаПомещения.КлючПомещения = Объект.КлючПомещения Тогда
		ЗаполнитьЗначенияСвойств(Объект,ДанныеКлючаПомещения,"КлючПомещения");
		ЗаполнитьЗначенияСвойств(ЭтаФорма,ДанныеКлючаПомещения,"ЧастныйСектор");
		ДанныеМаршрута  			= Обработки.энргМаршрутыКонтроллеровМенеджер.ДанныеМаршрутаПоКлючуПомещения(Объект.КлючПомещения);
		Объект.МаршрутКонтроллера 	= ДанныеМаршрута.Маршрут;
		Объект.Контроллер			= ДанныеМаршрута.Контролер;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ДанныеКлючаПомещения.Район) и НЕ Объект.Район = ДанныеКлючаПомещения.Район Тогда
		Объект.Район 				= ДанныеКлючаПомещения.Район;
	КонецЕсли; 	
	
	Если СтроениеИзменено и Объект.ТочкиУчета.Количество() = 0 Тогда
		ТекДата 					= ?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия), Объект.ДатаФактическогоСобытия, Объект.Дата);
		ТипСтроения 				= ТипСтроения();
		НастроитьВидимостьПомещенияСервер(ТипСтроения);	
		ЗаполнитьТЧНаОснованииСтроения(ТипСтроения);
		
		Строки  			= УслугиДерево.ПолучитьЭлементы();
		Строки.Очистить();
		ЗаполнитьДеревоУслугНаОснованииТочекУчета(Объект, УслугиДерево);
		
		// энргРаботаСПоставщиками {
		энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма,,,,"УслугиДерево");
		// энргРаботаСПоставщиками }
	КонецЕсли;
	
КонецПроцедуры 

