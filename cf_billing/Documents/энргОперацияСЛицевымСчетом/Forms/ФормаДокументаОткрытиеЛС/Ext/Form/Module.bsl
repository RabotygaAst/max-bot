Процедура ТочкиУчетаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	ТаблицаФормы 					= Элементы["ТочкиУчета" + ПрефиксТочекУчета];
	
	Если Копирование Тогда		
		Родитель	  				= УслугиДерево.НайтиПоИдентификатору(ТаблицаФормы.ТекущаяСтрока).ПолучитьРодителя();
	Иначе
		Отказ 						= Истина;		
		НоваяСтрока  				= УслугиДерево.ПолучитьЭлементы().Добавить();
		ТаблицаФормы.ТекущаяСтрока 	= НоваяСтрока.ПолучитьИдентификатор();
		ТаблицаФормы.ИзменитьСтроку();
