#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	слжСлужебныеОперацииПриСозданииНаСервере();
		
	энргЛокализацияСервер.ПриСозданииНаСервере_энргОперацияСЛицевымСчетом(ЭтотОбъект);
		
	// энргРаботаСПоставщиками {
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма,,,,"УслугиДерево");
	// энргРаботаСПоставщиками }
	
	ЗаполнитьПериодНачисления();
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании,,"ДобавитьКомандыСозданияОткрытияЛицевогоСчетаНаОсновании");
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
		яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
		энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета);
		
		Если НЕ ЗначениеЗаполнено(Объект.Договор) и ЗначениеЗаполнено(Объект.Организация) и ЗначениеЗаполнено(Объект.Район) и ЗначениеЗаполнено(ФизЛицо) Тогда
			Объект.Договор 				= Обработки.энргДоговорыКонтрагентовМенеджер.НайтиДействующийДоговорПоПараметрам(Объект.Организация, Объект.Район, ФизЛицо, ?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия),Объект.ДатаФактическогоСобытия,Объект.Дата));			
		КонецЕсли;
		
		ЗаполнитьСвойстваФормыПоДоговору(); 		
		ЗаполнитьСвойстваФормыПоКлючуПомещения();
		
		Если НЕ ЗначениеЗаполнено(Филиал) Тогда
			ЭтаФорма.Филиал = Обработки.энргФилиалыСтроенийМенеджер.ПолучитьТекущееЗначениеФилиала(Объект.Организация, Объект.Район, Строение);
		КонецЕсли;
		
		ПоказатьУзлы();
	КонецЕсли;			
	
	УстановитьПараметрВыбораПомещения();
	УстановитьСвязиПараметровВыбораТаблицыВидыБлагоустройстваТарифныеКатегории();
	
КонецПроцедуры  

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(ТекущийОбъект.КлючПомещения);
	ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);
	
	ЗаполнитьСвойстваАбонента(ТекущийОбъект.Абонент,ТекущийОбъект.ОписаниеАбонента);
			
	ЗаполнитьСвойстваТочекУчета(ТекущийОбъект);
		
	ЗаполнитьСвойстваПриборовУчета(ТекущийОбъект);
	ЗаполнитьСвойстваИзмерителей(ТекущийОбъект);
	
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета,ТекущийОбъект);
	
	УслугиДерево.ПолучитьЭлементы().Очистить();
	ЗаполнитьДеревоУслугНаОснованииТочекУчета(Объект, УслугиДерево);
		
	Если ЗначениеЗаполнено(ЭтотОбъект.Строение) Тогда
		ТипСтроения					= ТипСтроения();
		НастроитьВидимостьПомещенияСервер(ТипСтроения);		
	КонецЕсли; 
	
	ПоказатьУзлы();
	ПерезаполнитьКатегории();
	ЗаполнитьДанныеСНТ();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	//УстановитьСвязиПараметровВыбораТаблицыВидыБлагоустройстваТарифныеКатегории();
	УстановитьВидимостьГруппыДоговорСоцНайма();
	УстановитьВидимостьДолиСобственности();
	УстановитьВидимостьСНТ();
	ЗаполнитьТипСобственности();  
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ОписаниеАбонента = Обработки.энргАбонентыМенеджер.ЗаписатьДанныеАбонента(ЭтотОбъект);	
	
	СоответствиеСтрок = Новый Соответствие;	
	ЗаписатьПараметрыТочекИПриборовУчета(ТекущийОбъект, СоответствиеСтрок);
	энргШкалыТарифныеЗоныСервер.ЗаполнитьОбъектПоПредставлениюФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда		

		ДатаПроверки	= ?(Объект.ДатаФактическогоСобытия = Дата(1,1,1), Объект.Дата, Объект.ДатаФактическогоСобытия);
		НовыйАбонент	= Обработки.энргАбонентыМенеджер.СсылкаПоКлючевымПараметрам(ДатаПроверки, ТекущийОбъект.Организация, ТекущийОбъект.Район, ТекущийОбъект.КлючПомещения, Неопределено, ТекущийОбъект.Поставщик, ТекущийОбъект.ТочкиУчета.Выгрузить(,"Услуга"));
		
		Если ЗначениеЗаполнено(НовыйАбонент) Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По данным услугам в указанном помещении есть активный ЛС " + НовыйАбонент.ЛицевойСчет);
			Возврат;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТекущийОбъект.Абонент ) Тогда
			ТекущийОбъект.Абонент = Справочники.энргАбоненты.ПолучитьСсылку(Новый УникальныйИдентификатор);
			ТекущийОбъект.ДополнительныеСвойства.Вставить("ЭтоНовыйАбонент", Истина);
		КонецЕсли;
		
		// Определяем контроллера по адресу.
		// энргРаботаСЛицевымСчетомСервер.ДобавитьАдресКМашруту(ЭтотОбъект.АдресОбъекта,ЭтотОбъект.АдресОбъектаЗначение,ТекущийОбъект.Контроллер,ТекущийОбъект.МаршрутКонтроллера);
		Обработки.энргМаршрутыКонтроллеровМенеджер.ЗарегистрироватьКлючПомещенияВМаршрутеКонтролера(Объект.МаршрутКонтроллера, Объект.КлючПомещения);
		// TODO FIX ME
		//Справочники.энргПриборыУчетаАбонента.НайтиПриборыУчетаПоПараметрам(ТекущийОбъект,"ТочкиУчета",Отказ);
		// TODO FIX ME
		//Справочники.энргПриборыУчетаАбонента.НайтиПриборыУчетаПоПараметрам(ТекущийОбъект,"Измерители",Отказ);
		
		НовыеТочкиУчета						= Новый Массив;
		НовыеПриборыУчета 					= Новый Массив;
		НовыеИзмерители 					= Новый Массив;
		СоответствиеПрибора 				= Новый Соответствие;
		
		Для Каждого СтрокаТочкиУчета Из ТекущийОбъект.ТочкиУчета Цикл
			Если Не ЗначениеЗаполнено(СтрокаТочкиУчета.ТочкаУчета) Тогда
				СтрокаТочкиУчета.ТочкаУчета = Справочники.энргТочкиУчета.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеТочкиУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
			КонецЕсли;
			
			Если Не ПустаяСтрока(СтрокаТочкиУчета.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаТочкиУчета.ПриборУчета) Тогда
				СтрокаТочкиУчета.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеПриборыУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
				
				ЗаводскойНомерЗначение = СоответствиеСтрок[СтрокаТочкиУчета.IDСтроки];
				СоответствиеПрибора.Вставить(ЗаводскойНомерЗначение, СтрокаТочкиУчета.ПриборУчета);
			КонецЕсли;			
		КонецЦикла; 		
		
		Для Каждого СтрокаИзмерителя Из ТекущийОбъект.Измерители Цикл
			Если Не ПустаяСтрока(СтрокаИзмерителя.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаИзмерителя.ПриборУчета) Тогда
				//СтрокаИзмерителя.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
				//НовыеИзмерители.Добавить(СтрокаИзмерителя.НомерСтроки);
				
				ПриборУчетаЗначение = СоответствиеПрибора[СтрокаИзмерителя.ЗаводскойНомер];
				СоздаватьНовый 		= ПриборУчетаЗначение = Неопределено ИЛИ СтрокаИзмерителя.ВспомогательноеОборудование;
				
				Если СоздаватьНовый Тогда
					ПриборУчетаЗначение = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
					НовыеИзмерители.Добавить(СтрокаИзмерителя.НомерСтроки);
				КонецЕсли;			
				
				СтрокаИзмерителя.ПриборУчета = ПриборУчетаЗначение;
			КонецЕсли;			
		КонецЦикла;
		
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеТочкиУчета", 	НовыеТочкиУчета);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеПриборыУчета", 	НовыеПриборыУчета);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеИзмерители", 	НовыеИзмерители);		
	КонецЕсли; 	
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоАбоненту(Объект.Организация, Объект.ПериодНачисления,Объект.Район,ЧастныйСектор,Строение,Помещение,Объект.Абонент);
	
	ДопСвойства  = ТекущийОбъект.ДополнительныеСвойства;
	Если ДопСвойства.свойство("УстановкаФормулыРасчета") тогда
		ДанныеУстановкиФормулыРасчета = ДопСвойства.УстановкаФормулыРасчета;		 
	иначе
		ДанныеУстановкиФормулыРасчета = Неопределено;
	КонецЕсли;
	
	Если ДопСвойства.свойство("ДанныеДляПерерасчета") тогда
		ДанныеДляПерерасчета = ДопСвойства.ДанныеДляПерерасчета;		 
	иначе
		ДанныеДляПерерасчета = Неопределено;
	КонецЕсли;
	
	ЗаполнитьСвойстваАбонента(ТекущийОбъект.Абонент,ТекущийОбъект.ОписаниеАбонента);
	
	ЗаполнитьСвойстваТочекУчета(ТекущийОбъект);
	
	ЗаполнитьСвойстваПриборовУчета(ТекущийОбъект);
	ЗаполнитьСвойстваИзмерителей(ТекущийОбъект);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Не Отказ и ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда		
		ЗаполнитьДанныеАбонента(ТекущийОбъект);		
		НовыеТочкиУчета 					= Новый Массив;
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеТочкиУчета") Тогда
			НовыеТочкиУчета 				= ТекущийОбъект.ДополнительныеСвойства.НовыеТочкиУчета;
		КонецЕсли;
		
		НовыеПриборыУчета 					= Новый Массив;
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеПриборыУчета") Тогда
			НовыеПриборыУчета 				= ТекущийОбъект.ДополнительныеСвойства.НовыеПриборыУчета;
		КонецЕсли;
		
		НовыеИзмерители 					= Новый Массив;
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеИзмерители") Тогда
			НовыеИзмерители 				= ТекущийОбъект.ДополнительныеСвойства.НовыеИзмерители;
		КонецЕсли;
		
		Для Каждого СтрокаТочки Из ТекущийОбъект.ТочкиУчета Цикл
			ЗаполнитьДанныеТочкиВСтроке(Отказ,НовыеТочкиУчета, СтрокаТочки.ТочкаУчета, СтрокаТочки.ОписаниеТочки, СтрокаТочки.НомерСтроки);
			Если ЗначениеЗаполнено(СтрокаТочки.ПриборУчета) Тогда
				ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,НовыеПриборыУчета, СтрокаТочки.ПриборУчета, СтрокаТочки.ОписаниеПрибора, СтрокаТочки.НомерСтроки);
			КонецЕсли;			
		КонецЦикла;
		
		Для Каждого СтрокаИзмерителя Из ТекущийОбъект.Измерители Цикл
			Если ЗначениеЗаполнено(СтрокаТочки.ПриборУчета) Тогда
				ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,НовыеИзмерители, СтрокаИзмерителя.ПриборУчета, СтрокаИзмерителя.ОписаниеПрибора, СтрокаИзмерителя.НомерСтроки);						
			КонецЕсли;
		КонецЦикла; 		
	КонецЕсли;
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение И Не Отказ Тогда
		энргРаботаСТочкамиУчетаСервер.ЗаполнитьДанныеДляФормулРасчета(ТекущийОбъект);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ДанныеДляПерерасчета", энргРаботаСПериодомДействия.ЗаполнитьДанныеДляПерерасчета(ТекущийОбъект));   		
	КонецЕсли;	
	
	ПриЗаписиНаСервереПереопределяемыйПосле(Отказ, ТекущийОбъект, ПараметрыЗаписи); 	

КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервереПереопределяемыйПосле(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// Переопределяется в расширении
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если  ДанныеУстановкиФормулыРасчета <>Неопределено тогда
		ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросУстановкиФормулыРасчетаЗавершение",ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения,"Открыть документ установки формулы расчета?",РежимДиалогаВопрос.ДаНет);		
	КонецЕсли;
	
	Если  ДанныеДляПерерасчета <>Неопределено тогда
		ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросСозданияПерерасчета",ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения,"Открыть документ перерасчета?",РежимДиалогаВопрос.ДаНет);		
	КонецЕсли;
	
	Если Не Объект.Проведен Или Не ЗначениеЗаполнено(Строение) Тогда
		Возврат;
	КонецЕсли; 
	
	УстановитьТехВозможностьОРП();
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросУстановкиФормулыРасчетаЗавершение(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если  РезультатВопроса = КодВозвратаДиалога.Да тогда
			энргРаботаСТочкамиУчетаКлиент.ОткрытьФормуУстановкиФормулы(ДанныеУстановкиФормулыРасчета);
		иначе
			ДанныеУстановкиФормулыРасчета = Неопределено;
		КонецЕсли; 		
	КонецЕсли;	
КонецПроцедуры

