&НаКлиенте
Функция ЕстьОшибкиЗаполнения(РежимЗаписи)
	
	ЕстьОшибкиЗаполнения = Ложь;
		
	Если НачалоМесяца(Объект.Дата) = НачалоМесяца(Объект.ДатаФактическогоСобытия) Тогда
		ЕстьОшибкиЗаполнения = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Фактическая и текущая дата не могут находиться в одном периоде");
		Объект.ДатаФактическогоСобытия = Дата(1,1,1);
	КонецЕсли;

	Возврат ЕстьОшибкиЗаполнения;
	
КонецФункции

&НаСервере
Функция ПолучитьЛьготуКонтрагента(Контрагент)
	Период = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
	
	Возврат Документы.энргОперацияСЛицевымСчетом.ПолучитьЛьготуКонтрагента(Контрагент, Объект.Организация, Объект.Район, Период);
КонецФункции

&НаСервере
Функция ПолучитьПроцентЛьготы(ЛьготнаяКатегория)
	Период = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
	
	Возврат Документы.энргОперацияСЛицевымСчетом.ПолучитьПроцентЛьготы(ЛьготнаяКатегория, Объект.Организация, Объект.Район, Период);
КонецФункции

&НаСервере
Процедура ПерезаполнитьКатегории()
	Для каждого стр из Объект.Жильцы Цикл
		стр.ЛьготнаяКатегория = ПолучитьЛьготуКонтрагента(стр.ФизическоеЛицо);
		стр.ПроцентЛьготы = ПолучитьПроцентЛьготы(стр.ЛьготнаяКатегория);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеКлючаПомещения(Знач ДанныеПомещенияРезультат)
	
	Перем ДанныеПомещенияВыборка;
	
	Если Не ДанныеПомещенияРезультат.Пустой() Тогда
		ДанныеПомещенияВыборка  = ДанныеПомещенияРезультат.Выбрать();
		ДанныеПомещенияВыборка.Следующий();
		ЗаполнитьЗначенияСвойств(ЭтаФорма,ДанныеПомещенияВыборка,"Строение,Помещение,ЧастныйСектор");
	КонецЕсли;
	
КонецПроцедуры

