#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	энргЛокализацияСервер.ПриСозданииНаСервере_энргОперацияСЛицевымСчетом(ЭтотОбъект);

	// энргРаботаСПоставщиками {
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма,,,,"УслугиДерево");
	// энргРаботаСПоставщиками }
	
	ЗаполнитьДокумент  = Ложь;
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ЗначениеЗаполнено(Объект.КлючПомещения) Тогда
			ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(Объект.КлючПомещения);
			ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);
			
			Объект.МаршрутКонтроллера = ЭтотОбъект.Строение.МаршрутКонтроллера;
			Объект.Контроллер = Объект.МаршрутКонтроллера.Владелец;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.Организация) Тогда
			Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
				Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;
	
	Если Параметры.Свойство("ЗаполнитьДокумент") тогда
		ЗаполнитьДокумент 			= истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
		яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
		энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Абонент) и ЗаполнитьДокумент тогда
		Если не ЗначениеЗаполнено(Объект.Дата) тогда
			Объект.Дата 			= ТекущаяДата();
		КонецЕсли;
		
		ПерезаполнитьПоказанияПУСервер();
		ОбновитьДанныеПоУслугамСервер();
	КонецЕсли;
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ЗаполнтьСуммуКОплате();
	ТипСобственности = ?(Объект.ДолеваяСобственность, "Долевая", "Совместная");
	ЗаполнитьДанныеСНТ();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьВидимостьДолиСобственности();
	ПерезаполнитьКатегории();
	
	АбонентЗаполнен = ЗначениеЗаполнено(Объект.Абонент);
		
	УстановитьДоступностьГруппыАбонента(АбонентЗаполнен);
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения 
	
	ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(ТекущийОбъект.КлючПомещения);
	ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);
	
	энргРаботаСЛицевымСчетомСервер.ПрочитатьДанныеАбонента(ЭтотОбъект, ТекущийОбъект);
	
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета,ТекущийОбъект);
	
	энргРаботаСприборамиУчетаСервер.ЗаполнитьСвойствоРегистрируетОбъемПриЧтении(Объект.ТочкиУчета,ТекущийОбъект);
	
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();
	
	ЗаполнитьДеревоУслугНаОснованииТочекУчета(Объект, УслугиДерево);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если СуммаКОплате <> 0 и ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ПоказатьПредупреждение(,"У абонента есть задолженность/аванс");
	КонецЕсли;
	
	Если ЕстьОшибкиЗаполнения(ПараметрыЗаписи.РежимЗаписи) Тогда
		Отказ = Истина;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Не ЗначениеЗаполнено(Филиал) Тогда
		ЗаполнитьДополнительныеРеквизиты();
	КонецЕсли;
	
	ТекущийОбъект.ОписаниеАбонента 	= Обработки.энргАбонентыМенеджер.ЗаписатьДанныеАбонента(ЭтотОбъект);
	энргШкалыТарифныеЗоныСервер.ЗаполнитьОбъектПоПредставлениюФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		ДатаПроверки	= ?(Объект.ДатаФактическогоСобытия = Дата(1,1,1), Объект.Дата, Объект.ДатаФактическогоСобытия);
		НовыйАбонент	= Обработки.энргАбонентыМенеджер.СсылкаПоКлючевымПараметрам(ДатаПроверки, ТекущийОбъект.Организация, ТекущийОбъект.Район, ТекущийОбъект.КлючПомещения, ФизЛицо, ТекущийОбъект.Поставщик, ТекущийОбъект.ТочкиУчета.Выгрузить(,"Услуга"));
		
		Если ЗначениеЗаполнено(НовыйАбонент) Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По данным услугам в указанном помещении есть активный ЛС " + НовыйАбонент.ЛицевойСчет);
			Возврат;
		КонецЕсли;
		
		//Если Не ЗначениеЗаполнено(ТекущийОбъект.АбонентСмена) Тогда
		//	ТекущийОбъект.АбонентСмена 		= Справочники.энргАбоненты.ПолучитьСсылку(Новый УникальныйИдентификатор);
		//	ТекущийОбъект.ДополнительныеСвойства.Вставить("ЭтоНовыйАбонент", Истина);
		//КонецЕсли;

		
		Если Не ЗначениеЗаполнено(ТекущийОбъект.АбонентСмена) Тогда			
			Если ЭтотОбъект.ФизЛицо = Справочники.энргКонтрагенты.ПустаяСсылка() Тогда
				ТекущийОбъект.АбонентСмена = Справочники.энргАбоненты.ПустаяСсылка();				
			Иначе
				ТекущийОбъект.АбонентСмена = Справочники.энргАбоненты.ПолучитьСсылку(Новый УникальныйИдентификатор);
			КонецЕсли;
			
			ТекущийОбъект.ДополнительныеСвойства.Вставить("ЭтоНовыйАбонент", Истина); 			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// энргРаботаСПоследовательностями.ВосстановитьПоследовательностьПоАбоненту(Объект.Организация, Объект.ПериодНачисления,Объект.Район,ЧастныйСектор,Строение,Помещение,Объект.Абонент);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
	ДопСвойства  = ТекущийОбъект.ДополнительныеСвойства;
	
	Если ДопСвойства.свойство("ДанныеДляПерерасчета") тогда
		ДанныеДляПерерасчета = ДопСвойства.ДанныеДляПерерасчета;		 
	иначе
		ДанныеДляПерерасчета = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)	
	Если  ДанныеДляПерерасчета <>Неопределено тогда
		энргРаботаСПериодомДействияКлиент.ОткрытьФормуДокументаПерерасчет(ДанныеДляПерерасчета);
	КонецЕсли; 
	ПерезаполнитьКатегории();
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ДанныеДляПерерасчета", энргРаботаСПериодомДействия.ЗаполнитьДанныеДляПерерасчета(ТекущийОбъект,,Истина));
		ЗаполнитьПоставщикаАбонента(ТекущийОбъект); 
		Если ЭтотОбъект.ФизЛицо = Справочники.энргКонтрагенты.ПустаяСсылка() Тогда
			ФормироватьЛС = Ложь;
		Иначе			
			энргРаботаСЛицевымСчетомСервер.ПроверитьИСоздатьАбонента(ТекущийОбъект, Отказ);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#Конецобласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	ЗаполнитьПериодНачисленияСервер();
	ЗаполнтьСуммуКОплате();
	ПерезаполнитьПоказанияПУСервер();
	ОбновитьДанныеПоУслугамСервер();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПериодНачисленияСервер()
	Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда		
		Объект.ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
		ЗаполнтьСуммуКОплате();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АбонентПриИзменении(Элемент)
	
	АбонентЗаполнен = ЗначениеЗаполнено(Объект.Абонент);
	
	Если АбонентЗаполнен тогда
		энргПользовательскийВводКлиент.ПриИзмененииАбонента(ЭтаФорма);
		ЗаполнтьСуммуКОплате();
	иначе
		Объект.КлючПомещения	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
		ЭтаФорма.Помещение 		= ПредопределенноеЗначение("Справочник.энргПомещения.ПустаяСсылка");
		ЭтаФорма.Строение 		= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Строение) Тогда 
		ЗаполнитьМаршрутИКонтролера();
	КонецЕсли;
	
	ЗаполнитьДанныеОКоличествеЧеловек();
	ПерезаполнитьПоказанияПУСервер();
	ОбновитьДанныеПоУслугамСервер();
	
	энргПользовательскийВводКлиент.АктивизироватьНачальнуюСтрокуТочекУчета(Объект, Элементы, ПрефиксТочекУчета);
	УстановитьДоступностьГруппыАбонента(АбонентЗаполнен);
	ЗаполнитьДанныеСНТ();
КонецПроцедуры

&НаСервере 
Процедура ЗаполнитьДополнительныеРеквизиты()
	
	ПолучаемыеРеквизиты 					= "Филиал";
	
	ЗначенияРеквизитовАбонента 				= Обработки.энргАбонентыМенеджер.ЗначенияРеквизитовОбъекта(Объект.Абонент,ПолучаемыеРеквизиты);
	Филиал		 							= ЗначенияРеквизитовАбонента.Филиал;
	
КонецПроцедуры

&НаСервере 
Процедура ЗаполнитьПоставщикаАбонента(ТекущийОбъект)
	
	ТекущийОбъект.Поставщик = Объект.Абонент.Поставщик;
КонецПроцедуры

&НаКлиенте
Процедура СтроениеПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Строение) Тогда
		энргПользовательскийВводКлиент.ПриИзмененииСтроенияПомещения(ЭтаФорма);
		ЗаполнтьСуммуКОплате();
	Иначе
		ЭтаФорма.Строение 		= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
		Объект.КлючПомещения 	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
	КонецЕсли;
	
	ПерезаполнитьПоказанияПУСервер();
	
	ЗаполнитьМаршрутИКонтролера();
	ОбновитьДанныеПоУслугамСервер();
	ЗаполнитьДанныеСНТ();
	
КонецПроцедуры

&НаКлиенте
Процедура ПомещениеПриИзменении(Элемент)	
	энргПользовательскийВводКлиент.ПриИзмененииСтроенияПомещения(ЭтаФорма);
	
	ПомещениеПриИзмененииСервер();
	
КонецПроцедуры 

&НаКлиенте
Процедура ФизЛицоПриИзменении(Элемент)
	Объект.Жильцы.Очистить();
	Если ЗначениеЗаполнено(ЭтотОбъект.ФизЛицо) Тогда
		Стр = Объект.Жильцы.Добавить();
		Стр.ФизическоеЛицо					= ЭтотОбъект.ФизЛицо;
		Стр.ДоляСобственностиЧислитель		= 1;
		Стр.ДоляСобственностиЗнаменатель	= 1;
		Стр.Собственник						= Объект.ТипСобственностиЖилья = ПредопределенноеЗначение("Перечисление.энргТипыСобственниковЖилья.ЧастнаяСобственность");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТипСобственностиПриИзменении(Элемент)
	Объект.ДолеваяСобственность = ТипСобственности = "Долевая";
	Модифицированность = Истина;
	УстановитьВидимостьДолиСобственности();
КонецПроцедуры

&НаКлиенте
Процедура ДатаФактическогоСобытияПриИзменении(Элемент)
		
	энргРаботаСПериодомДействияКлиент.ПроверитьКорректностьДатыФактическогоСобытияКлиент(Объект.Организация, Объект.Район, Объект.Дата, Объект.ДатаФактическогоСобытия);
	
	Если ЗначениеЗаполнено(Объект.Абонент) тогда
		энргПользовательскийВводКлиент.ПриИзмененииАбонента(ЭтаФорма);
		ЗаполнтьСуммуКОплате();
	иначе
		Объект.КлючПомещения	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
		ЭтаФорма.Помещение 		= ПредопределенноеЗначение("Справочник.энргПомещения.ПустаяСсылка");
		ЭтаФорма.Строение 		= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Строение) Тогда 
		ЗаполнитьМаршрутИКонтролера();
	КонецЕсли;  
		
	ЗаполнитьДанныеОКоличествеЧеловек();
	ПерезаполнитьПоказанияПУСервер();
	ОбновитьДанныеПоУслугамСервер();
	
КонецПроцедуры

#Конецобласти

#Область СобытияТаблицыФормыТочкиУчетаЕстьШкалыЕстьТарифныеЗоны

&НаКлиенте
Процедура ТочкиУчетаЕстьШкалыЕстьТарифныеЗоныПриАктивизацииСтроки(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчетаЕстьШкалыЕстьТарифныеЗоны";
	ИмяТаблицыШкал							= "ШкалыПриборовУчетаЕстьШкалыЕстьТарифныеЗоны";
	ТаблицаФормыШкал	 					= Элементы[ИмяТаблицыШкал];
	
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
