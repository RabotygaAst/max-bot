&НаСервере
Процедура ОбновитьДанныеПоУслугамСервер()
	//яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	//яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	//энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета,Объект);	
	
	Строки = УслугиДерево.ПолучитьЭлементы();
	Строки.Очистить();
	
	ЗаполнитьДеревоУслугНаОснованииТочекУчета(Объект, УслугиДерево, Неопределено, Ложь);
	
	// энргРаботаСПоставщиками {
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма,,,,"УслугиДерево");
	// энргРаботаСПоставщиками }

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТочкиНаОснованииДереваУслуг(Строки, Родитель)
	
	Для Каждого Строка Из Строки Цикл 		
		СтрокаТочки  						= Объект.ТочкиУчета.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТочки, Строка);
		Если Не Родитель = Неопределено Тогда
			СтрокаТочки.IDСтрокиРодитель	= Родитель;			
		КонецЕсли;
		ЗаполнитьТочкиНаОснованииДереваУслуг(Строка.ПолучитьЭлементы(), Строка.IDСтроки);
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоУслугНаОснованииТочекУчета(ТекущийОбъект, СтрокаРодитель, Родитель = Неопределено, ЗаполнятьТекстыГиперссылок = Истина)
	
	Если Родитель = Неопределено Тогда
		ОписаниеТипа  		= Новый ОписаниеТипов("УникальныйИдентификатор");	
		Родитель 			= ОписаниеТипа.ПривестиЗначение();
	КонецЕсли;
	
	Вершины 				= ТекущийОбъект.ТочкиУчета.НайтиСтроки(Новый Структура("IDСтрокиРодитель", Родитель));
	Строки  				= СтрокаРодитель.ПолучитьЭлементы();
	
	Для Сч = 0 По Вершины.ВГраница() Цикл
		Если ЗначениеЗаполнено(Вершины[Сч].IDСтроки) Тогда
			СтрокаДерева  	= Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДерева, Вершины[Сч]);
			
			Если ЗаполнятьТекстыГиперссылок Тогда
				СтрокаДерева.ДанныеУслуги 			= энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстДанныеУслуги(СтрокаДерева);
				СтрокаДерева.ДанныеРасположения 	= энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстДанныеРасположения(СтрокаДерева);
				СтрокаДерева.ТехническиеСвойстваТУ	= энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстТехническихСвойств(СтрокаДерева, Объект.Потери.НайтиСтроки(Новый Структура("IDСтроки", СтрокаДерева.IDСтроки)));
				
				ДанныеИзмерителей = Новый Структура("Измерители", Объект.Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", СтрокаДерева.IDСтроки)));
				энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстСредствИзмерений(СтрокаДерева, ДанныеИзмерителей);
			КонецЕсли;
			
			ЗаполнитьДеревоУслугНаОснованииТочекУчета(ТекущийОбъект, СтрокаДерева, Вершины[Сч].IDСтроки, ЗаполнятьТекстыГиперссылок);
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьПоказанияПУСервер()
	ТочкаУчета = Неопределено; 
	
	ТаблицаТЧ 									= Объект.ПоказанияПриборовУчета.Выгрузить();
	Объект.ШкалыПриборовУчета.Очистить();
	Объект.ПоказанияПриборовУчета.Очистить();
	Объект.ТочкиУчета.Очистить();
	//УслугиДеревоОбъект = РеквизитФормыВЗначение("УслугиДерево");
	//УслугиДеревоОбъект.Строки.Очистить();
	Объект.ПоставщикиСоставныхУслуг.Очистить();
	
	Результат 									= Обработки.энргСостояниеТочекУчетаМенеджер.ДействующиеТочкиИИхПриборы(Объект.Дата,Объект.Организация,Объект.Район,Объект.КлючПомещения,, Новый Структура("ТолькоОткрытыеЛС, ВключаяОРП", Истина, Истина)); 
	Выборка  									= Результат.выбрать();
	ТекТочкаУчета 								= Неопределено;
	ТекШкала 									= Неопределено;
	IDСтрокиТочки 								= Неопределено;
	IDСтрокиШкалы 								= Неопределено;
	Пока Выборка.следующий() цикл
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			//СтрокаТочкиУчета  					= УслугиДеревоОбъект.Строки.Добавить();
			СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
			IDСтрокиТочки 						= Новый УникальныйИдентификатор;
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
			СтрокаТочкиУчета.РегистрируетОбъем 	= Выборка.РегистрируетОбъем;
			СтрокаТочкиУчета.ЭтоСоставнаяУслуга = Выборка.СоставнаяУслуга;
			Если СтрокаТочкиУчета.ЭтоСоставнаяУслуга Тогда 
				Для Каждого ТекУслуга Из Выборка.Услуга.СоставляющиеУслуг Цикл
					СтрокаУслуги  				= Объект.ПоставщикиСоставныхУслуг.Добавить();
					СтрокаУслуги.IDСтроки 		= IDСтрокиТочки;
					СтрокаУслуги.ЧастьСоставнойУслуги	= ТекУслуга.Услуга;
				КонецЦикла;
			КонецЕсли;
			//СтрокаТУ = Объект.ТочкиУчета.Добавить();
			//ЗаполнитьЗначенияСвойств(СтрокаТУ, СтрокаТочкиУчета);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) Тогда
			Если ЗначениеЗаполнено(Выборка.Шкала) и (НоваяТочка Или НЕ ТекШкала = Выборка.Шкала) Тогда
				СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
				IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
				СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
				СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
				СтрокаШкалы.Шкала 					= Выборка.Шкала;
				СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
			КонецЕсли;   			
			
			СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
			СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
			СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		КонецЕсли;
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
		ТекШкала 								= Выборка.Шкала;
	КонецЦикла;
	
	ДатаЗаполненияПоказаний = ?(Объект.ДатаФактическогоСобытия = Дата(1,1,1), Объект.Дата, Объект.ДатаФактическогоСобытия);
	
	//ЗначениеВРеквизитФормы(УслугиДеревоОбъект, "УслугиДерево");
	//Если ПрефиксТочекУчета = "ЕстьШкалыНетТарифныхЗон" Тогда
	//	ТаблицаТочекПередачи = УслугиДерево;
	//Иначе 
		ТаблицаТочекПередачи = Объект.ТочкиУчета;		
	//КонецЕсли;
	
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();
	
	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация, ТаблицаТочекПередачи, Объект.ШкалыПриборовУчета, Объект.ПоказанияПриборовУчета, Объект.Район, Объект.КлючПомещения); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказанийСУчетомОтклонения(Объект.Организация,Объект.Район,ТаблицаПоказанийДляЗаполнения,Объект.Дата, ПриборыДляОтклоненияПоказаний.Выгрузить());
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний, ТаблицаПоказанийДляЗаполнения, Объект.ПоказанияПриборовУчета);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, Объект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеОКоличествеЧеловек()
	
	Объект.КоличествоПроживающих = 0;
	Результат = Обработки.энргКлючиПомещенийМенеджер.КоличествоПроживающихПомещения(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения);
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Объект.КоличествоПроживающих = Выборка.Количество;
	КонецЕсли;
	
	Объект.КоличествоПрописанных = 0;
	Результат = Обработки.энргКлючиПомещенийМенеджер.КоличествоПрописанныхПомещения(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения);
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Объект.КоличествоПрописанных = Выборка.Количество;
	КонецЕсли;
	
	Объект.КоличествоСобственников = 0;
	Результат = Обработки.энргКлючиПомещенийМенеджер.КоличествоСобственниковПомещения(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения);
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Объект.КоличествоСобственников = Выборка.Количество;
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ЗаполнтьСуммуКОплате()
	МКД  			= ?(ЧастныйСектор,Справочники.энргСтроения.ПустаяСсылка(),Строение);
	СуммаКОплате 	= энргРаботаСТочкамиУчетаСервер.ЗадолженностьАбонента(Объект.Дата,Объект.Организация,Объект.Район,МКД,Объект.Абонент);
КонецПроцедуры

