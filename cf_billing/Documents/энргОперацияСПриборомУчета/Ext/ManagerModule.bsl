// Заполняет список команд отчетов.
// 
// Параметры:
//   КомандыОтчетов - ТаблицаЗначений - состав полей см. в функции МенюОтчеты.СоздатьКоллекциюКомандОтчетов.
//   Параметры		- Структура передаваемых параметров.
//
Процедура ДобавитьКомандыОтчетов(КомандыОтчетов, Параметры= Неопределено) Экспорт
		
	энргВариантыОтчетовПереопределяемый.ДобавитьКомандуСтруктураПодчиненности(КомандыОтчетов);
	
КонецПроцедуры

// Заполняет список команд создания на основании.
// 
// Параметры:
//   КомандыСоздатьНаОсновании - состав команд.
// 
// Возвращаемое значение:
//	 ТаблицаЗначений
//
Функция ДобавитьКомандыСозданияНаОсновании(КомандыСоздатьНаОсновании) Экспорт

	Возврат Документы.энргПерерасчет.ДобавитьКомандуСоздатьНаОснованииОперацияСПриборомУчета(КомандыСоздатьНаОсновании);  	
		
КонецФункции

// Получает изменяемые параметры расчета.
// 
// Возвращаемое значение:
//   Соответствие.
//
Функция ИзменяемыеПараметрыРасчета() Экспорт 
	
	ИзменяемыеПараметрыРасчета		 = Новый Соответствие; 
	
	ИзменяемыеПараметры 			= Новый Массив;
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета","ПриборУчета,ПриборВведен,ДатаСостоянияПрибора,КоэффициентПУ,ДатаПоверки,ПотериОбъем,ПотериПроцент,ПериодНачисленияВыводаПрибора,СрокПоверкиИстек"));
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","Услуга",""));
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВводПУ, ИзменяемыеПараметры);
	
	ИзменяемыеПараметры 			= Новый Массив;
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета","ПриборВведен"));
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета","ПриборУчета,ПриборВведен,КоэффициентПУ,ДатаПоверки,ПотериОбъем,ПотериПроцент,СрокПоверкиИстек,ПериодНачисленияВыводаПрибора"));
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ, ИзменяемыеПараметры);
	
	ИзменяемыеПараметры 			= Новый Массив;
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета","ПриборВведен,ДатаПоверки,ПериодНачисленияВыводаПрибора"));
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВыводПУ, ИзменяемыеПараметры);	
		
	Возврат ИзменяемыеПараметрыРасчета;
	
КонецФункции

// Получает данные для проведение по стабильным периодам.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ВыбираемыеТаблицы	-	Массив из Строка.
//
Процедура ПолучитьДанныеДляПроведенияПоСтабильнымПериодам(Схема,ВыбираемыеТаблицы) Экспорт 
	ПолучитьДанныеДляПроведенияПоСтабильнымПериодамВводПрибораУчета(Схема,ВыбираемыеТаблицы);	
	ПолучитьДанныеДляПроведенияПоСтабильнымПериодамЗаменаПрибораУчета(Схема,ВыбираемыеТаблицы);
	ПолучитьДанныеДляПроведенияПоСтабильнымПериодамВыводПрибораУчета(Схема,ВыбираемыеТаблицы);
КонецПроцедуры

// Получает данные изменения состава шкал.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ВыбираемыеТаблицы	-	Массив из Строка.
//
Процедура ПолучитьДанныеИзмененияСоставаШкал(Схема,ВыбираемыеТаблицы) Экспорт
	 ПолучитьДанныеИзмененияСоставаШкалАктВводаПрибораУчета(Схема,ВыбираемыеТаблицы);
	 ПолучитьДанныеИзмененияСоставаШкалАктЗаменыПрибораУчета(Схема,ВыбираемыеТаблицы);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	Поля.добавить("Номер");
	Поля.добавить("Дата");
	Поля.добавить("ВидОперации");
	СтандартнаяОбработка = Ложь; 	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	Представление 			="" + Данные.ВидОперации + " №" + Данные.номер + " от " +  Данные.дата;
	СтандартнаяОбработка 	= Ложь;
КонецПроцедуры

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	ЕстьЗначенияЗАполнения  	= Параметры.свойство("ЗначенияЗаполнения");
	
	ВидОперацииВыбран  			= Ложь;
	
	Если ЕстьЗначенияЗАполнения тогда
		 ВидОперацииВыбран 		= Параметры.ЗначенияЗаполнения.свойство("видоперации");
	КонецЕсли;
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка 	= Ложь;
		если Параметры.свойство("Ключ") тогда
			ВидОперации 		= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.ключ, "ВидОперации");//Параметры.ключ.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОперацияСПриборомУчета",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		ИначеЕсли  Параметры.свойство("ЗначениеКопирования") тогда
			ВидОперации 		= Параметры.ЗначениеКопирования.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОперацияСПриборомУчета",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы; 			
		ИначеЕсли  ЕстьЗначенияЗАполнения и ВидОперацииВыбран тогда
			ВидОперации 		= Параметры.ЗначенияЗаполнения.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОперацияСПриборомУчета",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;	

		иначе
			ВыбраннаяФорма 		= "ОбщаяФорма.энргФормаВыбораОперации";
			Параметры.вставить("ИмяДокумента","энргОперацияСПриборомУчета");
			Параметры.вставить("ВыборОперации",Истина);
		КонецЕсли; 		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
		
	ПараметрыЗапроса  			= Новый Структура;
	Схема 						= Неопределено;
	
	ДобавитьТекстЗапросаНомерПломбПриборовУчета(Схема, Регистры);
	ДобавитьТекстЗапросаВидыДифференцированностиПриборовУчета(Схема, Регистры);
	ДобавитьТекстЗапросаДатыПоверкиПрибораУчета(Схема, Регистры);
	ДобавитьТекстЗапросаКоэффциентыПриборовУчета(Схема, Регистры);
	ДобавитьТекстЗапросаПоказанияПриборовУчета(Схема, Регистры);
	ДобавитьТекстЗапросаВыводыПУБезПоказаний(Схема,Регистры);
	ДобавитьТекстЗапросаПриборыТочекУчета(Схема, Регистры);
	ДобавитьТекстЗапросаСостояниеПриборовУчетаАбонента(Схема, Регистры);
	ДобавитьТекстЗапросаСоставУзлаУчета(Схема, Регистры);
	ДобавитьТекстЗапросаСостояниеВыполненияОбязанностейГарантирующегоПоставщика(Схема, Регистры);
	
	ДанныеСтроения			= ДополнительныеСвойства.ДанныеСтроения;
	КлючиТаблицДвижений 	= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	Запрос  				= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("мДокументы"						, ДокументСсылка);
	Запрос.УстановитьПараметр("ЧастныйСектор"					, ДанныеСтроения.ЧастныйСектор);
	Запрос.УстановитьПараметр("Строение"						, ДанныеСтроения.Строение);
	Запрос.УстановитьПараметр("Помещение"						, ДанныеСтроения.Помещение);
	Запрос.УстановитьПараметр("ПустойУникальныйИдентификатор"	, ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
			
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		Запрос.ВыполнитьПакет());
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

#Область РеализацияИнтрейфеса_КонтрольПроведения

Процедура ИнициализироватьТаблицыДляКонтроля(ДокументСсылка,ДополнительныеСвойства) Экспорт 
	
	Схема  					= Неопределено;
	Параметры 				= Новый Структура;
	КлючиТаблицКонтроля 	= Новый Структура;	
	
	Если Не Схема = Неопределено Тогда		
		ПараметрыЗапроса 	= Новый Структура;
		ПараметрыЗапроса.Вставить("мДокументы", ДокументСсылка);
		ДополнительныеСвойства.Вставить("ТаблицыДляКонтроля", 	энргСхемаЗапросаСервер.ВыполнитьПакет(Схема,ПараметрыЗапроса));
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("КлючиТаблицКонтроля", 		КлючиТаблицКонтроля);
	
КонецПроцедуры

#КонецОбласти

Процедура ЗаполнитьСхемуПриборыУчетаДляАрхивации(Схема, ПараметрыСхемы, ТаблицаДляПомещения = "") Экспорт 
	ЭтоНовыйПакет 					= Истина;
	
	Если Схема = Неопределено Тогда
		Схема 						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	ИначеЕсли НЕ ПустаяСтрока(ТаблицаДляПомещения) Тогда
		
		Для Каждого ПакетСхемы Из Схема.ПакетЗапросов Цикл
			Если ВРег(ПакетСхемы.ТаблицаДляПомещения) = ВРег(ТаблицаДляПомещения) Тогда
				Пакет 				= ПакетСхемы;
				ЭтоНовыйПакет 		= Ложь;
				Прервать;
			КонецЕсли;			
		КонецЦикла;
		
		Если ЭтоНовыйПакет Тогда
			Пакет 					= Схема.ПакетЗапросов.Добавить();
		КонецЕсли;
		
	Иначе	
		Пакет 						= Схема.ПакетЗапросов.Добавить();
	КонецЕсли; 	
	
	Если ЭтоНовыйПакет Тогда
		Пакет.УстановитьТекстЗапроса(ТекстЗапросаПриборыУчетаДляАрхивации());
		Пакет.ТаблицаДляПомещения 	= ТаблицаДляПомещения;;
	Иначе
		врСхема 					= Новый СхемаЗапроса;
		врПакет 					= врСхема.ПакетЗапросов[0];
		врПакет.УстановитьТекстЗапроса(ТекстЗапросаПриборыУчетаДляАрхивации());
		Для Каждого врОператор из врПакет.Операторы Цикл
			НовыйПакет 				= Пакет.Операторы.Добавить(врОператор);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьСхемуПриборыУчетаДляПередачи(Схема, ПараметрыСхемы, ТаблицаДляПомещения = "") Экспорт
	ЭтоНовыйПакет 					= Истина;
	
	Если Схема = Неопределено Тогда
		Схема 						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	ИначеЕсли НЕ ПустаяСтрока(ТаблицаДляПомещения) Тогда
		Для Каждого ПакетСхемы Из Схема.ПакетЗапросов Цикл
			Если ВРег(ПакетСхемы.ТаблицаДляПомещения) = ВРег(ТаблицаДляПомещения) Тогда
				Пакет 				= ПакетСхемы;
				ЭтоНовыйПакет 		= Ложь;
				Прервать;
			КонецЕсли;			
		КонецЦикла;		
	Иначе	
		Пакет 						= Схема.ПакетЗапросов.Добавить();
	КонецЕсли; 	
	
	Если ЭтоНовыйПакет Тогда
		Пакет.УстановитьТекстЗапроса(ТекстЗапросаПриборыУчетаДляПередачи());
		Пакет.ТаблицаДляПомещения 	= ТаблицаДляПомещения;;
	Иначе
		врСхема 					= Новый СхемаЗапроса;
		врПакет 					= врСхема.ПакетЗапросов[0];
		врПакет.УстановитьТекстЗапроса(ТекстЗапросаПриборыУчетаДляПередачи());
		Для Каждого врОператор из врПакет.Операторы Цикл
			НовыйПакет 				= Пакет.Операторы.Добавить(врОператор);
		КонецЦикла;
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РеализацияИнтерефейса_Проведение

Процедура ДобавитьТекстЗапросаНомерПломбПриборовУчета(Схема, Регистры)
	
	ИмяРегистра = "энргНомерПломбПриборовУчета";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Период КАК Период,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	таблицаНомераПломб.КлючСтроки КАК МестоУстановки,
	|	таблицаНомераПломб.НомерПломбы КАК НомерПломбы,
	|	ИСТИНА КАК Состояние,
	|	ВложенныйЗапрос.ПериодРегистрации КАК ПериодРегистрации,
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	таблицаНомераПломб.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	|	таблицаНомераПломб.ЛицоУстановившееПломбу КАК ЛицоУстановившееПломбу,
	|	таблицаНомераПломб.ВидПломбы КАК ВидПломбы
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВЫБОР
	|			КОГДА НЕ табШапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА табШапка.ДатаФактическогоСобытия
	|			ИНАЧЕ табШапка.Дата
	|		КОНЕЦ КАК Период,
	|		табШапка.Организация КАК Организация,
	|		табШапка.Район КАК Район,
	|		табШапка.КлючПомещения КАК КлючПомещения,
	|		табТочкиУчета.ПриборУчета КАК ПриборУчета,
	|		табШапка.Дата КАК ПериодРегистрации,
	|		НАЧАЛОПЕРИОДА(табШапка.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления,
	|		табШапка.Ссылка КАК Ссылка,
	|		табТочкиУчета.IDСтроки КАК IDСтроки
	|	ИЗ
	|		Документ.энргОперацияСПриборомУчета КАК табШапка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСПриборомУчета.ТочкиУчета КАК табТочкиУчета
	|			ПО табШапка.Ссылка = табТочкиУчета.Ссылка
	|				И (табШапка.Ссылка В (&мДокументы))
	|				И (табТочкиУчета.Ссылка В (&мДокументы))
	|				И (табШапка.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСПриборомУчета_ВводПУ), ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ)))
	|				И (НЕ табТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|				И (НЕ табТочкиУчета.УстановленныйПУ)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
