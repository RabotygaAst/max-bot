	|					КОГДА Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|						ТОГДА Шапка.Дата
	|					ИНАЧЕ Шапка.ДатаФактическогоСобытия
	|				КОНЕЦ,
	|				ПриборыУчетаАбонента.Код,
	|				ПриборыУчетаАбонента.ТипПрибораУчета,
	|				ПриборыУчетаАбонента.РегистрируетОбъем
	|			ИЗ
	|				Документ.энргОперацияСПриборомУчета.ТочкиУчета КАК табТочкиУчета
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСПриборомУчета КАК Шапка
	|					ПО табТочкиУчета.Ссылка = Шапка.Ссылка
	|						И (Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ))
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК ПриборыУчетаАбонента
	|					ПО табТочкиУчета.ПриборУчета = ПриборыУчетаАбонента.Ссылка
	|			ГДЕ
