КонецФункции

&НаСервере
Процедура ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,Знач НовыеПриборыУчета, Знач ПриборУчета, Знач ОписаниеПрибора, Знач НомерСтроки)
		
	ЭтоНовыйПриборУчета									= НЕ НовыеПриборыУчета.Найти(НомерСтроки) = Неопределено;			
	ОписаниеОбъектаПриборУчета 							= Обработки.энргПриборыУчетаАбонентаМенеджер.ОписаниеОбъекта();
	ЗначенияРеквизитовПриборУчета						= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(ОписаниеПрибора);
	Для Каждого КлючЗначение Из ЗначенияРеквизитовПриборУчета Цикл
		Если ОписаниеОбъектаПриборУчета.Свойство(КлючЗначение.Ключ) Тогда
			ОписаниеОбъектаПриборУчета[КлючЗначение.Ключ] = КлючЗначение.Значение;
		КонецЕсли;				
	КонецЦикла;
	ОписаниеОбъектаПриборУчета.Ссылка 					= ПриборУчета;
	Если Не Обработки.энргПриборыУчетаАбонентаМенеджер.УдалосьЗаполнитьОбъектПоОписанию(ОписаниеОбъектаПриборУчета,ЭтоНовыйПриборУчета) Тогда
		Отказ											= Истина;
	КонецЕсли;	

КонецПроцедуры

&НаСервере
Процедура ПриИзмененииАбонентаСервер() 
	
	ПолучаемыеСвойства 			= "Организация,Район,КлючПомещения";
	ЗначенияРеквизитов 			= Обработки.энргАбонентыМенеджер.ЗначенияРеквизитовОбъекта(Объект.Абонент, ПолучаемыеСвойства);
	ЗаполнитьЗначенияСвойств(Объект,ЗначенияРеквизитов,ПолучаемыеСвойства);
	
	ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(Объект.КлючПомещения);
	ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);
	
	ЗаполнитьПриборыУчетаСервер();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПриборыУчетаСервер(ИдентификаторСтроки  = Неопределено)
	
	ТочкаУчета 										= Неопределено;
	СтрокаТочкиУчета 								= Неопределено;
	Если НЕ ИдентификаторСтроки = Неопределено Тогда
		СтрокаТочкиУчета 							= Объект.ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
	КонецЕсли;	
	
	ТаблицаТЧ 										= Объект.ПоказанияПриборовУчета.Выгрузить();
	
	Если СтрокаТочкиУчета = Неопределено Тогда 		
		Объект.ТочкиУчета.Очистить();
		Объект.Измерители.Очистить();
		Объект.ШкалыПриборовУчета.Очистить();
		Объект.ПоказанияПриборовУчета.Очистить();
	Иначе
		ОтборСтрок									= Новый Структура("IDСтрокиТочкиУчета", СтрокаТочкиУчета.IDСтроки);
		СтрокиШкалДляУдаления 						= Объект.ШкалыПриборовУчета.НайтиСтроки(ОтборСтрок);
		Для Индекс  = 0 По СтрокиШкалДляУдаления.ВГраница() Цикл
			СтрокаШкалы 							= СтрокиШкалДляУдаления[Индекс];
			СтрокиПоказанияДляУдаления 				= Объект.ПоказанияПриборовУчета.НайтиСтроки(Новый Структура("IDСтроки", СтрокаШкалы.IDСтроки));
			Для ИндекПоказаний = 0 По СтрокиПоказанияДляУдаления.ВГраница() Цикл
				Объект.ПоказанияПриборовУчета.Удалить(СтрокиПоказанияДляУдаления[ИндекПоказаний]);
			КонецЦикла;
			Объект.ШкалыПриборовУчета.Удалить(СтрокаШкалы);
		КонецЦикла;
		
		энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.Измерители, ОтборСтрок); 
	КонецЕсли;
	
	Если энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыФизЛиц() Тогда
		ЗаполнитьПриборыУчетаСВспомогательнымОборудованием(ТочкаУчета, ИдентификаторСтроки)
	Иначе 		
		ЗаполнитьПриборыУчетаБезВспомогательногоОборудования(ТочкаУчета, ИдентификаторСтроки);
	КонецЕсли;
	
	СоотвествиеКолонок = Новый Структура;
	СоотвествиеКолонок.Вставить("IDСтроки"		, "IDСтроки");
	СоотвествиеКолонок.Вставить("ПриборУчета"	, "ПриборУчета");
	
	ТаблицаПоказанийДляЗаполнения 		= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Район,Объект.КлючПомещения,ИдентификаторСтроки,СоотвествиеКолонок); 
	РезультатДанныеЗаполненияПоказаний 	= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Объект.Организация,Объект.Район,ТаблицаПоказанийДляЗаполнения,Объект.Дата);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, Объект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
	ЗаполнитьТекстовыеПоля();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПриборыУчетаБезВспомогательногоОборудования(ТочкаУчета, ИдентификаторСтроки)	
	Результат 										= энргСостояниеПриборовУчета.ДействующиеПриборыУчетаПомещения(Объект.Дата,Объект.Организация,Объект.Район,Объект.КлючПомещения, ТочкаУчета); 
	Выборка  										= Результат.выбрать();
	ТекТочкаУчета 									= Неопределено;
	ТекШкала 										= Неопределено;
	IDСтрокиТочки 									= Неопределено;
	IDСтрокиШкалы 									= Неопределено;
	Пока Выборка.следующий() цикл
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			Если ИдентификаторСтроки = Неопределено Тогда
				СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
				IDСтрокиТочки 						= Новый УникальныйИдентификатор;  				
				СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки; 				
				СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
				СтрокаТочкиУчета.КоэффициентПУ		= 1;
				СтрокаТочкиУчета.УстановленныйПУ 	= Истина;
			    СтрокаТочкиУчета.ЗаводскойНомер		= Выборка.ЗаводскойНомерПриборУчета;
			КонецЕсли;	
			СтрокаТочкиУчета.Услуга 				= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета			= Выборка.ПриборУчета;	
			СтрокаТочкиУчета.ВидКанальности			= Выборка.ПриборУчета.ВидКанальности;
			СтрокаТочкиУчета.ТипПрибораУчета		= Выборка.ПриборУчета.ТипПрибораУчета;
		КонецЕсли;
		
		Если НЕ ТекШкала = Выборка.Шкала Или НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			СтрокаШкалы  							= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 							= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 			= СтрокаТочкиУчета.IDСтроки;
			СтрокаШкалы.IDСтроки 					= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 						= Выборка.Шкала; 
			СтрокаШкалы.УстановленныйПУ 			= Истина;
		КонецЕсли;
		
		СтрокаПоказаний 							= Объект.ПоказанияПриборовУчета.Добавить();
		СтрокаПоказаний.Шкала                       = Выборка.Шкала;
		СтрокаПоказаний.ЕдиницаИзмерения            = Выборка.Шкала.ЕдиницаИзмерения;   
		СтрокаПоказаний.IDСтроки 					= IDСтрокиШкалы;
		СтрокаПоказаний.ТарифнаяЗона 				= Выборка.ТарифнаяЗона;
				
		ТекТочкаУчета 	= Выборка.ТочкаУчета;
		ТекШкала 		= Выборка.Шкала;
	КонецЦикла;
КонецПроцедуры

&НаСервере
