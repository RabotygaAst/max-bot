#Область ОбработчикиКомандФормы

// ВводНаОсновании
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуСоздатьНаОсновании(Команда)
	
	ВводНаОснованииКлиент.ВыполнитьПодключаемуюКомандуСоздатьНаОсновании(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры
// Конец ВводНаОсновании

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат) Экспорт
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	Если СтрНайти(ТекущаяСтраница.Имя, "Установленные") <> Неопределено Тогда
		ПрефиксУстановленных =  "Установленные";
	Иначе
		ПрефиксУстановленных = "";
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

#Область РаботаСУзлами

&НаКлиенте
Процедура ТочкиУчетаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда
		ИмяТаблицыТочек = "ТочкиУчета" + ПрефиксТочекУчета;
		ТекущиеДанные 	= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ТекущиеДанные.IDСтроки 			= Новый УникальныйИдентификатор;
		ТекущиеДанные.СредстваИзмерения = "Не заполнены";
	КонецЕсли; 
КонецПроцедуры


&НаКлиенте
Процедура ТочкиУчетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "ТочкиУчетаСредстваИзмерения" Тогда
		энргРаботаСТочкамиУчетаКлиент.ОткрытьФормуЗаполненияСредствИзмерений(энргРаботаСТочкамиУчетаКлиент.ПолучитьВходныеДанныеДляЗаполненияСредствИзмерений(ЭтотОбъект));
	КонецЕсли; 	
КонецПроцедуры 

&НаСервере
Процедура ОбновитьДанныеПоУслугамСервер(ПераметрыОбновления) Экспорт 
	энргРаботаСТочкамиУчетаСервер.ЗаполнитьДанныеТаблицРезультатаСредствИзмерений(Объект, ПераметрыОбновления.IDСтроки, ПераметрыОбновления.Результат, ПераметрыОбновления.ДанныеПУ);
	
	СтрокиТочки = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("IDСтроки", ПераметрыОбновления.IDСтроки));
	Если СтрокиТочки.Количество() > 0 Тогда 
		СтрокаТочки = СтрокиТочки[0];
		ЗаполнитьЗначенияСвойств(СтрокаТочки, ПераметрыОбновления.ДанныеПУ);
		СтрокаТочки.КоэффициентПУ = ПераметрыОбновления.Результат.КоэффициентПУ; 
		Если СтрокаТочки.Свойство("ДатаПриемки") Тогда
			СтрокаТочки.ДатаПриемки = ПераметрыОбновления.ДанныеПУ.ДатаВыпуска;
		КонецЕсли;
	КонецЕсли;
	
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета,Объект);
	
	ПоказатьУзлы();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекстовыеПоля()	
	Для Каждого ТекСтрока ИЗ Объект.ТочкиУчета Цикл
		ДанныеИзмерителей = Новый Структура("Измерители", Объект.Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекСтрока.IDСтроки)));
		энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстСредствИзмерений(ТекСтрока, ДанныеИзмерителей);
	КонецЦикла;		
КонецПроцедуры

// В дальнейшем удалится 
&НаСервере
Процедура ПоказатьУзлы()
	Если НЕ энргОбщегоНазначения.ЗначениеФункциональнойОпции("энргУзлыУчетаФизическихЛиц") Тогда
		Возврат
	КонецЕсли;
	
	ПрефиксТочекУчета 										= "";
	
	Элементы.СтраницаЕстьШкалыЕстьТарифныеЗоны.Видимость  	= Ложь;
	Элементы.СтраницаНетШкалЕстьТарифныеЗоны.Видимость  	= Ложь;
	Элементы.СтраницаЕстьШкалыНетТарифныхЗон.Видимость  	= Ложь;
	Элементы.СтраницаНетШкалНетТарифныхЗон.Видимость  		= Ложь;
	Элементы.СтраницаУслуги.Видимость  						= Истина;
КонецПроцедуры

#КонецОбласти








