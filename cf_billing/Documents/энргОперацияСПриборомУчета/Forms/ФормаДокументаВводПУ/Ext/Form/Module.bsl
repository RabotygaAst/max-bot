		КонецЕсли;		
				
		ТекТочкаУчета = Выборка.ТочкаУчета;
	КонецЦикла;
	
	//Результат 										= энргСостояниеПриборовУчета.ДействующийСоставУзлаПомещения(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения, ТочкаУчета); 
	//РезультатТУ										= Результат[Результат.Количество()-2];
	//РезультатИзмерители								= Результат[Результат.Количество()-1].Выгрузить();
	//Выборка  										= РезультатТУ.выбрать();
	//ТекТочкаУчета 									= Неопределено;
