#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет список команд отчетов.
// 
// Параметры:
//   КомандыОтчетов	-	ТаблицаЗначений	-	состав полей см. в функции МенюОтчеты.СоздатьКоллекциюКомандОтчетов.
//   Параметры		-	Структура.
//
Процедура ДобавитьКомандыОтчетов(КомандыОтчетов, Параметры= Неопределено) Экспорт

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	Поля.добавить("Номер");
	Поля.добавить("Дата");
	Поля.добавить("ВидОперации");
	СтандартнаяОбработка = Ложь; 	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	Представление 			="" + Данные.ВидОперации + " №" + Данные.номер + " от " +  Данные.дата;
	СтандартнаяОбработка 	= Ложь;
КонецПроцедуры

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка 	= Ложь;
		если Параметры.свойство("Ключ") тогда
			ВидОперации 		= Параметры.ключ.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОперацияСПриборомУчетаМКД",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		ИначеЕсли  Параметры.свойство("ЗначениеКопирования") тогда
			ВидОперации 		= Параметры.ЗначениеКопирования.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОперацияСПриборомУчетаМКД",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы; 			
		иначе
			ВыбраннаяФорма 		= "ОбщаяФорма.энргФормаВыбораОперации";
			Параметры.вставить("ИмяДокумента","энргОперацияСПриборомУчетаМКД");
			Параметры.вставить("ВыборОперации",Истина);
		КонецЕсли; 		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ИнициализироватьТаблицыДляКонтроля(ДокументСсылка, ДополнительныеСвойства) Экспорт 
	
	Схема  										= Неопределено;
	Параметры 									= Новый Структура;
	
	ДобавитьТекстЗапросаПараметрыКонтроля(Схема);
	ДобавитьТекстЗапросаКонтрольСостояниеМКД(Схема, Параметры);
		
	КлючиТаблицКонтроля  						= Новый Структура;
			
	Для Сч = 0 По Схема.ПакетЗапросов.Количество() - 1  Цикл
		Пакет 									= Схема.ПакетЗапросов[Сч];		
		Если Не ПустаяСтрока(Пакет.ТаблицаДляПомещения) И СтрНачинаетсяС(Пакет.ТаблицаДляПомещения, "Контроль") Тогда			
			КлючиТаблицКонтроля.Вставить(Прав(Пакет.ТаблицаДляПомещения,СтрДлина(Пакет.ТаблицаДляПомещения) - СтрДлина("Контроль")),Сч);			
			Пакет.ТаблицаДляПомещения 			= "";
		КонецЕсли;		
	КонецЦикла;
	ТекстСообщенияМногоквартирныйДомЗакрыт 		= НСтр("ru = 'На дату операции МКД закрыт'"); 
	
	ПараметрыЗапроса 							= Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы", 								ДокументСсылка);
	ПараметрыЗапроса.Вставить("ТекстСообщенияМногоквартирныйДомЗакрыт", 	ТекстСообщенияМногоквартирныйДомЗакрыт);
	
	ДополнительныеСвойства.Вставить("ТаблицыДляКонтроля", 					энргСхемаЗапросаСервер.ВыполнитьПакет(Схема,ПараметрыЗапроса));
	ДополнительныеСвойства.Вставить("КлючиТаблицКонтроля", 					КлючиТаблицКонтроля);
	
КонецПроцедуры

Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
		
	ПараметрыЗапроса = Новый Структура;
	Схема 			 = Неопределено;
	ИнициализироватьИсходныеДанныеДокумента(Схема);
	
	ДобавитьТекстЗапросаПриборыТочекМКД(Схема, Регистры);
	ДобавитьТекстЗапросаСостояниеПриборовМКД(Схема, Регистры);
	ДобавитьТекстЗапросаэнргВыводПриборовУчетаМКД(Схема, Регистры);
	
	ДобавитьТекстЗапросаэнргВидыДифференцированностиПриборовУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаэнргПоказанияПриборовУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаэнргКоэффциентыПриборовУчета(Схема, Регистры);
	
	ДобавитьТекстЗапросаэнргНомерПломбПриборовУчетаМКД(Схема, Регистры);	
	ДобавитьТекстЗапросаэнргДатыПоверкиПрибораУчета(Схема, Регистры); 	
	ДобавитьТекстЗапросаПриборыМОП(Схема, Регистры);
	
	ДобавитьТекстЗапросаВспомогательноеОборудованиеУзловУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаСостояниеВспомогательногоОборудованияУзловУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаДопускПриборовУчетаККоммерческомуУчетуМКД(Схема, Регистры);
	ДобавитьТекстЗапросаПараметрыИзмерителей(Схема, Регистры); 	
		
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		ВспомогательныеПараметры 	= Новый Структура;
		энргФормированиеТекстовЗапроса.УстановитьПерехватОбращенияКТаблицам(Схема, ДополнительныеСвойства.ТаблицыПодмены, ВспомогательныеПараметры); 
	КонецЕсли;
	
	ИспользоватьУзлыМКД 			= энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыМКД();
	КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	ПараметрыЗапроса 				= Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы", 					ДокументСсылка); 	
	ПараметрыЗапроса.Вставить("ПустойУникальныйИдентификатор", 	ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	ПараметрыЗапроса.Вставить("ИспользоватьУзлыМКД", 			ИспользоватьУзлыМКД);
			
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		энргСхемаЗапросаСервер.ВыполнитьПакет(Схема,ПараметрыЗапроса));
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияДанныхДокумента

Процедура ИнициализироватьИсходныеДанныеДокумента(Схема)
	ПолучитьШапкуДокумента(Схема);
	ПолучитьТаблицуТочекУчета(Схема);
	ПолучитьТаблицуИзмерителей(Схема);
	ПолучитьТаблицуШкалыПриборовУчета(Схема);
КонецПроцедуры

Процедура ПолучитьШапкуДокумента(Схема)
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	Шапка.Дата КАК Дата,
	|	Шапка.ДатаФактическогоСобытия КАК ДатаФактическогоСобытия,
	|	Шапка.Организация КАК Организация,
	|	Шапка.ПериодНачисления КАК ПериодНачисления,
	|	Шапка.Район КАК Район,
	|	Шапка.МКД КАК МКД,
	|	Шапка.ВидОперации КАК ВидОперации,
	|	Шапка.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ШапкаДокумента
	|ИЗ
	|	Документ.энргОперацияСПриборомУчетаМКД КАК Шапка
	|ГДЕ
	|	Шапка.Ссылка В(&мДокументы)");
	
КонецПроцедуры  

Процедура ПолучитьТаблицуТочекУчета(Схема)
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.Ссылка КАК Ссылка,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.IDСтроки КАК IDСтроки,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.IDСтрокиВывод КАК IDСтрокиВывод,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.ДатаПоверкиСчетчика КАК ДатаПоверкиСчетчика,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.ДатаПриемки КАК ДатаПриемки,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.ДатаУстановкиСчетчика КАК ДатаУстановкиСчетчика,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.КоэффициентПУ КАК КоэффициентПУ,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.НетВозможностьУстановкиПУ КАК НетВозможностьУстановкиПУ,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.НомерПломбы КАК НомерПломбы,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.ПриборУчетаВывод КАК ПриборУчетаВывод,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.Услуга КАК Услуга,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.УзелУчета КАК УзелУчета,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.ТипУзлаУчета КАК ТипУзлаУчета,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.КонецДействияКоммерскогоУчета КАК КонецДействияКоммерскогоУчета,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.ВидПараметра КАК ВидПараметра,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.РегистрируетОбъем КАК РегистрируетОбъем,
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.НазначениеПУ КАК НазначениеПУ
	|ПОМЕСТИТЬ ТаблицаТочекУчета
	|ИЗ
	|	Документ.энргОперацияСПриборомУчетаМКД.ТочкиУчета КАК энргОперацияСПриборомУчетаМКДТочкиУчета
	|ГДЕ
	|	энргОперацияСПриборомУчетаМКДТочкиУчета.Ссылка В(&мДокументы)");	
КонецПроцедуры

Процедура ПолучитьТаблицуИзмерителей(Схема)
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.Ссылка КАК Ссылка,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.IDСтроки КАК IDСтроки,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.IDСтрокиШкалы КАК IDСтрокиШкалы,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.ДатаВыпуска КАК ДатаВыпуска,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.ДатаПоверкиСчетчика КАК ДатаПоверкиСчетчика,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.КонецДействияКоммерскогоУчета КАК КонецДействияКоммерскогоУчета,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.КоэффициентПУ КАК КоэффициентПУ,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.НомерПломбы КАК НомерПломбы,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.ПриборУчета КАК ПриборУчета,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.РегистрируетОбъем КАК РегистрируетОбъем,
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.ТипПрибораУчета КАК ТипПрибораУчета,
	|	ИСТИНА КАК ВспомогательноеОборудование,
	|	NULL КАК КодАСКУЭ,
	|	NULL КАК СобственникАСКУЭ,
	|	NULL КАК ДатаИнтеграцииССистемой,
	|	NULL КАК СистемаУчетаЭлектроэнергии,
	|	NULL КАК ТипИзмерителя,
	|	NULL КАК ЗаводскойНомер,
	|	NULL КАК ДоступКПУ,
	|	NULL КАК ДатаУстановки,
	|	NULL КАК ДатаОчереднойПоверки,
	|	NULL КАК СобственникСИ,
	|	NULL КАК Фаза,
	|	NULL КАК Вывод,
	|	NULL КАК Ввод,
	|	NULL КАК БалансоваяПринадлежность
	|ПОМЕСТИТЬ ТаблицаИзмерителей
	|ИЗ
	|	Документ.энргОперацияСПриборомУчетаМКД.ПриборыУзловУчета КАК энргОперацияСПриборомУчетаМКДПриборыУзловУчета
	|ГДЕ
	|	энргОперацияСПриборомУчетаМКДПриборыУзловУчета.Ссылка В(&мДокументы)
	|	И НЕ &ИспользоватьУзлыМКД
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргОперацияСПриборомУчетаМКДИзмерители.Ссылка,
	|	энргОперацияСПриборомУчетаМКДИзмерители.IDСтрокиТочкиУчета,
	|	энргОперацияСПриборомУчетаМКДИзмерители.IDСтроки,
	|	энргОперацияСПриборомУчетаМКДИзмерители.ДатаВыпуска,
	|	энргОперацияСПриборомУчетаМКДИзмерители.ДатаПоверкиСчетчика,
	|	энргОперацияСПриборомУчетаМКДИзмерители.ДатаУстановкиПломбы,
	|	энргОперацияСПриборомУчетаМКДИзмерители.КонецДействияКоммерскогоУчета,
	|	энргОперацияСПриборомУчетаМКДИзмерители.КоэффициентПУ,
	|	энргОперацияСПриборомУчетаМКДИзмерители.НачалоДействияКоммерскогоУчета,
	|	энргОперацияСПриборомУчетаМКДИзмерители.НомерПломбы,
	|	энргОперацияСПриборомУчетаМКДИзмерители.ПриборУчета,
	|	энргОперацияСПриборомУчетаМКДИзмерители.РасположениеИзмерителя,
	|	энргОперацияСПриборомУчетаМКДИзмерители.РегистрируетОбъем,
	|	энргОперацияСПриборомУчетаМКДИзмерители.ТипПрибораУчета,
	|	энргОперацияСПриборомУчетаМКДИзмерители.ВспомогательноеОборудование,
	|	энргОперацияСПриборомУчетаМКДИзмерители.КодАСКУЭ,
