	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  		= 	
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Период КАК Период,
	|	ВложенныйЗапрос.ПриборУчета КАК Измеритель,
	|	ТаблицаШкал.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ВидПараметра КАК ВидПараметра,
	|	ВложенныйЗапрос.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	ЗНАЧЕНИЕ(Перечисление.бестТипыТемператур.ПустаяСсылка) КАК ТипТемпературы
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.Период КАК Период,
	|		ВложенныйЗапрос.Организация КАК Организация,
	|		ВложенныйЗапрос.Район КАК Район,
	|		ВложенныйЗапрос.МКД КАК МКД,
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		ВложенныйЗапрос.УзелУчета КАК УзелУчета,
	|		ТаблицаПриборыУзловУчета.ТипПрибораУчета.Родитель КАК ТипИзмерителя,
	|		ТаблицаПриборыУзловУчета.ПриборУчета КАК ПриборУчета,
	|		ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|		ВложенныйЗапрос.ПериодРегистрации КАК ПериодРегистрации,
	|		ТаблицаПриборыУзловУчета.IDСтроки КАК IDСтрокиШкалы,
	|		ЗНАЧЕНИЕ(Справочник.бестВидыПараметровИзмерителей.ПустаяСсылка) КАК ВидПараметра,
	|		ТаблицаПриборыУзловУчета.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|		ВложенныйЗапрос.Ссылка КАК Ссылка
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ВЫБОР
	|				КОГДА НЕ Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА Шапка.ДатаФактическогоСобытия
	|				ИНАЧЕ Шапка.Дата
	|			КОНЕЦ КАК Период,
	|			Шапка.Организация КАК Организация,
	|			Шапка.Район КАК Район,
	|			Шапка.МКД КАК МКД,
	|			табТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|			табТочкиУчета.ПриборУчета КАК УзелУчета,
	|			Шапка.Дата КАК ПериодРегистрации,
	|			Шапка.ПериодНачисления КАК ПериодНачисления,
	|			Шапка.Ссылка КАК Ссылка,
	|			табТочкиУчета.IDСтроки КАК IDСтроки
	|		ИЗ
	|			ШапкаДокумента КАК Шапка
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК табТочкиУчета
	|				ПО Шапка.Ссылка = табТочкиУчета.Ссылка
	|					И (Шапка.Ссылка В (&мДокументы))
	|					И (табТочкиУчета.Ссылка В (&мДокументы))
	|				И (Шапка.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСПриборомУчетаМКД_ВводПУ), ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСПриборомУчетаМКД_ЗаменаПУ)))
	|					И (НЕ табТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаИзмерителей КАК ТаблицаПриборыУзловУчета
	|			ПО ВложенныйЗапрос.Ссылка = ТаблицаПриборыУзловУчета.Ссылка
	|				И ВложенныйЗапрос.IDСтроки = ТаблицаПриборыУзловУчета.IDСтроки
	|				И (ТаблицаПриборыУзловУчета.Ссылка В (&мДокументы))
	|				И (НЕ ТаблицаПриборыУзловУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаШкалыПриборовУчета КАК ТаблицаШкал
	|		ПО ВложенныйЗапрос.Ссылка = ТаблицаШкал.Ссылка
	|			И ВложенныйЗапрос.IDСтрокиШкалы = ТаблицаШкал.IDСтроки
