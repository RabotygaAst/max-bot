&НаКлиенте
Процедура ДобавитьПриборыУчета(Команда) 
	
	ТекущиеДанные = Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураОтвета = энргРаботаСПриборамиУчетаКлиент.ВернутьНачальныеПараметрыПередачиДляУзлов(ЭтаФорма, ТекущиеДанные, Объект);
	ПолучитьДанныеТабЧастей(СтруктураОтвета.ПараметрыПередачи,ТекущиеДанные.IDСтроки,ТекущиеДанные.ТипУзлаУчета,ТекущиеДанные.НачалоДействияКоммерскогоУчета,ТекущиеДанные.КонецДействияКоммерскогоУчета);
	энргРаботаСПриборамиУчетаКлиент.ДобавитьПриборыУчета(СтруктураОтвета);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеТабЧастей(ПараметрыПередачи,IDСтроки,ТипУзлаУчета,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета) 	
	энргРаботаСприборамиУчетаСервер.ПолучитьДанныеТабЧастейУзла(ПараметрыПередачи, IDСтроки, Объект,ТипУзлаУчета,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета);
КонецПроцедуры

#КонецОбласти

&НаСервере
Функция ВернутьУзелУчета(ТочкаУчета)  	
	
	Ответ = Новый Структура("ПриборУчета, ТипУзлаУчета, НазначениеПУ",Справочники.энргПриборыУчетаАбонента.ПустаяСсылка(),Справочники.энргТипыПриборовУчета.ПустаяСсылка(), Перечисления.энргНазначениеПУ.ПустаяСсылка());
	
	Запрос = Новый Запрос;	
	Запрос.УстановитьПараметр("Организация",	Объект.Организация);
	Запрос.УстановитьПараметр("Район",			Объект.Район);
	Запрос.УстановитьПараметр("МКД",			Объект.МКД);	
	Запрос.УстановитьПараметр("ТочкаУчета",		ТочкаУчета);
	Запрос.УстановитьПараметр("Период",			?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия),КонецДня(Объект.ДатаФактическогоСобытия),Объект.Дата));
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка) КАК ПриборУчета,
		|	энргПриборыТочекМКДСрезПоследних.ПриборУчета КАК УдалитьПриборУчета,
		|	энргПриборыТочекМКДСрезПоследних.ПриборУчета.ТипУзлаУчета КАК ТипУзлаУчета,
		|	ВЫБОР
		|		КОГДА НЕ энргПриборыМОП.ПриборУчета ЕСТЬ NULL
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргНазначениеПУ.МОП)
		|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргНазначениеПУ.ОДПУ)
		|	КОНЕЦ КАК НазначениеПУ
		|ИЗ
		|	РегистрСведений.энргПриборыТочекМКД.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И МКД = &МКД
		|				И ТочкаУчета = &ТочкаУчета) КАК энргПриборыТочекМКДСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргПриборыМОП КАК энргПриборыМОП
		|		ПО энргПриборыТочекМКДСрезПоследних.Организация = энргПриборыМОП.Организация
		|			И энргПриборыТочекМКДСрезПоследних.Район = энргПриборыМОП.Район
		|			И энргПриборыТочекМКДСрезПоследних.МКД = энргПриборыМОП.МКД
		|			И энргПриборыТочекМКДСрезПоследних.ТочкаУчета = энргПриборыМОП.ТочкаУчета
		|			И энргПриборыТочекМКДСрезПоследних.ПриборУчета = энргПриборыМОП.ПриборУчета";
	
	РезультатЗапроса 	= Запрос.Выполнить(); 	
	Выборка 			= РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Ответ,Выборка); 		
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

#КонецОбласти


#Область РаботаСУзлами 

&НаКлиенте
Процедура ТочкиУчетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "ТочкиУчетаСредстваИзмерения" Тогда
		энргРаботаСТочкамиУчетаКлиент.ОткрытьФормуЗаполненияСредствИзмерений(энргРаботаСТочкамиУчетаКлиент.ПолучитьВходныеДанныеДляЗаполненияСредствИзмерений(ЭтотОбъект));
	КонецЕсли; 	
КонецПроцедуры 

&НаСервере
Процедура ОбновитьДанныеПоУслугамСервер(ПераметрыОбновления) Экспорт 
	энргРаботаСТочкамиУчетаСервер.ЗаполнитьДанныеТаблицРезультатаСредствИзмерений(Объект, ПераметрыОбновления.IDСтроки, ПераметрыОбновления.Результат, ПераметрыОбновления.ДанныеПУ);
	//энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект, Объект);
	ПоказатьУзлы();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекстовыеПоля()	
	
	Для Каждого ТекСтрока ИЗ Объект.ТочкиУчета Цикл
		ДанныеИзмерителей = Новый Структура("Измерители", Объект.Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекСтрока.IDСтроки)));
		энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстСредствИзмерений(ТекСтрока, ДанныеИзмерителей);
	КонецЦикла;	
	
КонецПроцедуры

// В дальнейшем удалится 
&НаСервере
Процедура ПоказатьУзлы()
	
	Если НЕ энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыМКД() Тогда
		Возврат
	КонецЕсли;
	
	ПрефиксТочекУчета = "";
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаУслуги", "Видимость", Истина);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаДобавитьПриборыУчета", "Видимость", Ложь);	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаЕстьШкалыЕстьТарифныеЗоны", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаНетШкалЕстьТарифныеЗоны", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаЕстьШкалыНетТарифныхЗон", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаНетШкалНетТарифныхЗон", "Видимость", Ложь);	
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТочкаУчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	энргПользовательскийВводКлиент.НачалоВыбораТочкиУчета(Элемент, Новый Структура("ТочкиСПриборами", Ложь));
КонецПроцедуры

#КонецОбласти
