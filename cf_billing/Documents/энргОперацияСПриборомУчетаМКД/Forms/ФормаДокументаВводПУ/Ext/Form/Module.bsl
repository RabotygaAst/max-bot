		ДанныеУзлаУчета 		= ВернутьУзелУчета(ТекущиеДанные.ТочкаУчета);
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, ДанныеУзлаУчета);
	Иначе
		ТекущиеДанные.Услуга 		= ПредопределенноеЗначение("Справочник.энргВидыУслуг.ПустаяСсылка");
		ТекущиеДанные.ПриборУчета 	= ПредопределенноеЗначение("Справочник.энргПриборыУчетаАбонента.ПустаяСсылка");		
		ТекущиеДанные.ТипУзлаУчета 	= ПредопределенноеЗначение("Справочник.энргТипыПриборовУчета.ПустаяСсылка");		
		ТекущиеДанные.НазначениеПУ 	= ПредопределенноеЗначение("Перечисление.энргНазначениеПУ.ПустаяСсылка");		
	КонецЕсли;
		
