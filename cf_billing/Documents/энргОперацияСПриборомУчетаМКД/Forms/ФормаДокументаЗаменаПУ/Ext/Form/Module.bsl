&НаКлиенте
Процедура ШкалыУслугШкалаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	ВидКанальности 							= ТекущиеДанные.ВидКанальности;
	СоставКанальности 						= энргРаботаСТочкамиУчетаСервер.СоставКанальности(ВидКанальности);
	Элемент.СписокВыбора.ЗагрузитьЗначения(СоставКанальности);
КонецПроцедуры

&НаКлиенте
Процедура ФормулыРасчетаУслугПриИзменении(Элемент)
	
	ИмяТаблицыТочек 					= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ИмяТаблицыФормул 						= "ФормулыРасчетаУслуг" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыФормул].ТекущиеДанные;
	Если ИмяТаблицыФормул = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ТекущиеДанные.IDСтроки = ТекДанные.IDСтроки;
КонецПроцедуры

&НаКлиенте
Процедура ФормулыРасчетаУслугУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ИмяТаблицыТочек		= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные		= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	СоставУслуги		= энргРаботаСПоставщикамиСервер.ПолучитьСоставУслуги(ТекущиеДанные.Услуга);
	Элемент.СписокВыбора.ЗагрузитьЗначения(СоставУслуги);
КонецПроцедуры

&НаКлиенте
Процедура ФормулыРасчетаУслугФормулаРасчетаПредставлениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанныеТочкиУчета 	= Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	ТекущиеДанные 				= Элементы["ФормулыРасчетаУслуг" + ПрефиксТочекУчета].ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено ИЛИ  ТекущиеДанныеТочкиУчета = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СоставУслуги 				= энргРаботаСПоставщикамиСервер.ПолучитьСоставУслуги(ТекущиеДанныеТочкиУчета.Услуга);
	
	Шкалы		 				= Новый Массив;
	
	Для Каждого СтрокаШкалы Из Объект.ШкалыПриборовУчета Цикл
		Если НЕ ТекущиеДанныеТочкиУчета.IDСтроки  = СтрокаШкалы.IDСтрокиТочкиУчета Тогда
			Продолжить;
		КонецЕсли;
		Шкалы.Добавить(СтрокаШкалы.Шкала);
	КонецЦикла;
	
	Оповещение 					= Новый ОписаниеОповещения("НастройкаФормулыРасчетаЗавершение",ЭтаФорма,Новый Структура("КлючСтроки", Элементы.ФормулыРасчетаУслугЕстьШкалыЕстьТарифныеЗоны.ТекущаяСтрока));
	ПараметрыФормы 				= Новый Структура;
	ПараметрыФормы.Вставить("Услуга", 					ТекущиеДанные.Услуга);
	ПараметрыФормы.Вставить("СоставУслуги", 			СоставУслуги);
	ПараметрыФормы.Вставить("Шкалы", 					Шкалы);
	ПараметрыФормы.Вставить("ПредставлениеФормулы", 	ТекущиеДанные.ФормулаРасчетаПредставление);
	
	ОткрытьФорму("ОбщаяФорма.энргНастройкаФормулРасчета",ПараметрыФормы,,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаФормулыРасчетаЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт 
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТипЗнч(РезультатЗакрытия) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не РезультатЗакрытия.Свойство("ПредставлениеФормулы") ИЛИ Не РезультатЗакрытия.Свойство("ФормулаРасчета") Тогда
		Возврат;
	КонецЕсли;
	
	КлючСтроки  								= ДополнительныеПараметры.КлючСтроки;
	ТекущиеДанные  								= Объект.ФормулыРасчетаУслуг.НайтиПоИдентификатору(КлючСтроки);
	ТекущиеДанные.ФормулаРасчетаПредставление 	= РезультатЗакрытия.ПредставлениеФормулы;
	ТекущиеДанные.ФормулаРасчета 				= РезультатЗакрытия.ФормулаРасчета;
	
КонецПроцедуры

