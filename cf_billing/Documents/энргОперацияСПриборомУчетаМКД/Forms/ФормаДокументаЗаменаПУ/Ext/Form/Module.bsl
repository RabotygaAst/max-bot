			СтрокаТочкиУчета.IDСтроки 				= IDСтрокиТочки;
			СтрокаТочкиУчета.IDСтрокиВывод 			= IDСтрокиТочкиВывод;
			СтрокаТочкиУчета.РегистрируетОбъемВывод = Выборка.РегистрируетОбъем;
			
			СтрокаИзмерителя 								= Объект.Измерители.Добавить();
			СтрокаИзмерителя.IDСтроки 						= Новый УникальныйИдентификатор;
			СтрокаИзмерителя.IDСтрокиТочкиУчета 			= IDСтрокиТочкиВывод;
			СтрокаИзмерителя.ПриборУчета 					= СтрокаТочкиУчета.ПриборУчетаВывод;
			СтрокаИзмерителя.ВспомогательноеОборудование 	= Ложь;
			СтрокаИзмерителя.ТипПрибораУчета       			= Выборка.ТипПрибораУчета;
			СтрокаИзмерителя.РасположениеИзмерителя			= Выборка.РасположениеИзмерителя; 			
			СтрокаИзмерителя.ТипИзмерителя					= Выборка.ТипИзмерителя;
			СтрокаИзмерителя.Вывод							= Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.Шкала) И (НоваяТочка Или НЕ ТекШкала = Выборка.Шкала) Тогда
			СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочкиВывод;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
			СтрокаШкалы.Вывод 					= Истина;
		КонецЕсли;

		Если ЗначениеЗаполнено(Выборка.ТарифнаяЗона) Тогда
			СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
			СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
			СтрокаПоказаний.IDСтрокиТочкиУчета 		= IDСтрокиТочкиВывод;
			СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
			СтрокаПоказаний.Вывод 					= Истина;
		КонецЕсли;
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекШкала 								= Выборка.Шкала;
		ТекПрибор 								= Выборка.ПриборУчета;
	КонецЦикла; 
	
	СоотвествиеКолонок  						= Новый Структура;
	СоотвествиеКолонок.Вставить("IDСтроки"		, "IDСтрокиВывод");
	СоотвествиеКолонок.Вставить("ПриборУчета"	, "ПриборУчетаВывод");

	//энргРаботаСПоказаниямиПриборовУчетаСервер.ОбновитьПоказанияПриборовУчетаМКД(Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Дата,Объект.Организация,Объект.Район,Объект.МКД,Ложь,Неопределено,СоотвествиеКолонок);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ОбновитьПоказанияПриборовУчетаМКД(Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Дата,Объект.Организация,Объект.Район,Объект.МКД,Ложь,,СоотвествиеКолонок);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект,Объект,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета);		
	
	ЗаполнитьТекстовыеПоля();
КонецПроцедуры

#Область ВЫБОР_ТИПА_ПУ

&НаКлиенте
Процедура ОткрытьВыборТипаПУ(СтандартнаяОбработка)
	
	ИмяТаблицыТочек 	= "ТочкиУчета" + ПрефиксТочекУчета;	
	ТекущиеДанные 		= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	Соответсвие = новый Соответствие;
	Соответсвие.Вставить("ТипУзлаУчета",ПредопределенноеЗначение("Справочник.энргТипыУзловУчета.ПустаяСсылка"));
	энргОбщегоНазначения.ПолучитьЗначенияРеквизитов(,ТекущиеДанные.УзелУчета,Соответсвие);
	
	ТипУзлаУчета = Соответсвие["ТипУзлаУчета"];
	Если ЗначениеЗаполнено(ТипУзлаУчета) Тогда 
		КолвоСостава = ПолучитьКолвоСоставаУзла(ТипУзлаУчета);
		
		Если КолвоСостава > 0 Тогда 	
			
			СоответсвиеТипа = новый Соответствие;
			СоответсвиеТипа.Вставить("ТипПрибораУчета","");
			энргОбщегоНазначения.ПолучитьЗначенияРеквизитов(,ТекущиеДанные.ПриборУчетаВывод,СоответсвиеТипа);
			
			СоответсвиеРод = новый Соответствие;
			СоответсвиеРод.Вставить("Родитель","");
			энргОбщегоНазначения.ПолучитьЗначенияРеквизитов(,СоответсвиеТипа["ТипПрибораУчета"],СоответсвиеРод);			
			
			СтандартнаяОбработка = Ложь;
			СтруктураОтбора = Новый Структура("Родитель",СоответсвиеРод["Родитель"]);			
			ПараметрыВыбораФормы	= Новый Структура("Отбор", СтруктураОтбора);
			ОписаниеОповещения 		= Новый ОписаниеОповещения("ТипПрибораУчетаОкончаниеВыбора",ЭтаФорма,Новый Структура("ТекДанные", ТекущиеДанные));
			
			Форма 					= ОткрытьФорму("Справочник.энргТипыПриборовУчета.ФормаВыбора",ПараметрыВыбораФормы,,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			Форма.Элементы.Список.Отображение = ОтображениеТаблицы.Список;   			
			
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ТипПрибораУчетаОкончаниеВыбора(Результат,ДополнительныеПараметры) Экспорт  
	
	Если Результат <> Неопределено Тогда 
		ТекДанные					= ДополнительныеПараметры.ТекДанные;
		ТекДанные.ТипПрибораУчета	= Результат;		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКолвоСоставаУзла(ТипУзлаУчета)
	Возврат ТипУзлаУчета.СоставУзла.Количество();
КонецФункции

#КонецОбласти

#Область РаботаСУзламиУчета

&НаСервере
Процедура УстановитьВидимостьУзловУчета()
	
	ИспользоватьУзлы = энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыМКД();
	Если НЕ ИспользоватьУзлы Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаСредстваИзмеренияВывод"	, "Видимость", ИспользоватьУзлы);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаСредстваИзмерения"		, "Видимость", ИспользоватьУзлы);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницыШкалыТарифныеЗоны"			, "Видимость", Ложь);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеПоУслугамСервер(ПараметрыОбновления) Экспорт 
	ДанныеОчистки = Новый Структура;
	ДанныеОчистки.Вставить("Измерители"				, Новый Структура("IDСтрокиТочкиУчета,Вывод",ПараметрыОбновления.IDСтроки, Ложь));
	ДанныеОчистки.Вставить("ШкалыПриборовУчета"		, Новый Структура("IDСтрокиТочкиУчета,Вывод",ПараметрыОбновления.IDСтроки, Ложь));
	ДанныеОчистки.Вставить("ПоказанияПриборовУчета"	, Новый Структура("IDСтрокиТочкиУчета,Вывод",ПараметрыОбновления.IDСтроки, Ложь));
	
	энргРаботаСТочкамиУчетаСервер.ЗаполнитьДанныеТаблицРезультатаСредствИзмерений(Объект, ПараметрыОбновления.IDСтроки, ПараметрыОбновления.Результат, ПараметрыОбновления.ДанныеПУ,ДанныеОчистки);
	ТекСтрока 					= Объект.ТочкиУчета.НайтиСтроки(Новый Структура("IDСтроки", ПараметрыОбновления.IDСтроки));
	ТекСтрока[0].КоэффициентПУ 	= ПараметрыОбновления.Результат.КоэффициентПУ;
	Если ПараметрыОбновления.Результат.ШкалыПриборовУчета.Количество() > 0 Тогда 
		ТекСтрока[0].ВидДифференцированности 	= ПараметрыОбновления.Результат.ШкалыПриборовУчета[0].ВидДифференцированности;
	КонецЕсли;
	ЗаполнитьТекстовыеПоля(ПараметрыОбновления.IDСтроки);
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеПоУслугамСерверВывод(ПараметрыОбновления) Экспорт 
	ДанныеОчистки = Новый Структура;
	ДанныеОчистки.Вставить("Измерители"				, Новый Структура("IDСтрокиТочкиУчета,Ввод"	, ПараметрыОбновления.IDСтроки, Ложь));
	ДанныеОчистки.Вставить("ШкалыПриборовУчета"		, Новый Структура("IDСтрокиТочкиУчета,Вывод", ПараметрыОбновления.IDСтроки, Истина));
	ДанныеОчистки.Вставить("ПоказанияПриборовУчета"	, Новый Структура("IDСтрокиТочкиУчета,Вывод", ПараметрыОбновления.IDСтроки, Истина));
	энргРаботаСТочкамиУчетаСервер.ЗаполнитьДанныеТаблицРезультатаСредствИзмерений(Объект, ПараметрыОбновления.IDСтроки, ПараметрыОбновления.Результат, ПараметрыОбновления.ДанныеПУ,ДанныеОчистки);
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("IDСтрокиВывод", ПараметрыОбновления.IDСтроки);
	мСтрокаТУ 		= Объект.ТочкиУчета.НайтиСтроки(ПараметрыОтбора);
	СтрокаТУ 		= мСтрокаТУ[0]; 
	Если СтрокаТУ.ПриборУчета = СтрокаТУ.ПриборУчетаВывод Тогда
		Для каждого стр из ПараметрыОбновления.Результат.Измерители Цикл
			Если стр.Вывод И НЕ стр.ВспомогательноеОборудование Тогда
				СтрокаТУ.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПустаяСсылка();
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ЗаполнитьТекстовыеПоля(ПараметрыОбновления.IDСтроки, "IDСтрокиВывод");
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекстовыеПоля(IDСтрокиТочкиУчета = Неопределено, ИмяIDСтроки = "IDСтроки")	
	Если IDСтрокиТочкиУчета = Неопределено Тогда
		СтрокиТЧ = Объект.ТочкиУчета;
	Иначе
		СтрокиТЧ = Объект.ТочкиУчета.НайтиСтроки(Новый Структура(ИмяIDСтроки, IDСтрокиТочкиУчета));
	КонецЕсли;
	
	Для Каждого ТекСтрока ИЗ СтрокиТЧ Цикл
		ДанныеИзмерителейВывод = Объект.Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета, Вывод", ТекСтрока.IDСтрокиВывод, Истина));
		Если ДанныеИзмерителейВывод.Количество() = 0 Тогда
			ТекСтрока.СредстваИзмеренияВывод = "Не заполнено";
		Иначе
			ТекСтрока.СредстваИзмеренияВывод = "Заполнено";
		КонецЕсли;
		
		ДанныеИзмерителейВвод = Объект.Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", ТекСтрока.IDСтроки));
		Если ДанныеИзмерителейВвод.Количество() = 0 Тогда
			ТекСтрока.СредстваИзмерения = "Не заполнено";
		Иначе
			ТекСтрока.СредстваИзмерения = "Заполнено";
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры


#Область ЗаполнениеСвойствПриборовУчета

&НаСервере
Процедура ЗаполнитьСвойстваПриборовУчета(Знач ТекущийОбъект)
	
	Перем мПриборыУчета, ПолучаемыеСвойстваПриборовУчета, СвойстваПриборовУчета;
	
	ПолучаемыеСвойстваПриборовУчета = ПолучаемыеСвойстваПриборовУчета();	
	мПриборыУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.ТочкиУчета.Выгрузить().ВыгрузитьКолонку("ПриборУчета"));
	СвойстваПриборовУчета 			= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектов(мПриборыУчета, ПолучаемыеСвойстваПриборовУчета);
	ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Объект.ТочкиУчета, СвойстваПриборовУчета);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваИзмерителей(Знач ТекущийОбъект)
	
	Перем мПриборыУчета, ПолучаемыеСвойстваПриборовУчета, СвойстваПриборовУчета;
	
	ПолучаемыеСвойстваПриборовУчета = ПолучаемыеСвойстваПриборовУчета();	
	мПриборыУчета 					= ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущийОбъект.Измерители.Выгрузить().ВыгрузитьКолонку("ПриборУчета"));
	СвойстваПриборовУчета 			= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектов(мПриборыУчета, ПолучаемыеСвойстваПриборовУчета);
	ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Объект.Измерители, СвойстваПриборовУчета, Истина);
	
КонецПроцедуры


&НаСервере
Процедура ЗаполнитьДанныеФормыПоСвойствамПриборовУчета(Коллекция, СвойстваПриборовУчета, ПроверятьПолеВывод = Ложь) 
	
	СоотвествиеРеквизитовСвойств 								= энргРаботаСприборамиУчетаСервер.СоотвествиеРеквизитовСвойствамПрибораУчета();
	
	Для Каждого СтрокаКоллекции Из Коллекция Цикл
		Если ПроверятьПолеВывод И СтрокаКоллекции.Вывод Тогда 
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаКоллекции.ПриборУчета) Тогда
			СвойстваПрибора 									= СвойстваПриборовУчета[СтрокаКоллекции.ПриборУчета];		
		Иначе
			СвойстваПрибора 									= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(СтрокаКоллекции.ОписаниеПрибора);
		КонецЕсли;
		
		Если СвойстваПрибора = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого КлючЗначение Из СоотвествиеРеквизитовСвойств Цикл
			Если СтрокаКоллекции.Свойство(КлючЗначение.Ключ) И СвойстваПрибора.Свойство(КлючЗначение.Значение) Тогда
				СтрокаКоллекции[КлючЗначение.Ключ] 	= СвойстваПрибора[КлючЗначение.Значение];
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла; 	
	
КонецПроцедуры

&НаСервере
Функция ПолучаемыеСвойстваПриборовУчета() 
	Возврат энргРаботаСприборамиУчетаСервер.ПолучаемыеСвойстваПриборовУчета();	
КонецФункции

#КонецОбласти


&НаСервере
Процедура ЗаписатьПараметрыТочекИПриборовУчета(ТекущийОбъект, СоответствиеСтрок)
	
	Сч 														= 0;
	Для Каждого СтрокаТочки Из Объект.ТочкиУчета Цикл
		ЗаписываемаяСтрока  								= ТекущийОбъект.ТочкиУчета[Сч];
		
		СвойстваПрибора 									= энргРаботаСприборамиУчетаСервер.ПолучаемыеСвойстваПриборовУчета();
		ДанныеПрибораУчета 									= Новый Структура(СвойстваПрибора);
		СоотвествиеРеквизитов 								= энргРаботаСприборамиУчетаСервер.СоотвествиеРеквизитовСвойствамПрибораУчета();
		Для Каждого КлючЗначение Из СоотвествиеРеквизитов Цикл
			Если НЕ СтрокаТочки.Свойство(КлючЗначение.Ключ) Тогда
				Продолжить;
			КонецЕсли;
			
			ДанныеПрибораУчета[КлючЗначение.Значение] 		= СтрокаТочки[КлючЗначение.Ключ];						
		КонецЦикла;
		ЗаписываемаяСтрока.ОписаниеПрибора 					= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектаВСтрокуJSON(ДанныеПрибораУчета);
		
		СоответствиеСтрок.Вставить(СтрокаТочки.IDСтроки, СтрокаТочки.ЗаводскойНомер);
		Сч 													= Сч + 1;		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,Знач НовыеПриборыУчета, Знач ПриборУчета, Знач ОписаниеПрибора, Знач НомерСтроки)		
	ЭтоНовыйПриборУчета									= НЕ НовыеПриборыУчета.Найти(НомерСтроки) = Неопределено;			
	ОписаниеОбъектаПриборУчета 							= Обработки.энргПриборыУчетаАбонентаМенеджер.ОписаниеОбъекта();
	ЗначенияРеквизитовПриборУчета						= Обработки.энргПриборыУчетаАбонентаМенеджер.ЗначенияРеквизитовОбъектовИзСтрокиJSON(ОписаниеПрибора);
	Для Каждого КлючЗначение Из ЗначенияРеквизитовПриборУчета Цикл
		Если ОписаниеОбъектаПриборУчета.Свойство(КлючЗначение.Ключ) Тогда
			ОписаниеОбъектаПриборУчета[КлючЗначение.Ключ] = КлючЗначение.Значение;
		КонецЕсли;				
	КонецЦикла;
	ОписаниеОбъектаПриборУчета.Ссылка 					= ПриборУчета;
	Если Не Обработки.энргПриборыУчетаАбонентаМенеджер.УдалосьЗаполнитьОбъектПоОписанию(ОписаниеОбъектаПриборУчета,ЭтоНовыйПриборУчета) Тогда
		Отказ											= Истина;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#КонецОбласти