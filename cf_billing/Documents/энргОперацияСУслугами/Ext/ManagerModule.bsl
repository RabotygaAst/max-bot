Процедура ДобавитьТекстЗапросаАбонентыПомещений(Схема, Регистры)
	
	ИмяРегистра = "энргАбонентыПомещений";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса( 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫБОР
	|		КОГДА НЕ Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА Шапка.ДатаФактическогоСобытия
	|		ИНАЧЕ Шапка.Дата
	|	КОНЕЦ КАК Период,
	|	Шапка.Организация КАК Организация,
	|	Шапка.Район КАК Район,
	|	Шапка.КлючПомещения КАК КлючПомещения,
	|	табТочкиУчета.Услуга КАК Услуга,
	|	Шапка.Абонент КАК Абонент,
	|	Шапка.Дата КАК ПериодРегистрации,
	|	НАЧАЛОПЕРИОДА(Шапка.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления
	|ПОМЕСТИТЬ ВТ_ДанныеДокумента
	|ИЗ
	|	Документ.энргОперацияСУслугами КАК Шапка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ТочкиУчета КАК табТочкиУчета
	|		ПО Шапка.Ссылка = табТочкиУчета.Ссылка
	|ГДЕ
	|	Шапка.Ссылка В(&мДокументы)
	|	И Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги)");
	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса( 
	"ВЫБРАТЬ
	|	энргАбонентыПомещенийСрезПоследних.Услуга КАК Услуга,
	|	энргАбонентыПомещенийСрезПоследних.Абонент КАК Абонент
	|ПОМЕСТИТЬ ВТ_ПодключенныеУслуги
	|ИЗ
	|	РегистрСведений.энргАбонентыПомещений.СрезПоследних(
	|			&ПериодРегистрации,
	|			(Организация, Район, КлючПомещения) В
	|				(ВЫБРАТЬ
	|					ВТ.Организация,
	|					ВТ.Район,
	|					ВТ.КлючПомещения
	|				ИЗ
	|					ВТ_ДанныеДокумента КАК ВТ)) КАК энргАбонентыПомещенийСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	энргАбонентыПомещенийСрезПоследних.Услуга,
	|	энргАбонентыПомещенийСрезПоследних.Абонент");

	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса( 
	"ВЫБРАТЬ
	|	ВТ_ДанныеДокумента.Период КАК Период,
	|	ВТ_ДанныеДокумента.Организация КАК Организация,
	|	ВТ_ДанныеДокумента.Район КАК Район,
	|	ВТ_ДанныеДокумента.КлючПомещения КАК КлючПомещения,
	|	ВТ_ДанныеДокумента.Услуга КАК Услуга,
	|	ВТ_ДанныеДокумента.Абонент КАК Абонент,
	|	ВТ_ДанныеДокумента.ПериодРегистрации КАК ПериодРегистрации,
	|	ВТ_ДанныеДокумента.ПериодНачисления КАК ПериодНачисления
	|ИЗ
	|	ВТ_ДанныеДокумента КАК ВТ_ДанныеДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПодключенныеУслуги КАК ВТ_ПодключенныеУслуги
	|		ПО ВТ_ДанныеДокумента.Абонент = ВТ_ПодключенныеУслуги.Абонент
	|			И ВТ_ДанныеДокумента.Услуга = ВТ_ПодключенныеУслуги.Услуга
	|ГДЕ
	|	ВТ_ПодключенныеУслуги.Услуга ЕСТЬ NULL");		
			
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаВладельцыТочекУчета(Схема, Регистры)
	
	ИмяРегистра = "энргВладельцыТочекУчета";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= Новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  		= 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА Шапка.ДатаФактическогоСобытия
	|		ИНАЧЕ Шапка.Дата
	|	КОНЕЦ КАК Период,
	|	Шапка.Организация КАК Организация,
	|	Шапка.Район КАК Район,
	|	ТаблицаТочек.ТочкаУчета КАК ТочкаУчета,
	|	Шапка.КлючПомещения КАК АбонентВладелец,
	|	Шапка.Дата КАК ПериодРегистрации,
	|	Шапка.ПериодНачисления КАК ПериодНачисления
	|ИЗ
	|	Документ.энргОперацияСУслугами КАК Шапка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ТочкиУчета КАК ТаблицаТочек
	|		ПО Шапка.Ссылка = ТаблицаТочек.Ссылка
	|			И (Шапка.Ссылка В (&мДокументы))
