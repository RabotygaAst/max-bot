	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВЫБОР
	|			КОГДА НЕ Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА Шапка.ДатаФактическогоСобытия
	|			ИНАЧЕ Шапка.Дата
	|		КОНЕЦ КАК Период,
	|		Шапка.Ссылка КАК Регистратор,
	|		Шапка.Организация КАК Организация,
	|		Шапка.Район КАК Район,
	|		Шапка.КлючПомещения КАК КлючПомещения,
	|		ТаблицаТочек.ТочкаУчета КАК ТочкаУчета,
	|		ТаблицаТочек.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|		ТаблицаТочек.IDСтроки КАК IDСтроки,
	|		Шапка.Дата КАК ПериодРегистрации,
	|		Шапка.ПериодНачисления КАК ПериодНачисления
	|	ИЗ
	|		Документ.энргОперацияСУслугами КАК Шапка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ТочкиУчета КАК ТаблицаТочек
	|			ПО Шапка.Ссылка = ТаблицаТочек.Ссылка
	|				И (Шапка.Ссылка В (&мДокументы))
	|				И (ТаблицаТочек.Ссылка В (&мДокументы))
	|				И (Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги))) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ЗначенияИзмерителей КАК ТаблицаЗначенияИзмерителей
	|		ПО ВложенныйЗапрос.Регистратор = ТаблицаЗначенияИзмерителей.Ссылка
	|			И ВложенныйЗапрос.IDСтроки = ТаблицаЗначенияИзмерителей.IDСтроки
	|			И (ТаблицаЗначенияИзмерителей.Ссылка В (&мДокументы))";	
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаДиаметрСеченияТочекУчета(Схема, Регистры) 
	
	ИмяРегистра = "энргДиаметрСеченияТочекУчета";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= Новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
