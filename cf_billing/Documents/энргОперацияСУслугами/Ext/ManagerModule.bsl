// Получает изменяемые параметры расчета.
//
// Параметры:
//  ДобавитьАбонента	-	Булево.
// 
// Возвращаемое значение:
//   Соответствие.
//
Функция ИзменяемыеПараметрыРасчета(ДобавитьАбонента = Истина) Экспорт 
	   
	ИзменяемыеПараметрыРасчета 	= Новый Соответствие;
	
	ИзменяемыеПараметры 		= Новый Массив;	
	СтрокаРесурсов = 
	"УслугаПодключена,ПриборВведен,ПриборУчета,
	|ДатаСостоянияПрибора,НаправлениеИспользованияТУ,КоэффициентПУ,Поставщик,
	|НетВозможностьУстановкиПУ,СоставнаяУслуга,ИспользоватьДиаметрСечения,
	|ДиаметрСечения,Техническая,РасчетТолькоПоПоказаниям,ТочкаУчетаРодитель,ВидБлагоустройства,
	|ТарифнаяГруппа,Плательщик,ДатаПоверки,ДатаРегистрацииПоверки,ПотериОбъем,ПотериПроцент,
	|КоличествоПрописанных,КоличествоПроживающих,КоличествоСобственников,КоличествоКомнат,КоличествоЖильцов,ДоговорЗаключенДоТП";
	
	Если ДобавитьАбонента ТОгда
		СтрокаРесурсов = СтрокаРесурсов + ",Абонент";	
	КонецЕсли;
	
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,НоваяТочка,Ресурсы", "ТочкаУчета,Услуга", Истина, СтрокаРесурсов));
	
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги, ИзменяемыеПараметры);
	     	
	ИзменяемыеПараметры 		= Новый Массив;
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета","УслугаПодключена,ПериодНачисленияВыводаПрибора"));
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги, ИзменяемыеПараметры);
	
	ИзменяемыеПараметры 		= Новый Массив;
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета","УслугаОграничена"));
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОграничениеРежимаПотребления, ИзменяемыеПараметры);
	
	ИзменяемыеПараметры 		= Новый Массив;
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета,Услуга" ,"УслугаОграничена"));
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления, ИзменяемыеПараметры);
			
	Возврат ИзменяемыеПараметрыРасчета;	
	
КонецФункции

// Получает данные для проведения по стабильным периодам.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ВыбираемыеТаблицы	-	Массив из Строка.
//
Процедура ПолучитьДанныеДляПроведенияПоСтабильнымПериодам(Схема,ВыбираемыеТаблицы) Экспорт 
	перем Пакет;
	
	ИмяТаблицы 											= "ДанныеДокументовПодключениеУслуги";
	ВыбираемыеТаблицы.Добавить(ИмяТаблицы);
	
	врСхема 											= Новый СхемаЗапроса;
	врСхема.УстановитьТекстЗапроса(ТекстДляПроведенияПоСтабильнымПериодам());
	
	Пакет 												= врСхема.ПакетЗапросов[врСхема.ПакетЗапросов.Количество() - 1];
	Пакет.ТаблицаДляПомещения 							= ИмяТаблицы;
	
	Для Каждого врПакет Из врСхема.ПакетЗапросов Цикл
		Если Схема = Неопределено Тогда
			Схема 										= Новый СхемаЗапроса;
			Пакет 										= Схема.ПакетЗапросов[0];
		Иначе
			Пакет 										= Схема.ПакетЗапросов.Добавить();
		КонецЕсли;
		
		Пакет.УстановитьТекстЗапроса(врПакет.ПолучитьТекстЗапроса());	
	КонецЦикла;	
	
	Для Каждого врПакет Из врСхема.ПакетЗапросов Цикл				
		Если НЕ врПакет.ТаблицаДляПомещения = ИмяТаблицы Тогда
			ПакетУничтожение 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросУничтоженияТаблицыСхемыЗапроса"));
			ПакетУничтожение.ИмяТаблицы 				= врПакет.ТаблицаДляПомещения;
		КонецЕсли;				
	КонецЦикла;
	
КонецПроцедуры

