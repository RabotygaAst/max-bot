Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
	
	ПараметрыЗапроса  	= Новый Структура;
	Схема 				= Неопределено;
	
	ДобавитьТекстЗапросаАбонентыПомещений(Схема,Регистры);
	ДобавитьТекстЗапросаВладельцыТочекУчета(Схема,Регистры);
	ДобавитьТекстЗапросаРодителейТочекУчета(Схема, Регистры);
	ДобавитьТекстЗапросаАктивностьТочекУчета(Схема,Регистры);
	ДобавитьТекстЗапросаУслугиТочекУчета(Схема,Регистры);
	ДобавитьТекстЗапросаПриборыТочекУчета(Схема,Регистры);
	ДобавитьТекстЗапросаТехническаяВозможностьУстановкиПУ(Схема,Регистры);
	ДобавитьТекстЗапросаСвойствоРасчетТолькоПоПоказаниямТочекУчета(Схема,Регистры);
	ДобавитьТекстЗапросаНаправлениеИспользованияТочекУчета(Схема,Регистры);
	ДобавитьТекстЗапросаЗначенияИзмерителейТочекУчета(Схема,Регистры);
	ДобавитьТекстЗапросаДиаметрСеченияТочекУчета(Схема,Регистры);
	ДобавитьТекстЗапросаСостояниеПриборовУчетаАбонента(Схема,Регистры);
	ДобавитьТекстЗапросаПоказанияПриборовУчета(Схема,Регистры);
	ДобавитьТекстЗапросаВыводыПУБезПоказаний(Схема,Регистры);
	ДобавитьТекстЗапросаНомерПломбПриборовУчета(Схема, Регистры);
	ДобавитьТекстЗапросаВидыДифференцированностиПриборовУчета(Схема,Регистры);
	ДобавитьТекстЗапросаДатыПоверкиПрибораУчета(Схема,Регистры);
	ДобавитьТекстЗапросаКоэффциентыПриборовУчета(Схема,Регистры);
	ДобавитьТекстЗапросаВидБлагоустройствАбонента(Схема, Регистры);
	ДобавитьТекстЗапросаГруппыПотребителейАбонентов(Схема, Регистры);
	ДобавитьТекстЗапросаПоставщикиУслугАбонента(Схема, Регистры);
	ДобавитьТекстЗапросаПлательщикиУслугАбонента(Схема, Регистры);
	ДобавитьТекстЗапросаЗначенияПлощадей(Схема, Регистры);
	ДобавитьТекстЗапросаКоличествоКомнат(Схема, Регистры);
	ДобавитьТекстЗапросаНазначенияПриборовУчета(Схема, Регистры);

	
	
	ДобавитьТекстЗапросаСостояниеВидовПотерьТочекУчета(Схема, Регистры);
	ДобавитьТекстЗапросаЗначенияПотерьТочекУчета(Схема, Регистры);
	
	ДобавитьТекстЗапросаТУНаСтруктуреСети(Схема, Регистры);
	
	ДобавитьТекстЗапросаТочкиПоставкиТочекУчета(Схема, Регистры);
	
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		ВспомогательныеПараметры 	= Новый Структура;
		энргФормированиеТекстовЗапроса.УстановитьПерехватОбращенияКТаблицам(Схема, ДополнительныеСвойства.ТаблицыПодмены, ВспомогательныеПараметры); 
	КонецЕсли;
	
	КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	
	ПараметрыЗапроса 				= Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы", 					ДокументСсылка);
	ПараметрыПроведения = ДополнительныеСвойства.ПараметрыПроведения;
	ПараметрыЗапроса.Вставить("ПериодРегистрации",				Новый Граница(ПараметрыПроведения.ПериодРегистрации, ВидГраницы.Исключая));
	ПараметрыЗапроса.Вставить("ПустойУникальныйИдентификатор", 	ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
		
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		энргСхемаЗапросаСервер.ВыполнитьПакет(Схема,ПараметрыЗапроса));
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

Процедура ИнициализироватьТаблицыДляКонтроля(ДокументСсылка,ДополнительныеСвойства) Экспорт 
	
	Схема  										= Неопределено;
	Параметры 									= Новый Структура;
	
	ДобавитьТекстЗапросаПараметрыКонтроля(Схема);
	ДобавитьТекстЗапросаКонтрольСостояниеМКД(Схема, Параметры);
	ДобавитьТекстЗапросаКонтрольСостояниеЛицевогоСчета(Схема);
		
	КлючиТаблицКонтроля  						= Новый Структура;
			
	Для Сч = 0 По Схема.ПакетЗапросов.Количество() - 1  Цикл
		Пакет 									= Схема.ПакетЗапросов[Сч];		
		Если Не ПустаяСтрока(Пакет.ТаблицаДляПомещения) И СтрНачинаетсяС(Пакет.ТаблицаДляПомещения, "Контроль") Тогда			
			КлючиТаблицКонтроля.Вставить(Прав(Пакет.ТаблицаДляПомещения,СтрДлина(Пакет.ТаблицаДляПомещения) - СтрДлина("Контроль")),Сч);			
			Пакет.ТаблицаДляПомещения 			= "";
		КонецЕсли;		
	КонецЦикла;
	ТекстСообщенияМногоквартирныйДомЗакрыт 		= НСтр("ru = 'На дату операции мкд закрыт'");
	ТекстСообщенияЛицевойСчетЗакрыт 			= НСтр("ru = 'На дату операции лицевой счет закрыт'");
	ДанныеСтроения 								= ДополнительныеСвойства.ДанныеСтроения;
	
	ПараметрыЗапроса 							= Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы", 								ДокументСсылка);
	ПараметрыЗапроса.Вставить("ЧастныйСектор",								ДанныеСтроения.ЧастныйСектор);
	ПараметрыЗапроса.Вставить("Строение", 									ДанныеСтроения.Строение);
	ПараметрыЗапроса.Вставить("ТекстСообщенияМногоквартирныйДомЗакрыт", 	ТекстСообщенияМногоквартирныйДомЗакрыт);
	ПараметрыЗапроса.Вставить("ТекстСообщенияЛицевойСчетЗакрыт", 			ТекстСообщенияЛицевойСчетЗакрыт);
		
	ДополнительныеСвойства.Вставить("ТаблицыДляКонтроля", 					энргСхемаЗапросаСервер.ВыполнитьПакет(Схема,ПараметрыЗапроса));
	ДополнительныеСвойства.Вставить("КлючиТаблицКонтроля", 					КлючиТаблицКонтроля);
	
КонецПроцедуры

Функция ДанныеНаГраницуДокумента(ДокументОбъект) Экспорт 
	Схема 				= Новый СхемаЗапроса;	
	ПараметрыОтбора 	= Новый Структура;
	ПараметрыЗапроса 	= Новый Структура;
	
	ИнициализироватьПараметрыОтбораДанныхНаГраницу(ПараметрыОтбора);
	ИнициализироватьПараметрыЗапросаДанныхНаГраницу(ДокументОбъект, ПараметрыЗапроса);
	
	ЗаполнитьНачальнуюСхемуДанныхНаГраницу(Схема);	
	энргРаботаСЛицевымСчетомСервер.ЗаполнитьСхемуДанныхНаГраницуВремени(Схема, ПараметрыОтбора); 
	СоединитьСхемуДанныхНаГраницу(Схема);
	СоединитьСхемуДанныхНаГраницуПотери(Схема);
	СоединитьСхемуДанныхНаГраницуЗначениеПлощадей(Схема);
	СоединитьСхемуДанныхНаГраницуЗначенияИзмерителей(Схема);
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьПакет(Схема, ПараметрыЗапроса);
КонецФункции 

Функция ЕстьТочкиСОРП(Период, Организация, Район, КлючПомещения) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргАктивностьТочекУчетаСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргАктивностьТочекУчетаСрезПоследних.Состояние КАК Состояние,
		|	энргАктивностьТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
		|ИЗ
		|	РегистрСведений.энргАктивностьТочекУчета.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И КлючПомещения = &КлючПомещения) КАК энргАктивностьТочекУчетаСрезПоследних
		|ГДЕ
		|	энргАктивностьТочекУчетаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.ОРП)";
	
	Запрос.УстановитьПараметр("КлючПомещения"	, КлючПомещения);
	Запрос.УстановитьПараметр("Организация"		, Организация);
	Запрос.УстановитьПараметр("Период"			, Период);
	Запрос.УстановитьПараметр("Район"			, Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

