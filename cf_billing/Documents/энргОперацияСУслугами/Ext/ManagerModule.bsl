Процедура ИнициализироватьПараметрыОтбораДанныхНаГраницу(ПараметрыОтбора)
	ПараметрыВТ 			= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно"		, Новый Структура("Абонент"			, "Абонент")		, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно"		, Новый Структура("Организация"		, "Организация")	, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно"		, Новый Структура("Район"			, "Район")			, Неопределено));	
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно"		, Новый Структура("КлючПомещения"	, "КлючПомещения")	, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно"		, Новый Структура("АбонентВладелец"	, "КлючПомещения")	, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраВСписке"	, Новый Структура("ТочкаУчета"		, "ТочкаУчета")		, Неопределено));
		
	ПараметрыОтбора.Вставить("Период"		, Новый Структура("ИмяПараметра, ТипПараметра", "Период" ,"ТипПараметраГраницаИсключая"));
	ПараметрыОтбора.Вставить("ПараметрыВТ"	, ПараметрыВТ);	
КонецПроцедуры

Процедура ИнициализироватьПараметрыЗапросаДанныхНаГраницу(ДокументОбъект, ПараметрыЗапроса)
	ДанныеТочекУчета = ДокументОбъект.ТочкиУчета.Выгрузить();
	
	ПараметрыЗапроса.Вставить("ДанныеУслуги"	, ДанныеТочекУчета);	
	ПараметрыЗапроса.Вставить("Период"			, Новый Граница(ДокументОбъект.Дата, ВидГраницы.Исключая));
	ПараметрыЗапроса.Вставить("Организация"		, ДокументОбъект.Организация);
	ПараметрыЗапроса.Вставить("Район"			, ДокументОбъект.Район); 	
	ПараметрыЗапроса.Вставить("КлючПомещения"	, ДокументОбъект.КлючПомещения);	
	ПараметрыЗапроса.Вставить("Абонент"			, ДокументОбъект.Абонент);	
	ПараметрыЗапроса.Вставить("ТочкаУчета"		, ДанныеТочекУчета.ВыгрузитьКолонку("ТочкаУчета")); 	
КонецПроцедуры

