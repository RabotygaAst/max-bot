	|		Шапка.Ссылка КАК Ссылка
	|	ИЗ
	|		Документ.энргОперацияСУслугами КАК Шапка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ТочкиУчета КАК табТочкиУчета
	|			ПО Шапка.Ссылка = табТочкиУчета.Ссылка
	|				И (Шапка.Ссылка В (&мДокументы))
	|				И (табТочкиУчета.Ссылка В (&мДокументы))
	|				И (Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги))) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ТочкиПоставок КАК табТочкиПоставок
	|		ПО ВложенныйЗапрос.Ссылка = табТочкиПоставок.Ссылка
	|			И ВложенныйЗапрос.IDСтроки = табТочкиПоставок.IDСтроки";  	
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
		
КонецПроцедуры

Процедура ДобавитьТекстЗапросаКоличествоКомнат(Схема, Регистры)
	ИмяРегистра = "энргКоличествоКомнат";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  		=
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ энргОперацияСУслугами.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА энргОперацияСУслугами.ДатаФактическогоСобытия
	|		ИНАЧЕ энргОперацияСУслугами.Дата
	|	КОНЕЦ КАК Период,
	|	энргОперацияСУслугами.Организация КАК Организация,
	|	энргОперацияСУслугами.Район КАК Район,
	|	энргОперацияСУслугами.КлючПомещения КАК КлючПомещения,
	|	энргОперацияСУслугами.КоличествоКомнат КАК Количество,
	|	энргОперацияСУслугами.Дата КАК ПериодРегистрации,
	|	НАЧАЛОПЕРИОДА(энргОперацияСУслугами.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления
	|ИЗ
	|	Документ.энргОперацияСУслугами КАК энргОперацияСУслугами
	|ГДЕ
	|	энргОперацияСУслугами.Ссылка = &мДокументы
	|	И энргОперацияСУслугами.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги)
	|	И энргОперацияСУслугами.КоличествоКомнат > 0";  	
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
		
КонецПроцедуры

