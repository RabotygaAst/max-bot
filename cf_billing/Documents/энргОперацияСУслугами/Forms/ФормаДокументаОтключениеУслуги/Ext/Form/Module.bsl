&НаСервере
Процедура ЗаполнитьПриборыУчетаСервер(ИдентификаторСтроки = Неопределено)
	
	ТочкаУчета  									= Неопределено;
	Если ИдентификаторСтроки = Неопределено Тогда
		ТаблицаТЧ 									= Объект.ПоказанияПриборовУчета.Выгрузить();
		Объект.ШкалыПриборовУчета.Очистить();
		Объект.ПоказанияПриборовУчета.Очистить();
		Объект.ТочкиУчета.Очистить();
	Иначе
		СтрокаТочкиУчета  							= Объект.ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
		ТочкаУчета 									= СтрокаТочкиУчета.ТочкаУчета;
		ПоискШкал	 								= Новый Структура("IDСтрокиТочкиУчета",СтрокаТочкиУчета.IDСтроки);
		СтрокиШкал  								= Объект.ШкалыПриборовУчета.НайтиСтроки(ПоискШкал);
		Для Каждого СтрокаШкалы Из СтрокиШкал Цикл
			ПоискПоказаний 							= Новый Структура("IDСтроки", СтрокаШкалы.IDСтроки);
			СтрокиПоказаний 						= Объект.ПоказанияПриборовУчета.НайтиСтроки(ПоискПоказаний);
			Для Каждого СтрокаПоказаний Из СтрокиПоказаний Цикл
				Объект.ПоказанияПриборовУчета.Удалить(СтрокаПоказаний);
			КонецЦикла;
			Объект.ШкалыПриборовУчета.Удалить(СтрокаШкалы);
		КонецЦикла; 		
	КонецЕсли;

	Если Объект.ВидОперации = Перечисления.энргВидыОпераций.ПустаяСсылка() Тогда
		Возврат;
	ИначеЕсли Объект.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления Тогда
		Результат = Обработки.энргСостояниеТочекУчетаМенеджер.ТочкиОРПиИхПриборы(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения, ТочкаУчета);
	ИначеЕсли Объект.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги Тогда
		Результат = Обработки.энргСостояниеТочекУчетаМенеджер.ДействующиеТочкиИИхПриборы(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения, ТочкаУчета,Новый Структура("ВключаяОРП", Истина));
	Иначе 		
		Результат = Обработки.энргСостояниеТочекУчетаМенеджер.ДействующиеТочкиИИхПриборы(Объект.Дата, Объект.Организация, Объект.Район, Объект.КлючПомещения, ТочкаУчета,Новый Структура("ТолькоОткрытыеЛС", Истина)); 
	КонецЕсли;

	Выборка  										= Результат.выбрать();
	ТекТочкаУчета 									= Неопределено;
	ТекШкала 										= Неопределено;
	IDСтрокиТочки 									= Неопределено;
	IDСтрокиШкалы 									= Неопределено;
	Пока Выборка.следующий() цикл
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			НоваяТочка = Истина;
			Если ИдентификаторСтроки = Неопределено Тогда
				СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
				IDСтрокиТочки 						= Новый УникальныйИдентификатор;
				СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
				СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			иначе 				
				СтрокаТочкиУчета  					= Объект.ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
				IDСтрокиТочки 						= СтрокаТочкиУчета.IDСтроки;
			КонецЕсли;
			СтрокаТочкиУчета.Услуга 				= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 			= Выборка.ПриборУчета;	
			//СтрокаТочкиУчета.Поставщик 				= Выборка.Поставщик;
			СтрокаТочкиУчета.ДатаПоверкиСчетчика 	= Выборка.ДатаПоверки;
			СтрокаТочкиУчета.ЭтоСоставнаяУслуга 	= Выборка.СоставнаяУслуга;
			Если Объект.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления Тогда
				Если СтрокаТочкиУчета.ЭтоСоставнаяУслуга Тогда 
					Для Каждого ТекУслуга Из Выборка.Услуга.СоставляющиеУслуг Цикл
						СтрокаУслуги  				= Объект.ПоставщикиСоставныхУслуг.Добавить();
						СтрокаУслуги.IDСтроки 		= IDСтрокиТочки;
						СтрокаУслуги.ЧастьСоставнойУслуги	= ТекУслуга.Услуга;
						СтрокаУслуги.Поставщик = ВернутьПоставщикаУслуги(ТекУслуга.Услуга, Выборка.ТочкаУчета, Объект.Организация, Объект.Дата, Объект.Район, Объект.КлючПомещения);
					КонецЦикла;
				иначе 
					СтрокаТочкиУчета.Поставщик = ВернутьПоставщикаУслуги(Выборка.Услуга, Выборка.ТочкаУчета, Объект.Организация, Объект.Дата, Объект.Район, Объект.КлючПомещения);
				КонецЕсли;
			иначе 
				СтрокаТочкиУчета.Поставщик = Выборка.Поставщик;
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) Тогда
			Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
				СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
				IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
				СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
				СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
				СтрокаШкалы.Шкала 					= Выборка.Шкала;
				СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
			КонецЕсли;
			
			СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
			СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
			СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		КонецЕсли;
		
		ТекТочкаУчета 								= Выборка.ТочкаУчета;
		ТекШкала 									= Выборка.Шкала;
	КонецЦикла;
	
	ДатаЗаполненияПоказаний = ?(Объект.ДатаФактическогоСобытия = Дата(1,1,1), Объект.Дата, Объект.ДатаФактическогоСобытия); 
	
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();
	
	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Район,Объект.КлючПомещения,ИдентификаторСтроки); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказанийСУчетомОтклонения(Объект.Организация,Объект.Район,ТаблицаПоказанийДляЗаполнения, ДатаЗаполненияПоказаний, ПриборыДляОтклоненияПоказаний.Выгрузить());
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект,Объект,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета);
	
	Если Объект.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления Тогда
		ОбновитьДанныеНаГраницуДокумента();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ВернутьПоставщикаУслуги(Услуга, ТочкаУчета, Организация, Дата, Район, КлючПомещения)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргПоставщикиУслугАбонентаСрезПоследних.Поставщик КАК Поставщик
	|ИЗ
	|	РегистрСведений.энргПоставщикиУслугАбонента.СрезПоследних(
	|			&Дата,
	|			КлючПомещения = &КлючПомещения
	|				И Организация = &Организация
	|				И Район = &Район
	|				И Услуга = &Услуга
	|				И ТочкаУчета = &ТочкаУчета ) КАК энргПоставщикиУслугАбонентаСрезПоследних";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("КлючПомещения", КлючПомещения);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ТочкаУчета", ТочкаУчета);
	Запрос.УстановитьПараметр("Услуга", Услуга);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Поставщик;
	КонецЦикла;	
КонецФункции

&НаСервере
Функция ПроверитьТочкиУчетаВРСРасчетныеФормулы()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	энргОперацияСУслугамиТочкиУчета.ТочкаУчета
	|ПОМЕСТИТЬ ВрТ
	|ИЗ
	|	Документ.энргОперацияСУслугами.ТочкиУчета КАК энргОперацияСУслугамиТочкиУчета
	|ГДЕ
	|	энргОперацияСУслугамиТочкиУчета.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	энргОперацияСУслугамиТочкиУчета.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВрТ.ТочкаУчета КАК ТочкаУчета,
	|	ЕСТЬNULL(энргФормулыРасчетаТочекУчетаСрезПоследних.РассчитываемаяТочка, ЛОЖЬ) КАК Рассчитываемая
	|ИЗ
	|	ВрТ КАК ВрТ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргФормулыРасчетаТочекУчета.СрезПоследних(&Дата, ) КАК энргФормулыРасчетаТочекУчетаСрезПоследних
	|		ПО ВрТ.ТочкаУчета = энргФормулыРасчетаТочекУчетаСрезПоследних.РассчитываемаяТочка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВрТ.ТочкаУчета,
	|	ЕСТЬNULL(энргФормулыРасчетаТочекУчетаСрезПоследних.ТочкаИсточник, ЛОЖЬ)
	|ИЗ
	|	ВрТ КАК ВрТ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргФормулыРасчетаТочекУчета.СрезПоследних(&Дата, ) КАК энргФормулыРасчетаТочекУчетаСрезПоследних
	|		ПО ВрТ.ТочкаУчета = энргФормулыРасчетаТочекУчетаСрезПоследних.ТочкаИсточник";
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия), Объект.ДатаФактическогоСобытия,Объект.Дата));
	Запрос.УстановитьПараметр("ссылка", Объект.Ссылка);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Истина;
	Иначе 
		Возврат ложь;
	КонецЕсли;
КонецФункции

&НаСервере
Функция ПоказанияЗависимыхТочекУчетаЗаполненны()
	
	Отказ 						= Ложь;
	
	// Если отключаемые точки учета учавствуют в формуле. 
	// в этом случае необходимо указать показания приборов учета.
	// которые установлены на точках учета участвующие в формуле.
	ПериодСреза 				= ?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия),КонецДня(Объект.ДатаФактическогоСобытия),Объект.Дата);
	РезультатФормулыРасчета 	= энргРаботаСТочкамиУчетаСервер.ФормулыРасчетаТочекУчета(Объект.ТочкиУчета.Выгрузить(,"ТочкаУчета,НомерСтроки"),Объект.Организация,Объект.Район,Объект.Абонент.КлючПомещения,ПериодСреза);
	
	Если РезультатФормулыРасчета.пустой() тогда
		Возврат Истина;
	КонецЕсли;
	
	ТаблицаФормулы  			= РезультатФормулыРасчета.Выгрузить();			
	ЗависимыеТочки  			= Новый Массив;
	
	для Каждого СтрокаТЧ из Объект.ТочкиУчета цикл
		// отключается рассчитываемая
		СтрокиФормулы			= ТаблицаФормулы.НайтиСтроки(Новый Структура("ТочкаУчета",СтрокаТЧ.ТочкаУчета));
		Если СтрокиФормулы.Количество() > 0 тогда
			для Каждого СтрокаФормулы из СтрокиФормулы цикл
				Если ЗависимыеТочки.Найти(СтрокаФормулы.ТочкаУчета) = Неопределено  тогда
					ЗависимыеТочки.добавить(СтрокаФормулы.ТочкаУчета);
				КонецЕсли;
			КонецЦикла;	
			Если ЗависимыеТочки.Найти(СтрокаТЧ.ТочкаУчета) = Неопределено  тогда
				ЗависимыеТочки.добавить(СтрокаТЧ.ТочкаУчета);
			КонецЕсли;
		КонецЕсли;	
		
		// отключается учавствующая в формуле		
		СтрокиФормулы			= ТаблицаФормулы.НайтиСтроки(Новый Структура("ТочкаУчета",СтрокаТЧ.ТочкаУчета));
		Если СтрокиФормулы.Количество() > 0 тогда
			ЗависимыеСтроки  	= ТаблицаФормулы.НайтиСтроки(Новый Структура("ТочкаУчета",СтрокиФормулы[0].ТочкаУчета));
			для Каждого СтрокаФормулы из ЗависимыеСтроки цикл
				Если ЗависимыеТочки.Найти(СтрокаФормулы.ТочкаУчета) = Неопределено  тогда
					ЗависимыеТочки.добавить(СтрокаФормулы.ТочкаУчета);
				КонецЕсли;
			КонецЦикла;			
			Если ЗависимыеТочки.Найти(СтрокиФормулы[0].ТочкаУчета) = Неопределено  тогда 
				ЗависимыеТочки.добавить(СтрокиФормулы[0].ТочкаУчета);
			КонецЕсли;			
		КонецЕсли;	
	КонецЦикла;
	
	Результат 					= энргСостояниеПриборовУчета.ДействующиеПриборыУчетаПомещения(ПериодСреза,Объект.Организация,Объект.Район,Объект.КлючПомещения); 
	Выборка  					= Результат.выбрать();
	
	Пока Выборка.следующий() цикл
		
		Если ЗависимыеТочки.Найти(Выборка.ТочкаУчета) = Неопределено тогда
			// точка не зависит от других
			Продолжить;
		КонецЕсли;
		
		СтрокиПриборов 			= Объект.ТочкиУчета.НайтиСтроки(Новый Структура("ТочкаУчета,ПриборУчета",Выборка.ТочкаУчета,Выборка.ПриборУчета));
		СтрокиОтключения 		= Объект.ТочкиУчета.НайтиСтроки(Новый Структура("ТочкаУчета,ПриборУчета",Выборка.ТочкаУчета,Выборка.ПриборУчета));
		Если СтрокиПриборов.Количество() > 0 или СтрокиОтключения.Количество() > 0 тогда
			// строка точки уже добавлена или отключается
			Продолжить;
		КонецЕсли;
		
		Отказ 					= Истина;
		СтрокаПриборов  		= Объект.ТочкиУчета.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПриборов,Выборка);	
	КонецЦикла;  	
		
	Возврат не Отказ;	
КонецФункции 

&НаСервере
Процедура ЗаполнитьДанныеКлючаПомещения(Знач ДанныеПомещенияРезультат)
	
	Перем ДанныеПомещенияВыборка;
	
	Если Не ДанныеПомещенияРезультат.Пустой() Тогда
		ДанныеПомещенияВыборка  = ДанныеПомещенияРезультат.Выбрать();
		ДанныеПомещенияВыборка.Следующий();
		ЗаполнитьЗначенияСвойств(ЭтаФорма,ДанныеПомещенияВыборка,"Строение,Помещение,ЧастныйСектор");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция ЕстьОшибкиЗаполнения(РежимЗаписи)
	
	ЕстьОшибкиЗаполнения = Ложь;
		
	Если НачалоМесяца(Объект.Дата) = НачалоМесяца(Объект.ДатаФактическогоСобытия) Тогда
		ЕстьОшибкиЗаполнения = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Фактическая и текущая дата не могут находиться в одном периоде");
		Объект.ДатаФактическогоСобытия = Дата(1,1,1);
	КонецЕсли;

	Возврат ЕстьОшибкиЗаполнения;
	
КонецФункции

#КонецОбласти

#Область ОбновлениеДанныхНаГраницуДокумента

&НаСервере
Процедура ОбновитьДанныеНаГраницуДокумента()
	Объект.ВидыБлагоустройстваТарифныеКатегории.Очистить();
	энргРаботаСЛицевымСчетомСервер.ОбновитьВидыБлагоустройстваТарифныеКатегории(ЭтотОбъект);
	
	МассивРезультатов 	= Документы.энргОперацияСУслугами.ДанныеНаГраницуДокумента(Объект);
	КолвоРезультатов	= МассивРезультатов.Количество();
	
	Выборка 			= МассивРезультатов[КолвоРезультатов - 4].Выбрать();
	Пока Выборка.Следующий() Цикл 
		ЗаполнитьЗначенияСвойств(Объект, Выборка,, "Организация,Район,КлючПомещения,Абонент");
		ЗаполнитьТочкиУчетаНаГраницу(Выборка);
		ЗаполнитьВидыБлагоустройстваТарифныеКатегорииНаГраницу(Выборка);
	КонецЦикла;	
	
	ЗаполнитьНаГраницуПотери(МассивРезультатов[КолвоРезультатов - 3].Выбрать());
	ЗаполнитьНаГраницуЗначениеПлощадей(МассивРезультатов[КолвоРезультатов - 2].Выбрать());
	ЗаполнитьНаГраницуЗначенияИзмерителей(МассивРезультатов[КолвоРезультатов - 1].Выбрать());
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТочкиУчетаНаГраницу(Выборка)
	МассивСтрок = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("ТочкаУчета", Выборка.ТочкаУчета));
	Если МассивСтрок.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	СтрокаТочки = МассивСтрок[0];
	ЗаполнитьЗначенияСвойств(СтрокаТочки, Выборка);
	СтрокаТочки.ТочкаУчетаРодитель = Выборка.РодительТочкиУчета;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВидыБлагоустройстваТарифныеКатегорииНаГраницу(Выборка)
	МассивСтрок = Объект.ВидыБлагоустройстваТарифныеКатегории.НайтиСтроки(Новый Структура("Услуга", Выборка.Услуга));
	Если МассивСтрок.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	ТекСтрока = МассивСтрок[0];
	ТекСтрока.ВидБлагоустройстваИндивидуальный 	= Выборка.ВидБлагоустройства;
	ТекСтрока.ТарифнаяКатегория 				= Выборка.ГруппаПотребителей;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаГраницуПотери(Выборка)
	Объект.Потери.Очистить();
	СпособПроцент = Перечисления.энргСпособыРасчетаПотерь.Процент;
	Пока Выборка.Следующий() Цикл
		Если Выборка.Значение = 0 Тогда 
			Продолжить;
		КонецЕсли;
		
		МассивСтрок = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("ТочкаУчета", Выборка.ТочкаУчета));
		Если МассивСтрок.Количество() = 0 Тогда 
			Возврат;
		КонецЕсли;
		
		IDСтрокиТочкиУчета 		= МассивСтрок[0].IDСтроки;
		
		НСтрока = Объект.Потери.Добавить();
		НСтрока.IDСтроки 						= IDСтрокиТочкиУчета;
		НСтрока.ВидПотерь 						= Выборка.ВидПотерь;
		Если Выборка.СпособРасчетаПотерь = СпособПроцент Тогда 
			НСтрока.ПроцентПотерь 				= Выборка.Значение;
		Иначе 
			НСтрока.ФиксированныйОбъемПотерь 	= Выборка.Значение;
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаГраницуЗначениеПлощадей(Выборка)
	Объект.ЗначениеПлощадей.Очистить();
	Пока Выборка.Следующий() Цикл		
		Если Выборка.ВидПлощади = Перечисления.энргВидыПлощадей.ПустаяСсылка()
			ИЛИ НЕ Объект.ЗначениеПлощадей.НайтиСтроки(Новый Структура("ВидПлощади", Выборка.ВидПлощади)).Количество() = 0 Тогда 
			Продолжить;
		КонецЕсли; 		
		
		НСтрока = Объект.ЗначениеПлощадей.Добавить();
		НСтрока.ВидПлощади 	= Выборка.ВидПлощади;
		НСтрока.Значение 	= Выборка.Площадь;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаГраницуЗначенияИзмерителей(Выборка)
	Объект.ЗначенияИзмерителей.Очистить();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Значение = 0 Тогда 
			Продолжить;
		КонецЕсли;
		
		МассивСтрок = Объект.ТочкиУчета.НайтиСтроки(Новый Структура("ТочкаУчета", Выборка.ТочкаУчета));
		Если МассивСтрок.Количество() = 0 Тогда 
			Продолжить;
		КонецЕсли;		
		IDСтрокиТочкиУчета = МассивСтрок[0].IDСтроки;
		
		НСтрока = Объект.ЗначенияИзмерителей.Добавить();
		НСтрока.IDСтроки 					= IDСтрокиТочкиУчета;
		НСтрока.НаправлениеИспользованияТУ 	= Выборка.НаправлениеИспользованияТУ;
		НСтрока.Значение 					= Выборка.Значение;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СервисПроверкиПоказанийПриборовУчета

&НаСервере
Процедура ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний()
	
	ТаблицаПриборов = энргРаботаСПоказаниямиПриборовУчетаСервер.НоваяТаблицаПриборовДляПроверки();
	Для Каждого ТекСтрока из Объект.ТочкиУчета Цикл
		НСтрока = ТаблицаПриборов.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока, ТекСтрока);
		НСтрока.Район 			= Объект.Район;
		НСтрока.КлючПомещения 	= Объект.КлючПомещения;
	КонецЦикла;
	
	ПериодЗапроса = Новый Граница(Объект.Дата, ВидГраницы.Исключая); 
	ВспомогательныеПараметры = энргРаботаСПоказаниямиПриборовУчетаСервер.НовыеВспомогательныеПараметрыПроверкиОтклоненияПоказаний();
	ВспомогательныеПараметры.ПоказанияВСрок = Истина;
	ВспомогательныеПараметры.ПериодНачисления = Объект.ПериодНачисления; 
	
	Если Объект.ВидОперации = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ВозобновлениеРежимаПотребления Тогда 
		ВспомогательныеПараметры.ПроверятьОРП = Ложь;
	КонецЕсли;
	
	РезультатЗапроса = энргРаботаСПоказаниямиПриборовУчетаСервер.ПриборыДляОтклоненияПоказаний(ПериодЗапроса, Объект.Организация, ТаблицаПриборов, ВспомогательныеПараметры);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний(ЭтотОбъект, РезультатЗапроса);	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтрокуСПоказаниями(ТекущиеДанныеТочкиУчета, ТекущиеДанные, ДанныеСтроки = Неопределено)
	
	РезультатПроверки = энргРаботаСПоказаниямиПриборовУчетаКлиент.ОпределитьСостояниеПоказанийПоСтроке(ТекущиеДанныеТочкиУчета.ПриборУчета, ЭтотОбъект, ТекущиеДанные);
	Если РезультатПроверки.СостояниеИзменено И Не ТекущиеДанные.ПричинаОтклонения = РезультатПроверки.ПричинаОтклонения Тогда
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, РезультатПроверки);	
		
		Если Не ДанныеСтроки = Неопределено Тогда
			Если ДанныеСтроки.Свойство("СтатусИзмененПользователем") И ДанныеСтроки.СтатусИзмененПользователем Тогда
				ДанныеСтроки.СтатусИзмененПользователем = Ложь;		
			КонецЕсли; 
			Если ДанныеСтроки.Свойство("ПереворотИзмененПользователем") И ДанныеСтроки.ПереворотИзмененПользователем Тогда
				ДанныеСтроки.ПереворотИзмененПользователем = Ложь;		
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	энргРаботаСПоказаниямиПриборовУчетаКлиент.ПересчитатьСтрокуПриборовУчета(ТекущиеДанные, ТекущиеДанныеТочкиУчета.РегистрируетОбъем, Объект.Дата, ДанныеСтроки); 
	
КонецПроцедуры

