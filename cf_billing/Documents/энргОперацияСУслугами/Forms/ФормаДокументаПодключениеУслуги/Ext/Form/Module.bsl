&НаКлиенте
Процедура РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные)
	ДопПараметры = Новый Структура("РегистрируетОбъем,ЭтоВводПУ,НеРегистрацияОбъема",ТекущиеДанные.РегистрируетОбъем,Истина,Истина);
	энргРаботаСПриборамиУчетаКлиент.РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные.РегистрируетОбъем,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета,ЭтаФорма,ДопПараметры);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоУслугНаОснованииТочекУчета(ТекущийОбъект, СтрокаРодитель, Родитель, ЗаполнятьТекстыГиперссылок = Истина)
	
	Вершины 			= ТекущийОбъект.ТочкиУчета.НайтиСтроки(Новый Структура("IDСтрокиРодитель", Родитель));
	Строки  			= СтрокаРодитель.ПолучитьЭлементы();
	
	Для Сч = 0 По Вершины.ВГраница() Цикл
		Если ЗначениеЗаполнено(Вершины[Сч].IDСтроки) Тогда
			СтрокаДерева  	= Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДерева, Вершины[Сч]);
			
			Если ЗаполнятьТекстыГиперссылок Тогда
				СтрокаДерева.ДанныеУслуги 			= энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстДанныеУслуги(СтрокаДерева);
				СтрокаДерева.ДанныеРасположения 	= энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстДанныеРасположения(СтрокаДерева);
				СтрокаДерева.ТехническиеСвойстваТУ	= энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстТехническихСвойств(СтрокаДерева, Объект.Потери.НайтиСтроки(Новый Структура("IDСтроки", СтрокаДерева.IDСтроки)));
				
				ДанныеИзмерителей = Новый Структура("Измерители", Объект.Измерители.НайтиСтроки(Новый Структура("IDСтрокиТочкиУчета", СтрокаДерева.IDСтроки)));
				энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстСредствИзмерений(СтрокаДерева, ДанныеИзмерителей);
			КонецЕсли;
			
			ЗаполнитьДеревоУслугНаОснованииТочекУчета(ТекущийОбъект, СтрокаДерева, Вершины[Сч].IDСтроки, ЗаполнятьТекстыГиперссылок);
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТочкиНаОснованииДереваУслуг(Строки, Родитель)
	
Для Каждого Строка Из Строки Цикл 		
		СтрокаТочки  						= Объект.ТочкиУчета.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТочки, Строка);
		Если Не Родитель = Неопределено Тогда
			СтрокаТочки.IDСтрокиРодитель	= Родитель;			
		КонецЕсли;
		ЗаполнитьТочкиНаОснованииДереваУслуг(Строка.ПолучитьЭлементы(), Строка.IDСтроки);
	КонецЦикла;	
	
КонецПроцедуры

