&НаКлиенте
Процедура ТочкиУчетаЕстьШкалыНетТарифныхЗонПриАктивизацииСтроки(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ИмяТаблицыШкал							= "ШкалыПриборовУчета" + ПрефиксТочекУчета;
	ТаблицаФормыШкалы	 					= Элементы[ИмяТаблицыШкал];
	
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
		ТекущиеДанные.IDСтроки 				= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	// энргРаботаСВидомДифференцированности {
	энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаФормыШкалы,"IDСтрокиТочкиУчета",ТекущиеДанные.IDСтроки); 
	// энргРаботаСВидомДифференцированности }
	
	ИмяТаблицыНаправленийИзмеренийТУ  	= "ЗначенияИзмерителей" + ПрефиксТочекУчета;
	ТаблицыНаправленийИзмеренийТУ  		= Элементы[ИмяТаблицыНаправленийИзмеренийТУ];
	энргРаботаСТочкамиУчетаКлиент.ТочкаУчетаПриАктивацииСтроки(ТаблицыНаправленийИзмеренийТУ,"IDСтроки",ТекущиеДанные.IDСтроки);
	
	РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные);
КонецПроцедуры

