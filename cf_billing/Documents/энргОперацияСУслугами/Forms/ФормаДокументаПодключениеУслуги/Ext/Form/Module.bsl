#Область РаботаСТочкамиПоставок

&НаКлиенте
Процедура ТочкиПоставокПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда		
		ИмяТаблицыТочек 		= "ТочкиУчета" + ПрефиксТочекУчета;
		ТекущиеДанные 			= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		Элемент.ТекущиеДанные.IDСтроки			= ТекущиеДанные.IDСтроки;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставокПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	ИмяТаблицыТочек 		= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 			= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(,"Выберите точку учета");
		Возврат;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставокУзлыТочкаПоставкиПриИзменении(Элемент)
	ИмяТаблицыТочек = "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 	= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.ДанныеРасположения = энргРаботаСТочкамиУчетаКлиент.ЗаполнитьТекстДанныеРасположения(ТекущиеДанные);
КонецПроцедуры

#КонецОбласти

#Область РаботаСДоговоромДоТП

&НаКлиенте
Процедура ДоговорЗаключенПриИзменении(Элемент)
	
	Если НЕ Объект.ДоговорЗаключен Тогда
		
		Объект.ТочкиПоставок.Очистить();
		Объект.ЗначенияИзмерителей.Очистить();
		Объект.Потери.Очистить();
		Объект.ТочкиУчета.Очистить();
		Объект.Измерители.Очистить();
		Объект.ШкалыПриборовУчета.Очистить();
		Объект.ПоказанияПриборовУчета.Очистить();
		Объект.НомераПломб.Очистить(); 		
		
		УслугиДерево.ПолучитьЭлементы().Очистить(); 		
		Возврат;
		
	КонецЕсли;
	
	ДоговорЗаключенПриИзмененииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ДоговорЗаключенПриИзмененииНаСервере()
	
	ДокОснование = Документы.энргОперацияСЛицевымСчетом.ДокументОткрытияЛицевогоСчетаСДоговоромДоТП(Объект.Абонент);
	Объект.ТочкиПоставок.Загрузить(ДокОснование.ТочкиПоставок.Выгрузить());
	Объект.ЗначенияИзмерителей.Загрузить(ДокОснование.ЗначенияИзмерителей.Выгрузить());
	Объект.Потери.Загрузить(ДокОснование.Потери.Выгрузить());
	Объект.ТочкиУчета.Загрузить(ДокОснование.ТочкиУчета.Выгрузить());
	Объект.Измерители.Загрузить(ДокОснование.Измерители.Выгрузить());	
	Объект.ШкалыПриборовУчета.Загрузить(ДокОснование.ШкалыПриборовУчета.Выгрузить());
	Объект.ПоказанияПриборовУчета.Загрузить(ДокОснование.ПоказанияПриборовУчета.Выгрузить());
	Объект.НомераПломб.Загрузить(ДокОснование.НомераПломб.Выгрузить()); 	
	
	ЗаполнитьСвойстваТочекУчета(Объект); 		
	ЗаполнитьСвойстваПриборовУчета(Объект);
	ЗаполнитьСвойстваИзмерителей(Объект);
	
	ПустойКлючСтроки = Новый ОписаниеТипов("УникальныйИдентификатор");
	УслугиДерево.ПолучитьЭлементы().Очистить();
	ЗаполнитьДеревоУслугНаОснованииТочекУчета(Объект, УслугиДерево, ПустойКлючСтроки.ПривестиЗначение());
	
КонецПроцедуры

#КонецОбласти