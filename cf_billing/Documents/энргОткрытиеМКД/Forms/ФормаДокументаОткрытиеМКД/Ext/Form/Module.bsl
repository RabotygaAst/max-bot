&НаКлиенте
Процедура ДобавитьПриборыУчета(Команда) 
	
	ТекущиеДанные = Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураОтвета = энргРаботаСПриборамиУчетаКлиент.ВернутьНачальныеПараметрыПередачиДляУзлов(ЭтаФорма, ТекущиеДанные, Объект);
	ПолучитьДанныеТабЧастей(СтруктураОтвета.ПараметрыПередачи,ТекущиеДанные.IDСтроки,ТекущиеДанные.ТипУзлаУчета,Неопределено,Неопределено);
	энргРаботаСПриборамиУчетаКлиент.ДобавитьПриборыУчета(СтруктураОтвета);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеТабЧастей(ПараметрыПередачи,IDСтроки,ТипУзлаУчета,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета) 	
	энргРаботаСприборамиУчетаСервер.ПолучитьДанныеТабЧастейУзла(ПараметрыПередачи, IDСтроки, Объект,ТипУзлаУчета,НачалоДействияКоммерскогоУчета,КонецДействияКоммерскогоУчета);
КонецПроцедуры

&НаСервере
Процедура УлицаНедобавленнаяВФИАСПриИзмененииНаСервере()
	Если ЗначениеЗаполнено(Объект.УлицаНедобавленнаяВФИАС) Тогда
		СтрокиКИ 							= Объект.УлицаНедобавленнаяВФИАС.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид",Справочники.ВидыКонтактнойИнформации.АдресНедобавленногоОбъекта));
		Если СтрокиКИ.количество() > 0 тогда
			АдресОбъекта  	= СтрокиКИ[0].Представление; 
			АдресОбъектаЗначение = СтрокиКИ[0].Значение;
			//УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(АдресОбъекта, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресДома"));
			АдресОбъектаСтроительный = АдресОбъекта;
			АдресОбъектаСтроительныйЗначение = АдресОбъектаЗначение;
			//УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(АдресОбъекта, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.СтроительныйАдресДома"));
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УлицаНедобавленнаяВФИАСПриИзменении(Элемент)
	УлицаНедобавленнаяВФИАСПриИзмененииНаСервере();
КонецПроцедуры

#КонецОбласти

&НаСервере
Функция ПолучитьПризнакРаспределения()
	Возврат	РегистрыСведений.энргФормыУправленияМКД.ПолучитьПризнакРаспределения(Объект.Дата, Новый Структура, Объект.ФормаУправления);
КонецФункции

#КонецОбласти

#Область РаботаСУзлами

&НаКлиенте
Процедура РедактироватьТочкиУчета(Команда)
	энргРаботаСТочкамиУчетаКлиент.ОткрытьФормуРедактированияУслугМКД(энргРаботаСТочкамиУчетаКлиент.ПолучитьВходныеДанныеДляЗаполненияУслугМКД(ЭтотОбъект));
КонецПроцедуры

// В дальнейшем удалится 
&НаСервере
Процедура ПоказатьУзлы()
	
	Если НЕ энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыМКД() Тогда
		Возврат
	КонецЕсли;
	
	ПрефиксТочекУчета = "";
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаДанныеУзла", "Видимость", Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаТочкиПоставки", "Видимость", Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаРедактироватьТочкиУчета", "Видимость", Истина);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДобавитьПриборыУчета", "Видимость", Ложь); 	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаЕстьШкалыЕстьТарифныеЗоныГруппа2", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаГруппа2", "Видимость", Ложь); 	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаГруппа1", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаЕстьШкалыЕстьТарифныеЗоныГруппа1", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаТипУзлаУчета", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаДобавить", "Видимость", Ложь);	
	
	энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстовыеПоляКоллекцииМКД(ЭтотОбъект);
		
КонецПроцедуры

#КонецОбласти

#Область РаботаСТочкамиПоставок

&НаКлиенте
Процедура ТочкиПоставокТочкаПоставкиПриИзменении(Элемент)
	ИмяТаблицыТочек = "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанныеТУ = Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	
	Если ТекущиеДанныеТУ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанныеТП	= Элементы.ТочкиПоставок.ТекущиеДанные;
	
	Если ТекущиеДанныеТП <> Неопределено Тогда
		ТекущиеДанныеТУ.СтруктураСети = ПолучитьСтруктуруСетиПоТочкеПоставки(ТекущиеДанныеТП.ТочкаПоставки);
	КонецЕсли;

	
	ТекущиеДанные = Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.ДанныеРасположения = энргРаботаСТочкамиУчетаКлиент.ЗаполнитьТекстДанныеРасположения(ТекущиеДанные);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПриАктивизацииСтроки(Элемент)
	ТаблицаТочкиПоставок	= Элементы.ТочкиПоставок;	
	ТекущиеДанные 			= Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаТочкиПоставок,"IDСтроки",ТекущиеДанные.IDСтроки);
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаТочкиПоставкиПриИзменении(Элемент)
	ПересчитатьНомерСтрокиТаблицаТП();
КонецПроцедуры 

&НаКлиенте
Процедура ТочкиПоставкиТочкаПоставкиПриИзменении(Элемент)
	ТекущиеДанныеСтрокиТабЧасти = Элементы.ТаблицаТочкиПоставки.ТекущиеДанные;
	ПараметрыТочкиПоставки  		=  Новый Структура("МаксимальнаяМощность,ПрисоединеннаяМощность,СетеваяОрганизация,СтруктураСети,УровеньНапряжения,УровеньНапряженияРасчетный, ДоговорТП, АктТП");
	УстановитьПараметрыТП(ТекущиеДанныеСтрокиТабЧасти.ТочкаПоставки,ПараметрыТочкиПоставки);
	ЗаполнитьЗначенияСвойств(ТекущиеДанныеСтрокиТабЧасти,ПараметрыТочкиПоставки);
КонецПроцедуры
	
&НаКлиенте
Процедура ТочкиПоставкиТочкаПоставкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка 	= ложь;	
	ЗначениеОтбора = Новый Структура("ЭтоТочкаПоставки", Истина);
	ПараметрыФормыВыбора = Новый Структура("Отбор", ЗначениеОтбора);
	ОткрытьФорму("Справочник.энргТочкиУчета.Форма.ФормаВыбора",ПараметрыФормыВыбора,Элемент);
КонецПроцедуры 

&НаКлиенте
Процедура ТочкиПоставокПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда		
		ТекущиеДанные 							= Элементы.ТочкиУчета.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		Элемент.ТекущиеДанные.IDСтроки			= ТекущиеДанные.IDСтроки;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставокПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	ТекущиеДанные 							= Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(,"Выберите точку учета");
		Возврат;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставокТочкаПоставкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ДоступныеТочкиПоставки 	 = ПолучитьСписокПодключенныхТП();
	Элемент.СписокВыбора.ЗагрузитьЗначения(ДоступныеТочкиПоставки);
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыТочкиПоставки

&НаСервере
Функция ПолучитьСтруктуруСетиПоТочкеПоставки(ТочкаПоставки) 	
	Результат	= РегистрыСведений.энргПараметрыТочекПоставки.АктуальныеПараметрыТочкиПоставкиПоСсылке(ТочкаПоставки);
	Выборка   	= Результат.Выбрать();

	Если Выборка.Следующий() Тогда 
		Возврат Выборка.СтруктураСети;
	Иначе
		Возврат Справочники.бестСтруктураСети.ПустаяСсылка();
	КонецЕсли;
КонецФункции

&НаСервере
Функция ПолучитьСписокПодключенныхТП()
	МассивТочкиПоставки =  ТочкиПоставки.Выгрузить(,"ТочкаПоставки").ВыгрузитьКолонку("ТочкаПоставки");
	Возврат МассивТочкиПоставки;
КонецФункции

&НаСервере
Процедура ПересчитатьНомерСтрокиТаблицаТП()
    НомерСтроки = 1;
    Для каждого Стр Из ТочкиПоставки Цикл

        Стр.НомерСтроки = НомерСтроки;  
		НомерСтроки=НомерСтроки+1;

	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыТП(ТочкаПоставки,Приемник) 	
	Результат	= РегистрыСведений.энргПараметрыТочекПоставки.АктуальныеПараметрыТочкиПоставкиПоСсылке(ТочкаПоставки);
	Выборка   	= Результат.Выбрать();

	Если Выборка.Следующий() Тогда 
		ЗаполнитьЗначенияСвойств(Приемник,Выборка); 	
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТабЧастьНаборТочекПоставок(ТекущийОбъект)
	ТекущийОбъект.НаборТочекПоставок.Очистить();
	Для Каждого Стр Из ТочкиПоставки Цикл
		НовСтр = ТекущийОбъект.НаборТочекПоставок.Добавить();
		НовСтр.ТочкаПоставки = Стр.ТочкаПоставки;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуТочкиПоставки(Ссылка)
	
	Результат = Документы.энргОткрытиеМКД.АктуальныеПараметрыТочкиПоставки(Ссылка);
	Выборка 				= Результат.Выбрать();
	
	ТочкиПоставки.Очистить();
	
	НомерСтроки = 1;
	
	Пока Выборка.Следующий() Цикл
		СтрокаДляЗаполнения = ТочкиПоставки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДляЗаполнения, Выборка);
		СтрокаДляЗаполнения.НомерСтроки 				= НомерСтроки;
		НомерСтроки 									= НомерСтроки + 1;
		
	КонецЦикла;
	
КонецПроцедуры 

#КонецОбласти  

#Область Подсистема_слжСлужебная

&НаКлиенте
Процедура Подключаемый_слж_ОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	слжСобытияФормКлиентМодуль = ОбщегоНазначенияКлиент.ОбщийМодуль("слжСобытияФормКлиент");
	слжСобытияФормКлиентМодуль.ОбработкаВыбораПоляВвода(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);	
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_слж_ПриИзменении(Элемент)
	
	слжСобытияФормКлиентМодуль = ОбщегоНазначенияКлиент.ОбщийМодуль("слжСобытияФормКлиент");
	слжСобытияФормКлиентМодуль.ПолеВводаПриИзменении(Элемент, ЭтаФорма);	
	ДействиеПоУмолчанию 		= слжСобытияФормКлиентМодуль.ДействиеПриИзмененииПоУмолчанию(Элемент, ЭтаФорма);
	Если Не ПустаяСтрока(ДействиеПоУмолчанию) Тогда
		Выполнить(ДействиеПоУмолчанию+"(Элемент)");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_слж_ПередЗаписью(Отказ, ПараметрыЗаписи)
	 	
	слжМодульКлиент					= ОбщегоНазначенияКлиент.ОбщийМодуль("слжСобытияФормКлиент");
	СтруктураДействияПоУмолчанию 	= слжМодульКлиент.СтруктураДействияПоУмолчанию(ЭтаФорма);
	Если Не ПустаяСтрока(СтруктураДействияПоУмолчанию.ПередЗаписью) Тогда
		Выполнить(СтруктураДействияПоУмолчанию.ПередЗаписью+"(Отказ, ПараметрыЗаписи)");
		Если Отказ Тогда
			Возврат;
		КонецЕсли;		
	КонецЕсли;
			
	Отказ 							= слжВыполнитьСлужебныеОперацииПередЗаписьюСервер(СтруктураДействияПоУмолчанию,ПараметрыЗаписи);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
		
	Если Не ПустаяСтрока(СтруктураДействияПоУмолчанию.ПослеЗаписи) Тогда
		Выполнить(СтруктураДействияПоУмолчанию.ПослеЗаписи+"(ПараметрыЗаписи)");
	КонецЕсли;
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Запись;
	КонецЕсли;
	Отказ 							= Истина;
	Модифицированность 				= Ложь;
	
КонецПроцедуры

&НаСервере
Функция слжВыполнитьСлужебныеОперацииПередЗаписьюСервер(СтруктураДействияПоУмолчанию,ПараметрыЗаписи)
	
	слжМодуль 					= ОбщегоНазначения.ОбщийМодуль("слжСобытияФорм");		
	слжТекущийОбъект 			= РеквизитФормыВЗначение("Объект");
	Отказ 						= Ложь;
	
	Если Не ПустаяСтрока(СтруктураДействияПоУмолчанию.ПередЗаписьюНаСервере) Тогда		
		Выполнить(СтруктураДействияПоУмолчанию.ПередЗаписьюНаСервере+"(Отказ, слжТекущийОбъект, ПараметрыЗаписи)");
		Если Отказ Тогда
			Возврат Истина;
		КонецЕсли;		
	КонецЕсли;		
	
	Если НЕ слжТекущийОбъект.ПроверитьЗаполнение() Тогда
		Отказ 					= Истина;
		Возврат Истина;
	КонецЕсли;

	НачатьТранзакцию();		
	слжТекущийОбъект.Записать(РежимЗаписиДокумента.Запись);
	
	Если Не ПустаяСтрока(СтруктураДействияПоУмолчанию.ПриЗаписиНаСервере) Тогда
		Выполнить(СтруктураДействияПоУмолчанию.ПриЗаписиНаСервере+"(Отказ, слжТекущийОбъект, ПараметрыЗаписи)");
		Если Отказ Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;	
	
	Если Не ПустаяСтрока(СтруктураДействияПоУмолчанию.ПослеЗаписиНаСервере) Тогда
		Выполнить(СтруктураДействияПоУмолчанию.ПослеЗаписиНаСервере+"(слжТекущийОбъект, ПараметрыЗаписи)");
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(слжТекущийОбъект,"Объект");
	ОтменитьТранзакцию();
	Возврат Ложь;
	
КонецФункции

#КонецОбласти