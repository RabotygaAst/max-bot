&НаСервере
Процедура АдресОбъектаНачалоВыбораЗавершениеНаСервере(Представление, Значение, Строительный) 
	
	Если Строительный Тогда
		АдресОбъектаСтроительный 					= Представление;
		АдресОбъектаСтроительныйЗначение		 	= Значение;
	Иначе
		АдресОбъекта 								= Представление;
		АдресОбъектаЗначение 						= Значение;
		
		ЧтениеJSON 									= Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Значение);
		КонтактнаяИнформация 						= ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		Если КонтактнаяИнформация.Свойство("oktmo") Тогда 
			ОКТМО									= КонтактнаяИнформация.oktmo;
		КонецЕсли;
	КонецЕсли;
	Объект.МКД = Справочники.энргСтроения.ПустаяСсылка();
КонецПроцедуры

