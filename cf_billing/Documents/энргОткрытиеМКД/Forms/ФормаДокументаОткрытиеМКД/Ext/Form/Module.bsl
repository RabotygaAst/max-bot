&НаКлиенте
Процедура ФормаУправленияПриИзменении(Элемент)
	Если Объект.ФормаУправления = ПредопределенноеЗначение("Перечисление.энргФормыУправленияМКД.НУ") Тогда
		Объект.УК = Неопределено;
		Объект.РасчетОбъемовВыполняетУК = Ложь;
	КонецЕсли;
	
	УправлениеВидимостью();
	
	ПризнакРаспределенияНаАбонентов = ПолучитьПризнакРаспределения();
	Для Каждого ТекСтр из Объект.ТочкиУчета Цикл
		ТекСтр.РаспределятьНаАбонентов = ПризнакРаспределенияНаАбонентов;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УправлениеВидимостью()
	Элементы.УК.Видимость = Объект.ФормаУправления <> ПредопределенноеЗначение("Перечисление.энргФормыУправленияМКД.НУ");
	Элементы.РасчетОбъемовВыполняетУК.Видимость = Элементы.УК.Видимость;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФормуПоСвойствамСтроения(СвойстваСтроения, ПолучаемыеСвойства)
	
	Если СвойстваСтроения = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	РеквизитыФормы 									= ПолучитьРеквизиты();
	мКлючиСтруктуры 								= СтрРазделить(СтрЗаменить(СтрЗаменить(СтрЗаменить(ПолучаемыеСвойства,Символы.ПС,""),Символы.НПП,"")," ",""),",",Ложь);
	Для Индекс  = 0 По мКлючиСтруктуры.ВГраница() Цикл
		Если СвойстваСтроения.Свойство(мКлючиСтруктуры[Индекс]) Тогда
			Для ИндексРеквизита = 0 По РеквизитыФормы.ВГраница() Цикл
				Если РеквизитыФормы[ИндексРеквизита].Имя = мКлючиСтруктуры[Индекс] Тогда
					ЭтаФорма[мКлючиСтруктуры[Индекс]] 	= СвойстваСтроения[мКлючиСтруктуры[Индекс]];
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;		
	КонецЦикла; 		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваСтроения(Знач ТекущийОбъект)
	
	Перем ПолучаемыеСвойстваСтроения, СвойстваСтроения;
	
	ПолучаемыеСвойстваСтроения		= 
	"Бойлер,ВидОбъектаАбонентов,ГодПостройки,ГруппаПотребителейПоУмолчанию,
	|КоличествоЭтажей,МаршрутКонтроллера,Контролер,ТипПлиты,ОКТМО,
	|АдресОбъекта,АдресОбъектаЗначение,АдресОбъектаСтроительный,АдресОбъектаСтроительныйЗначение";
	
	Если ЗначениеЗаполнено(ТекущийОбъект.МКД) Тогда	
		СвойстваСтроения  			= Обработки.энргСтроенияМенеджер.ЗначенияСвойствОбъекта(ТекущийОбъект.МКД, ПолучаемыеСвойстваСтроения);	
	ИначеЕсли Не ПустаяСтрока(ТекущийОбъект.ОписаниеМКД) Тогда
		СвойстваСтроения			= Обработки.энргОткрытиеМКДМенеджер.СвойстваСтроенияИзСтрокиJSON(ТекущийОбъект.ОписаниеМКД, ПолучаемыеСвойстваСтроения);
	КонецЕсли;
	ЗаполнитьФормуПоСвойствамСтроения(СвойстваСтроения,ПолучаемыеСвойстваСтроения);

КонецПроцедуры

&НаСервере
Функция СохраняемыеДанныеМКД()
	ДанныеМКД  				= Новый Структура;
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		ДанныеМКД.Вставить("Организация", 						"" + Объект.Организация.УникальныйИдентификатор());
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Объект.Район) Тогда
		ДанныеМКД.Вставить("Район", 							"" + Объект.Район.УникальныйИдентификатор());
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Бойлер) Тогда
		ДанныеМКД.Вставить("Бойлер", 							Формат(Бойлер,"БЛ=Нет; БИ=Да"));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ГодПостройки) Тогда
		ДанныеМКД.Вставить("ГодПостройки", 						СтрЗаменить(СтрЗаменить("" + ГодПостройки, " ",""), Символы.НПП,""));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидОбъектаАбонентов) Тогда
		ДанныеМКД.Вставить("ВидОбъектаАбонентов", 				"" + ВидОбъектаАбонентов.УникальныйИдентификатор());
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ГруппаПотребителейПоУмолчанию) Тогда
		ДанныеМКД.Вставить("ГруппаПотребителейПоУмолчанию", 	"" + ГруппаПотребителейПоУмолчанию.УникальныйИдентификатор());
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КоличествоЭтажей) Тогда
		ДанныеМКД.Вставить("КоличествоЭтажей",  				СтрЗаменить(СтрЗаменить("" + КоличествоЭтажей, " ",""), Символы.НПП,""));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОКТМО) Тогда
		ДанныеМКД.Вставить("ОКТМО",  							ОКТМО);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Дата) Тогда
		ДанныеМКД.Вставить("Дата", Объект.Дата);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТипПлиты) Тогда
		Индекс 					= Перечисления.энргТипыПлит.Индекс(ТипПлиты);
		ЗначениеПеречисления	= Метаданные.Перечисления.энргТипыПлит.ЗначенияПеречисления.Получить(Индекс);
		ДанныеМКД.Вставить("ТипПлиты",  						"" + ЗначениеПеречисления.Имя);
	КонецЕсли;
			
	Если ЗначениеЗаполнено(АдресОбъекта) Тогда
		ДанныеМКД.Вставить("АдресОбъекта", 						АдресОбъекта);
		ДанныеМКД.Вставить("АдресОбъектаЗначение", 				АдресОбъектаЗначение);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(АдресОбъектаСтроительный) Тогда
		ДанныеМКД.Вставить("АдресОбъектаСтроительный", 			АдресОбъектаСтроительный);
		ДанныеМКД.Вставить("АдресОбъектаСтроительныйЗначение",	АдресОбъектаСтроительныйЗначение);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МаршрутКонтроллера) Тогда
		ДанныеМКД.Вставить("МаршрутКонтроллера",  				"" + МаршрутКонтроллера.УникальныйИдентификатор());
	КонецЕсли;

	Если ЗначениеЗаполнено(Контролер) Тогда
		ДанныеМКД.Вставить("Контролер",  						"" + Контролер.УникальныйИдентификатор());
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.СетеваяОрганизация) Тогда
		ДанныеМКД.Вставить("СетеваяОрганизация", 				"" + Объект.СетеваяОрганизация.УникальныйИдентификатор());
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.СетеваяОрганизацияПередачаЭЭ) Тогда
		ДанныеМКД.Вставить("СетеваяОрганизацияПередачаЭЭ", 		"" + Объект.СетеваяОрганизацияПередачаЭЭ.УникальныйИдентификатор());
	КонецЕсли;

	Если Объект.ВидыБлагоустройстваТарифныеКатегории.Количество() > 0 Тогда
		МассивВидов = Новый Массив;
		Для Каждого СтрокаВидов Из Объект.ВидыБлагоустройстваТарифныеКатегории Цикл
			Структура = Новый Структура;
			Если ЗначениеЗаполнено(СтрокаВидов.Услуга) Тогда
				Структура.Вставить("Услуга", "" + СтрокаВидов.Услуга.УникальныйИдентификатор());	
			КонецЕсли; 
			Если ЗначениеЗаполнено(СтрокаВидов.ВидБлагоустройстваИндивидуальный) Тогда
				Структура.Вставить("ВидБлагоустройстваИндивидуальный", "" + СтрокаВидов.ВидБлагоустройстваИндивидуальный.УникальныйИдентификатор());	
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаВидов.ВидБлагоустройстваОбщедомовой) Тогда
				Структура.Вставить("ВидБлагоустройстваОбщедомовой", "" + СтрокаВидов.ВидБлагоустройстваОбщедомовой.УникальныйИдентификатор());	
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаВидов.ТарифнаяКатегория) Тогда
				Структура.Вставить("ТарифнаяКатегория", "" + СтрокаВидов.ТарифнаяКатегория.УникальныйИдентификатор());	
			КонецЕсли;			
			МассивВидов.Добавить(Структура);
		КонецЦикла;
		ДанныеМКД.Вставить("ВидыБлагоустройстваТарифныеКатегории",МассивВидов);
	КонецЕсли;
	
	
	Запись 					= Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись,ДанныеМКД);
	Возврат Запись.Закрыть();
КонецФункции

