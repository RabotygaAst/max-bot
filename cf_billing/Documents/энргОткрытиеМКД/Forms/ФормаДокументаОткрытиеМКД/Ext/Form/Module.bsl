#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		слжСобытияФормМодуль = ОбщегоНазначения.ОбщийМодуль("слжСобытияФорм");
		слжСобытияФормМодуль.ПриСозданииНаСервере(ЭтотОбъект, Объект);
		Если Параметры.Свойство("слжКлюч") Тогда			
			слжПреобразовательДанныхМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжПреобразовательДанных");
			слжТекущийОбъект 				= слжПреобразовательДанныхМодуль.ТекущийОбъектПриЧтенииНаСервере(Параметры["слжКлюч"]);			
			слжПреобразовательДанныхМодуль.ЗаполнитьДанныеФормы(Параметры["слжКлюч"],Объект);
			ПриЧтенииНаСервере(слжТекущийОбъект);			
		КонецЕсли;		
	КонецЕсли;	
	
	энргЛокализацияСервер.ПриСозданииНаСервере_энргОткрытиеМКД(ЭтотОбъект);	
	//энргОбщегоНазначения.УстановитьСписокРайонов(Объект.Район,Элементы.Район); 		
	энргОбщегоНазначения.УстановитьСписокМаршрутовКонтролера(Контролер,МаршрутКонтроллера,Элементы.МаршрутКонтроллера,Объект.МКД);
			
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
		КонецЕсли;
	КонецЕсли;
	
	Если Параметры.Ключ.Пустая() Тогда
		Объект.ФормаУправления		= ПредопределенноеЗначение("Перечисление.энргФормыУправленияМКД.НУ");		
	КонецЕсли; 
	
	// энргРаботаСПоставщиками {
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма);
	// энргРаботаСПоставщиками }
		
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
		
	ПризнакРаспределенияНаАбонентов = ПолучитьПризнакРаспределения();	
	ПоказатьУзлы();
	
	РезультатЗапроса = РегистрыСведений.энргТехническаяВозможностьОРП.ПолучитьВозможностьОРП(Объект.МКД);
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда 
		ТехническаяВозможностьПроведенияОРП = Выборка.ЕстьВозможность;
	Иначе
		ТехническаяВозможностьПроведенияОРП = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
		
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
			
	// энргРаботаСПоставщиками {
	энргРаботаСФормуламиРасчетаСервер.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// энргРаботаСПоставщиками }
	
	ЗаполнитьСвойстваСтроения(ТекущийОбъект);
	  	
	ЗаполнитьСвойстваТочекУчета(ТекущийОбъект);
	
	ЗаполнитьСвойстваПриборовУчета(ТекущийОбъект);
	
	ЗаполнитьТаблицуТочкиПоставки(ТекущийОбъект.Ссылка);

	
	//энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны"), Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета"),ТекущийОбъект);
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, ТекущийОбъект, Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны"), Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета"));

    нОтбор = РегистрыСведений.энргИсполнителиОРП.ПолучитьПоследнее(КонецДня(?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия), Объект.ДатаФактическогоСобытия, Объект.Дата)), Новый Структура("Строение", Объект.МКД));;
	ИсполнительОРП = нОтбор.ИсполнительОРП;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УправлениеВидимостью();
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыМКД() Тогда
		ЗаполнитьТабЧастьНаборТочекПоставок(ТекущийОбъект);
		ПередЗаписьюНаСервереУзлы(Отказ, ТекущийОбъект, ПараметрыЗаписи);
		Возврат;
	КонецЕсли;
		
	ТекущийОбъект.ОписаниеМКД 		= СохраняемыеДанныеМКД();
			
	//энргПользовательскийВводСервер.ЗаписатьПараметрыТочекИПриборовУчета(Объект.ТочкиУчета, ТекущийОбъект);
	энргРаботаСприборамиУчетаСервер.ЗаписатьПараметрыТочек_Узлов_Приборов(Объект.ТочкиУчета, Объект.ПриборыУзловУчета, ТекущийОбъект); 	
	
	//энргШкалыТарифныеЗоныСервер.ЗаполнитьОбъектПоПредставлениюФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		Если Не ЗначениеЗаполнено(ТекущийОбъект.МКД) Тогда
			ТекущийОбъект.МКД 			= Справочники.энргСтроения.ПолучитьСсылку(Новый УникальныйИдентификатор);
			ТекущийОбъект.ДополнительныеСвойства.Вставить("ЭтоНовыйМКД", Истина);
		КонецЕсли;
		
		//энргРаботаСприборамиУчетаСервер.НайтиПриборыУчетаПоПараметрам(ТекущийОбъект,"ТочкиУчета",Отказ);
		энргРаботаСприборамиУчетаСервер.НайтиПриборыУчетаУзловПоПараметрам(ТекущийОбъект,"ПриборыУзловУчета",Отказ);		
		
		НовыеТочкиУчета						= Новый Массив;
		НовыеУзлыУчета 						= Новый Массив;
		НовыеПриборыУчета 					= Новый Массив;
		
		Для Каждого СтрокаТочкиУчета Из ТекущийОбъект.ТочкиУчета Цикл
			Если Не ЗначениеЗаполнено(СтрокаТочкиУчета.ТочкаУчета) Тогда
				СтрокаТочкиУчета.ТочкаУчета = Справочники.энргТочкиУчета.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеТочкиУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
			КонецЕсли;
			
			// Теперь это для узлов --
			Если Не ПустаяСтрока(СтрокаТочкиУчета.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаТочкиУчета.ПриборУчета) Тогда
				СтрокаТочкиУчета.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеУзлыУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
			КонецЕсли;
			// --Теперь это для узлов					
			
		КонецЦикла;
		
		Для Каждого СтрокаПриборовУчета Из ТекущийОбъект.ПриборыУзловУчета Цикл
			
			Если Не ПустаяСтрока(СтрокаПриборовУчета.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаПриборовУчета.ПриборУчета) Тогда
				СтрокаПриборовУчета.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеПриборыУчета.Добавить(СтрокаПриборовУчета.НомерСтроки);
			КонецЕсли;			
			
		КонецЦикла;
		
		 		
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеТочкиУчета", 	НовыеТочкиУчета);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеУзлыУчета", 	НовыеУзлыУчета);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеПриборыУчета", 	НовыеПриборыУчета);
		
		
		////БЫЛО-->
		//НовыеТочкиУчета						= Новый Массив;
		//НовыеПриборыУчета 					= Новый Массив;
		//
		//Для Каждого СтрокаТочкиУчета Из ТекущийОбъект.ТочкиУчета Цикл
		//	Если Не ЗначениеЗаполнено(СтрокаТочкиУчета.ТочкаУчета) Тогда
		//		СтрокаТочкиУчета.ТочкаУчета = Справочники.энргТочкиУчета.ПолучитьСсылку(Новый УникальныйИдентификатор);
		//		НовыеТочкиУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
		//	КонецЕсли;
		//	
		//	Если Не ПустаяСтрока(СтрокаТочкиУчета.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаТочкиУчета.ПриборУчета) Тогда
		//		СтрокаТочкиУчета.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
		//		НовыеПриборыУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
		//	КонецЕсли;			
		//КонецЦикла;
		//
		//ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеТочкиУчета", 	НовыеТочкиУчета);
		//ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеПриборыУчета", 	НовыеПриборыУчета);
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыМКД() Тогда
		ПриЗаписиНаСервереУзлы(Отказ, ТекущийОбъект, ПараметрыЗаписи);
		Возврат;
	КонецЕсли;
	
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		энргРаботаСЛицевымСчетомСервер.ПроверитьИСоздатьМКД(ТекущийОбъект,Отказ);
		
		энргРаботаСТочкамиУчетаСервер.СоздатьТочкиУчета(ТекущийОбъект,"ТочкиУчета", Отказ);
		//энргРаботаСприборамиУчетаСервер.СоздатьПриборыУчета(ТекущийОбъект,"ТочкиУчета", Отказ);
		энргРаботаСприборамиУчетаСервер.СоздатьПриборыУчета(ТекущийОбъект,"ПриборыУзловУчета", Отказ);
		энргРаботаСприборамиУчетаСервер.СоздатьУзлыУчета(ТекущийОбъект,"ТочкиУчета",Отказ);
		
		// Определяем контроллера по адресу.
		Объект.УдалитьАдресОбъекта						= ЭтотОбъект.АдресОбъекта;
		Объект.УдалитьАдресОбъектаПредставлениеПолей	= ЭтотОбъект.АдресОбъектаЗначение;
		
		Если ЗначениеЗаполнено(МаршрутКонтроллера) Тогда
			энргРаботаСЛицевымСчетомСервер.ДобавитьАдресКМашруту(Объект.УдалитьАдресОбъекта,Объект.УдалитьАдресОбъектаПредставлениеПолей,ЭтотОбъект.Контролер,МаршрутКонтроллера);
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущийОбъект.МКД) Тогда
		РС = РегистрыСведений.энргТехническаяВозможностьОРП;		
		РезультатЗапроса = РС.ПолучитьВозможностьОРП(ТекущийОбъект.МКД);		
		Выборка = РезультатЗапроса.Выбрать();		
		Если Выборка.Следующий() Тогда 
			ТекТехническаяВозможностьПроведенияОРП = Выборка.ЕстьВозможность;
		Иначе
			ТекТехническаяВозможностьПроведенияОРП = Ложь;
		КонецЕсли;
		
		Если ТекТехническаяВозможностьПроведенияОРП <> ТехническаяВозможностьПроведенияОРП Тогда
			РС.УстановитьВозможностьОРП(ТекущийОбъект.МКД, Неопределено, ТехническаяВозможностьПроведенияОРП);
		КонецЕсли;
		
		рИсполнитель = РегистрыСведений.энргИсполнителиОРП;
		рИсполнитель.УстановитьИсполнителяОРП(ТекущийОбъект.МКД, ИсполнительОРП, ?(ЗначениеЗаполнено(ТекущийОбъект.ДатаФактическогоСобытия), ТекущийОбъект.ДатаФактическогоСобытия, ТекущийОбъект.Дата));
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ЗаполнитьСвойстваСтроения(ТекущийОбъект);	  	
	ЗаполнитьСвойстваТочекУчета(ТекущийОбъект);	
	ЗаполнитьСвойстваПриборовУчета(ТекущийОбъект);	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, ТекущийОбъект, Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны"), Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета"));

	ПоказатьУзлы(); 
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	УдалитьНезначащиеСтрокиВТочкахПоставок(); 	
	
	Если ЕстьОшибкиЗаполнения(ПараметрыЗаписи.РежимЗаписи) Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение И НачалоДня(Объект.Дата) <> Объект.ДатаФактическогоСобытия и ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия) Тогда 
		ОписаниеОповещения  = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПроведения",ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения,"Дата документа отличается от фактической даты! Провести документ?",РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
	Если не ЗначениеЗаполнено(Объект.ФормаУправления) Тогда 
		Отказ = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Поле «Форма управления» не заполнено");
	КонецЕсли;
	
	Если не ЗначениеЗаполнено(Объект.ВидыБлагоустройстваТарифныеКатегории) Тогда 
		Отказ = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не введено ни одной строки в список «Виды благоустройства, тарифные категории»");
	КонецЕсли;
	
	Если СостояниеМКД() И ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Такое МКД уже активно");
	КонецЕсли;

КонецПроцедуры

Функция СостояниеМКД()
	
	Состояние = Ложь;
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Приод",				?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия),КонецДня(Объект.ДатаФактическогоСобытия),Объект.Дата));
	Запрос.УстановитьПараметр("МКД",				Объект.МКД);
	Запрос.УстановитьПараметр("Организация",		Объект.Организация);
	Запрос.УстановитьПараметр("Район",				Объект.Район);
	Запрос.Текст  	= 
	"ВЫБРАТЬ
	|энргСостояниеМКДСрезПоследних.Состояние КАК Состояние
	|ИЗ
	|РегистрСведений.энргСостояниеМКД.СрезПоследних(
	|		&Приод,
	|		МКД = &МКД
	|			И Организация = &Организация
	|			И Район = &Район) КАК энргСостояниеМКДСрезПоследних";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Состояние = Выборка.Состояние;
	КонецЕсли;
	
	Возврат Состояние;
	
КонецФункции

&НаКлиенте
Процедура ПослеЗакрытияВопросаПроведения(РезультатВопроса,ДополнительныеПараметры) Экспорт
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если  РезультатВопроса = КодВозвратаДиалога.Нет тогда
			Отказ = Истина;
		КонецЕсли; 		
	КонецЕсли;	
КонецПроцедуры

//УЗЛЫ 

&НаСервере
Процедура ПередЗаписьюНаСервереУзлы(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ОписаниеМКД 		= СохраняемыеДанныеМКД();
	СоответствиеСтрок 				= Новый Соответствие; 
	ЗаписатьПараметрыТочекИПриборовУчета(ТекущийОбъект, СоответствиеСтрок);
	
	//энргШкалыТарифныеЗоныСервер.ЗаполнитьОбъектПоПредставлениюФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);	
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		Если Не ЗначениеЗаполнено(ТекущийОбъект.МКД) Тогда
			ТекущийОбъект.МКД 			= Справочники.энргСтроения.ПолучитьСсылку(Новый УникальныйИдентификатор);
			ТекущийОбъект.ДополнительныеСвойства.Вставить("ЭтоНовыйМКД", Истина);
		КонецЕсли;
		
		//Справочники.энргПриборыУчетаАбонента.НайтиПриборыУчетаПоПараметрам(ТекущийОбъект,"ТочкиУчета",Отказ);
		//Справочники.энргПриборыУчетаАбонента.НайтиПриборыУчетаПоПараметрам(ТекущийОбъект,"Измерители",Отказ);
		
		НовыеТочкиУчета						= Новый Массив;
		НовыеПриборыУчета 					= Новый Массив;
		НовыеИзмерители 					= Новый Массив;
		
		СоответвиеПрибора 					= Новый Соответствие;
		
		Для Каждого СтрокаТочкиУчета Из ТекущийОбъект.ТочкиУчета Цикл
			
			Если Не ЗначениеЗаполнено(СтрокаТочкиУчета.ТочкаУчета) Тогда
				СтрокаТочкиУчета.ТочкаУчета = Справочники.энргТочкиУчета.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеТочкиУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
			КонецЕсли;			
			
			Если Не ПустаяСтрока(СтрокаТочкиУчета.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаТочкиУчета.ПриборУчета) Тогда
				СтрокаТочкиУчета.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеПриборыУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
				
				ЗаводскойНомерЗначение = СоответствиеСтрок[СтрокаТочкиУчета.IDСтроки];
				СоответвиеПрибора.Вставить(ЗаводскойНомерЗначение, СтрокаТочкиУчета.ПриборУчета);
			КонецЕсли;
		
		КонецЦикла;
		
		Для Каждого СтрокаИзмерителя Из ТекущийОбъект.Измерители Цикл
			Если Не ПустаяСтрока(СтрокаИзмерителя.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаИзмерителя.ПриборУчета) Тогда
				ПриборУчетаЗначение = СоответвиеПрибора[СтрокаИзмерителя.ЗаводскойНомер];
				СоздаватьНовый 		= ПриборУчетаЗначение = Неопределено ИЛИ СтрокаИзмерителя.ВспомогательноеОборудование;
				
				Если СоздаватьНовый Тогда
					ПриборУчетаЗначение = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
					НовыеИзмерители.Добавить(СтрокаИзмерителя.НомерСтроки);
				КонецЕсли;			
				
				СтрокаИзмерителя.ПриборУчета = ПриборУчетаЗначение;				
			КонецЕсли;			
		КонецЦикла;
		
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеТочкиУчета", 	НовыеТочкиУчета);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеПриборыУчета", 	НовыеПриборыУчета);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеИзмерители", 	НовыеИзмерители);
		
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервереУзлы(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение тогда
		энргРаботаСЛицевымСчетомСервер.ПроверитьИСоздатьМКД(ТекущийОбъект,Отказ);
		
		НовыеТочкиУчета 					= Новый Массив;
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеТочкиУчета") Тогда
			НовыеТочкиУчета 				= ТекущийОбъект.ДополнительныеСвойства.НовыеТочкиУчета;
		КонецЕсли;
		
		НовыеПриборыУчета 					= Новый Массив;
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеПриборыУчета") Тогда
			НовыеПриборыУчета 				= ТекущийОбъект.ДополнительныеСвойства.НовыеПриборыУчета;
		КонецЕсли;
		
		НовыеИзмерители 					= Новый Массив;
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеИзмерители") Тогда
			НовыеИзмерители 				= ТекущийОбъект.ДополнительныеСвойства.НовыеИзмерители;
		КонецЕсли;
		
		Для Каждого СтрокаТочки Из ТекущийОбъект.ТочкиУчета Цикл
			ЗаполнитьДанныеТочкиВСтроке(Отказ, НовыеТочкиУчета, СтрокаТочки.ТочкаУчета, СтрокаТочки.ОписаниеТочки, СтрокаТочки.НомерСтроки);
			Если ЗначениеЗаполнено(СтрокаТочки.ПриборУчета) Тогда
				ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ, НовыеПриборыУчета, СтрокаТочки.ПриборУчета, СтрокаТочки.ОписаниеПрибора, СтрокаТочки.НомерСтроки);
			КонецЕсли;			
		КонецЦикла;
		
		Для Каждого СтрокаИзмерителя Из ТекущийОбъект.Измерители Цикл
			ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ, НовыеИзмерители, СтрокаИзмерителя.ПриборУчета, СтрокаИзмерителя.ОписаниеПрибора, СтрокаИзмерителя.НомерСтроки);						
		КонецЦикла;
		
		// Определяем контроллера по адресу.
		Объект.УдалитьАдресОбъекта=ЭтотОбъект.АдресОбъекта;
		Объект.УдалитьАдресОбъектаПредставлениеПолей=ЭтотОбъект.АдресОбъектаЗначение;
		
		Если ЗначениеЗаполнено(МаршрутКонтроллера) Тогда
			энргРаботаСЛицевымСчетомСервер.ДобавитьАдресКМашруту(Объект.УдалитьАдресОбъекта,Объект.УдалитьАдресОбъектаПредставлениеПолей,ЭтотОбъект.Контролер,МаршрутКонтроллера);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры


