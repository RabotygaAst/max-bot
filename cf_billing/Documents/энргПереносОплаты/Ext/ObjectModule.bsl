Функция ПолучитьНовыеЗаписи()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("Период", 			?(ЗначениеЗаполнено(ДатаФактическогоСобытия), ДатаФактическогоСобытия, Дата));
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	Запрос.Текст = "ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&Район КАК Район,
	|	&Период КАК Период,
	|	энргПереносОплатыПриемник.ИсточникПоступления КАК ИсточникПоступления,
	|	энргПереносОплатыПриемник.НомерПлатежногоПоручения КАК НомерПлатежногоПоручения,
	|	энргПереносОплатыПриемник.ДатаПлатежногоПоручения КАК ДатаПлатежногоПоручения,
	|	энргПереносОплатыПриемник.СуммаОплаты КАК СуммаОплаты,
	|	энргПереносОплатыПриемник.ФИОПлательщика КАК ФИОПлательщика,
	|	энргПереносОплатыПриемник.НазначениеПлатежа КАК НазначениеПлатежа,
	|	энргПереносОплатыПриемник.Абонент КАК Абонент,
	|	энргПереносОплатыПриемник.ЛицевойСчет КАК ЛицевойСчет,
	|	&ПериодНачисления КАК ПериодНачисления
	|ИЗ
	|	Документ.энргПереносОплаты.Приемник КАК энргПереносОплатыПриемник
	|ГДЕ
	|	энргПереносОплатыПриемник.Ссылка = &Ссылка";
	Результат = Запрос.Выполнить();
	Выборка		= Результат.Выбрать();
	
	Возврат Выборка;	
КонецФункции

