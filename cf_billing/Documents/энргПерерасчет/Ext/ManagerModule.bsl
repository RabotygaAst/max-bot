// Заполняет список команд отчетов.
// 
// Параметры:
//   КомандыОтчетов - ТаблицаЗначений - состав полей см. в функции МенюОтчеты.СоздатьКоллекциюКомандОтчетов.
//   Параметры		- Структура передаваемых параметров.
//
Процедура ДобавитьКомандыОтчетов(КомандыОтчетов, Параметры= Неопределено) Экспорт
	
	КомандаОтчет 									= КомандыОтчетов.Добавить();	
	КомандаОтчет.Идентификатор 						= Метаданные.Отчеты.ДвиженияДокумента.ПолноеИмя();
	КомандаОтчет.Представление 						= НСтр("ru = 'Движения документа'");
	КомандаОтчет.ФункциональныеОпции 				= "";
	КомандаОтчет.ИмяФормы 							= "Отчет.ДвиженияДокумента.Форма";
	КомандаОтчет.МножественныйВыбор 				= Ложь;
	
КонецПроцедуры

// Заполняет список команд создания на основании ОперацииСЛС.
// 
// Параметры:
//   КомандыСоздатьНаОсновании	-	КомандыФормы.
// 
// Возвращаемое значение:
//	 СтрокаТаблицыЗначений.
//
Функция ДобавитьКомандуСоздатьНаОснованииОперацииСЛС(КомандыСоздатьНаОсновании) Экспорт
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.энргПерерасчет) Тогда
		
		КомандаСоздатьНаОсновании 					= КомандыСоздатьНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Обработчик 		= "ВводНаОснованииБиллингКлиент.ПерерасчетНаОснованиииОперацииСЛС";
		КомандаСоздатьНаОсновании.Идентификатор 	= "ПерерасчетНаОснованииеОперацииСЛС";
		КомандаСоздатьНаОсновании.Представление 	= НСтр("ru = 'Перерасчет'");
		КомандаСоздатьНаОсновании.ПроверкаПроведенияПередСозданиемНаОсновании = Истина;
		
		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

