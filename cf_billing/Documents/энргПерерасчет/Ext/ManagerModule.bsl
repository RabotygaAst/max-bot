// Заполняет список возможных операций формы списка.
// 
// Возвращаемое значение:
//	 СписокЗначений.
//
Функция ЗаполнитьСписокВозможныхОперацийФормаСписка() Экспорт 
	
	ЗначенияПеречисления = Метаданные.Перечисления.энргВидыОпераций.ЗначенияПеречисления;
	
	СписокОпераций = Новый СписокЗначений;
	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет,									"Связанный перерасчет");
	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчет_ИзменениеПараметраРассчета,							"Изменение параметра расчета абонента");
	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчет_РучнойПерерасчет,										"Ручной перерасчет");
	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчет_БлокировочныйАкт,										"Регистрация блокировочного акта");
	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчет_КорректировкаГодовогоПотребленияСезонныхУслуг,			"Корректировка годового потребления сезонных услуг");
	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчет_КорректировкаОплаты,									ЗначенияПеречисления.энргПерерасчет_КорректировкаОплаты.Синоним);
	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчет_ИзменениеПризнакаНаличияПрибораСНачалаГода,			ЗначенияПеречисления.энргПерерасчет_ИзменениеПризнакаНаличияПрибораСНачалаГода.Синоним);
	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчет_СписаниеЗадолженности,									"Решение суда");
	СписокОпераций.добавить(Перечисления.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты,									"Перенос/Возврат оплаты");
	
	Возврат СписокОпераций;
	
КонецФункции 

// Возвращает соотвествие видов операции и префиксов форм.
// 
// Возвращаемое значение:
//   Соответствие.
//
Функция СоотвествиеВидовОперацииИПрефиксовФорм() Экспорт
	
	Соотвествие = Новый Соответствие;
	Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет,									"СвязанныйПерерасчет");
	Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_ИзменениеПараметраРассчета,							"ИзменениеПараметраРассчета");
	Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_РучнойПерерасчет,										"РучнойПерерасчет");
	Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_БлокировочныйАкт,										"РучнойПерерасчет");
	Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_КорректировкаГодовогоПотребленияСезонныхУслуг,		"КорректировкаПотребленияСезонныхУслуг");
	Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_КорректировкаОплаты,									"КорректировкаОплаты");
	Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_ИзменениеПризнакаНаличияПрибораСНачалаГода,			"ИзменениеПризнакаНаличияПрибораСНачалаГода");
	Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_СписаниеЗадолженности,								"КорректировкаЗадолженности");
	Соотвествие.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты,									"ПереносВозвратОплаты");
	
	Возврат Соотвествие;
	
КонецФункции

// Получает данные для заполнения расходного кассового ордера.
//
// Параметры:
//  ДокументСсылка	-	ДокументСсылка.энргПерерасчет.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ДанныеДляЗаполненияРасходныйКассовыйОрдер(ДокументСсылка) Экспорт 
	
	ДанныеДляЗаполнения 	= Новый Структура;
	ДанныеДляЗаполнения.Вставить("ДокументОснование", ДокументСсылка); 	
	 
	ДанныеАбонента 			= ДанныеАбонентаДляВозвратаОплаты(ДокументСсылка);
	СуммаВозврата 			= СуммаВозвратаКорректировкиОплаты(ДокументСсылка);
	
	ДанныеДляЗаполнения.Вставить("Сумма", 			СуммаВозврата);
	
	Если НЕ ДанныеАбонента = Неопределено Тогда
		ДанныеДляЗаполнения.Вставить("Абонент", 		ДанныеАбонента.Абонент);
		ДанныеДляЗаполнения.Вставить("КлючПомещения", 	ДанныеАбонента.КлючПомещения);
		ДанныеДляЗаполнения.Вставить("Организация", 	ДанныеАбонента.Организация);
		ДанныеДляЗаполнения.Вставить("Район", 			ДанныеАбонента.Район);
	КонецЕсли;
			
	Возврат ДанныеДляЗаполнения;
	
КонецФункции

// Создает объект связанный перерасчет
//
// Параметры:
//  СсылкаНового	-	ДокументСсылка.энргПерерасчет.
//  Организация		-	СправочникСсылка.Организации.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  МКД				-	СправочникСсылка.энргСтроения.
//  ДатаДокумента	-	Дата.
// 
// Возвращаемое значение:
//   ДанныеФормыСтруктура.
//
Функция СоздатьОбъектСвязанныйПерерасчет(СсылкаНового,Организация,Район,МКД,ДатаДокумента) Экспорт 
		
	ДокументОбъект  							= Документы.энргПерерасчет.СоздатьДокумент();
	ДокументОбъект.Строение						= МКД;				
	ДокументОбъект.УстановитьСсылкуНового(СсылкаНового);		
	ДокументОбъект.Район  						= Район;		
	ДокументОбъект.Дата							= ДатаДокумента;
	ДокументОбъект.Организация 					= Организация;
	ДокументОбъект.ВидОперации 					= Перечисления.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет;
		
	НаборДокументыНачислений 					= РегистрыСведений.энргДокументыНачислений.СоздатьНаборЗаписей();
	НаборДокументыНачислений.Отбор.Организация.Установить(Организация);
	НаборДокументыНачислений.Отбор.ПериодНачисления.Установить(НачалоМесяца(ДатаДокумента));
	НаборДокументыНачислений.Отбор.Район.Установить(Район);
	НаборДокументыНачислений.Отбор.ВидОперацийНачисления.Установить(Перечисления.энргВидыОперацийНачисления.ПерерасчетСредних);
	НаборДокументыНачислений.Отбор.МКД.Установить(МКД);
	
	СтрокаНабора 								= НаборДокументыНачислений.Добавить();
	СтрокаНабора.Организация 					= Организация;
	СтрокаНабора.ПериодНачисления 				= НачалоМесяца(ДатаДокумента);
	СтрокаНабора.Район			 				= Район;
	СтрокаНабора.ВидОперацийНачисления			= Перечисления.энргВидыОперацийНачисления.ПерерасчетСредних;
	СтрокаНабора.МКД							= МКД;
	СтрокаНабора.ДокументНачисления				= СсылкаНового;
	СтрокаНабора.ПометкаУдаления				= Ложь;
	
	ДокументОбъект.ДополнительныеСвойства.Вставить("НаборДокументыНачислений", НаборДокументыНачислений);
	
	Возврат ДокументОбъект; 
	
КонецФункции

// Снимает пометку на удаления связанный перерасчет.
//
// Параметры:
//  ДокументСсылка	-	ДокументСсылка.энргПерерасчет.
//  Организация		-	СправочникСсылка.Организации.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  МКД				-	СправочникСсылка.энргСтроения.
//
Процедура СнятьПометкуУдаленияСвязанныйПерерасчет(ДокументСсылка,Организация,Район,МКД) Экспорт  
	ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
	ДокументОбъект.УстановитьПометкуУдаления(Ложь);
КонецПроцедуры

// Выполняется при заполнении ограничения доступа.
//
// Параметры:
//  Ограничение		-	Структура	-	см.УправлениеДоступомПереопределяемый.ПриЗаполненииСписковСОграничениемДоступа.
//
Процедура ПриЗаполненииОграниченияДоступа(Ограничение) Экспорт
	
	Ограничение.Текст =
	"РазрешитьЧтениеИзменение
	|ГДЕ 
	|(ВидОперации = Значение(Перечисление.энргВидыОпераций.ПустаяСсылка))
	|ИЛИ
	|(ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_КорректировкаОплаты)
	|И РольДоступна(энргИзменение_энргПерерасчетКорректировкаОплаты))
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет)
	|И РольДоступна(энргИзменение_энргПерерасчетСвязанныйПерерасчет))
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_РучнойПерерасчет)
	|И РольДоступна(энргИзменение_энргПерерасчетРучнойПерерасчет))
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_ИзменениеПараметраРассчета)
	|И РольДоступна(энргИзменение_энргПерерасчетИзменениеПараметраРассчета))
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_РаспределениеЗадолженности)
	|И РольДоступна(энргИзменение_энргПерерасчетРаспределениеЗадолженности))
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_ИзменениеПризнакаНаличияПрибораСНачалаГода)
	|И РольДоступна(энргИзменение_энргПерерасчетИзменениеПризнакаНаличияПрибораУчетаСНачалаГода))
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_БлокировочныйАкт)
	|И РольДоступна(энргИзменение_энргПерерасчетБлокировочныйАкт))
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_КорректировкаГодовогоПотребленияСезонныхУслуг)
	|И РольДоступна(энргИзменение_энргПерерасчетКорректировкаГодовогоПотребленияСезонныхУслуг))	
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты)
	|И РольДоступна(энргИзменение_энргПерерасчетПереносВозвратОплаты))
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_ПерерасчетНенадлежащегоКачества)
	|И РольДоступна(энргИзменение_энргПерерасчетПерерасчетНенадлежащегоКачества))
	|
	|ИЛИ (ВидОперации = Значение(Перечисление.энргВидыОпераций.энргПерерасчет_СписаниеЗадолженности)
	|И РольДоступна(энргИзменение_энргПерерасчетКорректировкаЗадолженности))";
	
КонецПроцедуры

// Проверяет право для документа.
//
// Параметры:
//  ВидОперации		-	ПеречисленияСсылка.энргВидыОпераций.
//  ПроверкаПрав	-	Строка.
// 
// Возвращаемое значение:
//   Неопределено, Булево.
//
Функция ПроверитьПравоДляДокумента(ВидОперации, ПроверкаПрав = "") Экспорт
	
	РольДляОперации = ВернутьСоответствиеРолиИОперации(ВидОперации);
	Если ПроверкаПрав = "Чтение" Тогда
		РольДляОперации = СтрЗаменить(РольДляОперации, "энргИзменение_", "энргЧтение_");
	КонецЕслИ;
	
	ЕстьПрава = Пользователи.РолиДоступны(РольДляОперации);	
	
	Возврат РольДляОперации = Неопределено Или ЕстьПрава;
	
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	ЕстьОснование 				= Ложь;
	
	Если Параметры.Свойство("Основание") тогда
		Если ЗначениеЗаполнено(Параметры.Основание) тогда
			ЕстьОснование 		= Истина; 						
		КонецЕсли; 		
	КонецЕсли;
	
	ЕстьЗначенияЗаполнения  	= Параметры.свойство("ЗначенияЗаполнения");
	
	ВидОперацииВыбран  			= Ложь;
	
	Если ЕстьЗначенияЗаполнения тогда
		ВидОперацииВыбран 		= Параметры.ЗначенияЗаполнения.свойство("видоперации");
	КонецЕсли;	
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка 	= Ложь;
		Если Параметры.свойство("Ключ") тогда
			ВидОперации 		=  Параметры.ключ.Видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргПерерасчет",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		ИначеЕсли  Параметры.свойство("ЗначениеКопирования") тогда
			ВидОперации 		= Параметры.ЗначениеКопирования.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргПерерасчет",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		ИначеЕсли  ЕстьЗначенияЗАполнения и ВидОперацииВыбран тогда
			ВидОперации 		= Параметры.ЗначенияЗаполнения.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргПерерасчет",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;	
		ИначеЕсли ЕстьОснование тогда 
			Параметры.вставить("ЗаполнитьДокумент",Истина);
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормыПоОснованию("энргПерерасчет",ТипЗнч(Параметры.Основание));
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		иначе
			ВыбраннаяФорма 		= "ОбщаяФорма.энргФормаВыбораОперации";
			Параметры.вставить("ИмяДокумента","энргПерерасчет");
			Параметры.вставить("ВыборОперации",Истина);
		КонецЕсли; 		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	Поля.добавить("Номер");
	Поля.добавить("Дата");
	Поля.добавить("ВидОперации");
	СтандартнаяОбработка = Ложь; 	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	Представление 			="" + Данные.ВидОперации + " №" + Данные.номер + " от " +  Данные.дата;
	СтандартнаяОбработка 	= Ложь;
КонецПроцедуры

#КонецОбласти

