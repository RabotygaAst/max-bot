// Заполняет список команд создания на основании.
// 
// Параметры:
//   КомандыСоздатьНаОсновании	-	КомандыФормы.
//
Функция ДобавитьКомандыСозданияНаОсновании(КомандыСоздатьНаОсновании) Экспорт
	
	Документы.энргРасходныйКассовыйОрдер.ДобавитьКомандуСоздатьНаОснованииДокументПерерасчет(КомандыСоздатьНаОсновании);
	
КонецФункции

// Получает значения норматива ТУ.
//
// Параметры:
//  СтруктураСтроки	-	Структура.
//  СтруктураТарифа	-	Структура.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ЗначенияНормативаТУ(СтруктураСтроки, СтруктураТарифа) Экспорт
	ДействующиеТочки	= Новый ТаблицаЗначений;
	ДействующиеТочки.Колонки.Добавить("Организация",		Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ДействующиеТочки.Колонки.Добавить("Район",				Новый ОписаниеТипов("СправочникСсылка.энргЗоныОтвественности"));
	ДействующиеТочки.Колонки.Добавить("КлючПомещения",		Новый ОписаниеТипов("СправочникСсылка.энргКлючиПомещений"));
	ДействующиеТочки.Колонки.Добавить("ТочкаУчета",			Новый ОписаниеТипов("СправочникСсылка.энргТочкиУчета"));
	ДействующиеТочки.Колонки.Добавить("Услуга",				Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	ДействующиеТочки.Колонки.Добавить("СоставнаяУслуга",	Новый ОписаниеТипов("СправочникСсылка.энргВидыУслуг"));
	ДействующиеТочки.Колонки.Добавить("ГруппаПотребителей",	Новый ОписаниеТипов("СправочникСсылка.энргГруппыПотребителей"));
	ДействующиеТочки.Колонки.Добавить("Поставщик",			Новый ОписаниеТипов("СправочникСсылка.энргКонтрагенты"));
	ДействующиеТочки.Колонки.Добавить("ВидБлагоустройства",	Новый ОписаниеТипов("СправочникСсылка.энргВидыБлагоустройств"));
	
	НоваяСтрока	 = ДействующиеТочки.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураСтроки);
	ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураТарифа);
	
	Схема = Новый СхемаЗапроса;
	
	Параметры	= Новый Структура;
	ПараметрыВТ = Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация"		, "Организация")	, Неопределено));
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Район"			, "Район")			, Неопределено));	
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("КлючПомещения"	, "КлючПомещения")	, Неопределено));
		
	Параметры.Вставить("Период"		, Новый Структура("ИмяПараметра,ТипПараметра", "Период" ,"ТипПараметраГраницаИсключая"));
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	ДействующиеТочки.Организация КАК Организация,
		|	ДействующиеТочки.Район КАК Район,
		|	ДействующиеТочки.КлючПомещения КАК КлючПомещения,
		|	ДействующиеТочки.ТочкаУчета КАК ТочкаУчета,
		|	ДействующиеТочки.Услуга КАК Услуга,
		|	ДействующиеТочки.СоставнаяУслуга КАК СоставнаяУслуга,
		|	ДействующиеТочки.ГруппаПотребителей КАК ГруппаПотребителей,
		|	ДействующиеТочки.Поставщик КАК Поставщик,
		|	ДействующиеТочки.ВидБлагоустройства КАК ВидБлагоустройства
		|ПОМЕСТИТЬ ВспомогательныеДанныеУслуг
		|ИЗ
		|	&ДействующиеТочки КАК ДействующиеТочки");

	РегистрыСведений.энргНаправлениеИспользованияТочекУчета.НаправлениеИспользованияДействующихТочек(Схема, Параметры, "НаправлениеИспользованияДействующихТочек");
	энргРаботаСРабочимМестомОператора.ЗаполнитьСхемуЗначениеНормативов(Схема, Параметры);
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	ЗначенияТекущихНормПотребления.КлючНорматива КАК КлючНорматива,
		|	ЗначенияТекущихНормПотребления.ЗначениеНорматива КАК ЗначениеНорматива
		|ИЗ
		|	ВспомогательныеДанныеУслуг КАК ВспомогательныеДанныеУслуг
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияТекущихНормПотребления КАК ЗначенияТекущихНормПотребления
		|		ПО ВспомогательныеДанныеУслуг.Организация = ЗначенияТекущихНормПотребления.Организация
		|			И ВспомогательныеДанныеУслуг.Район = ЗначенияТекущихНормПотребления.Район
		|			И ВспомогательныеДанныеУслуг.Услуга = ЗначенияТекущихНормПотребления.Услуга");

	ДанныеЗаполнения  						= Новый Структура("КоличествоКомнат,КоличествоПрописанных, КоличествоПроживающих, КоличествоСобственников");
	энргРаботаСЛицевымСчетомСервер.ПараметрыРасчетаАбонента(СтруктураСтроки.Организация, СтруктураСтроки.Район, СтруктураСтроки.Абонент, ТекущаяДата(), ДанныеЗаполнения);

	ПараметрыЗапроса = Новый Структура("Организация,Район,КлючПомещения,КоличествоКомнат,КоличествоПроживающих,КоличествоПрописанных,КоличествоСобственников");
	ПараметрыЗапроса.Вставить("Период",					СтруктураСтроки.ПериодНачисления);
	ПараметрыЗапроса.Вставить("МоментВремени",			СтруктураСтроки.ПериодНачисления);
	ПараметрыЗапроса.Вставить("ТипНачисления",			Перечисления.энргТипыНачислений.ИндивидуальныеНачисления);
	ПараметрыЗапроса.Вставить("ДействующиеТочки",		ДействующиеТочки);
	ЗаполнитьЗначенияСвойств(ПараметрыЗапроса, СтруктураСтроки, "Организация,Район,КлючПомещения");
	ЗаполнитьЗначенияСвойств(ПараметрыЗапроса, ДанныеЗаполнения, "КоличествоКомнат,КоличествоПроживающих,КоличествоПрописанных,КоличествоСобственников");
	
	Пакет = энргСхемаЗапросаСервер.ВыполнитьПакет(Схема, ПараметрыЗапроса);
	Выборка	= Пакет[Пакет.Количество() - 1].Выбрать();
	
	Результат = Новый Структура("ЗначениеНорматива, КлючНорматива", 0, Справочники.энргКлючиНормативов.ПустаяСсылка());
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат,Выборка);
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Получает связанный РКО.
//
// Параметры:
//  ДокументСсылка	-	ДокументСсылка.энргПерерасчет, ДокументСсылка.энргРегистрацияПоказанийАбонента.
// 
// Возвращаемое значение:
//   Неопределено, ДокументСсылка.энргРасходныйКассовыйОрдер.
//
Функция ПолучитьСвязанныйРКО(ДокументСсылка)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргРасходныйКассовыйОрдер.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.энргРасходныйКассовыйОрдер КАК энргРасходныйКассовыйОрдер
		|ГДЕ
		|	НЕ энргРасходныйКассовыйОрдер.ПометкаУдаления
		|	И энргРасходныйКассовыйОрдер.ДокументОснование = &ДокументОснование";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументСсылка);
	
	Результат  					= Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		Выборка  				= Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;

КонецФункции

// Получает данные заполнения начальныех показаний.
//
// Параметры:
//  мДокументы		-	ДокументСсылка.энргПерерасчет.
//  мНомераСтрок	-	Массив из Чисел.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ДанныеЗаполненияНачальныеПоказания(мДокументы, мНомераСтрок) Экспорт 
	
	Схема  							= Новый СхемаЗапроса;
	Пакет 							= Схема.ПакетЗапросов[0];
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаДанныеЗаполненияНачальныеПоказания());
	
	ПараметрыЗапроса  				= Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы",	 	мДокументы);
	ПараметрыЗапроса.Вставить("мНомераСтрок", 	мНомераСтрок);
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргПерерасчет.ДанныеЗаполненияНачальныеПоказания";
		ПараметрыМетода 			= Новый Структура("мДокументы, мНомераСтрок",мДокументы, мНомераСтрок); 
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультат(ИмяМетода, РезультатЗапроса, ПараметрыМетода);
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДанныеАбонентаДляВозвратаОплаты(ДокументСсылка)
	
	Запрос 					= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст 			=
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	энргПерерасчет.Абонент КАК Абонент,
	|	энргАбоненты.КлючПомещения КАК КлючПомещения,
	|	энргАбоненты.Организация КАК Организация,
	|	энргАбоненты.Район КАК Район
	|ИЗ
	|	Документ.энргПерерасчет КАК энргПерерасчет
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|		ПО энргПерерасчет.Абонент = энргАбоненты.Ссылка
	|			И (энргПерерасчет.Ссылка = &Ссылка)";
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Результат  				= Запрос.Выполнить();	
	
	Если НЕ Результат.Пустой() Тогда
		Выборка  			= Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция СуммаВозвратаКорректировкиОплаты(ДокументСсылка)  
	
	Запрос 					= Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст 			=	
	"ВЫБРАТЬ
	|	энргПерерасчетКорректировкаОплаты.СуммаВозврата КАК Сумма
	|ИЗ
	|	Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|ГДЕ
	|	энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка";
		
	Результат  					= Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		Выборка  				= Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Сумма;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция ТекстЗапросаДанныеЗаполненияНачальныеПоказания()
	
	Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Район КАК Район,
	|	энргКлючиПомещений.ЧастныйСектор КАК ЧастныйСектор,
	|	энргКлючиПомещений.Строение КАК Строение,
	|	энргКлючиПомещений.Помещение КАК Помещение,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ВложенныйЗапрос.ДатаРегистратора КАК ДатаРегистратора,
	|	ВложенныйЗапрос.ДокРегистратор КАК ДокРегистратор,
	|	ВложенныйЗапрос.ВСрок КАК ВСрок,
	|	ВложенныйЗапрос.Показания КАК Показания,
	|	ВложенныйЗапрос.ПоказанияТекущегоПериода КАК ПоказанияТекущегоПериода
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргПерерасчет.Организация КАК Организация,
	//|		энргПерерасчет.ПериодНачисления КАК ПериодНачисления,
	|		энргПерерасчетКорректировкаПоказаний.ПериодНачисления КАК ПериодНачисления,
	|		энргПерерасчет.Район КАК Район,
	|		энргПерерасчетКорректировкаПоказаний.КлючПомещения КАК КлючПомещения,
	|		энргПерерасчетКорректировкаПоказаний.ПриборУчетаПосле КАК ПриборУчета,
	|		энргПерерасчетКорректировкаПоказаний.ШкалаПосле КАК Шкала,
	|		энргПерерасчетКорректировкаПоказаний.ТарифнаяЗонаПосле КАК ТарифнаяЗона,
	|		энргПерерасчет.Дата КАК ДатаРегистратора,
	|		энргПерерасчет.Ссылка КАК ДокРегистратор,
	|		ЛОЖЬ КАК ВСрок,
	|		энргПерерасчетКорректировкаПоказаний.ПоказанияПосле КАК Показания,
	|		ЛОЖЬ КАК ПоказанияТекущегоПериода
	|	ИЗ
	|		Документ.энргПерерасчет.КорректировкаПоказаний КАК энргПерерасчетКорректировкаПоказаний
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет КАК энргПерерасчет
	|			ПО энргПерерасчетКорректировкаПоказаний.Ссылка = энргПерерасчет.Ссылка
	|	ГДЕ
	|		энргПерерасчет.Ссылка = &мДокументы
	|		И энргПерерасчетКорректировкаПоказаний.Ссылка = &мДокументы
	|		И энргПерерасчетКорректировкаПоказаний.НомерСтроки В(&мНомераСтрок)) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО ВложенныйЗапрос.КлючПомещения = энргКлючиПомещений.КлючПомещения";
	
	Возврат Текст;
	
КонецФункции

Функция ВернутьСоответствиеРолиИОперации(ВидОперации)
	
	РолиИОперации = Новый Соответствие();
	
	ЗначениеКлюча = ВидОперации;
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_БлокировочныйАкт, "энргИзменение_энргПерерасчетБлокировочныйАкт");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_ИзменениеПараметраРассчета, "энргИзменение_энргПерерасчетИзменениеПараметраРассчета");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_ИзменениеПризнакаНаличияПрибораСНачалаГода, "энргИзменение_энргПерерасчетИзменениеПризнакаНаличияПрибораУчетаСНачалаГода");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_КорректировкаГодовогоПотребленияСезонныхУслуг, "энргИзменение_энргПерерасчетКорректировкаГодовогоПотребленияСезонныхУслуг");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_КорректировкаОплаты, "энргИзменение_энргПерерасчетКорректировкаОплаты");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты, "энргИзменение_энргПерерасчетПереносВозвратОплаты");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_ПерерасчетНенадлежащегоКачества, "энргИзменение_энргПерерасчетПерерасчетНенадлежащегоКачества");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_РаспределениеЗадолженности, "энргИзменение_энргПерерасчетРаспределениеЗадолженности");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_РучнойПерерасчет, "энргИзменение_энргПерерасчетРучнойПерерасчет");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет, "энргИзменение_энргПерерасчетСвязанныйПерерасчет");
	РолиИОперации.Вставить(Перечисления.энргВидыОпераций.энргПерерасчет_СписаниеЗадолженности, "энргИзменение_энргПерерасчетКорректировкаЗадолженности");
	
	Возврат РолиИОперации.Получить(ЗначениеКлюча);	
	
КонецФункции

#КонецОбласти

#КонецЕсли