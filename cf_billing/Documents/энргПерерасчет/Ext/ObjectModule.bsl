Процедура РаспределениеЗадолженности_ДанныеОплаты()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргПерерасчет.Организация КАК Организация,
		|	энргПерерасчет.ПериодНачисления КАК ПериодНачисления,
		|	энргПерерасчет.Район КАК Район,
		|	энргПерерасчет.КлючПомещения КАК КлючПомещения,
		|	энргПерерасчет.Абонент КАК Абонент,
		|	энргПерерасчет.Дата КАК Дата,
		|	энргПерерасчет.Ссылка КАК ДокРегистратор,
		|	0 КАК СуммаОплаты,
		|	ЛОЖЬ КАК ЭтоОплата,
		|	ЛОЖЬ КАК ЭтоКорректировкаОплаты
		|ПОМЕСТИТЬ ШапкаДокумента
		|ИЗ
		|	Документ.энргПерерасчет КАК энргПерерасчет
		|ГДЕ
		|	энргПерерасчет.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ШапкаДокумента.Организация КАК Организация,
		|	ШапкаДокумента.ПериодНачисления КАК ПериодНачисления,
		|	ШапкаДокумента.Район КАК Район,
		|	ВЫБОР
		|		КОГДА энргКлючиПомещений.ЧастныйСектор
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
		|		ИНАЧЕ энргКлючиПомещений.Строение
		|	КОНЕЦ КАК МКД,
		|	ШапкаДокумента.Абонент КАК Абонент,
		|	ШапкаДокумента.Дата КАК Дата,
		|	ШапкаДокумента.ДокРегистратор КАК ДокРегистратор,
		|	ШапкаДокумента.СуммаОплаты КАК СуммаОплаты,
		|	ШапкаДокумента.ЭтоОплата КАК ЭтоОплата,
		|	ШапкаДокумента.ЭтоКорректировкаОплаты КАК ЭтоКорректировкаОплаты
		|ПОМЕСТИТЬ ИтоговыеДанные
		|ИЗ
		|	ШапкаДокумента КАК ШапкаДокумента
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
		|		ПО ШапкаДокумента.КлючПомещения = энргКлючиПомещений.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ШапкаДокумента.Организация,
		|	ШапкаДокумента.ПериодНачисления,
		|	энргАбоненты.Район,
		|	ВЫБОР
		|		КОГДА энргКлючиПомещений.ЧастныйСектор
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
		|		ИНАЧЕ энргКлючиПомещений.Строение
		|	КОНЕЦ,
		|	энргПерерасчетРаспределениеЗадолженностиНовое.Абонент,
		|	ШапкаДокумента.Дата,
		|	ШапкаДокумента.ДокРегистратор,
		|	ШапкаДокумента.СуммаОплаты,
		|	ШапкаДокумента.ЭтоОплата,
		|	ШапкаДокумента.ЭтоКорректировкаОплаты
		|ИЗ
		|	ШапкаДокумента КАК ШапкаДокумента
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет.РаспределениеЗадолженностиНовое КАК энргПерерасчетРаспределениеЗадолженностиНовое
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
		|			ПО энргПерерасчетРаспределениеЗадолженностиНовое.КлючПомещения = энргКлючиПомещений.Ссылка
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		|			ПО энргПерерасчетРаспределениеЗадолженностиНовое.Абонент = энргАбоненты.Ссылка
		|		ПО ШапкаДокумента.ДокРегистратор = энргПерерасчетРаспределениеЗадолженностиНовое.Ссылка
		|			И (энргПерерасчетРаспределениеЗадолженностиНовое.Ссылка = &Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИтоговыеДанные.Организация КАК Организация,
		|	ИтоговыеДанные.ПериодНачисления КАК ПериодНачисления,
		|	ИтоговыеДанные.Район КАК Район,
		|	ИтоговыеДанные.МКД КАК МКД,
		|	ИтоговыеДанные.Абонент КАК Абонент,
		|	ИтоговыеДанные.Дата КАК Дата,
		|	ИтоговыеДанные.ДокРегистратор КАК ДокРегистратор,
		|	ИтоговыеДанные.СуммаОплаты КАК СуммаОплаты,
		|	ИтоговыеДанные.ЭтоОплата КАК ЭтоОплата,
		|	ИтоговыеДанные.ЭтоКорректировкаОплаты КАК ЭтоКорректировкаОплаты
		|ИЗ
		|	ИтоговыеДанные КАК ИтоговыеДанные";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	ДополнительныеСвойства.Вставить("ДанныеОплаты", РезультатЗапроса);
	
КонецПроцедуры
	
