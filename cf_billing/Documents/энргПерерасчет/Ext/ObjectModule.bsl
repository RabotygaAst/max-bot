#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Вставляет в дополнительные свойсва массив приборов.
//
Функция МассивПриборов() Экспорт 
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ссылка",				Ссылка);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("ПериодНачисления",	ПериодНачисления);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("ПериодРегистрации",	ДополнительныеСвойства.ПериодРегистрацииПоказаний);
	Запрос.УстановитьПараметр("МассивПриборов",		Движения.энргПоказанияПриборовУчета.ВыгрузитьКолонку("ПриборУчета"));
	Запрос.Текст  	= 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	&Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	&Район КАК Район,
	|	энргКлючиПомещений.Строение КАК Строение,
	|	энргКлючиПомещений.Помещение КАК Помещение,
	|	энргКлючиПомещений.ЧастныйСектор КАК ЧастныйСектор,
	|	ТаблицаПриборов.КлючПомещения КАК КлючПомещения,
	|	ТаблицаПриборов.ПриборУчетаПосле КАК ПриборУчета,
	|	ЛОЖЬ КАК ВыводПрибораУчета,
	|	""ПоказанияПриборовУчета"" КАК ИмяТабЧасти,
	|	0 КАК Разделитель,
	|	&ПериодРегистрации КАК ПериодРегистрации 
	|ИЗ
	|	Документ.энргПерерасчет.КорректировкаПоказаний КАК ТаблицаПриборов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО ТаблицаПриборов.КлючПомещения = энргКлючиПомещений.КлючПомещения
	|ГДЕ
	|	ТаблицаПриборов.Ссылка = &Ссылка
	|	И ТаблицаПриборов.ПриборУчетаПосле В(&МассивПриборов)";
	
	ДополнительныеСвойства.Вставить("МассивПриборов",Запрос.Выполнить());
	
КонецФункции

// Вставляет в дополнительные свойсва данные оплаты.
//
Процедура ДанныеОплаты() Экспорт 
	
	Если ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_РаспределениеЗадолженности Тогда
		РаспределениеЗадолженности_ДанныеОплаты();
		Возврат;
	КонецЕсли; 	
	
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("Строение", 			Строение);
	Запрос.УстановитьПараметр("Дата", 				Дата);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	Запрос.УстановитьПараметр("ОбъемНачислений", 	ЭтотОбъект.Движения.энргОбъемНачислений.Выгрузить());
	Запрос.Текст 	=
	
	"ВЫБРАТЬ
	|	ОбъемНачислений.Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	&Район КАК Район,
	|	&Строение КАК МКД,
	|	ОбъемНачислений.Абонент КАК Абонент,
	|	&Дата КАК Дата,
	|	&Ссылка КАК ДокРегистратор,
	|	0 КАК СуммаОплаты,
	|	ЛОЖЬ КАК ЭтоОплата,
	|	ЛОЖЬ КАК ЭтоКорректировкаОплаты
	|ПОМЕСТИТЬ ОбъемНачислений
	|ИЗ
	|	&ОбъемНачислений КАК ОбъемНачислений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПерерасчет.Ссылка КАК Ссылка,
	|	энргПерерасчет.Абонент КАК Абонент,
	|	энргПерерасчет.КлючПомещения КАК КлючПомещения,
	|	энргПерерасчет.ВидОперации КАК ВидОперации,
	|	энргПерерасчет.Район КАК Район,
	|	энргПерерасчет.Организация КАК Организация
	|ПОМЕСТИТЬ ДанныеШапки
	|ИЗ
	|	Документ.энргПерерасчет КАК энргПерерасчет
	|ГДЕ
	|	энргПерерасчет.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеШапки.Ссылка КАК Ссылка,
	|	ДанныеШапки.Абонент КАК АбонентШапки,
	|	ДанныеШапки.КлючПомещения КАК КлючПомещенияШапки,
	|	ДанныеШапки.ВидОперации КАК ВидОперации,
	|	энргПерерасчетКорректировкаОплаты.АбонентБыло КАК АбонентБыло,
	|	энргПерерасчетКорректировкаОплаты.АбонентСтало КАК АбонентСтало,
	|	энргПерерасчетКорректировкаОплаты.IDСтроки КАК IDСтроки
	|ПОМЕСТИТЬ ДанныеКорректировкиОплаты
	|ИЗ
	|	ДанныеШапки КАК ДанныеШапки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|		ПО ДанныеШапки.Ссылка = энргПерерасчетКорректировкаОплаты.Ссылка
	|			И (энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДанныеШапки.Ссылка КАК Ссылка,
	|	энргПерерасчетКорректировкаОплатыСтало.Абонент КАК Абонент
	|ПОМЕСТИТЬ ДанныеПереносаВозвратаОплаты
	|ИЗ
	|	ДанныеШапки КАК ДанныеШапки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет.КорректировкаОплатыСтало КАК энргПерерасчетКорректировкаОплатыСтало
	|		ПО ДанныеШапки.Ссылка = энргПерерасчетКорректировкаОплатыСтало.Ссылка
	|			И ДанныеШапки.Абонент <> энргПерерасчетКорректировкаОплатыСтало.Абонент
	|			И (ДанныеШапки.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты))
	|			И (энргПерерасчетКорректировкаОплатыСтало.Ссылка = &Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОбъемНачислений.Организация КАК Организация,
	|	ОбъемНачислений.ПериодНачисления КАК ПериодНачисления,
	|	ОбъемНачислений.Район КАК Район,
	|	ВЫБОР
	|		КОГДА энргКлючиПомещений.ЧастныйСектор
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|		ИНАЧЕ энргКлючиПомещений.Строение
	|	КОНЕЦ КАК МКД,
	|	ОбъемНачислений.Абонент КАК Абонент,
	|	ОбъемНачислений.Дата КАК Дата,
	|	ОбъемНачислений.ДокРегистратор КАК ДокРегистратор,
	|	ОбъемНачислений.СуммаОплаты КАК СуммаОплаты,
	|	ОбъемНачислений.ЭтоОплата КАК ЭтоОплата,
	|	ОбъемНачислений.ЭтоКорректировкаОплаты КАК ЭтоКорректировкаОплаты
	|ИЗ
	|	ОбъемНачислений КАК ОбъемНачислений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|			ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.КлючПомещения
	|		ПО ОбъемНачислений.Абонент = энргАбоненты.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация,
	|	&ПериодНачисления,
	|	ВложенныйЗапрос.Район,
	|	ВЫБОР
	|		КОГДА энргКлючиПомещений.ЧастныйСектор
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|		ИНАЧЕ энргКлючиПомещений.Строение
	|	КОНЕЦ,
	|	ВложенныйЗапрос.Абонент,
	|	&Дата,
	|	ВложенныйЗапрос.ДокРегистратор,
	|	0,
	|	ВложенныйЗапрос.ЭтоОплата,
	|	ВложенныйЗапрос.ЭтоКорректировкаОплаты
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ДанныеКорректировкиОплаты.АбонентБыло КАК Абонент,
	|		ДанныеКорректировкиОплаты.Ссылка КАК ДокРегистратор,
	|		энргАбоненты.КлючПомещения КАК КлючПомещения,
	|		ИСТИНА КАК ЭтоОплата,
	|		ИСТИНА КАК ЭтоКорректировкаОплаты,
	|		энргАбоненты.Организация КАК Организация,
	|		энргАбоненты.Район КАК Район
	|	ИЗ
	|		ДанныеКорректировкиОплаты КАК ДанныеКорректировкиОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ПО ДанныеКорректировкиОплаты.АбонентБыло = энргАбоненты.Ссылка
	|				И (НЕ ДанныеКорректировкиОплаты.АбонентБыло = ДанныеКорректировкиОплаты.АбонентСтало)
	|				И (НЕ ДанныеКорректировкиОплаты.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты))
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		энргПерерасчетКорректировкаОплаты.АбонентСтало,
	|		энргПерерасчетКорректировкаОплаты.Ссылка,
	|		энргАбоненты.КлючПомещения,
	|		ИСТИНА,
	|		ЛОЖЬ,
	|		энргАбоненты.Организация,
	|		энргАбоненты.Район
	|	ИЗ
	|		ДанныеКорректировкиОплаты КАК энргПерерасчетКорректировкаОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ПО энргПерерасчетКорректировкаОплаты.АбонентСтало = энргАбоненты.Ссылка
	|				И (НЕ энргПерерасчетКорректировкаОплаты.АбонентБыло = энргПерерасчетКорректировкаОплаты.АбонентСтало)
	|				И (НЕ энргПерерасчетКорректировкаОплаты.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты))
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		энргПерерасчетКорректировкаОплаты.АбонентСтало,
	|		энргПерерасчетКорректировкаОплаты.Ссылка,
	|		энргАбоненты.КлючПомещения,
	|		ИСТИНА,
	|		ИСТИНА,
	|		энргАбоненты.Организация,
	|		энргАбоненты.Район
	|	ИЗ
	|		ДанныеКорректировкиОплаты КАК энргПерерасчетКорректировкаОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ПО энргПерерасчетКорректировкаОплаты.АбонентБыло = энргАбоненты.Ссылка
	|				И (энргПерерасчетКорректировкаОплаты.АбонентБыло = энргПерерасчетКорректировкаОплаты.АбонентСтало)
	|				И (НЕ энргПерерасчетКорректировкаОплаты.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты))
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ДанныеШапки.Абонент,
	|		ДанныеШапки.Ссылка,
	|		ДанныеШапки.КлючПомещения,
	|		ИСТИНА,
	|		ИСТИНА,
	|		ДанныеШапки.Организация,
	|		ДанныеШапки.Район
	|	ИЗ
	|		ДанныеШапки КАК ДанныеШапки
	|	ГДЕ
	|		ДанныеШапки.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ДанныеПереносаВозвратаОплаты.Абонент,
	|		ДанныеПереносаВозвратаОплаты.Ссылка,
	|		энргАбоненты.КлючПомещения,
	|		ИСТИНА,
	|		ЛОЖЬ,
	|		энргАбоненты.Организация,
	|		энргАбоненты.Район
	|	ИЗ
	|		ДанныеПереносаВозвратаОплаты КАК ДанныеПереносаВозвратаОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ПО ДанныеПереносаВозвратаОплаты.Абонент = энргАбоненты.Ссылка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО ВложенныйЗапрос.КлючПомещения = энргКлючиПомещений.КлючПомещения";
	
	
	// Новый вариант корректировки оплаты
	
	//"ВЫБРАТЬ
	//|	&Организация КАК Организация,
	//|	&ПериодНачисления КАК ПериодНачисления,
	//|	&Район КАК Район,
	//|	&Строение КАК МКД,
	//|	ОбъемНачислений.Абонент КАК Абонент,
	//|	&Дата КАК Дата,
	//|	&Ссылка КАК ДокРегистратор,
	//|	0 КАК СуммаОплаты,
	//|	ЛОЖЬ КАК ЭтоОплата,
	//|	ЛОЖЬ КАК ЭтоКорректировкаОплаты
	//|ПОМЕСТИТЬ ОбъемНачислений
	//|ИЗ
	//|	&ОбъемНачислений КАК ОбъемНачислений
	//|;
	//|
	//|////////////////////////////////////////////////////////////////////////////////
	//|ВЫБРАТЬ РАЗЛИЧНЫЕ
	//|	ОбъемНачислений.Организация КАК Организация,
	//|	ОбъемНачислений.ПериодНачисления КАК ПериодНачисления,
	//|	ОбъемНачислений.Район КАК Район,
	//|	ВЫБОР
	//|		КОГДА энргКлючиПомещений.ЧастныйСектор
	//|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	//|		ИНАЧЕ энргКлючиПомещений.Строение
	//|	КОНЕЦ КАК МКД,
	//|	ОбъемНачислений.Абонент КАК Абонент,
	//|	ОбъемНачислений.Дата КАК Дата,
	//|	ОбъемНачислений.ДокРегистратор КАК ДокРегистратор,
	//|	ОбъемНачислений.СуммаОплаты КАК СуммаОплаты,
	//|	ОбъемНачислений.ЭтоОплата КАК ЭтоОплата,
	//|	ОбъемНачислений.ЭтоКорректировкаОплаты КАК ЭтоКорректировкаОплаты
	//|ИЗ
	//|	ОбъемНачислений КАК ОбъемНачислений
	//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	//|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	//|			ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.КлючПомещения
	//|		ПО ОбъемНачислений.Абонент = энргАбоненты.Ссылка
	//|
	//|ОБЪЕДИНИТЬ ВСЕ
	//|
	//|ВЫБРАТЬ
	//|	ВложенныйЗапрос.Организация,
	//|	&ПериодНачисления,
	//|	&Район,
	//|	ВЫБОР
	//|		КОГДА энргКлючиПомещений.ЧастныйСектор
	//|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	//|		ИНАЧЕ энргКлючиПомещений.Строение
	//|	КОНЕЦ,
	//|	ВложенныйЗапрос.Абонент,
	//|	&Дата,
	//|	ВложенныйЗапрос.ДокРегистратор,
	//|	0,
	//|	ВложенныйЗапрос.ЭтоОплата,
	//|	ВложенныйЗапрос.ЭтоКорректировкаОплаты
	//|ИЗ
	//|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	//|		энргАбоненты.Ссылка КАК Абонент,
