Процедура МассивПомещений() Экспорт 
	
	Запрос  			= Новый Запрос;
	Запрос.УстановитьПараметр("КлючПомещения",		КлючПомещения);
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("ПериодРегистрации",	ДополнительныеСвойства.ПериодРегистрацииПоказаний);
	Запрос.Текст 		=
	"ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	&Район КАК Район,
	|	энргКлючиПомещений.ЧастныйСектор КАК ЧастныйСектор,
	|	энргКлючиПомещений.Строение КАК Строение,
	|	энргКлючиПомещений.Помещение КАК Помещение,
	|	&ПериодРегистрации КАК ПериодРегистрации 
	|ИЗ
	|	РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|ГДЕ
	|	энргКлючиПомещений.КлючПомещения В (&КлючПомещения)";
	
	ДополнительныеСвойства.Вставить("МассивПомещений", Запрос.Выполнить());
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;	
		
	Если ПометкаУдаления Тогда
		ОчиститьДвижения();	
	КонецЕсли;
	
	Если ДополнительныеСвойства.свойство("ВосстановлениеПоследовательности") тогда
		Возврат;
	КонецЕсли;	
	
	Ответственный = Пользователи.ТекущийПользователь();
	ГраницыОтчетногоПериода = энргНачисления.ГраницыОтчетногоПериода(Организация,Район,ПериодНачисления);
	
	ДополнительныеСвойства.Вставить("ПериодРегистрацииПоказаний",	ГраницыОтчетногоПериода.НачалоОП);
	
	Если Не Документы.энргПерерасчет.ПроверитьПравоДляДокумента(ВидОперации, "Изменение") Тогда
		Отказ = Истина;
		ТекстИсключения = СтрШаблон(НСтр("ru = 'Нарушение прав доступа. Невозможно записать документ ""Перерасчет"" с видом операции: %1'"), ВидОперации);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
	Если ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет Тогда
		ДополнительныеСвойства.Вставить("НеПроверятьНаличиеПрисоединенныхФайлов", 	Истина);
		ДополнительныеСвойства.Вставить("НеРегестрироватьВзаиморасчеты", 			Истина);
		ДополнительныеСвойства.Вставить("РегистрироватьПоказанияПУ", 				Ложь);
		ДополнительныеСвойства.Вставить("РегистрироватьСтабильныеПериоды", 			Ложь);
		
		Если НЕ ЭтоНовый() Тогда
			РеквизитыОбъекты 			= ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка,"Организация,Район,Строение,Дата");
			Набор  						= РегистрыСведений.энргДокументыНачислений.СоздатьНаборЗаписей();
			Набор.Отбор.Организация.Установить(РеквизитыОбъекты.Организация);
			Набор.Отбор.ПериодНачисления.Установить(НачалоМесяца(РеквизитыОбъекты.Дата));
			Набор.Отбор.Район.Установить(РеквизитыОбъекты.Район);
			Набор.Отбор.ВидОперацийНачисления.Установить(Перечисления.энргВидыОперацийНачисления.ПерерасчетСредних);
			Набор.Отбор.МКД.Установить(РеквизитыОбъекты.Строение);
			
			Набор.Прочитать();
			
			Если Набор.Количество() > 0 и Набор[0].ДокументНачисления = Ссылка Тогда
				Набор[0].ПометкаУдаления = ПометкаУдаления;
				Набор.Записать();
			КонецЕсли;
		КонецЕсли;
		Возврат;				
	КонецЕсли;
	
	Если ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет Тогда
		ДополнительныеСвойства.Вставить("НеПроверятьНаличиеПрисоединенныхФайлов", 	Истина);
		ДополнительныеСвойства.Вставить("НеРегестрироватьВзаиморасчеты", 			Истина);
		ДополнительныеСвойства.Вставить("РегистрироватьПоказанияПУ", 				Ложь);
		ДополнительныеСвойства.Вставить("РегистрироватьСтабильныеПериоды", 			Ложь);
		
		Если НЕ ЭтоНовый() Тогда
			РеквизитыОбъекты 			= ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка,"Организация,Район,Строение,Дата");
			Набор  						= РегистрыСведений.энргДокументыНачислений.СоздатьНаборЗаписей();
			Набор.Отбор.Организация.Установить(РеквизитыОбъекты.Организация);
			Набор.Отбор.ПериодНачисления.Установить(НачалоМесяца(РеквизитыОбъекты.Дата));
			Набор.Отбор.Район.Установить(РеквизитыОбъекты.Район);
			Набор.Отбор.ВидОперацийНачисления.Установить(Перечисления.энргВидыОперацийНачисления.ПерерасчетСредних);
			Набор.Отбор.МКД.Установить(РеквизитыОбъекты.Строение);
			
			Набор.Прочитать();
			
			Если Набор.Количество() > 0 и Набор[0].ДокументНачисления = Ссылка Тогда
				Набор[0].ПометкаУдаления = ПометкаУдаления;
				Набор.Записать();
			КонецЕсли;
		КонецЕсли;
		Возврат;				
	КонецЕсли;

	ДополнительныеСвойства.Вставить("Кассир",						Справочники.Пользователи.ПустаяСсылка());
	ДополнительныеСвойства.Вставить("ГруппаАбонентов", 				Истина);
	ДополнительныеСвойства.Вставить("ИсточникПоступления", 			ИсточникПоступления);
	
	Если ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_БлокировочныйАкт Тогда
		ДополнительныеСвойства.Вставить("РегистрироватьСтабильныеПериоды", Истина);
	Иначе
		ДополнительныеСвойства.Вставить("РегистрироватьСтабильныеПериоды", Ложь);
	КонецЕсли;
	
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект); 
			
	Если НЕ ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_СвязанныйПерерасчет И НЕ ПометкаУдаления Тогда
		Если ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_БлокировочныйАкт Тогда
			ЗаписатьДанныеБлокировочногоАкта();
		Иначе
			Если ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_РучнойПерерасчет Тогда
				Движения.энргОбъемНачислений.ДополнительныеСвойства.Вставить("НеПересчитыватьСумму", Истина);
			КонецЕсли;

			Для Каждого СтрокаНабора Из Движения.энргОбъемНачислений Цикл
				СтрокаНабора.Период 		= Дата;
				СтрокаНабора.Активность 	= Истина;
				СтрокаНабора.ПериодРасчета 	= ПериодНачисления;		
				СтрокаНабора.Район			= Район;
				Если ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_РучнойПерерасчет Тогда
					СтрокаНабора.Организация 	= Организация;
					СтрокаНабора.КлючПомещения  = КлючПомещения;
				КонецЕсли;
				СтрокаНабора.ВидНачисления 	= Перечисления.энргВидыНачислений.Перерасчет;
				КлючПомещенияСтрока 		= СтрокаНабора.Абонент.КлючПомещения;
				СтрокаНабора.ЧастныйСектор  = КлючПомещенияСтрока.ЧастныйСектор;
				СтрокаНабора.Строение		= КлючПомещенияСтрока.Строение;
				СтрокаНабора.Помещение		= КлючПомещенияСтрока.Помещение;
				//СтрокаНабора.НачалоПериода  = НачалоМесяца(ПериодНачисления);
				//СтрокаНабора.КонецПериода   = КонецМесяца(ПериодНачисления);						
			КонецЦикла;
			
			Если ЕстьБлокировочныйАкт() Тогда
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			
		КонецЕсли;		
		
		
		Набор = Движения.энргВзаиморасчеты;
		Набор.Записывать = Ложь;		
	КонецЕсли; 	
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.энргОперацияСПриборомУчета") 
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.энргУстановитьКоличествоПрописанных") 
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.энргУстановитьКоличествоКомнат")
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.энргУстановитьЗначениеПлощади")
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.энргУстановитьГруппуПотребителейАбонента") 
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.энргУстановитьВидБлагоустройстваАбонента")
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.энргОперацияСУслугами")
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.энргУстановитьКоличествоПроживающих")
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.энргУстановитьКоличествоСобственников") Тогда 		
		СтрокаПомещения 				= Помещения.Добавить();
		СтрокаПомещения.КлючПомещения 	= ДанныеЗаполнения.КлючПомещения;
		СтрокаПомещения.Абонент		 	= ДанныеЗаполнения.Абонент;
		 
		ВидОперации 					= Перечисления.энргВидыОпераций.энргПерерасчет_ИзменениеПараметраРассчета;
		Организация 					= ДанныеЗаполнения.Организация;
		Район		 					= ДанныеЗаполнения.Район;
		ПериодНачисления		 		= ДанныеЗаполнения.ПериодНачисления;
		СтрокаОснования 				= ДокументыОснования.Добавить();
		СтрокаОснования.Документ 		= ДанныеЗаполнения;			
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		
	Иначе
		энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
	КонецЕсли;
			
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПометкаУдаления Тогда	
		Если КорректировкаПоказаний.Количество() > 0 Тогда
			
			СкорректироватьПоказания(Отказ);
			
		ИначеЕсли КорректировкаОплаты.Количество() > 0 И ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_КорректировкаОплаты Тогда			
			
			СкорректироватьОплату(Отказ);
		 			
		ИначеЕсли ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты Тогда
			ОчиститьДвижения();
			ПеренестиИВернутьОплату();
		ИначеЕсли ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_РаспределениеЗадолженности Тогда
			
			ОчиститьДвижения();
			ПерераспределитьДолги();
		КонецЕсли;
		
		Если ВидОперации = Перечисления.энргВидыОпераций.энргПерерасчет_СписаниеЗадолженности Тогда
			СписатьЗадолженность(Отказ); 		
		КонецЕсли;
	Иначе
		НаборНачальныхПоказаний 				= РегистрыСведений.энргПредоставленныеПоказания.СоздатьНаборЗаписей();
		НаборНачальныхПоказаний.Отбор.ДокРегистратор.Установить(Ссылка);
		НаборНачальныхПоказаний.Записать();
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Дата, Организация, Район);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура СкорректироватьПоказания(Отказ)
	Набор 									= Движения.энргПоказанияПриборовУчета;
	Набор.Записывать 						= Истина;
	
	НаборКорректировкаПоказаний 			= Движения.энргКорректировкаПоказаний;
	НаборКорректировкаПоказаний.Записывать	= Истина;
	
	НаборМаксимальныеПоказания 				= РегистрыСведений.энргМаксимальныеПоказания.СоздатьНаборЗаписей();
	НаборМаксимальныеПоказания.Отбор.ДокРегистратор.Установить(Ссылка);
	
	Результат 								= РезультатПоказанияПриборовУчета();
	Выборка  								= Результат.Выбрать();
	
	мНомераСтрок 							= Новый Массив;
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Набор.Добавить(), Выборка);
		ЗаполнитьЗначенияСвойств(НаборКорректировкаПоказаний.Добавить(), Выборка);
		
		НСтрокаМакс = НаборМаксимальныеПоказания.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрокаМакс, Выборка);
		НСтрокаМакс.ДокРегистратор = Ссылка;
		
		мНомераСтрок.Добавить(Выборка.НомерСтроки);
	КонецЦикла;
	
	НаборМаксимальныеПоказания.Записать();
	
	ДанныеЗаполненияНачальныеПоказания 		= Документы.энргПерерасчет.ДанныеЗаполненияНачальныеПоказания(Ссылка, мНомераСтрок);
	НаборНачальныхПоказаний 				= РегистрыСведений.энргПредоставленныеПоказания.НаборНачальныеПоказанияРасчетногоПериода(ДанныеЗаполненияНачальныеПоказания);
	НаборНачальныхПоказаний.Отбор.ДокРегистратор.Установить(Ссылка);
	НаборНачальныхПоказаний.Записать();
КонецПроцедуры

Функция РезультатПоказанияПриборовУчета()
	
	Запрос 			= Новый Запрос;             	
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	Запрос.УстановитьПараметр("ПериодРегистрации", 	ДополнительныеСвойства.ПериодРегистрацииПоказаний);	
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргПерерасчетКорректировкаПоказаний.ДатаПоказаний КАК ДатаПоказаний,
	|	энргПерерасчетКорректировкаПоказаний.ПереворотПосле КАК Переворот,
	|	энргПерерасчетКорректировкаПоказаний.ПоказанияПосле КАК Показания,
	|	энргПерерасчетКорректировкаПоказаний.ПриборУчетаПосле КАК ПриборУчета,
	|	энргПерерасчетКорректировкаПоказаний.СостояниеПоказанийПосле КАК СостояниеПоказаний,
	|	энргПерерасчетКорректировкаПоказаний.ТарифнаяЗонаПосле КАК ТарифнаяЗона,
	|	энргПерерасчетКорректировкаПоказаний.ШкалаПосле КАК Шкала,
	|	энргПерерасчетКорректировкаПоказаний.КСПосле КАК КС,
	|	энргПерерасчетКорректировкаПоказаний.ТочкаУчета КАК ТочкаУчета,
	|	энргПерерасчетКорректировкаПоказаний.РегистраторПоказаний КАК РегистраторПоказаний,
	|	энргПерерасчетКорректировкаПоказаний.КлючПомещения КАК КлючПомещения,
	|	энргПерерасчетКорректировкаПоказаний.НомерСтроки КАК НомерСтроки,
	|	энргПерерасчетКорректировкаПоказаний.ПериодНачисления КАК ПериодНачисления,
	|	энргПерерасчетКорректировкаПоказаний.ПоказанияДо КАК ПоказанияДо
	|ПОМЕСТИТЬ ДанныеТЧ
	|ИЗ
	|	Документ.энргПерерасчет.КорректировкаПоказаний КАК энргПерерасчетКорректировкаПоказаний
	|ГДЕ
	|	энргПерерасчетКорректировкаПоказаний.Ссылка = &Ссылка
	|	И (энргПерерасчетКорректировкаПоказаний.ПереворотДо <> энргПерерасчетКорректировкаПоказаний.ПереворотПосле
	|			ИЛИ энргПерерасчетКорректировкаПоказаний.ПоказанияДо <> энргПерерасчетКорректировкаПоказаний.ПоказанияПосле
	|			ИЛИ энргПерерасчетКорректировкаПоказаний.ПриборУчетаДо <> энргПерерасчетКорректировкаПоказаний.ПриборУчетаПосле
	|			ИЛИ энргПерерасчетКорректировкаПоказаний.СостояниеПоказанийДо <> энргПерерасчетКорректировкаПоказаний.СостояниеПоказанийПосле
	|			ИЛИ энргПерерасчетКорректировкаПоказаний.ТарифнаяЗонаДо <> энргПерерасчетКорректировкаПоказаний.ТарифнаяЗонаПосле
	|			ИЛИ энргПерерасчетКорректировкаПоказаний.ШкалаДо <> энргПерерасчетКорректировкаПоказаний.ШкалаПосле
	|			ИЛИ энргПерерасчетКорректировкаПоказаний.КСДо <> энргПерерасчетКорректировкаПоказаний.КСПосле)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&ПериодРегистрации КАК Период,
	|	&Организация КАК Организация,
	|	&Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ДанныеТЧ.ПриборУчета КАК ПриборУчета,
	|	ДанныеТЧ.Шкала КАК Шкала,
	|	ДанныеТЧ.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ДанныеТЧ.Переворот КАК Переворот,
	|	ДанныеТЧ.Показания КАК Показание,
	|	ЗНАЧЕНИЕ(перечисление.энргСостояниеПоказаний.Приняты) КАК СостояниеПоказаний,
	|	ДанныеТЧ.КС КАК КС,
	|	ДанныеТЧ.ПериодНачисления КАК ПериодНачисления,
	|	&ПериодРегистрации КАК ПериодРегистрации,
	|	ДанныеТЧ.ТочкаУчета КАК ТочкаУчета,
	|	ДанныеТЧ.НомерСтроки КАК НомерСтроки,
	|	ДанныеТЧ.РегистраторПоказаний КАК ДокРегистратор,
	|	ДанныеТЧ.ПоказанияДо КАК ПоказанияДо,
	|	ДанныеТЧ.Показания КАК ПоказанияПосле
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		ВложенныйЗапрос.ДатаПоказаний КАК ДатаПоказаний,
	|		ВложенныйЗапрос.Шкала КАК Шкала,
	|		ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|		МАКСИМУМ(ДанныеТЧ.РегистраторПоказаний) КАК РегистраторПоказаний
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ДанныеТЧ.КлючПомещения КАК КлючПомещения,
	|			ДанныеТЧ.ПриборУчета КАК ПриборУчета,
	|			МАКСИМУМ(ДанныеТЧ.ДатаПоказаний) КАК ДатаПоказаний,
	|			ДанныеТЧ.Шкала КАК Шкала,
	|			ДанныеТЧ.ТарифнаяЗона КАК ТарифнаяЗона
	|		ИЗ
	|			ДанныеТЧ КАК ДанныеТЧ
	|		ГДЕ
	|			ДанныеТЧ.СостояниеПоказаний = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ДанныеТЧ.ПриборУчета,
	|			ДанныеТЧ.Шкала,
	|			ДанныеТЧ.ТарифнаяЗона,
	|			ДанныеТЧ.КлючПомещения) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеТЧ КАК ДанныеТЧ
	|			ПО ВложенныйЗапрос.ПриборУчета = ДанныеТЧ.ПриборУчета
	|				И ВложенныйЗапрос.ДатаПоказаний = ДанныеТЧ.ДатаПоказаний
	|				И ВложенныйЗапрос.Шкала = ДанныеТЧ.Шкала
	|				И ВложенныйЗапрос.ТарифнаяЗона = ДанныеТЧ.ТарифнаяЗона
	|				И (ДанныеТЧ.СостояниеПоказаний = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты))
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ВложенныйЗапрос.ПриборУчета,
	|		ВложенныйЗапрос.ДатаПоказаний,
	|		ВложенныйЗапрос.Шкала,
	|		ВложенныйЗапрос.ТарифнаяЗона,
	|		ВложенныйЗапрос.КлючПомещения) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеТЧ КАК ДанныеТЧ
	|		ПО ВложенныйЗапрос.ПриборУчета = ДанныеТЧ.ПриборУчета
	|			И ВложенныйЗапрос.ДатаПоказаний = ДанныеТЧ.ДатаПоказаний
	|			И ВложенныйЗапрос.РегистраторПоказаний = ДанныеТЧ.РегистраторПоказаний
	|			И ВложенныйЗапрос.Шкала = ДанныеТЧ.Шкала
	|			И ВложенныйЗапрос.ТарифнаяЗона = ДанныеТЧ.ТарифнаяЗона
	|			И (ДанныеТЧ.СостояниеПоказаний = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПоказаний.Приняты))";
	
	Возврат Запрос.Выполнить();	
	
КонецФункции

Процедура СкорректироватьОплату(Отказ)
	Набор 									= Движения.энргВзаиморасчеты;
	Набор.Записывать 						= Истина;
	Результат 								= РезультатОперативнаяЗадолженность();
	Выборка  								= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Набор.Добавить(), Выборка);
	КонецЦикла;
	
	Набор 									= Движения.энргИсторияОплаты;
	Набор.Записывать 						= Истина;
	Результат 								= РезультатКорректировкаОплаты();
	Выборка  								= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Набор.Добавить(), Выборка);
	КонецЦикла;
	
КонецПроцедуры

Функция РезультатОперативнаяЗадолженность()
	
	Запрос 		 = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("Период",				Дата);
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	&Период КАК Период,
	|	ВложенныйЗапрос.ВидДвижения КАК ВидДвижения,
	|	&Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВЫБОР
	|		КОГДА энргКлючиПомещений.ЧастныйСектор
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|		ИНАЧЕ энргКлючиПомещений.Строение
	|	КОНЕЦ КАК МКД,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.Сумма КАК Сумма,
	|	&ПериодНачисления КАК ПериодНачисления
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргАбоненты.Район КАК Район,
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|		энргПерерасчетКорректировкаОплаты.АбонентБыло КАК Абонент,
	|		энргАбоненты.КлючПомещения КАК КлючПомещения,
	|		ВЫБОР
	|			КОГДА энргПерерасчетКорректировкаОплаты.АбонентБыло = энргПерерасчетКорректировкаОплаты.АбонентСтало
	|				ТОГДА -СУММА(энргПерерасчетКорректировкаОплаты.СуммаБыло - энргПерерасчетКорректировкаОплаты.СуммаСтало)
	|			ИНАЧЕ -СУММА(энргПерерасчетКорректировкаОплаты.СуммаСтало)
	|		КОНЕЦ КАК Сумма
	|	ИЗ
	|		Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ПО энргПерерасчетКорректировкаОплаты.АбонентБыло = энргАбоненты.Ссылка
	|	ГДЕ
	|		энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргПерерасчетКорректировкаОплаты.АбонентБыло,
	|		энргАбоненты.Район,
	|		энргАбоненты.КлючПомещения,
	|		энргПерерасчетКорректировкаОплаты.АбонентСтало
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		энргАбоненты.Район,
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|		энргПерерасчетКорректировкаОплаты.АбонентСтало,
	|		энргАбоненты.КлючПомещения,
	|		СУММА(энргПерерасчетКорректировкаОплаты.СуммаСтало)
	|	ИЗ
	|		Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ПО энргПерерасчетКорректировкаОплаты.АбонентСтало = энргАбоненты.Ссылка
	|	ГДЕ
	|		энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка
	|		И энргПерерасчетКорректировкаОплаты.АбонентБыло <> энргПерерасчетКорректировкаОплаты.АбонентСтало
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргАбоненты.Район,
	|		энргАбоненты.КлючПомещения,
	|		энргПерерасчетКорректировкаОплаты.АбонентСтало) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО ВложенныйЗапрос.КлючПомещения = энргКлючиПомещений.КлючПомещения";
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция РезультатКорректировкаОплаты() 
	Запрос 		 = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("Период",				Дата);
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	Запрос.УстановитьПараметр("ИсточникПоступления", ИсточникПоступления);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	&Период КАК Период,
	|	&Период КАК ДатаПлатежа,
	|	&Организация КАК Организация,
	|	энргАбоненты.Район КАК Район,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	СУММА(ВложенныйЗапрос.Сумма) КАК СуммаПлатежа,
	|	&ИсточникПоступления КАК ИсточникПоступления,
	|	СУММА(ВложенныйЗапрос.СуммаАвизо) КАК СуммаАвизо,
	|	СУММА(ВложенныйЗапрос.СуммаКРаспределению) КАК СуммаКРаспределению
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргПерерасчетКорректировкаОплаты.АбонентБыло КАК Абонент,
	|		ВЫБОР
	|			КОГДА энргПерерасчетКорректировкаОплаты.АбонентБыло = энргПерерасчетКорректировкаОплаты.АбонентСтало
	|				ТОГДА -СУММА(энргПерерасчетКорректировкаОплаты.СуммаБыло - энргПерерасчетКорректировкаОплаты.СуммаСтало)
	|			ИНАЧЕ -СУММА(энргПерерасчетКорректировкаОплаты.СуммаСтало)
	|		КОНЕЦ КАК Сумма,
	|		0 КАК СуммаАвизо,
	|		0 КАК СуммаКРаспределению
	|	ИЗ
	|		Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет КАК энргПерерасчет
	|			ПО энргПерерасчетКорректировкаОплаты.Ссылка = энргПерерасчет.Ссылка
	|				И (энргПерерасчет.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_КорректировкаОплаты))
	|				И (энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргПерерасчетКорректировкаОплаты.АбонентБыло,
	|		энргПерерасчетКорректировкаОплаты.АбонентСтало
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		энргПерерасчетКорректировкаОплаты.АбонентСтало,
	|		СУММА(энргПерерасчетКорректировкаОплаты.СуммаСтало),
	|		0,
	|		0
	|	ИЗ
	|		Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет КАК энргПерерасчет
	|			ПО энргПерерасчетКорректировкаОплаты.Ссылка = энргПерерасчет.Ссылка
	|				И (энргПерерасчет.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_КорректировкаОплаты))
	|				И (энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка)
	|				И (энргПерерасчетКорректировкаОплаты.АбонентБыло <> энргПерерасчетКорректировкаОплаты.АбонентСтало)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргПерерасчетКорректировкаОплаты.АбонентСтало
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		энргПерерасчет.Абонент,
	|		0,
	|		СУММА(энргПерерасчетКорректировкаОплаты.СуммаВозврата),
	|		-СУММА(энргПерерасчетКорректировкаОплаты.СуммаБыло)
	|	ИЗ
	|		Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет КАК энргПерерасчет
	|			ПО энргПерерасчетКорректировкаОплаты.Ссылка = энргПерерасчет.Ссылка
	|				И (энргПерерасчет.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты))
	|				И (энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргПерерасчет.Абонент
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		энргПерерасчетКорректировкаОплатыСтало.Абонент,
	|		СУММА(ВЫБОР
	|				КОГДА энргПерерасчет.Абонент <> энргПерерасчетКорректировкаОплатыСтало.Абонент
	|					ТОГДА энргПерерасчетКорректировкаОплатыСтало.Сумма
	|				ИНАЧЕ 0
	|			КОНЕЦ),
	|		0,
	|		СУММА(энргПерерасчетКорректировкаОплатыСтало.Сумма)
	|	ИЗ
	|		Документ.энргПерерасчет.КорректировкаОплатыСтало КАК энргПерерасчетКорректировкаОплатыСтало
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет КАК энргПерерасчет
	|			ПО энргПерерасчетКорректировкаОплатыСтало.Ссылка = энргПерерасчет.Ссылка
	|				И (энргПерерасчет.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты))
	|				И (энргПерерасчетКорректировкаОплатыСтало.Ссылка = &Ссылка)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргПерерасчетКорректировкаОплатыСтало.Абонент
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		энргПерерасчет.Абонент,
	|		-СУММА(энргПерерасчетКорректировкаОплатыСтало.Сумма),
	|		0,
	|		0
	|	ИЗ
	|		Документ.энргПерерасчет.КорректировкаОплатыСтало КАК энргПерерасчетКорректировкаОплатыСтало
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет КАК энргПерерасчет
	|			ПО энргПерерасчетКорректировкаОплатыСтало.Ссылка = энргПерерасчет.Ссылка
	|				И (энргПерерасчет.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргПерерасчет_ПереносВозвратОплаты))
	|				И (энргПерерасчетКорректировкаОплатыСтало.Ссылка = &Ссылка)
	|				И (энргПерерасчет.Абонент <> энргПерерасчетКорректировкаОплатыСтало.Абонент)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргПерерасчет.Абонент) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|		ПО ВложенныйЗапрос.Абонент = энргАбоненты.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Абонент,
	|	энргАбоненты.Район";
	
	Возврат Запрос.Выполнить();
КонецФункции

Процедура СписатьЗадолженность(Отказ)
	НаборВзаиморасчетыПоМесяцам				= Движения.энргВзаиморасчетыПоМесяцам;
	НаборВзаиморасчетыПоМесяцам.Записывать	= Истина;
	
	НаборВзаиморасчеты			  			= Движения.энргВзаиморасчеты;
	НаборВзаиморасчеты.Записывать 			= Истина;
	
	НаборВзаиморасчетыПени			  		= Движения.энргВзаиморасчетыПоПени;
	НаборВзаиморасчетыПени.Записывать 		= Истина;
	
	НаборРешениюСуда				  		= Движения.энргЗадолженностьПоРешениюСуда;
	НаборРешениюСуда.Записывать 			= Истина;
	
	
	Для каждого СтрокаТЧ Из УменьшениеОбъемаИСуммы Цикл		
		Движение = НаборВзаиморасчетыПоМесяцам.ДобавитьРасход();
		
		Движение.Период			  = Дата;
		Движение.Организация	  = Организация;
		Движение.Район			  = Район;
		Движение.МКД			  = Строение;
		Движение.Абонент		  = Абонент;
		Движение.Услуга			  = СтрокаТЧ.Услуга;
		Движение.ПериодНачисления = СтрокаТЧ.ПериодНачисления;
		Движение.Поставщик		  = СтрокаТЧ.Поставщик;
		Движение.Сумма			  = СтрокаТЧ.СуммаПерерасчет;
		
		Движение = НаборВзаиморасчеты.ДобавитьРасход();
		
		Движение.Период		 		= Дата;
		Движение.Организация 		= Организация;
		Движение.Район		 		= Район;
		Движение.ПериодНачисления	= ПериодНачисления;
		Движение.МКД		 		= Строение;
		Движение.Абонент	 		= Абонент;
		Движение.Сумма		 		= СтрокаТЧ.СуммаПерерасчет; 
		
		Движение = НаборВзаиморасчетыПени.ДобавитьРасход();
		
		Движение.Период				= Дата;
		Движение.Организация		= Организация;
		Движение.Район				= Район;
		Движение.ПериодНачисления	= СтрокаТЧ.ПериодНачисления;
		Движение.МКД				= Строение;
		Движение.Абонент			= Абонент;
		Движение.Услуга				= СтрокаТЧ.Услуга;
		Движение.Сумма				= СтрокаТЧ.Пеня;
	КонецЦикла;
	
	Для каждого СтрокаТЧ Из ЗадолженностьПоРешениюСуда Цикл		
		Движение = НаборРешениюСуда.ДобавитьПриход();	
		
		ЗаполнитьЗначенияСвойств(Движение, СтрокаТЧ);
		Движение.Период			  = Дата;
		Движение.Организация	  = Организация;
		Движение.Район			  = Район;
		Движение.Строение		  = Строение;
		Движение.Абонент		  = Абонент;
	КонецЦикла;
	
КонецПроцедуры

Процедура ПеренестиИВернутьОплату() 	
	
	Набор 									= Движения.энргВзаиморасчеты;
	Набор.Записывать 						= Истина;
	Результат 								= РезультатСторнированияОплаты();
	Выборка  								= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Набор.Добавить(), Выборка);
	КонецЦикла;	
	
	Набор 									= Движения.энргИсторияОплаты;
	Набор.Записывать 						= Истина;
	Результат 								= РезультатКорректировкаОплаты();
	Выборка  								= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Набор.Добавить(), Выборка);
	КонецЦикла;
	
КонецПроцедуры

Функция РезультатСторнированияОплаты()
	
	Запрос 		 = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("Период",				Дата);
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	энргПерерасчет.Район КАК Район,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	энргПерерасчет.Абонент КАК Абонент,
	|	энргПерерасчет.КлючПомещения КАК КлючПомещения,
	|	СУММА(энргПерерасчетКорректировкаОплаты.СуммаБыло) КАК Сумма,
	|	СУММА(энргПерерасчетКорректировкаОплаты.СуммаВозврата) КАК СуммаВозврата,
	|	&Ссылка КАК Ссылка,
	|	энргПерерасчет.Организация КАК Организация
	|ПОМЕСТИТЬ ДанныеАбонентаШапки
	|ИЗ
	|	Документ.энргПерерасчет КАК энргПерерасчет
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет.КорректировкаОплаты КАК энргПерерасчетКорректировкаОплаты
	|		ПО энргПерерасчет.Ссылка = энргПерерасчетКорректировкаОплаты.Ссылка
	|			И (энргПерерасчет.Ссылка = &Ссылка)
	|			И (энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка)
	|ГДЕ
	|	энргПерерасчетКорректировкаОплаты.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	энргПерерасчет.Абонент,
	|	энргПерерасчет.КлючПомещения,
	|	энргПерерасчет.Район,
	|	энргПерерасчет.Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргАбоненты.Район КАК Район,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	энргПерерасчетКорректировкаОплатыСтало.Абонент КАК Абонент,
	|	энргАбоненты.КлючПомещения КАК КлючПомещения,
	|	СУММА(энргПерерасчетКорректировкаОплатыСтало.Сумма) КАК Сумма,
	|	&Ссылка КАК Ссылка,
	|	энргАбоненты.Организация КАК Организация
	|ПОМЕСТИТЬ ДанныеРаспределения
	|ИЗ
	|	Документ.энргПерерасчет.КорректировкаОплатыСтало КАК энргПерерасчетКорректировкаОплатыСтало
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|		ПО энргПерерасчетКорректировкаОплатыСтало.Абонент = энргАбоненты.Ссылка
	|			И (энргПерерасчетКорректировкаОплатыСтало.Ссылка = &Ссылка)
	|ГДЕ
	|	энргПерерасчетКорректировкаОплатыСтало.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	энргАбоненты.Район,
	|	энргАбоненты.КлючПомещения,
	|	энргПерерасчетКорректировкаОплатыСтало.Абонент,
	|	энргАбоненты.Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеАбонентаШапки.Район КАК Район,
	|	ДанныеАбонентаШапки.ВидДвижения КАК ВидДвижения,
	|	ДанныеАбонентаШапки.Абонент КАК Абонент,
	|	ДанныеАбонентаШапки.КлючПомещения КАК КлючПомещения,
	|	ДанныеАбонентаШапки.Сумма - ДанныеАбонентаШапки.СуммаВозврата - ЕСТЬNULL(ВложенныйЗапрос.Сумма, 0) КАК Сумма,
	|	ДанныеАбонентаШапки.Сумма КАК СуммаСписания,
	|	ДанныеАбонентаШапки.СуммаВозврата КАК СуммаВозврата,
	|	ВложенныйЗапрос.Сумма КАК СуммаРаспределения,
	|	ДанныеАбонентаШапки.Организация КАК Организация
	|ПОМЕСТИТЬ Доначисление
	|ИЗ
	|	ДанныеАбонентаШапки КАК ДанныеАбонентаШапки
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДанныеРаспределения.Ссылка КАК Ссылка,
	|			СУММА(ДанныеРаспределения.Сумма) КАК Сумма
	|		ИЗ
	|			ДанныеРаспределения КАК ДанныеРаспределения
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ДанныеРаспределения.Ссылка) КАК ВложенныйЗапрос
	|		ПО ДанныеАбонентаШапки.Ссылка = ВложенныйЗапрос.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Период КАК Период,
	|	ВложенныйЗапрос.ВидДвижения КАК ВидДвижения,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВЫБОР
	|		КОГДА энргКлючиПомещений.ЧастныйСектор
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|		ИНАЧЕ энргКлючиПомещений.Строение
	|	КОНЕЦ КАК МКД,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.Сумма КАК Сумма,
	|	&ПериодНачисления КАК ПериодНачисления
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеАбонентаШапки.Район КАК Район,
	|		ДанныеАбонентаШапки.ВидДвижения КАК ВидДвижения,
	|		ДанныеАбонентаШапки.Абонент КАК Абонент,
	|		ДанныеАбонентаШапки.КлючПомещения КАК КлючПомещения,
	|		-ДанныеАбонентаШапки.Сумма КАК Сумма,
	|		ДанныеАбонентаШапки.Организация КАК Организация
	|	ИЗ
	|		ДанныеАбонентаШапки КАК ДанныеАбонентаШапки
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ДанныеРаспределения.Район,
	|		ДанныеРаспределения.ВидДвижения,
	|		ДанныеРаспределения.Абонент,
	|		ДанныеРаспределения.КлючПомещения,
	|		ДанныеРаспределения.Сумма,
	|		ДанныеРаспределения.Организация
	|	ИЗ
	|		ДанныеРаспределения КАК ДанныеРаспределения
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		Доначисление.Район,
	|		Доначисление.ВидДвижения,
	|		Доначисление.Абонент,
	|		Доначисление.КлючПомещения,
	|		Доначисление.Сумма,
	|		Доначисление.Организация
	|	ИЗ
	|		Доначисление КАК Доначисление) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
	|		ПО ВложенныйЗапрос.КлючПомещения = энргКлючиПомещений.КлючПомещения
	|ГДЕ
	|	ВложенныйЗапрос.Сумма <> 0";
	
	Результат = Запрос.Выполнить();
	Возврат Результат
	
КонецФункции

#Область РаспределениеЗадолженности

Процедура ПерераспределитьДолги() 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргПерерасчет.Ссылка КАК Ссылка,
		|	энргПерерасчет.Дата КАК Дата,
		|	энргПерерасчет.Организация КАК Организация,
		|	энргПерерасчет.Район КАК Район,
		|	энргПерерасчет.Абонент КАК Абонент,
		|	энргПерерасчет.КлючПомещения КАК КлючПомещения,
		|	энргПерерасчет.ПериодНачисления КАК ПериодНачисления
		|ПОМЕСТИТЬ ШапкаДокумента
		|ИЗ
		|	Документ.энргПерерасчет КАК энргПерерасчет
		|ГДЕ
		|	энргПерерасчет.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргПерерасчетЗадолженностьБыла.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА энргПерерасчетЗадолженностьБыла.ВидЗадолженности = ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.Пеня)
		|			ТОГДА энргПерерасчетЗадолженностьБыла.Услуга
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка)
		|	КОНЕЦ КАК Услуга,
		|	энргПерерасчетЗадолженностьБыла.ВидЗадолженности КАК ВидЗадолженности,
		|	ВЫБОР
		|		КОГДА энргПерерасчетЗадолженностьБыла.ВидЗадолженности = ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.Пеня)
		|			ТОГДА энргПерерасчетЗадолженностьБыла.ПериодНачисления
		|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
		|	КОНЕЦ КАК ПериодНачисления,
		|	СУММА(энргПерерасчетЗадолженностьБыла.Задолженность) КАК Задолженность,
		|	ВЫБОР
		|		КОГДА энргПерерасчетЗадолженностьБыла.ВидЗадолженности = ЗНАЧЕНИЕ(Перечисление.энргВидыЗадолженности.Пеня)
		|			ТОГДА энргПерерасчетЗадолженностьБыла.Поставщик
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка)
		|	КОНЕЦ КАК Поставщик,
		|	СУММА(энргПерерасчетЗадолженностьБыла.ЗадолженностьНовая) КАК ЗадолженностьНовая
		|ПОМЕСТИТЬ ПерераспределениеДолговАбонентаШапки
		|ИЗ
		|	Документ.энргПерерасчет.ЗадолженностьБыла КАК энргПерерасчетЗадолженностьБыла
		|ГДЕ
		|	энргПерерасчетЗадолженностьБыла.Ссылка = &Ссылка
