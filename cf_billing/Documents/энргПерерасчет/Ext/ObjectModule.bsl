	НаборНачислениеПени.Записывать 		= Истина;
	
	Выборка = РезультатЗапроса.Выбрать(); 	
	Пока Выборка.Следующий() Цикл
		Если Выборка.ВидЗадолженности = Перечисления.энргВидыЗадолженности.ОсновнойДолг Тогда
			Движение = НаборВзаиморасчеты.ДобавитьПриход();
			ЗаполнитьЗначенияСвойств(Движение, Выборка);
			Движение.ПериодНачисления = ПериодНачисления;
		КонецЕсли;
		
		Если Выборка.ВидЗадолженности = Перечисления.энргВидыЗадолженности.Пеня Тогда 
			Движение = НаборНачислениеПени.Добавить();			
			ЗаполнитьЗначенияСвойств(Движение, Выборка);
			Движение.ПериодРасчета = ПериодНачисления;
		КонецЕсли;
	КонецЦикла;
		
