		|	ВТ_ДанныеБлокАкта.ЗначениеТарифа КАК ЗначениеТарифа,
		|	ВТ_ДанныеБлокАкта.Поставщик КАК Поставщик,
		|	ВТ_ДанныеБлокАкта.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
		|	ВТ_ДанныеБлокАкта.Шкала КАК Шкала,
		|	ВТ_ДанныеБлокАкта.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ВТ_ДанныеБлокАкта.Измеритель КАК Измеритель,
		|	ВТ_ДанныеБлокАкта.ОбъемУслуги КАК ОбъемУслуги,
		|	ВТ_ДанныеБлокАкта.ОбъемУслугиПотребленный КАК ОбъемУслугиПотребленный,
		|	ВТ_ДанныеБлокАкта.Сумма КАК Сумма
		|ИЗ
		|	ВТ_ДанныеБлокАкта КАК ВТ_ДанныеБлокАкта
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	энргОбъемНачислений.ПериодНачисления,
		|	энргОбъемНачислений.ТочкаУчета,
		|	энргОбъемНачислений.Услуга,
		|	энргОбъемНачислений.ПриборУчета,
		|	энргОбъемНачислений.СпособНачисления,
		|	энргОбъемНачислений.ЗначениеТарифа,
		|	энргОбъемНачислений.Поставщик,
		|	энргОбъемНачислений.НаправлениеИспользованияТУ,
		|	энргОбъемНачислений.Шкала,
		|	энргОбъемНачислений.ТарифнаяЗона,
		|	энргОбъемНачислений.Измеритель,
		|	-энргОбъемНачислений.ОбъемУслуги,
		|	-энргОбъемНачислений.ОбъемУслугиПотребленный,
		|	-энргОбъемНачислений.Сумма
		|ИЗ
		|	ВТ_ДанныеБлокАкта КАК ВТ_ДанныеБлокАкта
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
		|		ПО ВТ_ДанныеБлокАкта.ПериодНачисления = энргОбъемНачислений.ПериодНачисления
		|			И ВТ_ДанныеБлокАкта.ТочкаУчета = энргОбъемНачислений.ТочкаУчета
		|			И ВТ_ДанныеБлокАкта.Услуга = энргОбъемНачислений.Услуга
		|			И ВТ_ДанныеБлокАкта.ПриборУчета = энргОбъемНачислений.ПриборУчета
		|			И ВТ_ДанныеБлокАкта.СпособНачисления = энргОбъемНачислений.СпособНачисления
		|			И ВТ_ДанныеБлокАкта.Поставщик = энргОбъемНачислений.Поставщик
		|			И ВТ_ДанныеБлокАкта.НаправлениеИспользованияТУ = энргОбъемНачислений.НаправлениеИспользованияТУ
		|			И ВТ_ДанныеБлокАкта.Шкала = энргОбъемНачислений.Шкала
		|			И ВТ_ДанныеБлокАкта.ТарифнаяЗона = энргОбъемНачислений.ТарифнаяЗона
		|			И ВТ_ДанныеБлокАкта.Измеритель = энргОбъемНачислений.Измеритель
		|			И (энргОбъемНачислений.Организация = &Организация)
		|			И (энргОбъемНачислений.Район = &Район)
		|			И (энргОбъемНачислений.Строение = &Строение)
		|			И (энргОбъемНачислений.Помещение = &Помещение)
		|			И (энргОбъемНачислений.Абонент = &Абонент)";
	
	Запрос.УстановитьПараметр("ДанныеБлокировочногоАкта",ДанныеБлокировочногоАкта.Выгрузить());
	Запрос.УстановитьПараметр("Организация"				,Организация);
	Запрос.УстановитьПараметр("Район"					,Район);
	Запрос.УстановитьПараметр("Строение"				,ДополнительныеДанные.Строение);
	Запрос.УстановитьПараметр("Помещение"				,ДополнительныеДанные.Помещение);
	Запрос.УстановитьПараметр("Абонент"					,ДополнительныеДанные.Абонент);
	
	
	РезультатЗапроса 		= Запрос.Выполнить();	
	Выборка 				= РезультатЗапроса.Выбрать();
	
	НаборОбъемНачислений 	= Движения.энргОбъемНачислений;
	НаборОбъемНачислений.Очистить();	
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = НаборОбъемНачислений.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);
		ЗаполнитьЗначенияСвойств(НоваяСтрока,ДополнительныеДанные);
	КонецЦикла;
		
КонецПроцедуры

Функция ЕстьБлокировочныйАкт()
										
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеОбъемовНачислений.ПериодНачисления КАК ПериодНачисления,
		|	ДанныеОбъемовНачислений.Строение КАК Строение,
		|	ДанныеОбъемовНачислений.Помещение КАК Помещение,
		|	ДанныеОбъемовНачислений.Абонент КАК Абонент,
		|	ДанныеОбъемовНачислений.ТочкаУчета КАК ТочкаУчета,
		|	ДанныеОбъемовНачислений.Услуга КАК Услуга,
		|	ДанныеОбъемовНачислений.ПриборУчета КАК ПриборУчета,
		|	ДанныеОбъемовНачислений.СпособНачисления КАК СпособНачисления,
		|	ДанныеОбъемовНачислений.ЗначениеТарифа КАК ЗначениеТарифа,
		|	ДанныеОбъемовНачислений.Поставщик КАК Поставщик,
		|	ДанныеОбъемовНачислений.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
		|	ДанныеОбъемовНачислений.Шкала КАК Шкала,
		|	ДанныеОбъемовНачислений.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ДанныеОбъемовНачислений.Измеритель КАК Измеритель
		|ПОМЕСТИТЬ ДанныеОбъемовНачислений
		|ИЗ
		|	&ДанныеОбъемовНачислений КАК ДанныеОбъемовНачислений
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргОбъемНачислений.ПериодНачисления КАК ПериодНачисления,
		|	энргОбъемНачислений.ТочкаУчета КАК ТочкаУчета,
		|	энргОбъемНачислений.Услуга КАК Услуга,
		|	энргОбъемНачислений.ПриборУчета КАК ПриборУчета,
		|	энргОбъемНачислений.СпособНачисления КАК СпособНачисления,
		|	энргОбъемНачислений.ЗначениеТарифа КАК ЗначениеТарифа,
		|	энргОбъемНачислений.Поставщик КАК Поставщик,
		|	энргОбъемНачислений.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
		|	энргОбъемНачислений.Шкала КАК Шкала,
		|	энргОбъемНачислений.ТарифнаяЗона КАК ТарифнаяЗона,
		|	энргОбъемНачислений.Измеритель КАК Измеритель
		|ИЗ
		|	ДанныеОбъемовНачислений КАК ДанныеОбъемовНачислений
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПерерасчет КАК энргПерерасчет
		|			ПО энргОбъемНачислений.Регистратор = энргПерерасчет.Ссылка
		|				И (энргПерерасчет.ВидОперации = &БлокировочныйАкт)
		|		ПО ДанныеОбъемовНачислений.ПериодНачисления = энргОбъемНачислений.ПериодНачисления
		|			И ДанныеОбъемовНачислений.Строение = энргОбъемНачислений.Строение
		|			И ДанныеОбъемовНачислений.Помещение = энргОбъемНачислений.Помещение
		|			И ДанныеОбъемовНачислений.Абонент = энргОбъемНачислений.Абонент
		|			И ДанныеОбъемовНачислений.ТочкаУчета = энргОбъемНачислений.ТочкаУчета
		|			И ДанныеОбъемовНачислений.Услуга = энргОбъемНачислений.Услуга
		|			И ДанныеОбъемовНачислений.ПриборУчета = энргОбъемНачислений.ПриборУчета
		|			И ДанныеОбъемовНачислений.СпособНачисления = энргОбъемНачислений.СпособНачисления
		|			И ДанныеОбъемовНачислений.Поставщик = энргОбъемНачислений.Поставщик
		|			И ДанныеОбъемовНачислений.НаправлениеИспользованияТУ = энргОбъемНачислений.НаправлениеИспользованияТУ
		|			И ДанныеОбъемовНачислений.Шкала = энргОбъемНачислений.Шкала
		|			И ДанныеОбъемовНачислений.ТарифнаяЗона = энргОбъемНачислений.ТарифнаяЗона
		|			И ДанныеОбъемовНачислений.Измеритель = энргОбъемНачислений.Измеритель
		|			И (энргОбъемНачислений.Организация = &Организация)
		|			И (энргОбъемНачислений.Район = &Район)
		|			И (энргОбъемНачислений.Регистратор ССЫЛКА Документ.энргПерерасчет)
		|			И (энргОбъемНачислений.Период <= &Дата)";
	
	Запрос.УстановитьПараметр("ДанныеОбъемовНачислений"	,Движения.энргОбъемНачислений.Выгрузить());
	Запрос.УстановитьПараметр("Организация"				,Организация);
	Запрос.УстановитьПараметр("Район"					,Район);
	Запрос.УстановитьПараметр("Дата"					,Дата);
	Запрос.УстановитьПараметр("БлокировочныйАкт"		,Перечисления.энргВидыОпераций.энргПерерасчет_БлокировочныйАкт);
	
	
	РезультатЗапроса 		= Запрос.Выполнить();	
	Выборка 				= РезультатЗапроса.Выбрать();		
	
	Пока Выборка.Следующий() Цикл
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По введенным данным есть Блокировочный акт.");
	КонецЦикла;
	
	Возврат НЕ РезультатЗапроса.Пустой();
		
КонецФункции

