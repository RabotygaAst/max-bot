&НаКлиенте
Процедура ПомещенияСтроениеПриИзменении(Элемент)
	
	ТекущиеДанные  = Элементы.Помещения.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Строение) Тогда
		ДанныеСтроения					= энргПользовательскийВводСервер.ПрочитатьКлючПомещения(ТекущиеДанные.Строение,ТекущиеДанные.Помещение);
		ТекущиеДанные.КлючПомещения 	= ДанныеСтроения.КлючПомещения;
	Иначе
		ТекущиеДанные.Помещение			= ПредопределенноеЗначение("Справочник.энргПомещения.ПустаяСсылка");
		ТекущиеДанные.КлючПомещения 	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПомещенияАбонентПриИзменении(Элемент)
	ТекущиеДанные  = Элементы.Помещения.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Абонент) Тогда
		
		ДанныеКлючПомещения				= энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущиеДанные.Абонент,"КлючПомещения");
		ТекущиеДанные.КлючПомещения 	= ДанныеКлючПомещения;
		ДанныеКлючаПомещения			= энргОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеКлючПомещения,"Строение,Помещение");
		ТекущиеДанные.Строение			= ДанныеКлючаПомещения.Строение;
		ТекущиеДанные.Помещение			= ДанныеКлючаПомещения.Помещение;
		
	Иначе
		ТекущиеДанные.Строение			= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
		ТекущиеДанные.Помещение			= ПредопределенноеЗначение("Справочник.энргПомещения.ПустаяСсылка");
		ТекущиеДанные.КлючПомещения 	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
	КонецЕсли;
	
КонецПроцедуры

