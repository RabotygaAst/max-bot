	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ЗадолженностьБыла,Неопределено,ТекДанные.IDСтроки,,"КорректировкаБыло");
	//энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.КорректировкаОплатыСтало,Неопределено,ТекДанные.IDСтроки,,"КорректировкаБыло");
КонецПроцедуры

&НаКлиенте
Процедура КорректировкаОплатыПередУдалением(Элемент, Отказ)
	IDСтроки = Элементы.КорректировкаОплаты.ТекущиеДанные.IDСтроки;
	ОчиститьСвязанныеТаблицы(IDСтроки);
КонецПроцедуры

&НаСервере
Процедура ОчиститьСвязанныеТаблицы(IDСтроки)
	Объект.ЗадолженностьБыла.Очистить();
	Объект.КорректировкаОплатыСтало.Очистить();
	Объект.ЗадолженностьСтала.Очистить();	
	//Отбор = Новый Структура("IDСтрокиКорректировкаБыло", IDСтроки);
	//
	//энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.ЗадолженностьБыла, Отбор);
	//энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.ЗадолженностьСтала, Отбор);
	//энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.КорректировкаОплатыСтало, Отбор);
КонецПроцедуры


&НаКлиенте
Процедура КорректировкаОплатыСуммаВозвратаПриИзменении(Элемент)
	ОбновитьКолонкуСуммуОстатка();
КонецПроцедуры

#КонецОбласти

#Область СобытияТЧКорректировкаОплатыСтало

&НаКлиенте
Процедура КорректировкаОплатыСталоПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	ДанныеДокументовОплаты = Элементы.КорректировкаОплаты.ТекущиеДанные;
	Если ДанныеДокументовОплаты = Неопределено Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выберите документ оплаты");
		Возврат;
	КонецЕсли;
	
	Если НоваяСтрока Тогда
		ТекущиеДанные 								= Элементы["КорректировкаОплатыСтало"].ТекущиеДанные;		
		ТекущиеДанные.IDСтроки						= Новый УникальныйИдентификатор;
		ТекущиеДанные.IDСтрокиКорректировкаБыло		= ДанныеДокументовОплаты.IDСтроки;
		ТекущиеДанные.ДокументОплаты				= ДанныеДокументовОплаты.ДокументОплаты;
	КонецЕсли;
	
	КорректировкаОплатыСталоПриАктивизацииСтроки(Элемент);
КонецПроцедуры

&НаКлиенте
Процедура КорректировкаОплатыСталоПередУдалением(Элемент, Отказ)
	ТекДанные 	= Элементы.КорректировкаОплатыСтало.ТекущиеДанные;
	УдалитьСтрокиЗадолженностьСталаПоIDСтроки(ТекДанные.IDСтроки);
КонецПроцедуры

&НаСервере
Процедура УдалитьСтрокиЗадолженностьСталаПоIDСтроки(IDСтроки)
	Отбор 		= Новый Структура("IDСтрокиКорректировкаСтала", IDСтроки);	
	энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.ЗадолженностьСтала, Отбор);
КонецПроцедуры


&НаКлиенте
Процедура КорректировкаОплатыСталоПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.КорректировкаОплатыСтало.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ЗадолженностьСтала,Неопределено,ТекДанные.IDСтроки,,"КорректировкаСтала");
КонецПроцедуры

&НаКлиенте
Процедура КорректировкаОплатыСталоПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	ДанныеДокументовОплаты = Элементы.КорректировкаОплаты.ТекущиеДанные;
	Если ДанныеДокументовОплаты = Неопределено Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выберите документ оплаты");
		Возврат;
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура КорректировкаОплатыСталоАбонентСталоПриИзменении(Элемент)
	ТекДанные 	= Элементы.КорректировкаОплатыСтало.ТекущиеДанные;
	Абонент		= ТекДанные.Абонент;
	Если АбонентДобавлен(Абонент) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Абонент уже выбран");
		ТекДанные.Абонент = ПредопределенноеЗначение("Справочник.энргАбоненты.ПустаяСсылка");
		Возврат;
	КонецЕсли;            	
	
	ДанныеАбонента  		= энргРаботаСЛицевымСчетомКлиент.СтруктруаЗначенийЗаполненияАбонента();		
	ДанныеАбонента.Удалить("Абонент");
	ДанныеАбонента.Вставить("IDСтрокиКорректировкаСтала", ТекДанные.IDСтроки);
	
	ЗаполнитьДанныеДляОплатыАбонента(Абонент, ДанныеАбонента);
	ДополнитьДаннымиРаспределенияДокументаОплаты(Абонент, ДанныеАбонента);
КонецПроцедуры

&НаСервере
Функция АбонентДобавлен(Абонент)
	Возврат Объект.КорректировкаОплатыСтало.НайтиСтроки(Новый Структура("Абонент", Абонент)).Количество() > 1;
КонецФункции

&НаСервере
Процедура ЗаполнитьДанныеДляОплатыАбонента(Абонент, ДанныеАбонента)		 	
	энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.ЗадолженностьСтала, Новый Структура("IDСтрокиКорректировкаСтала", ДанныеАбонента.IDСтрокиКорректировкаСтала));
	
	энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыАбонента(Абонент, ДанныеАбонента);	
	Результат 	= энргРаботаСЛицевымСчетомСервер.ДанныеДляОплатыАбонента(Объект.Дата, ДанныеАбонента.Организация, ДанныеАбонента.Район, ДанныеАбонента.МКД, Абонент); 
	Выборка  	= Результат.Выбрать();
	Пока Выборка.следующий() цикл
		СтрокаУслуги 							= Объект.ЗадолженностьСтала.Добавить();
		СтрокаУслуги.IDСтрокиКорректировкаСтала = ДанныеАбонента.IDСтрокиКорректировкаСтала;
		ЗаполнитьЗначенияСвойств(СтрокаУслуги,Выборка); 		 
	КонецЦикла;	
КонецПроцедуры

&НаСервере
Процедура ДополнитьДаннымиРаспределенияДокументаОплаты(Абонент, ДанныеАбонента)
	Если НЕ Абонент = Объект.Абонент Тогда 
		Возврат;	
	КонецЕсли;
	
	Для Каждого Выборка Из Объект.ЗадолженностьБыла Цикл
		СтрокаУслуги 							= Объект.ЗадолженностьСтала.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаУслуги, Выборка);
		СтрокаУслуги.IDСтрокиКорректировкаСтала = ДанныеАбонента.IDСтрокиКорректировкаСтала;			
		СтрокаУслуги.Задолженность 				= Выборка.СуммаОплаты;
		СтрокаУслуги.СуммаОплаты 				= 0;
	КонецЦикла;		
	
	КолонкиГруппировок 	= "IDСтрокиКорректировкаСтала,Услуга,ВидЗадолженности,ПериодНачисления,Поставщик";
	КолонкиСуммирования = "Задолженность,СуммаОплаты";
	
	ДанныеЗадолженности = Объект.ЗадолженностьСтала.Выгрузить();
	ДанныеЗадолженности.Свернуть(КолонкиГруппировок, КолонкиСуммирования);
	ДанныеЗадолженности.Сортировать("ПериодНачисления, ВидЗадолженности");
	Объект.ЗадолженностьСтала.Загрузить(ДанныеЗадолженности);
КонецПроцедуры

