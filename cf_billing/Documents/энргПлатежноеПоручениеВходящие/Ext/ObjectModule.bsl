#Область ЗаполнитьЕдиничнуюОплатуИзЗагрузкиДанных

Процедура ЗаполнитьЕдиничнуюОплатуИзЗагрузкиДанных(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	ДобавлениеЕдиничнойОплаты = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ДанныеЗаполнения,
		"ДобавлениеЕдиничнойОплаты",
		Неопределено);
		
	Если ДобавлениеЕдиничнойОплаты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДобавлениеЕдиничнойОплаты);
		
КонецПроцедуры 
	
#КонецОбласти

#Область РаботаСОплатой

Процедура ОбновитьСуммаОстатокОплаты(Отказ)
	
	Ошибки = Новый Массив;
	
	ШаблонОшибки = "В строке номер %1 по абоненту %2 некорректно распределена сумма оплаты";
	Для Каждого СтрокаНабора из Оплата Цикл
		
		СуммаПереноса = ОпределитьСуммуПереносаПоИдентификаторуСтроки(СтрокаНабора.IDСтроки);
		СтрокаНабора.СуммаОстаток = СтрокаНабора.СуммаОплаты - СтрокаНабора.Авизо - СуммаПереноса;
		
		СуммаРаспределенияОплатыНаЗадолженность = ОпределитьСуммуРаспределенияОплатыНаЗадолженностьПоИдентификаторуСтроки(СтрокаНабора.IDСтроки);		
		ОбщаяСумма = СтрокаНабора.Авизо + СуммаПереноса + СуммаРаспределенияОплатыНаЗадолженность; 		
		
		Если СтрокаНабора.СуммаОплаты < ОбщаяСумма Тогда
			Ошибки.Добавить(СтрШаблон(ШаблонОшибки, СтрокаНабора.НомерСтроки, СтрокаНабора.Абонент));			
		КонецЕсли;	
		
	КонецЦикла;
	
	Если Ошибки.Количество() > 0 Тогда
		Отказ = Истина;
		СообщениеИсключения = СтрСоединить(Ошибки, Символы.ПС);
		ОбщегоНазначения.СообщитьПользователю(СообщениеИсключения);
		ВызватьИсключение СообщениеИсключения;
	КонецЕсли;
			
КонецПроцедуры

Функция ОпределитьСуммуПереносаПоИдентификаторуСтроки(ИдентификаторСтроки)
	Возврат ПереносСуммыОплаты.Выгрузить(Новый Структура("IDСтроки", ИдентификаторСтроки), "СуммаПереноса").Итог("СуммаПереноса");
КонецФункции        

Функция ОпределитьСуммуРаспределенияОплатыНаЗадолженностьПоИдентификаторуСтроки(ИдентификаторСтроки)
	Возврат Задолженность.Выгрузить(Новый Структура("IDСтроки", ИдентификаторСтроки), "СуммаОплаты").Итог("СуммаОплаты");
КонецФункции

#КонецОбласти

#Область РаботаССостояниемДокументовПоказаний

Процедура ПроверитьДокументыРегистрацииПоказаний(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ДополнительныеСвойства.Свойство("ОтменитьПроверкуДокументовРегистрацииПоказаний") Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеСвойства.ЭтоНовый Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоПроведение = РежимЗаписи = РежимЗаписиДокумента.Проведение;
	ЭтоОтменаПроведения = РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения ИЛИ ПометкаУдаления;
	
	Если Не ЭтоПроведение и НЕ ЭтоОтменаПроведения Тогда
		Возврат;
	КонецЕсли; 	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргРегистрацияПоказанийАбонента.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.энргРегистрацияПоказанийАбонента КАК энргРегистрацияПоказанийАбонента
		|ГДЕ
		|	энргРегистрацияПоказанийАбонента.ДокументОснование = &ДокументОснование
		|	И энргРегистрацияПоказанийАбонента.Проведен";
	
	Запрос.УстановитьПараметр("ДокументОснование", Ссылка);
	
	Если ЭтоПроведение Тогда 
		
		Запрос.Текст = СтрЗаменить(
			Запрос.Текст, 
			"И энргРегистрацияПоказанийАбонента.Проведен",
			"И НЕ энргРегистрацияПоказанийАбонента.Проведен
			|	И НЕ энргРегистрацияПоказанийАбонента.ПометкаУдаления");
		
	КонецЕсли;
	
	
	РезультатЗапроса = Запрос.Выполнить();	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоПроведение Тогда
		
		Отказ = Истина;
		Комментарий = "Перед проведением текущего документа, необходимо провести связанные документы регистрации показаний";
		ОбщегоНазначения.СообщитьПользователю(Комментарий);
		ВызватьИсключение Комментарий; 
		
	КонецЕсли;
	
	Если ЭтоОтменаПроведения Тогда
		
		Отказ = Истина;
		Комментарий = "Перед отменой проведения текущего документа, необходимо отменить проведение связанных документов регистрации показаний";
		ОбщегоНазначения.СообщитьПользователю(Комментарий);
		ВызватьИсключение Комментарий; 
		
	КонецЕсли;
	
	
КонецПроцедуры

