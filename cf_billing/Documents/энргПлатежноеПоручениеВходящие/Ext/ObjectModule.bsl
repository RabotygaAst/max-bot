	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПлатежноеПоручениеВходящие.ШкалыПриборовУчета КАК ТаблицаШкал
	               |			ПО ТаблицаПриборовУчета.Ссылка = ТаблицаШкал.Ссылка
	               |				И ТаблицаПриборовУчета.IDСтроки = ТаблицаШкал.IDСтрокиТочкиУчета
	               |				И (ТаблицаПриборовУчета.Ссылка = &ДокументСсылка)
	               |				И (ТаблицаШкал.Ссылка = &ДокументСсылка)
	               |				И (НЕ ТаблицаПриборовУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПлатежноеПоручениеВходящие КАК ТаблицаДокумента
	               |			ПО ТаблицаПриборовУчета.Ссылка = ТаблицаДокумента.Ссылка
	               |				И (ТаблицаПриборовУчета.Ссылка = &ДокументСсылка)
	               |				И (ТаблицаДокумента.Ссылка = &ДокументСсылка)
	               |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	               |			ПО ТаблицаПриборовУчета.Абонент = энргАбоненты.Ссылка) КАК ВложенныйЗапрос
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргПлатежноеПоручениеВходящие.ПоказанияПриборовУчета КАК ТаблицаПоказанийПриборовУчета
	               |		ПО ВложенныйЗапрос.Ссылка = ТаблицаПоказанийПриборовУчета.Ссылка
	               |			И ВложенныйЗапрос.IDСтроки = ТаблицаПоказанийПриборовУчета.IDСтроки
	               |			И (ТаблицаПоказанийПриборовУчета.Ссылка = &ДокументСсылка)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	               |		ПО ВложенныйЗапрос.КлючПомещения = энргКлючиПомещений.Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ДанныеПоказаний.ДокРегистратор КАК ДокРегистратор,
	               |	ДанныеПоказаний.Район КАК Район,
	               |	ДанныеПоказаний.Организация КАК Организация,
	               |	ДанныеПоказаний.Шкала КАК Шкала,
	               |	ДанныеПоказаний.ТарифнаяЗона КАК ТарифнаяЗона,
	               |	ДанныеПоказаний.ОбъемУслугиПотребленный КАК ОбъемУслугиПотребленный,
	               |	ДанныеПоказаний.ПериодНачисления КАК ПериодНачисления,
	               |	ДанныеПоказаний.ТочкаУчета КАК ТочкаУчета,
	               |	ДанныеПоказаний.Строение КАК Строение,
	               |	ДанныеПоказаний.Помещение КАК Помещение,
	               |	ДанныеПоказаний.Период КАК Период,
	               |	ДанныеПоказаний.ЧастныйСектор КАК ЧастныйСектор
	               |ИЗ
	               |	ДанныеПоказаний КАК ДанныеПоказаний
	               |ГДЕ
	               |	ДанныеПоказаний.РегистрируетОбъем
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ДанныеПоказаний.Период КАК Период,
	               |	ДанныеПоказаний.Организация КАК Организация,
	               |	ДанныеПоказаний.Район КАК Район,
	               |	ДанныеПоказаний.КлючПомещения КАК КлючПомещения,
	               |	ДанныеПоказаний.ПриборУчета КАК ПриборУчета,
	               |	ДанныеПоказаний.Шкала КАК Шкала,
	               |	ДанныеПоказаний.ТарифнаяЗона КАК ТарифнаяЗона,
	               |	ДанныеПоказаний.ТекущиеПоказания КАК Показание,
	               |	ДанныеПоказаний.СостояниеПоказаний КАК СостояниеПоказаний,
	               |	ДанныеПоказаний.ИсточникПоступления = ЗНАЧЕНИЕ(Справочник.энргИсточникиПоказаний.КонтрольныйСъем) КАК КС,
	               |	ДанныеПоказаний.ИсточникПоказаний КАК ИсточникПоказаний,
	               |	ДанныеПоказаний.ПричинаОтклонения КАК ПричинаОтклонения,
	               |	ДанныеПоказаний.Переворот КАК Переворот,
	               |	ДанныеПоказаний.ПериодНачисления КАК ПериодНачисления,
	               |	ДанныеПоказаний.Период КАК ПериодРегистрации,
	               |	ДанныеПоказаний.НомерСтроки КАК НомерСтрокиТЧ,
	               |	ДанныеПоказаний.ТочкаУчета КАК ТочкаУчета
	               |ИЗ
	               |	ДанныеПоказаний КАК ДанныеПоказаний
	               |ГДЕ
	               |	НЕ ДанныеПоказаний.РегистрируетОбъем
	               |	И ВЫБОР
	               |			КОГДА ДанныеПоказаний.СтатусИзмененПользователем
	               |					ИЛИ ДанныеПоказаний.ПереворотИзмененПользователем
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ НЕ ДанныеПоказаний.ПричинаОтклонения В (&ПричиныОтклоненияИсключая)
	               |		КОНЕЦ
	               |	И ДанныеПоказаний.ПоказанияПредоставлены
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	КлючПомещения,
	               |	ПриборУчета,
	               |	Шкала,
	               |	ТарифнаяЗона";
	
	ПричиныОтклоненияИсключая = Новый Массив;//энргРаботаСПоказаниямиПриборовУчетаСервер.ПричиныОтклоненияИсключая();
	
	Запрос.УстановитьПараметр("ДокументСсылка"				, Ссылка);
	Запрос.УстановитьПараметр("Период"						, Дата);
	Запрос.УстановитьПараметр("ПричиныОтклоненияИсключая"	, ПричиныОтклоненияИсключая);
	Результат = Запрос.ВыполнитьПакет();
	
	Возврат Результат;	
КонецФункции

Процедура ЗарегистрироватьПоказанияПриборовУчета(РезультатЗапроса)
	Набор 				= Движения.энргПоказанияПриборовУчета;
	Выборка 			= РезультатЗапроса.Выбрать();			
	ТекКлючПомещения	= Неопределено;
	ТекПриборУчета 		= Неопределено;
	ТекТарифнаяЗона 	= Неопределено;
	ТекРазделитель 		= 0;
	
	Пока Выборка.следующий() цикл
		Если ТекКлючПомещения = Выборка.КлючПомещения И ТекПриборУчета = Выборка.ПриборУчета И ТекТарифнаяЗона = Выборка.ТарифнаяЗона тогда
			ТекРазделитель 				= ТекРазделитель + 1;
		иначе
			ТекРазделитель 				= 0;
		КонецЕсли;	
		Запись  						= Набор.добавить();		
		ЗаполнитьЗначенияСвойств(Запись,Выборка);
		Запись.Разделитель 				= ТекРазделитель;
		ТекКлючПомещения  				= Выборка.КлючПомещения;
		ТекПриборУчета 					= Выборка.ПриборУчета;
		ТекТарифнаяЗона 				= Выборка.ТарифнаяЗона;
	КонецЦикла;
КонецПроцедуры

Процедура ЗафиксироватьОбъемСреднего(Результат)
	Выборка 				= Результат.Выбрать();
	НаборРасчетСреднего 	= РегистрыСведений.энргРасчетСреднегоОбъема.СоздатьНаборЗаписей();
	НаборРасчетСреднего.ДополнительныеСвойства.Вставить("НеПроверятьДатуЗапретаРедактирования",истина);
	Пока Выборка.Следующий() Цикл 
		
		СтрокаНабор  			= НаборРасчетСреднего.Добавить();
		
		ЗаполнитьЗначенияСвойств(СтрокаНабор,Выборка);	
		СтрокаНабор.ОбъемУслуги = Выборка.ОбъемУслугиПотребленный;
		
	КонецЦикла;
	НаборРасчетСреднего.Записать(Ложь);
КонецПроцедуры

