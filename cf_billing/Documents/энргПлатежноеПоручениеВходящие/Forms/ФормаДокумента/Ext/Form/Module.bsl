&НаКлиенте
Процедура ОплатаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Если ДокументФискализирован Тогда		
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ОплатаУжеДобавлена = Ложь;
	Для Каждого СтрокаОплаты Из Объект.Оплата Цикл
		ОплатаУжеДобавлена = Истина;
		Прервать;
	КонецЦикла;
	
	Если РазрешеноДобавлятьОплату И ОплатаУжеДобавлена Тогда
		
		Отказ = Истина;
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Добавлять больше одной строки запрещено'"));
			
		Возврат;
		
	КонецЕсли;
	
	
	Если НЕ РазрешеноДобавлятьОплату И ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		
		Отказ = Истина;
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Документ загружен из реестра. Добавлять новые строки запрещено'"));
			
		Возврат;
			
	КонецЕсли;  	
	
