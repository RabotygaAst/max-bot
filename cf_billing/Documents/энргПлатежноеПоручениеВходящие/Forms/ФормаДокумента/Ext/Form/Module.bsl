&НаКлиенте
Процедура ПослеВопросаОПометкеСвязанныхДокументов(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если НЕ РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗапуститьФоновоеЗаданиеУстановкаПометкиУдаленияПоказанийКлиент();
		
КонецПроцедуры

&НаКлиенте
Процедура ПослеСообщенияОбОшибкеПередЗагрузкой(РезультатВопроса, ДополнительныеПараметры) Экспорт 
	
	Если РезультатВопроса = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	ДвоичныеДанные  	= Новый ДвоичныеДанные(Объект.ФайлДляЧтения); 	
	АдресХранилища  	= ПоместитьВоВременноеХранилище(ДвоичныеДанные,ЭтаФорма.УникальныйИдентификатор);
	
	ЗагрузитьПослеПроверкиПослеЗагрузки(Неопределено, АдресХранилища, Неопределено);
	
КонецПроцедуры

&НаСервере
Функция ВернутьПУ(Период, Абонент,точкаучета)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргПриборыТочекУчетаСрезПоследних.ПриборУчета КАК ПриборУчета
	|ИЗ
	|	РегистрСведений.энргПриборыТочекУчета.СрезПоследних(
	|			&Период,
	|			ТочкаУчета = &ТочкаУчета
	|				И Район = &Район
	|				И &КлючПомещения = КлючПомещения) КАК энргПриборыТочекУчетаСрезПоследних";
	
	Запрос.УстановитьПараметр("КлючПомещения"	, Абонент.КлючПомещения);
	Запрос.УстановитьПараметр("Период"			, Период);
	Запрос.УстановитьПараметр("Район"			,  Абонент.Район);
	Запрос.УстановитьПараметр("ТочкаУчета"		, ТочкаУчета);
	
	
	РезультатЗапроса 	= Запрос.Выполнить();	
	Выборка 			= РезультатЗапроса.Выбрать();
	МассивПриборов 		= новый Массив;
	
	Пока Выборка.Следующий() Цикл
		МассивПриборов.Добавить(Выборка.ПриборУчета);
	КонецЦикла;
	
	Возврат МассивПриборов; 	
	
КонецФункции

&НаСервере
Процедура ОбновитьКолВоСтрокВТЧ()
	СтрокВОплате 									= Объект.Оплата.Количество();
	СтрокВПоказаниях 								= Объект.ТочкиУчета.Количество();
	СтрокВНеЗагрежнных								= Объект.НеЗагруженныеДанные.Количество();
	
	Элементы.СтраницаОплата.Заголовок 				= "Оплата" + " (" + СтрокВОплате + ")";
	//Элементы.СтраницаПоказания.Заголовок 			= "Показания приборов учета" + " (" + СтрокВПоказаниях + ")";
	Элементы.СтраницыШкалыТарифныеЗоны.Заголовок	= "Показания приборов учета" + " (" + СтрокВПоказаниях + ")";
	Элементы.СтраницаНеЗагруженныеДанные.Заголовок 	= "Незагруженные данные" + " (" + СтрокВНеЗагрежнных + ")";
КонецПроцедуры

&НаСервере
Функция ЗагрузитьФайлСервер(АдресХранилища,ИсточникПоступления)
	
	ОбъектОбработки 		= ОбъектОбработкиЗагрузки(ИсточникПоступления);
	ДанныеДокумента  		= ОбъектОбработки.ДанныеДокумента();
	ЗаполнитьЗначенияСвойств(ДанныеДокумента,Объект);	
	ОшибкиПеред 			= "";
	Попытка
		ОшибкиПеред 		= ОбъектОбработки.ПередЗагрузкой(АдресХранилища,ДанныеДокумента);
	Исключение
		// Обработка не требуется
	КонецПопытки;
	
	Если ДанныеДокумента.Свойство("РеквизитыФормы") и НЕ ПустаяСтрока(ДанныеДокумента.РеквизитыФормы) Тогда
		ЗаполнитьЗначенияСвойств(ДанныеДокумента,ЭтаФорма,ДанныеДокумента.РеквизитыФормы);
	КонецЕсли; 	
	
	Если Не ПустаяСтрока(ОшибкиПеред) Тогда
		Возврат ОшибкиПеред; 
	КонецЕсли;	
	
	ЗагрузитьПослеПроверкиПослеЗагрузки(ОбъектОбработки, АдресХранилища, ДанныеДокумента);
	УстановитьВидимостьФункционалаРегистрацииПоказаний();
	
	Возврат "";
	
КонецФункции

&НаСервере
Процедура ЗагрузитьПослеПроверкиПослеЗагрузки(Знач ОбъектОбработки, АдресХранилища, ДанныеДокумента) 
	
	Если ОбъектОбработки = Неопределено Тогда
		ОбъектОбработки 	= ОбъектОбработкиЗагрузки(Объект.ИсточникПоступления);
	КонецЕсли; 	
	
	Если ДанныеДокумента = Неопределено Тогда
		ДанныеДокумента 	= ОбъектОбработки.ДанныеДокумента();
		ЗаполнитьЗначенияСвойств(ДанныеДокумента,Объект);		
	КонецЕсли; 
	
	Ошибка  				= ОбъектОбработки.Загрузить(АдресХранилища,ДанныеДокумента);
	
	Если ЗначениеЗаполнено(Ошибка) тогда
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	ДействияПослеЗагрузкиФайлаСервер();
	
КонецПроцедуры

&НаСервере
Процедура ДействияПослеЗагрузкиФайлаСервер()
	ОбновитьКолВоСтрокВТЧ();
		
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ТочкиУчета");
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"Оплата");
	
	энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоРайонПриЧтении(Объект.ТочкиУчета,Объект);
	энргРаботаСприборамиУчетаСервер.ЗаполнитьСвойствоРегистрируетОбъемПриЧтении(Объект.ТочкиУчета,Объект);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект, Объект, ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета);
	
	ПоказанияПредоставляютсяВСрок();
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();
	ВспомогательныеПараметры = энргРаботаСПоказаниямиПриборовУчетаСервер.НовыеВспомогательныеПараметрыПриЗаполненииТабличнойЧастиПоказания();
	ВспомогательныеПараметры.Период = Объект.Дата;
	
	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Неопределено); 
	тзПриборыДляОтклоненияПоказаний 			= ПолучитьТЗПриборыДляОтклоненияПоказаний(); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказанийСУчетомОтклонения(Объект.Организация,Неопределено,ТаблицаПоказанийДляЗаполнения,Объект.Дата, тзПриборыДляОтклоненияПоказаний);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета,ВспомогательныеПараметры);
	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПериодНачисленияСервер()
	
	Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация, Объект.Район);	
	ПоказанияПредоставляютсяВСрок();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПоказанияНаСервере()	
	
	Запрос = Новый Запрос;
	Запрос. Текст ="ВЫБРАТЬ
	|	ТекущиеДанные.номерСтроки,
	|	ВЫРАЗИТЬ(ТекущиеДанные.Абонент КАК Справочник.энргАбоненты) КАК Абонент,
	|	ТекущиеДанные.ТочкаУчета КАК ТочкаУчета,
	|	ТекущиеДанные.ЗначениеТарифа КАК ЗначениеТарифа,
	|	ТекущиеДанные.Услуга КАК Услуга,
	|	ТекущиеДанные.ПриборУчета КАК ПриборУчета,
	|	ТекущиеДанные.КоэффициентПУ КАК Коэффициент,
	|	ТекущиеДанные.МаксимальноВозможныеПоказания КАК МаксимальноВозможные,
	|	ТекущиеДанные.МаксимальноВозможныйОбъемПотребления КАК МаксимальныйОбъемПотребления,
	|	ТекущиеДанные.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ТекущиеДанные.Переворот КАК ТекущийПереворот,
	|	ТекущиеДанные.СостояниеПоказаний КАК ТекущиеСостояниеПоказаний,
	|	ТекущиеДанные.ПереворотИзмененПользователем,
	|	ТекущиеДанные.СтатусИзмененПользователем
	|ПОМЕСТИТЬ ТекущиеДанные
	|ИЗ
	|	&ТекущиеДанные КАК ТекущиеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТекущиеДанные.номерСтроки,
	|	ТекущиеДанные.Абонент,
	|	ТекущиеДанные.ТочкаУчета,
	|	ТекущиеДанные.ЗначениеТарифа,
	|	ТекущиеДанные.Услуга,
	|	ТекущиеДанные.ПриборУчета,
	|	ТекущиеДанные.Коэффициент,
	|	ТекущиеДанные.МаксимальноВозможные,
	|	ТекущиеДанные.МаксимальныйОбъемПотребления,
	|	ТекущиеДанные.ТекущиеПоказания,
	|	ТекущиеДанные.ТекущийПереворот,
	|	ТекущиеДанные.ТекущиеСостояниеПоказаний,
	|	ТекущиеДанные.ПереворотИзмененПользователем,
	|	ТекущиеДанные.СтатусИзмененПользователем,
	|	ТекущиеДанные.Абонент.Район КАК Район
	|ПОМЕСТИТЬ ВТ_Срайоном
	|ИЗ
	|	ТекущиеДанные КАК ТекущиеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Срайоном.номерСтроки,
	|	ВТ_Срайоном.Абонент,
	|	ВТ_Срайоном.ТочкаУчета,
	|	ВТ_Срайоном.ЗначениеТарифа,
	|	ВТ_Срайоном.Услуга,
	|	ВТ_Срайоном.ПриборУчета,
	|	ВТ_Срайоном.Коэффициент,
	|	ВТ_Срайоном.МаксимальноВозможные,
	|	ВТ_Срайоном.МаксимальныйОбъемПотребления,
	|	ВТ_Срайоном.ТекущиеПоказания,
	|	ВТ_Срайоном.ТекущийПереворот,
	|	ВТ_Срайоном.ТекущиеСостояниеПоказаний,
	|	ВТ_Срайоном.ПереворотИзмененПользователем,
	|	ВТ_Срайоном.СтатусИзмененПользователем,
	|	ВТ_Срайоном.Район КАК Район
	|ИЗ
	|	ВТ_Срайоном КАК ВТ_Срайоном
	|ИТОГИ ПО
	|	Район";
	
	
	ТекущиеДанные  			= Объект.Показания.Выгрузить();
	ПоказанияПоРайону		= ТекущиеДанные.Скопировать();
	ПоказанияПоРайону.Очистить();
	
	Запрос.УстановитьПараметр("ТекущиеДанные",ТекущиеДанные);
	РезультатЗапроса 		= Запрос.Выполнить();
	
	ВыборкаРайон 			= РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаРайон.Следующий() Цикл
		// Вставить обработку выборки ВыборкаРайон 		
		Выборка 			= ВыборкаРайон.Выбрать(); 		
		Пока Выборка.Следующий() Цикл
			ЗаполнитьЗначенияСвойств(ПоказанияПоРайону.Добавить(),Выборка);
		КонецЦикла;      		
		ПоказанияПоРайону.Очистить();		
	КонецЦикла;  
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКонтрагентаПоКоду(Код)
	
	Возврат Справочники.энргКонтрагенты.НайтиПоКоду(Код);
	
