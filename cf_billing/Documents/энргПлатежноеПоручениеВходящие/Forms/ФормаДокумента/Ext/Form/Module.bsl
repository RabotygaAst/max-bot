&НаСервере 
Функция УслугиАбонента(Период,ЛицевойСчет)
	Запрос = Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	энргАбоненты.ЛицевойСчет КАК ЛицевойСчет,
	|	энргАбоненты.КлючПомещения КАК КлючПомещения,
	|	энргАбоненты.Район КАК Район,
	|	энргАбоненты.Организация КАК Организация
	|ПОМЕСТИТЬ ВТ_Абонент
	|ИЗ
	|	Справочник.энргАбоненты КАК энргАбоненты
	|ГДЕ
	|	энргАбоненты.ЛицевойСчет = &ЛицевойСчет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга
	|ИЗ
	|	ВТ_Абонент КАК ВТ_Абонент
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргУслугиТочекУчета.СрезПоследних(&Период, ) КАК энргУслугиТочекУчетаСрезПоследних
	|		ПО ВТ_Абонент.КлючПомещения = энргУслугиТочекУчетаСрезПоследних.КлючПомещения
	|			И ВТ_Абонент.Район = энргУслугиТочекУчетаСрезПоследних.Район
	|			И ВТ_Абонент.Организация = энргУслугиТочекУчетаСрезПоследних.Организация";
	Запрос.УстановитьПараметр("ЛицевойСчет", ЛицевойСчет);
	Запрос.УстановитьПараметр("Период", Период);
	
	РезультатЗапроса 	= Запрос.Выполнить();	
	Выборка 			= РезультатЗапроса.Выбрать();
	МассивПриборов 		= новый Массив;
	
	Пока Выборка.Следующий() Цикл
		МассивПриборов.Добавить(Выборка.Услуга);
	КонецЦикла;
	
	Возврат МассивПриборов; 
	
КонецФункции

&НаКлиенте
Процедура НеЗагруженныеДанныеУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные=Элементы.НеЗагруженныеДанные.ТекущиеДанные;
	
	СтандартнаяОбработка 	= Ложь;
	ПараметрыФормы 			= Новый Структура("Отбор", Новый Структура("Ссылка", УслугиАбонента(Объект.Дата,ТекущиеДанные.лицевойсчет)));
	ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", ПараметрыФормы, Элемент);	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПриборыУчетаСервер(ИдентификаторСтроки = Неопределено, Район, КлючПомещения)
	
	ТочкаУчета = Неопределено;
	СтрокиПоказаний = Неопределено;
	
	Если ИдентификаторСтроки = Неопределено Тогда
		ТаблицаТЧ 									= Объект.ПоказанияПриборовУчета.Выгрузить();
		Объект.ШкалыПриборовУчета.Очистить();
		Объект.ПоказанияПриборовУчета.Очистить();
		Объект.ТочкиУчета.Очистить();
	Иначе
		СтрокаТочкиУчета  							= Объект.ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
		ТочкаУчета 									= СтрокаТочкиУчета.ТочкаУчета;
		ПоискШкал	 								= Новый Структура("IDСтрокиТочкиУчета",СтрокаТочкиУчета.IDСтроки);
		СтрокиШкал  								= Объект.ШкалыПриборовУчета.НайтиСтроки(ПоискШкал);
		Для Каждого СтрокаШкалы Из СтрокиШкал Цикл
			ПоискПоказаний 							= Новый Структура("IDСтроки", СтрокаШкалы.IDСтроки);
			СтрокиПоказаний 						= Объект.ПоказанияПриборовУчета.НайтиСтроки(ПоискПоказаний);
			Для Каждого СтрокаПоказаний Из СтрокиПоказаний Цикл
				Объект.ПоказанияПриборовУчета.Удалить(СтрокаПоказаний);
			КонецЦикла;
			Объект.ШкалыПриборовУчета.Удалить(СтрокаШкалы);
		КонецЦикла;		
	КонецЕсли;
	
	Результат 										= Обработки.энргСостояниеТочекУчетаМенеджер.ДействующиеТочкиИИхПриборы(Объект.Дата,Объект.Организация,Район,КлючПомещения,ТочкаУчета,Новый Структура("ТолькоОткрытыеЛС", Истина)); 
	Выборка  										= Результат.выбрать();
	ТекТочкаУчета 									= Неопределено;
	ТекШкала 										= Неопределено;
	IDСтрокиТочки 									= Неопределено;
	IDСтрокиШкалы 									= Неопределено;
	Пока Выборка.следующий() цикл
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			Если ИдентификаторСтроки = Неопределено Тогда
				СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
				IDСтрокиТочки 						= Новый УникальныйИдентификатор;
				СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
				СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			иначе 				
				СтрокаТочкиУчета  					= Объект.ТочкиУчета.НайтиПоИдентификатору(ИдентификаторСтроки);
				IDСтрокиТочки 						= СтрокаТочкиУчета.IDСтроки;
			КонецЕсли;
			СтрокаТочкиУчета.Услуга 				= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 			= Выборка.ПриборУчета;
			СтрокаТочкиУчета.РегистрируетОбъем 		= Выборка.РегистрируетОбъем;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) Тогда
			Если НЕ ТекШкала = Выборка.Шкала Тогда
				СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
				IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
				СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
				СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
				СтрокаШкалы.Шкала 					= Выборка.Шкала;
				СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
			КонецЕсли;
			
			СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
			СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
			СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
			
			Если НЕ СтрокиПоказаний = Неопределено Тогда
				Для Каждого СтрокаПоказанийСтарая Из СтрокиПоказаний Цикл
					
					Если НЕ СтрокаПоказанийСтарая.ТарифнаяЗона = Выборка.ТарифнаяЗона Тогда
						Продолжить;	
					КонецЕсли;
					
					СтрокаПоказаний.ТекущиеПоказания = СтрокаПоказанийСтарая.ТекущиеПоказания;
					
				КонецЦикла;	
			КонецЕсли;
			
		КонецЕсли;
		
		ТекТочкаУчета 								= Выборка.ТочкаУчета;
		ТекШкала 									= Выборка.Шкала;
	КонецЦикла; 
	
	ТаблицаПоказанийДляЗаполнения 				= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(Объект.Организация,Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Район,КлючПомещения,ИдентификаторСтроки); 
	РезультатДанныеЗаполненияПоказаний 			= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(Объект.Организация,Объект.Район,ТаблицаПоказанийДляЗаполнения,Объект.Дата);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний,ТаблицаПоказанийДляЗаполнения,Объект.ПоказанияПриборовУчета);
	
	энргШкалыТарифныеЗоныСервер.ЗаполнитьПредставлениеФормы(Объект,Объект,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета);
	
КонецПроцедуры

&НаСервере
Функция ОбъектОбработкиЗагрузки(ИсточникПоступления) 
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Источник",ИсточникПоступления);
	Запрос.Текст 	="ВЫБРАТЬ
	|	энргНастройкиЗагрузкиОплаты.ОбработкаЗагрузки
	|ИЗ
	|	РегистрСведений.энргНастройкиЗагрузкиОплаты КАК энргНастройкиЗагрузкиОплаты
	|ГДЕ
	|	энргНастройкиЗагрузкиОплаты.Источник = &Источник";
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось определить обработку для загрузки файла");
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка  = Результат.Выбрать();
	Выборка.Следующий();
	
	ВнешняяОбработкаОбъект  = Выборка.ОбработкаЗагрузки.ПолучитьОбъект();
	ИмяФайла  				= ПолучитьИмяВременногоФайла("epf");
	ДвоичныеДанные 			= ВнешняяОбработкаОбъект.ХранилищеОбработки.получить();
	ДвоичныеДанные.записать(ИмяФайла);
	
	Возврат ВнешниеОбработки.Создать(ИмяФайла,Ложь);
КонецФункции

&НаКлиенте
Процедура ФормаЗадолженностьОкончаниеВыбора(РезультатЗакрытия,ДополнительныеПараметры) Экспорт  
	
	Если РезультатЗакрытия <> Неопределено Тогда 
		
		Модифицированность	= Истина;
		
		Для каждого СтрокаДолг Из РезультатЗакрытия Цикл
			
			СтрокаТЗ = Объект.Задолженность.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЗ, СтрокаДолг);
			СтрокаТЗ.IDСтроки = ДополнительныеПараметры.IDСтроки;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте

Процедура ОбновитьИтогиТЧЗадолженность()
	
	ИтогСуммаОплаты = 0;
	ИтогЗадолженность = 0;
	
	Для каждого Стр Из Объект.Задолженность Цикл
		
		Если Элементы.Задолженность.ПроверитьСтроку(Стр.ПолучитьИдентификатор()) Тогда
			
			ИтогСуммаОплаты = ИтогСуммаОплаты + Стр.СуммаОплаты;
			ИтогЗадолженность = ИтогЗадолженность + Стр.Задолженность;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Элементы.ЗадолженностьСуммаОплаты.ТекстПодвала = ИтогСуммаОплаты;
	Элементы.ЗадолженностьЗадолженность.ТекстПодвала = ИтогЗадолженность;
	
	
КонецПроцедуры

