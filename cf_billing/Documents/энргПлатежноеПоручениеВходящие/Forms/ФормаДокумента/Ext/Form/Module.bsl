#Область ЗаполнитьЕдиничнуюОплатуИзЗагрузкиДанных

Процедура ЗаполнитьВозможностьДобавленияЕдиничнойОплат()
	
	ДобавлениеЕдиничнойОплаты = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		Параметры.ЗначенияЗаполнения,
		"ДобавлениеЕдиничнойОплаты",
		Неопределено);
		
	РазрешеноДобавлятьОплату = НЕ ДобавлениеЕдиничнойОплаты = Неопределено;
	
КонецПроцедуры
	
#КонецОбласти

#Область РаботаСВерсиейФункционалаДокумента

&НаСервере
Процедура УстановитьВерсиюДокумента()
	
	ЭтоНоваяВерсияФункционала = ЗначениеЗаполнено(Объект.ДокументОснование);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ДокументОснование",
		"Видимость", 
		ЭтоНоваяВерсияФункционала);
		
	Если НЕ ЭтоНоваяВерсияФункционала Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ЗагрузитьИзDBF",
		"Видимость", 
		Ложь);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"СтраницыШкалыТарифныеЗоны",
		"Видимость", 
		Ложь);	
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"СтраницаДокументыПоказанийПриборовУчета",
		"Видимость", 
		Ложь);	
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"СтраницаНеЗагруженныеДанные",
		"Видимость", 
		Ложь);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ГруппаОтчеты",
		"Видимость", 
		Ложь);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"Дата",
		"Доступность", 
		Ложь);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"Организация",
		"ТолькоПросмотр", 
		Истина);	
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"Район",
		"ТолькоПросмотр", 
		Истина);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"Поставщик",
		"ТолькоПросмотр", 
		Истина);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ФайлДляЧтения",
		"ТолькоПросмотр", 
		Истина);
		
	ТолькоПросмотрРеквизитовТЧОплаты = Истина;
	Если РазрешеноДобавлятьОплату Тогда
		ТолькоПросмотрРеквизитовТЧОплаты = Ложь;	
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ОплатаАбонент",
		"ТолькоПросмотр", 
		ТолькоПросмотрРеквизитовТЧОплаты);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ОплатаСтроение",
		"ТолькоПросмотр", 
		Истина);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ОплатаПомещение",
		"ТолькоПросмотр", 
		Истина);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ОплатаУслуга",
		"ТолькоПросмотр", 
		ТолькоПросмотрРеквизитовТЧОплаты);	
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ОплатаПоставщик",
		"ТолькоПросмотр", 
		ТолькоПросмотрРеквизитовТЧОплаты);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ОплатаСуммаОплаты",
		"ТолькоПросмотр", 
		ТолькоПросмотрРеквизитовТЧОплаты);	
		
	УстановитьВерсиюДокументаПереопределяемый(ЭтоНоваяВерсияФункционала);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВерсиюДокументаПереопределяемый(ЭтоНоваяВерсияФункционала)
	// переопределено в расширении	
КонецПроцедуры
	
