&НаКлиенте
Процедура ПодборЗадолженности(Команда)
	
	ТекущиеДанные 							= Элементы.Оплата.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;  
	
	СтруктураОтбора = Новый Структура("Период,ПериодНачисления,Организация,Район,Строение,Абонент,Услуга",КонецДня(Объект.Дата));
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,Объект);
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,ТекущиеДанные);
	
	МассивЗагруженныхПериодов = Новый Массив;
	
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
		ТекущиеДанные.IDСтроки 				= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	НайденныеСтроки = Объект.Задолженность.НайтиСтроки(Новый Структура("IDСтроки", ТекущиеДанные.IDСтроки));
	
	Для Каждого Строка Из НайденныеСтроки Цикл
		ЗагруженныеДанные = Новый Структура("ПериодНачисления, ВидЗадолженности", Строка.ПериодНачисления, Строка.ВидЗадолженности);
		МассивЗагруженныхПериодов.Добавить(Новый Структура("ПериодНачисления, ВидЗадолженности", Строка.ПериодНачисления, Строка.ВидЗадолженности));
		
	КонецЦикла;
	
	ПараметрыВыбораФормы	= Новый Структура("СтруктураОтбора, ЗагруженныеПериоды", СтруктураОтбора, МассивЗагруженныхПериодов);
	ОписаниеОповещения 		= Новый ОписаниеОповещения("ФормаЗадолженностьОкончаниеВыбора",ЭтаФорма,Новый Структура("IDСтроки", ТекущиеДанные.IDСтроки));
	
	ОткрытьФорму("Документ.энргПлатежноеПоручениеВходящие.Форма.ФормаВыбораЗадолженности",ПараметрыВыбораФормы, ЭтаФорма,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры


