// Функция - Обратная совместимость
// Разграничивает функционал регистрации показаний старых документов и новых 	
// СтараяВерсия - Регистрация и исправление показаний в текущем документе 
// НоваяВерсия - Регистрация и исправление показаний в документах Рег. показаний
//
// Возвращаемое значение:
// Результат  - Булево
//
&НаСервере
Функция ЭтоСтараяВерсияРегистрацииПоказаний()
	
	Результат = Объект.ТочкиУчета.Количество() > 0;
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция НеобходимоСкорректироватьСвязанныеДокументы(ДокументОснование, ЗависимыеРеквизиты)
	//Возврат Документы.энргРегистрацияПоказанийАбонента.НеобходимоСкорректироватьСвязанныеДокументы(ДокументОснование, ЗависимыеРеквизиты);
	Возврат энргМассоваяРегистрацияПоказаний.НеобходимоСкорректироватьСвязанныеДокументы(ДокументОснование, ЗависимыеРеквизиты);
КонецФункции 

&НаКлиенте
Процедура ПослеВопросаОНеобходимостиКорректировкиСвязанныхДокументов(Результат, ДополнительныеПараметры) Экспорт 
	
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		УстановитьДатуОтСвязанныхДокументовПоказаний();
		Возврат;
	КонецЕсли;
	
	ЗапуститьФоновоеЗаданиеСменаЗависимыхРеквизитовКлиент();
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьЗависимыеРеквизиты()
	
	Результат = Новый Структура("Дата", Объект.Дата);
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ПриИзмененииФайлаЗагрузки

