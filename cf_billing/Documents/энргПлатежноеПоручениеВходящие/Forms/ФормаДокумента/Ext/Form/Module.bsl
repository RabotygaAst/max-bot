&НаКлиенте
Процедура НеЗагруженныеДанные(Команда)
	
	спЗначений = СписокОпераций();
	ВыбратьОперациюИзСписка(спЗначений,Элементы.ЗагрузитьУ);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьОперациюИзСписка(СписокОпераций, элемент)
	
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВыбратьОперациюИзСпискаЗавершение",ЭтотОбъект);
	ПоказатьВыборИзМеню(ОписаниеОповещения,СписокОпераций, элемент);
	
КонецПроцедуры

&НаКлиенте
Функция СписокОпераций()
	
	Список  = Новый СписокЗначений;
	Список.Добавить(0,"Загруженные данные");
	Список.Добавить(1,"Не загруженные данные");
	
	Возврат Список;	
КонецФункции

&НаКлиенте
Процедура ВыбратьОперациюИзСпискаЗавершение(ВыбранныйЭлемент,ДополнительныеПараметры) Экспорт 
	
	Если ВыбранныйЭлемент = Неопределено тогда
		Возврат;
	КонецЕсли;
	Если ВыбранныйЭлемент = Неопределено
		Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ничего не выбрано");
		
	ИначеЕсли ВыбранныйЭлемент.Значение = 0  тогда
		ТабДок = СформироватьПротоколЗагруженныхДанныхНАсервере();
		ТабДок.показать();
	ИначеЕсли ВыбранныйЭлемент.Значение = 1 Тогда
		ТАбДок = СформироватьПротоколНеЗагруженныхДанныхНаСервере();
		ТабДок.показать();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьРеестр(Команда)
	ТАбДок = СформироватьРеестрНаСервере();
	ИмяФайла	= "ПП №" + СокрЛП(Объект.Номер) + " от " + Формат(Объект.Дата, "ДФ=dd.MM.yyyy");
	СохранитьВЭксель(ТАбДок, ИмяФайла + ".xlsx");
КонецПроцедуры

&НаКлиенте
Процедура СохранитьВЭксель(ТабДок, ИмяФайла, ВыбранныйКаталогСохранения = Неопределено)
	
	Попытка
		
		КаталогСохранения = КаталогВременныхФайлов();
		Если НЕ ВыбранныйКаталогСохранения = Неопределено Тогда
			КаталогСохранения = ВыбранныйКаталогСохранения;
		КонецЕсли;		
		ТабДок.Записать(КаталогСохранения + "\" + ИмяФайла, ТипФайлаТабличногоДокумента.XLSX);
		ЗапуститьПриложение(КаталогСохранения + "\" + ИмяФайла);
		
	Исключение
		
		инфОшибки = ИнформацияОбОшибке();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось сохранить файл(ы) по причине: " + Символы.ПС + КраткоеПредставлениеОшибки(инфОшибки));
		
	КонецПопытки;
	
КонецПроцедуры

