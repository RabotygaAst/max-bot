&НаКлиенте
Процедура ЗадолженностьСуммаОплатыПриИзменении(Элемент)
	
	ТекСтр = Элементы.Задолженность.ТекущиеДанные;
	
	СтрУслуги = Объект.Оплата.НайтиСтроки(Новый Структура("IDСтроки", ТекСтр.IDСтроки));
	
	Если СтрУслуги.Количество() > 0 Тогда
		СуммаОплаты = СтрУслуги[0].СуммаОплаты;
		
		СтрокиЗадолженности = Объект.Задолженность.НайтиСтроки(Новый Структура("IDСтроки", ТекСтр.IDСтроки));
		
		СуммаОплатыЗадолженности = 0;
		
		Для ИндексСтр = 0 По СтрокиЗадолженности.ВГраница() Цикл	
			
			СуммаОплатыЗадолженности = СуммаОплатыЗадолженности + СтрокиЗадолженности[ИндексСтр].СуммаОплаты; 
			Если СуммаОплатыЗадолженности > СуммаОплаты Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По абоненту " + СтрУслуги[0].Абонент + " сумма распределения превысила сумму оплаты.");
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	ОбновитьИтогиТЧЗадолженность();
	
	
КонецПроцедуры

