#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	энргЛокализацияСервер.ПриСозданииНаСервере_энргПлатежноеПоручениеВходящие(ЭтотОбъект);
	
	ЗаполнитьВозможностьДобавленияЕдиничнойОплат();
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			ЗаполнитьПериодНачисленияСервер();
		КонецЕсли;
	КонецЕсли; 
	
	ОбновитьКолВоСтрокВТЧ();
	
	Если не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
		яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
		энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета);
	КонецЕсли;
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// Фискализация ОФД
	Если ПодсистемаИнтеграцияОФДСуществует() Тогда
		МодульфискОбщегоНазначения = энргОбщегоНазначения.МодульОбщегоНазначенияИнтеграцииОФД();
		МодульфискОбщегоНазначения.ПриСозданииНаСервере(ЭтотОбъект);
	КонецЕсли;
	// Фискализация ОФД	
	
	УстановитьВидимостьФункционалаРегистрацииПоказаний();
	УстановитьОтборДокументовРегистрацииПоказаний();
	
	УстановитьВерсиюДокумента(); 
	
КонецПроцедуры   

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗаполнитьКоличествоАктивныхДлительныхОпераций();
	ПоказатьНадписьСозданияДокументов();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоРайонПриЧтении(Объект.ТочкиУчета, ТекущийОбъект);
	
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект, яИспользоватьТарифныеЗоны, яИспользоватьШкалыПриборовУчета, ТекущийОбъект);
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект, "ТочкиУчета");
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект, "Оплата");
	
	энргРаботаСприборамиУчетаСервер.ЗаполнитьСвойствоРегистрируетОбъемПриЧтении(Объект.ТочкиУчета, ТекущийОбъект);
	
	ПоказанияПредоставляютсяВСрок();
	ЗаполнитьТаблицуПриборыДляОтклоненияПоказаний();	
	
	// Фискализация ОФД
	Если ПодсистемаИнтеграцияОФДСуществует() Тогда
		МодульфискОбщегоНазначения = энргОбщегоНазначения.МодульОбщегоНазначенияИнтеграцииОФД();
		ДокументФискализирован = МодульфискОбщегоНазначения.ПлатежныйДокументОтправленВСистемуОФД(Объект.Ссылка);
	КонецЕсли;
	// Фискализация ОФД
	
	ОсталосьСоздатьДокументовДлительныхОпераций = КоличествоОсталосьСоздатьДокументовРегистратора(ТекущийОбъект.Ссылка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Объект.СуммаПоДокументу = Объект.Оплата.Итог("СуммаОплаты");
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	энргШкалыТарифныеЗоныСервер.ЗаполнитьОбъектПоПредставлениюФормы(Объект, ТекущийОбъект, ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета);	
	//Отказ = ПроверкаСуммыРаспределения(ТекущийОбъект.Задолженность);
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	энргРаботаСЛицевымСчетомСервер.ЗаполнитьСвойствоРайонПриЧтении(Объект.ТочкиУчета,ТекущийОбъект); 
	
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("энргИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета,ТекущийОбъект);
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ТочкиУчета");
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"Оплата"); 	
	энргРаботаСприборамиУчетаСервер.ЗаполнитьСвойствоРегистрируетОбъемПриЧтении(Объект.ТочкиУчета,ТекущийОбъект);
	
	// Фискализация ОФД
	Если ПодсистемаИнтеграцияОФДСуществует() Тогда
		МодульфискОбщегоНазначения = энргОбщегоНазначения.МодульОбщегоНазначенияИнтеграцииОФД();
		МодульфискОбщегоНазначения.ПослеЗаписи(ЭтотОбъект);
	КонецЕсли;
	// Фискализация ОФД
	
	УстановитьВидимостьФункционалаРегистрацииПоказаний();
	УстановитьОтборДокументовРегистрацииПоказаний();
	
	УстановитьВерсиюДокумента();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	ЗависимыеРеквизиты = ПолучитьЗависимыеРеквизиты();
	Если ЗначениеЗаполнено(Объект.Ссылка) И НеобходимоСкорректироватьСвязанныеДокументы(Объект.Ссылка, ЗависимыеРеквизиты) Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения(
			"ПослеВопросаОНеобходимостиКорректировкиСвязанныхДокументов",
			ЭтотОбъект);		
			
		ПоказатьВопрос(
			ОписаниеОповещения,
			НСтр("ru = 'Дата документа была изменена. Даты документов созданных на основании будут скорректированы. Продолжить?'"),
			РежимДиалогаВопрос.ДаНет);
			
	КонецЕсли;
	
	ЗаполнитьПериодНачисленияСервер();		
	
КонецПроцедуры

&НаКлиенте
Процедура ФайлДляЧтенияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Объект.Ссылка) и ЕстьСозданныеРегистрацииПоказанийОтДокументаОснования(Объект.Ссылка) Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения(	
			"ПослеВопросаОПометкеСвязанныхДокументов",
			ЭтотОбъект);
			
		ПоказатьВопрос(
			ОписаниеОповещения,
			НСтр("ru = 'На основании выбранного файла загрузки созданы документы ""Регистрация показаний"", удалить их?'"),
			РежимДиалогаВопрос.ДаНетОтмена);
		
		Возврат;
		
	КонецЕсли;
	
	ФайлДляЧтенияНачалоВыбораКлиент();
	//СтандартнаяОбработка 		= Ложь;
	//Диалог 						= Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	////Диалог.Фильтр 	= "Электронная таблица (*.dbf)|*.dbf";
	//Если Диалог.Выбрать() тогда
	//	Объект.ФайлДляЧтения 	= Диалог.ПолноеИмяФайла;
	//КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда 		
		ЗаполнитьПериодНачисленияСервер();		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТочкиУчета

&НаКлиенте
Процедура ТочкиУчетаПриАктивизацииСтроки(Элемент)
	ИмяТаблицыШкал	 						= "ТочкиУчета";
	ИмяТаблицыПоказания						= "ПОказанияПРиборовУчета";
	ТаблицаФормыПоказания 					= Элементы[ИмяТаблицыПоказания];
	
	ТекущиеДанные 							= Элементы[ИмяТаблицыШкал].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	// энргРаботаСВидомДифференцированности {
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(ТаблицаФормыПоказания,Неопределено,ТекущиеДанные.IDСтроки); 
	// энргРаботаСВидомДифференцированности }
	
	энргРаботаСПриборамиУчетаКлиент.РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные.РегистрируетОбъем,Истина,Ложь,ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаАбонентПриИзменении(Элемент)
	ТекТаблица 		= Элементы["ТочкиУчета" + ПрефиксТочекУчета];
	ТекущиеДанные 					= Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	ЕСли ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Абонент) тогда
		энргПользовательскийВводКлиент.ПриИзмененииАбонентаВТабличнойЧасти(ТекущиеДанные);
		
	иначе
		ТекущиеДанные.КлючПомещения	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
		ТекущиеДанные.Помещение 	= ПредопределенноеЗначение("Справочник.энргПомещения.ПустаяСсылка");
		ТекущиеДанные.Строение 		= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
	КонецЕсли;
	
	ТекущиеДанные.ТочкаУчета  = Неопределено; 
	ТекущиеДанные.Услуга  = Неопределено; 
	ТекущиеДанные.ПриборУчета  = Неопределено; 
	ТекущиеДанные.ТочкаУчета  = Неопределено; 
	ЗаполнитьПриборыУчетаСервер(ТекТаблица.ТекущаяСтрока, ТекущиеДанные.Район, ТекущиеДанные.КлючПомещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТочкаУчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)	
	ТекДанные = Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	//СтандартнаяОбработка	= Ложь;
	ДополнительныеПараметры = новый Структура("Дата,Организация,Район,КлючПомещения",Объект.Дата,Объект.Организация,ТекДанные.Район,ТекДанные.КлючПомещения);
	энргПользовательскийВводКлиент.НачалоВыбораТочкиУчета(Элемент,ДополнительныеПараметры);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТочкаУчетаПриИзменении(Элемент)
	ТекТаблица 		= Элементы["ТочкиУчета" + ПрефиксТочекУчета];
	ТекущиеДанные 	= ТекТаблица.ТекущиеДанные;
	ЗаполнитьПриборыУчетаСервер(ТекТаблица.ТекущаяСтрока, ТекущиеДанные.Район, ТекущиеДанные.КлючПомещения);
	//энргРаботаСПриборамиУчетаКлиент.РаботаСВидимостьюИДоступностьюСтрокПУ(ТекущиеДанные.РегистрируетОбъем,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета,ЭтаФорма);
	//ТочкиУчетаНетШкалЕстьТарифныеЗоныПриАктивизацииСтроки(Элемент);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПриборУчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекущиеДанные = Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;
	
	СтандартнаяОбработка 	= Ложь;
	ПараметрыФормы 			= Новый Структура("Отбор", Новый Структура("Ссылка", ВернутьПУ(Объект.Дата, ТекущиеДанные.Абонент, ТекущиеДанные.ТочкаУчета)));
	ОткрытьФорму("Справочник.энргПриборыУчетаАбонента.ФормаВыбора", ПараметрыФормы, Элемент);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПриборУчетаПриИзменении(Элемент)
	
	ТекущиеДанные	= Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущиеДанные;//Элементы.ТочкиУчета.ТекущиеДанные;
	ТекущаяСтрока 	= Элементы["ТочкиУчета" + ПрефиксТочекУчета].ТекущаяСтрока;
	ЗаполнитьПриборыУчетаСервер(ТекущаяСтрока, ТекущиеДанные.Район, ТекущиеДанные.КлючПомещения);
	
КонецПроцедуры

#КонецОбласти 

#Область РаботаСОплатой

#Область ОбработчикиСобытийЭлементовТаблицыФормыОплата

&НаКлиенте
Процедура ОплатаАбонентПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Оплата.ТекущиеДанные;
	ЕСли ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Абонент) тогда
		энргПользовательскийВводКлиент.ПриИзмененииАбонентаВТабличнойЧасти(ТекущиеДанные);
	иначе
		ТекущиеДанные.КлючПомещения	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
		ТекущиеДанные.Помещение 	= ПредопределенноеЗначение("Справочник.энргПомещения.ПустаяСсылка");
		ТекущиеДанные.Строение 		= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОплатаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда 		
		ТекущиеДанные 							= Элемент.ТекущиеДанные;
		// TODO FIX ME {
		ТекущиеДанные.Поставщик 				= ПолучитьКонтрагентаПоКоду("000000001");
		// }
		ТекущиеДанные.ДатаПлатежногоДокумента 	= Объект.Дата; 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОплатаПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.Оплата.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;  
	
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
		ТекущиеДанные.IDСтроки = Новый УникальныйИдентификатор;
	КонецЕсли;
	
	Элементы.Задолженность.ОтборСтрок = Новый ФиксированнаяСтруктура("IDСтроки", ТекущиеДанные.IDСтроки);
	Элементы.ПереносСуммыОплаты.ОтборСтрок = Новый ФиксированнаяСтруктура("IDСтроки", ТекущиеДанные.IDСтроки);
	//энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПереносСуммыОплаты, Неопределено, ТекущиеДанные.IDСтроки,, "");
	
