	//		КлючПомещения 		= ДанныеЗаполнения.КлючПомещения;
	//	Иначе
	//		КлючПомещения = Абонент.КлючПомещения;
	//	КонецЕсли;
	//	Если ДанныеЗаполнения.Свойство("Организация") Тогда
	//		Организация 		= ДанныеЗаполнения.Организация;
	//	Иначе
	//		Организация = Абонент.Организация;
	//	КонецЕсли;
	//	Если ДанныеЗаполнения.Свойство("Район") Тогда
