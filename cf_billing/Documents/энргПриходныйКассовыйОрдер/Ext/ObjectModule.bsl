#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда              

#Область ПрограммныйИнтерфейс

// Выставляет в дополнителные свойства массив приборов.
//
Функция МассивПриборов() Экспорт
		
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ссылка",Ссылка);
	Запрос.Текст  	= 
	"ВЫБРАТЬ
	|	ТаблицаПриборов.ПриборУчета КАК ПриборУчета,
	|	ЛОЖЬ КАК ВыводПрибораУчета,
	|	""ПоказанияПриборовУчета"" КАК ИмяТабЧасти,
	|	0 КАК Разделитель
	|ИЗ
	|	Документ.энргПриходныйКассовыйОрдер.ТочкиУчета КАК ТаблицаПриборов
	|ГДЕ
	|	ТаблицаПриборов.Ссылка = &Ссылка
	|	И НЕ ТаблицаПриборов.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)";
	
	ДополнительныеСвойства.Вставить("МассивПриборов",Запрос.Выполнить());
	
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеСвойства.свойство("РежимКонвертации") тогда
		Возврат;
	КонецЕсли;
		
	Если ДополнительныеСвойства.свойство("ВосстановлениеПоследовательности") тогда
		Возврат;
	КонецЕсли;	
	
	Ответственный = Пользователи.ТекущийПользователь();	
		 	
	ДополнительныеСвойства.Вставить("Кассир",				Ответственный);
	ДополнительныеСвойства.Вставить("ИсточникПоступления",	?(ЗначениеЗаполнено(ИсточникПоступления), ИсточникПоступления, Справочники.энргИсточникиПоступления.Касса));
	ДополнительныеСвойства.Вставить("ЭтоОплата", 			Истина);
			
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	
	Если ДополнительныеСвойства.свойство("РежимКонвертации") тогда
		Возврат;
	КонецЕсли;
	
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);  	
					
	ПроведениеПриборыУчета(); 	
	УменьшитьЗадолженностьАбонента();		
	УменьшитьЗадолженностьПоРассрочке();
	
КонецПроцедуры

