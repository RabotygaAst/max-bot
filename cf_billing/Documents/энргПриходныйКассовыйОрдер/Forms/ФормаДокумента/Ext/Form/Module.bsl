&НаСервере
Процедура ЗаполнитьНачисленияТекПериода()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргОбъемНачисленийОбороты.СуммаОборот КАК Сумма,
	|	энргОбъемНачисленийОбороты.ОбъемУслугиОборот КАК ОбъемУслуги,
	|	энргОбъемНачисленийОбороты.Услуга КАК Услуга,
	|	энргОбъемНачисленийОбороты.ПериодНачисления КАК ПериодНачисления
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			Период,
	|			Район = &Район
	|				И Организация = &Организация
	|				И Абонент = &Абонент) КАК энргОбъемНачисленийОбороты";
	
	Запрос.УстановитьПараметр("Абонент", Объект.Абонент);
	Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(Объект.Дата));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(Объект.Дата));
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Район", Объект.Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтрокаНачисления  								= Объект.НачисленияТекущегоПериода.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНачисления,ВыборкаДетальныеЗаписи); 
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УслугиОплаченоПриИзменении(Элемент)
	УслугиОплаченоПриИзмененииНаСервере();
	СуммаКРаспределению();
	
	ТекущаяСтрока = Элементы.Услуги.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ТекущаяСтрока.ВидЗадолженности = ПредопределенноеЗначение("Перечисление.энргВидыЗадолженности.МораторнаяЗадолженность") Тогда
		ПоказатьПредупреждение(,"Не забудьте согласовать с юристом оплату мораторной задолженности");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СуммаОплатыПриИзменении(Элемент)
	СуммаОплатыПриИзмененииНаСервере();
	СуммаКРаспределению();
КонецПроцедуры


&НаСервере
Процедура УслугиОплаченоПриИзмененииНаСервере()
	ВсегоПоСтрокам 	= Объект.Услуги.Итог("Оплачено");
	
	Если Объект.СуммаОплаты < ВсегоПоСтрокам Тогда
		ТекДанные 			= Объект.Услуги.НайтиПоИдентификатору(Элементы.Услуги.ТекущаяСтрока);
		Разница 			= Объект.СуммаОплаты - (ВсегоПоСтрокам - ТекДанные.Оплачено);
		ТекДанные.Оплачено 	= 0;		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сумма распределения превысила сумму оплаты. Остаток к распределению: " + Разница);
	КонецЕсли;
	
КонецПроцедуры   

&НаСервере
Процедура СуммаОплатыПриИзмененииНаСервере()
	ВсегоПоСтрокам 	= Объект.Услуги.Итог("Оплачено");
	
	Если Объект.СуммаОплаты < ВсегоПоСтрокам Тогда
		Объект.СуммаОплаты = ВсегоПоСтрокам;		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сумма распределения превысила сумму оплаты.");
	КонецЕсли;
КонецПроцедуры

