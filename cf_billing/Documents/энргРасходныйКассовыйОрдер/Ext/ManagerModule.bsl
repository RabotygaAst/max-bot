// Заполняет список команд печати.
// 
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	КомандаПечати 					= КомандыПечати.Добавить();
	КомандаПечати.Идентификатор 	= "Чек";
	КомандаПечати.Представление 	= НСтр("ru = 'Чек'; en = 'Acceptance note'");	
 
КонецПроцедуры

// Формирует печатные формы.
//
// Параметры:
//  МассивОбъектов			-	см. УправлениеПечатьюПереопределяемый.ПриПечати.МассивОбъектов.
//  ПараметрыПечати			-	см. УправлениеПечатьюПереопределяемый.ПриПечати.ПараметрыПечати.
//  КоллекцияПечатныхФорм	-	см. УправлениеПечатьюПереопределяемый.ПриПечати.КоллекцияПечатныхФорм.
//  ОбъектыПечати			-	см. УправлениеПечатьюПереопределяемый.ПриПечати.ОбъектыПечати.
//  ПараметрыВывода			-	см. УправлениеПечатьюПереопределяемый.ПриПечати.ПараметрыВывода.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "Чек") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"Чек", 
		НСтр("ru = 'Чек'; en = 'Acceptance note'"),
		СформироватьПечатнуюФормуЧека(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
	КонецЕсли;
	
	энргФормированиеПечатныхФорм.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);

КонецПроцедуры

// Заполняет структуру получателей печатных форм.
//
// Параметры:
//  СтруктураДанныхОбъектаПечати	-	Структура.
//
Процедура ЗаполнитьСтруктуруПолучателейПечатныхФорм(СтруктураДанныхОбъектаПечати) Экспорт

	СтруктураДанныхОбъектаПечати.ОсновнойПолучатель = "Абонент.ФизЛицо";
	
	СтруктураДанныхОбъектаПечати.МассивРеквизитовПолучателей.Добавить("Абонент.ФизЛицо");
	
КонецПроцедуры

// Добавляет команду создать на основании документ перерасчет.
//
// Параметры:
//  КомандыСоздатьНаОсновании	-	КомандыФормы.
//
Процедура ДобавитьКомандуСоздатьНаОснованииДокументПерерасчет(КомандыСоздатьНаОсновании) Экспорт 
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.энргПерерасчет) Тогда
		КомандаСоздатьНаОсновании 					= КомандыСоздатьНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Обработчик 		= "ВводНаОснованииБиллингКлиент.РасходныйКассовыйОрдерНаОснованииПерерасчет";
		КомандаСоздатьНаОсновании.Идентификатор 	= "РасходныйКассовыйОрдерНаОснованииПерерасчет";
		КомандаСоздатьНаОсновании.Представление 	= НСтр("ru = 'Расходный кассовый ордер'");
		КомандаСоздатьНаОсновании.ПроверкаПроведенияПередСозданиемНаОсновании = Ложь; 		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СформироватьПечатнуюФормуЧека(МассивОбъектов, ОбъектыПечати, ПараметрыПечати) 
	
	Макет					= УправлениеПечатью.МакетПечатнойФормы("ОбщиеМакеты.энргЧек");
	
	МВТ						= Новый МенеджерВременныхТаблиц;
	СтруктураРезультатов	= ПолучитьДанныеДляПечати(МассивОбъектов, ПараметрыПечати, МВТ);
	
	ЗапросНаОстатки			= Новый Запрос;
	ЗапросНаОстатки.МенеджерВременныхТаблиц	= МВТ;
	ЗапросНаОстатки.Текст	= ПолучитьТекстОстатков();
	
	

	ДанныеОрганизаций		= СтруктураРезультатов["РезультатПоШапке"].Выбрать();
	ДанныеКвитанций			= СтруктураРезультатов["РезультатПоКвитанциям"].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ДанныеПоДатам			= СтруктураРезультатов["РезультатПоДатам"].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ТабличныйДокумент 		= Новый ТабличныйДокумент;
	
	ПервыйДокумент = Истина;
	
	Пока ДанныеОрганизаций.Следующий() Цикл
		ЗапросНаОстатки.УстановитьПараметр("Организация", ДанныеОрганизаций.Организация);
		// Заполняем область шапки чека
		
		ОбластьОрганизация								= Макет.ПолучитьОбласть("Организация");
		ЗаполнитьЗначенияСвойств(ОбластьОрганизация.Параметры, ДанныеОрганизаций);
		
		СтруктураПоиска = Новый Структура("Организация", ДанныеОрганизаций.Организация);
		// Найдем в выборке даты по текущей организации
		НайденСледующий = ДанныеПоДатам.НайтиСледующий(СтруктураПоиска);
		Если НайденСледующий Тогда
			ВыборкаПоДатам = ДанныеПоДатам.Выбрать();
			ВыборкаПоДатам.Сбросить();
		Иначе
			Продолжить;
		КонецЕсли;
		
		Пока ВыборкаПоДатам.Следующий() Цикл
			// запрос на остатки услуг
			ЗапросНаОстатки.УстановитьПараметр("Дата",НачалоМесяца(ДобавитьМесяц(ВыборкаПоДатам.ДатаОстатков, 1)));
			   
			// Найдем в выборке квитанции по текущей организации
			НайденСледующий = ДанныеКвитанций.НайтиСледующий(СтруктураПоиска);
			
			// Если в Организации нет квитанций - перейдем к следующей организации
			Если НайденСледующий Тогда
				ВыборкаПоДатамКвитанций = ДанныеКвитанций.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				ВыборкаПоДатамКвитанций.Сбросить();
			Иначе
				Продолжить;
			КонецЕсли;
			
			// Найдем в квитанции по текущей дате
			СтруктураПоискаПоДате = Новый Структура("ДатаОстатков", ВыборкаПоДатам.ДатаОстатков);
			НайденСледующий = ВыборкаПоДатамКвитанций.НайтиСледующий(СтруктураПоискаПоДате);
			
			// Если в Дате нет квитанций - перейдем к следующей дате
			Если НайденСледующий Тогда
				ВыборкаПоДокументу = ВыборкаПоДатамКвитанций.Выбрать();
				ВыборкаПоДокументу.Сбросить();
			Иначе
				Продолжить;
			КонецЕсли;
			
			ВыборкаОстатков	= ЗапросНаОстатки.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаПоДокументу.Следующий() Цикл
							
				// Заполняем остатки
				СтруктураПоискаАбонента = Новый Структура("Абонент", ВыборкаПоДокументу.ФИО);
				НайденСледующий			= ВыборкаОстатков.НайтиСледующий(СтруктураПоискаАбонента);
				ТД_Аванс				= Неопределено;
				Если НайденСледующий И ВыборкаОстатков.СуммаОстаток > 0 Тогда
					ОбщаяЗадолженность	= ВыборкаОстатков.СуммаОстаток;
					ОбщаяОплата			= ВыборкаПоДокументу.СуммаОплаты;
					Если ОбщаяЗадолженность < ОбщаяОплата Тогда 
						// надо еще напечатать авансовый чек на (ОбщаяОплата - ОбщаяЗадолженность)						
						ТД_Аванс = ПолучитьЧек(Макет, ОбщаяОплата - ОбщаяЗадолженность, , ОбластьОрганизация, ДанныеОрганизаций, ВыборкаПоДокументу);
						ОбщаяОплата			= ОбщаяЗадолженность;
					КонецЕсли;
					
					ОстатокЗадолженности	= ОбщаяЗадолженность;
					ОстатокОплаты			= ОбщаяОплата;
					
					ВыборкаПоУслугам = ВыборкаОстатков.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					ВыборкаПоУслугам.Сбросить();
					
					ТД_Услуги = Новый ТабличныйДокумент;
					
					Пока ВыборкаПоУслугам.Следующий() Цикл
						ОбластьНазваниеУслуги	= Макет.ПолучитьОбласть("НазваниеУслуги");
					    ЗаполнитьЗначенияСвойств(ОбластьНазваниеУслуги.Параметры,ВыборкаПоУслугам);
						ТД_Услуги.Вывести(ОбластьНазваниеУслуги);
						
						ВыборкаПоДатамУслуги = ВыборкаПоУслугам.Выбрать();
						Пока ВыборкаПоДатамУслуги.Следующий() Цикл
							ОбластьДолгУслуги	= Макет.ПолучитьОбласть("ДолгУслуги");
							ЗаполнитьЗначенияСвойств(ОбластьДолгУслуги.Параметры,ВыборкаПоДатамУслуги);
							ОбластьДолгУслуги.Параметры.ПериодНачисления = Формат(ВыборкаПоДатамУслуги.ПериодНачисления, "ДФ=MMMM.yy");
							ТД_Услуги.Вывести(ОбластьДолгУслуги);
						КонецЦикла;
						
						ОбластьОплатаУслуги	= Макет.ПолучитьОбласть("ОплатаУслуги");
					    ЗаполнитьЗначенияСвойств(ОбластьОплатаУслуги.Параметры,ВыборкаПоУслугам);
						
						ОстатокЗадолженности = ОстатокЗадолженности - ВыборкаПоУслугам.СуммаОстаток;
						Если ОстатокЗадолженности = 0 Тогда
							ТекОплата	= ОстатокОплаты;
						Иначе
							ТекОплата	= Окр(ОбщаяОплата * ВыборкаПоУслугам.СуммаОстаток / ОбщаяЗадолженность, 2);
						КонецЕсли;
						ОстатокОплаты	= ОстатокОплаты - ТекОплата;
						
						ОбластьОплатаУслуги.Параметры.Оплачено	= ТекОплата;						
						ТД_Услуги.Вывести(ОбластьОплатаУслуги);
					КонецЦикла;
					
				Иначе
					// Авансовый платеж
					ОбщаяОплата	= ВыборкаПоДокументу.СуммаОплаты;
					ТД_Услуги	= Неопределено;
				КонецЕсли;
				
				ТД_Чек = ПолучитьЧек(Макет, ОбщаяОплата, ТД_Услуги, ОбластьОрганизация, ДанныеОрганизаций, ВыборкаПоДокументу);
				
				Если Не ПервыйДокумент Тогда
					ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				КонецЕсли;
				ПервыйДокумент		= Ложь;
				НомерСтрокиНачало	= ТабличныйДокумент.ВысотаТаблицы + 1;
				ТабличныйДокумент.Вывести(ТД_Чек);
				
				//УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаПоДокументу.Ссылка);
				Если ТД_Аванс <> Неопределено Тогда
					ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
					//НомерСтрокиНачало	= ТабличныйДокумент.ВысотаТаблицы + 1;
					ТабличныйДокумент.Вывести(ТД_Аванс);
				КонецЕсли;
				
				УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаПоДокументу.Ссылка);
				
			КонецЦикла;
		КонецЦикла;

	КонецЦикла;
	
	ТабличныйДокумент.КлючПараметровПечати				= "ПАРАМЕТРЫ_ПЕЧАТИ_Чек";
	ТабличныйДокумент.АвтоМасштаб						= Истина;
	ТабличныйДокумент.ОриентацияСтраницы				= ОриентацияСтраницы.Портрет;
	
	Возврат ТабличныйДокумент;	  	
КонецФункции

Функция ПолучитьДанныеДляПечати(МассивОбъектов, ПараметрыПечати, МВТ)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргКвитанция.Ссылка КАК Ссылка,
	|	энргКвитанция.Номер КАК Номер,
	|	энргКвитанция.Дата КАК Дата,
	|	энргКвитанция.Абонент КАК ФИО,
	|	энргКвитанция.Касса КАК Касса,
	|	энргКвитанция.СуммаОплаты КАК СуммаОплаты,
	|	энргКвитанция.Организация КАК Организация,
	|	энргКвитанция.Абонент.ЛицевойСчет КАК ЛС,
	|	энргКвитанция.Абонент.КлючПомещения КАК КлючПомещения,
	|	энргКвитанция.Ответственный КАК Кассир,
	|	энргКвитанция.ПериодОплатыКонец КАК ПериодОплатыКонец,
	|	энргКвитанция.ПериодОплатыНачало КАК ПериодОплатыНачало,
	|	ВЫБОР
	|		КОГДА ДЕНЬ(энргКвитанция.Дата) <= 10
	|			ТОГДА НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(энргКвитанция.Дата, МЕСЯЦ, -1), МЕСЯЦ)
	|		ИНАЧЕ НАЧАЛОПЕРИОДА(энргКвитанция.Дата, МЕСЯЦ)
	|	КОНЕЦ КАК ДатаОстатков
	|ПОМЕСТИТЬ ВТ_Квитанции
	|ИЗ
	|	Документ.энргПриходныйКассовыйОрдер КАК энргКвитанция
	|ГДЕ
	|	энргКвитанция.Ссылка В(&МассивДокументов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Квитанции.Организация КАК Организация
	|ПОМЕСТИТЬ ВТ_Организации
	|ИЗ
	|	ВТ_Квитанции КАК ВТ_Квитанции
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Квитанции.Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Организации.Организация КАК Организация,
	|	ВТ_Организации.Организация.ИНН КАК ОрганизацияИНН,
