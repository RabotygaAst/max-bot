Функция ПолучитьЧек(Макет, ОбщаяОплата, ТД_Услуги = Неопределено, ОбластьОрганизация, ДанныеОрганизаций, ВыборкаПоДокументу)
	ТабличныйДокументЧека = Новый ТабличныйДокумент;
	
	ТабличныйДокументЧека.Вывести(ОбластьОрганизация);
	
	ОбластьКвитанция	= Макет.ПолучитьОбласть("Квитанция");
	ЗаполнитьЗначенияСвойств(ОбластьКвитанция.Параметры, ВыборкаПоДокументу);
	ОбластьКвитанция.Параметры.Месяц = СформироватьПредставлениеМесяца(ВыборкаПоДокументу.ПериодОплатыНачало, ВыборкаПоДокументу.ПериодОплатыКонец);
	
	ТабличныйДокументЧека.Вывести(ОбластьКвитанция);
	
	Если ТД_Услуги = Неопределено ТОгда
		ТД_Услуги = Новый ТабличныйДокумент;
		ОбластьНазваниеУслуги	= Макет.ПолучитьОбласть("НазваниеУслуги");
		ОбластьНазваниеУслуги.Параметры.Услуга = "Авансовый платеж";
		ТД_Услуги.Вывести(ОбластьНазваниеУслуги);
		
		ОбластьОплатаУслуги	= Макет.ПолучитьОбласть("ОплатаУслуги");
		ОбластьОплатаУслуги.Параметры.Оплачено		= ОбщаяОплата;
		ОбластьОплатаУслуги.Параметры.СуммаОстаток	= ОбщаяОплата;
		ТД_Услуги.Вывести(ОбластьОплатаУслуги);
	КонецЕсли;
	ТабличныйДокументЧека.Вывести(ТД_Услуги);
	
	ОбластьПодвал	= Макет.ПолучитьОбласть("Подвал");
	ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры, ВыборкаПоДокументу);
	ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры, ДанныеОрганизаций);
	ОбластьПодвал.Параметры.СуммаОплаты	= Формат(ОбщаяОплата, "ЧДЦ=2");
	ОбластьПодвал.Параметры.НДС			= Формат(ОбщаяОплата * 0.2, "ЧДЦ=2");
	ТабличныйДокументЧека.Вывести(ОбластьПодвал);
	
	Возврат ТабличныйДокументЧека;
КонецФункции

#КонецОбласти

#КонецЕсли