	|ИТОГИ ПО
	|	Организация";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	
	МассивРезультатов		= Запрос.ВыполнитьПакет();
	РезультатПоШапке		= МассивРезультатов[2];
	РезультатПоКвитанциям	= МассивРезультатов[3];
	РезультатПоДатам		= МассивРезультатов[4];
	
	СтруктураДанныхДляПечати 	= Новый Структура("РезультатПоШапке,РезультатПоКвитанциям,РезультатПоДатам", РезультатПоШапке, РезультатПоКвитанциям, РезультатПоДатам);
	                     
	Возврат СтруктураДанныхДляПечати;
КонецФункции

Функция СформироватьПредставлениеМесяца(Начало, Конец)
	
	Если Год(Начало) = Год(Конец) Тогда
		Если Месяц(Начало) = Месяц(Конец) Тогда
			Возврат Формат(Конец, "ДФ=ММMM.yy");
		КонецЕсли;
		
		Возврат Формат(Начало, "ДФ=ММMM") + "-" + Формат(Конец, "ДФ=ММMM.yy");	
		
	КонецЕсли;
	
	Возврат Формат(Начало, "ДФ=ММMM.yy") + "-" + Формат(Конец, "ДФ=ММMM.yy");
	
КонецФункции

