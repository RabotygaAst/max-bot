#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
		КонецЕсли;
	КонецЕсли;
	
	Если Параметры.Ключ.Пустая() Тогда
		ПосчитатьКоличествоЧасовВПериоде(Объект.Организация, Объект.ПериодНачисления);
	КонецЕсли;
	
	КонецПериодаНачисления = КонецДня(ГраницыОтчетногоПериода(Объект.Организация, Объект.ПериодНачисления).ЗавершениеОП);
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы 

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда		
		Объект.ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация); 		
	КонецЕсли;
	
	КонецПериодаНачисления = КонецДня(ГраницыОтчетногоПериода(Объект.Организация, Объект.ПериодНачисления).ЗавершениеОП);
	
	ПосчитатьКоличествоЧасовВПериоде(Объект.Организация, Объект.ПериодНачисления);
КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	РайонПриИзмененииСервер();
	ОрганизацияПриИзменении(Элемент);
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда		
		Объект.ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация); 		
	КонецЕсли;
	
	ПосчитатьКоличествоЧасовВПериоде(Объект.Организация, Объект.ПериодНачисления);
КонецПроцедуры

&НаКлиенте
Процедура МКДПриИзменении(Элемент)
	МКДПриИзмененииНаСервере();
	ПосчитатьКоличествоЧасовВПериоде(Объект.Организация, Объект.ПериодНачисления);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТочкиУчета

&НаКлиенте
Процедура ТочкиУчетаКоличествоЧасовШтатнойРаботыПУПриИзменении(Элемент)
	ТекСтрока = Элементы.ТочкиУчета.ТекущиеДанные;
	ТекСтрока.КоличествоЧасовШТИзмененоПользователем = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаОбъемПриИзменении(Элемент)
	ТекСтрока = Элементы.ТочкиУчета.ТекущиеДанные;
	ТекСтрока.ЕстьПоказания = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаОбъемОчистка(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекСтрока = Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекСтрока <> Неопределено Тогда
		ТекСтрока.ЕстьПоказания = Ложь;
		ТекСтрока.Объем = 0;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПередУдалением(Элемент, Отказ)
	Отказ 			= Истина;
	ДопПараметры	= Новый Структура;
	ДопПараметры.Вставить("ТекущийОбъект", 	Объект.Ссылка);
	ДопПараметры.Вставить("ТЧ", 			"ТочкиУчета");
	ДопПараметры.Вставить("НомерСтроки", 	Элемент.ТекущиеДанные.НомерСтроки-1);
	ПроверкаУдаленияСтроки(ДопПараметры);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Заполнить(Команда)
	ТекИдентификатор 	= "";
	Дубль				= Неопределено;
	ЗаполнитьДанныеДоговораСервер(ТекИдентификатор,Дубль);
	Если не Дубль = Неопределено Тогда
		ДопПараметры	= Новый Структура;
		ДопПараметры.Вставить("ТекущийОбъект", 	Объект.Ссылка);
		ДопПараметры.Вставить("ТЧ", 			"ТочкиУчета");
		ДопПараметры.Вставить("ТекСтрока", 		ТекИдентификатор);
		ПоказанияУжеВведеныВопрос(ДопПараметры);			
	КонецЕсли;		
	Если НЕ ТекИдентификатор = "" Тогда
		ЭтаФорма.ТекущийЭлемент = Элементы.ТочкиУчета;
		Элементы.ТочкиУчета.ТекущаяСтрока = ТекИдентификатор;
		Элементы.ТочкиУчета.ТекущийЭлемент = Элементы.ТочкиУчетаОбъем; 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьЧасыШтатнойРаботы(Команда)
	Для каждого стр из Объект.ТочкиУчета Цикл
		Если Не стр.КоличествоЧасовШТИзмененоПользователем Тогда
			стр.КоличествоЧасовШтатнойРаботыПУ = стр.КоличествоЧасовРаботыТУ;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиКМКД(Команда)
	Элементы.ТочкиУчета.ОтборСтрок = Новый ФиксированнаяСтруктура();
	СтруктураОтбора = Новый Структура();
	Если ЗначениеЗаполнено(МКД) Тогда
		СтруктураОтбора.Вставить("МКД", МКД);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТочкаУчета) Тогда
		СтруктураОтбора.Вставить("МКД", МКД);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Услуга) Тогда
		СтруктураОтбора.Вставить("Услуга", Услуга);
	КонецЕсли;
	Элементы.ТочкиУчета.ОтборСтрок = Новый ФиксированнаяСтруктура(СтруктураОтбора);
КонецПроцедуры

&НаКлиенте
Процедура Рассчитать(Команда)
	РассчитатьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура УбратьОтбор(Команда)
	Элементы.ТочкиУчета.ОтборСтрок = Новый ФиксированнаяСтруктура();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура РайонПриИзмененииСервер()
	Объект.Организация = Объект.Район.Организация;	
КонецПроцедуры

&НаСервере
Процедура МКДПриИзмененииНаСервере()
	Объект.Район = МКД.Район;
	Объект.Организация = МКД.Организация;
КонецПроцедуры

&НаКлиенте
Процедура ПоказанияУжеВведеныВопрос(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросПереходаКСтроке",ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Объёмы уже введены. Перейти к строке?",РежимДиалогаВопрос.ДаНет,,КодВозвратаДиалога.Да);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПереходаКСтроке(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			ПерейтиКСтроке(ДополнительныеПараметры);			
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ПерейтиКСтроке(ДополнительныеПараметры)
	Элементы[ДополнительныеПараметры.ТЧ].ТекущаяСтрока = ДополнительныеПараметры.ТекСтрока;
	Элементы[ДополнительныеПараметры.ТЧ].ТекущийЭлемент = Элементы[ДополнительныеПараметры.ТЧ + "Объем"];	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеДоговораСервер(ТекИдентификатор,Дубль)
	
	Результат 								= ДействующиеПриборыУчетаМКД(Объект.Дата,Объект.Организация,Объект.Район,МКД,ТочкаУчета,Услуга); 
	Выборка  								= Результат.выбрать();
	
	ТЧТочки = Объект.ТочкиУчета;
	
	Пока Выборка.следующий() цикл
		НовСтр = ТЧТочки.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр,Выборка);
		НовСтр.МКД = МКД;
		НовСтр.КоличествоЧасовШтатнойРаботыПУ = Выборка.КоличествоЧасовРаботыТУ;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ДействующиеПриборыУчетаМКД(Период,Организация,Район,МКД,ТочкаУчета = Неопределено, Услуга = Неопределено)  
	
	ГраницыПериода  								= Обработки.энргГраницыПериодаНачисленияМенеджер.ГраницыРасчетногоПериода(объект.Организация,Объект.Район,Объект.ПериодНачисления,Ложь);
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("МКД",					МКД);
	Запрос.УстановитьПараметр("НачалоОП",				ГраницыПериода.НачалоОП);
	Запрос.УстановитьПараметр("ЗавершениеОП",			ГраницыПериода.ЗавершениеОП);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	энргАктивностьТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаМКД
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И МКД = &МКД
	|				И Район = &Район) КАК энргАктивностьТочекУчетаМКДСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекУчетаМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|	И энргАктивностьТочекУчетаМКДСрезПоследних.ТочкаУчета = &ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВладельцыТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ТочкиУчетаМКД
	|ИЗ
	|	РегистрСведений.энргВладельцыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ТочкаУчета В
	|					(ВЫБРАТЬ
	|						АктивныеТочкиУчетаМКД.ТочкаУчета
	|					ИЗ
	|						АктивныеТочкиУчетаМКД КАК АктивныеТочкиУчетаМКД)) КАК энргВладельцыТочекУчетаСрезПоследних
	|ГДЕ
	|	энргВладельцыТочекУчетаСрезПоследних.АбонентВладелец = &МКД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктивныеТочкиУчетаМКД.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ДействующиеТочкиУчета
	|ИЗ
	|	АктивныеТочкиУчетаМКД КАК АктивныеТочкиУчетаМКД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТочкиУчетаМКД КАК ТочкиУчетаМКД
	|		ПО АктивныеТочкиУчетаМКД.ТочкаУчета = ТочкиУчетаМКД.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПриборыТочекМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыТочекМКДСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыТочекМКД
	|ИЗ
	|	РегистрСведений.энргПриборыТочекМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД) КАК энргПриборыТочекМКДСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДействующиеТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	ПриборыТочекМКД.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ПриборыДействующихТочекМКД
	|ИЗ
	|	ДействующиеТочкиУчета КАК ДействующиеТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПриборыТочекМКД КАК ПриборыТочекМКД
	|		ПО ДействующиеТочкиУчета.ТочкаУчета = ПриборыТочекМКД.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргСостояниеПриборовМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргСостояниеПриборовМКДСрезПоследних.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВведенныеПриборыМКД
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД) КАК энргСостояниеПриборовМКДСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.Услуга КАК Услуга
	|ПОМЕСТИТЬ УслугиТочекУчетаМКД
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргУслугиТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|		ВЫБОР
	|			КОГДА энргУслугиТочекУчетаМКДСрезПоследних.Услуга.СоставнаяУслуга
	|				ТОГДА энргВидыУслугСоставляющиеУслуг.Услуга
	|			ИНАЧЕ энргУслугиТочекУчетаМКДСрезПоследних.Услуга
	|		КОНЕЦ КАК Услуга
	|	ИЗ
	|		РегистрСведений.энргУслугиТочекУчетаМКД.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район
	|					И МКД = &МКД) КАК энргУслугиТочекУчетаМКДСрезПоследних
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|			ПО энргУслугиТочекУчетаМКДСрезПоследних.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
	|				И (энргУслугиТочекУчетаМКДСрезПоследних.Услуга.СоставнаяУслуга)) КАК ВложенныйЗапрос
	|ГДЕ
	|	ВложенныйЗапрос.Услуга = &Услуга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргПриборыУзловУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПриборыУзловУчетаМКДСрезПоследних.УзелУчета КАК УзелУчета,
	|	энргПриборыУзловУчетаМКДСрезПоследних.ТипИзмерителя КАК ТипИзмерителя,
	|	энргПриборыУзловУчетаМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргПриборыУзловУчетаМКДСрезПоследних.МКД КАК МКД
	|ПОМЕСТИТЬ ВТ_ПриборыУзловУчета
	|ИЗ
	|	РегистрСведений.энргПриборыУзловУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И (ТочкаУчета, УзелУчета) В
	|					(ВЫБРАТЬ
	|						ВведенныеПриборыМКД.ТочкаУчета КАК ТочкаУчета,
