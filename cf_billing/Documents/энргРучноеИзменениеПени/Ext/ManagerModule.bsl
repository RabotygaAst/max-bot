Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
	
	ПараметрыЗапроса  			= Новый Структура;
	Схема 						= Неопределено;
	
	ЗаполнитьСхемуЗапроса(Схема, Регистры);
		
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		ВспомогательныеПараметры 	= Новый Структура;
		энргФормированиеТекстовЗапроса.УстановитьПерехватОбращенияКТаблицам(Схема, ДополнительныеСвойства.ТаблицыПодмены, ВспомогательныеПараметры); 
	КонецЕсли;
	
	КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	
	ПараметрыЗапроса 				= Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы", 					ДокументСсылка);
	//ПараметрыПроведения = ДополнительныеСвойства.ПараметрыПроведения;
	//ПараметрыЗапроса.Вставить("ПериодРегистрации",				ПараметрыПроведения.ПериодРегистрации);
	ПараметрыЗапроса.Вставить("ПустойУникальныйИдентификатор", 	ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
		
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		энргСхемаЗапросаСервер.ВыполнитьПакет(Схема,ПараметрыЗапроса));
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РеализацияИнтерефейса_Проведение

Процедура ЗаполнитьСхемуЗапроса(Схема, Регистры)
	ДобавитьТекстЗапросаНачислениеПени(Схема, Регистры);
	ДобавитьТекстЗапросаВзаиморасчетыПоПени(Схема, Регистры);// Перенести в восстановление последовательности!!!
	ДобавитьТекстЗапросаВзаиморасчеты(Схема, Регистры);
КонецПроцедуры

Процедура ДобавитьТекстЗапросаНачислениеПени(Схема, Регистры)
	
	ИмяРегистра = "энргНачислениеПени";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	энргРучноеИзменениеПени.Дата КАК Период,
	|	энргРучноеИзменениеПени.Организация КАК Организация,
	|	энргРучноеИзменениеПени.Район КАК Район,
	|	энргРучноеИзменениеПени.Абонент КАК Абонент,
	|	энргРучноеИзменениеПениПени.Услуга КАК Услуга,
	|	энргРучноеИзменениеПениПени.Поставщик КАК Поставщик,
	|	энргРучноеИзменениеПени.ПериодНачисления КАК ПериодРасчета,
	|	энргРучноеИзменениеПениПени.ПериодНачисления КАК ПериодНачисления,
	|	СУММА(энргРучноеИзменениеПениПени.Сумма) КАК Сумма,
	|	энргРучноеИзменениеПени.МКД КАК МКД
	|ИЗ
	|	Документ.энргРучноеИзменениеПени КАК энргРучноеИзменениеПени
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргРучноеИзменениеПени.Пени КАК энргРучноеИзменениеПениПени
	|		ПО энргРучноеИзменениеПени.Ссылка = энргРучноеИзменениеПениПени.Ссылка
	|			И (энргРучноеИзменениеПениПени.Ссылка В (&мДокументы))
	|
	|СГРУППИРОВАТЬ ПО
	|	энргРучноеИзменениеПени.Дата,
	|	энргРучноеИзменениеПени.Организация,
	|	энргРучноеИзменениеПени.Район,
	|	энргРучноеИзменениеПени.Абонент,
	|	энргРучноеИзменениеПениПени.Услуга,
	|	энргРучноеИзменениеПениПени.Поставщик,
	|	энргРучноеИзменениеПени.ПериодНачисления,
	|	энргРучноеИзменениеПениПени.ПериодНачисления,
	|	энргРучноеИзменениеПени.МКД";
			
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

