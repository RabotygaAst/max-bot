		МенеджерРегистра.ЗарегистрироватьСтатусНеВыполнено(ПериодВыполнения, ОписаниеОжидаемыхДанных);
	Исключение
		ИнформацияОбОшибке		= ИнформацияОбОшибке();
		Результат 				= "Событие не выполнено по причине: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		
		Комментарий				= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		НеобязательныеПараметры = энргОбщегоНазначения.НеобязательныеПараметрыРегистацииОшибки();
		НеобязательныеПараметры.ВыводитьСообщениеПользователю = Ложь;		
		энргОбщегоНазначения.ЗарегистрироватьОшибку("Выполнение события", УровеньЖурналаРегистрации.Ошибка, Комментарий, НеобязательныеПараметры); 		
