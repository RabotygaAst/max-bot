#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	ФормаКакОбъектМетаданых = Обработки.энргСобытиеМенеджерФорм.ПолучитьФормыДляОтображенияКакОбъектМетаданных();
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка 	= Ложь;
		ВыбраннаяФорма			= ФормаКакОбъектМетаданых.ФормаДокумента;		
	ИначеЕсли ВидФормы = "ФормаСписка" Тогда 		
		СтандартнаяОбработка 	= Ложь;
		ВыбраннаяФорма 			= ФормаКакОбъектМетаданых.ФормаСписка;		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область РаботаСПечатнымиФормами

#Область ПечатьПФ_MXL_Претензия_Долг_Пеня

Процедура НапечататьПретензиюДолгИПеня(ДокументСобытие, ТабДок) Экспорт 
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.энргСобытие.ПФ_MXL_ПретензияДолгИПеня");
	Результат	= ДанныеПретензияДолгПеня(ДокументСобытие);	
	ЗаполнитьДанныеПретензияДолгПеня(Результат, ТабДок, Макет);	
КонецПроцедуры

Процедура НапечататьПретензиюДолг(ДокументСобытие, ТабДок) Экспорт 
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.энргСобытие.ПФ_MXL_Претензия_Долг");
	Результат	= ДанныеПретензияДолгПеня(ДокументСобытие); 	
	ЗаполнитьДанныеПретензияДолг(Результат, ТабДок, Макет);	
КонецПроцедуры

Процедура НапечататьПретензиюПени(ДокументСобытие, ТабДок) Экспорт 
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.энргСобытие.ПФ_MXL_Претензия_Пени");
	Результат	= ДанныеПретензияДолгПеня(ДокументСобытие); 	
	ЗаполнитьДанныеПретензияПени(Результат, ТабДок, Макет);	
КонецПроцедуры

Процедура СформироватьСлужебнуюЗаписку(ДокументСобытие, ТабДок) Экспорт 
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.энргСобытие.ПФ_MXL_ПИР_СлужебнаяЗаписка");
	Результат	= ДанныеПретензияДолгПеня(ДокументСобытие); 	
	ЗаполнитьДанныеСлужебнаяЗаписка(Результат, ТабДок, Макет);	
КонецПроцедуры

Процедура СформироватьИсковоеЗаявление(ДокументСобытие, ТабДок) Экспорт 
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.энргСобытие.ПФ_MXL_ИсковоеЗаявлениеВСуд");
	Результат	= ДанныеПретензияДолгПеня(ДокументСобытие); 	
	ЗаполнитьДанныеИсковогоЗаявления(Результат, ТабДок, Макет);	
КонецПроцедуры

Процедура СформироватьУведомлениеОРП(ДокументСобытие, ТабДок) Экспорт 
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.энргСобытие.ПФ_MXL_УведомлениеОРП");
	Результат	= ДанныеУведомленияОРП(ДокументСобытие); 	
	ЗаполнитьДанныеУведомленияОРП(Результат, ТабДок, Макет);	
КонецПроцедуры

Функция ДанныеПретензияДолгПеня(ДокументСобытие)	
	Схема = Новый СхемаЗапроса;  	
	
	ДанныеДокументаСобытия(Схема);
	ДанныеПоОрганизации(Схема);
	ДанныеРайонногоОтделения(Схема);
	ДанныеАбонента(Схема);	
	ДанныеБанка(Схема);
	ДанныеКонтрагента(Схема);
	ДанныеПодписанта(Схема);
	ДанныеОтветственного(Схема);
	
	
	Пакет = Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеСобытия.Район КАК РайонноеОтделение,
	|	ДанныеСобытия.Абонент КАК Абонент,
	|	ДанныеРайона.ДиректорРО КАК ДиректорРО,
	|	ДанныеАбонентов.АдресОбъектаЛС КАК ЮрАдресПотребителя1,
	|	ДанныеБанка.Район КАК Район,
	|	ДанныеБанка.Организация КАК Организация,
	|	ДанныеБанка.Банк КАК НаименованиеБанка,
	|	ДанныеБанка.НомерСчета КАК РасчетныйСчет,
	|	ДанныеБанка.КоррСчет КАК КорСчет,
	|	ДанныеБанка.Код КАК БИК,
	|	ДанныеСобытия.СобытиеСсылка КАК СобытиеСсылка,
	|	энргЗадачаПИД.Дата КАК ДатаРегистрации,
	|	энргЗадачаПИД.ПериодЗадолженностиКонец КАК ЗадолженностьЗаПериодПо,
	|	энргЗадачаПИД.ПериодЗадолженностиНачало КАК ЗадолженностьЗаПериодС,
	|	энргЗадачаПИД.СуммаЗадолженности КАК СуммаЗадолженности,
	|	энргЗадачаПИД.СуммаПени КАК Пеня,
	|	ДанныеСобытия.Основание КАК Основание,
	|	энргЗадачаПИД.Договор.Дата КАК ДатаДоговора,
	|	энргЗадачаПИД.Договор.Номер КАК НомерДоговора,
	|	ДанныеСобытия.Организация КАК Организация1,
	|	энргЗадачаПИД.Абонент.Ссылка КАК АбонентСсылка,
	|	энргЗадачаПИД.Договор.Контрагент КАК Контрагент,
	|	энргЗадачаПИД.Договор КАК Договор,
	|	ДанныеКонтрагента.ЮрАдрес КАК ЮрАдресПотребителя,
	|	ДанныеПодписанта.Сотрудник КАК Подписант,
	|	ДанныеОтветственного.НомерТелефонаОтветственного КАК НомерТелефонаОтветственного,
	|	ДанныеСобытия.Ответственный КАК Ответственный,
	|	ДанныеСобытия.НаименованиеСуда КАК НаименованиеСуда,
	|	ДанныеПоОрганизации.ЮридическийАдресОрганизации КАК ЮридическийАдресОрганизации,
	|	ДанныеСобытия.ДатаАктаСверки КАК ДатаАктаСверки
	|ИЗ
	|	ДанныеСобытия КАК ДанныеСобытия
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеРайона КАК ДанныеРайона
	|		ПО ДанныеСобытия.Район = ДанныеРайона.Район
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеАбонентов КАК ДанныеАбонентов
	|		ПО ДанныеСобытия.КлючПомещения = ДанныеАбонентов.КлючПомещения
	|		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД КАК энргЗадачаПИД
	|			ЛЕВОЕ СОЕДИНЕНИЕ ДанныеКонтрагента КАК ДанныеКонтрагента
	|			ПО энргЗадачаПИД.Ссылка = ДанныеКонтрагента.СсылкаПид
	|		ПО ДанныеСобытия.Основание = энргЗадачаПИД.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеБанка КАК ДанныеБанка
	|		ПО ДанныеСобытия.Организация = ДанныеБанка.Организация
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеПодписанта КАК ДанныеПодписанта
	|		ПО ДанныеСобытия.Район = ДанныеПодписанта.Район
	|			И ДанныеСобытия.Организация = ДанныеПодписанта.Организация
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеОтветственного КАК ДанныеОтветственного
	|		ПО ДанныеСобытия.Ответственный = ДанныеОтветственного.Ответственный
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеПоОрганизации КАК ДанныеПоОрганизации
	|		ПО ДанныеСобытия.Организация = ДанныеПоОрганизации.Организация
	|
	|УПОРЯДОЧИТЬ ПО
	|	Абонент");
	
	
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Период"				, ДокументСобытие.Дата); 
	ПараметрыЗапроса.Вставить("Организация"			, ДокументСобытие.Организация);
	ПараметрыЗапроса.Вставить("Район"				, ДокументСобытие.Район); 	
	ПараметрыЗапроса.Вставить("СписокДокументов"	, ДокументСобытие); 	
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);	
КонецФункции

Функция ДанныеУведомленияОРП(ДокументСобытие)	
	Схема = Новый СхемаЗапроса;  	
	
	ДанныеДокументаСобытия(Схема);
	//ДанныеПоОрганизации(Схема);
	ДанныеРайонногоОтделения(Схема);
	//ДанныеБанка(Схема);
	ДанныеКонтрагента(Схема);
	//ДанныеПодписанта(Схема);
	//ДанныеОтветственного(Схема);
	ДанныеОбъектовРасчета(Схема);
	
	
	Пакет = Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеРайона.ДиректорРО КАК ДиректорРО,
	|	ДанныеРайона.Район КАК Район,
	|	ДанныеРайона.ФактАдресРайона КАК ФактАдресРайона,
	|	ДанныеРайона.ТелефонРайона КАК ТелефонРайона,
	|	ДанныеРайона.EmailРайона КАК EmailРайона,
	|	ДанныеСобытия.Основание КАК Основание,
	|	ДанныеСобытия.ДатаДоговора КАК ДатаДоговора,
	|	ДанныеСобытия.ДатаСобытия КАК ДатаСобытия,
	|	ДанныеСобытия.СпособВручения КАК СпособВручения,
	|	ДанныеСобытия.ДатаВрученияУведомления КАК ДатаВрученияУведомления,
	|	ДанныеСобытия.НомерДоговора КАК НомерДоговора,
	|	ДанныеКонтрагента.Контрагент КАК Контрагент,
	|	ДанныеСобытия.Исполнитель КАК Исполнитель,
	|	ДанныеСобытия.Договор КАК Договор
	|ИЗ
	|	ДанныеСобытия КАК ДанныеСобытия
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеРайона КАК ДанныеРайона
	|		ПО ДанныеСобытия.Район = ДанныеРайона.Район
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеКонтрагента КАК ДанныеКонтрагента
	|		ПО ДанныеСобытия.Контрагент = ДанныеКонтрагента.Контрагент");
	
	
	Пакет = Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеОбъектовРасчета.АдресОбъекта КАК АдресОбъекта,
	|	ДанныеОбъектовРасчета.ОбъектРасчета КАК ОбъектРасчета
	|ИЗ
	|	ДанныеОбъектовРасчета КАК ДанныеОбъектовРасчета");
	
	ПараметрыЗапроса 	= Новый Структура;
	ПараметрыЗапроса.Вставить("Период"				, ДокументСобытие.Дата); 
	ПараметрыЗапроса.Вставить("Организация"			, ДокументСобытие.Организация);
	ПараметрыЗапроса.Вставить("Район"				, ДокументСобытие.Район); 	
	ПараметрыЗапроса.Вставить("СписокДокументов"	, ДокументСобытие); 	
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьПакет(Схема, ПараметрыЗапроса);	
КонецФункции

Процедура ЗаполнитьДанныеПретензияДолгПеня(Результат, ТабДок, Макет) 
	ОбластьШапка 	= Макет.ПолучитьОбласть("Шапка");	
	Выборка 		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьПараметрыШапкиДолгПеня(ТабДок, ОбластьШапка, Выборка);
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьДанныеУведомленияОРП(Результат, ТабДок, Макет) 
	ОбластьШапка 	= Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал 	= Макет.ПолучитьОбласть("Подвал");
	
	ВыборкаШапка 			= Результат[4].Выбрать();
	ВыборкаОбъектыРасчета 	= Результат[5].Выбрать();
	              
	Пока ВыборкаШапка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры, ВыборкаШапка);
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры, ВыборкаШапка);
		ОбластьШапка.Параметры.ДатаСобытия 				= Формат(ВыборкаШапка.ДатаСобытия,"ДФ=dd.MM.yyyy");
		ОбластьШапка.Параметры.ДатаВрученияУведомления 	= Формат(ВыборкаШапка.ДатаВрученияУведомления,"ДФ=dd.MM.yyyy");
		ОбластьШапка.Параметры.ДатаДоговора 			= Формат(ВыборкаШапка.ДатаДоговора,"ДФ=dd.MM.yyyy");
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьШапка);
	
	Номер = 1;
	Пока ВыборкаОбъектыРасчета.Следующий() Цикл
		ОбластьОбъектыРасчета 	= Макет.ПолучитьОбласть("ОбъектыРасчета");
		ЗаполнитьЗначенияСвойств(ОбластьОбъектыРасчета.Параметры, ВыборкаОбъектыРасчета);
		ОбластьОбъектыРасчета.Параметры.Номер 	= Номер;
		ТабДок.Вывести(ОбластьОбъектыРасчета);
		Номер = Номер + 1;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьПодвал);
КонецПроцедуры

Процедура ЗаполнитьДанныеПретензияДолг(Результат, ТабДок, Макет) 
	ОбластьШапка 	= Макет.ПолучитьОбласть("Шапка");	
	Выборка 		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьПараметрыШапкиДолг(ТабДок, ОбластьШапка, Выборка);
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьДанныеПретензияПени(Результат, ТабДок, Макет) 
	ОбластьШапка 	= Макет.ПолучитьОбласть("Шапка");	
	Выборка 		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
