Функция СоздатьИВыполнитьСобытиеНаОсновеЗадачи(Задача, ТипСобытия, ТекстШаблона = "", ТексТемы = "", ИмяМакета = "", МассивФайлов = Неопределено) Экспорт
	
	ДокОбъект = Документы.энргСобытие.СоздатьДокумент();
	ДокОбъект.Дата				 = ТекущаяДатаСеанса();
	ДокОбъект.ТипСобытия		 = ТипСобытия;
	ДокОбъект.ТекстШаблона		 = ТекстШаблона;
	ДокОбъект.ТемаСобытия		 = ТексТемы;
	ДокОбъект.МакетПечатнойФормы = ИмяМакета;
	ДокОбъект.Организация		 = Задача.Организация;
	
	СтрокаТЧ = ДокОбъект.Абоненты.Добавить();
	СтрокаТЧ.Абонент	= Задача.Абонент;
	СтрокаТЧ.Основание	= Задача;
	Попытка
		ДокОбъект.Записать();
		
		Если ЗначениеЗаполнено(МассивФайлов) Тогда
			Для каждого ТекФайл Из МассивФайлов Цикл
				ДатаМодификацииФайла		= ТекущаяДатаСеанса();
				ПараметрыДобавляемогоФайла	= Новый Структура;
				ПараметрыДобавляемогоФайла.Вставить("ВладелецФайлов",	 			ДокОбъект.Ссылка);
				ПараметрыДобавляемогоФайла.Вставить("Автор",						Строка(ПараметрыСеанса.ТекущийПользователь));
				ПараметрыДобавляемогоФайла.Вставить("ИмяБезРасширения",				ТекФайл.Имя);
				ПараметрыДобавляемогоФайла.Вставить("РасширениеБезТочки",			ТекФайл.Расширение);
				ПараметрыДобавляемогоФайла.Вставить("ВремяИзменения",				МестноеВремя(ДатаМодификацииФайла, ЧасовойПоясСеанса()));
				ПараметрыДобавляемогоФайла.Вставить("ВремяИзмененияУниверсальное",	ДатаМодификацииФайла);
				РаботаСФайлами.ДобавитьФайл(ПараметрыДобавляемогоФайла, ТекФайл.Адрес); 
			КонецЦикла;
		КонецЕсли;
		
		ДокОбъект.ВыполнитьСобытия();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
	Если ДокОбъект.Абоненты[0].Успех Тогда
		Возврат Истина;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось отправить сообщение абоненту " + Задача.Абонент);
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция ЭтоСобытиеСОтправкой(ТипСобытия) Экспорт
	
	СобытияСОтправкой = Новый Массив;
	СобытияСОтправкой.Добавить(Справочники.энргСпособСвязи.АвтоЗвонок);
	СобытияСОтправкой.Добавить(Справочники.энргСпособСвязи.ОтправкаПисьмаНаЭлектроннуюПочту);
	СобытияСОтправкой.Добавить(Справочники.энргСпособСвязи.ОтправкаСМС);
	
	Возврат СобытияСОтправкой.Найти(ТипСобытия) <> Неопределено;
КонецФункции

Функция ПолучитьПодэтапыЗадачи(Основание) Экспорт 
	
	Перем Запрос;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргЗадачаПИДПодэтапы.Подэтап КАК Подэтап,
	|	энргЗадачаПИДПодэтапы.IDЭтапа КАК IDЭтапа,
	|	энргЗадачаПИДПодэтапы.Выполнен КАК Выполнен,
	|	энргЗадачаПИДПодэтапы.Текущий КАК Текущий,
	|	энргЗадачаПИДПодэтапы.Результат КАК Результат
	|ИЗ
	|	Задача.энргЗадачаПИД.Подэтапы КАК энргЗадачаПИДПодэтапы
	|ГДЕ
	|	энргЗадачаПИДПодэтапы.Ссылка = &Основание";
	
	Запрос.УстановитьПараметр("Основание", Основание);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

