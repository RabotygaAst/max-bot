	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	|				ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.Ссылка
	|			ПО энргСобытиеАбоненты.Абонент = энргАбоненты.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|			ПО энргСобытиеАбоненты.Абонент = энргДоговорыКонтрагентов.Ссылка
	|		ПО энргСобытие.Ссылка = энргСобытиеАбоненты.Ссылка
	|			И (энргСобытие.Ссылка В (&СписокДокументов))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргСобытие.Параметры КАК энргСобытиеПараметры
	|		ПО энргСобытие.Ссылка = энргСобытиеПараметры.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	энргАбоненты.ЛицевойСчет,
	|	энргСобытиеАбоненты.Абонент,
	|	энргКлючиПомещений.Ссылка,
	|	энргСобытие.Ссылка,
	|	энргСобытие.Организация,
	|	энргСобытие.Район,
	|	энргКлючиПомещений.Строение,
	|	ВЫБОР
	|		КОГДА энргКлючиПомещений.ЧастныйСектор
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.энргСтроения.ПустаяСсылка)
	|		ИНАЧЕ энргКлючиПомещений.Строение
	|	КОНЕЦ,
	|	энргКлючиПомещений.Помещение,
	|	энргКлючиПомещений.ЧастныйСектор,
	|	энргСобытиеАбоненты.Основание,
	|	энргСобытие.Ответственный,
	|	энргСобытие.Номер,
	|	энргСобытие.Дата,
	|	энргДоговорыКонтрагентов.Ссылка,
	|	энргДоговорыКонтрагентов.Дата,
	|	энргДоговорыКонтрагентов.Номер,
	|	энргДоговорыКонтрагентов.Контрагент";
	
	Возврат Текст;
КонецФункции  

