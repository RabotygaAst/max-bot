КонецПроцедуры

Процедура ЗаполнитьДанныеСлужебнаяЗаписка(Результат, ТабДок, Макет) 
	ОбластьШапка 	= Макет.ПолучитьОбласть("Шапка");	
	Выборка 		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьПараметрыШапкиСлужебнаяЗаписка(ТабДок, ОбластьШапка, Выборка);
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьДанныеИсковогоЗаявления(Результат, ТабДок, Макет) 
	ОбластьШапка 	= Макет.ПолучитьОбласть("Шапка");	
	Выборка 		= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьПараметрыШапкиИсковогоЗаявления(ТабДок, ОбластьШапка, Выборка);
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьПараметрыШапкиДолгПеня(ТабДок, ОбластьШапка, Выборка)
	ЗаполнитьЗначенияСвойств (ОбластьШапка.Параметры, Выборка);
	Если ЗначениеЗаполнено(Выборка.ДатаРегистрации) Тогда
		ДатаРегистрации = Выборка.ДатаРегистрации + 86400*30;
		ОбластьШапка.Параметры.ДатаРегистрации 		= Формат(ДатаРегистрации,"ДФ=dd.MM.yyyy" );
		Если ЗначениеЗаполнено(Выборка.Договор) Тогда
			РезультатЗадолженность = бестВзаиморасчетыЮрЛицаСервер.ПолучитьФактическуюЗадолженностьНаДату(Выборка.Организация, Выборка.Район, Выборка.ДатаРегистрации, Выборка.Договор);
			ВыборкаЗадолженность = РезультатЗадолженность.Выбрать();
			Пока ВыборкаЗадолженность.Следующий() Цикл
				СуммаЗадолженности = ВыборкаЗадолженность.Сумма;
			КонецЦикла;
			РезультатПени = бестВзаиморасчетыЮрЛицаСервер.ПолучитьПенюНаДату(Выборка.Организация, Выборка.Район, Выборка.ДатаРегистрации, Выборка.Договор); 	
			
			ВыборкаПени = РезультатПени.Выбрать();
			Пока ВыборкаПени.Следующий() Цикл
				СуммаПени = ВыборкаПени.Сумма;
			КонецЦикла; 	
			ОбластьШапка.Параметры.СуммаЗадолженности 		= СуммаЗадолженности;
			ОбластьШапка.Параметры.Пеня 		= СуммаПени;
			
		КонецЕсли;
	КонецЕсли;
	
	ОбластьШапка.Параметры.ДатаДоговора = Формат(Выборка.ДатаДоговора,"ДФ=dd.MM.yyyy" );
	ОбластьШапка.Параметры.ЗадолженностьЗаПериодС 			= Формат(Выборка.ЗадолженностьЗаПериодС,"ДФ=dd.MM.yyyy" );
