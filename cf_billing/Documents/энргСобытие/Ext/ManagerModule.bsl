Функция ПолучитьПараметрыПечатиЗаявлениеОВынесенииСудебногоПриказа(Задача) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргЗадачаПИД.Организация КАК Организация,
	|	энргЗадачаПИД.Район КАК Район,
	|	энргЗадачаПИД.Абонент КАК Абонент,
	|	энргЗадачаПИД.ПериодЗадолженностиНачало КАК ПериодЗадолженностиНачало,
	|	энргЗадачаПИД.ПериодЗадолженностиКонец КАК ПериодЗадолженностиКонец,
	|	энргЗадачаПИД.СуммаЗадолженности КАК ОсновнойДолг,
	|	энргЗадачаПИД.СуммаПени КАК Пени,
	|	энргЗадачаПИД.ДатаРасчетаПени КАК ДатаРасчетаПени,
	|	энргЗадачаПИД.СуммаГоспошлина КАК Госпошлина,
	|	энргЗадачаПИД.СуммаЗадолженности + энргЗадачаПИД.СуммаПени КАК СуммаИска,
	|	энргЗадачаПИД.Ссылка КАК Ссылка,
	|	энргЗадачаПИД.ВидСудопроизводства КАК ВидСудопроизводства,
	|	энргФилиалыАбонентовСрезПоследних.Филиал.Наименование КАК АбонентскийОтдел
	|ПОМЕСТИТЬ ВТ_Задача
	|ИЗ
	|	Задача.энргЗадачаПИД КАК энргЗадачаПИД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргФилиалыАбонентов.СрезПоследних(, ) КАК энргФилиалыАбонентовСрезПоследних
	|		ПО энргЗадачаПИД.Абонент = энргФилиалыАбонентовСрезПоследних.Абонент
	|ГДЕ
	|	энргЗадачаПИД.Ссылка = &Задача
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Задача.Ссылка КАК Ссылка,
	|	Организации.НаименованиеПолное КАК ОрганизацияПолное,
	|	Организации.НаименованиеСокращённое КАК ОрганизацияСокращенное,
	|	Организации.ИНН КАК ИНН_Организации,
	|	Организации.КПП КАК КПП_Организации,
	|	Организации.РегистрационныйНомер КАК ОГРН_Организации,
	|	Организации.КодПоОКПО КАК ОКПО_Организации
	|ПОМЕСТИТЬ ВТ_Организация
	|ИЗ
	|	ВТ_Задача КАК ВТ_Задача
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО ВТ_Задача.Организация = Организации.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Задача.Ссылка КАК Ссылка,
	|	энргЗадачаПИДСудебныеИнстанции.СудебыйУчасток КАК СудебыйУчасток,
	|	отэкСудыКонтактнаяИнформация.Представление КАК АдресСуда
	|ПОМЕСТИТЬ ВТ_СудебныйУчасток
	|ИЗ
	|	ВТ_Задача КАК ВТ_Задача
	|		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.СудебныеИнстанции КАК энргЗадачаПИДСудебныеИнстанции
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСуды.КонтактнаяИнформация КАК отэкСудыКонтактнаяИнформация
	|			ПО энргЗадачаПИДСудебныеИнстанции.Суд = отэкСудыКонтактнаяИнформация.Ссылка
	|				И (отэкСудыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресДома))
	|		ПО ВТ_Задача.Ссылка = энргЗадачаПИДСудебныеИнстанции.Ссылка
	|ГДЕ
	|	энргЗадачаПИДСудебныеИнстанции.Текущая
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Задача.Ссылка КАК Ссылка,
	|	энргКонтрагенты.бестФамилия КАК ФамилияДолжника,
	|	энргКонтрагенты.бестИмя КАК ИмяДолжника,
	|	энргКонтрагенты.бестОтчество КАК ОтчествоДолжника,
	|	энргКонтрагенты.бестДатаРождения КАК ДатаРожденияДолжника,
	|	энргКонтрагенты.МестоРождения КАК МестоРождения,
	//|	бестДокументыФизическихЛицСрезПоследних.Представление КАК Паспорт,
	|	энргКонтрагентыКонтактнаяИнформацияАдресПроживания.Представление КАК МестоРегистрацииДолжника,
	|	энргКонтрагентыКонтактнаяИнформацияАдресРегистрации.Представление КАК АдресДолжник,
	|	энргАбонентыКонтактнаяИнформация.Представление КАК АдресПомещения,
	|	энргАбонентыКонтактнаяИнформация.Город КАК Город,
	|	энргАбоненты.ВидОбъекта.Наименование КАК ВидОбъектаНаименование,
	|	энргФилиалыАбонентовСрезПоследних.Филиал КАК Филиал
	|ПОМЕСТИТЬ ВТ_Должник
	|ИЗ
	|	ВТ_Задача КАК ВТ_Задача
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
	//|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестДокументыФизическихЛиц.СрезПоследних КАК бестДокументыФизическихЛицСрезПоследних
	//|				ПО энргКонтрагенты.Ссылка = бестДокументыФизическихЛицСрезПоследних.Контрагент
	//|					И (бестДокументыФизическихЛицСрезПоследних.ВидДокумента = ЗНАЧЕНИЕ(справочник.ВидыДокументовФизическихЛиц.ПаспортРФ))
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформацияАдресРегистрации
	|				ПО энргКонтрагенты.Ссылка = энргКонтрагентыКонтактнаяИнформацияАдресРегистрации.Ссылка
	|					И (энргКонтрагентыКонтактнаяИнформацияАдресРегистрации.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента))
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформацияАдресПроживания
	|				ПО энргКонтрагенты.Ссылка = энргКонтрагентыКонтактнаяИнформацияАдресПроживания.Ссылка
	|					И (энргКонтрагентыКонтактнаяИнформацияАдресПроживания.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|			ПО энргАбоненты.ФизЛицо = энргКонтрагенты.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
	|			ПО энргАбоненты.Ссылка = энргАбонентыКонтактнаяИнформация.Ссылка
	|				И (энргАбонентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресОбъекта))
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргФилиалыАбонентов.СрезПоследних КАК энргФилиалыАбонентовСрезПоследних
	|			ПО энргАбоненты.Ссылка = энргФилиалыАбонентовСрезПоследних.Абонент.Ссылка
	|		ПО ВТ_Задача.Абонент = энргАбоненты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗадачаПИДЗадолженность.ПериодНачисления КАК ПериодНачисления,
	|	энргЗадачаПИДЗадолженность.Услуга КАК Услуга,
	|	ВТ_Задача.Организация КАК Организация,
	|	ВТ_Задача.Район КАК Район,
	|	ВТ_Задача.Абонент КАК Абонент
	|ПОМЕСТИТЬ ВТ_ПериодыДолга
	|ИЗ
	|	ВТ_Задача КАК ВТ_Задача
	|		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.Задолженность КАК энргЗадачаПИДЗадолженность
	|		ПО ВТ_Задача.Ссылка = энргЗадачаПИДЗадолженность.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргОбъемНачисленийОбороты.ПериодНачисления КАК ПериодНачисления,
	|	СУММА(энргОбъемНачисленийОбороты.СуммаОборот) КАК Сумма
	|ПОМЕСТИТЬ ВТ_НачисленияПоМесяцам
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений.Обороты(
	|			,
	|			,
	|			,
	|			(Организация, Район, Абонент, Услуга, ПериодНачисления) В
	|				(ВЫБРАТЬ
	|					ВТ_ПериодыДолга.Организация КАК Организация,
	|					ВТ_ПериодыДолга.Район КАК Район,
	|					ВТ_ПериодыДолга.Абонент КАК Абонент,
	|					ВТ_ПериодыДолга.Услуга КАК Услуга,
	|					ВТ_ПериодыДолга.ПериодНачисления КАК ПериодНачисления
	|				ИЗ
	|					ВТ_ПериодыДолга КАК ВТ_ПериодыДолга)) КАК энргОбъемНачисленийОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	энргОбъемНачисленийОбороты.ПериодНачисления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ВТ_НачисленияПоМесяцам.Сумма) КАК СуммаНачислений,
	|	&Задача КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ОбъемНачислений
	|ИЗ
	|	ВТ_НачисленияПоМесяцам КАК ВТ_НачисленияПоМесяцам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_НачисленияПоМесяцам.ПериодНачисления КАК ПериодНачисления,
	|	ВТ_НачисленияПоМесяцам.Сумма КАК Сумма
	|ИЗ
	|	ВТ_НачисленияПоМесяцам КАК ВТ_НачисленияПоМесяцам
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПериодНачисления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Задача.Организация КАК Организация,
	|	ВТ_Задача.Район КАК Район,
	|	ВТ_Задача.Абонент КАК Абонент,
	|	ВТ_Задача.ПериодЗадолженностиНачало КАК ПериодЗадолженностиНачало,
	|	ВТ_Задача.ПериодЗадолженностиКонец КАК ПериодЗадолженностиКонец,
	|	ВТ_Задача.ОсновнойДолг КАК ОсновнойДолг,
	|	ВТ_Задача.Пени КАК Пени,
	|	ВТ_Задача.ДатаРасчетаПени КАК ДатаПени,
	|	ВТ_Задача.Госпошлина КАК Госпошлина,
	|	ВТ_Задача.СуммаИска КАК СуммаИска,
	|	ВТ_Задача.Ссылка КАК Ссылка,
	|	ВТ_Должник.ФамилияДолжника КАК ФамилияДолжника,
	|	ВТ_Должник.ИмяДолжника КАК ИмяДолжника,
	|	ВТ_Должник.ОтчествоДолжника КАК ОтчествоДолжника,
	|	ВТ_Должник.ДатаРожденияДолжника КАК ДатаРожденияДолжника,
	|	ВТ_Должник.МестоРождения КАК МестоРождения,
	//|	ВТ_Должник.Паспорт КАК Паспорт,
	|	ВТ_Должник.МестоРегистрацииДолжника КАК МестоРегистрацииДолжника,
	|	ВТ_Должник.АдресДолжник КАК АдресДолжник,
	|	ВТ_Должник.АдресПомещения КАК АдресПомещения,
	|	ВТ_ОбъемНачислений.СуммаНачислений КАК СуммаНачислений,
	|	ВТ_Организация.ОрганизацияПолное КАК ОрганизацияПолное,
	|	ВТ_Организация.ОрганизацияСокращенное КАК ОрганизацияСокращенное,
	|	ВТ_Организация.ИНН_Организации КАК ИНН_Организации,
	|	ВТ_Организация.КПП_Организации КАК КПП_Организации,
	|	ВТ_Организация.ОГРН_Организации КАК ОГРН_Организации,
	|	ВТ_Организация.ОКПО_Организации КАК ОКПО_Организации,
	|	ВТ_СудебныйУчасток.СудебыйУчасток КАК СудебыйУчасток,
	|	ВТ_СудебныйУчасток.АдресСуда КАК АдресСуда,
	|	ЕСТЬNULL(ВТ_ОбъемНачислений.СуммаНачислений, 0) - ВТ_Задача.ОсновнойДолг КАК СуммаОплат,
	|	ВТ_Должник.Город КАК Город,
	|	ВТ_Должник.ВидОбъектаНаименование КАК ТипПомещения,
	|	ВТ_Задача.ВидСудопроизводства КАК ВидСудопроизводства,
	|	ВЫБОР
	|		КОГДА энргФилиалыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресАбонентскогоОтдела)
	|			ТОГДА энргФилиалыКонтактнаяИнформация.Представление
	|	КОНЕЦ КАК АдресФилиала,
	|	ВЫБОР
	|		КОГДА энргФилиалыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонЦентраОбслуживания)
	|			ТОГДА энргФилиалыКонтактнаяИнформация.Представление
	|	КОНЕЦ КАК ТелефонФилиала,
	|	ВТ_Задача.АбонентскийОтдел КАК АбонентскийОтдел
	|ИЗ
	|	ВТ_Задача КАК ВТ_Задача
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Организация КАК ВТ_Организация
	|		ПО ВТ_Задача.Ссылка = ВТ_Организация.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СудебныйУчасток КАК ВТ_СудебныйУчасток
	|		ПО ВТ_Задача.Ссылка = ВТ_СудебныйУчасток.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОбъемНачислений КАК ВТ_ОбъемНачислений
	|		ПО ВТ_Задача.Ссылка = ВТ_ОбъемНачислений.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Должник КАК ВТ_Должник
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргФилиалы.КонтактнаяИнформация КАК энргФилиалыКонтактнаяИнформация
	|			ПО ВТ_Должник.Филиал = энргФилиалыКонтактнаяИнформация.Ссылка
	|				И (энргФилиалыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресАбонентскогоОтдела))
	|		ПО ВТ_Задача.Ссылка = ВТ_Должник.Ссылка";
	
	Запрос.УстановитьПараметр("Задача", Задача);
	
	РезультатПакета  = Запрос.ВыполнитьПакет();
	РезультатЗапроса = РезультатПакета[РезультатПакета.Количество()-1];
	
	ПараметрыПечати = Новый Структура;
	Для каждого ТекКолонка Из РезультатЗапроса.Колонки Цикл
		ПараметрыПечати.Вставить(ТекКолонка.Имя);
	КонецЦикла;
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ПараметрыПечати, Выборка);
		Если СклонениеПредставленийОбъектов.ДоступенСервисСклонения() Тогда 
			СудебныйУчасток = НРег(Выборка.СудебыйУчасток);
			ПараметрыПечати.Вставить("СудебныйУчастокР", СклонениеПредставленийОбъектов.ПросклонятьПредставление(СудебныйУчасток, 2));
		КонецЕсли;
		ФамилияИмяОтчество = ?(ЗначениеЗаполнено(Выборка.ФамилияДолжника), Выборка.ФамилияДолжника, "")
		+ ?(ЗначениеЗаполнено(Выборка.ИмяДолжника), " " + Выборка.ИмяДолжника, "") 
		+ ?(ЗначениеЗаполнено(Выборка.ОтчествоДолжника), " " + Выборка.ОтчествоДолжника, "");
		ПараметрыПечати.Вставить("ФамилияИмяОтчество", ФамилияИмяОтчество);
		ФИО = 				 ?(ЗначениеЗаполнено(Выборка.ФамилияДолжника), Выборка.ФамилияДолжника, "")
		+ ?(ЗначениеЗаполнено(Выборка.ИмяДолжника), " " + Лев(Выборка.ИмяДолжника, 1) + ".", "") 
		+ ?(ЗначениеЗаполнено(Выборка.ОтчествоДолжника), " " + Лев(Выборка.ОтчествоДолжника, 1) + ".", "");
		ПараметрыПечати.Вставить("ФИО", ФИО);
		ПараметрыПечати.Вставить("ГодРождения", ?(ЗначениеЗаполнено(Выборка.ДатаРожденияДолжника), Формат(Выборка.ДатаРожденияДолжника, "ДФ=гггг"), ""));
		НачалоДолга = ?(ЗначениеЗаполнено(Выборка.ПериодЗадолженностиНачало), Формат(Выборка.ПериодЗадолженностиНачало, "ДФ='ММММ гггг'"), "");
		ПараметрыПечати.Вставить("НачалоДолга", НачалоДолга);
		ДеньНачалоДолга = ?(ЗначениеЗаполнено(Выборка.ПериодЗадолженностиНачало), Формат(Выборка.ПериодЗадолженностиНачало, "ДФ='dd ММММ гггг'"), "");
		ПараметрыПечати.Вставить("ДеньНачалоДолга", ДеньНачалоДолга);
		ДатаПени = ?(ЗначениеЗаполнено(Выборка.ДатаПени), Формат(Выборка.ДатаПени, "ДФ='dd ММММ гггг'"), "");
		ПараметрыПечати.Вставить("ДатаПени", ДатаПени);
		
		ОкончаниеДолга = ?(ЗначениеЗаполнено(Выборка.ПериодЗадолженностиКонец), Формат(Выборка.ПериодЗадолженностиКонец, "ДФ='ММММ гггг'"), "");
		ПараметрыПечати.Вставить("ОкончаниеДолга", ОкончаниеДолга);
	КонецЦикла;
	
	РезультатЗапроса = РезультатПакета[РезультатПакета.Количество()-2];
	ТаблицаНачислений = Новый Массив;
	Сч = 1;
	МесяцаЗадолженности = "";
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТаблицы = Новый Структура("НомерСтроки, МесяцНачислений, СуммаНачисленийЗаМесяц");
		
		СтрокаТаблицы.НомерСтроки = Сч;
		МесяцНачисления = НРег(Формат(Выборка.ПериодНачисления, "ДФ='ММММ гггг'"));
		МесяцаЗадолженности = ?(ЗначениеЗаполнено(МесяцаЗадолженности), МесяцаЗадолженности + ", ", "") + МесяцНачисления;
		СтрокаТаблицы.МесяцНачислений = МесяцНачисления;
		СтрокаТаблицы.СуммаНачисленийЗаМесяц = Выборка.Сумма;
		СтрокаТаблицы.НомерСтроки = Сч;
		
		ТаблицаНачислений.Добавить(СтрокаТаблицы);
		Сч = Сч + 1;
	КонецЦикла;
	
	ПараметрыПечати.Вставить("МесяцаДолга", МесяцаЗадолженности);
	ПараметрыПечати.Вставить("ТаблицаНачислений", ТаблицаНачислений);
	
	Если ЗначениеЗаполнено(ПараметрыПечати.ТипПомещения) Тогда
		ТипПомещения = ПолучитьСклоненияСтроки(НРег(ПараметрыПечати.ТипПомещения), 
		,"ПД=Родительный");
		ПараметрыПечати.ТипПомещения = ТипПомещения[0];
	Иначе	
		ПараметрыПечати.ТипПомещения = "      ";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыПечати.СуммаИска) Тогда
		ПараметрыПечати.Вставить("СуммаИскаПрописью",ЧислоПрописью(ПараметрыПечати.СуммаИска, "Л=ru_RU;ДП=Истина", "рубль,рубля,рублей,м,копейка,копейки,копеек,ж,2"));
	Иначе	
		ПараметрыПечати.СуммаИскаПрописью = "";
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ПараметрыПечати.Пени) Тогда
		ПараметрыПечати.Вставить("ПениПрописью",ЧислоПрописью(ПараметрыПечати.Пени, "Л=ru_RU;ДП=Истина", "рубль,рубля,рублей,м,копейка,копейки,копеек,ж,2"));
	Иначе	
		ПараметрыПечати.ПениПрописью = "";
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ПараметрыПечати.Госпошлина) Тогда
		ПараметрыПечати.Вставить("ГоспошлинаПрописью",ЧислоПрописью(ПараметрыПечати.Госпошлина, "Л=ru_RU;ДП=Истина", "рубль,рубля,рублей,м,копейка,копейки,копеек,ж,2"));
	Иначе	
		ПараметрыПечати.ГоспошлинаПрописью = "";
	КонецЕсли;	
	
	ЗапросОплат = Новый Запрос;
	ЗапросОплат.Текст = "ВЫБРАТЬ
	|	СУММА(энргВзаиморасчетыПоМесяцамОбороты.СуммаРасход) КАК СуммаОплаты,
	|	энргВзаиморасчетыПоМесяцамОбороты.Период КАК ДатаОплаты
	|ИЗ
	|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Обороты(
	|			,
	|			,
	|			Регистратор,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ПериодНачисления МЕЖДУ &НачалоПериода И &КонецПериода)
	|				И Абонент = &Абонент) КАК энргВзаиморасчетыПоМесяцамОбороты
	|ГДЕ
	|	(энргВзаиморасчетыПоМесяцамОбороты.Регистратор ССЫЛКА Документ.энргПлатежноеПоручениеВходящие
	|			ИЛИ энргВзаиморасчетыПоМесяцамОбороты.Регистратор ССЫЛКА Документ.энргПриходныйКассовыйОрдер)
	|
	|СГРУППИРОВАТЬ ПО
	|	энргВзаиморасчетыПоМесяцамОбороты.Период";
	
	ЗапросОплат.УстановитьПараметр("Организация",ПараметрыПечати.Организация);
	ЗапросОплат.УстановитьПараметр("Район",ПараметрыПечати.Район);
	ЗапросОплат.УстановитьПараметр("Абонент",ПараметрыПечати.Абонент);
	ЗапросОплат.УстановитьПараметр("НачалоПериода",ПараметрыПечати.ПериодЗадолженностиНачало);
	ЗапросОплат.УстановитьПараметр("КонецПериода",ПараметрыПечати.ПериодЗадолженностиКонец);
	
	Выборка = ЗапросОплат.Выполнить().Выбрать();
	ТаблицаОплат = Новый Массив;
	СтрокаОплат = "";
	
	Пока Выборка.Следующий() Цикл
		
		СтрокаОплат = СтрокаОплат + НРег(Формат(Выборка.ДатаОплаты, "ДФ='дд ММ гггг'"))+ " г. - " + Формат(Выборка.СуммаОплаты, "ЧЦ=10; ЧДЦ=2;") + " руб.,";
		
	КонецЦикла;
	
	ПараметрыПечати.Вставить("СтрокаОплат", Лев(СтрокаОплат,СтрДлина(СтрокаОплат)-2));
	
	ФИОД = ПолучитьСклоненияСтроки(ПараметрыПечати.ФамилияИмяОтчество,,"ПД=Дательный");
	ПараметрыПечати.Вставить("ФамилияИмяОтчествоД",ФИОД[0]);
	
	ФИОТ = ПолучитьСклоненияСтроки(ПараметрыПечати.ФамилияИмяОтчество,,"ПД=Творительный");
	ПараметрыПечати.Вставить("ФамилияИмяОтчествоТ",ФИОТ[0]);
	ФИОР = ПолучитьСклоненияСтроки(ПараметрыПечати.ФамилияИмяОтчество,,"ПД=Родительный");
	ПараметрыПечати.Вставить("ФамилияИмяОтчествоР",ФИОР[0]);
	ПараметрыПечати.Вставить("НачалоДолгаВ",Нрег(ПолучитьСклоненияСтроки(ПараметрыПечати.НачалоДолга,,"ПД=Родительный")[0]));
	ПараметрыПечати.Вставить("ОкончаниеДолгаНрег",Нрег(ПараметрыПечати.ОкончаниеДолга));
	ПараметрыПечати.Вставить("АдресФилиал",ПараметрыПечати.АдресФилиала);	
	ПараметрыПечати.Вставить("ТелефонФилиал",ПараметрыПечати.ТелефонФилиала);	
	
	Возврат ПараметрыПечати;
	
КонецФункции

Функция ПолучитьПараметрыПечатиЗаявлениеИсполнительногоДокумента(Задача) Экспорт
	
	ПараметрыПечати = Новый Структура;
	
	ПараметрыПечати.Вставить("НомерСудебногоДела",Задача.НомерСудебногоДела);
	ПараметрыПечати.Вставить("ДатаСудебногоДела",Формат(Задача.Дата, "ДФ='дд ММ гггг'"));
	ПараметрыПечати.Вставить("НомерИсполнительногоЛиста",Задача.НомерИсполнительногоЛиста);
	ПараметрыПечати.Вставить("ДатаИсполнительногоЛиста",Формат(Задача.ДатаИсполительногоЛиста, "ДФ='дд ММ гггг'"));
	Если Задача.ИсполнительныеДокументы.Количество() <> 0 Тогда
		ПараметрыПечати.Вставить("ВидДокумента",Нрег(Строка(Задача.ИсполнительныеДокументы[0].ИсполнительныйДокумент)));
	Иначе	
		ПараметрыПечати.Вставить("ВидДокумента","исполнительный лист/судебный приказ");
	КонецЕсли;	
	
	
	Возврат ПараметрыПечати
	
КонецФункции	

