// Возвращает соответствие изменяемые параметры расчета.
// 
// Возвращаемое значение:
//   Соответствие.
//
Функция ИзменяемыеПараметрыРасчета() Экспорт 
		
	ИзменяемыеПараметрыРасчета 	= Новый Соответствие;                  	
	ИзменяемыеПараметры 		= Новый Массив;	
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета","ДоляПотребленияЗнаменатель,ДоляПотребленияЧислитель,СпособРаспределенияОбъемаПомещения,КоэффициентРаспределенияОстатка,ФиксированныйОбъемПотребления"));	
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.ПустаяСсылка(), ИзменяемыеПараметры);
	Возврат ИзменяемыеПараметрыРасчета;

КонецФункции

// Получает данные для проведения по стабильным периодам.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ВыбираемыеТаблицы	-	Массив.
//
Процедура ПолучитьДанныеДляПроведенияПоСтабильнымПериодам(Схема,ВыбираемыеТаблицы) Экспорт	
	перем Пакет;
	
	ИмяТаблицы 											= "ДанныеДокументовСоглашениеОПотребленииВПомещении";
	ВыбираемыеТаблицы.Добавить(ИмяТаблицы);
	
	врСхема 											= Новый СхемаЗапроса;
	врСхема.УстановитьТекстЗапроса(ТекстДляПроведенияПоСтабильнымПериодам());
	
	Пакет 												= врСхема.ПакетЗапросов[врСхема.ПакетЗапросов.Количество() - 1];
	Пакет.ТаблицаДляПомещения 							= ИмяТаблицы;
	
	Для Каждого врПакет Из врСхема.ПакетЗапросов Цикл
		Если Схема = Неопределено Тогда
			Схема 										= Новый СхемаЗапроса;
			Пакет 										= Схема.ПакетЗапросов[0];
		Иначе
			Пакет 										= Схема.ПакетЗапросов.Добавить();
		КонецЕсли;
		
		Пакет.УстановитьТекстЗапроса(врПакет.ПолучитьТекстЗапроса()); 		
	КонецЦикла;
	
	Для Каждого врПакет Из врСхема.ПакетЗапросов Цикл				
		Если НЕ врПакет.ТаблицаДляПомещения = ИмяТаблицы Тогда
			ПакетУничтожение 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросУничтоженияТаблицыСхемыЗапроса"));
			ПакетУничтожение.ИмяТаблицы 				= врПакет.ТаблицаДляПомещения;
		КонецЕсли;				
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстДляПроведенияПоСтабильнымПериодам()
	
	Текст 		=
	"ВЫБРАТЬ
	|	ВложенныйЗАпрос.Организация КАК Организация,
	|	ВложенныйЗАпрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗАпрос.Район КАК Район,
	|	ВложенныйЗАпрос.ЧастныйСектор КАК ЧастныйСектор,
	|	ВложенныйЗАпрос.Строение КАК Строение,
	|	ВложенныйЗАпрос.Помещение КАК Помещение,
	|	ВложенныйЗАпрос.ПериодРегистрации КАК ПериодРегистрации,
	|	ВложенныйЗАпрос.ДатаРегистратора КАК ДатаРегистратора,
	|	ВложенныйЗАпрос.ДокРегистратор КАК ДокРегистратор,
	|	ВложенныйЗАпрос.ТочкаУчета КАК ТочкаУчета,
	|	ЕСТЬNULL(табДолиРаспределенияОбъемаПомещения.ДоляПотребленияЧислитель, 0) КАК ДоляПотребленияЧислитель,
	|	ЕСТЬNULL(табДолиРаспределенияОбъемаПомещения.ДоляПотребленияЗнаменатель, 0) КАК ДоляПотребленияЗнаменатель,
	|	ВложенныйЗАпрос.СпособРаспределенияОбъемаПомещения КАК СпособРаспределенияОбъемаПомещения,
	|	ВложенныйЗАпрос.КоэффициентРаспределенияОстатка КАК КоэффициентРаспределенияОстатка,
	|	ЕСТЬNULL(энргСоглашениеОПотребленииВПомещенииФиксированныеОбъемы.ФиксированныйОбъемПотребления, 0) КАК ФиксированныйОбъемПотребления
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДокументыДляПроведения.Организация КАК Организация,
	|		ДокументыДляПроведения.ПериодНачисления КАК ПериодНачисления,
	|		ДокументыДляПроведения.Район КАК Район,
	|		ДокументыДляПроведения.ЧастныйСектор КАК ЧастныйСектор,
	|		ДокументыДляПроведения.Строение КАК Строение,
	|		ДокументыДляПроведения.Помещение КАК Помещение,
	|		ДокументыДляПроведения.ПериодРегистрации КАК ПериодРегистрации,
	|		Шапка.Дата КАК ДатаРегистратора,
	|		ДокументыДляПроведения.ДокРегистратор КАК ДокРегистратор,
	|		табАбоненты.ТочкаУчета КАК ТочкаУчета,
	|		табАбоненты.IDСтроки КАК IDСтроки,
	|		табАбоненты.СпособРаспределения КАК СпособРаспределенияОбъемаПомещения,
	|		табАбоненты.КоэффициентРаспределенияОстатка КАК КоэффициентРаспределенияОстатка
	|	ИЗ
	|		ДокументыДляПроведения КАК ДокументыДляПроведения
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргСоглашениеОПотребленииВПомещении КАК Шапка
	|			ПО ДокументыДляПроведения.ДокРегистратор = Шапка.Ссылка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргСоглашениеОПотребленииВПомещении.Абоненты КАК табАбоненты
	|			ПО ДокументыДляПроведения.ДокРегистратор = табАбоненты.Ссылка
	|				И ДокументыДляПроведения.КлючПомещения = табАбоненты.КлючПомещения) КАК ВложенныйЗАпрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргСоглашениеОПотребленииВПомещении.ДолиРаспределенияОбъемаПомещения КАК табДолиРаспределенияОбъемаПомещения
	|		ПО ВложенныйЗАпрос.ДокРегистратор = табДолиРаспределенияОбъемаПомещения.Ссылка
	|			И ВложенныйЗАпрос.IDСтроки = табДолиРаспределенияОбъемаПомещения.IDСтроки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргСоглашениеОПотребленииВПомещении.ФиксированныеОбъемы КАК энргСоглашениеОПотребленииВПомещенииФиксированныеОбъемы
	|		ПО ВложенныйЗАпрос.IDСтроки = энргСоглашениеОПотребленииВПомещенииФиксированныеОбъемы.IDСтроки
	|			И ВложенныйЗАпрос.ДокРегистратор = энргСоглашениеОПотребленииВПомещенииФиксированныеОбъемы.Ссылка";
	
	Возврат Текст;

КонецФункции

#КонецОбласти

