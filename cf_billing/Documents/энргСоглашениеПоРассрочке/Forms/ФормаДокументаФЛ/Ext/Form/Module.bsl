	ЭтоЗакрытие = (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.СоглашениеПоРассрочке_ЗакрытиеЗадолженностиФЛ"));
	
	ТолькоПросмотр = ЭтоЗакрытие;
	
	Элементы.ПланПогашенияЗадолженностиОбновитьСуммуОплат.Доступность = НЕ ЭтоЗакрытие;
