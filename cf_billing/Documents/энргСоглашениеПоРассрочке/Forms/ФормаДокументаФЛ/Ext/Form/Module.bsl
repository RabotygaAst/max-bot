#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	энргРаботаСПрикрепленнымиФайламиСервер.ПриСозданииНаСервере(ЭтотОбъект);
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
 	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Если ЗначениеЗаполнено(Объект.Абонент) Тогда
			ДанныеАбонента  		= Новый Структура("Район,Организация,Строение,Помещение");			
			ДанныеАбонента.удалить("Абонент");
			энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыАбонента(Объект.Абонент,ДанныеАбонента);
			ЗаполнитьЗначенияСвойств(ЭтаФорма.Объект,ДанныеАбонента,"Район,Организация,Строение");
		КонецЕсли;	
		РасчитатьЗадолженностьНаСервере();
	КонецЕсли;	
	
 	ОбновитьСуммуОплатНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьДоступность();
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ОбновитьСуммуОплатНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	энргРаботаСПрикрепленнымиФайламиКлиент.ПослеЗаписи(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	энргРаботаСПрикрепленнымиФайламиКлиент.ПередЗаписью(Отказ, ЭтотОбъект);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы
// ВводНаОсновании
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуСоздатьНаОсновании(Команда)
	
	ВводНаОснованииКлиент.ВыполнитьПодключаемуюКомандуСоздатьНаОсновании(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры
// Конец ВводНаОсновании

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат)
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСуммуОплат(Команда)
	ОбновитьСуммуОплатНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура РасчитатьЗадолженность(Команда)
	РасчитатьЗадолженностьНаСервере();
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиСобытийЭлементыФормы
&НаКлиенте
Процедура ПланПогашенияЗадолженностиПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	Объект.ПланПогашенияЗадолженности.Сортировать("Дата Возр");
	ОбновитьСуммуОплатНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПланПогашенияЗадолженностиДатаПриИзменении(Элемент)
	ТекСтрока = Элементы.ПланПогашенияЗадолженности.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекСтрока.Дата < Объект.Дата Тогда
		ТекСтрока.Дата = Объект.Дата;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата плановой выплаты не может быть раньше даты задачи.");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПланПогашенияЗадолженностиПередУдалением(Элемент, Отказ)
	ОбновитьСуммуОплатНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура АбонентПриИзменении(Элемент)
	Объект.Организация	= энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Абонент, "Организация");
	Объект.Район		= энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Абонент, "Район");
	Объект.Строение 	= ПолучитьСтроениеАбонента(Объект.Абонент);
	
	РасчитатьЗадолженностьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ТекущиеЗадолженностиПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ТекущиеЗадолженностиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ТекущиеЗадолженностиОтметкаПриИзменении(Элемент)
	Объект.СуммаКРаспределению = 0;
	Для каждого Строка Из Объект.ТекущиеЗадолженности Цикл
		Если НЕ Строка.Отметка Тогда
			Продолжить;
		КонецЕсли;
		Объект.СуммаКРаспределению = Объект.СуммаКРаспределению + Строка.Сумма;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура СтроениеПриИзменении(Элемент)
	РасчитатьЗадолженностьНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
&НаСервере
Процедура ОбновитьСуммуОплатНаСервере()

	Если Не ЗначениеЗаполнено(Объект.ПланПогашенияЗадолженности) Тогда
		Возврат;
	КонецЕсли;
	
	Объект.ПланПогашенияЗадолженности.Сортировать("Дата");
	ДатаОкон = КонецДня(Объект.ПланПогашенияЗадолженности[Объект.ПланПогашенияЗадолженности.Количество()-1].Дата);
	
	Для каждого Строка Из Объект.ПланПогашенияЗадолженности Цикл
		Строка.СуммаУплачено = 0;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаИсточник.Услуга КАК Услуга,
		|	ТаблицаИсточник.ПериодНачисления КАК ПериодНачисления,
		|	ТаблицаИсточник.Поставщик КАК Поставщик
		|ПОМЕСТИТЬ ТаблицаИсточник
		|ИЗ
		|	&ТаблицаИсточник КАК ТаблицаИсточник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(энргЗабалансоваяЗадолженностьОбороты.Период, ДЕНЬ) КАК Период,
		|	СУММА(энргЗабалансоваяЗадолженностьОбороты.СуммаЗадолженностиРасход) КАК СуммаВыплат
		|ИЗ
		|	РегистрНакопления.энргЗабалансоваяЗадолженность.Обороты(
		|			&ДатаНач,
		|			&ДатаОкон,
		|			Регистратор,
		|			(Организация, Район, Абонент, Услуга, ПериодНачисления) В
		|					(ВЫБРАТЬ
		|						&Организация КАК Организация,
		|						&Район КАК Район,
		|						&Абонент КАК Абонент,
		|						ТаблицаИсточник.Услуга КАК Услуга,
		|						ТаблицаИсточник.ПериодНачисления КАК ПериодНачисления
		|					ИЗ
		|						ТаблицаИсточник КАК ТаблицаИсточник)
		|				И ВидЗадолженности = &ВидЗадолженности) КАК энргЗабалансоваяЗадолженностьОбороты
		|ГДЕ
		|	НЕ энргЗабалансоваяЗадолженностьОбороты.Регистратор ССЫЛКА Документ.энргБанкротство
		|
		|СГРУППИРОВАТЬ ПО
		|	НАЧАЛОПЕРИОДА(энргЗабалансоваяЗадолженностьОбороты.Период, ДЕНЬ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период";
	
	Запрос.УстановитьПараметр("Абонент", Объект.Абонент);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Строение", Объект.Строение);
	Запрос.УстановитьПараметр("Район", Объект.Район);
	Запрос.УстановитьПараметр("ДатаНач", Объект.Дата);
	Запрос.УстановитьПараметр("ДатаОкон", ДатаОкон);
	Запрос.УстановитьПараметр("ВидЗадолженности", Перечисления.энргВидыЗадолженности.РеструктуризированнаяЗадолженность);
	Запрос.УстановитьПараметр("ТаблицаИсточник", Объект.ТекущиеЗадолженности.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	//СуммаВыплат = Неопределено;
	//Если Выборка.Следующий() Тогда 
	//	СуммаВыплат = Выборка.СуммаВыплат;
	//КонецЕсли;
	//СуммаВыплат = ?(ЗначениеЗаполнено(СуммаВыплат), СуммаВыплат, 0);
	//
	//Для каждого СтрокаТЧ Из Объект.ПланПогашенияЗадолженности Цикл
	//	Если СтрокаТЧ.Сумма > СуммаВыплат Тогда
	//		СтрокаТЧ.СуммаУплачено = СуммаВыплат;
	//		СуммаВыплат = 0;
	//	Иначе
	//		СтрокаТЧ.СуммаУплачено = СтрокаТЧ.Сумма;
	//		СуммаВыплат = СуммаВыплат - СтрокаТЧ.Сумма;
	//	КонецЕсли;
	//КонецЦикла;
	
	ДатаДокумента = НачалоДня(Объект.Дата) - 1;	
	Пока Выборка.Следующий() Цикл
		
		ЭтоПерваяСтрока = Истина;
		ПредыдущаяДата = ДатаДокумента;
		Для каждого Строка Из Объект.ПланПогашенияЗадолженности Цикл
			
			Если Выборка.Период > ?(ЭтоПерваяСтрока, ДатаДокумента, ПредыдущаяДата) И Выборка.Период <= Строка.Дата Тогда
				Строка.СуммаУплачено = Строка.СуммаУплачено + Выборка.СуммаВыплат;
				Прервать;
			КонецЕсли;
			
			ПредыдущаяДата = Строка.Дата;
			ЭтоПерваяСтрока = Ложь;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура РасчитатьЗадолженностьНаСервере()
	//Задачи.энргЗадачаПИД.ЗаполнитьЗадолженностьЗадачи(Объект);
	
	Объект.СуммаЗадолженности = 0;
	Объект.СуммаКРаспределению = 0;
	Объект.СуммаПени = 0; 
	
	Объект.ПланПогашенияЗадолженности.Очистить();
	Объект.ТекущиеЗадолженности.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргВзаиморасчетыПоМесяцамОстатки.Организация КАК Организация,
		|	энргВзаиморасчетыПоМесяцамОстатки.Район КАК Район,
		|	энргВзаиморасчетыПоМесяцамОстатки.МКД КАК МКД,
		|	энргВзаиморасчетыПоМесяцамОстатки.Абонент КАК Абонент,
		|	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
		|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления КАК ПериодНачисления,
		|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток - ЕСТЬNULL(энргВзаиморасчетыПоМесяцамОбороты.СуммаПриход, 0) КАК Задолженность,
		|	энргВзаиморасчетыПоМесяцамОстатки.Поставщик КАК Поставщик,
		|	0 КАК СуммаПени
		|ПОМЕСТИТЬ ВТ_Задолженность
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
		|			&ТекДата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И Абонент = &Абонент
		|				И МКД = &МКД) КАК энргВзаиморасчетыПоМесяцамОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.энргВзаиморасчетыПоМесяцам.Обороты(
		|				&НачалоНеПрос,
		|				&ТекДата,
		|				,
		|				Организация = &Организация
		|					И Район = &Район
		|					И Абонент = &Абонент
		|					И МКД = &МКД) КАК энргВзаиморасчетыПоМесяцамОбороты
		|		ПО энргВзаиморасчетыПоМесяцамОстатки.Организация = энргВзаиморасчетыПоМесяцамОбороты.Организация
		|			И энргВзаиморасчетыПоМесяцамОстатки.Район = энргВзаиморасчетыПоМесяцамОбороты.Район
		|			И энргВзаиморасчетыПоМесяцамОстатки.МКД = энргВзаиморасчетыПоМесяцамОбороты.МКД
		|			И энргВзаиморасчетыПоМесяцамОстатки.Абонент = энргВзаиморасчетыПоМесяцамОбороты.Абонент
		|			И энргВзаиморасчетыПоМесяцамОстатки.Услуга = энргВзаиморасчетыПоМесяцамОбороты.Услуга
		|			И энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления = энргВзаиморасчетыПоМесяцамОбороты.ПериодНачисления
		|ГДЕ
		|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток - ЕСТЬNULL(энргВзаиморасчетыПоМесяцамОбороты.СуммаПриход, 0) >= 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргВзаиморасчетыПоПениОстатки.Организация КАК Организация,
		|	энргВзаиморасчетыПоПениОстатки.Район КАК Район,
		|	энргВзаиморасчетыПоПениОстатки.МКД КАК МКД,
		|	энргВзаиморасчетыПоПениОстатки.Абонент КАК Абонент,
		|	энргВзаиморасчетыПоПениОстатки.Услуга КАК Услуга,
		|	энргВзаиморасчетыПоПениОстатки.ПериодНачисления КАК ПериодНачисления,
		|	ЕСТЬNULL(энргВзаиморасчетыПоПениОстатки.СуммаОстаток, 0) КАК СуммаПени
		|ПОМЕСТИТЬ ВТ_ЗадолженностьПоПени
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчетыПоПени.Остатки(
		|			&ТекДата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И Абонент = &Абонент
		|				И МКД = &МКД) КАК энргВзаиморасчетыПоПениОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.энргВзаиморасчетыПоПени.Обороты(
		|				&НачалоНеПрос,
		|				&ТекДата,
		|				,
		|				Организация = &Организация
		|					И Район = &Район
		|					И Абонент = &Абонент
		|					И МКД = &МКД) КАК энргВзаиморасчетыПоПениОбороты
		|		ПО энргВзаиморасчетыПоПениОстатки.Организация = энргВзаиморасчетыПоПениОбороты.Организация
		|			И энргВзаиморасчетыПоПениОстатки.Район = энргВзаиморасчетыПоПениОбороты.Район
