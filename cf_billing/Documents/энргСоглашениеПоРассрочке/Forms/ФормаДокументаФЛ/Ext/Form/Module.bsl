		|	Реструктуризация.Документ КАК Документ,
		|	Реструктуризация.СуммаОбщая КАК СуммаОбщая,
		|	МИНИМУМ(Реструктуризация.Сумма >= Реструктуризация.СуммаНарастающимИтогом) КАК ОтметкаВыполненного
		|ПОМЕСТИТЬ ВыполненныеРеструктуризации
		|ИЗ
		|	Реструктуризация КАК Реструктуризация
		|
		|СГРУППИРОВАТЬ ПО
		|	Реструктуризация.Документ,
		|	Реструктуризация.СуммаОбщая
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргДокументыРеструктуризации.ДокументРасходов КАК Ссылка
		|ПОМЕСТИТЬ ДокументыИсключения
		|ИЗ
		|	РегистрСведений.энргДокументыРеструктуризации КАК энргДокументыРеструктуризации
		|ГДЕ
		|	энргДокументыРеструктуризации.ДокументРеструктуризации В
		|			(ВЫБРАТЬ
		|				ВыполненныеРеструктуризации.Документ
		|			ИЗ
		|				ВыполненныеРеструктуризации КАК ВыполненныеРеструктуризации
		|			ГДЕ
		|				ВыполненныеРеструктуризации.ОтметкаВыполненного)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИтоговыеДанные.Документ КАК Документ,
		|	ИтоговыеДанные.Сумма КАК Сумма,
		|	ИтоговыеДанные.Услуга КАК Услуга,
		|	ИтоговыеДанные.ПериодНачисления КАК ПериодНачисления,
		|	ИтоговыеДанные.Поставщик КАК Поставщик,
		|	ЕСТЬNULL(ВТ_ЗадолженностьПоПени.СуммаПени, 0) КАК СуммаПени,
		|	ИСТИНА КАК Отметка
		|ИЗ
		|	ИтоговыеДанные КАК ИтоговыеДанные
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗадолженностьПоПени КАК ВТ_ЗадолженностьПоПени
		|		ПО ИтоговыеДанные.Услуга = ВТ_ЗадолженностьПоПени.Услуга
		|			И ИтоговыеДанные.ПериодНачисления = ВТ_ЗадолженностьПоПени.ПериодНачисления
		|ГДЕ
		|	НЕ ИтоговыеДанные.Документ В
		|				(ВЫБРАТЬ
		|					ДокументыИсключения.Ссылка
		|				ИЗ
		|					ДокументыИсключения КАК ДокументыИсключения)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПериодНачисления";
	
	ДатаЗадачи = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
	Граница = Задачи.энргЗадачаПИД.ПолучитьГраницуПросрочки(ДатаЗадачи, Объект.Организация, Объект.Район, Объект.Абонент); 
	Запрос.УстановитьПараметр("Абонент",	 Объект.Абонент);
	Запрос.УстановитьПараметр("Граница",	 Граница);
	Запрос.УстановитьПараметр("НачалоНеПрос",Граница+1);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Район",		 Объект.Район);
	Запрос.УстановитьПараметр("ТекДата",	 ДатаЗадачи);
	Запрос.УстановитьПараметр("Документ",	 Объект.Ссылка);
	Запрос.УстановитьПараметр("МКД",	 	 Объект.Строение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Объект.СуммаЗадолженности = Объект.СуммаЗадолженности + Выборка.Сумма;
		Объект.СуммаПени = Объект.СуммаПени + Выборка.СуммаПени; 
		ЗаполнитьЗначенияСвойств(Объект.ТекущиеЗадолженности.Добавить(), Выборка); 
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСтроениеАбонента(Абонент)
	
	Строение = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргКлючиПомещений.Строение КАК Строение
		|ИЗ
		|	РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
		|ГДЕ
		|	энргКлючиПомещений.КлючПомещения = &КлючПомещения
		|	И энргКлючиПомещений.Строение.ТипСтроения = ЗНАЧЕНИЕ(Перечисление.энргТипыСтроений.МКД)";
	
	Запрос.УстановитьПараметр("КлючПомещения", Абонент.КлючПомещения);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Строение = ВыборкаДетальныеЗаписи.Строение;
	КонецЕсли;
	
	Возврат Строение;
	
КонецФункции

&НаКлиенте
