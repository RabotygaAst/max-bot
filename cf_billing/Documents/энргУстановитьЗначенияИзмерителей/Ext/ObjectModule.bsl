#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

Функция ПолучитьАбонентовПлательщиков() Экспорт
	
	МассивПлательщиков = Новый Массив;
		
	Возврат МассивПлательщиков;
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	Ответственный = Пользователи.ТекущийПользователь();		
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
 	ПериодРегистрации =	?(ЗначениеЗаполнено(ДатаФактическогоСобытия), ДатаФактическогоСобытия, Дата);
	
	ДополнительныеСвойства.ПараметрыПроведения.Вставить("ПериодРегистрации", ПериодРегистрации);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	Если ЗначениеЗаполнено(ДатаФактическогоСобытия) тогда
		Момент 			= КонецДня(ДатаФактическогоСобытия);
		СтрокаОтказа 	= "На дату фактического события";
	иначе
		Момент 			= МоментВремени();
		СтрокаОтказа 	= "На дату операции";
	КонецЕсли;
	
	ЛСОТкрыт = энргПроверкаДанныхАбонентаСервер.СостояниеЛС(Момент,Абонент,Район,Организация);
	
	Если не ЛСОТкрыт тогда
		Отказ = истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + СтрокаОтказа + " лицевой счет закрыт");
	КонецЕсли;
	
	Если Отказ тогда
		Возврат;
	КонецЕсли;	
	
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	ДанныеШапки  = Новый Структура;
	ДанныеШапки.Вставить("Документ", 				Ссылка);
	ДанныеШапки.Вставить("Дата",					?(ЗначениеЗаполнено(ДатаФактическогоСобытия),КонецДня(ДатаФактическогоСобытия),Дата));
	ДанныеШапки.Вставить("Район",					Район);
	ДанныеШапки.Вставить("Организация",				Организация); 	
	ДанныеШапки.Вставить("ПериодРегистрации",		?(ЗначениеЗаполнено(ДатаФактическогоСобытия),КонецДня(ДатаФактическогоСобытия),Дата));
	ДанныеШапки.Вставить("ПериодНачисления",		ПериодНачисления);
	ДанныеШапки.Вставить("КлючПомещения",			КлючПомещения);	
	ДанныеШапки.Вставить("ЗначенияИзмерителей",		ДанныеИзмерителей());
	
	энргРаботаСТочкамиУчетаСервер.УстановитьЗначенияИзмерителейТочекУчета(Движения,ДанныеШапки,"ЗначенияИзмерителей");
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Дата, Организация, Район);	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДанныеИзмерителей()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргУстановитьЗначенияИзмерителейТочкиУчета.ТочкаУчета КАК ТочкаУчета,
		|	энргУстановитьЗначенияИзмерителейЗначенияИзмерителей.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
		|	энргУстановитьЗначенияИзмерителейЗначенияИзмерителей.Значение КАК Значение
		|ИЗ
		|	Документ.энргУстановитьЗначенияИзмерителей.ТочкиУчета КАК энргУстановитьЗначенияИзмерителейТочкиУчета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргУстановитьЗначенияИзмерителей.ЗначенияИзмерителей КАК энргУстановитьЗначенияИзмерителейЗначенияИзмерителей
		|		ПО энргУстановитьЗначенияИзмерителейТочкиУчета.Ссылка = энргУстановитьЗначенияИзмерителейЗначенияИзмерителей.Ссылка
		|			И энргУстановитьЗначенияИзмерителейТочкиУчета.IDСтроки = энргУстановитьЗначенияИзмерителейЗначенияИзмерителей.IDСтроки
		|			И (энргУстановитьЗначенияИзмерителейЗначенияИзмерителей.Значение > 0)
		|ГДЕ
		|	энргУстановитьЗначенияИзмерителейТочкиУчета.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса;
	
КонецФункции

#КонецОбласти

