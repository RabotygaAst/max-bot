#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;

	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
			
	Ответственный			= Пользователи.ТекущийПользователь();
	
	энргРаботаСТочкамиУчетаСервер.УстановитьНаправлениеИспользованияТочекУчетаПоУмолчанию(Неопределено,НаправлениеИспользованияТУ);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Движения.энргЗначенияНормативовПотребления.Записывать = Истина;
	Движения.энргЗначенияСоциальныхНормативов.Записывать = Истина;
	Для каждого стр из ЗначенияНормативов Цикл
		Движение 							= Движения.энргЗначенияНормативовПотребления.Добавить();
		Движение.Период 					= Дата;
		Движение.Организация 				= Организация;
		Движение.Район 						= Район;
		Движение.Услуга 					= Услуга;
		Движение.ТипНачисления 				= ТипНачисления;
		Движение.НаправлениеИспользованияТУ = НаправлениеИспользованияТУ;
		Движение.КлючНорматива				= стр.КлючНорматива;	
		Движение.ЗначениеНорматива 			= стр.ЗначениеНорматива;
	КонецЦикла;
	
	Для каждого стр из ЗначенияСоциальныхНормативов Цикл
		Движение 							= Движения.энргЗначенияСоциальныхНормативов.Добавить();
		Движение.Период 					= Дата;
		Движение.Организация 				= Организация;
		Движение.Район 						= Район;
		Движение.Услуга 					= Услуга;
		Движение.ТипНачисления 				= ТипНачисления;
		Движение.НаправлениеИспользованияТУ = НаправлениеИспользованияТУ;
		Движение.КлючНорматива				= стр.КлючНорматива;	
		Движение.ЗначениеНорматива 			= стр.ЗначениеНорматива;
	КонецЦикла;
	
	Для каждого стр из ЗначенияНормативовСписокРайонов Цикл
		Движение 							= Движения.энргЗначенияНормативовПотребления.Добавить();
		Движение.Период 					= Дата;
		Движение.Организация 				= Организация;
		Движение.Район 						= стр.Район;
		Движение.Услуга 					= Услуга;
		Движение.ТипНачисления 				= ТипНачисления;
		Движение.НаправлениеИспользованияТУ = НаправлениеИспользованияТУ;
		Движение.КлючНорматива				= стр.КлючНорматива;	
		Движение.ЗначениеНорматива 			= стр.ЗначениеНорматива;
	КонецЦикла;
	
	Для каждого стр из ЗначенияСоциальныхНормативовСписокРайонов Цикл
		Движение 							= Движения.энргЗначенияСоциальныхНормативов.Добавить();
		Движение.Период 					= Дата;
		Движение.Организация 				= Организация;
		Движение.Район 						= стр.Район;
		Движение.Услуга 					= Услуга;
		Движение.ТипНачисления 				= ТипНачисления;
		Движение.НаправлениеИспользованияТУ = НаправлениеИспользованияТУ;
		Движение.КлючНорматива				= стр.КлючНорматива;	
		Движение.ЗначениеНорматива 			= стр.ЗначениеНорматива;
	КонецЦикла;

КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
			
КонецПроцедуры

