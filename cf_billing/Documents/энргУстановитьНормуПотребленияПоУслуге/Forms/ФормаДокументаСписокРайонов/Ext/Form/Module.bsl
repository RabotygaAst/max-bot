#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	энргЛокализацияСервер.ПриСозданииНаСервере_энргУстановитьНормуПотребленияПоУслуге(ЭтотОбъект);
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	Если Не ЗначениеЗаполнено(Объект.Ссылка)
		//И ЗначениеЗаполнено(Объект.Район)
		И ЗначениеЗаполнено(Объект.Услуга)
		И ЗначениеЗаполнено(Объект.Организация)
		И ЗначениеЗаполнено(Объект.ТипНачисления)   Тогда
		СоздатьРеквизитыКлючевыхПараметровСервер(Объект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	
	Если ЗначениеЗаполнено(ТекущийОбъект.Услуга)
		И ЗначениеЗаполнено(ТекущийОбъект.Организация)
		И ЗначениеЗаполнено(ТекущийОбъект.ТипНачисления)  Тогда
		
		СоздатьРеквизитыКлючевыхПараметровСервер(ТекущийОбъект);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка)
		//И ЗначениеЗаполнено(Объект.Район)
		И ЗначениеЗаполнено(Объект.Услуга)
		И ЗначениеЗаполнено(Объект.Организация)
		И ЗначениеЗаполнено(Объект.ТипНачисления)   Тогда
		СоздатьРеквизитыКлючевыхПараметровСервер();
	КонецЕсли;


КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	СтруктураЭлементов = Новый Структура("КлючевыеПараметры, КлючевыеПараметрыСоцНорматива", СписокКлючевыхПараметров, СписокКлючевыхПараметровСоцНорматива);
	КлючевыеПараметрыНорматива			= Перечисления.энргКлючевыеПараметрыНорматива.ОписаниеКлючевыхПараметров();
	
	Для Каждого ТекЭлемент Из СтруктураЭлементов Цикл
		ДанныеСтрок  						= Новый Массив;
		
		Для Каждого СтрокаНорматива Из ЭтаФорма[ТекЭлемент.Ключ] Цикл
			ОписаниеСтроки 					= Новый Структура;
			
			Для Каждого КлючевойПараметр Из ТекЭлемент.Значение Цикл
				Если КлючевойПараметр.Значение = Перечисления.энргКлючевыеПараметрыНорматива.ПустаяСсылка() ТОгда
					Продолжить;
				КонецЕсли;			
				ОписаниеПараметра 		 	= КлючевыеПараметрыНорматива[КлючевойПараметр.Значение];			
				
				Если ОписаниеПараметра.Диапазон Тогда
					ОписаниеСтроки.Вставить(ОписаниеПараметра.Имя + "От", СтрокаНорматива[ОписаниеПараметра.Имя + "От"]);
					ОписаниеСтроки.Вставить(ОписаниеПараметра.Имя + "До", СтрокаНорматива[ОписаниеПараметра.Имя + "До"]);
				Иначе
					ОписаниеСтроки.Вставить(ОписаниеПараметра.Имя, СтрокаНорматива[ОписаниеПараметра.Имя]);
				КонецЕсли;			
			КонецЦикла; 		
			ДанныеСтрок.Добавить(ОписаниеСтроки);
		КонецЦикла;
		
		КлючиНормативов 					= Справочники.энргКлючиНормативов.НайтиИлиСоздатьКлючПараметра(ДанныеСтрок, Отказ);
		
		Если Отказ Тогда
			//Дубли Ключей
			ТекстСообщения = "";
			Для каждого стр из КлючиНормативов Цикл
				ТекстСообщения = ТекстСообщения + "Для строки №" + стр.Индекс + " найден пересекающийся ключ норматива " + стр.Дубль + "; " + Символы.ПС;
			КонецЦикла;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат;
		КонецЕсли;
		
		Если ТекЭлемент.Ключ = "КлючевыеПараметры" Тогда
			ТабЧасть	= ТекущийОбъект.ЗначенияНормативовСписокРайонов;
		Иначе
			ТабЧасть	= ТекущийОбъект.ЗначенияСоциальныхНормативовСписокРайонов;
		КонецЕсли;
		ТабЧасть.Очистить();
		
		Для Сч = 0 По КлючиНормативов.ВГраница() Цикл
			СтрокаЗначения 						= ТабЧасть.Добавить();
			СтрокаЗначения.КлючНорматива 		= КлючиНормативов[Сч];
			СтрокаЗначения.ЗначениеНорматива 	= ЭтаФорма[ТекЭлемент.Ключ][Сч].ЗначениеНорматива;
			СтрокаЗначения.Район			 	= ЭтаФорма[ТекЭлемент.Ключ][Сч].Район;
		КонецЦикла;
	КонецЦикла; 
	
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовШапки

&НаКлиенте
Процедура УслугаПриИзменении(Элемент)
	СоздатьРеквизитыКлючевыхПараметровКлиент();
КонецПроцедуры

&НаКлиенте
Процедура ТипНачисленияПриИзменении(Элемент)
	СоздатьРеквизитыКлючевыхПараметровКлиент();
КонецПроцедуры

&НаКлиенте
Процедура НаправлениеИспользованияТУПриИзменении(Элемент)
	СоздатьРеквизитыКлючевыхПараметровКлиент();
КонецПроцедуры

&НаКлиенте
Процедура НаправлениеИспользованияТУНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	энргРаботаСТочкамиУчетаКлиент.ОткрытьФормуВыбораНаправленийИзмерителейТУ(Элемент,СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы

// ВводНаОсновании
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуСоздатьНаОсновании(Команда)
	
	ВводНаОснованииКлиент.ВыполнитьПодключаемуюКомандуСоздатьНаОсновании(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры
// Конец ВводНаОсновании

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат) Экспорт
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаКлиенте
Процедура СоздатьРеквизитыКлючевыхПараметровКлиент()
	
	Если НЕ ЗначениеЗаполнено(Объект.Район)
		Или НЕ ЗначениеЗаполнено(Объект.Услуга)
		Или НЕ ЗначениеЗаполнено(Объект.Организация)
		Или НЕ ЗначениеЗаполнено(Объект.ТипНачисления)   Тогда
		
		ВидПлощадиУслуги = ПредопределенноеЗначение("Перечисление.энргВидыПлощадей.ПустаяСсылка");
		
		Возврат;
	КонецЕсли;
	
	КлючевыеПараметры.Очистить();
	КлючевыеПараметрыСоцНорматива.Очистить();
	
	СоздатьРеквизитыКлючевыхПараметровСервер();
	
КонецПроцедуры

&НаСервере
Процедура СоздатьРеквизитыКлючевыхПараметровСервер(ТекущийОбъект = Неопределено) 
	
	Если ТекущийОбъект = Неопределено Тогда
		ТекущийОбъект 						= Объект;
		ЗаполнятьЗначенияПараметров 		= Ложь;
	КонецЕсли;
	Если НЕ ТекущийОбъект.ПометкаУдаления Тогда 
		ЗаполнятьЗначенияПараметров = Истина;
		
	Иначе  
		ЗаполнятьЗначенияПараметров = Ложь;
	КонецЕсли;
	
	Если ТекущийОбъект.ТипНачисления = Перечисления.энргТипыНачислений.ИндивидуальныеНачисления и (НЕ ЗначениеЗаполнено(ТекущийОбъект.НаправлениеИспользованияТУ) ИЛИ ТекущийОбъект.НаправлениеИспользованияТУ = Справочники.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление) Тогда
		ВидПлощадиУслуги 					= ТекущийОбъект.Услуга.ВидПлощади;
	ИначеЕсли ТекущийОбъект.ТипНачисления = Перечисления.энргТипыНачислений.ИндивидуальныеНачисления Тогда
		СпособыРасчетаПоНаправлениям 		= РегистрыСведений.энргСпособыРасчетаПоНаправлениям.ПолучитьПоследнее(Объект.Дата,Новый Структура("Организация, Район, Услуга, НаправлениеИспользованияТУ", ТекущийОбъект.Организация, ТекущийОбъект.Район, ТекущийОбъект.Услуга, ТекущийОбъект.НаправлениеИспользованияТУ));
		ВидПлощадиУслуги 					= СпособыРасчетаПоНаправлениям.ВидПлощади;
	ИначеЕсли ТекущийОбъект.ТипНачисления = Перечисления.энргТипыНачислений.ОбщедомовыеНачисления Тогда
		ВидПлощадиУслуги 					= ТекущийОбъект.Услуга.ВидПлощадиМКД;
	КонецЕсли;
	
	НаименованиеУслуги						= ТекущийОбъект.Услуга.Наименование;
	
	КлючевыеПараметрыНорматива				= Перечисления.энргКлючевыеПараметрыНорматива.ОписаниеКлючевыхПараметров();
	ЗначенияПараметров  					= Неопределено;
	//ЗаполнятьЗначенияПараметров  			= Истина;
	
	ТаблицаРайоны = ТекущийОбъект.ЗначенияНормативовСписокРайонов.Выгрузить();
	ТаблицаРайоны.Свернуть("Район");
	
	СписокРайонов 							= ТаблицаРайоны.ВыгрузитьКолонку("Район");
		
	КлючевыеПараметрыУслугиСтруткура		= КлючевыеПараметрыУслуги(ТекущийОбъект, СписокРайонов);
	
	Для Каждого ТекКлючевыеПараметрыУслуги Из КлючевыеПараметрыУслугиСтруткура Цикл 
		КлючевыеПараметрыУслуги 			= ТекКлючевыеПараметрыУслуги.Значение;
		НазваниеЭлемента					= ТекКлючевыеПараметрыУслуги.Ключ;
		
		Если НазваниеЭлемента = "КлючевыеПараметрыСоцНорматива" Тогда
			ТекСписокКлючевыхПараметров 	= СписокКлючевыхПараметровСоцНорматива;
			НазваниеНовогоЭлемента			= "КлючевойПараметрЗначениеСоцНорматива";
		Иначе                              
			ТекСписокКлючевыхПараметров 	= СписокКлючевыхПараметров;	
			НазваниеНовогоЭлемента			= "КлючевойПараметрЗначениеНорматива";
		КонецЕсли;
		
		ЭлементЗначениеНорматива  				=  Элементы.Найти(НазваниеНовогоЭлемента);
		Если НЕ ЭлементЗначениеНорматива = Неопределено Тогда
			Элементы.Удалить(ЭлементЗначениеНорматива);
		КонецЕсли;
		
		МассивРеквизитов 						= Новый Массив;
		МассивРеквизитовУдалить 				= Новый Массив;
		МассивСписокКлючПарУдалить 				= новый Массив;
		
		Для Каждого КлючевойПараметр Из ТекСписокКлючевыхПараметров Цикл
			Если НЕ КлючевыеПараметрыУслуги.Найти(КлючевойПараметр.Значение) = Неопределено Тогда				
				Продолжить;
			КонецЕсли;		
			ОписаниеПараметра 					= КлючевыеПараметрыНорматива[КлючевойПараметр.Значение];
			ПолеТаблицы 						= Новый РеквизитФормы(ОписаниеПараметра.Имя, ОписаниеПараметра.Тип, НазваниеЭлемента, ОписаниеПараметра.Заголовок);			
			МассивРеквизитовУдалить.Добавить(ПолеТаблицы.Путь + "." + ПолеТаблицы.Имя);
			
			МассивСписокКлючПарУдалить.Добавить(КлючевойПараметр);
		КонецЦикла;
		
		Для Каждого ПараметрДляУдаления из МассивСписокКлючПарУдалить Цикл
			СписокКлючевыхПараметров.Удалить(ПараметрДляУдаления);
		КонецЦикла; 		
		
		Для Каждого КлючевойПараметр Из КлючевыеПараметрыУслуги Цикл		
			Если НЕ ТекСписокКлючевыхПараметров.НайтиПоЗначению(КлючевойПараметр) = Неопределено Тогда
				Продолжить;
			КонецЕсли;		
			// Норматив не от чего не зависит (только от района)
			ТекСписокКлючевыхПараметров.Добавить(КлючевойПараметр);
			Если КлючевойПараметр = Перечисления.энргКлючевыеПараметрыНорматива.ПустаяСсылка() Тогда
				Продолжить;
			КонецЕсли;
			
			ОписаниеПараметра 					= КлючевыеПараметрыНорматива[КлючевойПараметр];
			
			Если ОписаниеПараметра.Диапазон Тогда			
				ПолеТаблицы 					= Новый РеквизитФормы(ОписаниеПараметра.Имя + "От", ОписаниеПараметра.Тип, НазваниеЭлемента, ОписаниеПараметра.Заголовок + " от");
				МассивРеквизитов.Добавить(ПолеТаблицы);
				
				ОписаниеПараметра 				= КлючевыеПараметрыНорматива[КлючевойПараметр];
				ПолеТаблицы 					= Новый РеквизитФормы(ОписаниеПараметра.Имя + "До", ОписаниеПараметра.Тип, НазваниеЭлемента, ОписаниеПараметра.Заголовок + " до");
				МассивРеквизитов.Добавить(ПолеТаблицы); 			
			Иначе 			
				ПолеТаблицы 					= Новый РеквизитФормы(ОписаниеПараметра.Имя, ОписаниеПараметра.Тип, НазваниеЭлемента, ОписаниеПараметра.Заголовок);
				МассивРеквизитов.Добавить(ПолеТаблицы);	
			КонецЕсли;
		КонецЦикла;
		
		ДобавитьЭлементыФормы  					= ложь;
		
		Если МассивРеквизитов.Количество() > 0 ИЛИ МассивРеквизитовУдалить.Количество() > 0 Тогда
			ИзменитьРеквизиты(МассивРеквизитов, МассивРеквизитовУдалить);
			ДобавитьЭлементыФормы 			= Истина;
		КонецЕсли;
		
		

		Если ДобавитьЭлементыФормы Тогда
			Порядок 							= 0;
			
			Для Каждого КлючевойПараметр Из КлючевыеПараметрыУслуги Цикл		
				ОписаниеПараметра 				= КлючевыеПараметрыНорматива[КлючевойПараметр];
				Если ОписаниеПараметра.Диапазон Тогда
					ПолеТаблицы 				= Элементы.Добавить(НазваниеЭлемента + ОписаниеПараметра.Имя + "От", Тип("ПолеФормы"), Элементы[НазваниеЭлемента]);
					ПолеТаблицы.Вид 			= ВидПоляФормы.ПолеВвода;
					ПолеТаблицы.ПутьКДанным  	= НазваниеЭлемента + "." + ОписаниеПараметра.Имя + "От";
					
					Элементы.Переместить(ПолеТаблицы,Элементы[НазваниеЭлемента],Элементы[НазваниеЭлемента+ "ГруппаЕдиницыИзмерения"]);
					
					ПолеТаблицы 				= Элементы.Добавить(НазваниеЭлемента + ОписаниеПараметра.Имя + "До", Тип("ПолеФормы"), Элементы[НазваниеЭлемента]);
					ПолеТаблицы.Вид 			= ВидПоляФормы.ПолеВвода;
					ПолеТаблицы.ПутьКДанным  	= НазваниеЭлемента + "." + ОписаниеПараметра.Имя + "До";
					
					Элементы.Переместить(ПолеТаблицы,Элементы[НазваниеЭлемента],Элементы[НазваниеЭлемента+ "ГруппаЕдиницыИзмерения"]);
				Иначе				
					ПолеТаблицы 				= Элементы.Добавить(НазваниеЭлемента + ОписаниеПараметра.Имя, Тип("ПолеФормы"), Элементы[НазваниеЭлемента]);
					ПолеТаблицы.Вид 			= ВидПоляФормы.ПолеВвода;
					ПолеТаблицы.ПутьКДанным  	= НазваниеЭлемента + "." + ОписаниеПараметра.Имя;
					//Если ОписаниеПараметра.Имя = "ВидБлагоустройства" Тогда
					//	ПолеТаблицы.УстановитьДействие("НачалоВыбора", "НачалоВыбораВидБлагоустройства");
					//КонецЕсли;
					
					Элементы.Переместить(ПолеТаблицы,Элементы[НазваниеЭлемента],Элементы[НазваниеЭлемента+ "ГруппаЕдиницыИзмерения"]);
				КонецЕсли;
				
				Если ОписаниеПараметра.ИспользоватьСвязиПараметровВыбора Тогда
					ЗадатьСвязиПараметровВыбора(ПолеТаблицы,ОписаниеПараметра.Имя);
				КонецЕсли;
				
			КонецЦикла;		
		КонецЕсли;                                                                        
		
		ПолеТаблицы						= Элементы.Добавить(НазваниеНовогоЭлемента, Тип("ПолеФормы"), Элементы[НазваниеЭлемента]);
		ПолеТаблицы.Вид 				= ВидПоляФормы.ПолеВвода;
		ПолеТаблицы.ПутьКДанным  		= НазваниеЭлемента + "." + "ЗначениеНорматива";
		Элементы.Переместить(ПолеТаблицы,Элементы[НазваниеЭлемента],Элементы[НазваниеЭлемента+ "ГруппаЕдиницыИзмерения"]);
		
		Если ЗаполнятьЗначенияПараметров Тогда
			ЗаполнитьЗначенияПараметровПоКлючам(ТекущийОбъект, НазваниеЭлемента);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗначенияПараметровПоКлючам(ТекущийОбъект, НазваниеЭлемента)
	Запрос  						= Новый Запрос;
	Запрос.УстановитьПараметр("Услуга", 	ТекущийОбъект.Услуга);
	
	Если ТекущийОбъект.НаправлениеИспользованияТУ = Справочники.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление Тогда	
		Запрос.УстановитьПараметр("ВидПлощади", ТекущийОбъект.Услуга.ВидПлощади);
	Иначе
		ВидПлощади = Неопределено;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСпособыРасчетаПоНаправлениямСрезПоследних.ВидПлощади КАК ВидПлощади
		|ИЗ
		|	РегистрСведений.энргСпособыРасчетаПоНаправлениям.СрезПоследних(
		|			&Дата,
		|			НаправлениеИспользованияТУ = &НаправлениеИспользованияТУ
		|				И Услуга = &Услуга) КАК энргСпособыРасчетаПоНаправлениямСрезПоследних
		|ГДЕ
		|	энргСпособыРасчетаПоНаправлениямСрезПоследних.Услуга = &Услуга
		|	И энргСпособыРасчетаПоНаправлениямСрезПоследних.НаправлениеИспользованияТУ = &НаправлениеИспользованияТУ";
		
		Запрос.УстановитьПараметр("НаправлениеИспользованияТУ", ТекущийОбъект.НаправлениеИспользованияТУ);
		Запрос.УстановитьПараметр("Услуга", ТекущийОбъект.Услуга);
		Запрос.УстановитьПараметр("Дата", 	ТекущийОбъект.Дата);

		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ВидПлощади = ВыборкаДетальныеЗаписи.ВидПлощади;
		КонецЦикла;
		
		//СпособыРасчетаПоНаправлениям = РегистрыСведений.энргСпособыРасчетаПоНаправлениям.Получить(Новый Структура("Услуга, НаправлениеИспользованияТУ", ТекущийОбъект.Услуга, ТекущийОбъект.НаправлениеИспользованияТУ));
		//Запрос.УстановитьПараметр("ВидПлощади", СпособыРасчетаПоНаправлениям.ВидПлощади);
		
		Запрос.УстановитьПараметр("ВидПлощади", ВидПлощади);
	КонецЕсли;
	
	Если ТипЗнч(ТекущийОбъект) = Тип("ДанныеФормыСтруктура") Тогда
		
		Если НазваниеЭлемента = "КлючевыеПараметрыСоцНорматива" Тогда
			ЗначенияНормативов 		= ТекущийОбъект.ЗначенияСоциальныхНормативовСписокРайонов.Выгрузить();
		Иначе
			ЗначенияНормативов 		= ТекущийОбъект.ЗначенияНормативовСписокРайонов.Выгрузить();	
		КонецЕсли;				
		Запрос.УстановитьПараметр("ЗначенияНормативов", ЗначенияНормативов);
		
		Текст 					= 
		"ВЫБРАТЬ
		|	ЗначенияНормативов.КлючНорматива КАК КлючНорматива,
		|	ЗначенияНормативов.Район КАК Район,
		|	ЗначенияНормативов.ЗначениеНорматива КАК ЗначениеНорматива
		|ПОМЕСТИТЬ ЗначенияНормативов
		|ИЗ
		|	&ЗначенияНормативов КАК ЗначенияНормативов
		|;
		|//
		|ВЫБРАТЬ
		|	энргКлючиНормативов.*,
		|	&Услуга КАК Услуга,
		|	&ВидПлощади КАК ВидПлощади,
		|	ЗначенияНормативов.Район КАК Район,
		|	ЗначенияНормативов.ЗначениеНорматива КАК ЗначениеНорматива
		|ИЗ
		|	Справочник.энргКлючиНормативов КАК энргКлючиНормативов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗначенияНормативов КАК ЗначенияНормативов
		|		ПО энргКлючиНормативов.Ссылка = ЗначенияНормативов.КлючНорматива";		
	Иначе		
		Запрос.УстановитьПараметр("Ссылка", ТекущийОбъект.Ссылка);
		Текст 					=
		"ВЫБРАТЬ
		|	энргКлючиНормативов.*,
		|	&Услуга КАК Услуга,
		|	&ВидПлощади КАК ВидПлощади,
		|	энргУстановитьНормуПотребленияПоУслугеЗначенияНормативовСписокРайонов.Район КАК Район,
		|	энргУстановитьНормуПотребленияПоУслугеЗначенияНормативовСписокРайонов.ЗначениеНорматива КАК ЗначениеНорматива
		|ИЗ
		|	Справочник.энргКлючиНормативов КАК энргКлючиНормативов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргУстановитьНормуПотребленияПоУслуге.ЗначенияНормативовСписокРайонов КАК энргУстановитьНормуПотребленияПоУслугеЗначенияНормативовСписокРайонов
		|		ПО энргКлючиНормативов.Ссылка = энргУстановитьНормуПотребленияПоУслугеЗначенияНормативовСписокРайонов.КлючНорматива
		|			И (энргУстановитьНормуПотребленияПоУслугеЗначенияНормативовСписокРайонов.Ссылка = &Ссылка)";
		
		Если НазваниеЭлемента = "КлючевыеПараметрыСоцНорматива" Тогда
			Текст = СтрЗаменить(Текст, "ЗначенияНормативов", "ЗначенияСоциальныхНормативов");
		КонецЕсли;
	КонецЕсли;
	
	Запрос.Текст 			= Текст;
	Результат  				= Запрос.Выполнить();
	Выборка  				= Результат.Выбрать();
	Сч = 1;
	Пока Выборка.Следующий() цикл
		НовСтрока = ЭтаФорма[НазваниеЭлемента].Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока,Выборка);
		НовСтрока.НомерСтроки = Сч;
		Сч = Сч + 1;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция КлючевыеПараметрыУслуги(ТекущийОбъект, СписокРайонов)
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период", 		ТекущийОбъект.Дата);
	Запрос.УстановитьПараметр("Организация", 	ТекущийОбъект.Организация);
	Запрос.УстановитьПараметр("Район", 			СписокРайонов);
	Запрос.УстановитьПараметр("Услуга", 		ТекущийОбъект.Услуга);
	Запрос.УстановитьПараметр("ТипНачисления", 	ТекущийОбъект.ТипНачисления);
	Запрос.УстановитьПараметр("НаправлениеИспользованияТУ", 	ТекущийОбъект.НаправлениеИспользованияТУ);
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ энргУстановленныеПараметрыРасчетаНормативаСрезПоследних.СоциальныйНорматив
	|			ТОГДА энргУстановленныеПараметрыРасчетаНормативаСрезПоследних.Разрез
	|		ИНАЧЕ ЗНАЧЕНИЕ(перечисление.энргКлючевыеПараметрыНорматива.ПустаяСсылка)
	|	КОНЕЦ КАК Разрез,
	|	ВЫБОР
	|		КОГДА энргУстановленныеПараметрыРасчетаНормативаСрезПоследних.СоциальныйНорматив
	|			ТОГДА энргУстановленныеПараметрыРасчетаНормативаСрезПоследних.Разрез
	|		ИНАЧЕ ЗНАЧЕНИЕ(перечисление.энргКлючевыеПараметрыНорматива.ПустаяСсылка)
	|	КОНЕЦ КАК РазрезСоцНорматива
	|ИЗ
	|	РегистрСведений.энргУстановленныеПараметрыРасчетаНорматива.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район В (&Район)
	|				И Услуга = &Услуга
	|				И ТипНачисления = &ТипНачисления
	|				И НаправлениеИспользованияТУ = &НаправлениеИспользованияТУ) КАК энргУстановленныеПараметрыРасчетаНормативаСрезПоследних";
	
	Результат  = Запрос.Выполнить().Выгрузить();
	Возврат Новый Структура("КлючевыеПараметры, КлючевыеПараметрыСоцНорматива", УдалитьПустыеЭлементы(Результат.ВыгрузитьКолонку("Разрез")), УдалитьПустыеЭлементы(Результат.ВыгрузитьКолонку("РазрезСоцНорматива")));
	
КонецФункции

&НаСервере
Функция УдалитьПустыеЭлементы(МассивЭлементов)
	
	Счетчик = 0;
	КоличествоЭлементов = МассивЭлементов.Количество();
	
	Пока Счетчик < КоличествоЭлементов Цикл
		
		Если МассивЭлементов [Счетчик].Пустая() Тогда
			МассивЭлементов.Удалить(Счетчик);
			
			КоличествоЭлементов = КоличествоЭлементов - 1;
			
		Иначе
			Счетчик = Счетчик + 1;
			
		КонецЕсли;
		
	КонецЦикла;
	Возврат МассивЭлементов;
КонецФункции

&НаКлиенте
Процедура КлючевыеПараметрыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	ТекущиеДанные = Элементы.КлючевыеПараметры.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.Услуга = Объект.Услуга;
	ТекущиеДанные.ВидПлощади = ВидПлощадиУслуги;
КонецПроцедуры

Процедура ЗадатьСвязиПараметровВыбора(ПолеТаблицы,ИмяПараметра)
		
	Если ИмяПараметра = "ИзмерительНаправленияИспользования" Тогда
		НоваяСвязь 	= Новый СвязьПараметраВыбора("Отбор.Родитель", "Объект.НаправлениеИспользованияТУ");		
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НоваяСвязь);
		НовыеСвязи 	= Новый ФиксированныйМассив(НовыйМассив);
		
		ПолеТаблицы.СвязиПараметровВыбора = НовыеСвязи;
	КонецЕсли;
	
КонецПроцедуры


#КонецОбласти
