#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	энргЛокализацияСервер.ПриСозданииНаСервере_энргУстановитьФормулуРасчетаТочекУчета(ЭтотОбъект);
	
	
	
	Если (Параметры.Свойство("ЗаполнитьДокумент") и Параметры.ЗаполнитьДокумент) ИЛИ (Параметры.Свойство("ЗначенияЗаполнения") и ЗначениеЗаполнено(Параметры.ЗначенияЗаполнения)) тогда
		Объект.ТочкиУчета.Очистить();
		энргПользовательскийВводСервер.УстановитьЗависимыеРеквизитыАбонента(Объект.Абонент,Объект);
		энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ТочкиУчета");
		
		ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(Объект.КлючПомещения);
		ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат);
		
		ЗаполнитьТочкиУчетаПоУмолчанию();	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Для каждого стр из Объект.ТочкиУчета Цикл
			стр.Техническая = ИзменениеТочкиУчета(стр.ТочкаУчета).Техническая;
		КонецЦикла;
		
	Иначе
		Объект.ПрименятьВсегда = Истина;
		
		Если ЗначениеЗаполнено(Объект.Организация) Тогда
			Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
				Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	//энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ДолевыеТочкиУчета");
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ТочкиУчета");
	
	ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(ТекущийОбъект.КлючПомещения);
	ЗаполнитьДанныеКлючаПомещения(ДанныеПомещенияРезультат); 	
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ДанныеДляПерерасчета", энргРаботаСПериодомДействия.ЗаполнитьДанныеДляПерерасчета(ТекущийОбъект,"ТочкиУчета"));
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ДопСвойства  = ТекущийОбъект.ДополнительныеСвойства;
	Если ДопСвойства.свойство("ДанныеДляПерерасчета") тогда
		ДанныеДляПерерасчета = ДопСвойства.ДанныеДляПерерасчета;		 
	иначе
		ДанныеДляПерерасчета = Неопределено;
	КонецЕсли;
	
	//энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ДолевыеТочкиУчета");
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект,"ТочкиУчета");
	
	Для каждого стр из Объект.ТочкиУчета Цикл
		стр.Техническая = ИзменениеТочкиУчета(стр.ТочкаУчета).Техническая;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ЕстьОшибкиЗаполнения(ПараметрыЗаписи.РежимЗаписи) Тогда
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Если  ДанныеДляПерерасчета <>Неопределено тогда
		ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросСозданияПерерасчета",ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения,"Открыть документ перерасчета?",РежимДиалогаВопрос.ДаНет);		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВопросСозданияПерерасчета(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если  РезультатВопроса = КодВозвратаДиалога.Да тогда
			энргРаботаСПериодомДействияКлиент.ОткрытьФормуДокументаПерерасчет(ДанныеДляПерерасчета);
		иначе
			ДанныеДляПерерасчета = Неопределено;
		КонецЕсли; 		
	КонецЕсли;	
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовШапки

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда 		
		ЗаполнитьПериодНачисленияСервер();
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПериодНачисленияСервер()
	Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);	
КонецПроцедуры

&НаКлиенте
Процедура АбонентПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Абонент) тогда
		энргПользовательскийВводКлиент.ПриИзмененииАбонента(ЭтаФорма);
	иначе
		Объект.КлючПомещения	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
		ЭтаФорма.Помещение 		= ПредопределенноеЗначение("Справочник.энргПомещения.ПустаяСсылка");
		ЭтаФорма.Строение 		= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитываемаяТочкаУчетаПриИзменении(Элемент)
	ЗаполнитьУслугуПоТочкеУчета();
КонецПроцедуры

&НаКлиенте
Процедура ДатаФактическогоСобытияПриИзменении(Элемент)
	
	энргРаботаСПериодомДействияКлиент.ПроверитьКорректностьДатыФактическогоСобытияКлиент(Объект.Организация, Объект.Район, Объект.Дата, Объект.ДатаФактическогоСобытия);

КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФУнкции

&НаСервере
Процедура ЗаполнитьТочкиУчетаПоУмолчанию()
	РассчитываемаяПоУмолачнию 	= энргОбщегоНазначения.ЗначениеКонстанты("энргРассчитываемаяУслугаПоУмолчанию");
	Если не ЗначениеЗаполнено(РассчитываемаяПоУмолачнию) тогда
		Возврат;
	КонецЕсли;
	
	АктивныеТочки				= энргРаботаСТочкамиУчетаСервер.ДействующиеТочкиУчета(Объект.Дата,Объект.Район,Объект.Абонент);
	Запрос  					= Новый Запрос;
	Запрос.УстановитьПараметр("АктивныеТочки",	АктивныеТочки);
	Запрос.УстановитьПараметр("Период" ,		Объект.Дата);
	Запрос.УстановитьПараметр("Район" ,			Объект.Район);
	Запрос.УстановитьПараметр("Абонент" ,		Объект.Абонент);
	
	Запрос.Текст 				= "ВЫБРАТЬ
	             				  |	АктивныеТочки.ТочкаУчета КАК ТочкаУчета
	             				  |ПОМЕСТИТЬ АктивныеТочки
	             				  |ИЗ
	             				  |	&АктивныеТочки КАК АктивныеТочки
	             				  |;
	             				  |
	             				  |////////////////////////////////////////////////////////////////////////////////
	             				  |ВЫБРАТЬ
	             				  |	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	             				  |	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга,
	             				  |	ВЫБОР
	             				  |		КОГДА энргУслугиТочекУчетаСрезПоследних.ТочкаУчета.Головная
	             				  |			ТОГДА 1
	             				  |		ИНАЧЕ -1
	             				  |	КОНЕЦ КАК Коэффициент,
	             				  |	энргУслугиТочекУчетаСрезПоследних.Техническая КАК Техническая
	             				  |ИЗ
	             				  |	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
	             				  |			&Период,
	             				  |			УдалитьАбонент = &Абонент
	             				  |				И Район = &Район
	             				  |				И ТочкаУчета В
	             				  |					(ВЫБРАТЬ
	             				  |						АктивныеТочки.ТочкаУчета
	             				  |					ИЗ
	             				  |						АктивныеТочки КАК АктивныеТочки)) КАК энргУслугиТочекУчетаСрезПоследних
	             				  |
	             				  |УПОРЯДОЧИТЬ ПО
	             				  |	Коэффициент УБЫВ";
	
	Результат  				    = Запрос.Выполнить();
	Выборка 				    = Результат.Выбрать();
	
	Пока Выборка.Следующий() цикл
		Если  Выборка.Услуга  = РассчитываемаяПоУмолачнию тогда
			Объект.РассчитываемаяТочкаУчета 	= Выборка.ТочкаУчета;
		иначе
			СтрокаТЧ  							= Объект.ТочкиУчета.Добавить();
			СтрокаТЧ.ТочкаУчета 				=  Выборка.ТочкаУчета;
			СтрокаТЧ.Коэффициент 				=  Выборка.Коэффициент; 
			СтрокаТЧ.Техническая 				=  Выборка.Техническая;
		КонецЕсли; 		
	КонецЦикла;
	
КонецПроцедуры 

&НаСервере 
Процедура ЗаполнитьУслугуПоТочкеУчета()
	
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	энргАбоненты.КлючПомещения КАК КлючПомещения,
	             |	энргАбоненты.Ссылка КАК Ссылка,
	             |	энргАбоненты.КлючПомещения.Строение КАК Строение,
	             |	энргАбоненты.КлючПомещения.Помещение КАК Помещение
	             |ПОМЕСТИТЬ ВТ_Абонент
	             |ИЗ
	             |	Справочник.энргАбоненты КАК энргАбоненты
	             |ГДЕ
	             |	энргАбоненты.Ссылка = &Абонент
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга,
	             |	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	             |	энргУслугиТочекУчетаСрезПоследних.КлючПомещения КАК КлючПомещения,
	             |	энргУслугиТочекУчетаСрезПоследних.КлючПомещения.Строение КАК Строение,
	             |	энргУслугиТочекУчетаСрезПоследних.КлючПомещения.Помещение КАК Помещение
	             |ИЗ
	             |	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
	             |			,
	             |			организация = &организация
	             |				И район = &район
	             |				И ключпомещения В
	             |					(ВЫБРАТЬ
	             |						вт_абонент.КлючПомещения
	             |					ИЗ
	             |						вт_абонент)) КАК энргУслугиТочекУчетаСрезПоследних
	             |ГДЕ
	             |	энргУслугиТочекУчетаСрезПоследних.ТочкаУчета.Код = &точкаучета"
	             ;
	            
				 
	Запрос.УстановитьПараметр("Организация", объект.Организация);
	Запрос.УстановитьПараметр("Район", объект.Район);
	ЗАпрос.УстановитьПараметр("точкаУчета", объект.РассчитываемаяТочкаУчета.Код);
	ЗАпрос.УстановитьПараметр("Период", объект.Дата);
	ЗАпрос.УстановитьПараметр("Абонент", объект.Абонент);
	
	Результат=Запрос.Выполнить();
	Выборка=Результат.Выбрать();
	
	пока Выборка.Следующий() цикл
		Объект.Услуга=Выборка.Услуга;
		ЗаполнитьЗначенияСвойств(Объект.ТочкиУчета.Добавить(),Выборка);
	КонецЦикла;
	
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеКлючаПомещения(Знач ДанныеПомещенияРезультат)
	
	Перем ДанныеПомещенияВыборка;
	
	Если Не ДанныеПомещенияРезультат.Пустой() Тогда
		ДанныеПомещенияВыборка  = ДанныеПомещенияРезультат.Выбрать();
		ДанныеПомещенияВыборка.Следующий();
		ЗаполнитьЗначенияСвойств(ЭтаФорма,ДанныеПомещенияВыборка,"Строение,Помещение,ЧастныйСектор");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция ЕстьОшибкиЗаполнения(РежимЗаписи)
	
	ЕстьОшибкиЗаполнения = Ложь;
		
	Если НачалоМесяца(Объект.Дата) = НачалоМесяца(Объект.ДатаФактическогоСобытия) Тогда
		ЕстьОшибкиЗаполнения = Истина; 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Фактическая и текущая дата не могут находиться в одном периоде");
		Объект.ДатаФактическогоСобытия = Дата(1,1,1);
	КонецЕсли;

	Возврат ЕстьОшибкиЗаполнения;
	
КонецФункции

#КонецОбласти

#Область ОбработчикиКомандФормы

// ВводНаОсновании
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуСоздатьНаОсновании(Команда)
	
	ВводНаОснованииКлиент.ВыполнитьПодключаемуюКомандуСоздатьНаОсновании(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры
// Конец ВводНаОсновании

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат) Экспорт
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

&НаКлиенте
Процедура СтроениеПриИзменении(Элемент)	
	Если ЗначениеЗаполнено(Строение) Тогда
		энргПользовательскийВводКлиент.ПриИзмененииСтроенияПомещения(ЭтаФорма);		
	Иначе
		ЭтаФорма.Строение 		= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
		Объект.КлючПомещения 	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПомещениеПриИзменении(Элемент)
	энргПользовательскийВводКлиент.ПриИзмененииСтроенияПомещения(ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаСтроениеПриИзменении(Элемент)
	
	ТекущиеДанные 				= Элементы.ТочкиУчета.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ИзменениеКлючаПомещенияТЧ(ТекущиеДанные.Строение, ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПомещениеПриИзменении(Элемент)
	ТекущиеДанные 				= Элементы.ТочкиУчета.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ИзменениеКлючаПомещенияТЧ(ТекущиеДанные.Помещение, ТекущиеДанные);

КонецПроцедуры

&НаКлиенте
Процедура ИзменениеКлючаПомещенияТЧ(ИзмененныйРеквизит, ТекущиеДанные)
	    	
	Если ЗначениеЗаполнено(ИзмененныйРеквизит) Тогда
		ДанныеСтроения				= энргПользовательскийВводСервер.ПрочитатьКлючПомещения(ТекущиеДанные.Строение,ТекущиеДанные.Помещение);
		ТекущиеДанные.КлючПомещения	= ДанныеСтроения.КлючПомещения;
		ТекущиеДанные.ТочкаУчета 	= ПредопределенноеЗначение("Справочник.энргТочкиУчета.ПустаяСсылка");
		ТекущиеДанные.Услуга		= ПредопределенноеЗначение("Справочник.энргВидыУслуг.ПустаяСсылка");
		ТекущиеДанные.Техническая	= Ложь;
	Иначе
		ТекущиеДанные.Помещение 	= ПредопределенноеЗначение("Справочник.энргСтроения.ПустаяСсылка");
		ТекущиеДанные.КлючПомещения = ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
		ТекущиеДанные.ТочкаУчета 	= ПредопределенноеЗначение("Справочник.энргТочкиУчета.ПустаяСсылка");
		ТекущиеДанные.Услуга		= ПредопределенноеЗначение("Справочник.энргВидыУслуг.ПустаяСсылка");
		ТекущиеДанные.Техническая	= Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТочкаУчетаПриИзменении(Элемент)
	ТУ = Элементы.ТочкиУчета.ТекущиеДанные.ТочкаУчета;
	ЗаполнитьЗначенияСвойств(Элементы.ТочкиУчета.ТекущиеДанные, ИзменениеТочкиУчета(ТУ));
КонецПроцедуры

&НаСервере
Функция ИзменениеТочкиУчета(ТУ)
	СтруктураВозврата = Новый Структура();
	СтруктураВозврата.Вставить("Техническая", Ложь);
	СтруктураВозврата.Вставить("Услуга", Справочники.энргВидыУслуг.ПустаяСсылка());
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргУслугиТочекУчетаСрезПоследних.Техническая КАК Техническая,
	|	энргУслугиТочекУчетаСрезПоследних.Услуга КАК Услуга
	|ИЗ
	|	РегистрСведений.энргУслугиТочекУчета.СрезПоследних(
	|			&Период,
	|			ТочкаУчета = &ТочкаУчета
	|				И Организация = &Организация
	|				И Район = &Район) КАК энргУслугиТочекУчетаСрезПоследних";
	
	Запрос.УстановитьПараметр("Организация", объект.Организация);
	Запрос.УстановитьПараметр("Период", объект.Дата);
	Запрос.УстановитьПараметр("Район", объект.Район);
	Запрос.УстановитьПараметр("ТочкаУчета", ТУ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтруктураВозврата.Техническая = ВыборкаДетальныеЗаписи.Техническая;
		СтруктураВозврата.Услуга = ВыборкаДетальныеЗаписи.Услуга;
	КонецЦикла;
	Возврат СтруктураВозврата;
КонецФункции

&НаКлиенте
Процедура ТочкиУчетаПередУдалением(Элемент, Отказ)
	
	Отказ = Истина;
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ТЧ", "ТочкиУчета");
	ДопПараметры.Вставить("НомерСтроки", 	Элемент.ТекущиеДанные.НомерСтроки-1);
	
	ПроверкаУдаленияСтроки(ДопПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаУдаленияСтроки(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросУдаленияСтроки",ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Удалить всю строку вместо значения ячейки?",РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросУдаленияСтроки(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			Объект[ДополнительныеПараметры.ТЧ].Удалить(ДополнительныеПараметры.НомерСтроки);	
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры