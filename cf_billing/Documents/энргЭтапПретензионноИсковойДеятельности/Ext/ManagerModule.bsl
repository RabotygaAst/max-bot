// Сформировать печатные формы объектов.
//
// ВХОДЯЩИЕ:
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать.
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы.
//   ОшибкиПечати          - Список значений  - Ошибки печати  (значение - ссылка на объект, представление - текст ошибки).
//   ОбъектыПечати         - Список значений  - Объекты печати (значение - ссылка на объект, представление - имя области
//												в которой был выведен объект).
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ИмяМакета 					= КоллекцияПечатныхФорм[0].ИмяМакета;
	СинонимМакета 				= КоллекцияПечатныхФорм[0].СинонимМакета;

	Если ИмяМакета ="ПФ_MXL_Предупреждение" тогда 		
		ТабличныйДокумент 		= СформироватьПредупреждение(МассивОбъектов);
	ИначеЕсли ИмяМакета ="ПФ_MXL_Извещение" тогда 		
		ТабличныйДокумент 		= СформироватьИзвещение(МассивОбъектов);		
	ИначеЕсли  ИмяМакета ="ПФ_MXL_Уведомление" тогда 		
		ТабличныйДокумент 		= СформироватьУведомление(МассивОбъектов);		
	КонецЕсли; 	
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, ИмяМакета) Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
						КоллекцияПечатныхФорм,
						ИмяМакета,СинонимМакета,
						ТабличныйДокумент, ,
						"Документ.энргЭтапПретензионноИсковойДеятельности." + ИмяМакета);
	КонецЕсли;

КонецПроцедуры

Функция СформироватьПредупреждение(МассивОбъектов)
	
	ТабличныйДокумент 						= Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати 	= "ПараметрыПечати_энргЭтапПретензионноИсковойДеятельности_Предупреждение";
	
	ИмяМакета 								= "ПФ_MXL_Предупреждение";
	
	ОбластиМакета = Новый Структура;
	ОбластиМакета.Вставить("Данные");
	ОбластиМакета.Вставить("Адреса");
	ОбластиМакета.Вставить("Подвал");
	
	Макет 									= УправлениеПечатью.МакетПечатнойФормы("Документ.энргЭтапПретензионноИсковойДеятельности." + ИмяМакета);
	
	для Каждого КлючЗначение из ОбластиМакета  цикл
		ОбластиМакета[КлючЗначение.ключ] 	= Макет.получитьОбласть(КлючЗначение.ключ);
	КонецЦикла; 	
			
	ПервыйДокумент = Истина;
	
	для Каждого ОбъектПечати из МассивОбъектов цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();	
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		Область 								= ОбластиМакета.Данные;
		Область.Параметры.Абонент 				= ОбъектПечати.Абонент;
		Область.Параметры.Адрес 				= ОбъектПечати.АдресОбъекта;
		Область.Параметры.Поставщик 			= ОбъектПечати.Поставщик;
		Область.Параметры.Сумма 				= ОбъектПечати.СуммаЗадолженности ;
		Область.Параметры.Дата 					= Формат(ОбъектПечати.Дата,"ДЛФ=DD");
		ТабличныйДокумент.Вывести(Область);
				
		Область 								= ОбластиМакета.Адреса;	
		ВывестиАдресаАбонентскихПунктов(Область,ТабличныйДокумент,ОбъектПечати.Поставщик);
						
		Область 								= ОбластиМакета.Подвал;
		ТабличныйДокумент.Вывести(Область);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция СформироватьИзвещение(МассивОбъектов)
	
	ТабличныйДокумент 						= Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати 	= "ПараметрыПечати_энргЭтапПретензионноИсковойДеятельности_Извещение";
	
	ИмяМакета 								= "ПФ_MXL_Извещение";
	
	ОбластиМакета = Новый Структура;
	ОбластиМакета.Вставить("Заголовок");
	ОбластиМакета.Вставить("Данные");
	ОбластиМакета.Вставить("Адреса");
	ОбластиМакета.Вставить("Телефоны");
	ОбластиМакета.Вставить("Подвал");
	
	Макет 									= УправлениеПечатью.МакетПечатнойФормы("Документ.энргЭтапПретензионноИсковойДеятельности." + ИмяМакета);
	
	для Каждого КлючЗначение из ОбластиМакета  цикл
		ОбластиМакета[КлючЗначение.ключ] 	= Макет.получитьОбласть(КлючЗначение.ключ);
	КонецЦикла; 	
	
	ПервыйДокумент = Истина;
	
	для Каждого ОбъектПечати из МассивОбъектов цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();	
		КонецЕсли;
		ПервыйДокумент = Ложь;   	
		
		ОбластьЗаголовок 						= ОбластиМакета.Заголовок;
		ОбластьЗаголовок.Параметры.Абонент 		= ОбъектПечати.Абонент;
		ОбластьЗаголовок.Параметры.Адрес 		= ОбъектПечати.АдресОбъекта;
		ОбластьЗаголовок.Параметры.Поставщик 	= ОбъектПечати.Поставщик;
		ОбластьЗаголовок.Параметры.Дата 		= Формат(ОбъектПечати.Дата,"ДЛФ=DD");
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);	
		
		ОбластьДанные 							= ОбластиМакета.Данные;
		ОбластьДанные.Параметры.Поставщик 		= ОбъектПечати.Поставщик;
		ОбластьДанные.Параметры.Сумма 			= ОбъектПечати.СуммаЗадолженности ;
		ОбластьДанные.Параметры.Дата 			= Формат(ОбъектПечати.Дата,"ДЛФ=DD");		
		ТабличныйДокумент.Вывести(ОбластьДанные); 		
		
		Область 								= ОбластиМакета.Адреса;	
		ВывестиАдресаАбонентскихПунктов(Область,ТабличныйДокумент,ОбъектПечати.Поставщик);		
			
		ОбластьПодвал 							= ОбластиМакета.Подвал;
		ТабличныйДокумент.Вывести(ОбластьПодвал);
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
КонецФункции

Функция СформироватьУведомление(МассивОбъектов)
	
	ТабличныйДокумент 							= Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати 		= "ПараметрыПечати_энргЭтапПретензионноИсковойДеятельности_Извещение";
	                                        	
	ИмяМакета 									= "ПФ_MXL_Уведомление";
	
	ОбластиМакета = Новый Структура;
	ОбластиМакета.Вставить("Заголовок");
	ОбластиМакета.Вставить("Данные");
	ОбластиМакета.Вставить("Адреса");
	ОбластиМакета.Вставить("Телефоны");
	ОбластиМакета.Вставить("Подвал");
	
	Макет 										= УправлениеПечатью.МакетПечатнойФормы("Документ.энргЭтапПретензионноИсковойДеятельности." + ИмяМакета);
	
	для Каждого КлючЗначение из ОбластиМакета  цикл
		ОбластиМакета[КлючЗначение.ключ] 		= Макет.получитьОбласть(КлючЗначение.ключ);
	КонецЦикла; 	
	
	ПервыйДокумент 								= Истина;
	
	для Каждого ОбъектПечати из МассивОбъектов цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();	
		КонецЕсли;
		ПервыйДокумент 							= Ложь;	
		
		ОбластьЗаголовок 						= ОбластиМакета.Заголовок;
		ОбластьЗаголовок.Параметры.Абонент 		= ОбъектПечати.Абонент;
		ОбластьЗаголовок.Параметры.Адрес 		= ОбъектПечати.АдресОбъекта;
		ОбластьЗаголовок.Параметры.Поставщик 	= ОбъектПечати.Поставщик;
		ОбластьЗаголовок.Параметры.Сумма 		= ОбъектПечати.СуммаЗадолженности ;
		ОбластьЗаголовок.Параметры.Дата 		= Формат(ОбъектПечати.Дата,"ДЛФ=DD");
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		ОбластьАдреса 							= ОбластиМакета.Адреса;	
		ТабличныйДокумент.Вывести(ОбластьАдреса);
		
		ОбластьДанные 							= ОбластиМакета.Данные;
		ОбластьДанные.Параметры.Поставщик 		= ОбъектПечати.Поставщик;
		ТабличныйДокумент.Вывести(ОбластьДанные);
		
		Область			 						= ОбластиМакета.Телефоны;
		ВывестиАдресаАбонентскихПунктов(Область,ТабличныйДокумент,ОбъектПечати.Поставщик);
			
		ОбластьПодвал 							= ОбластиМакета.Подвал;
		ТабличныйДокумент.Вывести(ОбластьПодвал);
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
КонецФункции

// СФормировать Первый этап ПИД.
Функция ПервыйЭтап_ПИД() Экспорт
	
	Запрос  		= Новый Запрос;
	Запрос.Текст 	="ВЫБРАТЬ
	|	МИНИМУМ(энргВидыОперацийПИД.Ссылка) КАК Этап
	|ИЗ
	|	(ВЫБРАТЬ
	|		МИНИМУМ(энргВидыОперацийПИД.Порядок) КАК Порядок
	|	ИЗ
	|		Справочник.энргВидыОперацийПИД КАК энргВидыОперацийПИД
	|	ГДЕ
	|		НЕ энргВидыОперацийПИД.Отключен) КАК ВложенныйЗАпрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыОперацийПИД КАК энргВидыОперацийПИД
	|		ПО ВложенныйЗАпрос.Порядок = энргВидыОперацийПИД.Порядок
	|			И (НЕ энргВидыОперацийПИД.Отключен)";
	Результат  = Запрос.Выполнить();
	Если Результат.Пустой() тогда
		Возврат Справочники.энргВидыОперацийПИД.ПустаяСсылка();
	иначе
		Выборка  = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Этап; 
	КонецЕсли;
	
КонецФункции

Функция ВывестиАдресаАбонентскихПунктов(Область,ТабличныйДокумент,Поставщик)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргКонтрагентыКонтактнаяИнформация.Представление КАК Адрес
	|ИЗ
	|	Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	энргКонтрагентыКонтактнаяИнформация.Ссылка = &Поставщик
	|	И энргКонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|	И энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресАбонПунктаПоставщикаУслуг)";
	
	Запрос.УстановитьПараметр("Поставщик", 	Поставщик); 	
	Результат 						= Запрос.Выполнить();	
	Выборка 						= Результат.Выбрать();
	Пока Выборка.Следующий() цикл
		 Область.параметры.Адреса 	= Выборка.Адрес;
		 ТабличныйДокумент.вывести(Область);
	КонецЦикла;	
КонецФункции
#КонецОбласти

