Функция UsersStartPOST(Запрос)

	ЗаписьЖурналаРегистрации("MAXBotHTTP",УровеньЖурналаРегистрации.Информация,,,"Вошли в обработчик UserStart");
	
	Если Не MAXBotИнтеграция.ПроверитьАвторизацию(Запрос) Тогда
		Возврат ОтветОшибка(401, "UNAUTHORIZED", "Неверный токен авторизации");
	КонецЕсли;
	Попытка
		Тело = ПрочитатьJSONИзЗапроса(Запрос);
		Имя = ""; 
		Если Тело.Свойство("first_name") Тогда
			Имя = Тело.first_name; 
		КонецЕсли;
		MAXBotИнтеграция.ЗарегистрироватьПользователя(Тело.max_user_id, Тело.chat_id, Имя);
		Возврат ОтветУспех(Новый Структура, "Пользователь зарегистрирован");
	Исключение 
		Возврат ОтветОшибка(500, "INTERNAL_ERROR", ОписаниеОшибки());
	КонецПопытки;
КонецФункции

