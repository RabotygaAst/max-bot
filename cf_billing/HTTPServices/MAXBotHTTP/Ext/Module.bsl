Функция ПрочитатьJSONИзЗапроса(Запрос) Экспорт
	Тело = Запрос.ПолучитьТелоКакСтроку();
	Если ПустаяСтрока(Тело) Тогда
		Возврат Новый Структура;
	КонецЕсли;
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Тело);
	Возврат ПрочитатьJSON(ЧтениеJSON);
КонецФункции

Функция ОтветУспех(Данные, Сообщение = "OK", Код = "OK", OperationID = "") Экспорт
	Тело = Новый Структура;
	Тело.Вставить("success", Истина);
	Тело.Вставить("code", Код);
	Тело.Вставить("message", Сообщение);
	Если ЗначениеЗаполнено(OperationID) Тогда
		Тело.Вставить("operation_id", OperationID);
	КонецЕсли;
	Тело.Вставить("data", Данные);

	Возврат СформироватьHTTPОтвет(200, Тело);
КонецФункции

Функция ОтветОшибка(КодСостояния, КодОшибки, Сообщение, OperationID = "") Экспорт
	Тело = Новый Структура;
	Тело.Вставить("success", Ложь);
	Тело.Вставить("code", КодОшибки);
	Тело.Вставить("message", Сообщение);
	Если ЗначениеЗаполнено(OperationID) Тогда
		Тело.Вставить("operation_id", OperationID);
	КонецЕсли;
	Возврат СформироватьHTTPОтвет(КодСостояния, Тело);
КонецФункции

Функция HTTPКодОшибкиПередачиПоказаний(КодОшибки)
	Если КодОшибки = "CONFIG_REQUIRED" Тогда Возврат 500; КонецЕсли;
	Если КодОшибки = "METER_NOT_FOUND" Тогда Возврат 404; КонецЕсли;
	Если КодОшибки = "ACCESS_DENIED" Тогда Возврат 403; КонецЕсли;
	Если КодОшибки = "READING_NOT_ALLOWED" Тогда Возврат 422; КонецЕсли;
	Если КодОшибки = "READING_LESS_THAN_PREVIOUS" Тогда Возврат 422; КонецЕсли;
	Если КодОшибки = "INVALID_PERIOD" Тогда Возврат 400; КонецЕсли;
	Если КодОшибки = "INVALID_VALUE" Тогда Возврат 400; КонецЕсли;
	Если КодОшибки = "NOT_IMPLEMENTED" Тогда Возврат 501; КонецЕсли;
	Возврат 500;
КонецФункции

Функция ДанныеОтветаПоказания(Результат, MeterID, Значение)
	Если Результат.Свойство("data") Тогда
		Возврат Результат.data;
	КонецЕсли;

	Данные = Новый Структура;
	Если Результат.Свойство("Номер") Тогда
		Данные.Вставить("document_number", Результат.Номер);
	КонецЕсли;
	Если Результат.Свойство("Дата") Тогда
		Данные.Вставить("document_date", Формат(Результат.Дата, "ДФ=yyyy-MM-dd"));
	КонецЕсли;
	Данные.Вставить("posted", Ложь);
	Данные.Вставить("meter_id", MeterID);
	Данные.Вставить("value", Значение);
	Данные.Вставить("status", "saved_unposted");

	Возврат Данные;
КонецФункции

Функция СформироватьHTTPОтвет(КодСостояния, Тело) Экспорт
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Тело);

	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть());
	Возврат Ответ;
КонецФункции

