#Область СлужебныеПроцедурыИФункции

Функция ПрочитатьJSONИзЗапроса(Запрос) Экспорт
	Тело = Запрос.ПолучитьТелоКакСтроку();
	Если ПустаяСтрока(Тело) Тогда
		Возврат Новый Структура;
	КонецЕсли;
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Тело);
	Возврат ПрочитатьJSON(ЧтениеJSON);
КонецФункции

Функция ОтветУспех(Данные, Сообщение = "OK", Код = "OK", OperationID = "") Экспорт
	Тело = Новый Структура;
	Тело.Вставить("success", Истина);
	Тело.Вставить("code", Код);
	Тело.Вставить("message", Сообщение);
	Тело.Вставить("operation_id", ?(ЗначениеЗаполнено(OperationID), OperationID, "1c-" + Строка(Новый УникальныйИдентификатор)));
	Тело.Вставить("actual_at", Формат(ТекущаяДата(), "ДФ=yyyy-MM-ddTHH:mm:ss"));
	Тело.Вставить("data", Данные);
	
	Возврат СформироватьHTTPОтвет(200, Тело);
КонецФункции

Функция ОтветОшибка(КодСостояния, КодОшибки, Сообщение, OperationID = "") Экспорт
	Тело = Новый Структура;
	Тело.Вставить("success", Ложь);
	Тело.Вставить("code", КодОшибки);
	Тело.Вставить("message", Сообщение);
	Тело.Вставить("operation_id", ?(ЗначениеЗаполнено(OperationID), OperationID, "1c-" + Строка(Новый УникальныйИдентификатор)));
	Тело.Вставить("actual_at", Формат(ТекущаяДата(), "ДФ=yyyy-MM-ddTHH:mm:ss"));
	Тело.Вставить("data", Новый Структура);
	Возврат СформироватьHTTPОтвет(КодСостояния, Тело);
КонецФункции

Функция СформироватьHTTPОтвет(КодСостояния, Тело) Экспорт
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Тело);
	
	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть());
	Возврат Ответ;
КонецФункции

