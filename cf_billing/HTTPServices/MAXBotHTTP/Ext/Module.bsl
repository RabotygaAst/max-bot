Функция AccountLinkStartpost(Запрос)

	Если Не MAXBotИнтеграция.ПроверитьАвторизацию(Запрос) Тогда
		Возврат MAXBotHTTP.ОтветОшибка(401, "UNAUTHORIZED", "Неверный токен авторизации");
	КонецЕсли;
	
	Попытка
		Тело = MAXBotHTTP.ПрочитатьJSONИзЗапроса(Запрос);
		
		Результат = MAXBotИнтеграция.НачатьПривязкуЛицевогоСчета(
			Тело.max_user_id,
			Тело.account_number,
			Тело.source
		);
		
		Если Не Результат.Успех Тогда
			Возврат MAXBotHTTP.ОтветОшибка(404, "ACCOUNT_NOT_FOUND", "Лицевой счет не найден");
		КонецЕсли;
		
		Возврат MAXBotHTTP.ОтветУспех(
			Новый Структура,
			"Код подтверждения отправлен"
		);
		
	Исключение
		Возврат MAXBotHTTP.ОтветОшибка(500, "INTERNAL_ERROR", ОписаниеОшибки());
	КонецПопытки;

КонецФункции

Функция AccountLinkConfirmpost(Запрос)

	Если Не MAXBotИнтеграция.ПроверитьАвторизацию(Запрос) Тогда
		Возврат MAXBotHTTP.ОтветОшибка(401, "UNAUTHORIZED", "Неверный токен авторизации");
	КонецЕсли;
	
	Попытка
		Тело = MAXBotHTTP.ПрочитатьJSONИзЗапроса(Запрос);
		
		Результат = MAXBotИнтеграция.ПодтвердитьПривязкуЛицевогоСчета(
			Тело.max_user_id,
			Тело.account_number,
			Тело.code,
			Тело.source
		);
		
		Если Результат.КодОшибки = "INVALID_CODE" Тогда
			Возврат MAXBotHTTP.ОтветОшибка(422, "INVALID_CODE", "Неверный код подтверждения");
		КонецЕсли;
		
		Если Результат.КодОшибки = "CODE_EXPIRED" Тогда
			Возврат MAXBotHTTP.ОтветОшибка(422, "CODE_EXPIRED", "Срок действия кода истек");
		КонецЕсли;
		
		ДанныеСчета = MAXBotИнтеграция.JSONЛицевойСчет(Результат.ЛицевойСчет);
		
		Возврат MAXBotHTTP.ОтветУспех(
			ДанныеСчета,
			"Лицевой счет привязан"
		);
		
	Исключение
		Возврат MAXBotHTTP.ОтветОшибка(500, "INTERNAL_ERROR", ОписаниеОшибки());
	КонецПопытки;

КонецФункции

