Функция MeterReadingpost(Запрос)

	Если Не MAXBotИнтеграция.ПроверитьАвторизацию(Запрос) Тогда
		Возврат ОтветОшибка(401, "UNAUTHORIZED", "Неверный токен авторизации");
	КонецЕсли;
	
	Попытка
		AccountID = Запрос.ПараметрыURL.Получить("account_id");
		MeterID = Запрос.ПараметрыURL.Получить("meter_id");
		Тело = ПрочитатьJSONИзЗапроса(Запрос);
		
		Если MAXBotИнтеграция.ОперацияУжеВыполнена(Тело.operation_id) Тогда
			ДанныеРанее = MAXBotИнтеграция.ПолучитьРезультатОперацииJSON(Тело.operation_id);
			Возврат ОтветУспех(ДанныеРанее, "Показание уже принято", "OK", Тело.operation_id);
		КонецЕсли;
		
		Если Не MAXBotИнтеграция.ПользовательИмеетДоступКЛС(Тело.max_user_id, AccountID) Тогда
			Возврат ОтветОшибка(403, "FORBIDDEN", "Нет доступа к лицевому счету", Тело.operation_id);
		КонецЕсли;
		
		Результат = MAXBotИнтеграция.СоздатьПоказаниеПрибора(
			AccountID,
			MeterID,
			Тело.period,
			Тело.value,
			Тело.source,
			Тело.max_user_id,
			Тело.message_id,
			Тело.operation_id
		);
		
		Данные = Новый Структура;
		Данные.Вставить("document_number", Результат.Номер);
		Данные.Вставить("document_date", Формат(Результат.Дата, "ДФ=yyyy-MM-dd"));
		Данные.Вставить("meter_id", MeterID);
		Данные.Вставить("value", Тело.value);
		
		MAXBotИнтеграция.ЗапомнитьРезультатОперации(Тело.operation_id, "reading", Данные);
		
		Возврат ОтветУспех(Данные, "Показание принято", "OK", Тело.operation_id);
		
	Исключение
		Возврат ОтветОшибка(500, "INTERNAL_ERROR", ОписаниеОшибки());
	КонецПопытки;

КонецФункции

Функция AccountAppealpost(Запрос)

	Если Не MAXBotИнтеграция.ПроверитьАвторизацию(Запрос) Тогда
		Возврат ОтветОшибка(401, "UNAUTHORIZED", "Неверный токен авторизации");
	КонецЕсли;
	
	Попытка
		AccountID = Запрос.ПараметрыURL.Получить("account_id");
		Тело = ПрочитатьJSONИзЗапроса(Запрос);
		
		Если MAXBotИнтеграция.ОперацияУжеВыполнена(Тело.operation_id) Тогда
			ДанныеРанее = MAXBotИнтеграция.ПолучитьРезультатОперацииJSON(Тело.operation_id);
			Возврат ОтветУспех(ДанныеРанее, "Обращение уже зарегистрировано", "OK", Тело.operation_id);
		КонецЕсли;
		
		Если Не MAXBotИнтеграция.ПользовательИмеетДоступКЛС(Тело.max_user_id, AccountID) Тогда
			Возврат ОтветОшибка(403, "FORBIDDEN", "Нет доступа к лицевому счету", Тело.operation_id);
		КонецЕсли;
		
		Результат = MAXBotИнтеграция.СоздатьОбращение(
			AccountID,
			Тело.max_user_id,
			Тело.category,
			Тело.text,
			Тело.source,
			Тело.message_id,
			Тело.operation_id
		);
		
		Данные = Новый Структура;
		Данные.Вставить("appeal_id", Строка(Результат.Ссылка.УникальныйИдентификатор()));
		Данные.Вставить("number", Результат.Номер);
		Данные.Вставить("status", "Зарегистрировано");
		Данные.Вставить("sla", Результат.СрокИсполненияСтрокой);
		
		MAXBotИнтеграция.ЗапомнитьРезультатОперации(Тело.operation_id, "appeal", Данные);
		
		Возврат ОтветУспех(Данные, "Обращение создано", "OK", Тело.operation_id);
		
	Исключение
		Возврат ОтветОшибка(500, "INTERNAL_ERROR", ОписаниеОшибки());
	КонецПопытки;
	
КонецФункции

