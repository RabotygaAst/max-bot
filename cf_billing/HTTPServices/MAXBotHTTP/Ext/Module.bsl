#Область ПрограммныйИнтерфейс

Функция UsersStartPOST(Запрос)
	
	Если Не MAXBotИнтеграция.ПроверитьАвторизацию(Запрос) Тогда
		Возврат MAXBotHTTP.ОтветОшибка(401, "UNAUTHORIZED", "Неверный токен авторизации");
	КонецЕсли;
	
	Попытка
		Тело = MAXBotHTTP.ПрочитатьJSONИзЗапроса(Запрос);
		
		MAXUserID = Тело.max_user_id;
		ChatID = Тело.chat_id;
		Имя = "";
		
		Если Тело.Свойство("first_name") Тогда
			Имя = Тело.first_name;
		КонецЕсли;
		
		MAXBotИнтеграция.ЗарегистрироватьПользователя(MAXUserID, ChatID, Имя);
		
		Возврат MAXBotHTTP.ОтветУспех(
			Новый Структура,
			"Пользователь зарегистрирован"
		);
		
	Исключение
		Возврат MAXBotHTTP.ОтветОшибка(500, "INTERNAL_ERROR", ОписаниеОшибки());
	КонецПопытки;
	
КонецФункции

