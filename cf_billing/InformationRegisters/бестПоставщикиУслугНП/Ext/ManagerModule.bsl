#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Получает данные поставщиков.
//
// Параметры:
//  Организация		-	СправочникСсылка.Организации.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  Период			-	Дата.
//  Поставщик		-	СправочникСсылка.энргКонтрагенты.
//  ТочкаУчета		-	СправочникСсылка.энргТочкиУчета.
//  Услуга			-	СправочникСсылка.энргВидыУслуг.
//  СоставныеУслуги	-	СправочникСсылка.энргВидыУслуг.
// 
// Возвращаемое значение:
//   РузультатЗапроса.
//
Функция ПолучитьДанныеПоставщиков(Организация, Район, Период, Поставщик = Неопределено, ТочкаУчета = Неопределено, Услуга = Неопределено,СоставныеУслуги = Ложь) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестПоставщикиУслугНП.ТочкаУчета КАК ТочкаУчета,
		|	бестПоставщикиУслугНП.Услуга КАК Услуга,
		|	бестПоставщикиУслугНП.Поставщик КАК Поставщик,
		|	бестПоставщикиУслугНП.ЧастьСоставной КАК ЧастьСоставной
		|ИЗ
		|	РегистрСведений.бестПоставщикиУслугНП.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И ТочкаУчета = &ТочкаУчета
		|				И ЧастьСоставной = &Услуга) КАК бестПоставщикиУслугНП
		|ГДЕ
		|	бестПоставщикиУслугНП.Поставщик = &Поставщик";
	
	
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Если ЗначениеЗаполнено(Поставщик) Тогда
		Запрос.УстановитьПараметр("Поставщик", Поставщик);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бестПоставщикиУслугНП.Поставщик = &Поставщик", "Истина");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТочкаУчета) Тогда
		Запрос.УстановитьПараметр("ТочкаУчета", ТочкаУчета);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТочкаУчета = &ТочкаУчета", "Истина");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Услуга) Тогда
		Если СоставныеУслуги Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЧастьСоставной = &Услуга", "Услуга = &Услуга");
		КонецЕсли;
		Запрос.УстановитьПараметр("Услуга", Услуга);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЧастьСоставной = &Услуга", "Истина");
	КонецЕсли;
	
	Возврат Запрос.Выполнить();

КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Получает действующие приборы учета вместе с поставщиками.
//
// Параметры:
//  Организация		-	СправочникСсылка.Организации.
//  Район			-	СправочникСсылка.энргЗоныОтвественности.
//  Период			-	Дата.
//  МВТ				-	МенеджерВременныхТаблиц.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция ПолучитьДействующиеПриборыУчетаВместеСПоставщиками(Организация, Район, Период, МВТ) Экспорт
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Итог.ОбъектРасчета КАК ОбъектРасчета,
		|	Итог.ТочкаУчета КАК ТочкаУчета,
		|	Итог.Шкала КАК Шкала,
		|	Итог.Услуга КАК Услуга,
		|	Итог.ВидДифференцированности КАК ВидДифференцированности,
		|	Итог.ТарифнаяЗона КАК ТарифнаяЗона,
		|	Итог.ПриборУчета КАК ПриборУчета,
		|	Итог.РегистрируетОбъем КАК РегистрируетОбъем,
		|	Итог.ВидПараметра КАК ВидПараметра,
		|	Итог.РасположениеИзмерителя КАК РасположениеИзмерителя,
		|	Итог.ВидКанальности КАК ВидКанальности
		|ПОМЕСТИТЬ СоставныеУслугиТУ
		|ИЗ
		|	Итог КАК Итог
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СоставныеУслугиТУ.ОбъектРасчета КАК ОбъектРасчета,
		|	СоставныеУслугиТУ.ТочкаУчета КАК ТочкаУчета,
		|	СоставныеУслугиТУ.Шкала КАК Шкала,
		|	СоставныеУслугиТУ.Услуга КАК Услуга,
		|	СоставныеУслугиТУ.ВидДифференцированности КАК ВидДифференцированности,
		|	СоставныеУслугиТУ.ТарифнаяЗона КАК ТарифнаяЗона,
		|	СоставныеУслугиТУ.ПриборУчета КАК ПриборУчета,
		|	СоставныеУслугиТУ.РегистрируетОбъем КАК РегистрируетОбъем,
		|	СоставныеУслугиТУ.ВидПараметра КАК ВидПараметра,
		|	СоставныеУслугиТУ.РасположениеИзмерителя КАК РасположениеИзмерителя,
		|	СоставныеУслугиТУ.ВидКанальности КАК ВидКанальности,
		|	энргВидыУслугСоставляющиеУслуг.Услуга КАК ПростаяУслуга,
		|	энргВидыУслуг.СоставнаяУслуга КАК СоставнаяУслуга
		|ПОМЕСТИТЬ ПростыеУслугиТУ
		|ИЗ
		|	СоставныеУслугиТУ КАК СоставныеУслугиТУ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
		|		ПО СоставныеУслугиТУ.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
		|		ПО СоставныеУслугиТУ.Услуга = энргВидыУслуг.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПростыеУслугиТУ.ОбъектРасчета КАК ОбъектРасчета,
		|	ПростыеУслугиТУ.ТочкаУчета КАК ТочкаУчета,
		|	ПростыеУслугиТУ.Шкала КАК Шкала,
		|	ПростыеУслугиТУ.Услуга КАК Услуга,
		|	ПростыеУслугиТУ.ВидДифференцированности КАК ВидДифференцированности,
		|	ПростыеУслугиТУ.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ПростыеУслугиТУ.ПриборУчета КАК ПриборУчета,
		|	ПростыеУслугиТУ.РегистрируетОбъем КАК РегистрируетОбъем,
		|	ПростыеУслугиТУ.ВидПараметра КАК ВидПараметра,
		|	ПростыеУслугиТУ.РасположениеИзмерителя КАК РасположениеИзмерителя,
		|	ПростыеУслугиТУ.ВидКанальности КАК ВидКанальности,
		|	ПростыеУслугиТУ.ПростаяУслуга КАК ПростаяУслуга,
		|	бестПоставщикиУслугНПСрезПоследних.Поставщик КАК Поставщик
		|ИЗ
		|	ПростыеУслугиТУ КАК ПростыеУслугиТУ
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестПоставщикиУслугНП.СрезПоследних(
		|				&Период,
		|				Организация = &Организация
		|					И Район = &Район) КАК бестПоставщикиУслугНПСрезПоследних
		|		ПО ПростыеУслугиТУ.ТочкаУчета = бестПоставщикиУслугНПСрезПоследних.ТочкаУчета
		|			И ПростыеУслугиТУ.ПростаяУслуга = бестПоставщикиУслугНПСрезПоследних.Услуга
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТочкаУчета,
		|	Шкала";
	
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Период", 		Период);
	Запрос.УстановитьПараметр("Район", 			Район);
	
	Возврат Запрос.Выполнить();
КонецФункции

#КонецОбласти

#КонецЕсли