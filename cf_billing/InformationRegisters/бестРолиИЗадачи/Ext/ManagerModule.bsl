Функция ПолучитьРольПоТочкеМаршрута(ТочкаМаршрутаБизнесПроцесса) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестРолиИЗадачи.Роль КАК Роль
		|ИЗ
		|	РегистрСведений.бестРолиИЗадачи КАК бестРолиИЗадачи
		|ГДЕ
		|	бестРолиИЗадачи.ТочкаМаршрута = &ТочкаМаршрута";
	
	Запрос.УстановитьПараметр("ТочкаМаршрута", ТочкаМаршрутаБизнесПроцесса);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Роль;
	КонецЦикла;
	
	Возврат Неопределено;
КонецФункции

