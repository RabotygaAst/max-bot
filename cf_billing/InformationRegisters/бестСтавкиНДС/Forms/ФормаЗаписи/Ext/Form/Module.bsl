
&НаСервере
Процедура СтавкаНДСНоваяПриИзмененииНаСервере()
	Если ЗначениеЗаполнено(Запись.СтавкаНДССсылка) Тогда
		Запись.СтавкаНДС	= Запись.СтавкаНДССсылка.Процент;
		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СтавкаНДСНоваяПриИзменении(Элемент)
	СтавкаНДСНоваяПриИзмененииНаСервере();
КонецПроцедуры
