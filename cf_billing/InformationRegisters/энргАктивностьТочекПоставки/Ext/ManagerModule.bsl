#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаАктивныеТочкиПоставокПомещения()
	
	Текст =
	"ВЫБРАТЬ
	|	энргАктивностьТочекПоставкиСрезПоследних.ТочкаПоставки КАК ТочкаПоставки
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекПоставки.СрезПоследних(
	|			&Период,
	|			ТочкаПоставки В
	|				(ВЫБРАТЬ
	|					ТочкиПоставокТочекУчета.ТочкаПоставки
	|				ИЗ
	|					ТочкиПоставокТочекУчета КАК ТочкиПоставокТочекУчета)) КАК энргАктивностьТочекПоставкиСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекПоставкиСрезПоследних.Состояние";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаАктивныеТочкиПоставокМКД()
	
	Текст =
	"ВЫБРАТЬ
	|	энргАктивностьТочекПоставкиСрезПоследних.ТочкаПоставки КАК ТочкаПоставки
	|ИЗ
	|	РегистрСведений.энргАктивностьТочекПоставки.СрезПоследних(
	|			&Период,
	|			ТочкаПоставки В
	|				(ВЫБРАТЬ
	|					ТочкиПоставокТочекУчетаСтроений.ТочкаПоставки
	|				ИЗ
	|					ТочкиПоставокТочекУчетаСтроений КАК ТочкиПоставокТочекУчетаСтроений)) КАК энргАктивностьТочекПоставкиСрезПоследних
	|ГДЕ
	|	энргАктивностьТочекПоставкиСрезПоследних.Состояние";
	
	Возврат Текст;
	
КонецФункции

