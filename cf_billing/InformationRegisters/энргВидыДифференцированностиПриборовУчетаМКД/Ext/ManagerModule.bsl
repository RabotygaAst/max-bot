#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет вид дифференцированности введенных приборов.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ВидДифференцированностиВведенныхПриборов(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		РегистрыСведений.энргПриборыТочекМКД.ПриборыДействующихТочек(Схема,ПараметрыОтбора,"ВведенныеПриборыДействующихТочекМКД");
	Иначе
		ЕстьВведенныеПриборыДействующихТочек			= Ложь;
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "ВведенныеПриборыДействующихТочекМКД" Тогда
				ЕстьВведенныеПриборыДействующихТочек 	= Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
		
		Если НЕ ЕстьВведенныеПриборыДействующихТочек Тогда
			РегистрыСведений.энргПриборыТочекМКД.ПриборыДействующихТочек(Схема,ПараметрыОтбора,"ВведенныеПриборыДействующихТочекМКД");
		КонецЕсли;	
	КонецЕсли; 
	
	Пакет 											= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаВидДифференцированностиВведенныхПриборов());
	Пакет.ТаблицаДляПомещения 						= ТаблицаДляПомещения;
	ОператорВыбора 									= Пакет.Операторы[0];	
	Источник 										= ОператорВыбора.Источники[0].Источник;
	Параметры 										= Источник.Параметры;
	
	ПараметрПериод 									= Параметры[0];
	
	Если НЕ ПараметрыОтбора.Свойство("Период") Тогда
		ПараметрПериод.Выражение 					= Новый ВыражениеСхемыЗапроса("");
	ИначеЕсли НЕ ПараметрыОтбора["Период"].ИмяПараметра = "Период" Тогда
		ПараметрПериод.Выражение 					= Новый ВыражениеСхемыЗапроса(СтрЗаменить(ПараметрПериод.Выражение,"&Период","&" + ПараметрыОтбора["Период"].ИмяПараметра));		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 					= "Организация, Район, МКД, ПриборУчета";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(ОператорВыбора.Источники[0].Источник.Параметры[1],ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);		
	КонецЕсли;

	ВспомогательныеПоля 							= "Период,Регистратор,НомерСтроки,Активность,ПериодРегистрации,ПериодНачисления";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 						= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 								= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаВидДифференцированностиВведенныхПриборов()
	Текст  = 
	"ВЫБРАТЬ
	|	ВидыДифференцированностиПриборовУчетаМКДСрезПоследних.Организация КАК Организация,
	|	ВидыДифференцированностиПриборовУчетаМКДСрезПоследних.Район КАК Район,
	|	ВидыДифференцированностиПриборовУчетаМКДСрезПоследних.МКД КАК МКД,
	|	ВидыДифференцированностиПриборовУчетаМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	ВидыДифференцированностиПриборовУчетаМКДСрезПоследних.Шкала КАК Шкала,
	|	ВидыДифференцированностиПриборовУчетаМКДСрезПоследних.ВидДифференцированности КАК ВидДифференцированности
	|ИЗ
	|	РегистрСведений.энргВидыДифференцированностиПриборовУчетаМКД.СрезПоследних(
	|			&Период,
	|			(Организация, Район, МКД, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						ВведенныеПриборыДействующихТочекМКД.Организация,
	|						ВведенныеПриборыДействующихТочекМКД.Район,
	|						ВведенныеПриборыДействующихТочекМКД.МКД,
	|						ВведенныеПриборыДействующихТочекМКД.ПриборУчета
	|					ИЗ
	|						ВведенныеПриборыДействующихТочекМКД КАК ВведенныеПриборыДействующихТочекМКД)) КАК ВидыДифференцированностиПриборовУчетаМКДСрезПоследних";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#КонецЕсли