#Область ПрограммныйИнтерфейс

// Получает длину ЛС.
//
// Параметры:
//  Организация	-	СправочникСсылка.Организации.
//  Дата		-	Дата.
// 
// Возвращаемое значение:
//   Число.
//
Функция ПолучитьДлинуЛС(Знач Организация,Дата = Неопределено) Экспорт
	
	Период 			= ТекущаяДата();
	Если НЕ Дата = Неопределено Тогда
		Период 		= Дата;
	КонецЕсли;
	
	ДлинаЛС			= 14;
	Запрос			= Новый Запрос;
	Запрос.УстановитьПараметр("Организация",Организация); 
	Запрос.УстановитьПараметр("Период",Период);
	ЗАпрос.Текст = 
	"ВЫБРАТЬ
	|	ДлинаЛицевогоСчетаСрезПоследних.ДлинаЛС КАК ДлинаЛС
	|ИЗ
	|	РегистрСведений.энргДлинаЛицевогоСчета.СрезПоследних(&Период, Организация = &Организация) КАК ДлинаЛицевогоСчетаСрезПоследних";
	Результат 	= Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат ДлинаЛС;
	КонецЕсли;
	
	Выборка		= Результат.Выбрать();
	Выборка.Следующий();	
	ДлинаЛС 	= Выборка.ДлинаЛС;	
	Возврат ДлинаЛС;
КонецФункции

#КонецОбласти

#КонецЕсли