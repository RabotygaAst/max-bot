#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

Функция АктуальныеДанныеСрезПоследних(Схема, ПараметрыОтбора, ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		Схема = Новый СхемаЗапроса;
		Пакет = Схема.ПакетЗапросов[0];
	Иначе
		Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаАктуальныеДанныеСрезПоследних());
	Пакет.ТаблицаДляПомещения 	= ТаблицаДляПомещения;
	ОператорВыбора 				= Пакет.Операторы[0];	
	Источник 					= ОператорВыбора.Источники[0].Источник;
	Параметры 					= Источник.Параметры;
	
	Если ПараметрыОтбора.Свойство("Период") И Не ПустаяСтрока(ПараметрыОтбора.Период.ИмяПараметра) Тогда
		ПараметрПериод = Параметры[0];
		ПараметрПериод.Выражение = Новый ВыражениеСхемыЗапроса("&" + ПараметрыОтбора["Период"].ИмяПараметра);		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		
		ДоступныеПараметры = "Организация, Район, ГруппаПотребителей, Услуга, Поставщик, ТарифнаяЗона, Диапазон";
		
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(
		Источник.Параметры[1],
		ПараметрыОтбора.ПараметрыВТ,
		ДоступныеПараметры);		
					
	КонецЕсли;	 	
		
	ВспомогательныеПоля = "Период,Регистратор,НомерСтроки,Активность";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение = Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗначенияТекущихТарифовКоллекцияПериодов(Схема, ПараметрыОтбора, ТаблицаПериодов, ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		Схема = Новый СхемаЗапроса;
		Пакет = Схема.ПакетЗапросов[0];
	Иначе
		Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТексЗапросаЗначенияТекущихТарифовКоллекцияПериодов());
	Пакет.ТаблицаДляПомещения 	= ТаблицаДляПомещения;
	ОператорВыбора 				= Пакет.Операторы[0].Источники[0].Источник.Запрос.Операторы[0];	
	Источник 					= ОператорВыбора.Источники[0].Источник;
	Параметры 					= Источник.Параметры;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		
		ДоступныеПараметры 	= "Организация, Район, ГруппаПотребителей, Услуга, Поставщик, ТарифнаяЗона, Диапазон";
		ИмяТаблицы 			= "энргЗначенияТарифовДиапазоновДифференцированногоТарифа";
		
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(
		ОператорВыбора.Отбор,
		ИмяТаблицы,
		ПараметрыОтбора.ПараметрыВТ,
		ДоступныеПараметры);
		
	КонецЕсли;	 	
	
	ВспомогательныеПоля = "Период,НомерСтроки,Активность";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение = Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры

Функция ТекстЗапросаАктуальныеДанныеСрезПоследних() Экспорт
	
	Текст = 
	"ВЫБРАТЬ
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.Организация КАК Организация,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.Район КАК Район,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.ГруппаПотребителей КАК ГруппаПотребителей,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.Услуга КАК Услуга,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.Поставщик КАК Поставщик,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.ТарифнаяЗона КАК ТарифнаяЗона,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.Диапазон КАК Диапазон,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.Значение КАК Значение,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.СтавкаНДС КАК СтавкаНДС,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних.НДСВнутри КАК НДСВнутри
	|ИЗ
	|	РегистрСведений.энргЗначенияТарифовДиапазоновДифференцированногоТарифа.СрезПоследних КАК энргЗначенияТарифовДиапазоновДифференцированногоТарифаСрезПоследних";
	
	Возврат Текст;
	
КонецФункции

Функция ТексЗапросаЗначенияТекущихТарифовКоллекцияПериодов() Экспорт
	
	Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.ГруппаПотребителей КАК ГруппаПотребителей,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.Поставщик КАК Поставщик,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ВложенныйЗапрос.Диапазон КАК Диапазон,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Значение КАК Значение,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифа.СтавкаНДС КАК СтавкаНДС,
	|	энргЗначенияТарифовДиапазоновДифференцированногоТарифа.НДСВнутри КАК НДСВнутри
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаПериодов.ПериодНачисления КАК ПериодНачисления,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Организация КАК Организация,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Район КАК Район,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.ГруппаПотребителей КАК ГруппаПотребителей,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Услуга КАК Услуга,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Поставщик КАК Поставщик,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.ТарифнаяЗона КАК ТарифнаяЗона,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Диапазон КАК Диапазон,
	|		МАКСИМУМ(энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Период) КАК Период
	|	ИЗ
	|		РегистрСведений.энргЗначенияТарифовДиапазоновДифференцированногоТарифа КАК энргЗначенияТарифовДиапазоновДифференцированногоТарифа
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПериодов КАК ТаблицаПериодов
	|			ПО энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Организация = ТаблицаПериодов.Организация
	|				И энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Район = ТаблицаПериодов.Район
	|				И энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Период < ТаблицаПериодов.ЗавершениеОП
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ТаблицаПериодов.ПериодНачисления,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Организация,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Район,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.ГруппаПотребителей,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Услуга,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Поставщик,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.ТарифнаяЗона,
	|		энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Диапазон) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргЗначенияТарифовДиапазоновДифференцированногоТарифа КАК энргЗначенияТарифовДиапазоновДифференцированногоТарифа
	|		ПО ВложенныйЗапрос.Организация = энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Организация
	|			И ВложенныйЗапрос.Район = энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Район
	|			И ВложенныйЗапрос.ГруппаПотребителей = энргЗначенияТарифовДиапазоновДифференцированногоТарифа.ГруппаПотребителей
	|			И ВложенныйЗапрос.Услуга = энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Услуга
	|			И ВложенныйЗапрос.Поставщик = энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Поставщик
	|			И ВложенныйЗапрос.ТарифнаяЗона = энргЗначенияТарифовДиапазоновДифференцированногоТарифа.ТарифнаяЗона
	|			И ВложенныйЗапрос.Диапазон = энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Диапазон
	|			И ВложенныйЗапрос.Период = энргЗначенияТарифовДиапазоновДифференцированногоТарифа.Период";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#КонецЕсли