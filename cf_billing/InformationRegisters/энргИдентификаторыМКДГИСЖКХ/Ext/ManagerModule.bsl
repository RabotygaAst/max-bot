#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗаполнитьСхемуИдентификаторыМКД(Схема,ПараметрыСхемы,ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		Схема 								= Новый СхемаЗапроса;
		Пакет 								= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 								= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаЗаполнитьСхемуИдентификаторыМКД());
	Пакет.ТаблицаДляПомещения 				= ТаблицаДляПомещения;
		
	Если ПараметрыСхемы.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 					= "МКД";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(Пакет.Операторы[0].Отбор, "ИдентификаторыМКДГИСЖКХ", ПараметрыСхемы.ПараметрыВТ, ДоступныеПараметры);		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаЗаполнитьСхемуИдентификаторыМКД()
	
	Текст =
	"ВЫБРАТЬ
	|	ИдентификаторыМКДГИСЖКХ.МКД КАК Строение,
	|	ИдентификаторыМКДГИСЖКХ.ИдентификаторДомаФИАС КАК ИдентификаторДомаФИАС,
	|	ИдентификаторыМКДГИСЖКХ.ОКТМО КАК ОКТМО
	|ИЗ
	|	РегистрСведений.энргИдентификаторыМКДГИСЖКХ КАК ИдентификаторыМКДГИСЖКХ";
	
	Возврат Текст;
	
КонецФункции 

#КонецОбласти

#КонецЕсли