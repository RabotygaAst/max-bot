
#Область СтандартныеПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Отбор.Свойство("Абонент") тогда
		Район = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.Отбор.Абонент,"Район");
		Параметры.Отбор.Вставить("Район",Район);
	КонецЕсли;  	
КонецПроцедуры


#КонецОбласти


