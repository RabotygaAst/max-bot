// Получает категории напряжения.
//
// Параметры:
//  Период	-	Дата.
//  мТочек	-	Массив из СправочникСсылка.энргТочкиУчета.
// 
// Возвращаемое значение:
//   Соответствие.
//
Функция ПолучитьКатегорииНапряжения(Период, мТочек) Экспорт
	СоответствиеКатегорий = Новый Соответствие;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргКатегорииНадежностиТочекПоставокСрезПоследних.ТочкаПоставки КАК ТочкаПоставки,
		|	энргКатегорииНадежностиТочекПоставокСрезПоследних.КатегорияНадежности КАК КатегорияНадежности,
		|	энргКатегорииНадежностиТочекПоставокСрезПоследних.ВТомЧисле КАК ВТомЧисле
		|ИЗ
		|	РегистрСведений.энргКатегорииНадежностиТочекПоставок.СрезПоследних(&Период, ТочкаПоставки В (&мТочек)) КАК энргКатегорииНадежностиТочекПоставокСрезПоследних
		|
		|УПОРЯДОЧИТЬ ПО
		|	КатегорияНадежности
		|ИТОГИ ПО
		|	ТочкаПоставки";
	
	Запрос.УстановитьПараметр("мТочек", мТочек);
	Запрос.УстановитьПараметр("Период", Период);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаТочкаПоставки = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаТочкаПоставки.Следующий() Цикл
		
		КатегорииНапряжения = "";
		
		ВыборкаДетальныеЗаписи = ВыборкаТочкаПоставки.Выбрать();
	
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			КатегорииНапряжения = КатегорииНапряжения + ?(КатегорииНапряжения <> "", ",", "") + ?(ВыборкаДетальныеЗаписи.ВТомЧисле, "(" + ВыборкаДетальныеЗаписи.КатегорияНадежности + ")", ВыборкаДетальныеЗаписи.КатегорияНадежности); 
		КонецЦикла;
		
		СоответствиеКатегорий.Вставить(ВыборкаТочкаПоставки.ТочкаПоставки, КатегорииНапряжения);

	КонецЦикла;

	Возврат СоответствиеКатегорий;
КонецФункции

#КонецОбласти

#КонецЕсли