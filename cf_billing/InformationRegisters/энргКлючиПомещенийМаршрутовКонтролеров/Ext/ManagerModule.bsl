// Регистрирует ключ помещения в маршруте контролера.
//
// Параметры:
//  МаршрутКонтролера	-	СправочникСсылка.энргМаршрутыКонтроллеров.
//  КлючПомещения		-	СправочникСсылка.энргКлючиПомещений.
//
Процедура ЗарегистрироватьКлючПомещенияВМаршрутеКонтролера(МаршрутКонтролера, КлючПомещения) Экспорт 
	Набор = СоздатьНаборЗаписей();
	Набор.Отбор.КлючПомещения.Установить(КлючПомещения);
	Набор.Прочитать();
	Набор.Очистить();
	
	НСтрока = Набор.Добавить();
	НСтрока.МаршрутКонтролера 	= МаршрутКонтролера;
	НСтрока.КлючПомещения		= КлючПомещения;
	
	Попытка
		Набор.Записать();
	Исключение		
	КонецПопытки;	
КонецПроцедуры

