#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет назначения ПУ точек учета.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура НазначенияПУТочекУчета(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "") Экспорт 
	
	Если Схема = Неопределено Тогда
		РегистрыСведений.энргАктивностьТочекУчета.АктивныеТочкиУчетаПомещения(Схема,ПараметрыОтбора,"ДействующиеТочки");
	Иначе
		ЕстьДействующиеТочки 			= Ложь;
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "ДействующиеТочки" Тогда
				ЕстьДействующиеТочки 	= Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
		
		Если НЕ ЕстьДействующиеТочки Тогда
			РегистрыСведений.энргАктивностьТочекУчета.АктивныеТочкиУчетаПомещения(Схема,ПараметрыОтбора,"ДействующиеТочки");
		КонецЕсли;
	КонецЕсли; 	
	
	Пакет 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаНазначенияПриборовУчета());
	
КонецПроцедуры

// Заполняет назначения ПУ срез.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Функция НазначенияПУСрез(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаНазначенияПУСрез());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	ОператорВыбора 					= Пакет.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;		
	
	Если ПараметрыОтбора.Свойство("Период") И Не ПустаяСтрока(ПараметрыОтбора.Период.ИмяПараметра) Тогда
		ПараметрПериод 				= Параметры[0];
		ПараметрПериод.Выражение 	= Новый ВыражениеСхемыЗапроса("&" + ПараметрыОтбора["Период"].ИмяПараметра);		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ЕстьОтборПоКлючамПомещений") И ПараметрыОтбора.ЕстьОтборПоКлючамПомещений Тогда
		НовыйИсточник 			= ОператорВыбора.Источники.Добавить("ЗначенияКлючейПомещений", "энргКлючиПомещений");
		
		СоотвествиеУсловий	= Новый Соответствие;
		СоотвествиеУсловий.Вставить("Помещение", "Помещение");
		СоотвествиеУсловий.Вставить("Строение", "Строение");
		МассивУсловий		= Новый Массив;
		МассивУсловий.Добавить(Новый Структура("ТипУсловия,СоотвествиеУсловий","ТипУсловияРавно", СоотвествиеУсловий));
		
		энргФормированиеТекстовЗапроса.УстановитьИсточникЗапроса(ОператорВыбора.Источники[0], НовыйИсточник, ТипСоединенияСхемыЗапроса.Внутреннее, МассивУсловий);  
		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация, Район, ЧастныйСектор, Строение, Помещение, ТочкаУчета, НазначениеПУ";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(ОператорВыбора.Источники[0].Источник.Параметры[1],ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);		
		Для Сч = 0 По ПараметрыОтбора.ПараметрыВТ.ВГраница() Цикл
			Если ПараметрыОтбора.ПараметрыВТ[Сч].ТипПараметра = "ТипПараметраВременнаяТаблица" Тогда
				Пакет.Операторы[0].Отбор.Очистить();
				СоотвествиеПолей 			= ПараметрыОтбора.ПараметрыВТ[Сч].СоотвествиеПолей;
				ОтборДляУстановки 			= Новый Структура("ИмяПараметра,ТипПараметра,СоотвествиеПолей", ПараметрыОтбора.ПараметрыВТ[Сч].ИмяПараметра,"ТипПараметраВременнаяТаблица", СоотвествиеПолей);
				энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(Пакет.Операторы[0].Отбор,"энргНазначенияПриборовУчетаСрезПоследних",ОтборДляУстановки, "");
			КонецЕсли;			
		КонецЦикла;		
	КонецЕсли;	 	
		
	ВспомогательныеПоля 			= "Период,Регистратор,НомерСтроки,Активность";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 		= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 				= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;

	
КонецФункции

// Заполняет назначения ПУ коллекция периодов.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаПериодов		-	Строка.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура НазначенияПУКоллекцияПериодов(Схема, ПараметрыОтбора, ТаблицаПериодов, ТаблицаДляПомещения = "") Экспорт 
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаНазначенияПУКоллекцияПериодов());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;	
	ОператорВыбора 					= Пакет.Операторы[0].Источники[0].Источник.Запрос.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация, Район, ЧастныйСектор, Строение, Помещение";
		ИмяТаблицы 					= "энргНазначенияПриборовУчета";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОператорВыбора.Отбор,ИмяТаблицы,ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);				
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Получает текст запроса назначения ПУ срез.
// 
// Возвращаемое значение:
//   Строка.
//
Функция ТекстЗапросаНазначенияПУСрез() Экспорт
	
	Текст = 
	"ВЫБРАТЬ
	|	*
	|ИЗ
	|	РегистрСведений.энргНазначенияПриборовУчета.СрезПоследних КАК энргНазначенияПриборовУчетаСрезПоследних";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаНазначенияПриборовУчета()
	
	Текст  =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(энргНазначенияПриборовУчетаСрезПоследних.НазначениеПУ, ЗНАЧЕНИЕ(Перечисление.энргНазначениеПУ.пустаяссылка)) КАК НазначениеПУ,
	|	ДействующиеТочки.ТочкаУчета КАК ТочкаУчета
	|ИЗ
	|	ДействующиеТочки КАК ДействующиеТочки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргНазначенияПриборовУчета.СрезПоследних(
	|				&Период,
	|				(Организация, Район, ТочкаУчета) В
	|					(ВЫБРАТЬ
	|						ДействующиеТочки.Организация,
	|						ДействующиеТочки.Район,
	|						ДействующиеТочки.ТочкаУчета
	|					ИЗ
	|						ДействующиеТочки КАК ДействующиеТочки)) КАК энргНазначенияПриборовУчетаСрезПоследних
	|		ПО ДействующиеТочки.Организация = энргНазначенияПриборовУчетаСрезПоследних.Организация
	|			И ДействующиеТочки.Район = энргНазначенияПриборовУчетаСрезПоследних.Район
	|			И ДействующиеТочки.ТочкаУчета = энргНазначенияПриборовУчетаСрезПоследних.ТочкаУчета";
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаНазначенияПУКоллекцияПериодов()
	Текст = 
	"ВЫБРАТЬ
	|	энргНазначенияПриборовУчета.Организация КАК Организация,
	|	энргНазначенияПриборовУчета.Район КАК Район,
	|	энргНазначенияПриборовУчета.ЧастныйСектор КАК ЧастныйСектор,
	|	энргНазначенияПриборовУчета.Строение КАК Строение,
	|	энргНазначенияПриборовУчета.Помещение КАК Помещение,
	|	энргНазначенияПриборовУчета.ТочкаУчета КАК ТочкаУчета,
	|	энргНазначенияПриборовУчета.НазначениеПУ КАК НазначениеПУ
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргНазначенияПриборовУчета.Организация КАК Организация,
	|		энргНазначенияПриборовУчета.Район КАК Район,
	|		МАКСИМУМ(энргНазначенияПриборовУчета.Период) КАК Период,
	|		энргНазначенияПриборовУчета.ЧастныйСектор КАК ЧастныйСектор,
	|		энргНазначенияПриборовУчета.Строение КАК Строение,
	|		энргНазначенияПриборовУчета.Помещение КАК Помещение,
	|		энргНазначенияПриборовУчета.ТочкаУчета КАК ТочкаУчета
	|	ИЗ
	|		РегистрСведений.энргНазначенияПриборовУчета КАК энргНазначенияПриборовУчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПериодов КАК ТаблицаПериодов
	|			ПО энргНазначенияПриборовУчета.Период < ТаблицаПериодов.ЗавершениеОП
	|				И энргНазначенияПриборовУчета.Организация = ТаблицаПериодов.Организация
	|				И энргНазначенияПриборовУчета.Район = ТаблицаПериодов.Район
	|	
	|	СГРУППИРОВАТЬ ПО
	|		энргНазначенияПриборовУчета.Организация,
	|		энргНазначенияПриборовУчета.Район,
	|		энргНазначенияПриборовУчета.ЧастныйСектор,
	|		энргНазначенияПриборовУчета.Строение,
	|		энргНазначенияПриборовУчета.Помещение,
	|		энргНазначенияПриборовУчета.ТочкаУчета) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргНазначенияПриборовУчета КАК энргНазначенияПриборовУчета
	|		ПО ВложенныйЗапрос.Организация = энргНазначенияПриборовУчета.Организация
	|			И ВложенныйЗапрос.Район = энргНазначенияПриборовУчета.Район
	|			И ВложенныйЗапрос.Период = энргНазначенияПриборовУчета.Период
	|			И ВложенныйЗапрос.ЧастныйСектор = энргНазначенияПриборовУчета.ЧастныйСектор
	|			И ВложенныйЗапрос.Строение = энргНазначенияПриборовУчета.Строение
	|			И ВложенныйЗапрос.Помещение = энргНазначенияПриборовУчета.Помещение
	|			И ВложенныйЗапрос.ТочкаУчета = энргНазначенияПриборовУчета.ТочкаУчета";
	
	Возврат Текст;
КонецФункции

#КонецОбласти

#КонецЕсли