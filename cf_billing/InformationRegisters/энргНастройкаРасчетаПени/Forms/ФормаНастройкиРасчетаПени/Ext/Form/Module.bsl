#Область СобытияФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ПолучитьЗначениеНастройки();
	
	// ++ Акимов Д.В.
	// Настройка доступности в зависимости от прав
	СписокЭлементов = Новый Структура("Период, ТаблицаРасчётаПени");
	энргОбщегоНазначения.УстановитьДоступностьЭлементовПоРолям(ЭтаФорма, СписокЭлементов, Метаданные.РегистрыСведений.энргНастройкаРасчетаПени);
	// -- Акимов Д.В.
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если Модифицированность Тогда
		Отказ = Истина;
		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаОтветаПриЗакрытии", ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения, "Данные были изменены. Сохранить изменения?", РежимДиалогаВопрос.ДаНетОтмена);
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#Область КомандыФормы
&НаКлиенте
Процедура ЗаписатьИЗакрытьРС(Команда)
	ЗаписатьРС(Команда);
	Если Не Модифицированность Тогда
		Закрыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьРС(Команда)
	
	ПредДо = Неопределено;
	Сч = 0;
	Отказ = Ложь;
	
	Если Не ЗначениеЗаполнено(Период) Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Поле ""Период"" не заполнено";
		Сообщение.Поле = "Период";
		Сообщение.УстановитьДанные(ЭтаФорма);
		Сообщение.Сообщить();
		
		Отказ = Истина;
	
	КонецЕсли;
	
	Для каждого СтрокаТЗ Из ТаблицаРасчётаПени Цикл
		ТекстСообщения	= "";
		ПолеСообщения	= "";
		Если СтрокаТЗ.До = ПредДо Тогда
			ПолеСообщения = "До";
		
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Уже есть запись с таким ""До"".";
			Сообщение.Поле = "ТаблицаРасчётаГоспошлины[" + Сч + "]." + ПолеСообщения;
			Сообщение.УстановитьДанные(ЭтаФорма);
			Сообщение.Сообщить();
			
			Отказ = Истина;
			ВыдатьСообщение = Истина;
		КонецЕсли;
		
		ПредДо	= СтрокаТЗ.До;
		Сч		= Сч + 1;
	КонецЦикла;

	Если Не Отказ Тогда
		ЗаписатьНаСервере();
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#Область СобытияЭлементовФормы
&НаКлиенте
Процедура ТаблицаРасчётаТаблицаРасчётаПениПриИзменении(Элемент)
	ОбновитьТаблицуРасчёта();
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаРасчётаТаблицаРасчётаПениПослеУдаления(Элемент)
	ОбновитьТаблицуРасчёта();
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаРасчётаТаблицаРасчётаПениПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ПериодПриИзменении(Элемент)
	Модифицированность = Истина;
	Период = НачалоМесяца(Период);
КонецПроцедуры
#КонецОбласти

