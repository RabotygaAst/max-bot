&НаСервере
Процедура ПолучитьЗначениеНастройки()
	Перем ТЗ_Настройки;
	
	ЗаписьРС = РеквизитФормыВЗначение("Запись");
	
	Период		 = ЗаписьРС.Период;
	Организация	 = ЗаписьРС.Организация;
	ТЗ_Настройки = ЗаписьРС.НастройкаРасчета.Получить();

	Если ТЗ_Настройки <> Неопределено Тогда
		ЗначениеВРеквизитФормы(ТЗ_Настройки, "ТаблицаРасчётаПени");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаписатьНаСервере()
	Перем ТЗ_Настройки;
	
	ЗаписьРС = РеквизитФормыВЗначение("Запись");
	ТЗ_Настройки = РеквизитФормыВЗначение("ТаблицаРасчётаПени");
	Хранилище = Новый ХранилищеЗначения(ТЗ_Настройки);
	
	ЗаписьРС.Период = Период;
	ЗаписьРС.Организация = Организация;
	ЗаписьРС.НастройкаРасчета = Хранилище;
	ЗаписьРС.Записать(Ложь);
	
	Модифицированность = Ложь; 
	
	ПолучитьЗначениеНастройки();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОтветаПриЗакрытии(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда 
		ЗаписатьИЗакрытьРС(Неопределено);
	ИначеЕсли РезультатВопроса = КодВозвратаДиалога.Нет Тогда 
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти





