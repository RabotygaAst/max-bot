#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет номера пломб введенных приборов действующих точек.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура НомераПломбВведенныхПриборовДействующихТочек(Схема, ПараметрыОтбора, ТаблицаДляПомещения = "") Экспорт
	ПредыдущееИмяТаблицы 	= "ВведенныеПриборыДействующихТочек";
	ИспользоватьУзлыМКД		= энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыМКД();
	Если Схема = Неопределено Тогда
		ПолучитьСхемуАктивныхПриборовУчета(Схема, ПараметрыОтбора, ПредыдущееИмяТаблицы, ИспользоватьУзлыМКД);
	Иначе
		ЕстьДействующиеНомераПозицииПломб	= Ложь;
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = ПредыдущееИмяТаблицы Тогда
				ЕстьДействующиеНомераПозицииПломб = Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
		
		Если НЕ ЕстьДействующиеНомераПозицииПломб Тогда
			ПолучитьСхемуАктивныхПриборовУчета(Схема, ПараметрыОтбора, ПредыдущееИмяТаблицы, ИспользоватьУзлыМКД);
		КонецЕсли; 		 		
	КонецЕсли;
		
	Пакет 								= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));		
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаНомераПломбВведенныхПриборовДействующихТочек(ИспользоватьУзлыМКД));
	Пакет.ТаблицаДляПомещения 			= ТаблицаДляПомещения;
	Пакет.ВыбиратьРазрешенные 			= ?(ПараметрыОтбора.Свойство("ВыбиратьРазрешенные") и НЕ ПараметрыОтбора.ВыбиратьРазрешенные, ЛОЖЬ, ИСТИНА);
	
	ОператорВыбора 						= Пакет.Операторы[0];	
	Источник 							= ОператорВыбора.Источники[0].Источник;
	Параметры 							= Источник.Запрос.Операторы[0].Источники[0].Источник.Параметры;	
	ПараметрыВторойТаблицы				= Источник.Запрос.Операторы[1].Источники[0].Источник.Параметры;	
	ПараметрПериод 						= Параметры[0];
	ПараметрПериодВторойТаблицы			= Параметры[0];
	
	Если ПараметрыОтбора.Свойство("Период") Тогда
		ПараметрПериод.Выражение 				= Новый ВыражениеСхемыЗапроса("&" + ПараметрыОтбора["Период"].ИмяПараметра);
		ПараметрПериодВторойТаблицы.Выражение 	= Новый ВыражениеСхемыЗапроса("&" + ПараметрыОтбора["Период"].ИмяПараметра);		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		Отбор 							= ОператорВыбора.Отбор;		
		ДоступныеПараметры 				= "Организация, Район, МКД, ПриборУчета, МестоУстановки";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(Параметры[1], ПараметрыОтбора.ПараметрыВТ, ДоступныеПараметры);				
	КонецЕсли;
	
	ВспомогательныеПоля 				= "Период,Регистратор,НомерСтроки,Активность,ПериодРегистрации,ПериодНачисления";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 			= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 					= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПолучитьСхемуАктивныхПриборовУчета(Схема, Параметры, ПредыдущееИмяТаблицы, ИспользоватьУзлыМКД)
	Если ИспользоватьУзлыМКД Тогда
		РегистрыСведений.энргСостояниеПриборовМКД.АктивныеПриборыУчетаМКД(Схема, Параметры, ПредыдущееИмяТаблицы);
	Иначе
		РегистрыСведений.энргСостояниеПриборовМКД.ДействующиеПриборыУчетаМКД(Схема, Параметры, ПредыдущееИмяТаблицы); 		
	КонецЕсли;
КонецПроцедуры

Функция ТекстЗапросаНомераПломбВведенныхПриборовДействующихТочек(ИспользоватьУзлыМКД)
	Если ИспользоватьУзлыМКД Тогда
		Возврат ТекстЗапросаОпломбированныеПриборыУчетаСУзлом();
	Иначе		
		Возврат ТекстЗапросаОпломбированныеПриборыУчетаБезУзла();
	КонецЕсли; 	
КонецФункции

Функция ТекстЗапросаОпломбированныеПриборыУчетаБезУзла()
	
	Текст  =
	"ВЫБРАТЬ
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.Организация КАК Организация,
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.Район КАК Район,
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.МКД КАК МКД,
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.МестоУстановки КАК МестоУстановки,
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.НомерПломбы КАК НомерПломбы
	|ИЗ
	|	РегистрСведений.энргНомерПломбПриборовУчетаМКД.СрезПоследних(
	|			,
	|			(Организация, Район, МКД, ПриборУчета) В
	|				(ВЫБРАТЬ
	|					ВведенныеПриборыДействующихТочек.Организация,
	|					ВведенныеПриборыДействующихТочек.Район,
	|					ВведенныеПриборыДействующихТочек.МКД,
	|					ВведенныеПриборыДействующихТочек.ПриборУчета
	|				ИЗ
	|					ВведенныеПриборыДействующихТочек КАК ВведенныеПриборыДействующихТочек)) КАК энргНомерПломбПриборовУчетаМКДСрезПоследних
	|ГДЕ
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.Состояние";
	
	Возврат Текст;
КонецФункции

Функция ТекстЗапросаОпломбированныеПриборыУчетаСУзлом()
	
	Текст  =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.МестоУстановки КАК МестоУстановки,
	|	ВложенныйЗапрос.НомерПломбы КАК НомерПломбы
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.Организация КАК Организация,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.Район КАК Район,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.МКД КАК МКД,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.МестоУстановки КАК МестоУстановки,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.НомерПломбы КАК НомерПломбы
	|	ИЗ
	|		РегистрСведений.энргНомерПломбПриборовУчетаМКД.СрезПоследних(
	|				,
	|				(Организация, Район, МКД, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						ВведенныеПриборыДействующихТочек.Организация,
	|						ВведенныеПриборыДействующихТочек.Район,
	|						ВведенныеПриборыДействующихТочек.МКД,
	|						ВведенныеПриборыДействующихТочек.ПриборУчета
	|					ИЗ
	|						ВведенныеПриборыДействующихТочек КАК ВведенныеПриборыДействующихТочек)) КАК энргНомерПломбПриборовУчетаМКДСрезПоследних
	|	ГДЕ
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.Состояние
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.Организация,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.Район,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.МКД,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.ПриборУчета,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.МестоУстановки,
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.НомерПломбы
	|	ИЗ
	|		РегистрСведений.энргНомерПломбПриборовУчетаМКД.СрезПоследних(
	|				,
	|				(Организация, Район, МКД, ПриборУчета) В
	|					(ВЫБРАТЬ
	|						ВведенныеПриборыДействующихТочек.Организация,
	|						ВведенныеПриборыДействующихТочек.Район,
	|						ВведенныеПриборыДействующихТочек.МКД,
	|						ВведенныеПриборыДействующихТочек.ПриборУчета
	|					ИЗ
	|						ВведенныеПриборыДействующихТочек КАК ВведенныеПриборыДействующихТочек)) КАК энргНомерПломбПриборовУчетаМКДСрезПоследних
	|	ГДЕ
	|		энргНомерПломбПриборовУчетаМКДСрезПоследних.Состояние) КАК ВложенныйЗапрос";
	
	Возврат Текст;
КонецФункции

#КонецОбласти

#КонецЕсли