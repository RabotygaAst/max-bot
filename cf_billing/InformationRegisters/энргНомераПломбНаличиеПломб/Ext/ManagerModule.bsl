#Область ПрограммныйИнтерфейс

// Заполняет опломбированные приборы учета.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ОпломбированныеПриборыУчета(Схема, ПараметрыОтбора, ТаблицаДляПомещения = "ОпломбированныеПриборыУчета") Экспорт
	
	Если Схема = Неопределено Тогда
		РегистрыСведений.энргСостояниеПриборовУчетаАбонента.ДействующиеПриборыУчетаПомещения(Схема, ПараметрыОтбора, "ДействующиеПриборыУчетаПомещения");		
	Иначе
		ЕстьДействующиеПриборыУчетаПомещения 		= Ложь;
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "ДействующиеПриборыУчетаПомещения" Тогда
				ЕстьДействующиеПриборыУчетаПомещения = Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
		
		Если НЕ ЕстьДействующиеПриборыУчетаПомещения Тогда
			РегистрыСведений.энргСостояниеПриборовУчетаАбонента.ДействующиеПриборыУчетаПомещения(Схема, ПараметрыОтбора, "ДействующиеПриборыУчетаПомещения");		
		КонецЕсли; 		 		
	КонецЕсли;
		    	
	ЕстьТекущийСоставУзла		 		= Ложь;
	Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
		Если яПакет.ТаблицаДляПомещения  = "ТекущийСоставУзла" Тогда
			ЕстьТекущийСоставУзла = Истина;
			Прервать;
		КонецЕсли;		
	КонецЦикла;
	
	Если НЕ ЕстьТекущийСоставУзла Тогда
		РегистрыСведений.энргСоставУзлаУчетаПомещения.ТекущийСоставУзла(Схема, ПараметрыОтбора, "ТекущийСоставУзла");		
	КонецЕсли;
	
	Пакет 								= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));		
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаОпломбированныеПриборыУчета());
	Пакет.ТаблицаДляПомещения 			= ТаблицаДляПомещения;
	Пакет.ВыбиратьРазрешенные 			= ?(ПараметрыОтбора.Свойство("ВыбиратьРазрешенные") и НЕ ПараметрыОтбора.ВыбиратьРазрешенные, ЛОЖЬ, ИСТИНА);
	
	ОператорВыбора 						= Пакет.Операторы[0];	
	Источник 							= ОператорВыбора.Источники[0].Источник;
	Параметры 							= Источник.Параметры;	
	ПараметрПериод 						= Параметры[0];
	
	Если НЕ ПараметрыОтбора.Свойство("Период") Тогда
		ПараметрПериод.Выражение 			= Новый ВыражениеСхемыЗапроса("");
	ИначеЕсли НЕ ПараметрыОтбора["Период"].ИмяПараметра = "Период" Тогда
		ПараметрПериод.Выражение 		= Новый ВыражениеСхемыЗапроса(СтрЗаменить(ПараметрПериод.Выражение,"&Период","&" + ПараметрыОтбора["Период"].ИмяПараметра));		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		Отбор 							= ОператорВыбора.Отбор;		
		ДоступныеПараметры 				= "Организация, Район, КлючПомещения, ПриборУчета";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(Параметры[1],ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);				
	КонецЕсли;
	
	ВспомогательныеПоля 				= "Период,Регистратор,НомерСтроки,Активность,ПериодРегистрации,ПериодНачисления";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 			= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 					= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаОпломбированныеПриборыУчета()
	
	Текст  =
	"ВЫБРАТЬ
	|	энргНомераПломбНаличиеПломбСрезПоследних.Организация КАК Организация,
	|	энргНомераПломбНаличиеПломбСрезПоследних.Район КАК Район,
	|	энргНомераПломбНаличиеПломбСрезПоследних.КлючПомещения КАК КлючПомещения,
	|	энргНомераПломбНаличиеПломбСрезПоследних.ПриборУчета КАК ПриборУчета
	|ИЗ
	|	РегистрСведений.энргНомераПломбНаличиеПломб.СрезПоследних(
	|			,
	|			(Организация, Район, КлючПомещения, ПриборУчета) В
	|				(ВЫБРАТЬ
	|					ДействующиеПриборыУчетаПомещения.Организация,
	|					ДействующиеПриборыУчетаПомещения.Район,
	|					ДействующиеПриборыУчетаПомещения.КлючПомещения,
	|					ДействующиеПриборыУчетаПомещения.ПриборУчета
	|				ИЗ
	|					ДействующиеПриборыУчетаПомещения КАК ДействующиеПриборыУчетаПомещения)) КАК энргНомераПломбНаличиеПломбСрезПоследних
	|ГДЕ
	|	энргНомераПломбНаличиеПломбСрезПоследних.Опломбирован
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	энргНомераПломбНаличиеПломбСрезПоследних.Организация,
	|	энргНомераПломбНаличиеПломбСрезПоследних.Район,
	|	энргНомераПломбНаличиеПломбСрезПоследних.КлючПомещения,
	|	энргНомераПломбНаличиеПломбСрезПоследних.ПриборУчета
	|ИЗ
	|	РегистрСведений.энргНомераПломбНаличиеПломб.СрезПоследних(
	|			,
	|			(Организация, Район, КлючПомещения, ПриборУчета) В
	|				(ВЫБРАТЬ
	|					ТекущийСоставУзла.Организация,
	|					ТекущийСоставУзла.Район,
	|					ТекущийСоставУзла.КлючПомещения,
	|					ТекущийСоставУзла.Измеритель
	|				ИЗ
	|					ТекущийСоставУзла КАК ТекущийСоставУзла)) КАК энргНомераПломбНаличиеПломбСрезПоследних
	|ГДЕ
	|	энргНомераПломбНаличиеПломбСрезПоследних.Опломбирован";
	
	Возврат Текст;
КонецФункции

#КонецОбласти

#КонецЕсли