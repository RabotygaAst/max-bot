#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Получает актуальные параметры точки поставки по ссылке.
//
// Параметры:
//  ТочкаПоставкиСсылка	-	СправочникСсылка.энргТочкиУчета.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция АктуальныеПараметрыТочкиПоставкиПоСсылке(ТочкаПоставкиСсылка) Экспорт 
	
	Запрос  	= Новый Запрос(ТекстЗапросаЗначенияПараметровПоСсылке());
	Запрос.УстановитьПараметр("ТочкаПоставки",ТочкаПоставкиСсылка);
	Возврат Запрос.Выполнить();
	
КонецФункции

// Заполняет схему актуальные параметры точки поставки.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ЗаполнитьСхемуАктуальныеПараметрыТочкиПоставки(Схема, ПараметрыСхемы, ТаблицаДляПомещения = "") Экспорт 
	
	Если Схема = Неопределено Тогда
		Схема  	= Новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить();
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаАктуальныеПараметрыТочкиПоставки());
	Пакет.ТаблицаДляПомещения = "ДанныеРС";
	Операторы = Пакет.Операторы;
	ПараметрыИсточника = Операторы[0].Источники[0].Источник.Параметры;
	
	
	Если ПараметрыСхемы.Свойство("ПараметрыВТ") Тогда
		ОтборПакета 		= Операторы[0].Отбор;
		ДоступныеПоляОтбора = "ТочкаПоставки";
		ПараметрИсточника 	= ПараметрыИсточника[1];
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(ПараметрИсточника, ПараметрыСхемы.ПараметрыВТ, ДоступныеПоляОтбора);
	КонецЕсли;	
	
КонецПроцедуры 

// Получает максимальную мощность.
//
// Параметры:
//  Период			-	Дата.
//  мТочкиПоставки	-	Массив из СправочникСсылка.энргТочкиУчета.
// 
// Возвращаемое значение:
//   Число.
//
Функция ПолучитьМаксимальнуюМощность(Период, мТочкиПоставки) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаМаксимальнаяМощность();
	
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("ТочкиПоставки", мТочкиПоставки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.МаксимальнаяМощность; 
	КонецЦикла;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Заполняет актуальные параметры точки поставки помещения.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура АктуальныеПараметрыТочкиПоставкиПомещения(Схема, ПараметрыОтбора, ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		РегистрыСведений.энргАктивностьТочекПоставки.АктивныеТочкиПоставокПомещения(Схема,ПараметрыОтбора, "АктивныеТочкиПоставок");
	Иначе
		ЕстьДействующиеТочки 			= Ложь;
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "АктивныеТочкиПоставок" Тогда
				ЕстьДействующиеТочки 	= Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
		
		Если НЕ ЕстьДействующиеТочки Тогда
			РегистрыСведений.энргАктивностьТочекПоставки.АктивныеТочкиПоставокПомещения(Схема,ПараметрыОтбора, "АктивныеТочкиПоставок");
		КонецЕсли;
	КонецЕсли;
	
	Пакет 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаАктуальныеПараметрыТочкиПоставкиПомещения());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	Пакет.ВыбиратьРазрешенные 		= ?(ПараметрыОтбора.Свойство("ВыбиратьРазрешенные") и НЕ ПараметрыОтбора.ВыбиратьРазрешенные, ЛОЖЬ, ИСТИНА);
	ОператорВыбора 					= Пакет.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;
	
	ПараметрПериод 					= Параметры[0];
	
	Если ПараметрыОтбора.Свойство("Период") Тогда
		ПараметрПериод.Выражение 		= Новый ВыражениеСхемыЗапроса(СтрШаблон("&%1",ПараметрыОтбора["Период"].ИмяПараметра));		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 					= "ТочкаПоставки";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(ОператорВыбора.Источники[0].Источник.Параметры[1], ПараметрыОтбора.ПараметрыВТ, ДоступныеПараметры);		
	КонецЕсли;
	
	ВспомогательныеПоля 			= "Период,Регистратор,НомерСтроки,Активность,ПериодРегистрации,ПериодНачисления";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 		= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 				= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
КонецПроцедуры

// Заполняет актуальные параметры точки поставки МКД.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура АктуальныеПараметрыТочкиПоставкиМКД(Схема, ПараметрыОтбора, ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		РегистрыСведений.энргАктивностьТочекПоставки.АктивныеТочкиПоставокСтроенийМКД(Схема,ПараметрыОтбора, "АктивныеТочкиПоставокСтроенийМКД");
	Иначе
		ЕстьДействующиеТочки 			= Ложь;
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "АктивныеТочкиПоставокСтроенийМКД" Тогда
				ЕстьДействующиеТочки 	= Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
		
		Если НЕ ЕстьДействующиеТочки Тогда
			РегистрыСведений.энргАктивностьТочекПоставки.АктивныеТочкиПоставокСтроенийМКД(Схема,ПараметрыОтбора, "АктивныеТочкиПоставокСтроенийМКД");
		КонецЕсли;
	КонецЕсли;
	
	Пакет 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаАктуальныеПараметрыТочкиПоставкиМКД());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	Пакет.ВыбиратьРазрешенные 		= ?(ПараметрыОтбора.Свойство("ВыбиратьРазрешенные") и НЕ ПараметрыОтбора.ВыбиратьРазрешенные, ЛОЖЬ, ИСТИНА);
	ОператорВыбора 					= Пакет.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;
	
	ПараметрПериод 					= Параметры[0];
	
	Если ПараметрыОтбора.Свойство("Период") Тогда
		ПараметрПериод.Выражение 		= Новый ВыражениеСхемыЗапроса(СтрШаблон("&%1",ПараметрыОтбора["Период"].ИмяПараметра));		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 					= "ТочкаПоставки";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(ОператорВыбора.Источники[0].Источник.Параметры[1], ПараметрыОтбора.ПараметрыВТ, ДоступныеПараметры);		
	КонецЕсли;
	
	ВспомогательныеПоля 			= "Период,Регистратор,НомерСтроки,Активность,ПериодРегистрации,ПериодНачисления";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 		= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 				= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
КонецПроцедуры

// Заполняет актуальные параметры точки поставки строений.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура АктуальныеПараметрыТочкиПоставкиСтроений(Схема, ПараметрыОтбора, ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		РегистрыСведений.энргАктивностьТочекПоставки.АктивныеТочкиПоставокСтроенийЧастныйСектор(Схема,ПараметрыОтбора, "АктивныеТочкиПоставокСтроенийЧастныйСектор");
	Иначе
		ЕстьДействующиеТочки 			= Ложь;
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "АктивныеТочкиПоставокСтроенийЧастныйСектор" Тогда
				ЕстьДействующиеТочки 	= Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
		
		Если НЕ ЕстьДействующиеТочки Тогда
			РегистрыСведений.энргАктивностьТочекПоставки.АктивныеТочкиПоставокСтроенийЧастныйСектор(Схема,ПараметрыОтбора, "АктивныеТочкиПоставокСтроенийЧастныйСектор");
		КонецЕсли;
	КонецЕсли;
	
	Пакет 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаАктуальныеПараметрыТочкиПоставкиСтроений());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	Пакет.ВыбиратьРазрешенные 		= ?(ПараметрыОтбора.Свойство("ВыбиратьРазрешенные") и НЕ ПараметрыОтбора.ВыбиратьРазрешенные, ЛОЖЬ, ИСТИНА);
	ОператорВыбора 					= Пакет.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;
	
	ПараметрПериод 					= Параметры[0];
	
	Если ПараметрыОтбора.Свойство("Период") Тогда
		ПараметрПериод.Выражение 		= Новый ВыражениеСхемыЗапроса(СтрШаблон("&%1",ПараметрыОтбора["Период"].ИмяПараметра));		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 					= "ТочкаПоставки";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(ОператорВыбора.Источники[0].Источник.Параметры[1], ПараметрыОтбора.ПараметрыВТ, ДоступныеПараметры);		
	КонецЕсли;
	
	ВспомогательныеПоля 			= "Период,Регистратор,НомерСтроки,Активность,ПериодРегистрации,ПериодНачисления";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 		= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 				= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаАктуальныеПараметрыТочкиПоставкиПомещения()
	
	Текст =
	"ВЫБРАТЬ
	|	энргПараметрыТочекПоставкиСрезПоследних.ТочкаПоставки КАК ТочкаПоставки,
	|	энргПараметрыТочекПоставкиСрезПоследних.МаксимальнаяМощность КАК МаксимальнаяМощность,
	|	энргПараметрыТочекПоставкиСрезПоследних.ПрисоединеннаяМощность КАК ПрисоединеннаяМощность,
	|	энргПараметрыТочекПоставкиСрезПоследних.СетеваяОрганизация КАК СетеваяОрганизация,
	|	энргПараметрыТочекПоставкиСрезПоследних.СтруктураСети КАК СтруктураСети,
	|	энргПараметрыТочекПоставкиСрезПоследних.УровеньНапряжения КАК УровеньНапряжения,
	|	энргПараметрыТочекПоставкиСрезПоследних.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный
	|ИЗ
	|	РегистрСведений.энргПараметрыТочекПоставки.СрезПоследних(
	|			&Период,
	|			ТочкаПоставки В
	|				(ВЫБРАТЬ
	|					АктивныеТочкиПоставок.ТочкаПоставки
	|				ИЗ
	|					АктивныеТочкиПоставок КАК АктивныеТочкиПоставок)) КАК энргПараметрыТочекПоставкиСрезПоследних";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаАктуальныеПараметрыТочкиПоставки()
	Текст  = 
	"ВЫБРАТЬ
	|	энргПараметрыТочекПоставкиСрезПоследних.ТочкаПоставки КАК ТочкаПоставки,
	|	энргПараметрыТочекПоставкиСрезПоследних.МаксимальнаяМощность КАК МаксимальнаяМощность,
	|	энргПараметрыТочекПоставкиСрезПоследних.ПрисоединеннаяМощность КАК ПрисоединеннаяМощность,
	|	энргПараметрыТочекПоставкиСрезПоследних.СетеваяОрганизация КАК СетеваяОрганизация,
	|	энргПараметрыТочекПоставкиСрезПоследних.СтруктураСети КАК СтруктураСети,
	|	энргПараметрыТочекПоставкиСрезПоследних.УровеньНапряжения КАК УровеньНапряжения,
	|	энргПараметрыТочекПоставкиСрезПоследних.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный,
	|	энргПараметрыТочекПоставкиСрезПоследних.ДоговорТП КАК ДоговорТП,
	|	энргПараметрыТочекПоставкиСрезПоследних.АктТП КАК АктТП,
	|	энргПараметрыТочекПоставкиСрезПоследних.НапряжениеГБП КАК НапряжениеГБП,
	|	энргПараметрыТочекПоставкиСрезПоследних.АктРазграниченияБалансовойПринадлежности КАК АктРазграниченияБалансовойПринадлежности
	|ИЗ
	|	РегистрСведений.энргПараметрыТочекПоставки.СрезПоследних КАК энргПараметрыТочекПоставкиСрезПоследних";
	
	Возврат Текст;
	
КонецФункции 

Функция ТекстЗапросаАктуальныеПараметрыТочкиПоставкиМКД()
	
	Текст =
	"ВЫБРАТЬ
	|	энргПараметрыТочекПоставкиСрезПоследних.ТочкаПоставки КАК ТочкаПоставки,
	|	энргПараметрыТочекПоставкиСрезПоследних.МаксимальнаяМощность КАК МаксимальнаяМощность,
