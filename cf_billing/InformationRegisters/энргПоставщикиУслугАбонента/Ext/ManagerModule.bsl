#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаПоставщикиУслугАбонента()
	Текст  =
	"ВЫБРАТЬ
	|	энргПоставщикиУслугАбонентаСрезПоследних.Организация КАК Организация,
	|	энргПоставщикиУслугАбонентаСрезПоследних.Район КАК Район,
	|	энргПоставщикиУслугАбонентаСрезПоследних.КлючПомещения КАК КлючПомещения,
	|	энргПоставщикиУслугАбонентаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПоставщикиУслугАбонентаСрезПоследних.Услуга КАК Услуга,
	|	энргПоставщикиУслугАбонентаСрезПоследних.ЧастьСоставной КАК ЧастьСоставной,
	|	энргПоставщикиУслугАбонентаСрезПоследних.Поставщик КАК Поставщик
	|ИЗ
	|	РегистрСведений.энргПоставщикиУслугАбонента.СрезПоследних КАК энргПоставщикиУслугАбонентаСрезПоследних";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаПоставщикиУслугДействующихТочек()
	
	Текст  =
		"ВЫБРАТЬ
		|	энргПоставщикиУслугАбонентаСрезПоследних.Организация КАК Организация,
		|	энргПоставщикиУслугАбонентаСрезПоследних.Район КАК Район,
		|	энргПоставщикиУслугАбонентаСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргПоставщикиУслугАбонентаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
		|	энргПоставщикиУслугАбонентаСрезПоследних.Услуга КАК Услуга,
		|	энргПоставщикиУслугАбонентаСрезПоследних.Поставщик КАК Поставщик
		|ИЗ
		|	РегистрСведений.энргПоставщикиУслугАбонента.СрезПоследних(
		|			,
		|			(Организация, Район, КлючПомещения, ТочкаУчета, Услуга) В
		|					(ВЫБРАТЬ
		|						УслугиДействующихТочек.Организация,
		|						УслугиДействующихТочек.Район,
		|						УслугиДействующихТочек.КлючПомещения,
		|						УслугиДействующихТочек.ТочкаУчета,
		|						УслугиДействующихТочек.Услуга
		|					ИЗ
		|						УслугиДействующихТочек КАК УслугиДействующихТочек)
		|				И НЕ ЧастьСоставной) КАК энргПоставщикиУслугАбонентаСрезПоследних";
	
	Возврат Текст;
	
КонецФункции 

Функция ТекстЗапросаПоставщикиСоставнойУслуги()
	
	Текст  =
	"ВЫБРАТЬ
	|	энргПоставщикиУслугАбонентаСрезПоследних.Организация КАК Организация,
	|	энргПоставщикиУслугАбонентаСрезПоследних.Район КАК Район,
	|	энргПоставщикиУслугАбонентаСрезПоследних.КлючПомещения КАК КлючПомещения,
	|	энргПоставщикиУслугАбонентаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргПоставщикиУслугАбонентаСрезПоследних.Услуга КАК Услуга,
	|	энргПоставщикиУслугАбонентаСрезПоследних.Поставщик КАК Поставщик
	|ИЗ
	|	РегистрСведений.энргПоставщикиУслугАбонента.СрезПоследних(&Период, ЧастьСоставной) КАК энргПоставщикиУслугАбонентаСрезПоследних";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

