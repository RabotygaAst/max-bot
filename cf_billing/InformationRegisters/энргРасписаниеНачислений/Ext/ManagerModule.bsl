Функция ПолучитьВсеДанныеРегистра() Экспорт 
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргРасписаниеНачислений.*
	|ИЗ
	|	РегистрСведений.энргРасписаниеНачислений КАК энргРасписаниеНачислений
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПорядокЗапуска";
	
	Возврат Запрос.Выполнить();
КонецФункции

Функция ЗаписатьВсеДанныеРегистра(ТЗ) Экспорт 
	НаборЗаписей = РегистрыСведений.энргРасписаниеНачислений.СоздатьНаборЗаписей();
	НаборЗаписей.Загрузить(ТЗ);
	СчетчикЗапуска = 0;
	Для Каждого ТекЗапись Из НаборЗаписей Цикл 
		СчетчикЗапуска = СчетчикЗапуска + 1;
		ТекЗапись.ПорядокЗапуска = СчетчикЗапуска;
	КонецЦикла;
	НаборЗаписей.Записать();
КонецФункции

