Процедура ИнициализироватьМВТРассчетаСреднегоОбъемаПотребленияАбонентов(МВТ,Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение)
	
	СоотвествиеПолей					= Новый Структура("Организация,ПериодНачисления,Район","Организация","ПериодНачисления","Район");
	СтруктураПараметров 				= Новый Структура("Организация,ПериодНачисления,Район",Организация,ПериодНачисления,Район);
	Схема 								= Неопределено; 
	ПараметрыОтбора 					= Новый Структура;
	ПараметрыВТ 						= Новый Массив;
	
	Если Не ЧастныйСектор = Неопределено Тогда		 
		СоотвествиеПолей.Вставить("ЧастныйСектор", "ЧастныйСектор");
	КонецЕсли; 
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", СоотвествиеПолей));
			
	Если Не Строение = Неопределено Тогда
		Если ТипЗнч(Строение) = Тип("СправочникСсылка.энргСтроения") Тогда			
			ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", Новый Структура("Строение", "Строение")));
		ИначеЕсли ТипЗнч(Строение) = Тип("Массив") Тогда
			ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраВСписке", Новый Структура("Строение", "Строение")));
		КонецЕсли;
	КонецЕсли;
	
	Если Не Помещение = Неопределено Тогда
		Если ТипЗнч(Помещение) = Тип("СправочникСсылка.энргПомещения") Тогда			
			ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", Новый Структура("Помещение", "Помещение")));
		ИначеЕсли ТипЗнч(Помещение) = Тип("Массив") Тогда
			ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраВСписке", Новый Структура("Помещение", "Помещение")));
		КонецЕсли;
	КонецЕсли;
		
	ПараметрыОтбора.Вставить("Период", Новый Структура("ИмяПараметра","ПериодНачисления"));
	ПараметрыОтбора.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	РегистрыСведений.энргНастройкиРасчетаСреднегоПотребления.НастройкиРасчетаСреднегоПотребления(Схема,ПараметрыОтбора,"НастройкиРасчетаСреднегоПотребления");
	РегистрыСведений.энргСпособыРасчетаПоНаправлениям.СпособыРасчетаПоНаправлениям(Схема,ПараметрыОтбора,"СпособыРасчетаПоНаправлениям");
	РегистрыСведений.энргСтабильныеПериоды.СтабильныеПериоды(Схема,ПараметрыОтбора,"СтабильныеПериоды");
	ЗаполнитьСхемуРасчетСреднегоОбъема(Схема,ПараметрыОтбора,"РасчетСреднегоОбъема"); 	
	
	ПараметрыЗапроса 					= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация", 			Организация);
	ПараметрыЗапроса.Вставить("ПериодНачисления", 		ПериодНачисления);
	ПараметрыЗапроса.Вставить("Район", 					Район);
	// Это не ошибка, этот параметр появляется при вызове метода СтабильныеПериоды
	// в данном случае нам не важен период регистрации поэтому передаем все что угодно
	ПараметрыЗапроса.Вставить("НачалоПериодаРасчета",	ПериодНачисления);
	Если Не ЧастныйСектор = Неопределено Тогда
		ПараметрыЗапроса.Вставить("ЧастныйСектор", 		ЧастныйСектор);
		СтруктураПараметров.Вставить("ЧастныйСектор",	ЧастныйСектор);
	КонецЕсли;
	Если Не Строение = Неопределено Тогда
		ПараметрыЗапроса.Вставить("Строение", 			Строение);
		СтруктураПараметров.Вставить("Строение",		Строение);
	КонецЕсли;
	Если Не Помещение = Неопределено Тогда
		ПараметрыЗапроса.Вставить("Помещение", 			Помещение);
		СтруктураПараметров.Вставить("Помещение",		Помещение);
	КонецЕсли;	
			
	энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса,МВТ);

	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		Коллекция 						= СтрРазделить("НастройкиРасчетаСреднегоПотребления,СпособыРасчетаПоНаправлениям,СтабильныеПериоды,РасчетСреднегоОбъема",",",Ложь);
		Для ИндексТаблицы = 0 По Коллекция.ВГраница() Цикл
			РезультатЗапроса 			= МВТ.Таблицы[Коллекция[ИндексТаблицы]].ПолучитьДанные();			
			ИмяМетода 					= "энргРасчетСреднегоОбъема.ИнициализироватьМВТРассчетаСреднегоОбъемаПотребленияАбонентов" + "." + Коллекция[ИндексТаблицы];
			слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
			слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультатЗапросаКодом(ИмяМетода, РезультатЗапроса);			
		КонецЦикла; 		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли