#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Получает среднего объема потребления абонентов.
//
// Параметры:
//  Организация			-	СправочникСсылка.Организации.
//  ПериодНачисления	-	Дата.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  ЧастныйСектор		-	Булево.
//  Строение			-	СправочникСсылка.энргСтроения.
//  Помещение			-	СправочникСсылка.энргПомещения.
// 
// Возвращаемое значение:
//   РезультатЗапроса.
//
Функция РезультатРассчетаСреднегоОбъемаПотребленияАбонентов(Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение) Экспорт 
		
	// TODO
	// Есть зависимость от данных в таблице энргДатыОтчетногоПериоды
	
	МВТ 								= Новый МенеджерВременныхТаблиц;
	ИнициализироватьМВТРассчетаСреднегоОбъемаПотребленияАбонентов(МВТ,Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение);				
	ТочкиДляРасчетСреднегоОбъемаВоВременную(МВТ,Организация,ПериодНачисления,Район,"ТочкиДляРасчета");
	
	Схема 								= Новый СхемаЗапроса; 
	ПакетПериодыРасчетаСреднего 		= Схема.ПакетЗапросов[0];
	ПакетПериодыРасчетаСреднего.УстановитьТекстЗапроса(ТекстЗапросаПериодыРасчетаСреднего());
	ПакетПериодыРасчетаСреднего.ТаблицаДляПомещения = "ПериодыРасчетаСреднего";
	
	ПакетГраницыПолученияСезонности 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	ПакетГраницыПолученияСезонности.УстановитьТекстЗапроса(ТекстЗапросаГраницыПолученияСезонностиПериодовРасчетаСреднего());
	
	ПараметрыЗапроса 					= Новый Структура;
	ПараметрыЗапроса.Вставить("ПериодНачисления", ПериодНачисления);
		
	РезультатГраницыПолученияСезонности = энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса,МВТ);
		
	ТекстГраницОтчетногоПериода 		= "";
	Если НЕ РезультатГраницыПолученияСезонности.Пустой() Тогда
		Выборка 						= РезультатГраницыПолученияСезонности.Выбрать();
		Выборка.Следующий();
		ТекстГраницОтчетногоПериода 	= энргНачисления.ТекстГраницОтчетногоПериода(Выборка.ПериодНачисленияНачало,Выборка.ПериодНачисленияКонец,Ложь);
	КонецЕсли;
	
	Схема  								= Новый СхемаЗапроса;
	
	Если НЕ ПустаяСтрока(ТекстГраницОтчетногоПериода) Тогда
		ПакетТаблицаПериодов			= Схема.ПакетЗапросов[0];
		ПакетТаблицаПериодов.УстановитьТекстЗапроса("ВЫБРАТЬ * ПОМЕСТИТЬ ТаблицаПериодов  ИЗ (" + ТекстГраницОтчетногоПериода + ") КАК ВложенныйЗапрос");
		СоотвествиеПолей 				= Новый Структура("Организация,Район","Организация","Район");
		
		Параметры 						= Новый Структура;
		ПараметрыВТ 					= Новый Массив;
		ПараметрыВТ.Добавить(Новый Структура());
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", СоотвествиеПолей));
		
		РегистрыСведений.энргДлительностиПериодов.ПериодыСезонностиКоллекцияПериодов(Схема,Параметры,"ТаблицаПериодов", "ПериодыСезонности");		
	Иначе		
		РегистрыСведений.энргДлительностиПериодов.ПериодыСезонностиПустаяТаблица(Схема,Параметры,"ПериодыСезонности");				
	КонецЕсли;
	
	ПакетРасчетСреднегоОбъема 			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	ПакетРасчетСреднегоОбъема.УстановитьТекстЗапроса(ТекстЗапросаРасчетСреднегоОбъема());
	
	ПараметрыЗапроса 					= Новый Структура;
	ПараметрыЗапроса.Вставить("ПериодНачисления", 	ПериодНачисления);
	ПараметрыЗапроса.Вставить("Организация", 		Организация);
	ПараметрыЗапроса.Вставить("Район", 				Район);
	
	РезультатЗапроса 				= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса,МВТ);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("слжСлужебная") Тогда
		ИмяМетода 					= "энргРасчетСреднегоОбъема.РезультатРассчетаСреднегоОбъемаПотребленияАбонентов";
		ПараметрыМетода 			= Новый Структура("Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение",Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение); 
		слжОбщегоНазначенияМодуль 	= ОбщегоНазначения.ОбщийМодуль("слжОбщегоНазначения");
		слжОбщегоНазначенияМодуль.Логгер().ЗаписатьРезультатЗапросаКодом(ИмяМетода, РезультатЗапроса);
	КонецЕсли;
	
	Возврат РезультатЗапроса
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ТочкиДляРасчетСреднегоОбъемаВоВременную(МВТ,Организация,ПериодНачисления,Район,ТаблицаДляПомещения)
	
	Схема 								= Новый СхемаЗапроса;
	Пакет 								= Схема.ПакетЗапросов[0];
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаВсеТочкиДляРасчетСреднегоОбъема());
	Пакет.ТаблицаДляПомещения 			= "ВсеТочкиДляРасчета";
	
	Пакет 								= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаСамыйРаннийПериодПолученияСезонностиТочекДляРасчетСреднегоОбъема());
	
	ПараметрыЗапроса 					= Новый Структура;
	ПараметрыЗапроса.Вставить("ПериодНачисления", ПериодНачисления);
	
	Результат  							= энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса,МВТ);
			
	Если Не Результат.Пустой() Тогда
		Выборка 						= Результат.Выбрать();
		Выборка.Следующий();
		ТекстГраницОтчетногоПериода	 	= энргНачисления.ТекстГраницОтчетногоПериода(Выборка.КонецПериода,ПериодНачисления,Ложь);
		
		Схема 							= Новый СхемаЗапроса;
		Пакет 							= Схема.ПакетЗапросов[0];
		Пакет.УстановитьТекстЗапроса(ТекстГраницОтчетногоПериода);
		Пакет.ТаблицаДляПомещения  		= "ТаблицаПериодов";
		Для Каждого Оператор Из Пакет.Операторы Цикл
			Оператор.ВыбираемыеПоля.Добавить("&Район");
		КонецЦикла;
		СоотвествиеПолей				= Новый Структура("Организация,Район","Организация","Район");		
		ПараметрыВТ  					= Новый Массив;
		ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей", "ТипПараметраРавно", СоотвествиеПолей));
		Параметры 						= Новый Структура("ПараметрыВТ", ПараметрыВТ);
		РегистрыСведений.энргДлительностиПериодов.ПериодыСезонностиКоллекцияПериодов(Схема,Параметры,"ТаблицаПериодов","ПериодыСезонности");
	Иначе
		Схема 							= Новый СхемаЗапроса;
		РегистрыСведений.энргДлительностиПериодов.ПериодыСезонностиПустаяТаблица(Схема,Неопределено,"ПериодыСезонности");
	КонецЕсли;
		
	Пакет 								= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаТочкиДляРасчетаПериодыСезонностиИсключая());
	Пакет.ТаблицаДляПомещения 			= ТаблицаДляПомещения;
	
	ПараметрыЗапроса 					= Новый Структура;
	ПараметрыЗапроса.Вставить("Организация", 		Организация);
	ПараметрыЗапроса.Вставить("ПериодНачисления",	ПериодНачисления);
	ПараметрыЗапроса.Вставить("Район",				Район);
	
	энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема,ПараметрыЗапроса,МВТ);   	
	    
	Если НЕ МВТ.Таблицы.Найти("ПериодыСезонности") = Неопределено Тогда		
		Запрос 							= Новый Запрос("УНИЧТОЖИТЬ ПериодыСезонности");
		Запрос.МенеджерВременныхТаблиц 	= МВТ;
		Запрос.Выполнить();
	КонецЕсли;
	
	Если НЕ МВТ.Таблицы.Найти("ТаблицаПериодов") = Неопределено Тогда		
		Запрос 							= Новый Запрос("УНИЧТОЖИТЬ ТаблицаПериодов");
		Запрос.МенеджерВременныхТаблиц 	= МВТ;
		Запрос.Выполнить();
	КонецЕсли;
	
КонецПроцедуры

// Заполняет схему расчет среднего объема.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ЗаполнитьСхемуРасчетСреднегоОбъема(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаНаборЗаписейРасчетСреднегоОбъем());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	ОператорВыбора 					= Пакет.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;		
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация, Район, ЧастныйСектор, Строение, Помещение, ТочкаУчета, Шкала, ТарифнаяЗона";
		ИмяТаблицы 					= "РасчетСреднегоОбъема";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОператорВыбора.Отбор,ИмяТаблицы,ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаВсеТочкиДляРасчетСреднегоОбъема()
	Текст =
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.ЧастныйСектор КАК ЧастныйСектор,
	|	ВложенныйЗапрос.Строение КАК Строение,
	|	ВложенныйЗапрос.Помещение КАК Помещение,
	|	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ВложенныйЗапрос.Шкала КАК Шкала,
	|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ВложенныйЗапрос.ДатаСостоянияЛицевогоСчета КАК ДатаСостоянияЛицевогоСчета,
	|	ВложенныйЗапрос.КоличествоПредоставленных КАК КоличествоПредоставленных,
	|	ВложенныйЗапрос.СрокНеПредоставления КАК СрокНеПредоставления,
	|	ВЫБОР
	|		КОГДА ВложенныйЗапрос.ПериодНачисленияВыводаПрибора = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ВложенныйЗапрос.КонецПериода
	|		КОГДА ВложенныйЗапрос.ПериодНачисленияВыводаПрибора < ВложенныйЗапрос.КонецПериода
	|			ТОГДА ВложенныйЗапрос.ПериодНачисленияВыводаПрибора
	|		ИНАЧЕ ВложенныйЗапрос.КонецПериода
	|	КОНЕЦ КАК КонецПериода,
	|	ВложенныйЗапрос.КоличествоПоказаний КАК КоличествоПоказаний,
	|	ВложенныйЗапрос.КоличествоПериодов КАК КоличествоПериодов,
	|	ВложенныйЗапрос.ЗаПрошлыйГод КАК ЗаПрошлыйГод,
	|	ВложенныйЗапрос.НачислятьСреднийОбъемНеБолееМесяцев КАК НачислятьСреднийОбъемНеБолееМесяцев,
	|	ВложенныйЗапрос.ЭтоОбъемПотребленный КАК ЭтоОбъемПотребленный,
	|	ВложенныйЗапрос.ДатаСостоянияПрибора КАК ДатаСостоянияПрибора,
	|	ВложенныйЗапрос.ПриборВведен КАК ПриборВведен,
	|	ВложенныйЗапрос.ПериодНачисленияВыводаПрибора КАК ПериодНачисленияВыводаПрибора,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	ВложенныйЗапрос.НеПрименятьСезонность КАК НеПрименятьСезонность,
	|	ЕСТЬNULL(СпособыРасчетаПоНаправлениям.Сезонность, ЗНАЧЕНИЕ(Справочник.энргВидыСезонности.ПустаяСсылка)) КАК Сезонность,
	|	ЕСТЬNULL(энргВидыУслуг.КорректироватьГодовойОбъем, ЛОЖЬ) КАК КорректироватьГодовойОбъем
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргРасчетСреднегоОбъема.Район КАК Район,
	|		энргРасчетСреднегоОбъема.ЧастныйСектор КАК ЧастныйСектор,
	|		энргРасчетСреднегоОбъема.Строение КАК Строение,
	|		энргРасчетСреднегоОбъема.Помещение КАК Помещение,
	|		энргРасчетСреднегоОбъема.ТочкаУчета КАК ТочкаУчета,
	|		СтабильныеПериоды.Услуга КАК Услуга,
	|		энргРасчетСреднегоОбъема.Шкала КАК Шкала,
	|		энргРасчетСреднегоОбъема.ТарифнаяЗона КАК ТарифнаяЗона,
	|		СтабильныеПериоды.ДатаСостоянияЛицевогоСчета КАК ДатаСостоянияЛицевогоСчета,
	|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ НАЧАЛОПЕРИОДА(энргРасчетСреднегоОбъема.ПериодНачисления, МЕСЯЦ)) КАК КоличествоПредоставленных,
	|		РАЗНОСТЬДАТ(МАКСИМУМ(энргРасчетСреднегоОбъема.ПериодНачисления), &ПериодНачисления, МЕСЯЦ) - 1 КАК СрокНеПредоставления,
	|		МАКСИМУМ(энргРасчетСреднегоОбъема.ПериодНачисления) КАК КонецПериода,
	|		МАКСИМУМ(СтабильныеПериоды.КоличествоПоказаний) КАК КоличествоПоказаний,
	|		МАКСИМУМ(СтабильныеПериоды.КоличествоПериодов) КАК КоличествоПериодов,
	|		МАКСИМУМ(СтабильныеПериоды.ЗаПрошлыйГод) КАК ЗаПрошлыйГод,
	|		МАКСИМУМ(СтабильныеПериоды.НачислятьСреднийОбъемНеБолееМесяцев) КАК НачислятьСреднийОбъемНеБолееМесяцев,
	|		МАКСИМУМ(СтабильныеПериоды.НеПрименятьСезонность) КАК НеПрименятьСезонность,
	|		ЛОЖЬ КАК ЭтоОбъемПотребленный,
	|		СтабильныеПериоды.ДатаСостоянияПрибора КАК ДатаСостоянияПрибора,
	|		СтабильныеПериоды.ПериодНачисленияВыводаПрибора КАК ПериодНачисленияВыводаПрибора,
	|		СтабильныеПериоды.ПриборВведен КАК ПриборВведен,
	|		СтабильныеПериоды.Организация КАК Организация,
	|		СтабильныеПериоды.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ
	|	ИЗ
	|		(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|			СтабильныеПериоды.Организация КАК Организация,
	|			СтабильныеПериоды.Район КАК Район,
	|			СтабильныеПериоды.ЧастныйСектор КАК ЧастныйСектор,
	|			СтабильныеПериоды.Строение КАК Строение,
	|			СтабильныеПериоды.Помещение КАК Помещение,
	|			СтабильныеПериоды.ТочкаУчета КАК ТочкаУчета,
	|			СтабильныеПериоды.Услуга КАК Услуга,
	|			СтабильныеПериоды.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|			СтабильныеПериоды.ДатаСостоянияЛицевогоСчета КАК ДатаСостоянияЛицевогоСчета,
	|			СтабильныеПериоды.ДатаСостоянияПрибора КАК ДатаСостоянияПрибора,
