Процедура ЗаписатьНачалоОперации(СтрокаЗаписиРезультата) Экспорт
	
	Набор = СоздатьНаборЗаписей();
	НоваяСтрока = Набор.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаЗаписиРезультата);
	Набор.Записать(Ложь);	
	
КонецПроцедуры

Процедура ЗаписатьЗавершениеОперации(СтрокаЗаписиРезультата) Экспорт
	
	Набор = СоздатьНаборЗаписей();
	Набор.Отбор.Период.Установить(СтрокаЗаписиРезультата.Период);
	Набор.Отбор.ПериодНачисления.Установить(СтрокаЗаписиРезультата.ПериодНачисления);
	Набор.Отбор.Организация.Установить(СтрокаЗаписиРезультата.Организация);
	Набор.Отбор.Район.Установить(СтрокаЗаписиРезультата.Район);
	Набор.Отбор.Операция.Установить(СтрокаЗаписиРезультата.Операция);
	Набор.Отбор.ИдентификаторГруппировкиЗаданий.Установить(СтрокаЗаписиРезультата.ИдентификаторГруппировкиЗаданий);
	
	НоваяСтрока = Набор.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаЗаписиРезультата);
	Набор.Записать();	
	
КонецПроцедуры

Функция ПолучитьОписаниеОбъекта() Экспорт
	
	МетаданныеРегистра = Метаданные.РегистрыСведений.энргРезультатВыполненияОперацийНачислений;
	ОписаниеОбъекта = энргОбщегоНазначения.ПолучитьОписаниеСвойствРегистра(МетаданныеРегистра);
	Если МетаданныеРегистра.ПериодичностьРегистраСведений <> Метаданные.СвойстваОбъектов.ПериодичностьРегистраСведений.Непериодический Тогда
		ОписаниеОбъекта.Вставить("Период", Дата(1,1,1));
	КонецЕсли;
	
	Возврат ОписаниеОбъекта;
	
КонецФункции

