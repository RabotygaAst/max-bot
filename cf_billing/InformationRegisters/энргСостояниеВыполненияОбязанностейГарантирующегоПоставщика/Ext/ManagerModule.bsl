Процедура ТочкиСНеВыполненнымиОбязанностямиГарантирующегоПоставщикаКоллекцияПериодов(Схема, ПараметрыОтбора, ТаблицаПериодов, ТаблицаДляПомещения = "") Экспорт 
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаТочкиСНеВыполненнымиОбязанностямиГарантирующегоПоставщикаКоллекцияПериодов());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	//ОператорВыбора 					= Пакет.Операторы[0].Источники[0].Источник.Запрос.Операторы[0].Источники[0].Источник.Запрос.Операторы[0].Источники[0].Источник.Запрос.Операторы[0];	
	//Источник 						= ОператорВыбора.Источники[1].Источник;		
КонецПроцедуры

#Область ТекстыЗапросов

Функция ТекстЗапросаСостояниеВыполненияОбязанностейГарантирующегоПоставщика()
	
	Текст = 
	"ВЫБРАТЬ
	|	ТаблицаСрезаДанных.ПериодНачисления КАК ПериодНачисленияРегистратора,
	|	ТаблицаСрезаДанных.Организация КАК Организация,
	|	ТаблицаСрезаДанных.Район КАК Район,
	|	ТаблицаСрезаДанных.ЧастныйСектор КАК ЧастныйСектор,
	|	ТаблицаСрезаДанных.Строение КАК Строение,
	|	ТаблицаСрезаДанных.Помещение КАК Помещение,
	|	ТаблицаСрезаДанных.ТочкаУчета КАК ТочкаУчета,
	|	ТаблицаСрезаДанных.ОбязанностиВыполнены КАК ОбязанностиВыполнены	
	|ИЗ
	|	РегистрСведений.энргСостояниеВыполненияОбязанностейГарантирующегоПоставщика.СрезПоследних КАК ТаблицаСрезаДанных";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаТочкиСНеВыполненнымиОбязанностямиГарантирующегоПоставщика()
	
	Текст = 
	"ВЫБРАТЬ
	|	ТаблицаСрезаДанных.ПериодНачисления КАК ПериодНачисленияРегистратора,
	|	ТаблицаСрезаДанных.Организация КАК Организация,
	|	ТаблицаСрезаДанных.Район КАК Район,
	|	ТаблицаСрезаДанных.ЧастныйСектор КАК ЧастныйСектор,
	|	ТаблицаСрезаДанных.Строение КАК Строение,
	|	ТаблицаСрезаДанных.Помещение КАК Помещение,
	|	ТаблицаСрезаДанных.ТочкаУчета КАК ТочкаУчета
	|ИЗ
	|	РегистрСведений.энргСостояниеВыполненияОбязанностейГарантирующегоПоставщика.СрезПоследних КАК ТаблицаСрезаДанных
	|ГДЕ
	|	НЕ ТаблицаСрезаДанных.ОбязанностиВыполнены";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаТочкиСНеВыполненнымиОбязанностямиГарантирующегоПоставщикаКоллекцияПериодов()
	Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ТаблицаСостояниеВыполненияОбязанностей.ПериодНачисления КАК ПериодНачисленияРегистратора,
	|	ТаблицаСостояниеВыполненияОбязанностей.Организация КАК Организация,
	|	ТаблицаСостояниеВыполненияОбязанностей.Район КАК Район,
	|	ТаблицаСостояниеВыполненияОбязанностей.ЧастныйСектор КАК ЧастныйСектор,
	|	ТаблицаСостояниеВыполненияОбязанностей.Строение КАК Строение,
	|	ТаблицаСостояниеВыполненияОбязанностей.Помещение КАК Помещение,
	|	ТаблицаСостояниеВыполненияОбязанностей.ТочкаУчета КАК ТочкаУчета,
	|	ТаблицаСостояниеВыполненияОбязанностей.ОбязанностиВыполнены КАК ОбязанностиВыполнены
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаПериодов.ПериодНачисления КАК ПериодНачисления,
	|		ТаблицаСостояниеВыполненияОбязанностей.Организация КАК Организация,
	|		ТаблицаСостояниеВыполненияОбязанностей.Район КАК Район,
	|		ТаблицаСостояниеВыполненияОбязанностей.ЧастныйСектор КАК ЧастныйСектор,
	|		ТаблицаСостояниеВыполненияОбязанностей.Строение КАК Строение,
	|		ТаблицаСостояниеВыполненияОбязанностей.Помещение КАК Помещение,
	|		ТаблицаСостояниеВыполненияОбязанностей.ТочкаУчета КАК ТочкаУчета,
	|		МАКСИМУМ(ТаблицаСостояниеВыполненияОбязанностей.Период) КАК Период
	|	ИЗ
	|		РегистрСведений.энргСостояниеВыполненияОбязанностейГарантирующегоПоставщика КАК ТаблицаСостояниеВыполненияОбязанностей
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПериодов КАК ТаблицаПериодов
	|			ПО ТаблицаСостояниеВыполненияОбязанностей.Организация = ТаблицаПериодов.Организация
	|				И ТаблицаСостояниеВыполненияОбязанностей.Район = ТаблицаПериодов.Район
	|				И ТаблицаСостояниеВыполненияОбязанностей.Период < ТаблицаПериодов.ЗавершениеОП
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ТаблицаПериодов.ПериодНачисления,
	|		ТаблицаСостояниеВыполненияОбязанностей.Организация,
	|		ТаблицаСостояниеВыполненияОбязанностей.Район,
	|		ТаблицаСостояниеВыполненияОбязанностей.ЧастныйСектор,
	|		ТаблицаСостояниеВыполненияОбязанностей.Строение,
	|		ТаблицаСостояниеВыполненияОбязанностей.Помещение,
	|		ТаблицаСостояниеВыполненияОбязанностей.ТочкаУчета) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСостояниеВыполненияОбязанностейГарантирующегоПоставщика КАК ТаблицаСостояниеВыполненияОбязанностей
	|		ПО ВложенныйЗапрос.Период = ТаблицаСостояниеВыполненияОбязанностей.Период
	|			И ВложенныйЗапрос.Организация = ТаблицаСостояниеВыполненияОбязанностей.Организация
	|			И ВложенныйЗапрос.Район = ТаблицаСостояниеВыполненияОбязанностей.Район
	|			И ВложенныйЗапрос.ЧастныйСектор = ТаблицаСостояниеВыполненияОбязанностей.ЧастныйСектор
	|			И ВложенныйЗапрос.Строение = ТаблицаСостояниеВыполненияОбязанностей.Строение
	|			И ВложенныйЗапрос.Помещение = ТаблицаСостояниеВыполненияОбязанностей.Помещение
	|			И ВложенныйЗапрос.ТочкаУчета = ТаблицаСостояниеВыполненияОбязанностей.ТочкаУчета
	|			И (НЕ ТаблицаСостояниеВыполненияОбязанностей.ОбязанностиВыполнены)";
	
	Возврат Текст;
КонецФункции

