// Заполняет схему действующие приборы моменты времени.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ЗаполнитьСхемуДействующиеПриборыМоментыВремени(Схема, ПараметрыОтбора, ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		Схема 								= Новый СхемаЗапроса;
		Пакет 								= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 								= Схема.ПакетЗапросов.Добавить();
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаДействующиеПриборыМоментыВремени());
	Пакет.ТаблицаДляПомещения 				= ТаблицаДляПомещения;
	
	ОператорыВыбора  						= Пакет.Операторы[0].Источники[0].Источник.Запрос.Операторы[0].Источники[0].Источник.Запрос.Операторы;
	ОсновнойОператор 						= ОператорыВыбора[0];
	ЕстьВременнаяТаблица					= Ложь;
	ПоляВременных 							= Новый Соответствие;
	ДоступныеПоляОтбора 					= "Организация,Район,КлючПомещения,ТочкаУчета,ПриборУчета";	 
	ИменаВременныхТаблиц 					= Новый Массив;
	ДоступныеПоляСоединений 				= СтрРазделить("Организация,Район,КлючПомещения,ТочкаУчета,ПриборУчета",",");
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ПараметрыВТ 						= ПараметрыОтбора.ПараметрыВТ;
		Для Индекс = 0 По ПараметрыВТ.ВГРаница() Цикл
			ОписаниеПараметра 				= ПараметрыВТ[Индекс];
			Если ОписаниеПараметра.ТипПараметра = "ТипПараметраВременнаяТаблица" Тогда
				Для Каждого КлючЗначение Из ОписаниеПараметра.СоотвествиеПолей Цикл
					Если ДоступныеПоляСоединений.Найти(КлючЗначение.Ключ) = Неопределено Тогда
						Продолжить;
					КонецЕсли; 
					ЕстьВременнаяТаблица 	= Истина;
					ИндексВременной 		= ИменаВременныхТаблиц.Найти(ОписаниеПараметра.ТаблицаИсточник);
					Если ИндексВременной = Неопределено Тогда
						ИменаВременныхТаблиц.Добавить(ОписаниеПараметра.ТаблицаИсточник);
						ПоляВременных.Вставить(ОписаниеПараметра.ТаблицаИсточник, Новый Массив);									 
					КонецЕсли;
					ПоляВременных[ОписаниеПараметра.ТаблицаИсточник].Добавить(КлючЗначение);
				КонецЦикла;				
			ИначеЕсли ОписаниеПараметра.ТипПараметра = "ТипПараметраРавно" Тогда
				врПараметры 				= Новый Массив;
				врПараметры.Добавить(ОписаниеПараметра);
				энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОсновнойОператор.Отбор, "СостояниеПриборовУчетаАбонента", врПараметры, ДоступныеПоляОтбора);
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;
	
	Если ЕстьВременнаяТаблица Тогда 		
		Для Индекс = 0 По ИменаВременныхТаблиц.ВГраница() Цикл
			НовыйИсточник 					= ОсновнойОператор.Источники.Добавить(ИменаВременныхТаблиц[Индекс]);			
			УсловиеСоединения 				= Новый Массив;
			СоотвествиеПолей 				= ПоляВременных[ИменаВременныхТаблиц[Индекс]];
			Для Каждого КлючЗначение Из СоотвествиеПолей Цикл
				Если ДоступныеПоляСоединений.Найти(КлючЗначение.Ключ) = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				УсловиеСоединения.Добавить(СтрШаблон("СостояниеПриборовУчетаАбонента.%1 = %2.%3", КлючЗначение.Ключ, ИменаВременныхТаблиц[Индекс], КлючЗначение.Значение));
			КонецЦикла;
			УсловиеСоединения.Добавить(СтрШаблон(
			"ВЫБОР 
			|	КОГДА СостояниеПриборовУчетаАбонента.Период < %1.Период
			|		ТОГДА ИСТИНА
			|	КОГДА СостояниеПриборовУчетаАбонента.Период = %1.Период
			|		ТОГДА СостояниеПриборовУчетаАбонента.Регистратор < %1.Регистратор
			|	ИНАЧЕ ЛОЖЬ
			|КОНЕЦ", ИменаВременныхТаблиц[Индекс]));
			ОсновнойОператор.Источники[0].Соединения.Добавить(ИменаВременныхТаблиц[Индекс],СтрСоединить(УсловиеСоединения,Символы.ПС + " И ")); 
			НовоеСоединение 				= ОсновнойОператор.Источники[0].Соединения[ОсновнойОператор.Источники[0].Соединения.Количество() -1];
			НовоеСоединение.ТипСоединения 	= ТипСоединенияСхемыЗапроса.Внутреннее;			
		КонецЦикла;	
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

