	Пакет.ТаблицаДляПомещения 				= ТаблицаДляПомещения;
	
	ДоступныеПоляОтбора 					= "Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение,Услуга,ТочкаУчета";
	энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(Пакет.Операторы[0].Отбор,"СтабильныеПериоды",Параметры, ДоступныеПоляОтбора);		
	   	                           	
	ДоступныеПоляОтбора 					= "Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение,ТочкаУчета";
	ПакетШкалы								= Схема.ПакетЗапросов.Добавить();	
	ПакетШкалы.УстановитьТекстЗапроса(ТекстЗапросаСостояниеШкалНаНачалоПериодаНачисления());
	ПакетШкалы.ТаблицаДляПомещения 			= ТаблицаДляПомещения + "Шкалы";
	энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ПакетШкалы.Операторы[0].Отбор,"СтабильныеПериодыШкалы",Параметры, ДоступныеПоляОтбора);
	
	ДоступныеПоляОтбора 					= "Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение,ТочкаУчета";
	ПакетИзмерители							= Схема.ПакетЗапросов.Добавить();	
	ПакетИзмерители.УстановитьТекстЗапроса(ТекстЗапросаСостояниеИзмерителейНаНачалоПериодаНачисления());
	ПакетИзмерители.ТаблицаДляПомещения 	= ТаблицаДляПомещения + "ИзмерителиНаправлений";
	энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ПакетИзмерители.Операторы[0].Отбор,"СтабильныеПериодыИзмерители",Параметры, ДоступныеПоляОтбора);
	
КонецПроцедуры

// Очищает наборы.
//
// Параметры:
//  Параметры	-	Структура.
//
Процедура ОчиститьНаборы(Параметры) Экспорт 
	
	Набор 							= РегистрыСведений.энргСтабильныеПериоды.СоздатьНаборЗаписей();
	Набор.Отбор.ДокРегистратор.Установить(Параметры.ДокРегистратор);
	Набор.Отбор.Организация.Установить(Параметры.Организация);
	Набор.Отбор.ПериодНачисления.Установить(Параметры.ПериодНачисления);
	Набор.Отбор.Район.Установить(Параметры.Район);
	Набор.Отбор.ЧастныйСектор.Установить(Параметры.ЧастныйСектор);
	Набор.Отбор.Строение.Установить(Параметры.Строение);
	Набор.Отбор.Помещение.Установить(Параметры.Помещение);
	Набор.Записать();
	
	НаборШкалы 						= РегистрыСведений.энргСтабильныеПериодыШкалы.СоздатьНаборЗаписей();
	НаборШкалы.Отбор.ДокРегистратор.Установить(Параметры.ДокРегистратор);
	НаборШкалы.Отбор.Организация.Установить(Параметры.Организация);
	НаборШкалы.Отбор.ПериодНачисления.Установить(Параметры.ПериодНачисления);
	НаборШкалы.Отбор.Район.Установить(Параметры.Район);
	НаборШкалы.Отбор.ЧастныйСектор.Установить(Параметры.ЧастныйСектор);
	НаборШкалы.Отбор.Строение.Установить(Параметры.Строение);
	НаборШкалы.Отбор.Помещение.Установить(Параметры.Помещение);
	НаборШкалы.Записать();
	
	НаборИзмерители 					= РегистрыСведений.энргСтабильныеПериодыИзмерителиНаправлений.СоздатьНаборЗаписей();
	НаборИзмерители.Отбор.ДокРегистратор.Установить(Параметры.ДокРегистратор);
	НаборИзмерители.Отбор.Организация.Установить(Параметры.Организация);
	НаборИзмерители.Отбор.ПериодНачисления.Установить(Параметры.ПериодНачисления);
	НаборИзмерители.Отбор.Район.Установить(Параметры.Район);
	НаборИзмерители.Отбор.ЧастныйСектор.Установить(Параметры.ЧастныйСектор);
	НаборИзмерители.Отбор.Строение.Установить(Параметры.Строение);
	НаборИзмерители.Отбор.Помещение.Установить(Параметры.Помещение);
	НаборИзмерители.Записать(); 

КонецПроцедуры

// Заполняет номера позиций на границу нарушения последовательности.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура НомераПозицийНаГраницуНарушенияПоследовательности(Схема,Параметры,ТаблицаДляПомещения)
	перем Пакет;
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить();
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаНомераПозицийНаГраницуНарушенияПоследовательности());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	
	ДоступныеПоляОтбора 			= "Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение,Услуга,ТочкаУчета";
	энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(Пакет.Операторы[0].Отбор,"СтабильныеПериоды",Параметры,ДоступныеПоляОтбора);		
		
КонецПроцедуры

// Заполняет значение индивидуальных площадей МКД.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ЗначениеИндивидуальныхПлощадейМКД(Схема, Параметры, ТаблицаДляПомещения="") Экспорт 
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаЗначениеИндивидуальныхПлощадейМКД());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	ОператорВыбора 					= Пакет.Операторы[0].Источники[0].Источник.Запрос.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	
	Если Параметры.Свойство("ПараметрыВТ") Тогда
		
		ДоступныеПараметры 	= "Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Услуга";
		ИмяТаблицы 			= "СтабильныеПериоды";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(
			ОператорВыбора.Отбор,
			ИмяТаблицы,
			Параметры.ПараметрыВТ,
			ДоступныеПараметры);
		
		// Определить свойство МКД	
		Для Сч = 0 По Параметры.ПараметрыВТ.ВГраница() Цикл
			
			Если Параметры.ПараметрыВТ[Сч].СоотвествиеПолей.Свойство("МКД") Тогда				
				СоотвествиеПолей 	= Новый Структура("Строение", Параметры.ПараметрыВТ[Сч].СоотвествиеПолей["МКД"]);
				ОтборМКД 			= Новый Структура("ТипПараметра,СоотвествиеПолей", Параметры.ПараметрыВТ[Сч].ТипПараметра, СоотвествиеПолей);
							
				МассивОтбора = Новый Массив;
				МассивОтбора.Добавить(ОтборМКД);
				энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(
					ОператорВыбора.Отбор,
					ИмяТаблицы,
					МассивОтбора,
					ДоступныеПараметры);
				
				Прервать;
			КонецЕсли;
			
		КонецЦикла;				
		
		// Отбор значения площадей
		ДоступныеПараметры = "Организация, Район, КлючПомещения, ВидПлощади";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(
			ОператорВыбора.Источники[2].Источник.Параметры[1],
			Параметры.ПараметрыВТ,
			ДоступныеПараметры);		
		
	КонецЕсли;

КонецПроцедуры

// Заполняет наличие приборов учета с начала года.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура НаличиеПриборовУчетаСНачалаГода(Схема,Параметры,ТаблицаДляПомещения="") Экспорт 
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаНаличиеПриборовУчетаСНачалаГода());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	ОператорВыбора 					= Пакет.Операторы[0];	
	
	Если Параметры.Свойство("ЕстьОтборПоКлючамПомещений") И Параметры.ЕстьОтборПоКлючамПомещений Тогда
		НовыйИсточник 			= ОператорВыбора.Источники.Добавить("ЗначенияКлючейПомещений", "энргКлючиПомещений");
		
		СоотвествиеУсловий	= Новый Соответствие;
		СоотвествиеУсловий.Вставить("Помещение", "Помещение");
		СоотвествиеУсловий.Вставить("Строение", "Строение");
		МассивУсловий		= Новый Массив;
		МассивУсловий.Добавить(Новый Структура("ТипУсловия,СоотвествиеУсловий","ТипУсловияРавно", СоотвествиеУсловий));
		
		энргФормированиеТекстовЗапроса.УстановитьИсточникЗапроса(ОператорВыбора.Источники[0], НовыйИсточник, ТипСоединенияСхемыЗапроса.Внутреннее, МассивУсловий);  
		
	КонецЕсли;
	
	Если Параметры.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация, Район,ЧастныйСектор,Строение,Помещение,Услуга";
		ИмяТаблицы 					= "СтабильныеПериоды";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОператорВыбора.Отбор,ИмяТаблицы,Параметры.ПараметрыВТ,ДоступныеПараметры);		
	КонецЕсли;
КонецПроцедуры

// Заполняет значение индивидуальных площадей коллекция периодов.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаПериодов		-	Строка.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ЗначениеИндивидуальныхПлощадейКоллекцияПериодов(Схема,ПараметрыОтбора,ТаблицаПериодов,ТаблицаДляПомещения = "") Экспорт  
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаЗначениеИндивидуальныхПлощадейКоллекцияПериодов());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	ОператорВыбора 					= Пакет.Операторы[0].Источники[0].Источник.Запрос.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация, ПериодНачисления, Район, ЧастныйСектор, Строение, Услуга";
		ИмяТаблицы 					= "СтабильныеПериоды";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОператорВыбора.Отбор,ИмяТаблицы,ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);				
	КонецЕсли;	 	
			
КонецПроцедуры

// Заполняет точки учета с изменившимся состояние прибора учета.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ТочкиУчетаСИзменившимсяСостояниеПрибораУчета(Схема,Параметры,ТаблицаДляПомещения="") Экспорт  
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
