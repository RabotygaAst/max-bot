// Заполняет набор документов для проведения.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура НаборДокументовДляПроведения(Схема,Параметры,ТаблицаДляПомещения  = "") Экспорт 
	перем Пакет;
	
	ТаблицаПоследовательности(Схема,Параметры,"ДанныеПоследовательности");
	
	ГраницаНарушенияПоследовательности(Схема,Параметры,"ГраницаНарушенияПоследовательности");
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить();
	КонецЕсли;
		
	Пакет.УстановитьТекстЗапроса(ТекстНаборДокументовДляПроведения());
	Пакет.ТаблицаДляПомещения 		= "ДокументыДляПроведенияПервичныйНабор";	
			
	Пакет 							= Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(ТекстНаборДокументовДляПроведенияСвязанныеПомещения());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;	
		
КонецПроцедуры

// Заполняет набор документов для проведения по фактическому периоду.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаПериодов		-	Строка.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура НаборДокументовДляПроведенияПоФактическомуПериоду(Схема,Параметры,ТаблицаПериодов,ТаблицаДляПомещения  = "") Экспорт 
	перем Пакет;
	
	ТаблицаПоследовательностиПомещенияСРазделеннымиЛС(Схема,Параметры,"ДокументыДляПроведенияРазделенныеЛСПервичныйНабор");
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить();
	КонецЕсли;
		
	Пакет.УстановитьТекстЗапроса(ТекстНаборДокументовДляПроведенияПерерасчетПоПериодуРегистрации());
	Пакет.ТаблицаДляПомещения 		= "ДокументыДляПроведенияПервичныйНабор_ПоПериодуРегистрации";
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(ТекстНаборДокументовДляПроведенияПерерасчетПоДатаРегистратора());
	Пакет.ТаблицаДляПомещения 		= "ДокументыДляПроведенияПервичныйНабор_ПоДатеРегистрации";
	
	Пакет 							= Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(ТекстНаборДокументовДляПроведенияПерерасчетОбъединение());
	Пакет.ТаблицаДляПомещения 		= "ДокументыДляПроведенияПервичныйНабор";

	Пакет 							= Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаНаборДокументовСвязанныеПомещенияДляПроведенияПоФактическомуПериоду());
	Пакет.ТаблицаДляПомещения 		= "ДокументыДляПроведенияПервичныйНаборСвязанныеПомещения";
			
	Пакет 							= Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаНаборДокументовДляПроведенияПоФактическомуПериоду());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;	

	
КонецПроцедуры

#КонецОбласти

// Устанавливает состояние последовательности.
//
// Параметры:
//  Организация			-	СправочникСсылка.Организации.
//  ПериодНачисления	-	Дата.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  ЧастныйСектор		-	Булево.
//  Строение			-	СправочникСсылка.энргСтроения.
//  Помещение			-	СправочникСсылка.энргПомещения.
//
Процедура УстановитьСостояниеПоследовательности(Организация,ПериодНачисления,Район,ЧастныйСектор = Неопределено,Строение = Неопределено,Помещение = Неопределено) Экспорт 
	
	ПроведенВПоследовательности 		= Перечисления.энргСостояниеДокументаВПоследовательности.ПроведенВПоследовательности;
	Набор  								= СоздатьНаборЗаписей();
	Набор.Отбор.Организация.установить(Организация);
	Набор.Отбор.ПериодНачисления.установить(ПериодНачисления);
	Набор.Отбор.Район.установить(Район);
	Если НЕ ЧастныйСектор = Неопределено Тогда
		Набор.Отбор.ЧастныйСектор.установить(ЧастныйСектор);
	КонецЕсли;
	
	Если НЕ Строение = Неопределено Тогда
		Набор.Отбор.Строение.установить(Строение);
	КонецЕсли;
	
	Если НЕ Помещение = Неопределено Тогда
		Набор.Отбор.Помещение.установить(Помещение);
	КонецЕсли; 	
	
	СтрокиУдалить  						= Новый Массив;
	
	Набор.Прочитать(); 	
	для Каждого СтрокаНабора из Набор цикл
		Если СтрокаНабора.СостояниеПроведения = Перечисления.энргСостояниеДокументаВПоследовательности.ИсключенИзПоследовательности Тогда
			СтрокиУдалить.Добавить(СтрокаНабора);
			Продолжить;
		КонецЕсли;		
		СтрокаНабора.СостояниеПроведения = ПроведенВПоследовательности;
	КонецЦикла;
	
	Для Сч = 0 По СтрокиУдалить.ВГраница() Цикл
		Набор.Удалить(СтрокиУдалить[Сч]);
	КонецЦикла;	
	
	Набор.Записать();				
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ТаблицаПоследовательности(Схема,Параметры,ТаблицаДляПомещения) 
	
	Если Схема = Неопределено Тогда
		Схема  					= Новый СхемаЗапроса;
		Пакет 					= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 					= Схема.ПакетЗапросов.Добавить();
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(ТекстДанныеПоследовательностиПервичныйНабор());
	Пакет.ТаблицаДляПомещения 	= "ДанныеПоследовательностиПервичныйНабор";
	ДоступныеПоляОтбора 		= "Организация,ПериодНачисления,Район,ЧастныйСектор,Строение,Помещение";
	энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(Пакет.Операторы[0].Отбор,"ТаблицаПоследовательности",Параметры, ДоступныеПоляОтбора);
	
	Пакет 					= Схема.ПакетЗапросов.Добавить();
	Пакет.УстановитьТекстЗапроса(ТекстДанныеПоследовательностиСвязанныеПомещения());
	Пакет.ТаблицаДляПомещения 	= ТаблицаДляПомещения;

КонецПроцедуры

