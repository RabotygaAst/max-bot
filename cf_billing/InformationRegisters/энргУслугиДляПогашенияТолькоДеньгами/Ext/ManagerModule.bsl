Функция РезультатУслугиДляПогашенияТолькоДеньгами() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаУслугиДляПогашенияТолькоДеньгами();
	
	Результат = Запрос.Выполнить();
	Возврат Результат;
	                     	
КонецФункции

Функция УслугиДляПогашенияТолькоДеньгами(Схема, ПараметрыОтбора, ТаблицаДляПомещения) Экспорт
	 Если Схема = Неопределено Тогда
		Схема  = Новый СхемаЗапроса;
		Пакет  = Схема.ПакетЗапросов[0];
	Иначе
		Пакет  = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаУслугиДляПогашенияТолькоДеньгами());
	Пакет.ТаблицаДляПомещения 	= ТаблицаДляПомещения;
КонецФункции

