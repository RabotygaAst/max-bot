#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Функция СформироватьТабличныйДокумент(Период, Организация, Район, АбонентскийОтдел, Договор, ВариантОтчета) Экспорт
	ТабДок	= Новый ТабличныйДокумент;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапроса();

	Если Не ЗначениеЗаполнено(Договор) Тогда    
		Запрос.Текст	= СтрЗаменить(Запрос.Текст, "бестАвансыИспользованныеЭЭ.Договор = &Договор", "ИСТИНА");
		Запрос.Текст	= СтрЗаменить(Запрос.Текст, "Договор = &Договор", "ИСТИНА");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(АбонентскийОтдел) Тогда
		Запрос.Текст	= СтрЗаменить(Запрос.Текст, "энргДоговорыКонтрагентов.Филиал = &АбонентскийОтдел", "ИСТИНА");
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.УстановитьПараметр("АбонентскийОтдел",	АбонентскийОтдел);
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("Договор",			Договор);
	Запрос.УстановитьПараметр("Начало",				Новый Граница(Период.ДатаНачала, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Конец",				Новый Граница(Период.ДатаОкончания, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Начало2",			Период.ДатаНачала);
	Запрос.УстановитьПараметр("Конец2",				Период.ДатаОкончания); 
	
	ОснованаяРеализация	= Истина;
	Пени				= Истина;
		
	Если ВариантОтчета = 0 Тогда
		Пени				= Ложь;
	ИначеЕсли ВариантОтчета = 1 Тогда
		ОснованаяРеализация	= Ложь;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ОснованаяРеализация",	ОснованаяРеализация);
	Запрос.УстановитьПараметр("Пени",					Пени);

	Макет			= ПолучитьМакет("Макет"); 
	
	ОбластьЗаголовок			= Макет.Получитьобласть("Заголовок");
	
	ОбластьШапкаНачало			= Макет.Получитьобласть("ШапкаНачало");
	ОбластьШапкаЗадолженность	= Макет.Получитьобласть("ШапкаЗадолженность");
	ОбластьШапкаОбороты			= Макет.Получитьобласть("ШапкаОбороты");
	ОбластьШапкаКонец			= Макет.Получитьобласть("ШапкаКонец");
	
	ОбластьСтрокаНачало			= Макет.Получитьобласть("СтрокаНачало");
	ОбластьСтрокаЗадолженность	= Макет.Получитьобласть("СтрокаЗадолженность");
	ОбластьСтрокаОбороты		= Макет.Получитьобласть("СтрокаОбороты");
	ОбластьСтрокаКонец			= Макет.Получитьобласть("СтрокаКонец");
	
	ОбластьГруппаНачало			= Макет.Получитьобласть("ГруппаНачало");
	ОбластьГруппаЗадолженность	= Макет.Получитьобласть("ГруппаЗадолженность");
	ОбластьГруппаОбороты		= Макет.Получитьобласть("ГруппаОбороты");
	ОбластьГруппаКонец			= Макет.Получитьобласть("ГруппаКонец");
	
	ОбластьИтого				= Макет.Получитьобласть("Итого");
	
	ОбластьЗаголовок.Параметры.Начало			= Формат(Период.ДатаНачала, "ДЛФ=D"); 
	ОбластьЗаголовок.Параметры.Конец			= Формат(Период.ДатаОкончания, "ДЛФ=D");
	ОбластьЗаголовок.Параметры.Организация		= Организация;
	ОбластьЗаголовок.Параметры.Район			= Район;
	ОбластьЗаголовок.Параметры.Договор			= Договор;
    ТабДок.Вывести(ОбластьЗаголовок);

	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаПериодов = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Период", "ВСЕ");
	
	ТабДок.Вывести(ОбластьШапкаНачало);
	// выводим шапку
	Пока ВыборкаПериодов.Следующий() Цикл
		ОбластьШапкаЗадолженность.Параметры.Период	= Формат(ВыборкаПериодов.Период, "ДЛФ=DD");
		ТабДок.Присоединить(ОбластьШапкаЗадолженность);
		ТабДок.Присоединить(ОбластьШапкаОбороты);
	КонецЦикла;
	
	ОбластьШапкаЗадолженность.Параметры.Период	= Формат(Период.ДатаОкончания, "ДЛФ=DD");
	ТабДок.Присоединить(ОбластьШапкаЗадолженность);
	ТабДок.Присоединить(ОбластьШапкаКонец); 
	
	ТабДок.НачатьАвтогруппировкуСтрок();
	
	ВыборкаИтог	= РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаИтог.Следующий() Цикл
		
		ВыборкаБюджета	= ВыборкаИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаБюджета.Следующий() Цикл
			ЗаполнитьСтроку(ВыборкаБюджета, ОбластьГруппаНачало, ОбластьГруппаЗадолженность, ОбластьГруппаОбороты, ОбластьГруппаКонец, ТабДок);
			
			ВыборкаКонтрагент = ВыборкаБюджета.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКонтрагент.Следующий() Цикл
					
				ВыборкаДоговор = ВыборкаКонтрагент.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				Пока ВыборкаДоговор.Следующий() Цикл    
					ЗаполнитьСтроку(ВыборкаДоговор, ОбластьСтрокаНачало, ОбластьСтрокаЗадолженность, ОбластьСтрокаОбороты, ОбластьСтрокаКонец, ТабДок)
				КонецЦикла; 
			КонецЦикла;
		КонецЦикла;
		
		ТабДок.ЗакончитьАвтогруппировкуСтрок();
		
		ЗаполнитьСтроку(ВыборкаИтог, ОбластьИтого, ОбластьГруппаЗадолженность, ОбластьГруппаОбороты, ОбластьГруппаКонец, ТабДок)
		
	КонецЦикла;	
	
	ТабДок.ФиксацияСверху = 6;
	Возврат ТабДок;
	
КонецФункции       

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьСтроку(Выборка, ОбластьСтрокаНачало, ОбластьСтрокаЗадолженность, ОбластьСтрокаОбороты, ОбластьСтрокаКонец, ТабДок)
	ЗаполнитьЗначенияСвойств(ОбластьСтрокаНачало.Параметры, Выборка);
	ТабДок.Вывести(ОбластьСтрокаНачало, Выборка.Уровень());
	
	ВыборкаПериодов = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Период", "ВСЕ");
	Пока ВыборкаПериодов.Следующий() Цикл 
		ЗаполнитьЗначенияСвойств(ОбластьСтрокаЗадолженность.Параметры, ВыборкаПериодов);
		ОбластьСтрокаЗадолженность.Параметры.Задолженность		= ВыборкаПериодов.ДтНачальныйОстаток - ВыборкаПериодов.КтНачальныйОстаток;
		ТабДок.Присоединить(ОбластьСтрокаЗадолженность);
		
		ЗаполнитьЗначенияСвойств(ОбластьСтрокаОбороты.Параметры, ВыборкаПериодов);
		ТабДок.Присоединить(ОбластьСтрокаОбороты);
		
	КонецЦикла;
	
	ОбластьСтрокаЗадолженность.Параметры.Задолженность			= Выборка.ДтКонечныйОстаток - Выборка.КтКонечныйОстаток;
	ОбластьСтрокаЗадолженность.Параметры.ДтНачальныйОстаток		= Выборка.ДтКонечныйОстаток;
	ОбластьСтрокаЗадолженность.Параметры.КтНачальныйОстаток		= Выборка.КтКонечныйОстаток;
	ТабДок.Присоединить(ОбластьСтрокаЗадолженность);
	
	ЗаполнитьЗначенияСвойств(ОбластьСтрокаКонец.Параметры, Выборка);
	ТабДок.Присоединить(ОбластьСтрокаКонец);
КонецПроцедуры

Функция ПолучитьТекстЗапроса()
	
	Текст =
	"ВЫБРАТЬ
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Период КАК Период,
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Договор.Контрагент КАК ДоговорКонтрагент,
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Договор КАК Договор,
	|	СУММА(бестВзаиморасчетыЭЭОстаткиИОбороты.СуммаНачальныйОстаток) КАК СуммаНачальныйОстаток,
	|	0 КАК Начислено,
	|	0 КАК Оплачено,
	|	СУММА(бестВзаиморасчетыЭЭОстаткиИОбороты.СуммаРасход) КАК ОплаченоДт,
	|	СУММА(бестВзаиморасчетыЭЭОстаткиИОбороты.СуммаКонечныйОстаток) КАК СуммаКонечныйОстаток,
	|	0 КАК КтНачальныйОстаток,
	|	0 КАК КтКонечныйОстаток
	|ПОМЕСТИТЬ ОбщиеДанные
	|ИЗ
	|	РегистрНакопления.бестВзаиморасчетыПоМесяцамЭЭ.ОстаткиИОбороты(
	|			&начало,
	|			&Конец,
	|			Месяц,
	|			,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор) КАК бестВзаиморасчетыЭЭОстаткиИОбороты
	|ГДЕ
	|	&ОснованаяРеализация
	|
	|СГРУППИРОВАТЬ ПО
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Период,
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Договор,
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Договор.Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Период,
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Договор.Контрагент,
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Договор,
	|	СУММА(бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.СуммаНачальныйОстаток),
	|	0,
	|	0,
	|	СУММА(бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.СуммаРасход),
	|	СУММА(бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.СуммаКонечныйОстаток),
	|	0,
	|	0
	|ИЗ
	|	РегистрНакопления.бестВзаиморасчетыПоПениЭЭ.ОстаткиИОбороты(
	|			&начало,
	|			&Конец,
	|			Месяц,
	|			,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор) КАК бестВзаиморасчетыПоПениЭЭОстаткиИОбороты
	|ГДЕ
	|	&Пени
	|
	|СГРУППИРОВАТЬ ПО
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Период,
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Договор,
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Договор.Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Период,
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Договор.Контрагент,
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Договор,
	|	0,
	|	СУММА(бестВзаиморасчетыЭЭОстаткиИОбороты.СуммаПриход),
	|	0,
	|	0,
	|	0,
	|	0,
	|	0
	|ИЗ
	|	РегистрНакопления.бестВзаиморасчетыЭЭ.ОстаткиИОбороты(
	|			&начало,
	|			&Конец,
	|			Месяц,
	|			,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор) КАК бестВзаиморасчетыЭЭОстаткиИОбороты
	|ГДЕ
	|	&ОснованаяРеализация
	|
	|СГРУППИРОВАТЬ ПО
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Договор,
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Договор.Контрагент,
	|	бестВзаиморасчетыЭЭОстаткиИОбороты.Период
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бестСуммыОплатЭЭОбороты.Период,
	|	бестСуммыОплатЭЭОбороты.Договор.Контрагент,
	|	бестСуммыОплатЭЭОбороты.Договор,
	|	0,
	|	0,
	|	ВЫБОР
	|		КОГДА НЕ &ОснованаяРеализация
	|				И &Пени
	|			ТОГДА 0
	|		ИНАЧЕ СУММА(бестСуммыОплатЭЭОбороты.СуммаОборот)
	|	КОНЕЦ,
	|	0,
	|	0,
	|	0,
	|	0
	|ИЗ
	|	РегистрНакопления.бестСуммыОплатЭЭ.Обороты(
	|			&начало,
	|			&Конец,
	|			Месяц,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор) КАК бестСуммыОплатЭЭОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	бестСуммыОплатЭЭОбороты.Договор,
	|	бестСуммыОплатЭЭОбороты.Договор.Контрагент,
	|	бестСуммыОплатЭЭОбороты.Период
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Период,
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Договор.Контрагент,
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Договор,
	|	0,
	|	0,
	|	ВЫБОР
	|		КОГДА &ОснованаяРеализация
	|				И НЕ &Пени
	|			ТОГДА -СУММА(бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.СуммаРасход)
	|		КОГДА НЕ &ОснованаяРеализация
	|				И &Пени
	|			ТОГДА СУММА(бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.СуммаРасход)
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	0,
	|	0,
	|	0,
	|	0
	|ИЗ
	|	РегистрНакопления.бестВзаиморасчетыПоПениЭЭ.ОстаткиИОбороты(
	|			&начало,
	|			&Конец,
	|			Месяц,
	|			,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор) КАК бестВзаиморасчетыПоПениЭЭОстаткиИОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Период,
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Договор,
	|	бестВзаиморасчетыПоПениЭЭОстаткиИОбороты.Договор.Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бестАвансыЭЭОстаткиИОбороты.Период,
	|	бестАвансыЭЭОстаткиИОбороты.Договор.Контрагент,
	|	бестАвансыЭЭОстаткиИОбороты.Договор,
	|	0,
	|	0,
	|	0,
	|	0,
	|	0,
	|	СУММА(бестАвансыЭЭОстаткиИОбороты.СуммаНачальныйОстаток),
	|	СУММА(бестАвансыЭЭОстаткиИОбороты.СуммаКонечныйОстаток)
	|ИЗ
	|	РегистрНакопления.бестАвансыЭЭ.ОстаткиИОбороты(
	|			&начало,
	|			&Конец,
	|			Месяц,
	|			,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Договор = &Договор) КАК бестАвансыЭЭОстаткиИОбороты
	|ГДЕ
	|	&ОснованаяРеализация
	|
	|СГРУППИРОВАТЬ ПО
	|	бестАвансыЭЭОстаткиИОбороты.Период,
	|	бестАвансыЭЭОстаткиИОбороты.Договор.Контрагент,
	|	бестАвансыЭЭОстаткиИОбороты.Договор
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(бестАвансыИспользованныеЭЭ.Период, МЕСЯЦ),
	|	бестАвансыИспользованныеЭЭ.Договор.Контрагент,
	|	бестАвансыИспользованныеЭЭ.Договор,
	|	0,
	|	0,
	|	0,
	|	СУММА(бестАвансыИспользованныеЭЭ.Сумма),
	|	0,
	|	0,
