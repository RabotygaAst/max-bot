		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргИсточникиПоступления.Родитель КАК ТипКонтрагента,
	энргИсточникиПоступления.Контрагент КАК Контрагент,
	энргИсторияОплаты.Организация КАК Организация,
	энргИсторияОплаты.Район КАК Район,
	СУММА(энргИсторияОплаты.СуммаПлатежа) КАК Сумма,
	СУММА(1) КАК КоличествоПлатежей,
	энргИсторияОплаты.Абонент КАК Абонент,
	энргИсторияОплаты.ДатаПлатежа КАК ДатаПлатежа,
	НАЧАЛОПЕРИОДА(энргИсторияОплаты.ДатаПлатежа, МЕСЯЦ) КАК ГодИМесяцПлатежа
ИЗ
	РегистрСведений.энргИсторияОплаты КАК энргИсторияОплаты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргИсточникиПоступления КАК энргИсточникиПоступления
		ПО энргИсторияОплаты.ИсточникОплаты = энргИсточникиПоступления.Ссылка
ГДЕ
	энргИсторияОплаты.ДатаПлатежа &gt;= &amp;ДатаНач
	И энргИсторияОплаты.ДатаПлатежа &lt;= &amp;ДатаОкон
	И (энргИсторияОплаты.Район = &amp;Район
			ИЛИ &amp;Район = ЗНАЧЕНИЕ(справочник.энргЗоныОтвественности.ПустаяСсылка)
			ИЛИ &amp;Район = Неопределено)

СГРУППИРОВАТЬ ПО
	энргИсточникиПоступления.Родитель,
	энргИсточникиПоступления.Контрагент,
	энргИсторияОплаты.Организация,
	энргИсторияОплаты.Район,
	энргИсторияОплаты.Абонент,
	энргИсторияОплаты.ДатаПлатежа</query>
