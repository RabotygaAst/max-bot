#Область СлужебныйПрограммныйИнтерфейс

Процедура СформироватьОтчет(ТабДок, ПараметрыОтчета) Экспорт
	ТабДок.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", 	ПараметрыОтчета.Организация);
	Запрос.УстановитьПараметр("ДатаНач", 		ПараметрыОтчета.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаКон", 		КонецДня(ПараметрыОтчета.ДатаКонца)); 
	ГВС	= Новый Массив;
	ГВС.Добавить(ПараметрыОтчета.ТН);
	ГВС.Добавить(ПараметрыОтчета.ТЭ);
	Запрос.УстановитьПараметр("ГВС", 			ГВС);
	Запрос.УстановитьПараметр("ТН", 			ПараметрыОтчета.ТН);
	Запрос.УстановитьПараметр("Тепло", 			ПараметрыОтчета.Тепло);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	энргАбоненты.Ссылка КАК Абонент,
	               |	энргАбоненты.КлючПомещения КАК КлючПомещения,
	               |	энргАбоненты.ЛицевойСчет КАК ЛицевойСчет,
	               |	энргАбоненты.Организация КАК Организация,
	               |	энргАбоненты.Район КАК Район,
	               |	энргАбоненты.СтарыйЛС КАК СтарыйЛС
	               |ПОМЕСТИТЬ ВрТАбоненты
	               |ИЗ
	               |	Справочник.энргАбоненты КАК энргАбоненты
	               |ГДЕ
	               |	НЕ энргАбоненты.ПометкаУдаления
	               |	И энргАбоненты.Организация = &Организация
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	энргАбоненты.Ссылка,
	               |	энргАбоненты.КлючПомещения,
	               |	энргАбоненты.ЛицевойСчет,
	               |	энргАбоненты.Организация,
	               |	энргАбоненты.Район,
	               |	энргАбоненты.СтарыйЛС
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВрТАбоненты.Абонент КАК Абонент,
	               |	ВрТАбоненты.КлючПомещения КАК КлючПомещения,
	               |	ВрТАбоненты.ЛицевойСчет КАК ЛицевойСчет,
	               |	ВрТАбоненты.Организация КАК Организация,
	               |	ВрТАбоненты.Район КАК Район,
	               |	ВрТАбоненты.СтарыйЛС КАК СтарыйЛС
	               |ПОМЕСТИТЬ ВрТЛьготники
	               |ИЗ
	               |	ВрТАбоненты КАК ВрТАбоненты
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргЖильцыЛьготныхКатегорий.СрезПоследних(&ДатаКон, Организация = &Организация) КАК Льготники
	               |		ПО ВрТАбоненты.Организация = Льготники.Организация
	               |			И ВрТАбоненты.Район = Льготники.Район
	               |			И ВрТАбоненты.Абонент = Льготники.Абонент
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВрТАбоненты.Абонент,
	               |	ВрТАбоненты.КлючПомещения,
	               |	ВрТАбоненты.ЛицевойСчет,
	               |	ВрТАбоненты.Организация,
	               |	ВрТАбоненты.Район,
	               |	ВрТАбоненты.СтарыйЛС
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВрТЛьготники.Абонент КАК Абонент,
	               |	ВрТЛьготники.КлючПомещения КАК КлючПомещения,
	               |	ВрТЛьготники.ЛицевойСчет КАК ЛицевойСчет,
	               |	ВрТЛьготники.Организация КАК Организация,
	               |	ВрТЛьготники.Район КАК Район,
	               |	энргКлючиПомещений.Строение КАК Строение,
	               |	энргКлючиПомещений.Помещение КАК Помещение,
	               |	ВрТЛьготники.СтарыйЛС КАК СтарыйЛС
	               |ПОМЕСТИТЬ ВрТКлючи
	               |ИЗ
	               |	ВрТЛьготники КАК ВрТЛьготники
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
	               |		ПО ВрТЛьготники.КлючПомещения = энргКлючиПомещений.Ссылка
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВрТЛьготники.Абонент,
	               |	ВрТЛьготники.КлючПомещения,
	               |	ВрТЛьготники.ЛицевойСчет,
	               |	ВрТЛьготники.Организация,
	               |	ВрТЛьготники.Район,
	               |	энргКлючиПомещений.Строение,
	               |	энргКлючиПомещений.Помещение,
	               |	ВрТЛьготники.СтарыйЛС
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВрТКлючи.Организация КАК Организация,
	               |	ВрТКлючи.Район КАК Район,
	               |	ВрТКлючи.Строение КАК МКД,
	               |	ВрТКлючи.Абонент КАК Абонент,
	               |	НАЧАЛОПЕРИОДА(&ДатаКон, МЕСЯЦ) КАК ПериодНачисления,
	               |	ЕСТЬNULL(энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток, 0) КАК Задолженность,
	               |	0 КАК НачисленоГВСРуб,
	               |	0 КАК НачисленоГВСОбъем,
	               |	0 КАК НачисленоОтоплениеРуб,
	               |	0 КАК НачисленоОтоплениеОбъем,
	               |	0 КАК ПерерасчетОтоплениеРуб,
	               |	0 КАК ПерерасчетГВСРуб,
	               |	0 КАК ПерерасчетОтоплениеОбъем,
	               |	0 КАК ПерерасчетГВСОбъем,
