	               |	ВЫБОР
	               |		КОГДА ВрТ0.Помещение.Родитель = ЗНАЧЕНИЕ(Справочник.энргПомещения.ПустаяСсылка)
	               |			ТОГДА энргПомещения.Наименование
	               |		ИНАЧЕ энргПомещения.Родитель.Наименование
	               |	КОНЕЦ КАК Квартира
	               |ИЗ
	               |	ВрТ0 КАК ВрТ0
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения КАК энргПомещения
	               |		ПО ВрТ0.Помещение = энргПомещения.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения КАК энргСтроения
	               |		ПО ВрТ0.МКД = энргСтроения.Ссылка
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВрТ0.Организация,
	               |	ВрТ0.Район,
	               |	ВрТ0.МКД,
	               |	ВрТ0.Абонент,
	               |	ВрТ0.ПериодНачисления,
	               |	ВрТ0.КлючПомещения,
	               |	ВрТ0.Помещение,
	               |	энргСтроения.Город,
	               |	энргСтроения.Улица,
	               |	энргСтроения.Дом,
	               |	энргСтроения.Корпус,
	               |	энргПомещения.Наименование,
	               |	ВрТ0.СтарыйЛС,
	               |	энргСтроения.ДомДляСортировки,
	               |	энргПомещения.НомерДляСортировки,
	               |	ЕСТЬNULL(ВрТ0.МКД.Наименование, """") + "", "" + ЕСТЬNULL(энргПомещения.Наименование, """"),
	               |	ВЫБОР
	               |		КОГДА ВрТ0.Помещение.Родитель = ЗНАЧЕНИЕ(Справочник.энргПомещения.ПустаяСсылка)
	               |			ТОГДА энргПомещения.Наименование
	               |		ИНАЧЕ энргПомещения.Родитель.Наименование
	               |	КОНЕЦ
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДомДляСортировки,
	               |	НомерДляСортировки";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();	
	
	
	Макет	= Отчеты.бестОтчетДляНРИЦПоЛьготникам.ПолучитьМакет("Макет");
	
	Область	= Макет.ПолучитьОбласть("Шапка");	
	ТабДок.Вывести(Область);
	
	НомерСтроки = 1; 
	Пока Выборка.Следующий() Цикл
		Область	= Макет.ПолучитьОбласть("СтрокаТЧ");
		Область.Параметры.НомерСтроки = НомерСтроки;
		Область.Параметры.Заполнить(Выборка);
		ТабДок.Вывести(Область);
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	Область	= Макет.ПолучитьОбласть("Подвал");
	Область.Параметры.ТекПользователь = Пользователи.ТекущийПользователь();
	ТабДок.Вывести(Область);	
КонецПроцедуры

