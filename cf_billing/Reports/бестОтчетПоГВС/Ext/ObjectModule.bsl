					НомерСтроки = НомерСтроки + 1;
					
					
				КонецЦикла;
				
				ОбластьИтогоМКД.Параметры.МКДУлица = ВыборкаМКД.МКДУлица;
				ОбластьИтогоМКД.Параметры.Заполнить(ВыборкаМКД);
				ТабДок.Вывести(ОбластьИтогоМКД);
				
				ТекСтр = ТекСтр + 1;
				
				ВыборкаПомещение = ВыборкаМКД.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Приоритет");
				
				Если ВыборкаПомещение.Количество() > 1 Тогда
					
					Пока ВыборкаПомещение.Следующий() Цикл
