#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Процедура СформироватьОтчет(ТабДок, ПараметрыОтчета) Экспорт
	
	ТабДок.Очистить();
	
	Макет	= Отчеты.бестОтчетПоГВС.ПолучитьМакет("Макет");
	
	
	ОбластьЗаголовок		= Макет.ПолучитьОбласть("ОбластьЗаголовок");
	ОбластьШапка			= Макет.ПолучитьОбласть("ОбластьШапка");
	ОбластьУК				= Макет.ПолучитьОбласть("ОбластьУК");
	ОбластьМКД				= Макет.ПолучитьОбласть("ОбластьМКД");
	ОбластьДетали			= Макет.ПолучитьОбласть("ОбластьДетали");
	ОбластьИтогоМКД			= Макет.ПолучитьОбласть("ОбластьИтогоМКД");
	ОбластьИтогоМКДЖилые	= Макет.ПолучитьОбласть("ОбластьИтогоМКДЖилые");
	ОбластьИтогоМКДНежилые	= Макет.ПолучитьОбласть("ОбластьИтогоМКДНежилые");
	ОбластьИтогоУК			= Макет.ПолучитьОбласть("ОбластьИтогоУК");
	ОбластьИтогоУКЖилые		= Макет.ПолучитьОбласть("ОбластьИтогоУКЖилые");
	ОбластьИтогоУКНежилые	= Макет.ПолучитьОбласть("ОбластьИтогоУКНежилые");
	ОбластьИтого			= Макет.ПолучитьОбласть("ОбластьИтого");
	ОбластьИтогоЖилые		= Макет.ПолучитьОбласть("ОбластьИтогоЖилые");
	ОбластьИтогоНежилые		= Макет.ПолучитьОбласть("ОбластьИтогоНежилые");
	
	ОбластьЗаголовок.Параметры.Организация = ПараметрыОтчета.Организация;
	ТабДок.Вывести(ОбластьЗаголовок);
	
	ТабДок.Вывести(ОбластьШапка);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", 		ПараметрыОтчета.Организация);
	Запрос.УстановитьПараметр("НачалоПериода", 		ПараметрыОтчета.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", 		КонецДня(ПараметрыОтчета.КонецПериода));
	Запрос.УстановитьПараметр("ГВС_ТН", 			Справочники.энргВидыУслуг.НайтиПоКоду("000000053"));
	Запрос.УстановитьПараметр("ГВС_ТЭ", 			Справочники.энргВидыУслуг.НайтиПоКоду("000000051"));
	Запрос.УстановитьПараметр("ВидНачисления", 		Перечисления.энргВидыНачислений.Начисление);
	Запрос.УстановитьПараметр("ПоНормативу", 		Перечисления.энргСпособНачислений.ПоНормативу);
	Запрос.УстановитьПараметр("ПоСреднему", 		Перечисления.энргСпособНачислений.НачислениеПоСреднему);
	Запрос.УстановитьПараметр("ПоПриборам", 		Перечисления.энргСпособНачислений.ПоПриборам);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	энргФормыУправленияМКДСрезПоследних.Организация КАК Организация,
	               |	энргФормыУправленияМКДСрезПоследних.МКД КАК МКД,
	               |	энргФормыУправленияМКДСрезПоследних.УК КАК УК,
	               |	энргЗначениеПлощадейМКДСрезПоследних.Площадь КАК ПлощадьМКД,
	               |	энргФормыУправленияМКДСрезПоследних.МКД.Улица + "", д. "" + энргФормыУправленияМКДСрезПоследних.МКД.Дом КАК МКДУлица,
	               |	энргФормыУправленияМКДСрезПоследних.МКД.Дом КАК МКДДом
	               |ПОМЕСТИТЬ ВТ_МКД
	               |ИЗ
	               |	РегистрСведений.энргФормыУправленияМКД.СрезПоследних(&КонецПериода, Организация = &Организация) КАК энргФормыУправленияМКДСрезПоследних
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргЗначениеПлощадейМКД.СрезПоследних(
	               |				&КонецПериода,
	               |				Организация = &Организация
	               |					И ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадьМКД)) КАК энргЗначениеПлощадейМКДСрезПоследних
	               |		ПО энргФормыУправленияМКДСрезПоследних.МКД = энргЗначениеПлощадейМКДСрезПоследних.МКД
	               |ГДЕ
	               |	энргФормыУправленияМКДСрезПоследних.ФормаУправления = ЗНАЧЕНИЕ(Перечисление.энргФормыУправленияМКД.УК)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	энргОбъемНачислений.Организация КАК Организация,
	               |	энргОбъемНачислений.Район КАК Район,
	               |	энргОбъемНачислений.Строение КАК МКД,
	               |	энргОбъемНачислений.Абонент КАК Абонент,
	               |	энргОбъемНачислений.Шкала КАК Шкала,
	               |	1 КАК Приоритет,
	               |	СУММА(ВЫБОР
	               |			КОГДА энргОбъемНачислений.СпособНачисления = &ПоНормативу
	               |					И энргОбъемНачислений.Услуга = &ГВС_ТН
	               |				ТОГДА ВЫБОР
	               |						КОГДА энргОбъемНачислений.ПовыщающийКоэффициент > 1
	               |							ТОГДА ВЫРАЗИТЬ(энргОбъемНачислений.ОбъемУслуги / энргОбъемНачислений.ПовыщающийКоэффициент КАК ЧИСЛО(15, 2))
	               |						ИНАЧЕ энргОбъемНачислений.ОбъемУслуги
	               |					КОНЕЦ
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК ОбъемПоНормативу,
	               |	СУММА(ВЫБОР
	               |			КОГДА энргОбъемНачислений.СпособНачисления = &ПоСреднему
	               |					И энргОбъемНачислений.Услуга = &ГВС_ТН
	               |				ТОГДА ВЫБОР
	               |						КОГДА энргОбъемНачислений.ПовыщающийКоэффициент > 1
	               |							ТОГДА ВЫРАЗИТЬ(энргОбъемНачислений.ОбъемУслуги / энргОбъемНачислений.ПовыщающийКоэффициент КАК ЧИСЛО(15, 2))
	               |						ИНАЧЕ энргОбъемНачислений.ОбъемУслуги
	               |					КОНЕЦ
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК ОбъемПоСреднему,
	               |	СУММА(ВЫБОР
	               |			КОГДА энргОбъемНачислений.СпособНачисления = &ПоПриборам
	               |					И энргОбъемНачислений.Услуга = &ГВС_ТН
	               |				ТОГДА ВЫБОР
	               |						КОГДА энргОбъемНачислений.ПовыщающийКоэффициент > 1
	               |							ТОГДА ВЫРАЗИТЬ(энргОбъемНачислений.ОбъемУслуги / энргОбъемНачислений.ПовыщающийКоэффициент КАК ЧИСЛО(15, 2))
	               |						ИНАЧЕ энргОбъемНачислений.ОбъемУслуги
	               |					КОНЕЦ
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК ОбъемПоСПриборам,
	               |	СУММА(ВЫБОР
	               |			КОГДА энргОбъемНачислений.Услуга = &ГВС_ТН
	               |				ТОГДА ВЫБОР
	               |						КОГДА энргОбъемНачислений.ПовыщающийКоэффициент > 1
	               |							ТОГДА ВЫРАЗИТЬ(энргОбъемНачислений.ОбъемУслуги / энргОбъемНачислений.ПовыщающийКоэффициент КАК ЧИСЛО(15, 2))
	               |						ИНАЧЕ энргОбъемНачислений.ОбъемУслуги
	               |					КОНЕЦ
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК ОбъемТН,
	               |	энргОбъемНачислений.ПриборУчета КАК ПриборУчета,
	               |	МИНИМУМ(энргОбъемНачислений.НачальныеПоказания) КАК НачальныеПоказания,
	               |	МАКСИМУМ(энргОбъемНачислений.КонечныеПоказания) КАК КонечныеПоказания,
	               |	энргОбъемНачислений.КоличествоПрописанных КАК КоличествоПрописанных,
	               |	энргОбъемНачислений.ЗначениеПлощади КАК ЗначениеПлощади,
	               |	энргОбъемНачислений.НормаПотребления КАК НормаПотребления,
	               |	энргОбъемНачислений.Абонент.УдалитьКвартира КАК Квартира,
	               |	энргОбъемНачислений.Абонент.ЛицевойСчет КАК ЛицевойСчет,
	               |	СУММА(ВЫБОР
	               |			КОГДА энргОбъемНачислений.Услуга = &ГВС_ТН
	               |				ТОГДА энргОбъемНачислений.ЗначениеТарифа
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК ТарифТН,
	               |	СУММА(ВЫБОР
	               |			КОГДА энргОбъемНачислений.Услуга = &ГВС_ТН
	               |				ТОГДА ВЫБОР
	               |						КОГДА энргОбъемНачислений.ПовыщающийКоэффициент > 1
	               |							ТОГДА ВЫРАЗИТЬ(энргОбъемНачислений.Сумма / энргОбъемНачислений.ПовыщающийКоэффициент КАК ЧИСЛО(15, 2))
	               |						ИНАЧЕ энргОбъемНачислений.Сумма
	               |					КОНЕЦ
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК СуммаТН,
	               |	энргОбъемНачислений.ПовыщающийКоэффициент КАК ПовыщающийКоэффициент,
	               |	СУММА(энргОбъемНачислений.ОбъемУслуги) КАК ОбъемУслуги,
	               |	СУММА(энргОбъемНачислений.Сумма) КАК Сумма
	               |ПОМЕСТИТЬ ВТ_ОбъемНачислений_ТН
	               |ИЗ
	               |	РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
	               |ГДЕ
	               |	энргОбъемНачислений.Услуга = &ГВС_ТН
	               |	И энргОбъемНачислений.ВидНачисления = &ВидНачисления
	               |	И энргОбъемНачислений.Период МЕЖДУ &НачалоПериода И &КонецПериода
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	энргОбъемНачислений.Организация,
	               |	энргОбъемНачислений.Район,
	               |	энргОбъемНачислений.Строение,
	               |	энргОбъемНачислений.Шкала,
	               |	энргОбъемНачислений.Абонент,
	               |	энргОбъемНачислений.ПриборУчета,
	               |	энргОбъемНачислений.КоличествоПрописанных,
	               |	энргОбъемНачислений.ЗначениеПлощади,
	               |	энргОбъемНачислений.НормаПотребления,
	               |	энргОбъемНачислений.Абонент.УдалитьКвартира,
	               |	энргОбъемНачислений.Абонент.ЛицевойСчет,
	               |	энргОбъемНачислений.ПовыщающийКоэффициент
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	бестОбъемНачисленийНП.Организация,
	               |	бестОбъемНачисленийНП.Район,
	               |	бестОбъемНачисленийНП.МКД,
	               |	бестОбъемНачисленийНП.ОбъектРасчета,
	               |	бестОбъемНачисленийНП.Шкала,
	               |	2,
	               |	СУММА(ВЫБОР
	               |			КОГДА бестОбъемНачисленийНП.СпособНачисления = &ПоНормативу
	               |					И бестОбъемНачисленийНП.Услуга = &ГВС_ТН
	               |				ТОГДА ВЫБОР
	               |						КОГДА бестОбъемНачисленийНП.ПовыщающийКоэффициент > 1
	               |							ТОГДА ВЫРАЗИТЬ(бестОбъемНачисленийНП.ОбъемУслуги / бестОбъемНачисленийНП.ПовыщающийКоэффициент КАК ЧИСЛО(15, 2))
	               |						ИНАЧЕ бестОбъемНачисленийНП.ОбъемУслуги
	               |					КОНЕЦ
	               |			ИНАЧЕ 0
	               |		КОНЕЦ),
	               |	СУММА(ВЫБОР
	               |			КОГДА бестОбъемНачисленийНП.СпособНачисления = &ПоСреднему
	               |					И бестОбъемНачисленийНП.Услуга = &ГВС_ТН
	               |				ТОГДА ВЫБОР
	               |						КОГДА бестОбъемНачисленийНП.ПовыщающийКоэффициент > 1
	               |							ТОГДА ВЫРАЗИТЬ(бестОбъемНачисленийНП.ОбъемУслуги / бестОбъемНачисленийНП.ПовыщающийКоэффициент КАК ЧИСЛО(15, 2))
	               |						ИНАЧЕ бестОбъемНачисленийНП.ОбъемУслуги
	               |					КОНЕЦ
	               |			ИНАЧЕ 0
	               |		КОНЕЦ),
	               |	СУММА(ВЫБОР
	               |			КОГДА бестОбъемНачисленийНП.СпособНачисления = &ПоПриборам
	               |					И бестОбъемНачисленийНП.Услуга = &ГВС_ТН
	               |				ТОГДА ВЫБОР
	               |						КОГДА бестОбъемНачисленийНП.ПовыщающийКоэффициент > 1
	               |							ТОГДА ВЫРАЗИТЬ(бестОбъемНачисленийНП.ОбъемУслуги / бестОбъемНачисленийНП.ПовыщающийКоэффициент КАК ЧИСЛО(15, 2))
	               |						ИНАЧЕ бестОбъемНачисленийНП.ОбъемУслуги
	               |					КОНЕЦ
	               |			ИНАЧЕ 0
	               |		КОНЕЦ),
	               |	СУММА(ВЫБОР
	               |			КОГДА бестОбъемНачисленийНП.Услуга = &ГВС_ТН
	               |				ТОГДА ВЫБОР
	               |						КОГДА бестОбъемНачисленийНП.ПовыщающийКоэффициент > 1
	               |							ТОГДА ВЫРАЗИТЬ(бестОбъемНачисленийНП.ОбъемУслуги / бестОбъемНачисленийНП.ПовыщающийКоэффициент КАК ЧИСЛО(15, 2))
	               |						ИНАЧЕ бестОбъемНачисленийНП.ОбъемУслуги
	               |					КОНЕЦ
	               |			ИНАЧЕ 0
	               |		КОНЕЦ),
	               |	бестОбъемНачисленийНП.ПриборУчета,
	               |	МИНИМУМ(бестОбъемНачисленийНП.НачальныеПоказания),
	               |	МАКСИМУМ(бестОбъемНачисленийНП.КонечныеПоказания),
	               |	NULL,
	               |	бестОбъемНачисленийНП.ЗначениеПлощади,
	               |	бестОбъемНачисленийНП.НормаПотребления,
	               |	""нежилое"",
	               |	бестОбъемНачисленийНП.Договор.Номер,
	               |	NULL,
	               |	NULL,
	               |	бестОбъемНачисленийНП.ПовыщающийКоэффициент,
	               |	СУММА(бестОбъемНачисленийНП.ОбъемУслуги),
	               |	NULL
	               |ИЗ
	               |	РегистрНакопления.бестОбъемНачисленийНП КАК бестОбъемНачисленийНП
	               |ГДЕ
	               |	бестОбъемНачисленийНП.Услуга = &ГВС_ТЭ
	               |	И бестОбъемНачисленийНП.ВидНачисления = &ВидНачисления
	               |	И бестОбъемНачисленийНП.Период МЕЖДУ &НачалоПериода И &КонецПериода
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	бестОбъемНачисленийНП.Организация,
	               |	бестОбъемНачисленийНП.Район,
	               |	бестОбъемНачисленийНП.МКД,
	               |	бестОбъемНачисленийНП.ОбъектРасчета,
	               |	бестОбъемНачисленийНП.Шкала,
	               |	бестОбъемНачисленийНП.ПриборУчета,
	               |	бестОбъемНачисленийНП.НормаПотребления,
	               |	бестОбъемНачисленийНП.ЗначениеПлощади,
	               |	бестОбъемНачисленийНП.Договор.Номер,
	               |	бестОбъемНачисленийНП.ПовыщающийКоэффициент
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	энргОбъемНачислений.Организация КАК Организация,
	               |	энргОбъемНачислений.Район КАК Район,
	               |	энргОбъемНачислений.Строение КАК МКД,
	               |	энргОбъемНачислений.Абонент КАК Абонент,
	               |	СУММА(ВЫБОР
	               |			КОГДА энргОбъемНачислений.Услуга = &ГВС_ТЭ
	               |				ТОГДА энргОбъемНачислений.Сумма
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК СуммаТЭ,
	               |	СУММА(ВЫБОР
	               |			КОГДА энргОбъемНачислений.Услуга = &ГВС_ТЭ
	               |				ТОГДА энргОбъемНачислений.ЗначениеТарифа
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК ТарифТЭ,
	               |	СУММА(ВЫБОР
	               |			КОГДА энргОбъемНачислений.Услуга = &ГВС_ТЭ
