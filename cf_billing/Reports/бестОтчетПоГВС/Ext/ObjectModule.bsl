	               |	ВТ_ОбъемНачислений.ОбъемПоСреднему КАК ОбъемПоСреднему,
	               |	ВТ_ОбъемНачислений.ОбъемТН КАК ОбъемТН,
	               |	ВТ_ОбъемНачислений.ТарифТН КАК ТарифТН,
	               |	ВТ_ОбъемНачислений.СуммаТН КАК СуммаТН,
	               |	ВТ_ОбъемНачислений.ОбъемТЭ КАК ОбъемТЭ,
	               |	ВТ_ОбъемНачислений.ТарифТЭ КАК ТарифТЭ,
	               |	ВТ_ОбъемНачислений.СуммаТЭ КАК СуммаТЭ,
	               |	ВТ_ОбъемНачисленийМКД_ТН.ОбъемУслуги КАК ОбъемУслугиМКД,
	               |	ВТ_ОбъемНачислений.ПовыщающийКоэффициент КАК ПовыщающийКоэффициент,
	               |	ВТ_ОбъемНачислений.ОбъемУслуги КАК ОбъемУслугиСПовышающим,
	               |	ВТ_ОбъемНачислений.Сумма КАК СуммаСПовышающим,
	               |	ВТ_МКД.УК КАК УК,
	               |	ВТ_МКД.МКДУлица КАК МКДУлица,
	               |	(ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_ОбъемНачислений.СуммаТН, 0) / ВТ_ОбъемНачислений.ПовыщающийКоэффициент КАК ЧИСЛО(15, 4))) + (ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_ОбъемНачислений.СуммаТЭ, 0) КАК ЧИСЛО(15, 4))) КАК СуммаИтого,
	               |	(ВЫРАЗИТЬ(ВТ_ОбъемНачислений.Сумма КАК ЧИСЛО(15, 4))) - (ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_ОбъемНачислений.СуммаТН, 0) / ВТ_ОбъемНачислений.ПовыщающийКоэффициент КАК ЧИСЛО(15, 4))) - (ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_ОбъемНачислений.СуммаТЭ, 0) КАК ЧИСЛО(15, 4))) КАК НачисленоПоПовышающему,
	               |	ЕСТЬNULL(ВТ_ОбъемНачисленийМКД_ТН.ОбъемУслуги, 0) - ЕСТЬNULL(ВТ_ОбъемНачислений.ОбъемТН, 0) КАК ОДН
	               |ИЗ
	               |	ВТ_МКД КАК ВТ_МКД
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ОбъемНачислений КАК ВТ_ОбъемНачислений
	               |			ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НормативыПотребления КАК ВТ_НормативыПотребленияОДН
	               |			ПО ВТ_ОбъемНачислений.Организация = ВТ_НормативыПотребленияОДН.Организация
	               |				И ВТ_ОбъемНачислений.Район = ВТ_НормативыПотребленияОДН.Район
	               |				И (ВТ_НормативыПотребленияОДН.ТипНачисления = ЗНАЧЕНИЕ(Перечисление.энргТипыНачислений.ОбщедомовыеНачисления))
	               |				И (ВТ_НормативыПотребленияОДН.Услуга = &ГВС_ТЭ)
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ДанныеПоАбонентам КАК ВТ_ДанныеПоАбонентам
	               |			ПО ВТ_ОбъемНачислений.Абонент = ВТ_ДанныеПоАбонентам.Абонент
	               |		ПО ВТ_МКД.Организация = ВТ_ОбъемНачислений.Организация
	               |			И ВТ_МКД.МКД = ВТ_ОбъемНачислений.МКД
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПлощадьПомещенийМКД КАК ВТ_ПлощадьПомещенийМКД
	               |		ПО ВТ_МКД.МКД = ВТ_ПлощадьПомещенийМКД.МКД
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОбъемНачисленийМКД_ТН КАК ВТ_ОбъемНачисленийМКД_ТН
	               |		ПО ВТ_МКД.МКД = ВТ_ОбъемНачисленийМКД_ТН.МКД
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	УК,
	               |	МКДУлица,
	               |	Приоритет
	               |ИТОГИ
	               |	СУММА(КоличествоПрописанных),
