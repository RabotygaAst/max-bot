	               |	МКДУлица,
	               |	Приоритет,
	               |	Абонент";
	
	Результат = Запрос.Выполнить();
	
	ВыборкаИтоги = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
