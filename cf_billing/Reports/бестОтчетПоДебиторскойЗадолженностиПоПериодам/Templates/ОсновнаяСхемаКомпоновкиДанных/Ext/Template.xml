			<dataPath>СальдоНаНачалоКт</dataPath>
			<field>СальдоНаНачалоКт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сальдо на начало кт</v8:content>
