			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Задолженность до90 дн</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЗадолженностьОт91До180Дн</dataPath>
			<field>ЗадолженностьОт91До180Дн</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Задолженность от91 до180 дн</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЗадолженностьОт181До365Дн</dataPath>
			<field>ЗадолженностьОт181До365Дн</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Задолженность от181 до365 дн</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЗадолженностьОт365До1065Дн</dataPath>
			<field>ЗадолженностьОт365До1065Дн</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Задолженность от365 до1065 дн</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЗадолженностьОт1065Дн</dataPath>
			<field>ЗадолженностьОт1065Дн</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Задолженность от1065 дн</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>слжРазделительДляТестов</dataPath>
			<field>слжРазделительДляТестов</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргВзаиморасчетыПоМесяцам.Абонент КАК Абонент,
	энргАбоненты.ЛицевойСчет КАК ЛицевойСчет,
	энргАбоненты.ФизЛицо КАК ФИО,
	энргВзаиморасчетыПоМесяцам.ПериодНачисления КАК ПериодНачисления,
	энргВзаиморасчетыПоМесяцам.Услуга КАК Услуга,
	энргВзаиморасчетыПоМесяцам.Сумма КАК Сумма,
	энргВзаиморасчетыПоМесяцам.Период КАК ДатаПоступления,
	энргВзаиморасчетыПоМесяцам.ВидДвижения КАК ВидДвижения,
	энргАбонентыКонтактнаяИнформация.Представление КАК АдресАбонента,
	ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(энргВзаиморасчетыПоМесяцам.ПериодНачисления, МЕСЯЦ), ДЕНЬ, 10) КАК СрокОплаты,
	энргАбоненты.КлючПомещения КАК КлючПомещения,
	энргВзаиморасчетыПоМесяцам.МКД КАК МКД,
	энргСтроенияКонтактнаяИнформация.Представление КАК АдресМКД,
	КОНЕЦПЕРИОДА(энргВзаиморасчетыПоМесяцам.ПериодНачисления, МЕСЯЦ) КАК ДатаВозникновенияЗадолженности
ПОМЕСТИТЬ ВТ_Взаиморасчеты
ИЗ
	РегистрНакопления.энргВзаиморасчетыПоМесяцам КАК энргВзаиморасчетыПоМесяцам
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
			ПО энргАбоненты.Ссылка = энргАбонентыКонтактнаяИнформация.Ссылка
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
			ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.КлючПомещения
		ПО энргВзаиморасчетыПоМесяцам.Абонент = энргАбоненты.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
		ПО энргВзаиморасчетыПоМесяцам.МКД = энргСтроенияКонтактнаяИнформация.Ссылка
ГДЕ
	энргВзаиморасчетыПоМесяцам.ПериодНачисления МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	энргВзаиморасчетыПоМесяцамОстатки.Абонент КАК Абонент,
	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток КАК СуммаОстаток
ПОМЕСТИТЬ ВТ_ЗадолженностьНаНачало
ИЗ
	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
			&amp;НачалоПериода,
			Организация = &amp;Организация
				И Район = &amp;Район
				И Абонент В
					(ВЫБРАТЬ
						ВТ_Взаиморасчеты.Абонент
					ИЗ
						ВТ_Взаиморасчеты)) КАК энргВзаиморасчетыПоМесяцамОстатки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Взаиморасчеты.Абонент КАК Абонент,
	ВТ_Взаиморасчеты.ПериодНачисления КАК ПериодНачисления,
	ВТ_Взаиморасчеты.Услуга КАК Услуга,
	ВТ_Взаиморасчеты.Сумма КАК Сумма
ПОМЕСТИТЬ ВТ_НачислениеПоУслугам
ИЗ
	ВТ_Взаиморасчеты КАК ВТ_Взаиморасчеты
ГДЕ
	ВТ_Взаиморасчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Взаиморасчеты.Абонент КАК Абонент,
	ВТ_Взаиморасчеты.ПериодНачисления КАК ПериодНачисления,
	ВТ_Взаиморасчеты.Услуга КАК Услуга,
	ВТ_Взаиморасчеты.Сумма КАК Сумма
ПОМЕСТИТЬ ВТ_ОплатаПоУслугам
ИЗ
	ВТ_Взаиморасчеты КАК ВТ_Взаиморасчеты
ГДЕ
	ВТ_Взаиморасчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВТ_Взаиморасчеты.Абонент КАК Абонент,
	ВТ_Взаиморасчеты.ЛицевойСчет КАК ЛицевойСчет,
	ВТ_Взаиморасчеты.АдресАбонента КАК АдресАбонента,
	ВТ_Взаиморасчеты.ФИО КАК ФИО,
	ВТ_Взаиморасчеты.ПериодНачисления КАК ПериодНачисления,
	ВТ_Взаиморасчеты.Услуга КАК Услуга,
	ВТ_Взаиморасчеты.СрокОплаты КАК СрокОплаты,
	ВТ_Взаиморасчеты.КлючПомещения КАК КлючПомещения,
	ВТ_Взаиморасчеты.МКД КАК МКД,
	ЕСТЬNULL(ВТ_ЗадолженностьНаНачало.СуммаОстаток, 0) КАК ЗадолженностьНаНачало,
	ВТ_Взаиморасчеты.АдресМКД КАК АдресМКД,
	ВТ_Взаиморасчеты.ДатаВозникновенияЗадолженности КАК ДатаВозникновенияЗадолженности
ПОМЕСТИТЬ ВТ_Абоненты
ИЗ
	ВТ_Взаиморасчеты КАК ВТ_Взаиморасчеты
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗадолженностьНаНачало КАК ВТ_ЗадолженностьНаНачало
		ПО ВТ_Взаиморасчеты.Абонент = ВТ_ЗадолженностьНаНачало.Абонент
			И ВТ_Взаиморасчеты.Услуга = ВТ_ЗадолженностьНаНачало.Услуга
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВТ_Абоненты.Абонент КАК Абонент,
	ВТ_Абоненты.ЛицевойСчет КАК ЛицевойСчет,
	ВТ_Абоненты.АдресМКД КАК АдресМКД,
	ВТ_Абоненты.АдресАбонента КАК АдресАбонента,
	ВТ_Абоненты.ФИО КАК ФИО,
	ВТ_Абоненты.ПериодНачисления КАК ПериодНачисления,
	ВТ_Абоненты.Услуга КАК Услуга,
	ЕСТЬNULL(ВТ_НачислениеПоУслугам.Сумма, 0) КАК НачисленнаяСумма,
	ЕСТЬNULL(ВТ_ОплатаПоУслугам.Сумма, 0) КАК СуммаОплаты,
	ВТ_Абоненты.ДатаВозникновенияЗадолженности КАК ДатаВозникновенияЗадолженности,
	ВТ_Абоненты.СрокОплаты КАК ДатаПогашенияЗадолженности,
	ВЫБОР
		КОГДА ВТ_Абоненты.ЗадолженностьНаНачало &gt; 0
			ТОГДА ВТ_Абоненты.ЗадолженностьНаНачало
		ИНАЧЕ 0
	КОНЕЦ КАК СальдоНаНачалоДт,
	ВЫБОР
		КОГДА ВТ_Абоненты.ЗадолженностьНаНачало &lt;= 0
			ТОГДА ВТ_Абоненты.ЗадолженностьНаНачало
		ИНАЧЕ 0
	КОНЕЦ КАК СальдоНаНачалоКт,
	ВЫБОР
		КОГДА РАЗНОСТЬДАТ(&amp;ТекДата, ВТ_Абоненты.СрокОплаты, ДЕНЬ) &lt;= 90
			ТОГДА ЕСТЬNULL(ВТ_НачислениеПоУслугам.Сумма, 0) - ЕСТЬNULL(ВТ_ОплатаПоУслугам.Сумма, 0)
		ИНАЧЕ 0
	КОНЕЦ КАК ЗадолженностьДо90Дн,
	ВЫБОР
		КОГДА РАЗНОСТЬДАТ(&amp;ТекДата, ВТ_Абоненты.СрокОплаты, ДЕНЬ) &gt;= 91
				И РАЗНОСТЬДАТ(&amp;ТекДата, ВТ_Абоненты.СрокОплаты, ДЕНЬ) &lt;= 180
			ТОГДА ЕСТЬNULL(ВТ_НачислениеПоУслугам.Сумма, 0) - ЕСТЬNULL(ВТ_ОплатаПоУслугам.Сумма, 0)
		ИНАЧЕ 0
	КОНЕЦ КАК ЗадолженностьОт91До180Дн,
	ВЫБОР
		КОГДА РАЗНОСТЬДАТ(&amp;ТекДата, ВТ_Абоненты.СрокОплаты, ДЕНЬ) &gt;= 181
				И РАЗНОСТЬДАТ(&amp;ТекДата, ВТ_Абоненты.СрокОплаты, ДЕНЬ) &lt;= 365
			ТОГДА ЕСТЬNULL(ВТ_НачислениеПоУслугам.Сумма, 0) - ЕСТЬNULL(ВТ_ОплатаПоУслугам.Сумма, 0)
		ИНАЧЕ 0
	КОНЕЦ КАК ЗадолженностьОт181До365Дн,
	ВЫБОР
		КОГДА РАЗНОСТЬДАТ(&amp;ТекДата, ВТ_Абоненты.СрокОплаты, ДЕНЬ) &gt;= 366
				И ВЫБОР
					КОГДА РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&amp;ТекДата, ГОД), МЕСЯЦ, 1), ДЕНЬ, 27), ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&amp;ТекДата, ГОД), МЕСЯЦ, 2), ДЕНЬ) = 2
						ТОГДА РАЗНОСТЬДАТ(&amp;ТекДата, ВТ_Абоненты.СрокОплаты, ДЕНЬ) &lt;= 1066
					ИНАЧЕ РАЗНОСТЬДАТ(&amp;ТекДата, ВТ_Абоненты.СрокОплаты, ДЕНЬ) &lt;= 1065
				КОНЕЦ
			ТОГДА ЕСТЬNULL(ВТ_НачислениеПоУслугам.Сумма, 0) - ЕСТЬNULL(ВТ_ОплатаПоУслугам.Сумма, 0)
		ИНАЧЕ 0
	КОНЕЦ КАК ЗадолженностьОт365До1065Дн,
	ВЫБОР
		КОГДА РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&amp;ТекДата, ГОД), МЕСЯЦ, 1), ДЕНЬ, 27), ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&amp;НачалоПериода, ГОД), МЕСЯЦ, 2), ДЕНЬ) = 2
			ТОГДА ВЫБОР
					КОГДА РАЗНОСТЬДАТ(&amp;ТекДата, ВТ_Абоненты.СрокОплаты, ДЕНЬ) &gt; 1066
