				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Объем услуги потребленный (норма)</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргОбъемНачисленийОбороты.Организация КАК Организация,
	энргОбъемНачисленийОбороты.Строение КАК МКД,
	энргОбъемНачисленийОбороты.Абонент КАК Абонент,
	энргОбъемНачисленийОбороты.Услуга КАК Услуга,
	энргОбъемНачисленийОбороты.ЗначениеТарифа КАК ЗначениеТарифа,
	СУММА(энргОбъемНачисленийОбороты.СуммаОборот) КАК СуммаОборот,
	СУММА(энргОбъемНачисленийОбороты.ОбъемУслугиОборот) КАК ОбъемУслугиОборот,
	ВЫБОР
		КОГДА энргОбъемНачисленийОбороты.ОбъемУслугиОборот * энргОбъемНачисленийОбороты.ЗначениеТарифа = 0
			ТОГДА 0
		ИНАЧЕ ВЫРАЗИТЬ(энргОбъемНачисленийОбороты.СуммаОборот / (энргОбъемНачисленийОбороты.ОбъемУслугиОборот * энргОбъемНачисленийОбороты.ЗначениеТарифа) КАК ЧИСЛО(3, 1))
	КОНЕЦ КАК Коэф,
	энргОбъемНачисленийОбороты.Помещение КАК Помещение,
	энргОбъемНачисленийОбороты.СуммаПоПовышенномуКоэффициентуОборот КАК СуммаПоПовКоэф,
	энргОбъемНачисленийОбороты.ВидНачисления КАК ВидНачисления,
	СУММА(энргОбъемНачисленийОбороты.ОбъемУслугиПотребленныйОборот) КАК ОбъемУслугиПотребленный,
	СУММА(ВЫБОР
			КОГДА энргОбъемНачисленийОбороты.СверхНорматива
				ТОГДА энргОбъемНачисленийОбороты.ОбъемУслугиОборот
			ИНАЧЕ 0
		КОНЕЦ) КАК ОбъемУслугиСверхНорма,
	СУММА(ВЫБОР
			КОГДА энргОбъемНачисленийОбороты.СверхНорматива
				ТОГДА 0
			ИНАЧЕ энргОбъемНачисленийОбороты.ОбъемУслугиОборот
		КОНЕЦ) КАК ОбъемУслугиНорма,
	СУММА(ВЫБОР
			КОГДА энргОбъемНачисленийОбороты.СверхНорматива
				ТОГДА энргОбъемНачисленийОбороты.ОбъемУслугиПотребленныйОборот
			ИНАЧЕ 0
		КОНЕЦ) КАК ОбъемУслугиПотребленныйСверхНорма,
	СУММА(ВЫБОР
			КОГДА энргОбъемНачисленийОбороты.СверхНорматива
				ТОГДА 0
			ИНАЧЕ энргОбъемНачисленийОбороты.ОбъемУслугиПотребленныйОборот
		КОНЕЦ) КАК ОбъемУслугиПотребленныйНорма
ПОМЕСТИТЬ ВрТ0
ИЗ
	РегистрНакопления.энргОбъемНачислений.Обороты(
			,
			,
			,
			Организация = &amp;Организация
				) КАК энргОбъемНачисленийОбороты

СГРУППИРОВАТЬ ПО
	энргОбъемНачисленийОбороты.Услуга,
	энргОбъемНачисленийОбороты.Абонент,
	энргОбъемНачисленийОбороты.Организация,
	энргОбъемНачисленийОбороты.Строение,
	энргОбъемНачисленийОбороты.ЗначениеТарифа,
	энргОбъемНачисленийОбороты.Помещение,
	ВЫБОР
		КОГДА энргОбъемНачисленийОбороты.ОбъемУслугиОборот * энргОбъемНачисленийОбороты.ЗначениеТарифа = 0
			ТОГДА 0
		ИНАЧЕ ВЫРАЗИТЬ(энргОбъемНачисленийОбороты.СуммаОборот / (энргОбъемНачисленийОбороты.ОбъемУслугиОборот * энргОбъемНачисленийОбороты.ЗначениеТарифа) КАК ЧИСЛО(3, 1))
	КОНЕЦ,
	энргОбъемНачисленийОбороты.СуммаПоПовышенномуКоэффициентуОборот,
	энргОбъемНачисленийОбороты.ВидНачисления
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВрТ0.Организация КАК Организация,
	ВрТ0.МКД КАК МКД,
	ВрТ0.Абонент КАК Абонент,
