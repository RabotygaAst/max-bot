	ВрТ0.Помещение КАК Помещение,
	ВрТ0.СуммаПоПовКоэф КАК СуммаПоПовКоэф,
	ВрТ0.ВидНачисления КАК ВидНачисления,
	ВрТ0.ОбъемУслугиПотребленный КАК ОбъемУслугиПотребленный,
	ВрТ0.ОбъемУслугиСверхНорма КАК ОбъемУслугиСверхНорма,
	ВрТ0.ОбъемУслугиНорма КАК ОбъемУслугиНорма,
	ВрТ0.ОбъемУслугиПотребленныйСверхНорма КАК ОбъемУслугиПотребленныйСверхНорма,
	ВрТ0.ОбъемУслугиПотребленныйНорма КАК ОбъемУслугиПотребленныйНорма
ПОМЕСТИТЬ ВрТ1
ИЗ
	ВрТ0 КАК ВрТ0
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		ПО ВрТ0.Абонент = энргАбоненты.Ссылка

СГРУППИРОВАТЬ ПО
	энргАбоненты.УдалитьУлица,
	ВрТ0.Услуга,
	ВрТ0.Организация,
	ВрТ0.Абонент,
	ВрТ0.МКД,
	энргАбоненты.УдалитьКвартира,
	энргАбоненты.УдалитьДом,
	ВрТ0.ЗначениеТарифа,
	ВрТ0.СуммаОборот,
	ВрТ0.ОбъемУслугиОборот,
	ВрТ0.Коэф,
	энргАбоненты.ЛицевойСчет,
	ВрТ0.Помещение,
	ВрТ0.СуммаПоПовКоэф,
	ВрТ0.ВидНачисления,
	ВрТ0.ОбъемУслугиПотребленный,
	ВрТ0.ОбъемУслугиСверхНорма,
	ВрТ0.ОбъемУслугиНорма,
	ВрТ0.ОбъемУслугиПотребленныйСверхНорма,
	ВрТ0.ОбъемУслугиПотребленныйНорма
;

