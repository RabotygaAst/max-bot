		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргДоговорыКонтрагентов.Контрагент КАК НаименованиеОтветчика,
	энргКонтрагенты.ИНН КАК ИНН,
	энргЗадачаПИД.Договор КАК Договор,
	энргЗадачаПИД.Район КАК РайонноеОтделение,
	энргЗадачаПИД.НомерСудебногоДела КАК НомерСлужебнойЗаписки,
	энргЗадачаПИД.ДатаСдачиИска КАК ДатаСдачиИскаВСуд,
	"взыскание долга и пени" КАК ПредметИска,
	энргЗадачаПИД.СуммаЗадолженности КАК ОсновнойДолг,
	энргЗадачаПИД.ПериодЗадолженностиНачало КАК ПериодЗадолженностиНачало,
	энргЗадачаПИД.ПериодЗадолженностиКонец КАК ПериодЗадолженностиКонец,
	энргЗадачаПИД.СуммаПени КАК ПениПроценты,
	энргЗадачаПИД.СуммаПени + энргЗадачаПИД.СуммаЗадолженности + энргЗадачаПИД.Прочие КАК СуммаКВзысканию,
	энргЗадачаПИД.СуммаГоспошлина КАК Госпошлина,
	энргЗадачаПИД.Прочие КАК РасходыПредставителя,
	энргЗадачаПИД.НомерСудебногоДела КАК НомерСудебногоДела,
	энргЗадачаПИД.ВидСудопроизводства КАК ТипСудебногоРазбирательства,
	энргЗадачаПИДСудебныеИнстанции.ДатаВынесенияРешенияСуда КАК ДатаВынесенияРешенияСуда,
	энргЗадачаПИДСудебныеИнстанции.ДатаВступленияВЗаконнуюСилу КАК ДатаВступленияВЗаконнуюСилу,
	энргЗадачаПИДСудебныеИнстанции.ОсновнойДолг КАК СуммаДолгаПоРешениюСуда,
	энргЗадачаПИДСудебныеИнстанции.Пени КАК СуммаПениПоРешениюСуда,
	энргЗадачаПИДСудебныеИнстанции.Госпошлина КАК СуммаГоспошлиныПоРешениюСуда,
	энргЗадачаПИДСудебныеИнстанции.Прочие КАК СуммаРасходовПредставителяПоРешениюСуда,
	энргЗадачаПИДИсполнительныеДокументы.Дата КАК ДатаПредъявленияИсполнительногоЛистаКИсполнению,
	энргЗадачаПИДИсполнительныеДокументы.Долг КАК СуммаЗадолженностиНаИсполненииПоОсновномуДолгу,
	энргЗадачаПИДИсполнительныеДокументы.Пеня КАК СуммаЗадолженностиНаИсполненииПоПени,
	энргЗадачаПИДИсполнительныеДокументы.Госпошлина КАК СуммаЗадолженностиНаИсполненииПоГоспошлине,
	энргЗадачаПИДИсполнительныеДокументы.Прочие КАК СуммаЗадолженностиНаИсполненииРасходыПредставителя,
	энргЗадачаПИДИсполнительныеДокументы.Долг + энргЗадачаПИДИсполнительныеДокументы.Пеня + энргЗадачаПИДИсполнительныеДокументы.Госпошлина + энргЗадачаПИДИсполнительныеДокументы.Прочие КАК ИтогоСуммаЗадолженностиНаИсполнении,
	энргЗадачаПИД.СтадияИсполнения КАК СтадияИсполнения,
	энргЗадачаПИДИсполнительныеДокументы.ИсполнительПоСуду КАК ИсполнительПоСуду,
	энргЗадачаПИДИсполнительныеДокументы.ИсполнительПоИсполнительномуПроизводству КАК ИсполнительПоИсполнительномуПроизводству,
	бестБанкротствоПоДоговоруСрезПоследних.ПризнанБанкротом КАК ПризнанБанкротом,
	ЕСТЬNULL(бестБанкротствоПоДоговоруСрезПоследних.ДатаПубликации, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПубликацииОБанкротстве
ИЗ
	Задача.энргЗадачаПИД КАК энргЗадачаПИД
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
			ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагенты.Ссылка
		ПО энргЗадачаПИД.Договор = энргДоговорыКонтрагентов.Ссылка
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыОперацийПИД КАК энргВидыОперацийПИД
		ПО энргЗадачаПИД.Этап = энргВидыОперацийПИД.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.СудебныеИнстанции КАК энргЗадачаПИДСудебныеИнстанции
		ПО (энргЗадачаПИДСудебныеИнстанции.Ссылка = энргЗадачаПИД.Ссылка)
			И (энргЗадачаПИДСудебныеИнстанции.Текущая)
		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.ИсполнительныеДокументы КАК энргЗадачаПИДИсполнительныеДокументы
		ПО (энргЗадачаПИДИсполнительныеДокументы.Ссылка = энргЗадачаПИД.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестЗарегистрированныеБанкроты.СрезПоследних КАК бестБанкротствоПоДоговоруСрезПоследних
		ПО энргЗадачаПИД.Организация = бестБанкротствоПоДоговоруСрезПоследних.Организация
			И энргЗадачаПИД.Район = бестБанкротствоПоДоговоруСрезПоследних.Район
			И энргЗадачаПИД.Договор = бестБанкротствоПоДоговоруСрезПоследних.Договор
ГДЕ
	энргВидыОперацийПИД.Тип = ЗНАЧЕНИЕ(Перечисление.энргТипыЭтапов.ИсполнительнаяРабота)
	И НЕ энргВидыОперацийПИД.ПометкаУдаления
{ГДЕ
	(энргЗадачаПИД.Дата &gt;= &amp;НачалоПериода),
	(энргЗадачаПИД.Дата &lt;= &amp;КонецПериода),
	(энргЗадачаПИД.Район = &amp;Район),
	(энргЗадачаПИД.Договор = &amp;Договор),
	(энргЗадачаПИД.Исполнитель = &amp;Исполнитель)}</query>
	</dataSet>
