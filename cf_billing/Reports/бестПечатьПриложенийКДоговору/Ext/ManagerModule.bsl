			КодОбъекта = Строка(ВыборкаДанные2.НомерДоговора) + "_" + Строка(ВыборкаДанные2.КодОбъектаРасчета);
			Если КодОбъекта <> ТекКодОбъекта Тогда
				ОбластьШапка.Параметры.КодОбъекта = Строка(ОбластьШапка.Параметры.КодОбъекта) + ?(ЗначениеЗаполнено(ОбластьШапка.Параметры.КодОбъекта), ", ", "") + КодОбъекта;		
			КонецЕсли;
			ТекКодОбъекта = КодОбъекта;	
		КонецЕсли;	
	КонецЦикла;

	ТабДок.Вывести(ОбластьШапка);
	ТранзитШаблон = НСтр("ru = '%1%2<%3>, %4, %5'");
	Пока ВыборкаДанные.Следующий() Цикл
		Если ВыборкаДанные.ОбъектРасчета <> ТекОбъектРасчета Тогда
			Если ОбластьДанные <> Неопределено Тогда
				ОбластьДанные.Параметры.ТБ  	   	= ТБ;
				ОбластьДанные.Параметры.АБ 			= АБ;
				ТабДок.Вывести(ОбластьДанные);
			КонецЕсли;
			ТБ = "";
			АБ = "";
			ОбластьДанные = Макет.ПолучитьОбласть("Данные");                                                                  
			ЗаполнитьЗначенияСвойств(ОбластьДанные.Параметры, ВыборкаДанные);
			
			Транзит = "";
			СимволПереноса = "";
			Пока ВыборкаТранзит.НайтиСледующий(ВыборкаДанные.ОбъектРасчета, "ОбъектРасчета") Цикл
				Если Не Транзит = "" Тогда
					СимволПереноса = Символы.ПС;
				КонецЕсли;
				Транзит = СтрШаблон(ТранзитШаблон,
									Транзит,
									СимволПереноса,
									ВыборкаТранзит.ДоговорПредставление, 
									ВыборкаТранзит.АдресПредставление, 
									ВыборкаТранзит.ОбъектРасчетаСубабонентаПредставление);
			КонецЦикла;
			ВыборкаТранзит.Сбросить();					
			Если Транзит = "" Тогда
				Транзит = НСтр("ru = 'Нет'");
			КонецЕсли;
			ОбластьДанные.Параметры.Транзит = Транзит;
				
			Если ЗначениеЗаполнено(ВыборкаДанные.КодОбъектаРасчета) Тогда
				КодОбъекта = Строка(ВыборкаДанные.НомерДоговора) + "_" + Строка(ВыборкаДанные.КодОбъектаРасчета);
				ОбластьДанные.Параметры.КодОбъекта 	= КодОбъекта;
			КонецЕсли;

			Если СоответствиеКатегорийНапряжения[ВыборкаДанные.ТочкаПоставки] <> Неопределено Тогда
				ОбластьДанные.Параметры.КатегорияНадежности = СоответствиеКатегорийНапряжения[ВыборкаДанные.ТочкаПоставки];
			КонецЕсли;
		КонецЕсли;
		
		Если ВыборкаДанные.ТипБрони = Перечисления.бестТипБрониЭлектроснабжения.Технологическая Тогда
			ТБ 	= ТБ + ВыборкаДанные.Сезонность + " " + ВыборкаДанные.Услуга + ": " + ВыборкаДанные.ЗначениеБрони + "; ";
		ИначеЕсли ВыборкаДанные.ТипБрони = Перечисления.бестТипБрониЭлектроснабжения.Аварийная Тогда
			АБ 	= АБ + ВыборкаДанные.Сезонность + " " + ВыборкаДанные.Услуга + ": " + ВыборкаДанные.ЗначениеБрони + "; ";
		КонецЕсли;
		ТекОбъектРасчета = ВыборкаДанные.ОбъектРасчета;
	КонецЦикла;
	
	Если ОбластьДанные <> Неопределено Тогда
		Если ЗначениеЗаполнено(КодОбъекта) Тогда	
			ОбластьДанные.Параметры.КодОбъекта 	= КодОбъекта;
		КонецЕсли;
		ОбластьДанные.Параметры.ТБ = ТБ;
		ОбластьДанные.Параметры.АБ = АБ;
		ТабДок.Вывести(ОбластьДанные);
	КонецЕсли;
	
	ТабДок.Вывести(ОбластьПодвал);
КонецПроцедуры

Процедура СформироватьПриложение5(ТабДок, ПараметрыОтчета) Экспорт
	
	Макет = Отчеты.бестПечатьПриложенийКДоговору.ПолучитьМакет("ПФ_MXL_Приложение5");
	
	мОбъектыРасчета = ПараметрыОтчета.ОбъектыРасчета;

	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьСведения  = Макет.ПолучитьОбласть("Сведения");
	ОбластьДанные  = Макет.ПолучитьОбласть("ДанныеОбъектаРасчета");
	ОбластьСведенияПродолжение  = Макет.ПолучитьОбласть("СведенияПродолжение");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
		
	Если мОбъектыРасчета.Количество() = 0 Тогда
		ТабДок.Вывести(ОбластьШапка);
		ТабДок.Вывести(ОбластьПодвал);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	энргДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	энргКонтрагентыКонтактнаяИнформация.Представление КАК ФактАдресКонтрагента,
	|	энргДоговорыКонтрагентов.Организация КАК Организация,
	|	энргДоговорыКонтрагентов.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ДоговорыКонтрагентов
	|ИЗ
	|	Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
	|		ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагентыКонтактнаяИнформация.Ссылка
	|			И (энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|ГДЕ
	|	энргДоговорыКонтрагентов.Ссылка = &Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДоговорыКонтрагентов.НомерДоговора КАК НомерДоговора,
	|	ВТ_ДоговорыКонтрагентов.ДатаДоговора КАК ДатаДоговора,
	|	ВТ_ДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	ВТ_ДоговорыКонтрагентов.ФактАдресКонтрагента КАК ФактАдресКонтрагента,
	|	ВТ_ДоговорыКонтрагентов.Организация КАК Организация,
	|	ВТ_ДоговорыКонтрагентов.Ссылка КАК Ссылка
	|ИЗ
	|	ВТ_ДоговорыКонтрагентов КАК ВТ_ДоговорыКонтрагентов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестОбъектыРасчета.Ссылка КАК ОбъектРасчета,
	|	бестОбъектыРасчета.Представление КАК Представление,
	|	бестОбъектыРасчетаКонтактнаяИнформация.Представление КАК АдресОбъектаРасчета,
	|	рксОбъектыРасчетаДополнительныеРеквизиты.КодОбъектаРасчета КАК КодОбъектаРасчета
	|ИЗ
	|	Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета.КонтактнаяИнформация КАК бестОбъектыРасчетаКонтактнаяИнформация
	|		ПО (бестОбъектыРасчетаКонтактнаяИнформация.Ссылка = бестОбъектыРасчета.Ссылка)
	|			И (бестОбъектыРасчетаКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресОбъектаРасчета))
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.рксОбъектыРасчетаДополнительныеРеквизиты КАК рксОбъектыРасчетаДополнительныеРеквизиты
	|		ПО бестОбъектыРасчета.Ссылка = рксОбъектыРасчетаДополнительныеРеквизиты.ОбъектРасчета
	|ГДЕ
	|	бестОбъектыРасчета.Ссылка В(&мОбъектыРасчета)";
	
	Запрос.УстановитьПараметр("мОбъектыРасчета",мОбъектыРасчета);
	Запрос.УстановитьПараметр("Договор", 		ПараметрыОтчета.Договор);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаШапкаПодвал 				= РезультатЗапроса.Получить(1).Выбрать();
	ВыборкаДанные 					= РезультатЗапроса.Получить(2).Выбрать();
	НомерДоговор = "";
	
	ОбластьПодвал.Параметры.ДатаПриложения = Формат(ПараметрыОтчета.Период, "ДЛФ=D");
	
	Если ВыборкаШапкаПодвал.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры, ВыборкаШапкаПодвал);
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры, ВыборкаШапкаПодвал);
		ОбластьШапка.Параметры.ДатаДоговора 	= Формат(ВыборкаШапкаПодвал.ДатаДоговора, "ДЛФ=D");
		НомерДоговора = ВыборкаШапкаПодвал.НомерДоговора;
	КонецЕсли;	
	
	ТекОбъектРасчета = Неопределено;
	
	ОбластьШапка.Параметры.КодОбъекта = "";
	
	ТекКодОбъекта = Неопределено;
	
	Пока ВыборкаДанные.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаДанные.КодОбъектаРасчета) Тогда
			КодОбъекта = Строка(НомерДоговора) + "_" + Строка(ВыборкаДанные.КодОбъектаРасчета);
			Если КодОбъекта <> ТекКодОбъекта Тогда
				ОбластьШапка.Параметры.КодОбъекта = Строка(ОбластьШапка.Параметры.КодОбъекта) + ?(ЗначениеЗаполнено(ОбластьШапка.Параметры.КодОбъекта), ", ", "") + КодОбъекта;		
			КонецЕсли;
			ТекКодОбъекта = КодОбъекта;	
		КонецЕсли;	
	КонецЦикла;

	ТабДок.Вывести(ОбластьШапка);
	ТабДок.Вывести(ОбластьСведения);
	ВыборкаДанные.Сбросить();
	ШаблонПредставлениеОбъекта = НСтр("ru = '%1_%2 %3'");
	Пока ВыборкаДанные.Следующий() Цикл
		ОбластьДанные.Параметры.Заполнить(ВыборкаДанные);
		ОбластьДанные.Параметры.ПредставлениеОбъектаРасчета = СтрШаблон(ШаблонПредставлениеОбъекта, 
																		НомерДоговора, 
																		ВыборкаДанные.КодОбъектаРасчета, 
																		ВыборкаДанные.Представление);
		ТабДок.Вывести(ОбластьДанные);
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьСведенияПродолжение);
	ТабДок.Вывести(ОбластьПодвал);
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли