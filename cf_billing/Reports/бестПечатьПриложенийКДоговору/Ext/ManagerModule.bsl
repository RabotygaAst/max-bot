		ТабДок.Вывести(ОбластьЗаголовокПеречень);
		ОбластьШапкаЗаголовок31 = Макет.ПолучитьОбласть("Заголовок31БезПУ");
		ТабДок.Вывести(ОбластьШапкаЗаголовок31);
		ОбластьШапкаБезПУ = Макет.ПолучитьОбласть("ШапкаБезПУ");
		ТабДок.Вывести(ОбластьШапкаБезПУ);
		ТекТУ = Неопределено;
		ОбластьДанныеБезПУ = Неопределено;
		Пока ВыборкаДанныеБезПУ.Следующий() Цикл
			Если ТекТУ <> ВыборкаДанныеБезПУ.ТочкаУчета Тогда
				Если ОбластьДанныеБезПУ <> Неопределено Тогда
					ТабДок.Вывести(ОбластьДанныеБезПУ);
				КонецЕсли;			
				ОбластьДанныеБезПУ = Макет.ПолучитьОбласть("ДанныеБезПУ");
				ЗаполнитьЗначенияСвойств(ОбластьДанныеБезПУ.Параметры, ВыборкаДанныеБезПУ); 
				Если ЗначениеЗаполнено(ВыборкаДанныеБезПУ.КодОбъектаРасчета) Тогда
					КодОбъекта = Строка(ВыборкаДанныеБезПУ.НомерДоговора) + "_" + Строка(ВыборкаДанныеБезПУ.КодОбъектаРасчета);
					ОбластьДанныеБезПУ.Параметры.КодОбъекта  = КодОбъекта;
				КонецЕсли;				
			КонецЕсли;
			Если ЗначениеЗаполнено(ВыборкаДанныеБезПУ.Месяц) и ЗначениеЗаполнено(ВыборкаДанныеБезПУ.ОбъемУслуги) Тогда
				ОбластьДанныеБезПУ.Параметры["Объем" + ВыборкаДанныеБезПУ.Месяц] = ВыборкаДанныеБезПУ.ОбъемУслуги;
			КонецЕсли;
			ТекТУ = ВыборкаДанныеБезПУ.ТочкаУчета;			
		КонецЦикла;
		Если ОбластьДанныеБезПУ <> Неопределено  Тогда
			ТабДок.Вывести(ОбластьДанныеБезПУ);
		КонецЕсли;
		
	КонецЕсли;
	ТабДок.Вывести(ОбластьПодвал);
КонецПроцедуры

Процедура СформироватьПриложение3_2(ТабДок, ПараметрыОтчета) Экспорт
	
	мОбъектыРасчета = ПараметрыОтчета.ОбъектыРасчета;
	
	Если мОбъектыРасчета.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	МВТ = Новый МенеджерВременныхТаблиц;
	бестРаботаСприборамиУчетаСервер.ДействующиеПриборыУчетаПоОбъектуРасчета(ПараметрыОтчета.Период, ПараметрыОтчета.Организация, ПараметрыОтчета.Район, мОбъектыРасчета,,,МВТ,Истина,,Истина);
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
