		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ОбластьСтрокаПоказаний.Параметры,ВыборкаДанные);
		ТабДок.Вывести(ОбластьСтрокаПоказаний);
	КонецЦикла;
		                                                          
	ТабДок.Вывести(ОбластьПодвал);
	
КонецПроцедуры	

Процедура СформироватьПриложение4_1(ТабДок, ПараметрыОтчета) Экспорт
	
	Макет = Отчеты.бестПечатьПриложенийКДоговору.ПолучитьМакет("ПФ_MXL_Приложение4_1ПочасовоеПотребление");
	
	ТабДок 									= Новый ТабличныйДокумент;
	
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	ОбластьДанные = Макет.ПолучитьОбласть("Данные");

	РезультатОбъектыРасчета = РегистрыСведений.бестДоговорыТочекУчета.ПолучитьДанныеДоговоров(ПараметрыОтчета.Организация, ПараметрыОтчета.Район, ПараметрыОтчета.Период, ПараметрыОтчета.Договор, ПараметрыОтчета.ОбъектыРасчета, , , , Ложь);
	
	ОбъектыРасчета = РезультатОбъектыРасчета.Выгрузить();	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&Район КАК Район,
	|	ОбъектыРасчета.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ ВТОбъектыРасчета
	|ИЗ
	|	&ОбъектыРасчета КАК ОбъектыРасчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестПриборыТочекУчетаНП.ТочкаУчета КАК ТочкаУчета,
	|	бестПриборыТочекУчетаНП.ОбъектРасчета КАК ОбъектРасчета,
	|	бестПриборыТочекУчетаНП.ПриборУчета КАК ПриборУчета,
	|	энргТочкиУчета.Код КАК Код
	|ИЗ
	|	РегистрСведений.бестПриборыТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			(Организация, Район, ОбъектРасчета) В
	|				(ВЫБРАТЬ
	|					ВТОбъектыРасчета.Организация,
	|					ВТОбъектыРасчета.Район,
	|					ВТОбъектыРасчета.ОбъектРасчета
	|				ИЗ
	|					ВТОбъектыРасчета КАК ВТОбъектыРасчета)) КАК бестПриборыТочекУчетаНП
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТочкиУчета КАК энргТочкиУчета
	|		ПО бестПриборыТочекУчетаНП.ТочкаУчета = энргТочкиУчета.Ссылка";
	
	Запрос.УстановитьПараметр("Период", ПараметрыОтчета.Период);
	Запрос.УстановитьПараметр("Район", ПараметрыОтчета.Район);
	Запрос.УстановитьПараметр("Организация", ПараметрыОтчета.Организация);
	Запрос.УстановитьПараметр("ОбъектыРасчета", ОбъектыРасчета);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл                                                                   
		
		ОбластьШапка.Параметры.ПУ 						= ВыборкаДетальныеЗаписи.ПриборУчета;				
		ОбластьШапка.Параметры.ТочкаУчета 				= ВыборкаДетальныеЗаписи.ТочкаУчета;
		ОбластьШапка.Параметры.КодТУ 					= ВыборкаДетальныеЗаписи.Код;
		ОбластьШапка.Параметры.Период 					= Формат(ПараметрыОтчета.Период, "ДЛФ=D");
		ОбластьШапка.Параметры.Контрагент 				= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыОтчета.Договор, "Контрагент");
		ОбластьШапка.Параметры.НомерДоговора 			= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыОтчета.Договор, "Номер");
		ОбластьШапка.Параметры.ДатаДоговора 			= Формат(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыОтчета.Договор, "Дата"), "ДЛФ=D");
		
		ОбластьПодвал.Параметры.Контрагент 				= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыОтчета.Договор, "Контрагент");
		ОбластьПодвал.Параметры.Организация 			= ПараметрыОтчета.Организация;
		
		ТабДок.Вывести(ОбластьШапка);
		
		пДень = НачалоМесяца(ПараметрыОтчета.Период);                     
		
		Пока Месяц(ПараметрыОтчета.Период) = Месяц(пДень) Цикл
			ОбластьДанные.Параметры.День 			= Формат(пДень,"ДЛФ=D");                                                                
			ТабДок.Вывести(ОбластьДанные);
			пДень = пДень + 86400;
		КонецЦикла;
		
		ТабДок.Вывести(ОбластьПодвал);
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЦикла
	
КонецПроцедуры

Процедура СформироватьПриложение6(ТабДок, ПараметрыОтчета) Экспорт
	Макет = Отчеты.бестПечатьПриложенийКДоговору.ПолучитьМакет("ПФ_MXL_Приложение6ГрафикиОграничения");
	
	мОбъектыРасчета = ПараметрыОтчета.ОбъектыРасчета;
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	энргДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	энргКонтрагентыКонтактнаяИнформация.Представление КАК ФактАдресКонтрагента,
	|	энргДоговорыКонтрагентов.Организация КАК Организация
	|ИЗ
	|	Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
	|		ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагентыКонтактнаяИнформация.Ссылка
	|			И (энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|ГДЕ
	|	энргДоговорыКонтрагентов.Ссылка = &Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестГрафикиРежимаОграничения.Услуга КАК Услуга,
	|	бестГрафикиРежимаОграничения.Месяц КАК Месяц,
	|	бестГрафикиРежимаОграничения.КодРежима КАК КодРежима,
	|	бестГрафикиРежимаОграничения.Значение КАК Значение,
	|	энргВидыУслуг.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	бестГрафикиРежимаОграничения.ОбъектРасчета КАК ОбъектРасчета,
	|	энргВидыУслуг.бестИспользоватьРасчетПоМощности КАК ИспользоватьРасчетПоМощности,
	|	бестОбъектыРасчетаКонтактнаяИнформация.Представление КАК АдресОбъекта
	|ИЗ
	|	РегистрСведений.бестГрафикиРежимаОграничения КАК бестГрафикиРежимаОграничения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО бестГрафикиРежимаОграничения.Услуга = энргВидыУслуг.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета.КонтактнаяИнформация КАК бестОбъектыРасчетаКонтактнаяИнформация
	|		ПО бестГрафикиРежимаОграничения.ОбъектРасчета = бестОбъектыРасчетаКонтактнаяИнформация.Ссылка
	|			И (бестОбъектыРасчетаКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресОбъектаРасчета))
	|			И (НЕ бестГрафикиРежимаОграничения.КодРежима = 0)
	|ГДЕ
	|	бестГрафикиРежимаОграничения.Организация = &Организация
	|	И бестГрафикиРежимаОграничения.Район = &Район
	|	И бестГрафикиРежимаОграничения.ОбъектРасчета В(&мОбъектыРасчета)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОбъектРасчета,
	|	ИспользоватьРасчетПоМощности УБЫВ,
	|	Услуга,
	|	Месяц";
	
	Запрос.УстановитьПараметр("мОбъектыРасчета",мОбъектыРасчета);
	Запрос.УстановитьПараметр("Организация", 	ПараметрыОтчета.Организация);
	Запрос.УстановитьПараметр("Район", 			ПараметрыОтчета.Район);
	Запрос.УстановитьПараметр("Договор", 		ПараметрыОтчета.Договор);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаШапкаПодвал 	= РезультатЗапроса[0].Выбрать();
	ВыборкаДанные 		= РезультатЗапроса[1].Выбрать();
	
	ДатаДоговораГод = "";
	
	ОбластьПодвал.Параметры.ДатаПриложения = Формат(ПараметрыОтчета.Период, "ДЛФ=D");
	
	Если ВыборкаШапкаПодвал.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ВыборкаШапкаПодвал);
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапкаПодвал);
		ДатаДоговораГод 						= Формат(ВыборкаШапкаПодвал.ДатаДоговора, "ДФ=yyyy");
		ОбластьШапка.Параметры.ДатаДоговора 	= Формат(ВыборкаШапкаПодвал.ДатаДоговора, "ДЛФ=D");
	КонецЕсли;	
	
	ТабДок.Вывести(ОбластьШапка);
	
	ТекОбъектРасчета = Неопределено;
	ТекМесяц 		 = Неопределено;
	ТекУслуга 		 = Неопределено;
	ОбластьДанные	 = Неопределено;
	Пока ВыборкаДанные.Следующий() Цикл
		Если ВыборкаДанные.ОбъектРасчета <> ТекОбъектРасчета ИЛИ ВыборкаДанные.Месяц <> ТекМесяц ИЛИ ВыборкаДанные.Услуга <> ТекУслуга Тогда
			Если ОбластьДанные <> Неопределено Тогда
				ТабДок.Вывести(ОбластьДанные);
			КонецЕсли;
			ОбластьДанные = ?(ВыборкаДанные.ИспользоватьРасчетПоМощности, Макет.ПолучитьОбласть("ДанныеМощность"),Макет.ПолучитьОбласть("ДанныеЭЭ"));
		КонецЕсли;
		
		Если ВыборкаДанные.ОбъектРасчета <> ТекОбъектРасчета Тогда
			ОбластьШапкаМощность = Макет.ПолучитьОбласть("ШапкаМощность");
			ЗаполнитьЗначенияСвойств(ОбластьШапкаМощность.Параметры, ВыборкаДанные);
			ОбластьШапкаМощность.Параметры.ДатаДоговораГод 		= ДатаДоговораГод;
			ТабДок.Вывести(ОбластьШапкаМощность);
		КонецЕсли;
		
		Если НЕ ВыборкаДанные.ИспользоватьРасчетПоМощности И (ВыборкаДанные.ОбъектРасчета <> ТекОбъектРасчета ИЛИ ВыборкаДанные.Услуга <> ТекУслуга) Тогда
			ОбластьШапкаЭЭ = Макет.ПолучитьОбласть("ШапкаЭЭ");
			ЗаполнитьЗначенияСвойств(ОбластьШапкаЭЭ.Параметры, ВыборкаДанные);
			ТабДок.Вывести(ОбластьШапкаЭЭ);
		КонецЕсли;
		
		
		ОбластьДанные.Параметры.ЕдИзм 									= ВыборкаДанные.ЕдиницаИзмерения;
		ОбластьДанные.Параметры.Месяц 									= Формат(ДобавитьМесяц(Дата("00020101"), ВыборкаДанные.Месяц - 1), "ДФ='MMMM'");
		ОбластьДанные.Параметры["Параметр" + ВыборкаДанные.КодРежима] 	= ВыборкаДанные.Значение;

		ТекОбъектРасчета = ВыборкаДанные.ОбъектРасчета;
		ТекМесяц 		 = ВыборкаДанные.Месяц;
		ТекУслуга 		 = ВыборкаДанные.Услуга;
	КонецЦикла;
	
	Если ОбластьДанные <> Неопределено Тогда
		ТабДок.Вывести(ОбластьДанные);
	КонецЕсли;
	
	
	ТабДок.Вывести(ОбластьПодвал);
КонецПроцедуры

Процедура СформироватьПриложениеА(ТабДок, ПараметрыОтчета) Экспорт
	Макет = Отчеты.бестПечатьПриложенийКДоговору.ПолучитьМакет("ПФ_MXL_СписокОбъектовПриложениеА");
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	мОбъектыРасчета = ПараметрыОтчета.ОбъектыРасчета;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	энргДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	энргКонтрагентыКонтактнаяИнформация.Представление КАК ФактАдресКонтрагента,
	|	энргДоговорыКонтрагентов.Организация КАК Организация,
	|	энргДоговорыКонтрагентов.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ДоговорыКонтрагентов
	|ИЗ
	|	Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
	|		ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагентыКонтактнаяИнформация.Ссылка
	|			И (энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|ГДЕ
	|	энргДоговорыКонтрагентов.Ссылка = &Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДоговорыКонтрагентов.НомерДоговора КАК НомерДоговора,
	|	ВТ_ДоговорыКонтрагентов.ДатаДоговора КАК ДатаДоговора,
	|	ВТ_ДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	ВТ_ДоговорыКонтрагентов.ФактАдресКонтрагента КАК ФактАдресКонтрагента,
	|	ВТ_ДоговорыКонтрагентов.Организация КАК Организация
	|ИЗ
	|	ВТ_ДоговорыКонтрагентов КАК ВТ_ДоговорыКонтрагентов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	бестОбъектыРасчетаКонтактнаяИнформация.Представление КАК Адрес,
	|	бестОбъектыРасчета.Ссылка КАК ОбъектРасчета,
	|	бестЦеновыеКатегорииТочекУчетаСрезПоследних.ЦеноваяКатегория КАК ЦеноваяКатегория,
	|	ВЫБОР
	|		КОГДА бестЦеновыеКатегорииТочекУчетаСрезПоследних.ЦеноваяКатегория = ЗНАЧЕНИЕ(Перечисление.бестЦеновыеКатегории.ЧетвертаяЦК)
	|				ИЛИ бестЦеновыеКатегорииТочекУчетаСрезПоследних.ЦеноваяКатегория = ЗНАЧЕНИЕ(Перечисление.бестЦеновыеКатегории.ПятаяЦК)
	|				ИЛИ бестЦеновыеКатегорииТочекУчетаСрезПоследних.ЦеноваяКатегория = ЗНАЧЕНИЕ(Перечисление.бестЦеновыеКатегории.ШестаяЦК)
	|			ТОГДА ""Двуставочный""
	|		ИНАЧЕ ""Одноставочный""
	|	КОНЕЦ КАК Тариф
	|ПОМЕСТИТЬ ВТ_ОбъектыРасчета
	|ИЗ
	|	Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестЦеновыеКатегорииТочекУчета.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район) КАК бестЦеновыеКатегорииТочекУчетаСрезПоследних
	|		ПО бестОбъектыРасчета.Ссылка = бестЦеновыеКатегорииТочекУчетаСрезПоследних.ОбъектРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета.КонтактнаяИнформация КАК бестОбъектыРасчетаКонтактнаяИнформация
	|		ПО (бестОбъектыРасчетаКонтактнаяИнформация.Ссылка = бестОбъектыРасчета.Ссылка)
	|			И (бестОбъектыРасчетаКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресОбъектаРасчета))
	|ГДЕ
	|	бестОбъектыРасчета.Ссылка В(&мОбъектыРасчета)
