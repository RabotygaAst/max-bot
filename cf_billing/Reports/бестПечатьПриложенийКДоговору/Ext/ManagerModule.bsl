	ВыборкаДанные 					= РезультатЗапроса[4].Выбрать();
	ВыборкаДанные2					= РезультатЗапроса[4].Выбрать();                                                                                

	мТочек = РезультатЗапроса[4].Выгрузить().ВыгрузитьКолонку("ТочкаПоставки");
	
	СоответствиеКатегорийНапряжения = РегистрыСведений.энргКатегорииНадежностиТочекПоставок.ПолучитьКатегорииНапряжения(ПараметрыОтчета.Период, мТочек);

