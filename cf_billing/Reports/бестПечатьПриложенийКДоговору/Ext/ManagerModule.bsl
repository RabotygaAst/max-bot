	Запрос.УстановитьПараметр("Договор", 		ПараметрыОтчета.Договор);
	Запрос.УстановитьПараметр("Организация", 	ПараметрыОтчета.Организация);
	Запрос.УстановитьПараметр("Период", 		ПараметрыОтчета.Период);
	Запрос.УстановитьПараметр("Район", 			ПараметрыОтчета.Район);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ИндексПоследнегоПакета = РезультатЗапроса.ВГраница();
	
	Если РезультатЗапроса[3].Пустой() ИЛИ РезультатЗапроса[ИндексПоследнегоПакета - 1].Пустой() И РезультатЗапроса[ИндексПоследнегоПакета].Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Макет = Отчеты.бестПечатьПриложенийКДоговору.ПолучитьМакет("ПФ_MXL_Приложение3_1МестаУстановкиПУ");

	ВыборкаШапкаПодвал 				= РезультатЗапроса[1].Выбрать();
	ВыборкаДанные 					= РезультатЗапроса[ИндексПоследнегоПакета - 1].Выбрать();
	ВыборкаДанные2 					= РезультатЗапроса[ИндексПоследнегоПакета - 1].Выбрать();
	ВыборкаДанныеБезПУ 				= РезультатЗапроса[ИндексПоследнегоПакета].Выбрать();
	
	ОбластьШапкаНачало  	 = Макет.ПолучитьОбласть("ШапкаНачало");
	ОбластьШапкаЗаголовок32  = Макет.ПолучитьОбласть("Заголовок32");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");

	ОбластьШапкаНачало.Параметры.Нумерация = "3.2"; 
	
	ОбластьПодвал.Параметры.ДатаПриложения = Формат(ПараметрыОтчета.Период, "ДЛФ=D");
	
	Если ВыборкаШапкаПодвал.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапкаНачало.Параметры,ВыборкаШапкаПодвал);
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапкаПодвал);
		ОбластьШапкаНачало.Параметры.ДатаДоговора = Формат(ВыборкаШапкаПодвал.ДатаДоговора, "ДЛФ=D");
	КонецЕсли;	
	
	ОбластьШапкаНачало.Параметры.КодОбъекта = "";
	
	ТекКодОбъекта = Неопределено;
	
	Пока ВыборкаДанные2.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаДанные2.КодОбъектаРасчета) Тогда
			КодОбъекта = Строка(ВыборкаДанные2.НомерДоговора) + "_" + Строка(ВыборкаДанные2.КодОбъектаРасчета);
			Если КодОбъекта <> ТекКодОбъекта Тогда
				ОбластьШапкаНачало.Параметры.КодОбъекта = Строка(ОбластьШапкаНачало.Параметры.КодОбъекта) + ?(ЗначениеЗаполнено(ОбластьШапкаНачало.Параметры.КодОбъекта), ", ", "") + КодОбъекта;		
			КонецЕсли;
			ТекКодОбъекта = КодОбъекта;	
		КонецЕсли;	
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьШапкаНачало);
	ТабДок.Вывести(ОбластьШапкаЗаголовок32);
	
	Если Не РезультатЗапроса[ИндексПоследнегоПакета - 1].Пустой() Тогда
		
		ОбластьШапкаОкончание  	 = Макет.ПолучитьОбласть("ШапкаОкончание");
	    ТабДок.Вывести(ОбластьШапкаОкончание);
		
		Пока ВыборкаДанные.Следующий() Цикл                        
			ОбластьДанные = Макет.ПолучитьОбласть("Данные");
			ЗаполнитьЗначенияСвойств(ОбластьДанные.Параметры, ВыборкаДанные); 
			Если ЗначениеЗаполнено(ВыборкаДанные.КодОбъектаРасчета) Тогда
				КодОбъекта = Строка(ВыборкаДанные.НомерДоговора) + "_" + Строка(ВыборкаДанные.КодОбъектаРасчета);	
				ОбластьДанные.Параметры.КодОбъекта 	= КодОбъекта;
			КонецЕсли;
			ОбластьДанные.Параметры.Ток 			= Строка(ВыборкаДанные.I1) + "/" + ВыборкаДанные.I2;
			ОбластьДанные.Параметры.Напряжение 		= Строка(ВыборкаДанные.U1) + "/" + ВыборкаДанные.U2;
			ОбластьДанные.Параметры.ТарифнаяЗона	= ВРег(ОбластьДанные.Параметры.ТарифнаяЗона); 
			
			ТабДок.Вывести(ОбластьДанные);
		КонецЦикла;
		
	КонецЕсли;
	
	Если Не РезультатЗапроса[ИндексПоследнегоПакета].Пустой() Тогда
		ОбластьШапкаБезПУ = Макет.ПолучитьОбласть("ШапкаБезПУ");
		ТабДок.Вывести(ОбластьШапкаБезПУ);
		ТекТУ = Неопределено;
		ОбластьДанныеБезПУ = Неопределено;
		Пока ВыборкаДанныеБезПУ.Следующий() Цикл
			Если ТекТУ <> ВыборкаДанныеБезПУ.ТочкаУчета Тогда
				Если ОбластьДанныеБезПУ <> Неопределено Тогда
					ТабДок.Вывести(ОбластьДанныеБезПУ);
				КонецЕсли;			
