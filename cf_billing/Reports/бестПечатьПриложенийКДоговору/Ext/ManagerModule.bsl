			ОбластьДанные.Параметры.ТарифнаяЗона	= ВРег(ОбластьДанные.Параметры.ТарифнаяЗона); 
			
			ТабДок.Вывести(ОбластьДанные);
		КонецЦикла;
	КонецЕсли;
	
	Если Не РезультатЗапроса[ИндексПоследнегоПакета].Пустой() Тогда
