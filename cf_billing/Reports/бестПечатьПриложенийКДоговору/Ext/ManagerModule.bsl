		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапкаПодвал);
		ОбластьШапкаНачало.Параметры.ДатаДоговора = Формат(ВыборкаШапкаПодвал.ДатаДоговора, "ДЛФ=D");
	КонецЕсли;	
	
	ОбластьШапкаНачало.Параметры.КодОбъекта = "";
	
	ТекКодОбъекта = Неопределено;
	
	Пока ВыборкаДанные2.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаДанные2.КодОбъектаРасчета) Тогда
			КодОбъекта = Строка(ВыборкаДанные2.НомерДоговора) + "_" + Строка(ВыборкаДанные2.КодОбъектаРасчета);
			Если КодОбъекта <> ТекКодОбъекта Тогда
				ОбластьШапкаНачало.Параметры.КодОбъекта = Строка(ОбластьШапкаНачало.Параметры.КодОбъекта) + ?(ЗначениеЗаполнено(ОбластьШапкаНачало.Параметры.КодОбъекта), ", ", "") + КодОбъекта;		
			КонецЕсли;
			ТекКодОбъекта = КодОбъекта;	
		КонецЕсли;	
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьШапкаНачало);
		
	Если Не РезультатЗапроса[ИндексПоследнегоПакета - 1].Пустой() Тогда
		ОбластьЗаголовокПеречень = Макет.ПолучитьОбласть("ЗаголовокПеречень");
		ТабДок.Вывести(ОбластьЗаголовокПеречень);
