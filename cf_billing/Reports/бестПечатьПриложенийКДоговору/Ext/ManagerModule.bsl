		ОбластьДанные.Параметры.НомерСтроки = НомерСтроки;
		ТабДок.Вывести(ОбластьДанные);
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
		
	Для Счетчик = 1 по 4 Цикл
