#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

// СтандартныеПодсистемы.ВариантыОтчетов

// Задает расширенные настройки отчетов конфигурации.
//
// Параметры:
//	 Настройки - ТаблицаЗначений - коллекция предопределенных вариантов отчетов
//	 НастройкиОтчета - Структура
//
Процедура НастроитьВариантыОтчета(Настройки, НастройкиОтчета) Экспорт
	
	НастройкиВарианта = ВариантыОтчетов.ОписаниеВарианта(Настройки, НастройкиОтчета, "");
	НастройкиВарианта.Описание = НСтр("ru = 'Печать приложений к договору'");
	НастройкиВарианта.ВидимостьПоУмолчанию = Истина;
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.ВариантыОтчетов

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура СформироватьПриложение2_1(ТабДок, ПараметрыОтчета, ОтчетПоМощности) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	энргДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	энргКонтрагентыКонтактнаяИнформация.Представление КАК ФактАдресКонтрагента,
	|	энргДоговорыКонтрагентов.Организация КАК Организация,
	|	энргДоговорыКонтрагентов.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ДоговорыКонтрагентов
	|ИЗ
	|	Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
	|		ПО энргДоговорыКонтрагентов.Контрагент = энргКонтрагентыКонтактнаяИнформация.Ссылка
	|			И (энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|ГДЕ
	|	энргДоговорыКонтрагентов.Ссылка = &Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДоговорыКонтрагентов.НомерДоговора КАК НомерДоговора,
	|	ВТ_ДоговорыКонтрагентов.ДатаДоговора КАК ДатаДоговора,
	|	ВТ_ДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	ВТ_ДоговорыКонтрагентов.ФактАдресКонтрагента КАК ФактАдресКонтрагента,
	|	ВТ_ДоговорыКонтрагентов.Организация КАК Организация
	|ИЗ
	|	ВТ_ДоговорыКонтрагентов КАК ВТ_ДоговорыКонтрагентов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестГарантированныеОбъемыСрезПоследних.Месяц КАК Месяц,
	|	бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги КАК ОбъемУслуги,
	|	бестГарантированныеОбъемыСрезПоследних.ОбъектРасчета КАК ОбъектРасчета,
	|	бестРежимыПотребленияСрезПоследних.РежимЭлСнабжения КАК РежимЭлСнабжения,
	|	бестРежимыПотребленияСрезПоследних.ПотреблениеВРабДни КАК ПотреблениеВРабДни,
	|	бестРежимыПотребленияСрезПоследних.ПотреблениеВРВыхДни КАК ПотреблениеВРВыхДни,
	|	СУММА(энргПараметрыТочекПоставкиСрезПоследних.МаксимальнаяМощность) КАК МаксимальнаяМощность,
	|	бестДоговорыТочекУчетаСрезПоследних.Договор КАК Договор
	|ПОМЕСТИТЬ ВТ_ТаблицаДляСвязывания
	|ИЗ
	|	РегистрСведений.бестДоговорыТочекУчета.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета В (&мОбъектыРасчета)) КАК бестДоговорыТочекУчетаСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестГарантированныеОбъемы.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район) КАК бестГарантированныеОбъемыСрезПоследних
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|			ПО бестГарантированныеОбъемыСрезПоследних.Услуга = энргВидыУслуг.Ссылка
	|				И (энргВидыУслуг.бестИспользоватьРасчетПоМощности = &ОтчетПоМощности)
	|		ПО бестДоговорыТочекУчетаСрезПоследних.Организация = бестГарантированныеОбъемыСрезПоследних.Организация
	|			И бестДоговорыТочекУчетаСрезПоследних.Район = бестГарантированныеОбъемыСрезПоследних.Район
	|			И бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета = бестГарантированныеОбъемыСрезПоследних.ОбъектРасчета
	|			И (бестГарантированныеОбъемыСрезПоследних.Услуга = бестДоговорыТочекУчетаСрезПоследних.Услуга)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестРежимыПотребления.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район) КАК бестРежимыПотребленияСрезПоследних
	|		ПО бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета = бестРежимыПотребленияСрезПоследних.ОбъектРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестТочкиПоставкиОбъектовРасчета.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район) КАК бестТочкиПоставкиОбъектовРасчетаСрезПоследних
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргПараметрыТочекПоставки.СрезПоследних(&Период, ) КАК энргПараметрыТочекПоставкиСрезПоследних
	|			ПО бестТочкиПоставкиОбъектовРасчетаСрезПоследних.ТочкаПоставки = энргПараметрыТочекПоставкиСрезПоследних.ТочкаПоставки
	|		ПО бестДоговорыТочекУчетаСрезПоследних.ОбъектРасчета = бестТочкиПоставкиОбъектовРасчетаСрезПоследних.ОбъектРасчета
	|ГДЕ
	|	бестДоговорыТочекУчетаСрезПоследних.Договор = &Договор
	|
	|СГРУППИРОВАТЬ ПО
	|	бестГарантированныеОбъемыСрезПоследних.Месяц,
	|	бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги,
	|	бестГарантированныеОбъемыСрезПоследних.ОбъектРасчета,
	|	бестРежимыПотребленияСрезПоследних.РежимЭлСнабжения,
	|	бестРежимыПотребленияСрезПоследних.ПотреблениеВРабДни,
	|	бестРежимыПотребленияСрезПоследних.ПотреблениеВРВыхДни,
	|	бестДоговорыТочекУчетаСрезПоследних.Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ТаблицаДляСвязывания.Месяц КАК Месяц,
	|	ВТ_ТаблицаДляСвязывания.ОбъемУслуги КАК ОбъемУслуги,
	|	ВТ_ТаблицаДляСвязывания.ОбъектРасчета КАК ОбъектРасчета,
	|	ВТ_ТаблицаДляСвязывания.РежимЭлСнабжения КАК РежимЭлСнабжения,
	|	ВТ_ТаблицаДляСвязывания.ПотреблениеВРабДни КАК ПотреблениеВРабДни,
	|	ВТ_ТаблицаДляСвязывания.ПотреблениеВРВыхДни КАК ПотреблениеВРВыхДни,
	|	ВТ_ТаблицаДляСвязывания.МаксимальнаяМощность КАК МаксимальнаяМощность,
	|	рксОбъектыРасчетаДополнительныеРеквизиты.КодОбъектаРасчета КАК КодОбъектаРасчета,
	|	рксОбъектыРасчетаДополнительныеРеквизиты.Договор КАК Договор
	|ПОМЕСТИТЬ ВТ_КодОбъекта
	|ИЗ
	|	ВТ_ТаблицаДляСвязывания КАК ВТ_ТаблицаДляСвязывания
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.рксОбъектыРасчетаДополнительныеРеквизиты КАК рксОбъектыРасчетаДополнительныеРеквизиты
	|		ПО ВТ_ТаблицаДляСвязывания.ОбъектРасчета = рксОбъектыРасчетаДополнительныеРеквизиты.ОбъектРасчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_КодОбъекта.Месяц КАК Месяц,
	|	ВТ_КодОбъекта.ОбъемУслуги КАК ОбъемУслуги,
	|	ВТ_КодОбъекта.ОбъектРасчета КАК ОбъектРасчета,
	|	ВТ_КодОбъекта.РежимЭлСнабжения КАК РежимЭлСнабжения,
	|	ВТ_КодОбъекта.ПотреблениеВРабДни КАК ПотреблениеВРабДни,
	|	ВТ_КодОбъекта.ПотреблениеВРВыхДни КАК ПотреблениеВРВыхДни,
	|	СУММА(ВТ_КодОбъекта.МаксимальнаяМощность) КАК МаксимальнаяМощность,
	|	ВТ_КодОбъекта.КодОбъектаРасчета КАК КодОбъектаРасчета,
	|	ВТ_ДоговорыКонтрагентов.НомерДоговора КАК НомерДоговора
	|ИЗ
	|	ВТ_КодОбъекта КАК ВТ_КодОбъекта
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДоговорыКонтрагентов КАК ВТ_ДоговорыКонтрагентов
	|		ПО ВТ_КодОбъекта.Договор = ВТ_ДоговорыКонтрагентов.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_КодОбъекта.Месяц,
	|	ВТ_КодОбъекта.ОбъемУслуги,
	|	ВТ_КодОбъекта.ОбъектРасчета,
	|	ВТ_КодОбъекта.РежимЭлСнабжения,
	|	ВТ_КодОбъекта.ПотреблениеВРабДни,
	|	ВТ_КодОбъекта.ПотреблениеВРВыхДни,
	|	ВТ_КодОбъекта.КодОбъектаРасчета,
	|	ВТ_ДоговорыКонтрагентов.НомерДоговора
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерДоговора,
	|	КодОбъектаРасчета
	|ИТОГИ
	|	СУММА(ОбъемУслуги),
	|	МАКСИМУМ(РежимЭлСнабжения),
	|	МАКСИМУМ(ПотреблениеВРабДни),
	|	МАКСИМУМ(ПотреблениеВРВыхДни),
	|	МАКСИМУМ(МаксимальнаяМощность),
	|	МАКСИМУМ(КодОбъектаРасчета),
	|	МАКСИМУМ(НомерДоговора)
	|ПО
	|	ОбъектРасчета";
			
	Запрос.УстановитьПараметр("Договор", 			ПараметрыОтчета.Договор);
	Запрос.УстановитьПараметр("Организация", 		ПараметрыОтчета.Организация);
	Запрос.УстановитьПараметр("Период", 			ПараметрыОтчета.Период);
	Запрос.УстановитьПараметр("Район", 				ПараметрыОтчета.Район);
	Запрос.УстановитьПараметр("мОбъектыРасчета",	ПараметрыОтчета.ОбъектыРасчета);
	Запрос.УстановитьПараметр("ОтчетПоМощности",	ОтчетПоМощности);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Если РезультатЗапроса[4].Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Макет = Отчеты.бестПечатьПриложенийКДоговору.ПолучитьМакет("ПФ_MXL_ДоговорныеВеличины");
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	ВыборкаШапкаПодвал 					= РезультатЗапроса[1].Выбрать();
	ВыборкаДанные 						= РезультатЗапроса[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаДанные2       				= РезультатЗапроса[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);                                                                                
	
	ОбластьПодвал.Параметры.ДатаПриложения = Формат(ПараметрыОтчета.Период, "ДЛФ=D");
	
	Если ВыборкаШапкаПодвал.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ВыборкаШапкаПодвал);
		ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,ВыборкаШапкаПодвал);
		ОбластьШапка.Параметры.ДатаДоговора = Формат(ВыборкаШапкаПодвал.ДатаДоговора, "ДЛФ=D");
	КонецЕсли;
	
	Если ОтчетПоМощности Тогда
		ОбластьШапка.Параметры.Заголовок 		= "ДОГОВОРНЫЕ ЗНАЧЕНИЯ ЗАЯВЛЕННОЙ МОЩНОСТИ, В КВТ";
		ОбластьШапка.Параметры.НомерПриложения 	= "2";
	Иначе
		ОбластьШапка.Параметры.Заголовок 		= "1. ДОГОВОРНЫЕ ВЕЛИЧИНЫ ОТПУСКА ЭЛЕКТРОЭНЕРГИИ, КВТ.Ч., ВКЛЮЧАЯ СУБАБОНЕНТОВ ПО РЕЖИМУ 1:";
		ОбластьШапка.Параметры.НомерПриложения 	= "1";
	КонецЕсли;
	
	ТекКодОбъекта = Неопределено;
	
	ОбластьШапка.Параметры.КодОбъекта = "";
	Пока ВыборкаДанные2.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаДанные2.КодОбъектаРасчета) Тогда
			КодОбъекта = Строка(ВыборкаДанные2.НомерДоговора) + "_" + Строка(ВыборкаДанные2.КодОбъектаРасчета);
			Если КодОбъекта <> ТекКодОбъекта Тогда
				ОбластьШапка.Параметры.КодОбъекта = Строка(ОбластьШапка.Параметры.КодОбъекта) + ?(ЗначениеЗаполнено(ОбластьШапка.Параметры.КодОбъекта), ", ", "") + КодОбъекта;		
			КонецЕсли;
			ТекКодОбъекта = КодОбъекта;	
		КонецЕсли;	
	КонецЦикла;
		
	ТабДок.Вывести(ОбластьШапка);
	
	Если ОтчетПоМощности Тогда 
		ОбластьШапкаДоп  = Макет.ПолучитьОбласть("ШапкаМощность");
	Иначе
		ОбластьШапкаДоп  = Макет.ПолучитьОбласть("ШапкаЭЭ");
	КонецЕсли;
	
	ТабДок.Вывести(ОбластьШапкаДоп);
	
	Пока ВыборкаДанные.Следующий() Цикл
	
		Если ОтчетПоМощности Тогда
			ОбластьДанные = Макет.ПолучитьОбласть("ДанныеМощность");
		Иначе
			ОбластьДанные = Макет.ПолучитьОбласть("ДанныеЭЭ");
			ОбластьДанные.Параметры.ВсегоЗаГод 			= ВыборкаДанные.ОбъемУслуги;
			ОбластьДанные.Параметры.ЭлектроПотребление 	= "" + ?(ЗначениеЗаполнено(ВыборкаДанные.ПотреблениеВРабДни), "Раб.дни " + ВыборкаДанные.ПотреблениеВРабДни + "%; ","") + ?(ЗначениеЗаполнено(ВыборкаДанные.ПотреблениеВРВыхДни), "Вых.дни " + ВыборкаДанные.ПотреблениеВРВыхДни + "%;","");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВыборкаДанные.КодОбъектаРасчета) Тогда
			КодОбъекта = Строка(ВыборкаДанные.НомерДоговора) + "_" + Строка(ВыборкаДанные.КодОбъектаРасчета);
			ОбластьДанные.Параметры.КодОбъекта 			= КодОбъекта;	
		КонецЕсли;

		ЗаполнитьЗначенияСвойств(ОбластьДанные.Параметры, ВыборкаДанные);		
		
		Выборка = ВыборкаДанные.Выбрать();
		Пока Выборка.Следующий() Цикл
			ОбластьДанные.Параметры["Объем" + Выборка.Месяц] = Выборка.ОбъемУслуги;
		КонецЦикла;
		ТабДок.Вывести(ОбластьДанные);
	КонецЦикла;
	ТабДок.Вывести(ОбластьПодвал);

КонецПроцедуры

Процедура СформироватьПриложение1(ТабДок, ПараметрыОтчета) Экспорт
	Макет = Отчеты.бестПечатьПриложенийКДоговору.ПолучитьМакет("ПФ_MXL_Приложение1ТочкиПрисоединения");

	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	энргДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	энргДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	МАКСИМУМ(ВЫБОР
