<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Организация</dataPath>
			<field>Организация</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>МКД</dataPath>
			<field>МКД</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Услуга</dataPath>
			<field>Услуга</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Район</dataPath>
			<field>Район</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КлючПомещения</dataPath>
			<field>КлючПомещения</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УдалитьАбонент</dataPath>
			<field>УдалитьАбонент</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>АдресАбонента</dataPath>
			<field>АдресАбонента</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Адрес абонента</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЛицевойСчет</dataPath>
			<field>ЛицевойСчет</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТочкаУчета</dataPath>
			<field>ТочкаУчета</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаПоступления</dataPath>
			<field>ДатаПоступления</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата поступления</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:periodNumber>1</dcscom:periodNumber>
				<dcscom:periodType>Main</dcscom:periodType>
			</role>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ДФ=dd.MM.yyyy</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Абонент</dataPath>
			<field>Абонент</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаОплатыПотребителем</dataPath>
			<field>ДатаОплатыПотребителем</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата оплаты потребителем</v8:content>
				</v8:item>
			</title>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ДФ=dd.MM.yyyy</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПриборУчета</dataPath>
			<field>ПриборУчета</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УК</dataPath>
			<field>УК</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ФИО</dataPath>
			<field>ФИО</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>ФИО</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПериодНачисления</dataPath>
			<field>ПериодНачисления</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НачисленнаяСумма</dataPath>
			<field>НачисленнаяСумма</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Начисленная сумма</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаОплаты</dataPath>
			<field>СуммаОплаты</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма оплаты</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СрокОплаты</dataPath>
			<field>СрокОплаты</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Срок оплаты</v8:content>
				</v8:item>
			</title>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ДФ=dd.MM.yyyy</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВидБлагоустройства</dataPath>
			<field>ВидБлагоустройства</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТарифнаяКатегория</dataPath>
			<field>ТарифнаяКатегория</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Тарифная категория</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СостояниеОДПУ</dataPath>
			<field>СостояниеОДПУ</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Состояние ОДПУ</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргВзаиморасчетыПоМесяцам.Абонент КАК Абонент,
	энргАбоненты.ЛицевойСчет КАК ЛицевойСчет,
	энргФормыУправленияМКДСрезПоследних.УК КАК УК,
	энргАбоненты.ФизЛицо КАК ФИО,
	энргВзаиморасчетыПоМесяцам.ПериодНачисления КАК ПериодНачисления,
	энргВзаиморасчетыПоМесяцам.Услуга КАК Услуга,
	энргВзаиморасчетыПоМесяцам.Сумма КАК Сумма,
	энргВзаиморасчетыПоМесяцам.Период КАК ДатаПоступления,
	энргВзаиморасчетыПоМесяцам.ВидДвижения КАК ВидДвижения,
	энргАбонентыКонтактнаяИнформация.Представление КАК АдресАбонента,
	энргПлатежноеПоручениеВходящиеОплата.Ссылка.Дата КАК ДатаОплатыПотребителем,
	ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(энргВзаиморасчетыПоМесяцам.ПериодНачисления, МЕСЯЦ), ДЕНЬ, 10) КАК СрокОплаты,
	энргАбоненты.КлючПомещения КАК КлючПомещения,
	энргВзаиморасчетыПоМесяцам.МКД КАК МКД
ПОМЕСТИТЬ ВТ_Взаиморасчеты
ИЗ
	РегистрНакопления.энргВзаиморасчетыПоМесяцам КАК энргВзаиморасчетыПоМесяцам
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
			ПО энргАбоненты.Ссылка = энргАбонентыКонтактнаяИнформация.Ссылка
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
			ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.КлючПомещения
		ПО энргВзаиморасчетыПоМесяцам.Абонент = энргАбоненты.Ссылка
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргФормыУправленияМКД.СрезПоследних(
				&amp;НачалоПериода,
				Организация = &amp;Организация
					И Район = &amp;Район) КАК энргФормыУправленияМКДСрезПоследних
		ПО (энргКлючиПомещений.Строение = энргФормыУправленияМКДСрезПоследних.МКД)
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргПлатежноеПоручениеВходящие.Оплата КАК энргПлатежноеПоручениеВходящиеОплата
		ПО энргВзаиморасчетыПоМесяцам.Регистратор = энргПлатежноеПоручениеВходящиеОплата.Ссылка
			И энргВзаиморасчетыПоМесяцам.Абонент = энргПлатежноеПоручениеВходящиеОплата.Абонент
ГДЕ
	энргВзаиморасчетыПоМесяцам.ПериодНачисления МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Взаиморасчеты.Абонент КАК Абонент,
	ВТ_Взаиморасчеты.ПериодНачисления КАК ПериодНачисления,
	ВТ_Взаиморасчеты.Услуга КАК Услуга,
	ВТ_Взаиморасчеты.Сумма КАК Сумма
ПОМЕСТИТЬ ВТ_НачислениеПоУслугам
ИЗ
	ВТ_Взаиморасчеты КАК ВТ_Взаиморасчеты
ГДЕ
	ВТ_Взаиморасчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Взаиморасчеты.Абонент КАК Абонент,
	ВТ_Взаиморасчеты.ПериодНачисления КАК ПериодНачисления,
	ВТ_Взаиморасчеты.Услуга КАК Услуга,
	ВТ_Взаиморасчеты.Сумма КАК Сумма,
	ВТ_Взаиморасчеты.ДатаОплатыПотребителем КАК ДатаОплатыПотребителем,
	ВТ_Взаиморасчеты.ДатаПоступления КАК ДатаПоступления
ПОМЕСТИТЬ ВТ_ОплатаПоУслугам
ИЗ
	ВТ_Взаиморасчеты КАК ВТ_Взаиморасчеты
ГДЕ
	ВТ_Взаиморасчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВТ_Взаиморасчеты.Абонент КАК Абонент,
	ВТ_Взаиморасчеты.ЛицевойСчет КАК ЛицевойСчет,
	ВТ_Взаиморасчеты.УК КАК УК,
	ВТ_Взаиморасчеты.АдресАбонента КАК АдресАбонента,
	ВТ_Взаиморасчеты.ФИО КАК ФИО,
	ВТ_Взаиморасчеты.ПериодНачисления КАК ПериодНачисления,
	ВТ_Взаиморасчеты.Услуга КАК Услуга,
	ВТ_Взаиморасчеты.СрокОплаты КАК СрокОплаты,
	ВТ_Взаиморасчеты.КлючПомещения КАК КлючПомещения,
	ВТ_Взаиморасчеты.МКД КАК МКД
ПОМЕСТИТЬ ВТ_Абоненты
ИЗ
	ВТ_Взаиморасчеты КАК ВТ_Взаиморасчеты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВТ_Абоненты.МКД КАК МКД
ПОМЕСТИТЬ ВТ_МКД
ИЗ
	ВТ_Абоненты КАК ВТ_Абоненты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_МКД.МКД КАК МКД,
	энргУслугиТочекУчетаМКДСрезПоследних.Услуга КАК Услуга,
	энргУслугиТочекУчетаМКДСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	энргСостояниеПриборовМКДСрезПоследних.ПриборУчета КАК ПриборУчета,
	энргСостояниеПриборовМКДСрезПоследних.Состояние КАК Состояние
ПОМЕСТИТЬ ВТ_СостояниеОДПУ
ИЗ
	ВТ_МКД КАК ВТ_МКД
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргУслугиТочекУчетаМКД.СрезПоследних(
				&amp;КонецПериода,
				Организация = &amp;Организация
					И Район = &amp;Район
					И МКД В
						(ВЫБРАТЬ
							ВТ_МКД.МКД
						ИЗ
							ВТ_МКД)) КАК энргУслугиТочекУчетаМКДСрезПоследних
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСостояниеПриборовМКД.СрезПоследних(
					&amp;КонецПериода,
					Организация = &amp;Организация
						И Район = &amp;Район
						И МКД В
							(ВЫБРАТЬ
								ВТ_МКД.МКД
							ИЗ
								ВТ_МКД)) КАК энргСостояниеПриборовМКДСрезПоследних
			ПО энргУслугиТочекУчетаМКДСрезПоследних.МКД = энргСостояниеПриборовМКДСрезПоследних.МКД
				И энргУслугиТочекУчетаМКДСрезПоследних.ТочкаУчета = энргСостояниеПриборовМКДСрезПоследних.ТочкаУчета
		ПО ВТ_МКД.МКД = энргУслугиТочекУчетаМКДСрезПоследних.МКД
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВТ_Абоненты.Абонент КАК Абонент,
	ВТ_Абоненты.ЛицевойСчет КАК ЛицевойСчет,
	ВТ_Абоненты.УК КАК УК,
	ВТ_Абоненты.АдресАбонента КАК АдресАбонента,
	ВТ_Абоненты.ФИО КАК ФИО,
	ВТ_Абоненты.ПериодНачисления КАК ПериодНачисления,
	ВТ_Абоненты.Услуга КАК Услуга,
	ЕСТЬNULL(ВТ_НачислениеПоУслугам.Сумма, 0) КАК НачисленнаяСумма,
	ЕСТЬNULL(ВТ_ОплатаПоУслугам.Сумма, 0) КАК СуммаОплаты,
	ВТ_ОплатаПоУслугам.ДатаОплатыПотребителем КАК ДатаОплатыПотребителем,
	ВТ_ОплатаПоУслугам.ДатаПоступления КАК ДатаПоступления,
	ВТ_Абоненты.СрокОплаты КАК СрокОплаты,
	энргВидБлагоустройствАбонентаСрезПоследних.ВидБлагоустройства КАК ВидБлагоустройства,
	энргГруппыПотребителейАбонентовСрезПоследних.ГруппаПотребителей КАК ТарифнаяКатегория,
	ВТ_СостояниеОДПУ.Состояние КАК СостояниеОДПУ
ИЗ
	ВТ_Абоненты КАК ВТ_Абоненты
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НачислениеПоУслугам КАК ВТ_НачислениеПоУслугам
		ПО ВТ_Абоненты.Абонент = ВТ_НачислениеПоУслугам.Абонент
			И ВТ_Абоненты.ПериодНачисления = ВТ_НачислениеПоУслугам.ПериодНачисления
			И ВТ_Абоненты.Услуга = ВТ_НачислениеПоУслугам.Услуга
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОплатаПоУслугам КАК ВТ_ОплатаПоУслугам
		ПО ВТ_Абоненты.Абонент = ВТ_ОплатаПоУслугам.Абонент
			И ВТ_Абоненты.ПериодНачисления = ВТ_ОплатаПоУслугам.ПериодНачисления
			И ВТ_Абоненты.Услуга = ВТ_ОплатаПоУслугам.Услуга
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргВидБлагоустройствАбонента.СрезПоследних(
				&amp;КонецПериода,
				Организация = &amp;Организация
					И Район = &amp;Район
					И КлючПомещения В
						(ВЫБРАТЬ
							ВТ_Абоненты.КлючПомещения
						ИЗ
							ВТ_Абоненты)) КАК энргВидБлагоустройствАбонентаСрезПоследних
		ПО ВТ_Абоненты.КлючПомещения = энргВидБлагоустройствАбонентаСрезПоследних.КлючПомещения
			И ВТ_Абоненты.Услуга = энргВидБлагоустройствАбонентаСрезПоследних.Услуга
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргГруппыПотребителейАбонентов.СрезПоследних(
				&amp;КонецПериода,
				Организация = &amp;Организация
					И Район = &amp;Район
					И КлючПомещения В
						(ВЫБРАТЬ
							ВТ_Абоненты.КлючПомещения
						ИЗ
							ВТ_Абоненты)) КАК энргГруппыПотребителейАбонентовСрезПоследних
		ПО ВТ_Абоненты.КлючПомещения = энргГруппыПотребителейАбонентовСрезПоследних.КлючПомещения
			И ВТ_Абоненты.Услуга = энргГруппыПотребителейАбонентовСрезПоследних.Услуга
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СостояниеОДПУ КАК ВТ_СостояниеОДПУ
