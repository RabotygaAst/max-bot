		<query>ВЫБРАТЬ
	бестВзаиморасчетыПоМесяцамЭЭ.Сумма КАК Выписано,
	бестВзаиморасчетыПоМесяцамЭЭ.СуммаНДС КАК ВыписаноНДС,
	бестВзаиморасчетыПоМесяцамЭЭ.Сумма - бестВзаиморасчетыПоМесяцамЭЭ.СуммаНДС КАК ВыписаноБезНДС,
	NULL КАК Авансы,
	NULL КАК АвансыНДС,
	NULL КАК АвансыБезНДС
ИЗ
	РегистрНакопления.бестВзаиморасчетыПоМесяцамЭЭ КАК бестВзаиморасчетыПоМесяцамЭЭ
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
		ПО бестВзаиморасчетыПоМесяцамЭЭ.Регистратор = бестПлатежныйДокумент.Ссылка
ГДЕ
	бестПлатежныйДокумент.Организация = &amp;Организация
	И бестПлатежныйДокумент.Район = &amp;Район
	И бестПлатежныйДокумент.ПериодНачисления = &amp;НачалоМесяца

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	NULL,
	NULL,
	NULL,
	бестАвансыЭЭОбороты.СуммаПриход,
	бестАвансыЭЭОбороты.СуммаНДСПриход,
	бестАвансыЭЭОбороты.СуммаПриход - бестАвансыЭЭОбороты.СуммаНДСПриход
ИЗ
	РегистрНакопления.бестАвансыЭЭ.Обороты(
			&amp;НачалоМесяца {(&amp;НачалоМесяца)},
			&amp;КонецМесяца {(&amp;КонецМесяца)},
			,
			Организация = &amp;Организация
				И Район = &amp;Район) КАК бестАвансыЭЭОбороты</query>
	</dataSet>
