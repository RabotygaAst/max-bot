		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргОбъемНачисленийОбороты.Абонент КАК Абонент,
	энргОбъемНачисленийОбороты.ВидНачисления КАК ВидНачисления,
	энргОбъемНачисленийОбороты.ЗначениеТарифа КАК ТарифВклНДС,
	энргОбъемНачисленийОбороты.Услуга КАК Услуга,
	энргОбъемНачисленийОбороты.СуммаОборот КАК Начислено,
	энргОбъемНачисленийОбороты.ОбъемУслугиОборот КАК Объем,
	ВЫБОР
		КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Начисление)
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК Порядок,
	энргОбъемНачисленийОбороты.ПериодНачисления КАК ПериодНачисления,
	энргОбъемНачисленийОбороты.Строение КАК МКД,
	энргОбъемНачисленийОбороты.Абонент.ЛицевойСчет КАК АбонентЛицевойСчет,
	энргАбонентыКонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей
ИЗ
	РегистрНакопления.энргОбъемНачислений.Обороты(&amp;НачалоПериода, &amp;КонецПериода, , {(Район = &amp;Район), (Строение = &amp;МКД), (Абонент = &amp;Абонент)}) КАК энргОбъемНачисленийОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
		ПО энргОбъемНачисленийОбороты.Абонент = энргАбонентыКонтактнаяИнформация.Ссылка
			И (энргАбонентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресОбъекта))

УПОРЯДОЧИТЬ ПО
	Абонент,
	ПериодНачисления,
	Порядок</query>
