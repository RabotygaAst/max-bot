Функция ВывестиНачальныеПоказатели(ПараметрыОтчета,ОбластиМакета,СтруктураНачПок,НачальныйОстаток)
	
	Район 										= Неопределено;
	Если ПараметрыОтчета.Свойство("Район") Тогда
		Район 									= ПараметрыОтчета.Район;
	КонецЕсли;
	
	ТабДок  									= Новый ТабличныйДокумент;
	ТабДок.НачатьАвтогруппировкуСтрок();
	ДанныеЗаполнения  							= Новый Структура("ДанныеАбонента, ДанныеФизЛица, КоличествоКомнат");  // TODO FIX ME Убрать количетство комнат
	ДанныеЗаполнения.ДанныеАбонента  			= Новый Структура("Район,КлючПомещения,Строение,Помещение,ЛицевойСчет,СтарыйЛС,ПредставлениеАбонента,АдресОбъекта,АдресОбъектаЗначенияПолей,ВидОбъекта,ГруппаАбонента, ОтключатьВНеполивнойСезон");
	ДанныеЗаполнения.ДанныеФизЛица  			= Новый Структура("ПаспортРФ,ДатаРождения,МестоРождения");
	энргРаботаСЛицевымСчетомСервер.ПараметрыРасчетаАбонента(ПараметрыОтчета.Организация, Район, ПараметрыОтчета.Абонент,ПараметрыОтчета.НачалоПериода,ДанныеЗаполнения);
	
	ИмяОбласти  								= "ПараметрыАбонента";
	Область  									= ОбластиМакета[ИмяОбласти];
	
	ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ДанныеЗаполнения.ДанныеАбонента);
	ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ДанныеЗаполнения.ДанныеФизЛица);
	ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ДанныеЗаполнения.ДанныеФизЛица.ПаспортРФ);
	ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,0);
	
	ПараметрыЗапроса 							= Новый Структура("Организация,Район,Абонент,МКД,КлючПомещения,Строение,Помещение,Период");
	ЗаполнитьЗначенияСвойств(ПараметрыЗапроса,ПараметрыОтчета);
	ПараметрыЗапроса.Период 					= ПараметрыОтчета.НачалоПериода;







	
	ИмяОбласти  								= "СтрокаСобытия";		
	Область  									= ОбластиМакета[ИмяОбласти]; 	
	Область.Параметры.Событие 					= "Начальные показатели";
	ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,1);
	
	РезультатНачальныеОстатки  					= РезультатЗапроса(ТекстНачальныеПоказатели(),ПараметрыЗапроса);
	Выборка 									= РезультатНачальныеОстатки.выбрать();
	
	ПараметрыЗапроса.Период 					= Новый Граница(ПараметрыОтчета.НачалоПериода,ВидГраницы.Исключая);
	
	РезультатДеталиВзаиморасчеты 				= РезультатЗапроса(ТекстНачальныеДеталиВзаиморасчетов(),ПараметрыЗапроса);				  
	ВыборкаВзаиморасчеты 						= РезультатДеталиВзаиморасчеты.Выбрать();
	Пока Выборка.следующий() цикл
		
		Если Выборка.ПредставлениеСобытия = "Задолженность на начало периода" тогда
			ИмяОбласти  							= "СтрокаСобытия";
		Иначе
			ИмяОбласти  							= "Расшифровка";
		КонецЕсли;
		
		Значение=Выборка.Значение;
		
		Если Выборка.ПредставлениеСобытия = "Изменение вида благоустройства" тогда   // ДопЗначение4-хвс,ДопЗначение5-Полив
			
			Значение=Строка(Значение)+";"+Символы.ПС+"Норма ХВС: "+Строка(Выборка.ДопЗначение4)+" Норма Полив: "+Строка(Выборка.ДопЗначение5);
			
		КонецЕсли;
		
		ПараметрыОбласти 						= ПараметрыОбласти(ИмяОбласти);
		ПараметрыОбласти.Событие 				= Выборка.ПредставлениеСобытия;
		
		Если Выборка.ПредставлениеСобытия = "Задолженность на начало периода" тогда
			ПараметрыОбласти.Начислено 				= Значение;
		Иначе
			ПараметрыОбласти.Период 				= Выборка.Период;
			ПараметрыОбласти.ДопЗначение 			= Выборка.ДопЗначение1;
			ПараметрыОбласти.ТочкаУчета 			= Выборка.ТочкаУчетаПредставление;
			ПараметрыОбласти.ПриборУчета 			= Выборка.ПриборУчетаПредставление;
			ПараметрыОбласти.ТипПрибора 			= Выборка.ТипПрибораУчетаПредставление;
			ПараметрыОбласти.Значение 				= Значение;
			ПараметрыОбласти.КонПок 				= ФорматироватьПоказания(Выборка, Выборка.КонечныеПоказания);
		КонецЕсли;
		
		ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбласти);
		
		
		Если Выборка.ПредставлениеСобытия = "Задолженность на начало периода" тогда
			ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,1);
			
			ИмяОбласти = "Расшифровка";
			НачальныйОстаток 					= Выборка.Значение; 			
			Пока ВыборкаВзаиморасчеты.следующий() цикл
				ПараметрыОбласти 				= ПараметрыОбласти(ИмяОбласти);
				ПараметрыОбласти.Событие 		= "		" + ВыборкаВзаиморасчеты.Событие + ?(ЗначениеЗаполнено(ВыборкаВзаиморасчеты.ПоставщикПредставление),Символы.ПС +"(" +ВыборкаВзаиморасчеты.ПоставщикПредставление +")","");
				ПараметрыОбласти.Период 		= Формат(ВыборкаВзаиморасчеты.ПериодНачисления,"ДФ='ММММ гггг'; ДП=-");
				ПараметрыОбласти.Начислено		= ВыборкаВзаиморасчеты.Начислено;
				ПараметрыОбласти.Оплачено		= ВыборкаВзаиморасчеты.Оплачено;
				ПараметрыОбласти.Значение		= ВыборкаВзаиморасчеты.УслугаПредставление;
				ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбласти);
				ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,2);				
			КонецЦикла;
		Иначе 
			ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти, 2);
		КонецЕсли;			
	КонецЦикла;
	ТабДок.ЗакончитьАвтогруппировкуСтрок();
	Возврат ТабДок;	
