Функция СоотвествиеДеталиВзаиморасчеты(результатВзаиморасчеты)
	Соотвествие  				= Новый Соответствие;
	ВыборкаРегистратор 		 	= результатВзаиморасчеты.выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ОписаниеСтроки 				= Новый ФиксированнаяСтруктура("ПредставлениеСобытия,ПериодНачисления,Услуга,УслугаПредставление,Поставщик,ПоставщикПредставление,Начислено,Оплачено"); 
	
	Пока ВыборкаРегистратор.следующий() цикл
		
		Детали  				= ВыборкаРегистратор.выбрать();
		ДеталиМассив  			= Новый Массив;
		Пока Детали.следующий() цикл
			ДанныеСтроки  	= Новый Структура(ОписаниеСтроки);
			ЗаполнитьЗначенияСвойств(ДанныеСтроки,Детали);
			ДеталиМассив.Добавить(ДанныеСтроки);
		КонецЦикла; 		   
		Соотвествие.Вставить(ВыборкаРегистратор.Регистратор,ДеталиМассив);		   
	КонецЦикла;
	
	Возврат Соотвествие;	
	
КонецФункции  

Функция СоотвествиеДеталиНачислений(РезультатНачисления)
	
	Соотвествие  				= Новый Соответствие;
	ВыборкаРегистратор 		 	= РезультатНачисления.выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ОписаниеСтроки 				= Новый ФиксированнаяСтруктура("
	|ПредставлениеСобытия,ПериодНачисления,ПериодРасчета,
	|УслугаПредставление,ТочкаУчетаПредставление,
	|ПоставщикПредставление,ЗначениеТарифа,
	|ПриборУчетаПредставление,
	|НачалоПериода,КонецПериода,
	|НачальныеПоказания,КонечныеПоказания,
	|Расход,Начислено"); 
	
	Пока ВыборкаРегистратор.следующий() цикл
		
		Детали  				= ВыборкаРегистратор.выбрать();
		ДеталиМассив  			= Новый Массив;
		Пока Детали.следующий() цикл
			ДанныеСтроки  		= Новый Структура(ОписаниеСтроки);
			ЗаполнитьЗначенияСвойств(ДанныеСтроки,Детали);
			ДанныеСтроки.НачальныеПоказания = ФорматироватьПоказания(Детали, Детали.НачальныеПоказания);
			ДанныеСтроки.КонечныеПоказания = ФорматироватьПоказания(Детали, Детали.КонечныеПоказания);
			ДеталиМассив.Добавить(ДанныеСтроки);
		КонецЦикла; 		   
		Соотвествие.Вставить(ВыборкаРегистратор.Регистратор,ДеталиМассив);		   
	КонецЦикла;
	
	Возврат Соотвествие; 	
	
КонецФункции

Функция СоотвествиеИтогиВзаиморасчетов(РезультатИтогиВзаиморасчетов) 
	
	Соотвествие  				= Новый Соответствие;
	
	СоотвествиеИтоги 			= Новый Соответствие;
	
	
	ВыборкаПериодНачисления	 	= РезультатИтогиВзаиморасчетов.выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ОписаниеСтроки 				= Новый ФиксированнаяСтруктура(ПараметрыОбласти("ВзаиморасчетыСтрока"));	
	Пока ВыборкаПериодНачисления.следующий() цикл
		ДанныеСтроки  			= Новый Структура(ОписаниеСтроки);
		ЗаполнитьЗначенияСвойств(ДанныеСтроки,ВыборкаПериодНачисления);
		СоотвествиеИтоги.Вставить(ВыборкаПериодНачисления.ПериодРасчетов,ДанныеСтроки);
		Детали  				= ВыборкаПериодНачисления.выбрать();
		ДеталиМассив  			= Новый Массив;
		Пока Детали.следующий() цикл
			
			//Если Детали.ОстатокКонДт = 0 И  Детали.ОстатокКонДтМор = 0 И Детали.ОстатокКонДтРест = 0 И Детали.ОстатокКонКт = 0
			//	И Детали.ОстатокНачДт = 0 И  Детали.ОстатокНачДтМор = 0 И Детали.ОстатокНачДтРест = 0 И Детали.ОстатокНачКт = 0 И Детали.Оплачено = 0 Тогда
			//	Продолжить;
			//КонецЕсли;
			
			ДанныеСтроки  		= Новый Структура(ОписаниеСтроки);
			ЗаполнитьЗначенияСвойств(ДанныеСтроки,Детали);
			ДеталиМассив.Добавить(ДанныеСтроки);
		КонецЦикла; 		   
		Соотвествие.Вставить(ВыборкаПериодНачисления.ПериодРасчетов,ДеталиМассив);		   
	КонецЦикла;
	
	Возврат Новый Структура("Детали,Итоги",Соотвествие,СоотвествиеИтоги); 
	
КонецФункции

Функция ПараметрыОбласти(ИмяОбласти)
	
	Если ИмяОбласти = "СтрокаСобытия"  тогда
		Возврат 
		Новый Структура("
		|Событие,ТочкаУчета,Регистратор,
		|Период,Начислено,Оплачено");
	ИначеЕсли ИмяОбласти = "Расшифровка" тогда
		Возврат
		Новый Структура("
		|Событие,Период,
		|ДопЗначение,ЗначениеТарифа,
		|Начислено,Расход,НачПок,КонПок,Оплачено,
		|Значение,ТочкаУчета,ПриборУчета,ТипПрибора");
	ИначеЕсли ИмяОбласти = "ВзаиморасчетыСтрока" тогда
		Возврат 
		Новый Структура("
		|Поставщик,ПериодНачисления,Услуга,ОстатокНачДт,ОстатокНачКт,
		|НачисленноСумма,НачисленноОбъем,Оплачено,
		|ИспользованоИзАвансов,ОстатокКонДт,ОстатокКонКт,
		|ОстатокНачДтМор,ОстатокНачДтРест,ОстатокКонДтМор,ОстатокКонДтРест,ОстатокНачДтИтого,ОстатокКонДтИтого,Статус,ОстатокКонДтПеня");	
