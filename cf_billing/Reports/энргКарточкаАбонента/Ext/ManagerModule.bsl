#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Процедура СформироватьСобытияАбонента(ПараметрыОтчета,АдресХранилища) Экспорт 
	
	ТабСобытияАбонента 			= Новый ТабличныйДокумент;
	
	ОбластиМакета  				= ОбластиМакета(ПараметрыОтчета);
	
	СобытияАбонента(ТабСобытияАбонента,ПараметрыОтчета,ОбластиМакета);
	
	ТабСобытияАбонента.ПоказатьУровеньГруппировокСтрок(1);
	ПараметрыОтчета.вставить("ТабСобытияАбонента",ТабСобытияАбонента);
	ПоместитьВоВременноеХранилище(ТабСобытияАбонента,АдресХранилища); 	
	//АдресХранилища = ПоместитьВоВременноеХранилище(ТабСобытияАбонента); 	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,Параметры)
	
	ОбластиМакета[ИмяОбласти].параметры.заполнить(Параметры);	
	
КонецПроцедуры

Процедура ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,Уровень)
	
	ТабДок.вывести(ОбластиМакета[ИмяОбласти],Уровень);	
	
КонецПроцедуры

Функция СобытияАбонента(ТабСобытияАбонента,ПараметрыОтчета,ОбластиМакета)
	перем ТДНач;
	
	ТабСобытияАбонента.ФиксацияСверху 	= 10;
	СтруктураПоказаний 					= Новый Соответствие(); 	
	СтруктураНачПок						= Новый Соответствие;
	
	ДанныеЗаполнения  							= Новый Структура("ДанныеАбонента, КоличествоКомнат, ДанныеСостоянияЛС");  // TODO FIX ME Убрать количетство комнат
	ДанныеЗаполнения.ДанныеАбонента  			= Новый Структура("Район,КлючПомещения,Строение,Помещение");
	ДанныеЗаполнения.ДанныеСостоянияЛС			= Новый Структура("ДатаСостоянияЛС, СостояниеЛС");
	
	энргРаботаСЛицевымСчетомСервер.ПараметрыРасчетаАбонента(ПараметрыОтчета.Организация, ПараметрыОтчета.Район, ПараметрыОтчета.Абонент,ПараметрыОтчета.НачалоПериода,ДанныеЗаполнения);
	
	ДанныеЗаполнения.Вставить("выбПериод", ПредставлениеПериода(ПараметрыОтчета.НачалоПериода, ПараметрыОтчета.КонецПериода));
	
	Если Не ПараметрыОтчета.Свойство("Район") Тогда
		ПараметрыОтчета.Вставить("Район", ДанныеЗаполнения.ДанныеАбонента.Район);
	КонецЕсли;
	
	Если Не ПараметрыОтчета.Свойство("КлючПомещения") Тогда
		ПараметрыОтчета.Вставить("КлючПомещения", ДанныеЗаполнения.ДанныеАбонента.КлючПомещения);
	КонецЕсли;
	
	Если Не ПараметрыОтчета.Свойство("Строение") Тогда
		ПараметрыОтчета.Вставить("Строение", ДанныеЗаполнения.ДанныеАбонента.Строение);
	КонецЕсли;
	
	Если Не ПараметрыОтчета.Свойство("Помещение") Тогда
		ПараметрыОтчета.Вставить("Помещение", ДанныеЗаполнения.ДанныеАбонента.Помещение);
	КонецЕсли;
	








	ТДШапка 							= ВывестиШапкуОтчета(ОбластиМакета, ДанныеЗаполнения);	
	ТабСобытияАбонента.Вывести(ТДШапка);
	
	//Если ДанныеЗаполнения.ДанныеСостоянияЛС.СостояниеЛС <> Неопределено ИЛИ ДанныеЗаполнения.ДанныеСостоянияЛС.ДатаСостоянияЛС <> Неопределено Тогда
	НачальныйОстаток 					= 0;	
	Если ЗначениеЗаполнено(ПараметрыОтчета.НачалоПериода) тогда		 					
		ТДНачПоказатели					= ВывестиНачальныеПоказатели(ПараметрыОтчета,ОбластиМакета,СтруктураНачПок,НачальныйОстаток);
		ТабСобытияАбонента.Вывести(ТДНачПоказатели);
	КонецЕсли;
	
	ТДДАнныеЗаПериод  					= ВывестиДанныеЗаПериод(ПараметрыОтчета,ОбластиМакета,СтруктураПоказаний,СтруктураНачПок,НачальныйОстаток);
	
	ТабСобытияАбонента.Вывести(ТДДАнныеЗаПериод); 
	//	КонецЕсли;	
	
	Возврат ТабСобытияАбонента;
	
КонецФункции


Функция ОбластиМакета(ПараметрыОтчета)
	//ПрефиксШапки	 			= ?(ПараметрыОтчета.РасчетДляСуда,"ДляСуда","");
	ПрефиксШапки	 			= "";
	
	
	// Макет 						= Отчеты.энргКарточкаАбонента.ПолучитьМакет("Макет");
	Макет 						= ПолучитьМакет("Макет");;
	
	ОбластиМакета  				= Новый Структура;
	
	Области  					= Новый Массив;
	Области.Добавить("Шапка");
	Области.Добавить("ШапкаДляСуда");
	Области.Добавить("ПараметрыАбонента");
	Области.Добавить("ПериодНачисления");
	Области.Добавить("СтрокаСобытия");
	Области.Добавить("Расшифровка");
	Области.Добавить("ИтогиПериод");
	Области.Добавить("ШапкаИтогиВзаиморасчетов");
	Области.Добавить("ВзаиморасчетыСтрока");
	Области.Добавить("ВзаиморасчетыИтогПериод");
	Области.Добавить("ПодвалСобытияСуд");
	Области.Добавить("Подписанты");
	Области.Добавить("Исполнитель");
	Области.Добавить("Пустая");
	
	для Каждого ИмяОбласти из Области цикл
		ОбластиМакета.Вставить("" +   ИмяОбласти,Макет.ПолучитьОбласть(ИмяОбласти));
	КонецЦикла; 
	
	Возврат ОбластиМакета;
КонецФункции

Функция ВывестиШапкуОтчета(ОбластиМакета, ДанныеЗаполнения)
	
	ТабДок  = Новый ТабличныйДокумент;
	ЗаполнитьПараметрыОбласти(ОбластиМакета,"Шапка",ДанныеЗаполнения);
	
	ВывестиОбластиВМакет(ТабДок,ОбластиМакета,"Шапка",0);
	Возврат ТабДок;
	
КонецФункции

Функция ВывестиДанныеЗаПериод(ПараметрыОтчета,ОбластиМакета,СтруктураПоказаний,СтруктураНачПок,НачальныйОстаток)
	
	ТабДок 												= Новый ТабличныйДокумент;
	ТабДок.НачатьАвтогруппировкуСтрок();
	
	РезультатПериодДействияАбонента						= РезультатЗапроса(ТекстЗапросаПериодаДействияАбонента(),ПараметрыОтчета);
	ВыборкаПериодДействияАбонента						= РезультатПериодДействияАбонента.Выбрать();
	ВыборкаПериодДействияАбонента.Следующий();
	ПараметрыОтчета.Вставить("НачалоПериодаДействияЛС",	ВыборкаПериодДействияАбонента.НачалоПериодаДействияЛС);
	ПараметрыОтчета.Вставить("КонецПериодаДействияЛС",	ВыборкаПериодДействияАбонента.КонецПериодаДействияЛС);
	ПараметрыОтчета.Вставить("ТекущаяДата",				ТекущаяДатаСеанса());
	
	РезультатСобытияАбонента  							= РезультатЗапроса(ТекстЗапросаСобытияАбонента(),ПараметрыОтчета);
	ВыборкаПериодНачисления								= РезультатСобытияАбонента.выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	РезультатДеталиВзаиморасчетов 						= РезультатЗапроса(ТекстДеталиВзаиморасчетов(),ПараметрыОтчета);
	СоотвествиеДеталиВзаиморасчеты 						= СоотвествиеДеталиВзаиморасчеты(РезультатДеталиВзаиморасчетов);
	
	РезультатДеталиНачислений							= РезультатЗапроса(ТекстДеталиНачислений(),ПараметрыОтчета);
	СоотвествиеДеталиНачислений 						= СоотвествиеДеталиНачислений(РезультатДеталиНачислений);
	
	РезультатИтогиВзаиморасчетов 						= РезультатЗапроса(ТекстОстаткиГраницыПериодаНачисления(ПараметрыОтчета),ПараметрыОтчета);
	СоотвествиеИтогиВзаиморасчетов 						= СоотвествиеИтогиВзаиморасчетов(РезультатИтогиВзаиморасчетов);
	
	ТекПериод 											= Неопределено;
	Пока ВыборкаПериодНачисления.следующий() цикл  		
		Если ТекПериод <> ВыборкаПериодНачисления.ПериодНачисления и ТекПериод <> Неопределено тогда
			// выводим итоги за период  			
			ИмяОбласти 									= "СтрокаСобытия";
			ПараметрыОбл 								= ПараметрыОбласти(ИмяОбласти);
			ПараметрыОбл.Событие 						= "Итого за период";
			ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл); 			
			ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,2);
			
			ИмяОбласти 									= "ШапкаИтогиВзаиморасчетов";
			ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,3);
			
			МассивИтогиЗаПериод 						= СоотвествиеИтогиВзаиморасчетов.Детали[ТекПериод];
			Если МассивИтогиЗаПериод <> Неопределено тогда								
				
				ИтогиЗаПериод 							= СоотвествиеИтогиВзаиморасчетов.итоги[ТекПериод];
				НачальныйОстаток						= ИтогиЗаПериод.ОстатокКонДт - ИтогиЗаПериод.ОстатокКонКт - ИтогиЗаПериод.ОстатокКонДтПеня;
				ЗадолженностьПени						= ИтогиЗаПериод.ОстатокКонДтПеня;
				ИмяОбласти 								= "ВзаиморасчетыИтогПериод";
				ПараметрыОбл 							= ПараметрыОбласти(ИмяОбласти);				
				ЗаполнитьЗначенияСвойств(ПараметрыОбл,ИтогиЗаПериод);
				ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл);
				ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,3);				
				
				ИмяОбласти 								= "ВзаиморасчетыСтрока"; 
				ПараметрыОбл 							= ПараметрыОбласти(ИмяОбласти);
				для Каждого СтрокаИтогов из МассивИтогиЗаПериод цикл
					ЗаполнитьЗначенияСвойств(ПараметрыОбл,СтрокаИтогов);
					ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл);
					ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,4);
				КонецЦикла;				
			КонецЕсли;
		КонецЕсли;
		
		ТекПериод 										= ВыборкаПериодНачисления.ПериодНачисления;
		ИмяОбласти 										= "ПериодНачисления";
		ПараметрыОбл  									= Новый Структура("ПериодНачисления,Задолженность,ЗадолженностьПени",Формат(ТекПериод,"ДФ='ММММ гггг'"),НачальныйОстаток,ЗадолженностьПени);
		ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл);
		ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,ВыборкаПериодНачисления.уровень()+1);
		
		ВыборкаРегистратор  							= ВыборкаПериодНачисления.выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаРегистратор.следующий() цикл
			
			ИмяОбласти 									= "СтрокаСобытия";
			ПараметрыОбл 								= ПараметрыОбласти(ИмяОбласти);
			
			ПараметрыОбл.Событие 						= ВыборкаРегистратор.РегистраторПредставление + ВыборкаРегистратор.ИсточникОплаты;
			ПараметрыОбл.Регистратор					= ВыборкаРегистратор.Регистратор;
			ПараметрыОбл.ТочкаУчета						= ВыборкаРегистратор.ТочкаУчетаПредставление;
			ПараметрыОбл.Период							= ВыборкаРегистратор.Период;
			ПараметрыОбл.Начислено						= ВыборкаРегистратор.НачисленоИтого;
			ПараметрыОбл.Оплачено						= ВыборкаРегистратор.Оплачено;
			
			ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл);
			
			ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,ВыборкаРегистратор.уровень()+1);
			
			МассивВзаиморасчеты  						= СоотвествиеДеталиВзаиморасчеты.получить(ВыборкаРегистратор.Регистратор); 	
			МассивНачисления 							= СоотвествиеДеталиНачислений.получить(ВыборкаРегистратор.Регистратор);
			
			Выборка  									= ВыборкаРегистратор.выбрать();
			
			Пока Выборка.следующий() цикл
				Если ТипЗнч(Выборка.Регистратор) = Тип("ДокументСсылка.КорректировкаРегистров") Тогда
					ТипРегистратора	= 1;
				ИначеЕсли ТипЗнч(Выборка.Регистратор) = Тип("ДокументСсылка.энргНачислениеПени") Или ТипЗнч(Выборка.Регистратор) = Тип("ДокументСсылка.энргРучноеИзменениеПени") Тогда
					ТипРегистратора = 2;
				Иначе
					ТипРегистратора	= 0;
				КонецЕсли;
				
				Если ТипЗнч(Выборка.Значение) = Тип("Дата") тогда
					Значение 							= Формат(Выборка.Значение,"ДФ=dd.MM.гггг");
				иначе
					Значение 							= Выборка.Значение;
				КонецЕсли;  
				
				Если ТипЗнч(Выборка.ДопЗначение1) = Тип("Дата") тогда
					ДопЗначение1 						= Формат(Выборка.ДопЗначение1,"ДФ=dd.MM");
				иначе
					ДопЗначение1 						= Выборка.ДопЗначение1;
				КонецЕсли;
				
				Если ТипЗнч(Выборка.ДопЗначение2) = Тип("Дата") тогда
					ДопЗначение2 						= Формат(Выборка.ДопЗначение2,"ДФ=dd.MM");
				иначе
					ДопЗначение2						= Выборка.ДопЗначение2;
				КонецЕсли; 
				
				Если ТипЗнч(Выборка.ДопЗначение3) = Тип("Дата") тогда
					ДопЗначение3 						= Формат(Выборка.ДопЗначение3,"ДФ=dd.MM");
				иначе
					ДопЗначение3						= Выборка.ДопЗначение3;
				КонецЕсли; 
				
				Если Выборка.НачальныеПоказания  = Неопределено тогда
					НачальныеПоказания 					= "";
				иначе
					НачальныеПоказания 					= Выборка.НачальныеПоказания;
				КонецЕсли;
				
				Если Выборка.КонечныеПоказания  = Неопределено тогда
					КонечныеПоказания 					= "";
				иначе
					КонечныеПоказания 					= Выборка.КонечныеПоказания;
				КонецЕсли;   
				
				ДопЗначение1 							= ?(ЗначениеЗаполнено(ДопЗначение1),ДопЗначение1,"");
				ДопЗначение2 							= ?(ЗначениеЗаполнено(ДопЗначение2),ДопЗначение2,"");
				ДопЗначение2 							= ?(ЗначениеЗаполнено(ДопЗначение2),ДопЗначение2,"");
				ДопЗначение 							= 
				?(ЗначениеЗаполнено(ДопЗначение1) 
				или ЗначениеЗаполнено(ДопЗначение2)
				или ЗначениеЗаполнено(ДопЗначение3),
				"(" + 
				?(ЗначениеЗаполнено(ДопЗначение1),ДопЗначение1,"") + 
				?(ЗначениеЗаполнено(ДопЗначение2)," - " + ДопЗначение2,"") +
				?(ЗначениеЗаполнено(ДопЗначение3)," - " + ДопЗначение3,"") +
				")","");
				
				Если Выборка.ПредставлениеСобытия = "Изменение вида благоустройства" тогда   // ДопЗначение4-хвс,ДопЗначение5-Полив
					
					Значение=Строка(Значение)+";"+Символы.ПС+"Норма ХВС: "+Строка(Выборка.ДопЗначение4)+" Норма Полив: "+Строка(Выборка.ДопЗначение5);
					
				КонецЕсли;
				
				ИмяОбласти 								= "Расшифровка";
				ПараметрыОбл 							= Новый Структура("
				|Событие, Период,
				|ДопЗначение
				|,ТочкаУчета,ПриборУчета,ТипПрибора,
				|Начислено,Оплачено,Расход,
				|Значение,ЗначениеТарифа,НачПок,КонПок,Статус",
				Выборка.ПредставлениеСобытия,Выборка.Период,
				ДопЗначение,
				Выборка.ТочкаУчетаПредставление,Выборка.ПриборУчетаПредставление,Выборка.ТипПрибораУчетаПредставление,
				Выборка.Начислено,Выборка.Оплачено,Выборка.Расход,
				Значение,Выборка.ЗначениеТарифа,НачальныеПоказания,КонечныеПоказания);
				ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл);
				
				
				ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,Выборка.уровень()+1);  				
				
				Если Выборка.ПредставлениеСобытия = "Изменение задолженности" или  Выборка.ПредставлениеСобытия = "Оплата" тогда
					Если МассивВзаиморасчеты<> Неопределено тогда
						ПараметрыОбл 					= Новый Структура("
						|Событие,Период,
						|ДопЗначение,
						|Начислено,Оплачено,
						|Значение,ТочкаУчета,ПриборУчета",);
						
						для Каждого СтруктрураВзаиморасчетов  из МассивВзаиморасчеты цикл
							ПараметрыОбл.Событие 		= "		" + СтруктрураВзаиморасчетов.ПредставлениеСобытия;
							ПараметрыОбл.ДопЗначение	= Символы.ПС + "(" + СтруктрураВзаиморасчетов.ПоставщикПредставление + ")";
							ПараметрыОбл.Начислено 		= СтруктрураВзаиморасчетов.Начислено;
							ПараметрыОбл.Оплачено 		= СтруктрураВзаиморасчетов.Оплачено;
							ПараметрыОбл.Период 		= Формат(СтруктрураВзаиморасчетов.ПериодНачисления,"ДФ='ММММ гггг'");
							ПараметрыОбл.Значение 		= СтруктрураВзаиморасчетов.УслугаПредставление;
							ПараметрыОбл.ТочкаУчета 	= "";
							ПараметрыОбл.ПриборУчета 	= "";
							ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл);
							ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,Выборка.уровень()+2);
						КонецЦикла;  						
					КонецЕсли;
				ИначеЕсли Выборка.ПредставлениеСобытия = "Начисление за период" тогда
					// Выводим детали начислений
					Если МассивНачисления <> Неопределено тогда
						
						ПараметрыОбл 					= ПараметрыОбласти(ИмяОбласти);
						
						для Каждого СтруктрураНачислений  из МассивНачисления цикл
							Если ТипРегистратора = 1 И СтруктрураНачислений.ПериодРасчета <> Выборка.ПериодНачисления Тогда 
								// Надо выводить начисление только этого периода
								// Документ корректировка делает движения в разные периоды начислений
								Продолжить;
							ИначеЕсли ТипРегистратора = 2 И СтруктрураНачислений.ПериодНачисления <> Выборка.Период Тогда 
								// Надо выводить начисление только этого периода
								Продолжить;
							КонецЕсли;
							
							ПараметрыОбл.Событие 		= "		" + СтруктрураНачислений.ПредставлениеСобытия;
							ПараметрыОбл.ДопЗначение	= Символы.ПС + "(" + СтруктрураНачислений.ПоставщикПредставление + ")";
							ПараметрыОбл.Начислено 		= СтруктрураНачислений.Начислено;
							ПараметрыОбл.Расход 		= СтруктрураНачислений.Расход;
							Если ЗначениеЗаполнено(СтруктрураНачислений.НачалоПериода) ИЛИ ЗначениеЗаполнено(СтруктрураНачислений.КонецПериода) тогда
								ПараметрыОбл.Период 		= Формат(СтруктрураНачислений.НачалоПериода,"ДФ=дд.ММ") + "-" +  Формат(СтруктрураНачислений.КонецПериода,"ДФ=дд.ММ");
							Иначе
								ПараметрыОбл.Период 		= Формат(НачалоМесяца(СтруктрураНачислений.ПериодНачисления),"ДФ=дд.ММ") + "-" +  Формат(КонецМесяца(СтруктрураНачислений.ПериодНачисления),"ДФ=дд.ММ"); 
							КонецЕсли;
							ПараметрыОбл.Значение 		= СтруктрураНачислений.УслугаПредставление;
							ПараметрыОбл.ТочкаУчета 	= СтруктрураНачислений.ТочкаУчетаПредставление ;
							ПараметрыОбл.ЗначениеТарифа	= СтруктрураНачислений.ЗначениеТарифа;  
							ПараметрыОбл.НачПок 		= СтруктрураНачислений.НачальныеПоказания;
							ПараметрыОбл.КонПок 		= СтруктрураНачислений.КонечныеПоказания;
							ПараметрыОбл.ПриборУчета 	= СтруктрураНачислений.ПриборУчетаПредставление;
							ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл);
							ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,Выборка.уровень()+2);
						КонецЦикла;
					КонецЕсли;					
				КонецЕсли;   								
			КонецЦикла;			
		КонецЦикла; 			
	КонецЦикла;
	
	Если ТекПериод <> Неопределено тогда
		ИмяОбласти 											= "СтрокаСобытия";
		ПараметрыОбл 										= ПараметрыОбласти(ИмяОбласти);
		ПараметрыОбл.Событие 								= "Итого за период";
		ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл); 			
		ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,2);
		
		ИмяОбласти 											= "ШапкаИтогиВзаиморасчетов";
		ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,3);
		
		МассивИтогиЗаПериод 								= СоотвествиеИтогиВзаиморасчетов.Детали[ТекПериод];
		Если МассивИтогиЗаПериод <> Неопределено тогда								
			
			ИтогиЗаПериод 									= СоотвествиеИтогиВзаиморасчетов.итоги[ТекПериод];
			ИмяОбласти 										= "ВзаиморасчетыИтогПериод";
			ПараметрыОбл 									= ПараметрыОбласти(ИмяОбласти);				
			ЗаполнитьЗначенияСвойств(ПараметрыОбл,ИтогиЗаПериод);
			ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл);
			ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,3);				
			
			ИмяОбласти 										= "ВзаиморасчетыСтрока"; 
			ПараметрыОбл 									= ПараметрыОбласти(ИмяОбласти);
			для Каждого СтрокаИтогов из МассивИтогиЗаПериод цикл
				ЗаполнитьЗначенияСвойств(ПараметрыОбл,СтрокаИтогов);
				ЗаполнитьПараметрыОбласти(ОбластиМакета,ИмяОбласти,ПараметрыОбл);
				ВывестиОбластиВМакет(ТабДок,ОбластиМакета,ИмяОбласти,4);
			КонецЦикла;				
		КонецЕсли;
	КонецЕсли;	
	
	ТабДок.ЗакончитьАвтогруппировкуСтрок();
	Возврат ТабДок;
КонецФункции

Функция РезультатЗапроса(Текст,ПараметрыОтчета)
	
	Запрос 		 							= Новый Запрос;
	Запрос.Текст 							= Текст;
	для Каждого ПараметрОтчета из ПараметрыОтчета цикл
		Запрос.УстановитьПараметр(ПараметрОтчета.Ключ,ПараметрОтчета.Значение);
	КонецЦикла;	
	
	Результат  								= Запрос.Выполнить();
	Возврат  Результат;
КонецФункции

Функция ТекстЗапросаПериодаДействияАбонента()
	Текст = 
	"ВЫБРАТЬ
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА энргСостояниеЛС.Состояние
	|				ТОГДА энргСостояниеЛС.Период
	|			ИНАЧЕ &НачалоПериода
	|		КОНЕЦ) КАК Начало,
	|	МИНИМУМ(ВЫБОР
	|			КОГДА НЕ энргСостояниеЛС.Состояние
	|				ТОГДА энргСостояниеЛС.Период
	|			ИНАЧЕ &КонецПериода
	|		КОНЕЦ) КАК КОНЕЦ

	|ПОМЕСТИТЬ ВТ_Даты
	|ИЗ
	|	РегистрСведений.энргСостояниеЛС КАК энргСостояниеЛС
	|ГДЕ
	//|	энргСостояниеЛС.Период МЕЖДУ &НачалоПериода И &КонецПериода
	| энргСостояниеЛС.Организация = &Организация
	|	И энргСостояниеЛС.Район = &Район
	|	И энргСостояниеЛС.Абонент = &Абонент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&НачалоПериода,
	|	&КонецПериода


	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВТ_Даты.Начало) КАК НачалоПериодаДействияЛС,
	|	МИНИМУМ(ВТ_Даты.Конец) КАК КонецПериодаДействияЛС

	|ИЗ
	|	ВТ_Даты КАК ВТ_Даты";


	
	Возврат Текст;
КонецФункции

Функция ТекстЗапросаСобытияАбонента()
	
	Текст 	=
	"ВЫБРАТЬ
	|	энргВзаиморасчеты.Период КАК Период,
	|	энргВзаиморасчеты.Регистратор КАК Регистратор,
	|	энргВзаиморасчеты.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ РегистраторыВзаиморасчеты
	|ИЗ
	|	РегистрНакопления.энргВзаиморасчеты КАК энргВзаиморасчеты
	|ГДЕ
	|	энргВзаиморасчеты.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И энргВзаиморасчеты.Абонент = &Абонент
	|	И НЕ энргВзаиморасчеты.Регистратор ССЫЛКА Документ.энргБанкротство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргКоличествоДнейИспользованияУслугиПриОтключении.Период КАК Период,
	|	энргКоличествоДнейИспользованияУслугиПриОтключении.Регистратор КАК Регистратор,
	|	энргКоличествоДнейИспользованияУслугиПриОтключении.НомерСтроки КАК НомерСтроки,
	|	энргКоличествоДнейИспользованияУслугиПриОтключении.Услуга КАК Услуга
	|ПОМЕСТИТЬ РегистраторыОтключениеУслуги
	|ИЗ
	|	РегистрНакопления.энргКоличествоДнейИспользованияУслугиПриОтключении КАК энргКоличествоДнейИспользованияУслугиПриОтключении
	|ГДЕ
	|	энргКоличествоДнейИспользованияУслугиПриОтключении.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И энргКоличествоДнейИспользованияУслугиПриОтключении.Регистратор.Абонент = &Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргЗабалансоваяЗадолженность.Период КАК Период,
	|	энргЗабалансоваяЗадолженность.Регистратор КАК Регистратор,
	|	энргЗабалансоваяЗадолженность.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ РегистраторыЗабаланс
	|ИЗ
	|	РегистрНакопления.энргЗабалансоваяЗадолженность КАК энргЗабалансоваяЗадолженность
	|ГДЕ
	|	энргЗабалансоваяЗадолженность.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И энргЗабалансоваяЗадолженность.Абонент = &Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргОбъемНачислений.Период КАК Период,
	|	энргОбъемНачислений.Регистратор КАК Регистратор,
	|	энргОбъемНачислений.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ РегистраторыОбъемы
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			Запись,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Строение = &Строение
	|				И Помещение = &Помещение
	|				И Абонент = &Абонент) КАК энргОбъемНачислений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаРегистра.ВидБлагоустройства КАК ВидБлагоустройства,
	|	ТаблицаРегистра.ПериодНачисления КАК ПериодНачисления,
	|	ТаблицаРегистра.ПериодРегистрации КАК ПериодРегистрации,
	|	ТаблицаРегистра.Период КАК Период,
	|	ТаблицаРегистра.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВидыБлагоустройстваАбонентов
	|ИЗ
	|	РегистрСведений.энргВидБлагоустройствАбонента КАК ТаблицаРегистра
	|ГДЕ
	|	ТаблицаРегистра.Период МЕЖДУ &НачалоПериодаДействияЛС И &КонецПериодаДействияЛС
	|	И ТаблицаРегистра.Организация = &Организация
	|	И ТаблицаРегистра.Район = &Район
	|	И ТаблицаРегистра.КлючПомещения = &КлючПомещения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыБлагоустройстваАбонентов.ВидБлагоустройства КАК ВидБлагоустройства,
	|	ВидыБлагоустройстваАбонентов.ПериодНачисления КАК ПериодНачисления,
	|	ВидыБлагоустройстваАбонентов.ПериодРегистрации КАК ПериодРегистрации,
	|	0 КАК НормаХВС,
	|	0 КАК НормаПолив,
	|	ВидыБлагоустройстваАбонентов.Период КАК Период,
	|	ВидыБлагоустройстваАбонентов.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВидыБлагоустройстваАбонентовСНормами
	|ИЗ
	|	ВидыБлагоустройстваАбонентов КАК ВидыБлагоустройстваАбонентов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВидыБлагоустройстваАбонентов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаРегистра.Состояние КАК Значение,
	|	"""" КАК ДопЗначение1,
	|	"""" КАК ДопЗначение2,
	|	"""" КАК ДопЗначение3,
	|	"""" КАК ПриборУчетаПредставление,
	|	"""" КАК ТипПрибораУчетаПредставление,
	|	"""" КАК ТочкаУчетаПредставление,
	|	ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.Пустаяссылка) КАК ТочкаУчета,
	|	ТаблицаРегистра.Период КАК Период,
	|	ТаблицаРегистра.Регистратор КАК Регистратор,
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаРегистра.Регистратор) КАК РегистраторПредставление,
	|	""Изменение состояния лицевого счета"" КАК ПредставлениеСобытия,
	|	ТаблицаРегистра.ПериодНачисления КАК ПериодНачисления,
	|	ТаблицаРегистра.ПериодРегистрации КАК ПериодРегистрации,
	|	0 КАК Начислено,
	|	0 КАК НачисленоИтого,
	|	0 КАК Оплачено,
	|	0 КАК Расход,
	|	0 КАК ЗначениеТарифа,
	|	НЕОПРЕДЕЛЕНО КАК НачальныеПоказания,
	|	НЕОПРЕДЕЛЕНО КАК КонечныеПоказания,
	|	NULL КАК ДопЗначение4,
	|	NULL КАК ДопЗначение5,
	|	NULL КАК ИсточникОплаты
	|ИЗ
	|	РегистрСведений.энргСостояниеЛС КАК ТаблицаРегистра
	|ГДЕ
	|	ТаблицаРегистра.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ТаблицаРегистра.Организация = &Организация
	|	И ТаблицаРегистра.Район = &Район
	|	И ТаблицаРегистра.Абонент = &Абонент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаРегистра.Услуга),
	|	"""",
	|	"""",
	|	"""",
	|	"""",
	|	"""",
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаРегистра.ТочкаУчета),
	|	ТаблицаРегистра.ТочкаУчета,
	|	ТаблицаРегистра.Период,
	|	ТаблицаРегистра.Регистратор,
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаРегистра.Регистратор),
	|	""Изменение услуги точки учета"",
	|	ТаблицаРегистра.ПериодНачисления,
	|	ТаблицаРегистра.ПериодРегистрации,
	|	0,
	|	0,
	|	0,
	|	0,
	|	0,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	NULL,
	|	NULL,
	|	NULL
	|ИЗ
	|	РегистрСведений.энргУслугиТочекУчета КАК ТаблицаРегистра
	|ГДЕ
	|	ТаблицаРегистра.Период МЕЖДУ &НачалоПериодаДействияЛС И &КонецПериодаДействияЛС
	|	И ТаблицаРегистра.Организация = &Организация
	|	И ТаблицаРегистра.Район = &Район
	|	И ТаблицаРегистра.КлючПомещения = &КлючПомещения
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаРегистра.Состояние),
	|	"""",
	|	"""",
	|	"""",
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаРегистра.ПриборУчета),
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаРегистра.ПриборУчета.ТипПрибораУчета),
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаРегистра.ТочкаУчета),
	|	ТаблицаРегистра.ТочкаУчета,
	|	ТаблицаРегистра.Период,
	|	ТаблицаРегистра.Регистратор,
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаРегистра.Регистратор),
	|	""Изменение сост-я пр-ра учета"",
