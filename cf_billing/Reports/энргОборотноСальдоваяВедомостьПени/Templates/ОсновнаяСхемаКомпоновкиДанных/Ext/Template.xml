			<field>ВидДоговора</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргВзаиморасчетыПоПениОстаткиИОбороты.Район КАК Район,
	энргВзаиморасчетыПоПениОстаткиИОбороты.МКД КАК МКД,
	энргВзаиморасчетыПоПениОстаткиИОбороты.Абонент КАК Абонент,
	энргВзаиморасчетыПоПениОстаткиИОбороты.Услуга КАК Услуга,
	энргВзаиморасчетыПоПениОстаткиИОбороты.СуммаНачальныйОстаток КАК СуммаПениНачальныйОстаток,
	энргВзаиморасчетыПоПениОстаткиИОбороты.СуммаКонечныйОстаток КАК СуммаПениКонечныйОстаток,
	0 КАК СуммаПениПерерасчет,
	0 КАК СуммаПениНачислено,
	0 КАК СуммаПениОплачено,
	0 КАК ЗачтеноИзАвансов
ПОМЕСТИТЬ ВТ_ВзаиморасчетыПоПене
ИЗ
	РегистрНакопления.энргВзаиморасчетыПоПени.ОстаткиИОбороты(&amp;НачалоПериода, &amp;КонецПериода, , , {(Организация = &amp;Организация), (Район В (&amp;Район)), (МКД В (&amp;МКД)), (Абонент = &amp;Абонент)}) КАК энргВзаиморасчетыПоПениОстаткиИОбороты

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	энргНачислениеПени.Район,
	энргНачислениеПени.МКД,
	энргНачислениеПени.Абонент,
	энргНачислениеПени.Услуга,
	0,
	0,
	СУММА(ВЫБОР
			КОГДА энргНачислениеПени.Регистратор ССЫЛКА Документ.энргРучноеИзменениеПени
				ТОГДА энргНачислениеПени.Сумма
			ИНАЧЕ 0
		КОНЕЦ),
	СУММА(ВЫБОР
			КОГДА НЕ энргНачислениеПени.Регистратор ССЫЛКА Документ.энргРучноеИзменениеПени
				ТОГДА энргНачислениеПени.Сумма
			ИНАЧЕ 0
		КОНЕЦ),
	0,
	0
ИЗ
	РегистрНакопления.энргНачислениеПени КАК энргНачислениеПени
ГДЕ
	энргНачислениеПени.Период &gt;= &amp;НачалоПериода
	И энргНачислениеПени.Период &lt;= &amp;КонецПериода
{ГДЕ
	(энргНачислениеПени.Район В (&amp;Район)),
	(энргНачислениеПени.Организация = &amp;Организация),
	(энргНачислениеПени.МКД В (&amp;МКД)),
	(энргНачислениеПени.Абонент = &amp;Абонент)}

СГРУППИРОВАТЬ ПО
	энргНачислениеПени.Район,
	энргНачислениеПени.МКД,
	энргНачислениеПени.Абонент,
	энргНачислениеПени.Услуга

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	энргОплатаПени.Район,
	энргОплатаПени.МКД,
	энргОплатаПени.Абонент,
	энргОплатаПени.Услуга,
	0,
	0,
	0,
	0,
	СУММА(энргОплатаПени.Сумма),
	0
ИЗ
	РегистрНакопления.энргОплатаПени КАК энргОплатаПени
ГДЕ
	энргОплатаПени.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
{ГДЕ
	(энргОплатаПени.Район В (&amp;Район)),
	(энргОплатаПени.Организация = &amp;Организация),
	(энргОплатаПени.МКД В (&amp;МКД)),
	(энргОплатаПени.Абонент = &amp;Абонент)}

СГРУППИРОВАТЬ ПО
	энргОплатаПени.Район,
	энргОплатаПени.Абонент,
	энргОплатаПени.МКД,
	энргОплатаПени.Услуга

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	энргАвансыИспользованныеОбороты.Район,
	энргАвансыИспользованныеОбороты.МКД,
	энргАвансыИспользованныеОбороты.Абонент,
	энргАвансыИспользованныеОбороты.Услуга,
	0,
	0,
	0,
	0,
	0,
	энргАвансыИспользованныеОбороты.СуммаОборот
ИЗ
	РегистрНакопления.энргАвансыИспользованные.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Регистратор, {(Организация = &amp;Организация), (Район В (&amp;Район)), (МКД В (&amp;МКД)), (Абонент = &amp;Абонент)}) КАК энргАвансыИспользованныеОбороты
ГДЕ
	(энргАвансыИспользованныеОбороты.Регистратор ССЫЛКА Документ.энргНачислениеПени
			ИЛИ энргАвансыИспользованныеОбороты.Регистратор ССЫЛКА Документ.энргРучноеИзменениеПени)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	энргФилиалыАбонентовСрезПоследних.Абонент КАК Абонент,
	энргФилиалыАбонентовСрезПоследних.Филиал КАК Филиал
ПОМЕСТИТЬ ВТ_ФилиалыАбонентов
ИЗ
	РегистрСведений.энргФилиалыАбонентов.СрезПоследних(
			&amp;КонецПериода,
			Абонент В
				(ВЫБРАТЬ
					ВТ_ВзаиморасчетыПоПене.Абонент КАК Абонент
				ИЗ
					ВТ_ВзаиморасчетыПоПене КАК ВТ_ВзаиморасчетыПоПене)) КАК энргФилиалыАбонентовСрезПоследних
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	энргДоговорыАбонентовСрезПоследних.Абонент КАК Абонент,
	скэкДоговорыКонтрагентовДополнительныеРеквизиты.ВидДоговора КАК ВидДоговора
ПОМЕСТИТЬ ВТ_ДоговорыАбонентов
ИЗ
	РегистрСведений.энргДоговорыАбонентов.СрезПоследних(
			&amp;КонецПериода,
			Абонент В
				(ВЫБРАТЬ
					ВТ_ВзаиморасчетыПоПене.Абонент КАК Абонент
				ИЗ
					ВТ_ВзаиморасчетыПоПене КАК ВТ_ВзаиморасчетыПоПене)) КАК энргДоговорыАбонентовСрезПоследних
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.скэкДоговорыКонтрагентовДополнительныеРеквизиты КАК скэкДоговорыКонтрагентовДополнительныеРеквизиты
		ПО энргДоговорыАбонентовСрезПоследних.Договор = скэкДоговорыКонтрагентовДополнительныеРеквизиты.ДоговорКонтрагента
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ДоговорыАбонентов.ВидДоговора КАК ВидДоговора,
	ВТ_ВзаиморасчетыПоПене.Район КАК ТериторриальныйОрган,
	ВТ_ВзаиморасчетыПоПене.МКД КАК МКД,
	ВТ_ВзаиморасчетыПоПене.Абонент КАК Абонент,
	ВТ_ВзаиморасчетыПоПене.Услуга КАК Услуга,
	СУММА(ВТ_ВзаиморасчетыПоПене.СуммаПениНачальныйОстаток) КАК СуммаПениНачальныйОстаток,
	СУММА(ВТ_ВзаиморасчетыПоПене.СуммаПениКонечныйОстаток) КАК СуммаПениКонечныйОстаток,
	СУММА(ВТ_ВзаиморасчетыПоПене.СуммаПениПерерасчет) КАК СуммаПениПерерасчет,
	СУММА(ВТ_ВзаиморасчетыПоПене.СуммаПениНачислено) КАК СуммаПениНачислено,
	СУММА(ВТ_ВзаиморасчетыПоПене.СуммаПениОплачено) КАК СуммаПениОплачено,
	ЕСТЬNULL(ВТ_ФилиалыАбонентов.Филиал, ЗНАЧЕНИЕ(Справочник.энргФилиалы.ПустаяСсылка)) КАК Филиал,
	СУММА(ВТ_ВзаиморасчетыПоПене.ЗачтеноИзАвансов) КАК ЗачтеноИзАвансов,
	энргКлючиПомещений.Строение КАК Строение,
	энргКлючиПомещений.Помещение КАК Помещение,
	энргАбоненты.ЛицевойСчет КАК ЛицевойСчет
ИЗ
	ВТ_ВзаиморасчетыПоПене КАК ВТ_ВзаиморасчетыПоПене
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ФилиалыАбонентов КАК ВТ_ФилиалыАбонентов
		ПО ВТ_ВзаиморасчетыПоПене.Абонент = ВТ_ФилиалыАбонентов.Абонент
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДоговорыАбонентов КАК ВТ_ДоговорыАбонентов
		ПО ВТ_ВзаиморасчетыПоПене.Абонент = ВТ_ДоговорыАбонентов.Абонент
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
			ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.Ссылка
		ПО ВТ_ВзаиморасчетыПоПене.Абонент = энргАбоненты.Ссылка
{ГДЕ
	(ВТ_ФилиалыАбонентов.Филиал В (&amp;Филиал)),
	(ВТ_ДоговорыАбонентов.ВидДоговора = &amp;ВидДоговора)}

СГРУППИРОВАТЬ ПО
	ВТ_ДоговорыАбонентов.ВидДоговора,
	ВТ_ВзаиморасчетыПоПене.Район,
	ВТ_ВзаиморасчетыПоПене.МКД,
	ВТ_ВзаиморасчетыПоПене.Абонент,
	ВТ_ВзаиморасчетыПоПене.Услуга,
	ЕСТЬNULL(ВТ_ФилиалыАбонентов.Филиал, ЗНАЧЕНИЕ(Справочник.энргФилиалы.ПустаяСсылка)),
	энргКлючиПомещений.Строение,
	энргКлючиПомещений.Помещение,
	энргАбоненты.ЛицевойСчет</query>
	</dataSet>
	<totalField>
		<dataPath>СуммаПениКонечныйОстаток</dataPath>
		<expression>Сумма(СуммаПениКонечныйОстаток)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаПениНачальныйОстаток</dataPath>
		<expression>Сумма(СуммаПениНачальныйОстаток)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаПениНачислено</dataPath>
		<expression>Сумма(СуммаПениНачислено)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаПениОплачено</dataPath>
		<expression>Сумма(СуммаПениОплачено)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаПениПерерасчет</dataPath>
		<expression>Сумма(СуммаПениПерерасчет)</expression>
	</totalField>
	<totalField>
		<dataPath>ЗачтеноИзАвансов</dataPath>
		<expression>Сумма(ЗачтеноИзАвансов)</expression>
	</totalField>
	<parameter>
		<name>НачалоПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Начало периода</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>false</useRestriction>
		<expression>&amp;ПериодФормирования.ДатаНачала</expression>
	</parameter>
	<parameter>
		<name>КонецПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Конец периода</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>false</useRestriction>
		<expression>КонецПериода(&amp;ПериодФормирования.ДатаОкончания,"День")</expression>
	</parameter>
	<parameter>
