		<query>ВЫБРАТЬ
	ВложенныйЗапрос.Абонент КАК Абонент
ПОМЕСТИТЬ ВрТ0
ИЗ
	(ВЫБРАТЬ
		энргАбоненты.Ссылка КАК Абонент
	ИЗ
		Справочник.энргАбоненты КАК энргАбоненты
	ГДЕ
		энргАбоненты.ПометкаУдаления
		И энргАбоненты.ЭтоГруппа
		И энргАбоненты.Организация = &amp;Организация
	
	СГРУППИРОВАТЬ ПО
		энргАбоненты.Ссылка) КАК ВложенныйЗапрос
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргСостояниеЛС.СрезПоследних(&amp;ДатаКон, ) КАК энргСостояниеЛССрезПоследних
		ПО ВложенныйЗапрос.Абонент = энргСостояниеЛССрезПоследних.Абонент
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	энргАбоненты.СтарыйЛС КАК СтарыйЛС,
	энргОбъемНачисленийОбороты.Услуга КАК Услуга,
	энргОбъемНачисленийОбороты.ПериодРасчета КАК ПериодРасчета,
	энргОбъемНачисленийОбороты.ПериодНачисления КАК ПериодНачисления,
	СУММА(энргОбъемНачисленийОбороты.ОбъемУслугиОборот) КАК ОбъемУслуги,
	энргОбъемНачисленийОбороты.Организация КАК Организация,
	энргОбъемНачисленийОбороты.Район КАК Район,
	энргОбъемНачисленийОбороты.Абонент КАК Абонент,
	энргАбоненты.КлючПомещения КАК КлючПомещения
ПОМЕСТИТЬ ВрТ1
ИЗ
	РегистрНакопления.энргОбъемНачислений.Обороты(
			,
			,
			,
			ПериодРасчета = &amp;ПериодРасчета
				И Организация = &amp;Организация
				И Услуга = &amp;Услуга) КАК энргОбъемНачисленийОбороты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		ПО энргОбъемНачисленийОбороты.Абонент = энргАбоненты.Ссылка
ГДЕ
	НЕ энргАбоненты.ПометкаУдаления

СГРУППИРОВАТЬ ПО
	энргОбъемНачисленийОбороты.ПериодНачисления,
	энргАбоненты.СтарыйЛС,
	энргОбъемНачисленийОбороты.ПериодРасчета,
	энргОбъемНачисленийОбороты.Услуга,
	энргОбъемНачисленийОбороты.Организация,
	энргОбъемНачисленийОбороты.Район,
	энргОбъемНачисленийОбороты.Абонент,
	энргАбоненты.КлючПомещения
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВрТ1.СтарыйЛС КАК СтарыйЛС,
	ВрТ1.Услуга КАК Услуга,
	ВрТ1.ПериодРасчета КАК ПериодРасчета,
	ВрТ1.ПериодНачисления КАК ПериодНачисления,
	ВрТ1.ОбъемУслуги КАК ОбъемУслуги,
	ВрТ1.Организация КАК Организация,
	ВрТ1.Район КАК Район,
	ВрТ1.Абонент КАК Абонент,
	ВрТ1.КлючПомещения КАК КлючПомещения,
	ЕСТЬNULL(энргКлючиПомещений.Строение, "") КАК Строение,
	ЕСТЬNULL(энргКлючиПомещений.Помещение, "") КАК Помещение
ПОМЕСТИТЬ ВрТ2
ИЗ
	ВрТ1 КАК ВрТ1
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
		ПО ВрТ1.КлючПомещения = энргКлючиПомещений.Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВрТ2.СтарыйЛС КАК СтарыйЛС,
