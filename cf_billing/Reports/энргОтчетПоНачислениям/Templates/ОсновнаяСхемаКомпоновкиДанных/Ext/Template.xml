			<field>НеПрименятьСезонность</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргОбъемНачисленийОбороты.Организация КАК Организация,
	энргОбъемНачисленийОбороты.Абонент.ЛицевойСчет КАК АбонентЛицевойСчет,
	энргОбъемНачисленийОбороты.Абонент КАК Абонент,
	энргАбонентыКонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей,
	ВЫБОР
		КОГДА энргАбоненты.ФизЛицо.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.бестЮрФизЛицо.ФизЛицо)
			ТОГДА "Жилое помещение"
		ИНАЧЕ "Нежилое помещение"
	КОНЕЦ КАК ТипПомещения,
	энргОбъемНачисленийОбороты.Район КАК Район,
	энргОбъемНачисленийОбороты.Строение КАК Строение,
	энргАбоненты.КлючПомещения КАК КлючПомещения,
	энргОбъемНачисленийОбороты.Услуга КАК Услуга,
	энргОбъемНачисленийОбороты.ОбъемУслугиОборот КАК ОбъемУслугиОборот,
	энргОбъемНачисленийОбороты.Услуга.ЕдиницаИзмерения КАК УслугаЕдиницаИзмерения,
	энргОбъемНачисленийОбороты.ЗначениеТарифа КАК ЗначениеТарифа,
	ВЫБОР
		КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.НачислениеОДН)
				ИЛИ энргОбъемНачисленийОбороты.СпособНачисления = ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.НачислениеОДН)
			ТОГДА ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.НачислениеОДН)
		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Начисление)
	КОНЕЦ КАК СпособНачисления,
	энргОбъемНачисленийОбороты.СпособНачисления КАК ТипРасчёта,
	ВЫБОР
		КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Перерасчет)
			ТОГДА 0
		ИНАЧЕ энргОбъемНачисленийОбороты.СуммаОборот
	КОНЕЦ КАК СуммаНачислений,
	ВЫБОР
		КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Перерасчет)
				И энргОбъемНачисленийОбороты.СуммаОборот &gt; 0
			ТОГДА энргОбъемНачисленийОбороты.СуммаОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ПерерасчДебет,
	ВЫБОР
		КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Перерасчет)
				И энргОбъемНачисленийОбороты.СуммаОборот &lt; 0
			ТОГДА -энргОбъемНачисленийОбороты.СуммаОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ПерерасчКредит
ПОМЕСТИТЬ ВТ_Данные
ИЗ
	РегистрНакопления.энргОбъемНачислений.Обороты({(&amp;ПериодНачало)}, {(&amp;ПериодОкончание)}, , ПериодРасчета = &amp;ПериодМесяц {(Абонент = &amp;Абонент), (Район = &amp;Филиал), (Строение = &amp;Строение), (Услуга = &amp;Услуга)}) КАК энргОбъемНачисленийОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
		ПО энргОбъемНачисленийОбороты.Абонент = энргАбонентыКонтактнаяИнформация.Ссылка
			И (энргАбонентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресОбъекта))
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		ПО энргОбъемНачисленийОбороты.Абонент = энргАбоненты.Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	энргФормыУправленияМКДСрезПоследних.УК КАК ИКУ,
	энргФормыУправленияМКДСрезПоследних.Организация КАК Организация,
	энргФормыУправленияМКДСрезПоследних.Район КАК Район,
	энргФормыУправленияМКДСрезПоследних.МКД КАК МКД
ПОМЕСТИТЬ ВТ_ФормыУправленияМКД
ИЗ
	РегистрСведений.энргФормыУправленияМКД.СрезПоследних(
			{(&amp;ПериодОкончание)},
			(Организация, Район, МКД) В
					(ВЫБРАТЬ
						ВТ_Данные.Организация КАК Организация,
						ВТ_Данные.Район КАК Район,
						ВТ_Данные.Строение КАК Строение
					ИЗ
						ВТ_Данные КАК ВТ_Данные)
				И ПериодНачисления &lt;= &amp;ПериодМесяц) КАК энргФормыУправленияМКДСрезПоследних
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	энргЗначенияПлощадейСрезПоследних.Организация КАК Организация,
	энргЗначенияПлощадейСрезПоследних.Район КАК Район,
	энргЗначенияПлощадейСрезПоследних.КлючПомещения КАК КлючПомещения,
	МАКСИМУМ(энргЗначенияПлощадейСрезПоследних.Площадь) КАК Площадь
ПОМЕСТИТЬ ВТ_Площадь
ИЗ
	РегистрСведений.энргЗначенияПлощадей.СрезПоследних(
			{(&amp;ПериодОкончание)},
			(Организация, Район, КлючПомещения) В
					(ВЫБРАТЬ
						ВТ_Данные.Организация КАК Организация,
						ВТ_Данные.Район КАК Район,
						ВТ_Данные.КлючПомещения КАК КлючПомещения
					ИЗ
						ВТ_Данные КАК ВТ_Данные)
				И ПериодНачисления &lt;= &amp;ПериодМесяц
				И ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадь)) КАК энргЗначенияПлощадейСрезПоследних

СГРУППИРОВАТЬ ПО
	энргЗначенияПлощадейСрезПоследних.Организация,
	энргЗначенияПлощадейСрезПоследних.Район,
	энргЗначенияПлощадейСрезПоследних.КлючПомещения
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	энргОбъемНачисленийДляЛьготныхЛицОбороты.Организация КАК Организация,
	энргОбъемНачисленийДляЛьготныхЛицОбороты.МКД КАК МКД,
	энргОбъемНачисленийДляЛьготныхЛицОбороты.Абонент КАК Абонент,
	энргОбъемНачисленийДляЛьготныхЛицОбороты.Район КАК Район,
	СУММА(-энргОбъемНачисленийДляЛьготныхЛицОбороты.СуммаЛьготыОборот) КАК СуммаЛьготыОборот,
	МАКСИМУМ(энргОбъемНачисленийДляЛьготныхЛицОбороты.ЛьготнаяКатегория) КАК ЛьготнаяКатегория,
	энргОбъемНачисленийДляЛьготныхЛицОбороты.Услуга КАК Услуга
ПОМЕСТИТЬ ВТ_Льготы
ИЗ
	РегистрНакопления.энргОбъемНачисленийДляЛьготныхЛиц.Обороты(
			{(&amp;ПериодНачало)},
			{(&amp;ПериодОкончание)},
			,
			(Организация, МКД, Район, Абонент) В
					(ВЫБРАТЬ
						ВТ_Данные.Организация КАК Организация,
						ВТ_Данные.Строение КАК Строение,
						ВТ_Данные.Район КАК Район,
						ВТ_Данные.Абонент КАК Абонент
					ИЗ
						ВТ_Данные КАК ВТ_Данные)
				И ПериодРасчета = &amp;ПериодМесяц) КАК энргОбъемНачисленийДляЛьготныхЛицОбороты

СГРУППИРОВАТЬ ПО
	энргОбъемНачисленийДляЛьготныхЛицОбороты.Организация,
	энргОбъемНачисленийДляЛьготныхЛицОбороты.МКД,
	энргОбъемНачисленийДляЛьготныхЛицОбороты.Абонент,
	энргОбъемНачисленийДляЛьготныхЛицОбороты.Район,
