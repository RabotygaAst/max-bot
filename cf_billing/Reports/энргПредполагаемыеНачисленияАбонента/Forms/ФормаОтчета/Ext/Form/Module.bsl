	МассивПараметров.Добавить(АдресХранилища);
	
	Если ЗначениеЗаполнено(ИдентификаторЗадания) Тогда
		ДлительныеОперации.ОтменитьВыполнениеЗадания(ИдентификаторЗадания);
	Иначе
		ИдентификаторЗадания = Новый УникальныйИдентификатор;
	КонецЕсли;
	
	
	ИмяМетода  							= "";
		
	ПараметрыЗадания = Новый Массив;
	ПараметрыЗадания.Добавить(ИмяМетода);
	ПараметрыЗадания.Добавить(ПараметрыКарточки);
	
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(ИдентификаторЗадания);
	//ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Сопоставление объектов'");

	
	ПараметрыЗапуска = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыЗапуска.НаименованиеФоновогоЗадания = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Выполнение отчета: %1'"), "Предполагаемые начисления абонента");
	ПараметрыЗапуска.ОжидатьЗавершение = Ложь;
	ПараметрыЗапуска.ЗапуститьНеВФоне = Ложь;
	РезультатФоновогоЗадания = ДлительныеОперации.ВыполнитьВФоне("Отчеты.энргПредполагаемыеНачисленияАбонента.СформироватьОтчет", 
					ПараметрыКарточки, ПараметрыЗапуска);

	
	
	
	
	
	//Задание 							= ДлительныеОперации.ЗапуститьФоновоеЗаданиеСКонтекстомКлиента(ИмяМетода,МассивПараметров);

	//ИдентификаторЗадания 				= РезультатФоновогоЗадания.ИдентификаторЗадания;		
	//	
	//Если Задание.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
	//	РезультатОтчета = ПолучитьИзВременногоХранилища(АдресХранилища);
	//	Возврат Истина;
	//иначе
	//	Возврат Ложь;
	//КонецЕсли;   
	//
	
	Если РезультатФоновогоЗадания.Статус = "Ошибка" Тогда
		//ПоказатьОшибкиФормирования(РезультатФоновогоЗадания.КраткоеПредставлениеОшибки);
		Возврат Ложь;
	КонецЕсли;
	
	ИдентификаторЗадания  = РезультатФоновогоЗадания.ИдентификаторЗадания;
	АдресХранилища = РезультатФоновогоЗадания.АдресРезультата;
	
	Если РезультатФоновогоЗадания.Статус = "Выполнено" Тогда
		РезультатОтчета = ПолучитьИзВременногоХранилища(АдресХранилища);
		Возврат Истина;
	Иначе
		//ОтображениеСостояния = Элементы.ОтчетТабличныйДокумент.ОтображениеСостояния;
		//ОтображениеСостояния.Видимость                      = Истина;
		//ОтображениеСостояния.ДополнительныйРежимОтображения = ДополнительныйРежимОтображения.Неактуальность;
		//ОтображениеСостояния.Картинка                       = БиблиотекаКартинок.ДлительнаяОперация48;
		//ОтображениеСостояния.Текст                          = НСтр("ru = 'Отчет формируется...'");
		
		Возврат Ложь;
	КонецЕсли;
	
	//Возврат ЗаданиеЗапущено;

КонецФункции 

