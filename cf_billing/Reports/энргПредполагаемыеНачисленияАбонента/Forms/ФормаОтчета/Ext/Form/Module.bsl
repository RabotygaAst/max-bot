
#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Основание") тогда		
		Абонент 			= Параметры.Основание.Абонент;
		Период 				= Параметры.Основание.Дата;
		ПериодНачисления	= Параметры.Основание.ПериодНачисления;
	КонецЕсли; 	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ЗначениеЗаполнено(Абонент) и ЗначениеЗаполнено(Период) тогда 		
		ОбщегоНазначенияКлиентСервер.УстановитьСостояниеПоляТабличногоДокумента(Элементы.РезультатОтчета,"ФОРМИРОВАНИЕОТЧЕТА");
		Если не ОбновитьОтчетСервер() тогда
			ПодключитьОбработчикОжидания("Подключаемый_ПроверитьВыполнениеЗадания",2,Истина);
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовШапки

&НаКлиенте
Процедура ПериодПриИзменении(Элемент)
	ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Период, Организация);
КонецПроцедуры

#КонецОбласти


#Область КомандыФормы

&НаКлиенте
Процедура ОбновитьОтчет(Команда)
	
	ОбщегоНазначенияКлиентСервер.УстановитьСостояниеПоляТабличногоДокумента(Элементы.РезультатОтчета,"ФОРМИРОВАНИЕОТЧЕТА");

	Если не ОбновитьОтчетСервер() тогда
		ПодключитьОбработчикОжидания("Подключаемый_ПроверитьВыполнениеЗадания",2,Истина);
	КонецЕсли;   
	
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаКлиенте
Процедура Подключаемый_ПроверитьВыполнениеЗадания()  
	
	ПараметрыОбработчикаОжидания = Новый Структура("ТекущийИнтервал,КоэффициентУвеличенияИнтервала,МаксимальныйИнтервал",2,1,10);
	
	Попытка
		Если ЗаданиеВыполнено(ИдентификаторЗадания) Тогда
			РезультатОтчета = ПолучитьИзВременногоХранилища(АдресХранилища);
			ОбщегоНазначенияКлиентСервер.УстановитьСостояниеПоляТабличногоДокумента(Элементы.РезультатОтчета,"НЕИСПОЛЬЗОВАТЬ");   
		Иначе
			ДлительныеОперацииКлиент.ОбновитьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания);
			ПодключитьОбработчикОжидания(
				"Подключаемый_ПроверитьВыполнениеЗадания", 
				ПараметрыОбработчикаОжидания.ТекущийИнтервал, 
				Истина);
		КонецЕсли;
	Исключение
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗаданиеВыполнено(ИдентификаторЗадания)
	
	Возврат ДлительныеОперации.ЗаданиеВыполнено(ИдентификаторЗадания);
	
КонецФункции

&НаСервере
Функция ОбновитьОтчетСервер()
		
	ПараметрыКарточки  					= Новый Структура("Период,ПериодНачисления,Абонент",Период,ПериодНачисления,Абонент);
