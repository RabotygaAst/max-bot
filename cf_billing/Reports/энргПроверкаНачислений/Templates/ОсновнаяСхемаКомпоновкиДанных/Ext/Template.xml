	энргОбъемНачислений.Услуга КАК Услуга,
	энргОбъемНачислений.ТочкаУчета КАК ТочкаУчета,
	энргОбъемНачислений.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	энргОбъемНачислений.ТарифнаяЗона КАК ТарифнаяЗона,
	энргОбъемНачислений.ЗначениеТарифа КАК ЗначениеТарифа,
	энргОбъемНачислений.ОбъемУслуги КАК ОбъемУслуги,
	энргОбъемНачислений.Сумма КАК Сумма,
	энргОбъемНачислений.Абонент.ЛицевойСчет КАК АбонентЛицевойСчет,
	энргОбъемНачислений.НормаПотребления КАК НормаПотребления,
	ВЫБОР
		КОГДА энргОбъемНачислений.Сумма = 0
			ТОГДА "Не заполнена сумма "
		ИНАЧЕ ""
	КОНЕЦ КАК СуммаНеЗаполнена,
	ВЫБОР
		КОГДА энргОбъемНачислений.ЗначениеТарифа = 0
			ТОГДА "Не заполнен тариф"
		ИНАЧЕ ""
	КОНЕЦ КАК ТарифНеЗаполнен,
	ВЫБОР
		КОГДА энргОбъемНачислений.ОбъемУслуги = 0
			ТОГДА "Не заполнен объем услуги "
		ИНАЧЕ ""
	КОНЕЦ КАК ОбъемНеЗаполнен,
	"" КАК ОписаниеОшибки
ПОМЕСТИТЬ ВТ1
ИЗ
	РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
ГДЕ
	энргОбъемНачислений.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
	И энргОбъемНачислений.ТочкаУчетаРодитель = ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)
	И ВЫБОР
			КОГДА энргОбъемНачислений.СпособНачисления = ЗНАЧЕНИЕ(Перечисление.энргСпособНачислений.ПоПриборам)
				ТОГДА энргОбъемНачислений.НачальныеПоказания &lt;&gt; энргОбъемНачислений.КонечныеПоказания
			ИНАЧЕ ИСТИНА
		КОНЕЦ

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	энргОбъемНачислений.Организация,
	энргОбъемНачислений.Район,
	энргОбъемНачислений.Строение,
	энргОбъемНачислений.Абонент,
	энргОбъемНачислений.Услуга,
	энргОбъемНачислений.ТочкаУчета,
	энргОбъемНачислений.НаправлениеИспользованияТУ,
	энргОбъемНачислений.ТарифнаяЗона,
	энргОбъемНачислений.ЗначениеТарифа,
	энргОбъемНачислений.ОбъемУслуги,
	энргОбъемНачислений.Сумма,
	энргОбъемНачислений.Абонент.ЛицевойСчет,
	энргОбъемНачислений.НормаПотребления,
	"",
	"",
	"",
	"Отрицательный объем начислений"
ИЗ
	РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
ГДЕ
	энргОбъемНачислений.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
	И энргОбъемНачислений.ОбъемУслуги &lt; 0
	И НЕ ТИПЗНАЧЕНИЯ(энргОбъемНачислений.Регистратор) = ЗНАЧЕНИЕ(документ.энргперерасчет)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	энргУслугиТочекУчетаСрезПоследних.Организация КАК Организация,
