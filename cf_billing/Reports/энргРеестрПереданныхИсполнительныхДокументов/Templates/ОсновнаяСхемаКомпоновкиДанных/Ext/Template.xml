		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргЭтапПретензионноИсковойДеятельности.Район,
	энргЭтапПретензионноИсковойДеятельности.Абонент КАК Должник,
	энргЭтапПретензионноИсковойДеятельности.ЛицевойСчет КАК ЛС,
	ВЫРАЗИТЬ(энргЭтапПретензионноИсковойДеятельности.АдресОбъекта КАК СТРОКА(300)) КАК Адрес,
	энргЭтапПретензионноИсковойДеятельности.Номер КАК НомерИсполнительногоДок,
	энргЭтапПретензионноИсковойДеятельности.Дата КАК ДатаВыдачиИсполнительногоДок,
	энргЭтапПретензионноИсковойДеятельности.СуммаЗадолженности КАК СуммаЗадолженности,
	энргЭтапПретензионноИсковойДеятельности.СуммаГоспошлина КАК СуммаГоспошлина,
	энргЭтапПретензионноИсковойДеятельности.СуммаЗадолженности + энргЭтапПретензионноИсковойДеятельности.СуммаГоспошлина КАК Взыскать,
	0 КАК ОплаченоПоДолгам
ПОМЕСТИТЬ ВрТ1
ИЗ
	Документ.энргЭтапПретензионноИсковойДеятельности КАК энргЭтапПретензионноИсковойДеятельности
ГДЕ
	энргЭтапПретензионноИсковойДеятельности.Проведен = ИСТИНА
	И энргЭтапПретензионноИсковойДеятельности.Дата МЕЖДУ &amp;ДатаНач И &amp;ДатаКон
	И энргЭтапПретензионноИсковойДеятельности.ЭтапПИД = ЗНАЧЕНИЕ(Справочник.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_ПередачаПакетаДокументовЮристам)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВрТ1.Район,
	ВрТ1.Должник,
	ВрТ1.ЛС,
	ВрТ1.Адрес,
	ВрТ1.НомерИсполнительногоДок,
	ВрТ1.ДатаВыдачиИсполнительногоДок,
	СУММА(ВрТ1.СуммаЗадолженности) КАК СуммаДолга,
	СУММА(ВрТ1.СуммаГоспошлина) КАК СуммаГП,
	СУММА(ВрТ1.Взыскать) КАК Взыскать,
	СУММА(ВрТ1.ОплаченоПоДолгам) КАК ОплаченоПоДолгам
ИЗ
	ВрТ1 КАК ВрТ1

СГРУППИРОВАТЬ ПО
	ВрТ1.Должник,
	ВрТ1.ЛС,
	ВрТ1.Адрес,
	ВрТ1.НомерИсполнительногоДок,
	ВрТ1.ДатаВыдачиИсполнительногоДок,
	ВрТ1.Район</query>
