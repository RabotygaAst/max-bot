<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>МКД</dataPath>
			<field>МКД</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ФормаУправления</dataPath>
			<field>ФормаУправления</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УК</dataPath>
			<field>УК</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаНачала</dataPath>
			<field>ДатаНачала</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата начала</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаОкончания</dataPath>
			<field>ДатаОкончания</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата окончания</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргФормыУправленияМКД.Период КАК Период,
	энргФормыУправленияМКД.МКД КАК МКД,
	энргФормыУправленияМКД.ФормаУправления КАК ФормаУправления,
	энргФормыУправленияМКД.УК КАК УК
ПОМЕСТИТЬ ВТ_Источник
ИЗ
	РегистрСведений.энргФормыУправленияМКД КАК энргФормыУправленияМКД
ГДЕ
	энргФормыУправленияМКД.Организация = &amp;Организация
	И энргФормыУправленияМКД.Район = &amp;Район
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ИсточникНачало.МКД КАК МКД,
	ВТ_ИсточникНачало.УК КАК УК,
	ВТ_ИсточникНачало.ФормаУправления КАК ФормаУправления,
	МИНИМУМ(ВТ_ИсточникНачало.Период) КАК Начало,
	МИНИМУМ(ВТ_ИсточникКонец.Период) КАК Конец
ПОМЕСТИТЬ ВТ_Периоды
ИЗ
	ВТ_Источник КАК ВТ_ИсточникНачало
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Источник КАК ВТ_ИсточникКонец
		ПО ВТ_ИсточникНачало.МКД = ВТ_ИсточникКонец.МКД
			И ВТ_ИсточникНачало.Период &lt; ВТ_ИсточникКонец.Период

СГРУППИРОВАТЬ ПО
	ВТ_ИсточникНачало.МКД,
	ВТ_ИсточникНачало.ФормаУправления,
	ВТ_ИсточникНачало.УК
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Периоды.МКД КАК МКД,
	ВТ_Периоды.УК КАК УК,
	ВТ_Периоды.ФормаУправления КАК ФормаУправления,
	ВТ_Периоды.Начало КАК ДатаНачала,
	ВТ_Периоды.Конец КАК ДатаОкончания
ИЗ
	ВТ_Периоды КАК ВТ_Периоды
ГДЕ
	ВТ_Периоды.УК &lt;&gt; ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка)</query>
	</dataSet>
