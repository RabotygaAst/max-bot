			<field>ВидУслуги</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Вид услуги</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЗначенияПолей</dataPath>
			<field>ЗначенияПолей</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>АбонентскийОтдел</dataPath>
			<field>АбонентскийОтдел</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Абонентский отдел</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТерриториальныйОрган</dataPath>
			<field>ТерриториальныйОрган</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Территориальный орган</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипВодопотребления</dataPath>
			<field>ТипВодопотребления</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Тип водопотребления</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Услуга</dataPath>
			<field>Услуга</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Строение</dataPath>
			<field>Строение</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	энргСостояниеПриборовУчетаАбонентаСрезПоследних.ПриборУчета КАК ПриборУчета,
	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Район КАК Район,
	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Период КАК Период,
	ВЫБОР
		КОГДА энргСостояниеПриборовУчетаАбонентаСрезПоследних.КлючПомещения.Помещение &lt;&gt; ЗНАЧЕНИЕ(Справочник.энргПомещения.ПустаяСсылка)
			ТОГДА энргСостояниеПриборовУчетаАбонентаСрезПоследних.КлючПомещения.Строение.Наименование + ", " + энргСостояниеПриборовУчетаАбонентаСрезПоследних.КлючПомещения.Помещение.Наименование
		ИНАЧЕ энргСостояниеПриборовУчетаАбонентаСрезПоследних.КлючПомещения.Строение.Наименование
	КОНЕЦ КАК Адрес,
	энргДатыПоверкиПрибораУчетаСрезПоследних.ДатаПоверки КАК ДатаПоверки,
	энргСостояниеПриборовУчетаАбонентаСрезПоследних.КлючПомещения КАК КлючПомещения,
	ВЫБОР
		КОГДА энргПомещенияКонтактнаяИнформация.ЗначенияПолей ЕСТЬ NULL
			ТОГДА энргСтроенияКонтактнаяИнформация.ЗначенияПолей
		ИНАЧЕ энргПомещенияКонтактнаяИнформация.ЗначенияПолей
	КОНЕЦ КАК ЗначенияПолей,
	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Организация КАК Организация,
	энргФилиалыСтроенийСрезПоследних.Филиал КАК Филиал
ПОМЕСТИТЬ ПриборыУчета
ИЗ
	РегистрСведений.энргСостояниеПриборовУчетаАбонента.СрезПоследних(&amp;КонецПериода, ) КАК энргСостояниеПриборовУчетаАбонентаСрезПоследних
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
		ПО энргСостояниеПриборовУчетаАбонентаСрезПоследних.КлючПомещения.Строение = энргСтроенияКонтактнаяИнформация.Ссылка
			И (энргСтроенияКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресДома))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргДатыПоверкиПрибораУчета.СрезПоследних(&amp;КонецПериода, ) КАК энргДатыПоверкиПрибораУчетаСрезПоследних
		ПО энргСостояниеПриборовУчетаАбонентаСрезПоследних.КлючПомещения = энргДатыПоверкиПрибораУчетаСрезПоследних.КлючПомещения
			И энргСостояниеПриборовУчетаАбонентаСрезПоследних.ПриборУчета = энргДатыПоверкиПрибораУчетаСрезПоследних.ПриборУчета
			И энргСостояниеПриборовУчетаАбонентаСрезПоследних.Район = энргДатыПоверкиПрибораУчетаСрезПоследних.Район
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргПомещения.КонтактнаяИнформация КАК энргПомещенияКонтактнаяИнформация
		ПО энргСостояниеПриборовУчетаАбонентаСрезПоследних.КлючПомещения.Помещение = энргПомещенияКонтактнаяИнформация.Ссылка
			И (энргПомещенияКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.Видыконтактнойинформации.АдресПомещения))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргФилиалыСтроений.СрезПоследних(&amp;КонецПериода, ) КАК энргФилиалыСтроенийСрезПоследних
		ПО энргСостояниеПриборовУчетаАбонентаСрезПоследних.Организация = энргФилиалыСтроенийСрезПоследних.Организация
			И энргСостояниеПриборовУчетаАбонентаСрезПоследних.Район = энргФилиалыСтроенийСрезПоследних.Район
			И энргСостояниеПриборовУчетаАбонентаСрезПоследних.КлючПомещения.Строение = энргФилиалыСтроенийСрезПоследних.Строение
ГДЕ
	энргСостояниеПриборовУчетаАбонентаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)
	И энргСостояниеПриборовУчетаАбонентаСрезПоследних.Период &gt; &amp;НачалоПериода
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПриборыУчета.ПриборУчета КАК ПриборУчета,
	ПриборыУчета.Район КАК ТерриториальныйОрган,
	ПриборыУчета.Период КАК ДатаУстановкиСчетчика,
	ПриборыУчета.Адрес КАК Адрес,
	ПриборыУчета.ДатаПоверки КАК КонечнаяДата,
	энргУслугиТочекУчетаСрезПоследних.Услуга КАК ВидУслуги,
	ПриборыУчета.ЗначенияПолей КАК ЗначенияПолей,
	ПриборыУчета.Организация КАК Организация,
	ВЫБОР
		КОГДА энргВидыУслуг.СоставнаяУслуга = ИСТИНА
			ТОГДА энргВидыУслугСоставляющиеУслуг.Услуга
		ИНАЧЕ энргВидыУслуг.Ссылка
	КОНЕЦ КАК Услуга,
	ПриборыУчета.КлючПомещения КАК КлючПомещения,
	энргВидыУслугЗависимыеУслуги.Услуга КАК Услуга1,
	ПриборыУчета.ТочкаУчета КАК ТочкаУчета,
	ПриборыУчета.Филиал КАК АбонентскийОтдел
ПОМЕСТИТЬ Вр
ИЗ
	ПриборыУчета КАК ПриборыУчета
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргУслугиТочекУчета.СрезПоследних КАК энргУслугиТочекУчетаСрезПоследних
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
				ПО энргВидыУслуг.Ссылка = энргВидыУслугСоставляющиеУслуг.Ссылка
				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.ЗависимыеУслуги КАК энргВидыУслугЗависимыеУслуги
				ПО энргВидыУслуг.Ссылка = энргВидыУслугЗависимыеУслуги.Ссылка
			ПО энргУслугиТочекУчетаСрезПоследних.Услуга = энргВидыУслуг.Ссылка
		ПО ПриборыУчета.ТочкаУчета = энргУслугиТочекУчетаСрезПоследних.ТочкаУчета
			И ПриборыУчета.Район = энргУслугиТочекУчетаСрезПоследних.Район
			И ПриборыУчета.КлючПомещения = энргУслугиТочекУчетаСрезПоследних.КлючПомещения
			И ПриборыУчета.Организация = энргУслугиТочекУчетаСрезПоследних.Организация
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВЫБОР
		КОГДА Вр.Услуга = Вр.Услуга1
			ТОГДА NULL
		ИНАЧЕ Вр.ПриборУчета
	КОНЕЦ КАК ПриборУчета,
	Вр.ТерриториальныйОрган КАК ТерриториальныйОрган,
	ВЫБОР
		КОГДА Вр.Услуга = Вр.Услуга1
			ТОГДА NULL
		ИНАЧЕ Вр.ДатаУстановкиСчетчика
	КОНЕЦ КАК ДатаУстановкиСчетчика,
	Вр.Адрес КАК Адрес,
	ВЫБОР
		КОГДА Вр.Услуга = Вр.Услуга1
			ТОГДА NULL
		ИНАЧЕ Вр.КонечнаяДата
	КОНЕЦ КАК КонечнаяДата,
	Вр.ВидУслуги КАК ВидУслуги,
	Вр.ЗначенияПолей КАК ЗначенияПолей,
	Вр.Организация КАК Организация,
	Вр.АбонентскийОтдел КАК АбонентскийОтдел,
	Вр.Услуга КАК Услуга,
	Вр.КлючПомещения КАК КлючПомещения,
	Вр.Услуга1 КАК Услуга1
ПОМЕСТИТЬ ВременнаяТаблица
ИЗ
	Вр КАК Вр
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	энргВидБлагоустройствАбонентаСрезПоследних.ВидБлагоустройства КАК ТипВодопотребления,
	ВременнаяТаблица.ПриборУчета КАК ПриборУчета,
	ВременнаяТаблица.ТерриториальныйОрган КАК ТерриториальныйОрган,
	ВременнаяТаблица.ДатаУстановкиСчетчика КАК ДатаУстановкиСчетчика,
	ВременнаяТаблица.Адрес КАК Адрес,
	ВременнаяТаблица.КонечнаяДата КАК КонечнаяДата,
	ВременнаяТаблица.ВидУслуги КАК ВидУслуги,
	ВременнаяТаблица.ЗначенияПолей КАК ЗначенияПолей,
	ВременнаяТаблица.Организация КАК Организация,
	ВременнаяТаблица.АбонентскийОтдел КАК АбонентскийОтдел,
	ВременнаяТаблица.Услуга КАК Услуга
ИЗ
	ВременнаяТаблица КАК ВременнаяТаблица
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргВидБлагоустройствАбонента.СрезПоследних(&amp;КонецПериода, ) КАК энргВидБлагоустройствАбонентаСрезПоследних
		ПО ВременнаяТаблица.КлючПомещения = энргВидБлагоустройствАбонентаСрезПоследних.КлючПомещения
			И ВременнаяТаблица.Организация = энргВидБлагоустройствАбонентаСрезПоследних.Организация
			И ВременнаяТаблица.Услуга = энргВидБлагоустройствАбонентаСрезПоследних.Услуга
			И ВременнаяТаблица.ТерриториальныйОрган = энргВидБлагоустройствАбонентаСрезПоследних.Район

УПОРЯДОЧИТЬ ПО
	Адрес</query>
	</dataSet>
	<calculatedField>
		<dataPath>Улица</dataPath>
		<expression> выбор когда Адрес &lt;&gt; "" тогда энргОбщегоНазначения.JSONВКонтактнуюИнформациюПоПолям(Адрес) иначе "" конец</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Улица</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<totalField>
		<dataPath>ПриборУчета</dataPath>
		<expression>Количество(Различные ПриборУчета)</expression>
	</totalField>
	<parameter>
		<name>КонецПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Конец периода</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
		<expression>КОНЕЦПЕРИОДА(&amp;ПериодРасчета.ДатаОкончания, "День")</expression>
	</parameter>
	<parameter>
		<name>ПериодРасчета</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Период расчета</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>v8:StandardPeriod</v8:Type>
		</valueType>
		<value xsi:type="v8:StandardPeriod">
			<v8:variant xsi:type="v8:StandardPeriodVariant">Custom</v8:variant>
			<v8:startDate>0001-01-01T00:00:00</v8:startDate>
			<v8:endDate>0001-01-01T00:00:00</v8:endDate>
		</value>
		<useRestriction>false</useRestriction>
	</parameter>
	<parameter>
		<name>Период</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Период</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
	</parameter>
	<parameter>
		<name>НачалоПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
