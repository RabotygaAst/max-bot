			<field>КлючПомещения</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТочкаУчета</dataPath>
			<field>ТочкаУчета</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПриборУчета</dataPath>
			<field>ПриборУчета</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УдалитьАбонент</dataPath>
			<field>УдалитьАбонент</field>
		</field>
		<field xsi:type="DataSetFieldField">
