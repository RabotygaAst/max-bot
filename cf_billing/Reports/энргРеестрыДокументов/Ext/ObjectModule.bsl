#Область ОбработчикиСобытий

Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	СтандартнаяОбработка 		= Ложь;
	
	
	СхемаКомпоновкиДанных 		= ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	
	пВарианты = СхемаКомпоновкиДанных.ВариантыНастроек;
	
	СтруктураВариантов = Новый Структура;
	Для Каждого пЭл ИЗ пВарианты Цикл
		СтруктураВариантов.Вставить(пЭл.Имя,пЭл.Настройки);
	КонецЦикла;
	
	//Если ЗакрытиеЛС Тогда
	//	пНастройки = СтруктураВариантов.ЗакрытиеЛС;
	//ИначеЕсли АктВводаПУ Тогда
	//	пНастройки = СтруктураВариантов.АктУстановкиПУ;
	//ИначеЕсли АктВыводаПУ Тогда
	//	пНастройки = СтруктураВариантов.АктСнятияПУ;
	//КонецЕсли;
	Если ВидДокумента = Перечисления.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС Тогда
		пНастройки = СтруктураВариантов.ОткрытиеЛС;
	ИначеЕсли ВидДокумента = Перечисления.энргВидыОпераций.энргОперацияСЛС_ЗакрытиеЛС Тогда 
		пНастройки = СтруктураВариантов.ЗакрытиеЛС;
	ИначеЕсли ВидДокумента = Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВводПУ Тогда 
		пНастройки = СтруктураВариантов.АктСнятияПУ;
	ИначеЕсли ВидДокумента = Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ВыводПУ Тогда 
		пНастройки = СтруктураВариантов.АктУстановкиПУ;
	ИначеЕсли ВидДокумента = Перечисления.энргВидыОпераций.энргОперацияСПриборомУчета_ЗаменаПУ Тогда 
		пНастройки = СтруктураВариантов.АктЗаменаПУ;
	ИначеЕсли ВидДокумента = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ПодключениеУслуги Тогда 
		пНастройки = СтруктураВариантов.ПодключениеУслуг;
	ИначеЕсли ВидДокумента = Перечисления.энргВидыОпераций.энргОперацияСУслугами_ОтключениеУслуги Тогда 
		пНастройки = СтруктураВариантов.ОтключениеУслуг;
	ИначеЕсли ВидДокумента = "Приходный кассовый ордер" Тогда 
		пНастройки = СтруктураВариантов.ПКО;
	КонецЕсли;
	
	КомпоновщикНастроек.ЗагрузитьНастройки(пНастройки);
	Настройки					= КомпоновщикНастроек.Настройки;
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ДатаНач",	 ДатаНач);
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ДатаКон",	 КонецДня(ДатаКон));
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ВидОперации", ВидДокумента);
	//Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ЗакрытиеЛС", 	ЗакрытиеЛС);
	//Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("АктВводаПУ", 	АктВводаПУ);
	//Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("АктВыводаПУ", 	АктВыводаПУ);
	
	ДанныеРасшифровки 			= Новый ДанныеРасшифровкиКомпоновкиДанных;
	
	КомпоновщикМакета 			= Новый КомпоновщикМакетаКомпоновкиДанных;
	
	МакетКомпоновки 			= КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки);
	
	ПроцессорКомпоновкиДанных 	= Новый ПроцессорКомпоновкиДанных;

	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ,ДанныеРасшифровки);
	
	ДокументРезультат.Очистить();
	
	ПроцессорВывода 			= Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
КонецПроцедуры

#КонецОбласти

