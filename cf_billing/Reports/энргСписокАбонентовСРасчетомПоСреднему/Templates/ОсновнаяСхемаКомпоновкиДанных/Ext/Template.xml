		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	энргОбъемНачислений.Абонент КАК Абонент,
	СУММА(энргОбъемНачислений.ОбъемУслуги) КАК Расход,
	энргОбъемНачислений.ЗначениеТарифа КАК Цена,
	СУММА(энргОбъемНачислений.Сумма) КАК Стоимость,
	энргОбъемНачислений.Услуга КАК Услуга,
	энргОбъемНачислений.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	энргОбъемНачислений.СпособНачисления КАК СпособНачисления,
	энргОбъемНачислений.Район КАК ТерриториальныйОрган,
	энргОбъемНачислений.Организация КАК Организация,
	энргОбъемНачислений.Строение КАК Строение,
	энргОбъемНачислений.Помещение КАК Помещение,
	энргФилиалыАбонентовСрезПоследних.Филиал КАК АбонентскийОтдел,
	энргОбъемНачислений.Абонент.ЛицевойСчет КАК ЛицевойСчет
ИЗ
	РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргФилиалыАбонентов.СрезПоследних(&amp;КонецПериода, ) КАК энргФилиалыАбонентовСрезПоследних
		ПО энргОбъемНачислений.Абонент = энргФилиалыАбонентовСрезПоследних.Абонент
ГДЕ
	энргОбъемНачислений.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
	И ВЫБОР
			КОГДА энргОбъемНачислений.ОбъемУслуги = 0
					И энргОбъемНачислений.Сумма = 0
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И энргОбъемНачислений.ВидНачисления &lt;&gt; ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Перерасчет)

СГРУППИРОВАТЬ ПО
	энргОбъемНачислений.Абонент,
	энргОбъемНачислений.ЗначениеТарифа,
	энргОбъемНачислений.Услуга,
	энргОбъемНачислений.НаправлениеИспользованияТУ,
	энргОбъемНачислений.СпособНачисления,
	энргОбъемНачислений.Район,
	энргОбъемНачислений.Организация,
	энргОбъемНачислений.Строение,
	энргОбъемНачислений.Помещение,
	энргФилиалыАбонентовСрезПоследних.Филиал</query>
