	Если СтруктураДолга = Неопределено Тогда
		СтруктураДолга = Новый Структура;
	КонецЕсли;
	ТекДата = ТекущаяДатаСеанса();
	Запрос.УстановитьПараметр("ТекДата", ТекДата);
	Запрос.УстановитьПараметр("Задача", Задача);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	КолПакет		 = РезультатЗапроса.Количество();
	Макет			 = ПолучитьМакет("МакетЗаявлениеОВынесенииСудебногоПриказа");
	
	ОбластьШапка	 		= Макет.ПолучитьОбласть("Шапка");
	ОбластьСередина	 		= Макет.ПолучитьОбласть("Середина");
	ОбластьПриложениеШапка	= Макет.ПолучитьОбласть("ПриложениеШапка");
	ОбластьПриложениеСтрока	= Макет.ПолучитьОбласть("ПриложениеСтрока");
	ОбластьПодвал			= Макет.ПолучитьОбласть("Подвал");
	
	Выборка				= РезультатЗапроса[КолПакет-2].Выбрать();
	ВыборкаПредписания	= РезультатЗапроса[КолПакет-1].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ОбластьПринадлежностьДоля = Макет.ПолучитьОбласть("ПринадлежностьДоля");
		
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
		ТабДок.АвтоМасштаб = Истина;
		
		ВыводШапкиФилиала(ТабДок, Выборка.Район, ОбластьШапка);
		
		ОбластьШапка.Параметры.Заполнить(Выборка);
		
		ПараметрыШапки = Новый Структура;

		АдресОрганизации = "";
		Префикс			 = "";
		АбонентФИО		 = "";
		АбонентФИОКраткое = "";
		АдресАбонента	 = "";
		АбонентПаспортныеДанные = "";
		ДоляАбонента = "";
		Предписания = "";
		НачалоЗадолженности = "";
		КонецЗадолженности = "";
		ОбщаяСуммаПрописью = "";
		СуммаЗадолженностиПрописью = "";
		СуммаПениПрописью = "";
		ТипСобственника = "";
		ДатаДоговораСоцНайма = "";
		СуммаОсновногоДолга = Неопределено;
		Пеня = Неопределено;
		
		Если ЗначениеЗаполнено(Выборка.ДатаДоговораСоцНайма) Тогда
			ДатаДоговораСоцНайма = Формат(Выборка.ДатаДоговораСоцНайма, "ДФ=dd.MM.yyyy");
		КонецЕсли;
		ПараметрыШапки.Вставить("ДатаДоговораСоцНайма", ДатаДоговораСоцНайма);
		
		// Тип собственности
		Если ЗначениеЗаполнено(Выборка.ТипСобственности) Тогда
			Если Выборка.ТипСобственности = Перечисления.энргТипыСобственниковЖилья.МуниципальнаяСобственность
					Или Выборка.ТипСобственности = Перечисления.энргТипыСобственниковЖилья.ФедеральнаяСобственность Тогда
				ТипСобственника = "нанимателя жилого помещения";
				ОбластьПринадлежностьДоля = Макет.ПолучитьОбласть("ПринадлежностьДоговорСоцНайма");
			ИначеЕсли ЗначениеЗаполнено(Выборка.ДоляСобственностиЗнаменатель) И 
					Выборка.ДоляСобственностиЗнаменатель <> Выборка.ДоляСобственностиЗнаменатель Тогда 
				ТипСобственника = "собственника доли жилого помещения (квартиры)";
			Иначе
				ТипСобственника = "собственника жилого помещения";
			КонецЕсли;
		КонецЕсли;
		ПараметрыШапки.Вставить("ТипСобственника", ТипСобственника);
		
		// Данные организации
		Если ЗначениеЗаполнено(Выборка.АдресОрганизация) Тогда
			АдресОрганизации = "Адрес: " + Выборка.АдресОрганизация;
			Префикс			 = "; ";
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ТелефонОрганизация) Тогда
			АдресОрганизации = АдресОрганизации + Префикс + "Тел.: " + Выборка.ТелефонОрганизация;
			Префикс			 = "; ";
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ФаксОрганизация) Тогда
			АдресОрганизации = АдресОрганизации + Префикс + "Факс: " + Выборка.ФаксОрганизация;
			Префикс			 = "; ";
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.АдресЭлектроннойПочтыОрганизация) Тогда
			АдресОрганизации = АдресОрганизации + Префикс + "Email: " + Выборка.АдресЭлектроннойПочтыОрганизация;
		КонецЕсли;
		ПараметрыШапки.Вставить("АдресОрганизации", АдресОрганизации);
		
		// ФИО абонента
		Если ЗначениеЗаполнено(Выборка.Фамилия) Тогда
			АбонентФИО = Выборка.Фамилия + ?(ЗначениеЗаполнено(Выборка.Имя), " " + Выборка.Имя, "") 
							+ ?(ЗначениеЗаполнено(Выборка.Отчество), " " + Выборка.Отчество, "");
			АбонентФИОКраткое = Выборка.Фамилия + ?(ЗначениеЗаполнено(Выборка.Имя), " " + Лев(Выборка.Имя, 1) + ".", "") 
							+ ?(ЗначениеЗаполнено(Выборка.Отчество), " " + Лев(Выборка.Отчество, 1) + ".", "");
		Иначе
			АбонентФИО = Строка(Выборка.ФизЛицо);
			АбонентФИОКраткое = Строка(Выборка.ФизЛицо);
		КонецЕсли;
		ПараметрыШапки.Вставить("АбонентФИО", АбонентФИО);
		ПараметрыШапки.Вставить("АбонентФИОКраткое", АбонентФИОКраткое);

		// Данные абонента
		АдресАбонента = "";
		Префикс		  = "";
		Если ЗначениеЗаполнено(Выборка.ЮрАдресАбонента) Тогда
			АдресАбонента = "Адрес: " + Выборка.АдресОрганизация;
			Префикс		  = "; ";
		ИначеЕсли ЗначениеЗаполнено(Выборка.ФактАдресАбонента) Тогда
			АдресАбонента = "Адрес: " + Выборка.ФактАдресАбонента;
			Префикс		  = "; ";
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ТелефонАбонента) Тогда
			АдресАбонента = АдресАбонента + Префикс + "Тел.: " + Выборка.ТелефонАбонента;
			Префикс		  = "; ";
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ФаксАбонента) Тогда
			АдресАбонента = АдресАбонента + Префикс + "Факс: " + Выборка.ФаксАбонента;
			Префикс			 = "; ";
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ЭлАдресАбонента) Тогда
			АдресАбонента = АдресАбонента + Префикс + "Email: " + Выборка.ЭлАдресАбонента;
		КонецЕсли;
		ПараметрыШапки.Вставить("АдресАбонента", АдресАбонента);
		
		// Паспортные данные абонента
		АбонентПаспортныеДанные = АбонентФИОКраткое;
		Если ЗначениеЗаполнено(Выборка.ДатаРождения) Тогда
			АбонентПаспортныеДанные = АбонентПаспортныеДанные + ", " + Выборка.ДатаРождения +
				?(ЗначениеЗаполнено(Выборка.МестоРождения), " в " + Выборка.МестоРождения, "");
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.Паспорт) Тогда	
			АбонентПаспортныеДанные = АбонентПаспортныеДанные + ", паспорт " + Выборка.Паспорт;
		ИначеЕсли ЗначениеЗаполнено(Выборка.ИНН) Тогда	
			АбонентПаспортныеДанные = АбонентПаспортныеДанные + ", ИНН №" + Выборка.ИНН;
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.СНИЛС) Тогда	
			АбонентПаспортныеДанные = АбонентПаспортныеДанные + ", СНИЛС " + Выборка.СНИЛС;
		КонецЕсли;
		ПараметрыШапки.Вставить("АбонентПаспортныеДанные", АбонентПаспортныеДанные);
		
		// Вид и доля собственности
		Префикс = "";
		Если ЗначениеЗаполнено(Выборка.ВидОбъекта) Тогда
			Если ЗначениеЗаполнено(Выборка.ДоляСобственностиЗнаменатель) И Выборка.ДоляСобственностиЧислитель <> Выборка.ДоляСобственностиЗнаменатель Тогда
				ДоляАбонента = НРег((Выборка.ВидОбъекта)) + ?(ЗначениеЗаполнено(Выборка.ДоляСобственностиЗнаменатель),
						" в доле " + Выборка.ДоляСобственностиЧислитель + "/" + Выборка.ДоляСобственностиЗнаменатель, "");
			Иначе
				ДоляАбонента = Выборка.ВидОбъекта;
			КонецЕсли;
		КонецЕсли;
		ПараметрыШапки.Вставить("ДоляАбонента", ДоляАбонента);
		
		// Номера предписаний, высланных абоненту
		ВыборкаПредписания.Сбросить();
		Отбор = Новый Структура("ТекЗадача", Выборка.Задача);
		Префикс = "";
		Пока ВыборкаПредписания.НайтиСледующий(Отбор) Цикл
			Предписания = Предписания + Префикс + "№ " + ВыборкаПредписания.Номер + " от " + Формат(Выборка.Дата, "ДФ=dd.MM.yyyy");
		    Префикс = "; ";
		КонецЦикла;
		ПараметрыШапки.Вставить("Предписания", Предписания);
		
		// Период и сумма задолженности
		Если ЗначениеЗаполнено(Выборка.ПериодЗадолженностиНачало) Тогда
			НачалоЗадолженности = Формат(Выборка.ПериодЗадолженностиНачало, "ДФ='ММММ гггг'");
		КонецЕсли;
		ПараметрыШапки.Вставить("НачалоЗадолженности", НРег(НачалоЗадолженности));

		Если ЗначениеЗаполнено(Выборка.ПериодЗадолженностиКонец) Тогда
			КонецЗадолженности = Формат(Выборка.ПериодЗадолженностиКонец, "ДФ='ММММ гггг'");
		КонецЕсли;
		ПараметрыШапки.Вставить("КонецЗадолженности", НРег(КонецЗадолженности));
		
		ФормСтрока  = "Л = ru_RU; ДП = Истина";
		ПарПредмета ="рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2";
		СтруктураДолга.Свойство("СуммаОсновногоДолга", СуммаОсновногоДолга);
		СтруктураДолга.Свойство("Пеня", Пеня);

		Если ЗначениеЗаполнено(СуммаОсновногоДолга) Тогда
			СуммаЗадолженностиПрописью = Строка(СуммаОсновногоДолга) + "руб. (" + ЧислоПрописью(СуммаОсновногоДолга, ФормСтрока, ПарПредмета) + ")";
		Иначе
			СуммаЗадолженностиПрописью = "0 руб. (ноль рублей)";
			СуммаОсновногоДолга = 0;
		КонецЕсли;
		ПараметрыШапки.Вставить("СуммаЗадолженностиПрописью", НРег(СуммаЗадолженностиПрописью));
		
		Если ЗначениеЗаполнено(Пеня) Тогда
			СуммаПениПрописью = Строка(Пеня) + "руб. (" + ЧислоПрописью(Пеня, ФормСтрока, ПарПредмета) + ")";
		Иначе
			СуммаПениПрописью = "0 руб. (ноль рублей)";
			Пеня = 0;
		КонецЕсли;
		ПараметрыШапки.Вставить("СуммаПениПрописью", НРег(СуммаПениПрописью));
		
		Если ЗначениеЗаполнено(СуммаОсновногоДолга) Тогда
			ОбщаяСуммаПрописью = Строка(СуммаОсновногоДолга + Пеня) + "руб. (" + ЧислоПрописью(СуммаОсновногоДолга + Пеня, ФормСтрока, ПарПредмета) + ")";
		Иначе
			ОбщаяСуммаПрописью = "0 руб. (ноль рублей)";
		КонецЕсли;
		ПараметрыШапки.Вставить("ОбщаяСуммаПрописью", НРег(ОбщаяСуммаПрописью));
		
		ОбластьШапка.Параметры.Заполнить(Выборка);
		ОбластьШапка.Параметры.Заполнить(ПараметрыШапки);
		
		ОбластьСередина.Параметры.Заполнить(Выборка);
		ОбластьСередина.Параметры.Заполнить(ПараметрыШапки);
		
		ОбластьПринадлежностьДоля.Параметры.Заполнить(Выборка);
		ОбластьПринадлежностьДоля.Параметры.Заполнить(ПараметрыШапки);
		
		ТабДок.Вывести(ОбластьШапка);
		ТабДок.Вывести(ОбластьПринадлежностьДоля);
		ТабДок.Вывести(ОбластьСередина);
		
		// Вывод приложения
		Если ЗначениеЗаполнено(СписокПрикреплённыхДокументов) Тогда 
			Сч = 1;
			ТабДок.Вывести(ОбластьПриложениеШапка);
			
			Для каждого СтрокаПриложения Из СписокПрикреплённыхДокументов Цикл
				Приложение = "" + Сч + ". " + СтрокаПриложения;
				ОбластьПриложениеСтрока.Параметры.Приложение = Приложение;
				ТабДок.Вывести(ОбластьПриложениеСтрока);
			    Сч = Сч + 1;
			КонецЦикла;
		КонецЕсли;
		
		// Вывод подвала
		ОбластьПодвал.Параметры.ДатаЗаявления = ТекДата;
		ОбластьПодвал.Параметры.Пользователь  = ПараметрыСеанса.ТекущийПользователь;
		ТабДок.Вывести(ОбластьПодвал);
	КонецЦикла;
	
	Возврат ТабДок;
КонецФункции

Функция ПечатьЗаявленияОВыдачеСудебногоПриказаОВзыскании(Задача, СписокПрикреплённыхДокументов = Неопределено, ОтветНаПритензию = "", СтруктураДолга = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗадачаПИД.Ссылка КАК Задача,
		|	энргЗадачаПИД.Абонент КАК Абонент,
		|	энргЗадачаПИДСудебныеИнстанции.СудебнаяИинстанция КАК Суд,
		|	Организации.Ссылка КАК Организация,
		|	Организации.НаименованиеПолное КАК НаименованиеПолноеОрганизация,
		|	энргАбоненты.ФизЛицо КАК ФизЛицо,
		|	энргЗадачаПИД.СуммаЗадолженности КАК СуммаЗадолженности,
		|	энргЗадачаПИД.ПериодЗадолженностиНачало КАК ПериодЗадолженностиНачало,
		|	энргЗадачаПИД.ПериодЗадолженностиКонец КАК ПериодЗадолженностиКонец,
		|	энргЗадачаПИД.Дата КАК Дата,
		|	энргЗадачаПИД.СтартоваяЗадача КАК СтартоваяЗадача,
		|	энргАбоненты.ВидОбъекта КАК ВидОбъекта,
		|	энргАбоненты.КлючПомещения КАК КлючПомещения,
		|	энргАбонентыКонтактнаяИнформация.Представление КАК АдресОбъекта,
		|	энргЗадачаПИД.Район КАК Район,
		|	энргЗадачаПИД.СуммаГоспошлина КАК СуммаГоспошлина,
		|	энргКлючиПомещений.Помещение КАК Помещение,
		|	энргОперацияСЛицевымСчетом.Договор.Дата КАК ДатаДоговораОбслуживания,
		|	энргОперацияСЛицевымСчетом.Договор.Номер КАК НомерДоговораОбслуживания,
		|	энргОперацияСЛицевымСчетомЖильцы.СвидетельствоОРегистрацииНомер КАК СвидетельствоОРегистрацииНомер,
		|	энргОперацияСЛицевымСчетомЖильцы.СвидетельствоОРегистрацииДата КАК СвидетельствоОРегистрацииДата,
		|	энргОперацияСЛицевымСчетомЖильцы.СвидетельствоОРегистрацииСерия КАК СвидетельствоОРегистрацииСерия
		|ПОМЕСТИТЬ ВТ_Задача
		|ИЗ
		|	Задача.энргЗадачаПИД КАК энргЗадачаПИД
		|		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.СудебныеИнстанции КАК энргЗадачаПИДСудебныеИнстанции
		|		ПО энргЗадачаПИД.Ссылка = энргЗадачаПИДСудебныеИнстанции.Ссылка
		|			И (энргЗадачаПИДСудебныеИнстанции.Текущая)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
		|		ПО энргЗадачаПИД.Организация = Организации.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом КАК энргОперацияСЛицевымСчетом
		|		ПО энргЗадачаПИД.Организация = энргОперацияСЛицевымСчетом.Организация
		|			И энргЗадачаПИД.Район = энргОперацияСЛицевымСчетом.Район
		|			И энргЗадачаПИД.Абонент = энргОперацияСЛицевымСчетом.Абонент
		|			И (энргОперацияСЛицевымСчетом.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС))
		|			И (энргОперацияСЛицевымСчетом.Проведен)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
		|			ПО энргАбоненты.Ссылка = энргАбонентыКонтактнаяИнформация.Ссылка
		|				И (энргАбонентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(справочник.ВидыконтактнойИнформации.АдресОбъекта))
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
		|			ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.КлючПомещения
		|		ПО энргЗадачаПИД.Абонент = энргАбоненты.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом.Жильцы КАК энргОперацияСЛицевымСчетомЖильцы
		|		ПО (энргОперацияСЛицевымСчетом.Ссылка = энргОперацияСЛицевымСчетомЖильцы.Ссылка)
		|			И (энргАбоненты.ФизЛицо = энргОперацияСЛицевымСчетомЖильцы.ФизическоеЛицо)
		|ГДЕ
		|	энргЗадачаПИД.Ссылка = &Задача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Задача.Организация КАК Организация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК АдресОрганизация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ТелефонОрганизация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ФаксОрганизация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК АдресЭлектроннойПочтыОрганизация
		|ПОМЕСТИТЬ ВТ_ДанныеОрганизации
		|ИЗ
		|	ВТ_Задача КАК ВТ_Задача
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
		|		ПО ВТ_Задача.Организация = ОрганизацииКонтактнаяИнформация.Ссылка
		|			И (ОрганизацииКонтактнаяИнформация.Вид В (ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонОрганизации), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксОрганизации), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailОрганизации)))
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Задача.Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Задача.ФизЛицо КАК ФизЛицо,
		|	энргКонтрагенты.бестФамилия КАК Фамилия,
		|	энргКонтрагенты.бестИмя КАК Имя,
		|	энргКонтрагенты.бестОтчество КАК Отчество,
		|	энргКонтрагенты.НаименованиеПолное КАК НаименованиеПолное,
		|	энргКонтрагенты.ИНН КАК ИНН,
		|	энргКонтрагенты.бестДатаРождения КАК ДатаРождения,
		|	энргКонтрагенты.МестоРождения КАК МестоРождения
		|ПОМЕСТИТЬ ВТ_ДанныеФизЛица
