	Запрос.УстановитьПараметр("КонГода",		КонецГода(КонПериод));
	Запрос.УстановитьПараметр("НачГод",			НачалоГода(НачПериод));
	
	РезультатЗапроса = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	КолЗапросов		 = РезультатЗапроса.Количество();
	
	// Вывод тарифов услуг
	ВыборкаУслуга = РезультатЗапроса[КолЗапросов-2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаУслуга.Следующий() Цикл
		Выборка = ВыборкаУслуга.Выбрать();
		
		ОбластьУслуга = Макет.ПолучитьОбласть("Услуга");
		ОбластьУслуга.Параметры.Услуга = НРег(ВыборкаУслуга.Услуга);
		ОбластьУслуга.Параметры.ЕдИзм  = ВыборкаУслуга.ЕдИзм;
		Если ЗначениеЗаполнено(ВыборкаУслуга.ОбоснованиеНорма) Тогда
			ОбластьУслуга.Параметры.ОбоснованиеНорма  = "(" + ВыборкаУслуга.ОбоснованиеНорма + ")";
		Иначе
			ОбластьУслуга.Параметры.ОбоснованиеНорма = "";
		КонецЕсли;
		НормаПотребления = 0;
		Пока Выборка.Следующий() Цикл
			НормаПотребления = Выборка.НормаПотребления;
		КонецЦикла;
		ОбластьУслуга.Параметры.НормаПотребления = НормаПотребления;
		ТабДок.Вывести(ОбластьУслуга);
		
		Выборка.Сбросить();
		Сч = 1;
		ТекТариф = Неопределено;
		Пока Выборка.Следующий() Цикл
			//Если ТекТариф = Неопределено Или ТекТариф <> Выборка.ЗначениеТарифа Тогда
				ОбластьСтрокаТариф = Макет.ПолучитьОбласть("СтрокаТариф");
				ОбластьСтрокаТариф.Параметры.Заполнить(Выборка);
				ОбластьСтрокаТариф.Параметры.НомерСтроки = Сч;
				//ОбластьСтрокаТариф.Параметры.ПериодНачисления = НРег(Формат(Выборка.ПериодНачисления, "ДФ='ММММ гггг'")) + " - " + ?(Выборка.ПериодЗавершение = "настоящее время", Выборка.ПериодЗавершение, НРег(Формат(Выборка.ПериодЗавершение, "ДФ='ММММ гггг'")));
				ОбластьСтрокаТариф.Параметры.ПериодНачисления = НРег(Формат(Выборка.ПериодНачисления, "ДФ=dd.MM.yyyy")) + " - " + НРег(Формат(Выборка.ПериодЗавершение, "ДФ=dd.MM.yyyy"));
				
				Если ЗначениеЗаполнено(Выборка.ОбоснованиеТариф) Тогда
					ОбластьСтрокаТариф.Параметры.ОбоснованиеТариф  = "(" + Выборка.ОбоснованиеТариф + ")";
				Иначе
					ОбластьСтрокаТариф.Параметры.ОбоснованиеТариф = "";
				КонецЕсли;
				
				ТабДок.Вывести(ОбластьСтрокаТариф);
				
				ТекТариф = Выборка.ЗначениеТарифа;
				Сч = Сч + 1;
			//КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Вывод сумм
	ВыборкаИтог = РезультатЗапроса[КолЗапросов-1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы");
	ТабДок.Вывести(ОбластьШапкаТаблицы);
	
	Пока ВыборкаИтог.Следующий() Цикл
		Выборка = ВыборкаИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);		
		СоответствиеСумм = Новый Соответствие;
		
		Пока Выборка.Следующий() Цикл
			
			ТекСальдо = СоответствиеСумм.Получить(Выборка.Услуга);
			Если ТекСальдо = Неопределено Тогда
				ТекСальдо = 0;
				СоответствиеСумм.Вставить(Выборка.Услуга, 0);
			КонецЕсли;
			
			ОбластьСтрокаТаблицы = Макет.ПолучитьОбласть("СтрокаТаблицы");
			ОбластьСтрокаТаблицы.Параметры.Заполнить(Выборка);
			
			//ОбластьСтрокаТаблицы.Параметры.ВхСальдо = ВхСальдо;
			//ВхСальдо = ВхСальдо + ОбластьСтрокаТаблицы.Параметры.ИтогоНачислено - ОбластьСтрокаТаблицы.Параметры.Оплачено;
			//ОбластьСтрокаТаблицы.Параметры.ИсхСальдо = ВхСальдо;
			
			ОбластьСтрокаТаблицы.Параметры.ВхСальдо = ТекСальдо;
			ТекСальдо = ТекСальдо + ОбластьСтрокаТаблицы.Параметры.ИтогоНачислено - ОбластьСтрокаТаблицы.Параметры.Оплачено;
			//ВхСальдо = ВхСальдо + ТекСальдо;
			ОбластьСтрокаТаблицы.Параметры.ИсхСальдо = ТекСальдо;
			
			ВидЗадолженности = "";
			
			//ВидЗадолженности = ?(Выборка.Основ, "текущ", "");
			//ВидЗадолженности = ?(Выборка.Мораторная, ВидЗадолженности + ?(ВидЗадолженности = "", "", ", ") + "мораторн", ВидЗадолженности);
			//ВидЗадолженности = ?(Выборка.Реструкт, ВидЗадолженности + ?(ВидЗадолженности = "", "", ", ") + "реструктур", ВидЗадолженности);
			
			Если Выборка.Мораторная И Выборка.Реструкт Тогда
				ВидЗадолженности = "мораторн, реструктур";
			ИначеЕсли Выборка.Мораторная Тогда
				ВидЗадолженности = "мораторн";
			ИначеЕсли Выборка.Реструкт Тогда
				ВидЗадолженности = "реструктур";
			Иначе
				ВидЗадолженности = ?(ВыборкаИтог.Мораторная, "текущ", "просроч");
			КонецЕсли;
			ОбластьСтрокаТаблицы.Параметры.ВидЗадолженности = ВидЗадолженности;
			
			ТабДок.Вывести(ОбластьСтрокаТаблицы);
			
			СоответствиеСумм.Вставить(Выборка.Услуга, ТекСальдо);
			
		КонецЦикла;
		
		ВхСальдо = 0;
		Для каждого Строка Из СоответствиеСумм Цикл
			ВхСальдо = ВхСальдо + Строка.Значение;
		КонецЦикла;
		
		ОбластьИтогТаблицы = Макет.ПолучитьОбласть("ИтогоТаблицы");
		ОбластьИтогТаблицы.Параметры.Заполнить(ВыборкаИтог);
		ОбластьИтогТаблицы.Параметры.ИсхСальдо = ВхСальдо;
		ТабДок.Вывести(ОбластьИтогТаблицы);
	КонецЦикла;
	
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	ТабДок.Вывести(ОбластьПодвал);
	
	Возврат ТабДок;
КонецФункции

#Конецобласти

Функция ЕстьСобытияПоЗадаче(Задача) Экспорт

	Если Не ЗначениеЗаполнено(Задача) Тогда
		Возврат Ложь;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	энргСобытия.ТипСобытия КАК СпособСвязи,
		|	энргСобытия.Период КАК ДатаОтправки,
		|	ВЫБОР
		|		КОГДА энргСобытия.Успех
		|			ТОГДА ""Отправлено""
		|		ИНАЧЕ энргСобытия.Результат
		|	КОНЕЦ КАК Комментарий,
		|	энргСобытия.Регистратор КАК Регистратор,
		|	энргСобытия.Период КАК ДатаПолучения
		|ИЗ
		|	РегистрСведений.энргСобытия КАК энргСобытия
		|ГДЕ
		|	энргСобытия.Основание = &Задача";
	
	Запрос.УстановитьПараметр("Задача", Задача);
	
	Возврат Не Запрос.Выполнить().Пустой();
КонецФункции

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	Если ВидФормы = "ФормаОбъекта" Тогда
		Если Параметры.Свойство("Ключ") И Параметры.Ключ.ЗадачаЮЛ Тогда
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма 		 = "ФормаЗадачиЮЛ";
		ИначеЕсли Параметры.Свойство("Ключ") И Параметры.Ключ.ЗадачаНапоминание Тогда
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма 		 = "ФормаНапоминания";
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ОбъединитьЗадачиНаСервере(СписокЗадач, Задача) Экспорт

	Если Ложь Тогда
		СписокЗадач = Новый СписокЗначений;
		Задача	 	= Задачи.энргЗадачаПИД.НайтиПоНаименованию("");
	КонецЕсли;
	
	НачатьТранзакцию();
	ОбъектЗадача = Задача.ПолучитьОбъект();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗадачаПИДПланПогашенияЗадолженности.Дата КАК Дата,
		|	СУММА(энргЗадачаПИДПланПогашенияЗадолженности.Сумма) КАК Сумма
		|ИЗ
		|	Задача.энргЗадачаПИД.ПланПогашенияЗадолженности КАК энргЗадачаПИДПланПогашенияЗадолженности
		|ГДЕ
		|	энргЗадачаПИДПланПогашенияЗадолженности.Ссылка В(&СписокЗадач)
		|
		|СГРУППИРОВАТЬ ПО
		|	энргЗадачаПИДПланПогашенияЗадолженности.Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗадачаПИДНачисления.Регистратор КАК Регистратор,
		|	СУММА(энргЗадачаПИДНачисления.ПросроченнаяЗадолженность) КАК ПросроченнаяЗадолженность,
		|	энргЗадачаПИДНачисления.ДатаНачисления КАК ДатаНачисления
		|ИЗ
		|	Задача.энргЗадачаПИД.Начисления КАК энргЗадачаПИДНачисления
		|ГДЕ
		|	энргЗадачаПИДНачисления.Ссылка В(&СписокЗадач)
		|
		|СГРУППИРОВАТЬ ПО
		|	энргЗадачаПИДНачисления.Регистратор,
		|	энргЗадачаПИДНачисления.ДатаНачисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗадачаПИДСудебныеИнстанции.СудебнаяИинстанция КАК СудебнаяИинстанция,
		|	ЛОЖЬ КАК Текущая,
		|	энргЗадачаПИДСудебныеИнстанции.Событие КАК Событие,
		|	энргЗадачаПИДСудебныеИнстанции.Судья КАК Судья,
		|	энргЗадачаПИДСудебныеИнстанции.Статус КАК Статус,
		|	энргЗадачаПИДСудебныеИнстанции.Срок КАК Срок,
		|	энргЗадачаПИДСудебныеИнстанции.Номер КАК Номер,
		|	энргЗадачаПИДСудебныеИнстанции.Дата КАК Дата,
		|	энргЗадачаПИДСудебныеИнстанции.СтатусИнстанции КАК СтатусИнстанции,
		|	энргЗадачаПИДСудебныеИнстанции.ОсновнойДолг КАК ОсновнойДолг,
		|	энргЗадачаПИДСудебныеИнстанции.Пени КАК Пени,
		|	энргЗадачаПИДСудебныеИнстанции.Госпошлина КАК Госпошлина,
		|	энргЗадачаПИДСудебныеИнстанции.СтатусУтверждения КАК СтатусУтверждения,
		|	энргЗадачаПИДСудебныеИнстанции.Суд КАК Суд,
		|	энргЗадачаПИДСудебныеИнстанции.СудебыйУчасток КАК СудебыйУчасток,
		|	энргЗадачаПИДСудебныеИнстанции.Прочие КАК Прочие
		|ИЗ
		|	Задача.энргЗадачаПИД.СудебныеИнстанции КАК энргЗадачаПИДСудебныеИнстанции
		|ГДЕ
		|	энргЗадачаПИДСудебныеИнстанции.Ссылка В(&СписокЗадач)
		|	И энргЗадачаПИДСудебныеИнстанции.Ссылка <> &Задача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗадачаПИДПодэтапы.IDЭтапа КАК IDЭтапа,
		|	энргЗадачаПИДФайлыПодэтапов.Файл КАК Файл
		|ИЗ
		|	Задача.энргЗадачаПИД.Подэтапы КАК энргЗадачаПИДПодэтапы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.Подэтапы КАК энргЗадачаПИДПодэтапы_Отменяемые
		|			ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.ФайлыПодэтапов КАК энргЗадачаПИДФайлыПодэтапов
		|			ПО энргЗадачаПИДПодэтапы_Отменяемые.Ссылка = энргЗадачаПИДФайлыПодэтапов.Ссылка
		|				И энргЗадачаПИДПодэтапы_Отменяемые.IDЭтапа = энргЗадачаПИДФайлыПодэтапов.IDЭтапа
		|		ПО энргЗадачаПИДПодэтапы.Ссылка <> энргЗадачаПИДПодэтапы_Отменяемые.Ссылка
		|			И энргЗадачаПИДПодэтапы.Подэтап = энргЗадачаПИДПодэтапы_Отменяемые.Подэтап
		|ГДЕ
		|	энргЗадачаПИДПодэтапы.Ссылка = &Задача
		|	И энргЗадачаПИДФайлыПодэтапов.Ссылка В(&СписокЗадач)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗадачаПИДЗадолженность.ПериодНачисления КАК ПериодНачисления,
		|	энргЗадачаПИДЗадолженность.Услуга КАК Услуга,
		|	МАКСИМУМ(энргЗадачаПИДЗадолженность.Задолженность) КАК Задолженность
		|ИЗ
		|	Задача.энргЗадачаПИД.Задолженность КАК энргЗадачаПИДЗадолженность
		|ГДЕ
		|	энргЗадачаПИДЗадолженность.Ссылка В(&СписокЗадач)
		|
		|СГРУППИРОВАТЬ ПО
		|	энргЗадачаПИДЗадолженность.ПериодНачисления,
		|	энргЗадачаПИДЗадолженность.Услуга
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗадачаПИДИсполнительныеДокументы.НомерСтроки КАК НомерСтроки,
		|	энргЗадачаПИДИсполнительныеДокументы.ИсполнительныйДокумент КАК ИсполнительныйДокумент,
		|	энргЗадачаПИДИсполнительныеДокументы.Номер КАК Номер,
		|	энргЗадачаПИДИсполнительныеДокументы.Дата КАК Дата,
		|	энргЗадачаПИДИсполнительныеДокументы.Предъявлен КАК Предъявлен,
		|	энргЗадачаПИДИсполнительныеДокументы.Ответственность КАК Ответственность,
		|	энргЗадачаПИДИсполнительныеДокументы.Долг КАК Долг,
		|	энргЗадачаПИДИсполнительныеДокументы.Пеня КАК Пеня,
		|	энргЗадачаПИДИсполнительныеДокументы.Госпошлина КАК Госпошлина,
		|	энргЗадачаПИДИсполнительныеДокументы.Прочие КАК Прочие
		|ИЗ
		|	Задача.энргЗадачаПИД.ИсполнительныеДокументы КАК энргЗадачаПИДИсполнительныеДокументы
		|ГДЕ
		|	энргЗадачаПИДИсполнительныеДокументы.Ссылка В(&СписокЗадач)
		|	И энргЗадачаПИДИсполнительныеДокументы.Ссылка <> &Задача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	энргЗадачаПИДПрисоединенныеФайлы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.энргЗадачаПИДПрисоединенныеФайлы КАК энргЗадачаПИДПрисоединенныеФайлы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД КАК энргЗадачаПИД
		|		ПО энргЗадачаПИДПрисоединенныеФайлы.ВладелецФайла = энргЗадачаПИД.СтартоваяЗадача
		|ГДЕ
		|	энргЗадачаПИД.Ссылка В(&СписокЗадач)
		|	И энргЗадачаПИД.Ссылка <> &Задача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	энргСобытиеАбоненты.Ссылка КАК Ссылка,
		|	энргСобытиеАбоненты.Основание КАК Основание
		|ИЗ
		|	Документ.энргСобытие.Абоненты КАК энргСобытиеАбоненты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргСобытие КАК энргСобытие
		|		ПО энргСобытиеАбоненты.Ссылка = энргСобытие.Ссылка
		|ГДЕ
		|	энргСобытиеАбоненты.Основание В(&СписокЗадач)
		|	И энргСобытиеАбоненты.Основание <> &Задача
		|	И НЕ энргСобытие.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Задача", Задача);
	Запрос.УстановитьПараметр("СписокЗадач", СписокЗадач);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ОбъектЗадача.ПланПогашенияЗадолженности.Очистить();
	Если Не РезультатЗапроса[0].Пустой() Тогда
		ОбъектЗадача.ПланПогашенияЗадолженности.Загрузить(РезультатЗапроса[0].Выгрузить());
	КонецЕсли;
	
	ОбъектЗадача.Начисления.Очистить();
	Если Не РезультатЗапроса[1].Пустой() Тогда
		ОбъектЗадача.Начисления.Загрузить(РезультатЗапроса[1].Выгрузить());
	КонецЕсли;	
	
	Выборка = РезультатЗапроса[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТЧ = ОбъектЗадача.СудебныеИнстанции.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
	КонецЦикла;
	
	Выборка = РезультатЗапроса[3].Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТЧ = ОбъектЗадача.ФайлыПодэтапов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
	КонецЦикла;
	
	ОбъектЗадача.Задолженность.Очистить();
	Если Не РезультатЗапроса[4].Пустой() Тогда
		ОбъектЗадача.Задолженность.Загрузить(РезультатЗапроса[4].Выгрузить());
	КонецЕсли;
	
	Выборка = РезультатЗапроса[5].Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТЧ = ОбъектЗадача.ИсполнительныеДокументы.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
	КонецЦикла;
	
	Выборка = РезультатЗапроса[6].Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.Ссылка) Тогда
			
			Попытка
			
				ФайлЗадачи = Выборка.Ссылка.ПолучитьОбъект();
				ФайлЗадачи.ВладелецФайла = ОбъектЗадача.СтартоваяЗадача;
				ФайлЗадачи.Записать();
			
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось объединить задачи по причине: " + ОписаниеОшибки());
				ОтменитьТранзакцию();
				Возврат;
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
	Выборка = РезультатЗапроса[7].Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.Ссылка) Тогда
			
			Попытка
			
				СобытиеДок = Выборка.Ссылка.ПолучитьОбъект();
				Если Ложь Тогда
				 	СобытиеДок = Документы.энргСобытие.СоздатьДокумент();
				КонецЕсли;
				СобытиеДок.ДополнительныеСвойства.Вставить("Основание", 	  Выборка.Основание);
				СобытиеДок.ДополнительныеСвойства.Вставить("ОснованиеЗамена", ОбъектЗадача.Ссылка);
				СобытиеДок.Записать();
			
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось объединить задачи по причине: " + ОписаниеОшибки());
				ОтменитьТранзакцию();
				Возврат;
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ТекЭлемент Из СписокЗадач Цикл
	
		Если ТекЭлемент.Значение <> Задача Тогда
			
			Попытка
				
				ОбъектУстарЗадача = ТекЭлемент.Значение.ПолучитьОбъект();
				ОбъектУстарЗадача.УстановитьПометкуУдаления(Истина);
				
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось объединить задачи по причине: " + ОписаниеОшибки());
				ОтменитьТранзакцию();
				Возврат;
			КонецПопытки;
		КонецЕсли;
		
	КонецЦикла;
	
	Попытка
	
		ОбъектЗадача.Записать();
	
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось объединить задачи по причине: " + ОписаниеОшибки());
		ОтменитьТранзакцию();
		Возврат;
	КонецПопытки;
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

Функция ЭтапПИР_СоответствуетТребованиям(ЗадачаОбъект, Этап) Экспорт
	Перем Строение, Помещение;
	ЗаполнитьПомещениеИСтроениеПоАбоненту(ЗадачаОбъект.Абонент, Строение, Помещение);
	
	НарушеныУсловия = Новый Массив;
	
	РС = РегистрыСведений.энргНастройкаУсловийДляПереходаНаЭтап;
	Если Ложь Тогда
	
		ЗадачаОбъект = Задачи.энргЗадачаПИД.СоздатьЗадачу();
	
	КонецЕсли;
	
	АбонентВИП = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗадачаОбъект.Абонент, "VIPабонент", Истина);
	Если ЗначениеЗаполнено(ЗадачаОбъект.Задолженность) И РС.ЕстьУсловияПоЭтапу(Этап, ЗадачаОбъект.Организация, ЗадачаОбъект.Район, АбонентВИП) Тогда
		Запрос = Новый Запрос;
		
		ТекстЗапросаДолгиНач = 
			"ВЫБРАТЬ
			|	&Услуга_1 КАК Услуга,
			|	&ПериодНачисления_1 КАК ПериодНачисления";
		
		
		ИмяВТ = Символы.ПС + "ПОМЕСТИТЬ ВТ_Долги ";
		Сч = 1;
		
		ДатаОкон = Неопределено;
		Для каждого СрокаТЧ Из ЗадачаОбъект.Задолженность Цикл
			ПарамУслуга = "Услуга_" + Формат(Сч, "ЧГ=0");
			ПарамПериод = "ПериодНачисления_" + Формат(Сч, "ЧГ=0");
			
			Если Сч = 1 Тогда
				ТекстЗапроса 	 = ТекстЗапросаДолгиНач + ИмяВТ;
				ДатаОкон		 = СрокаТЧ.ПериодНачисления;
			Иначе
				ТекстОбъединения = Символы.ПС + " ОБЪЕДИНИТЬ ВСЕ " + Символы.ПС + ТекстЗапросаДолгиНач + Символы.ПС;
				ТекстОбъединения = СтрЗаменить(ТекстОбъединения, "Услуга_1 КАК Услуга", ПарамУслуга);
				ТекстОбъединения = СтрЗаменить(ТекстОбъединения, "ПериодНачисления_1 КАК ПериодНачисления", ПарамПериод);
				
				ТекстЗапроса	 = ТекстЗапроса + ТекстОбъединения;
				ДатаОкон		 = Макс(ДатаОкон, СрокаТЧ.ПериодНачисления);
			КонецЕсли;
			
			Запрос.УстановитьПараметр(ПарамУслуга, СрокаТЧ.Услуга);
			Запрос.УстановитьПараметр(ПарамПериод, СрокаТЧ.ПериодНачисления);
			Сч = Сч + 1;
		КонецЦикла;
		
		Запрос.Текст = ТекстЗапроса + ОкончаниеТесктаЗаросаПроверкаЭтапаПИР();
		
		Запрос.УстановитьПараметр("Абонент", ЗадачаОбъект.Абонент);
		Запрос.УстановитьПараметр("ДатаОкон", ДатаОкон);
		Запрос.УстановитьПараметр("ИспользуютсяТарифныеЗоны", ПолучитьФункциональнуюОпцию("энргИспользоватьТарифныеЗоны"));
		Запрос.УстановитьПараметр("Организация", ЗадачаОбъект.Организация);
		Запрос.УстановитьПараметр("Помещение", Помещение);
		Запрос.УстановитьПараметр("Район", ЗадачаОбъект.Район);
		Запрос.УстановитьПараметр("Строение", Строение);
		Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
		Запрос.УстановитьПараметр("АбонентВИП", АбонентВИП);
		Запрос.УстановитьПараметр("Этап", Этап);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл 
			Если Выборка.СверхСрокиЗадолженности < 0 Тогда
				НарушеныУсловия.Добавить("Недостаточное количество периодов для перехода на этап " + Этап);
			КонецЕсли;
			Если Выборка.СверхСуммаЗадолженности < 0 Тогда
				НарушеныУсловия.Добавить("Недостаточная сумма долга для перехода на этап " + Этап);
			КонецЕсли;
			Если Не Выборка.ВходитВДиапозон Тогда
				НарушеныУсловия.Добавить("Сумма долга не попадает в лимит этапа """ + Этап + """");
			КонецЕсли;

		КонецЦикла;
	КонецЕсли;

	Возврат НарушеныУсловия;
КонецФункции


Процедура ИсполнительныйИлиСудебныйЭтап(Знач Этап, Исполнитльный = Ложь, Судебный = Ложь, Досудебный = Ложь) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА энргВидыОперацийПИД.Тип = ЗНАЧЕНИЕ(Перечисление.энргТипыЭтапов.СудебнаяРабота)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Судебный,
		|	ВЫБОР
		|		КОГДА энргВидыОперацийПИД.Тип = ЗНАЧЕНИЕ(Перечисление.энргТипыЭтапов.ИсполнительнаяРабота)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Исполнитльный,
		|	ВЫБОР
		|		КОГДА энргВидыОперацийПИД.Тип = ЗНАЧЕНИЕ(Перечисление.энргТипыЭтапов.ДосудебнаяРабота)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Досудебный
		|ИЗ
		|	Справочник.энргВидыОперацийПИД КАК энргВидыОперацийПИД
		|ГДЕ
		|	энргВидыОперацийПИД.Ссылка = &Этап";
	
	Запрос.УстановитьПараметр("Этап", Этап);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Исполнитльный = Выборка.Исполнитльный;
		Судебный	  = Выборка.Судебный;
		Досудебный	  = Выборка.Досудебный;
	КонецЦикла;
КонецПроцедуры

#Область ЮЛ

Процедура СоздатьЗадачуПоДанным(ДанныеЗадачи) Экспорт
	НоваяЗадача = Задачи.энргЗадачаПИД.СоздатьЗадачу();
	НоваяЗадача.Дата = ТекущаяДата();
	ЗаполнитьЗначенияСвойств(НоваяЗадача, ДанныеЗадачи); 
	ЗаполнитьНаименованиеИЭтап(НоваяЗадача,,ДанныеЗадачи.Этап);
	Попытка
		НоваяЗадача.Записать();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось создать задачу по договору " + ДанныеЗадачи.Договор);
		Возврат;
	КонецПопытки; 
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Создана задача по договору " + ДанныеЗадачи.Договор);
КонецПроцедуры
	 
#Конецобласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РеализацияИнтерфейса_ПолучениеДанных

Процедура ПолучитьЗадачиПИД(Схема, ПараметрыОтбора, ТаблицаДляПомещения = "") Экспорт 
	
	Если Схема = Неопределено Тогда
		Схема 								= Новый СхемаЗапроса;
		Пакет 								= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 								= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаЗадачиПИД());
	Пакет.ТаблицаДляПомещения 			= ТаблицаДляПомещения;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры = "Ссылка, Абонент";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(Пакет.Операторы[0].Отбор, "энргЗадачаПИД", ПараметрыОтбора.ПараметрыВТ, ДоступныеПараметры);		
	КонецЕсли;
	
КонецПроцедуры

#Область ТекстыЗапросов

Функция ТекстЗапросаЗадачиПИД()
	
	Текст  		=
	"ВЫБРАТЬ
	|	энргЗадачаПИД.Ссылка КАК Задача,
	|	энргЗадачаПИД.Абонент КАК Абонент
	|ИЗ
	|	Задача.энргЗадачаПИД КАК энргЗадачаПИД";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

