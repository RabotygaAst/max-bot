		|			КОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаТелефон
		|				ТОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Значение
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК КонтактныйЦентр_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаАдресСайта
		|				ТОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Значение
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК АдресСайта_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаЮридическийАдрес
		|				ТОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Значение
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ЮридическийАдрес_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаЭлекАдрес
		|				ТОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Значение
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ЭлекАдрес_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаОКПО
		|				ТОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Значение
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ОКПО_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаОГРН
		|				ТОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Значение
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ОГРН_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаИНН
		|				ТОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Значение
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ИНН_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаКПП
		|				ТОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Значение
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК КПП_Филиала,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаФакс
		|				ТОГДА энргЗоныОтвественностиДополнительныеРеквизиты.Значение
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК Факс_Филиала,
		|	энргЗоныОтвественности.Ссылка КАК Район,
		|	Организации.Ссылка КАК Организация,
		|	Организации.НаименованиеПолное КАК ОрганизацияНаименованиеПолное,
		|	Организации.НаименованиеСокращённое КАК ОрганизацияНаименованиеСокращённое
		|ИЗ
		|	Справочник.энргЗоныОтвественности.ДополнительныеРеквизиты КАК энргЗоныОтвественностиДополнительныеРеквизиты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргЗоныОтвественности КАК энргЗоныОтвественности
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
		|			ПО энргЗоныОтвественности.Организация = Организации.Ссылка
		|		ПО энргЗоныОтвественностиДополнительныеРеквизиты.Ссылка = энргЗоныОтвественности.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_РеквизитыФилиала КАК ВТ_РеквизитыФилиала
		|		ПО (энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаАдрес
		|				ИЛИ энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаТелефон
		|				ИЛИ энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаАдресСайта
		|				ИЛИ энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаЮридическийАдрес
		|				ИЛИ энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаЭлекАдрес
		|				ИЛИ энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаОКПО
		|				ИЛИ энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаОГРН
		|				ИЛИ энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаИНН
		|				ИЛИ энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаКПП
		|				ИЛИ энргЗоныОтвественностиДополнительныеРеквизиты.Свойство = ВТ_РеквизитыФилиала.энргРеквизитФилиалаФакс)
		|ГДЕ
		|	энргЗоныОтвественности.Ссылка = &Район
		|
		|СГРУППИРОВАТЬ ПО
		|	энргЗоныОтвественности.Ссылка,
		|	Организации.Ссылка";
	
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если ОбластьШапкаДляВывода = Неопределено Тогда
		Макет = ПолучитьМакет("МакетБланкФилиала");
		ОбластьБланкФилиала = Макет.ПолучитьОбласть("БланкФилиала");
	Иначе
		ОбластьБланкФилиала = ОбластьШапкаДляВывода;
	КонецЕсли;
	
	ТекОбъект = Новый Структура;
	Если Выборка.Следующий() Тогда 
		ОбластьБланкФилиала.Параметры.Заполнить(Выборка);
		
		ТекОбъект.Вставить("ОрганизацияПрописью", ВРег(Строка(Выборка.Организация)));
		
		Если ЗначениеЗаполнено(Выборка.ЮридическийАдрес_Филиала) И Выборка.ЮридическийАдрес_Филиала <> Выборка.Адрес_Филиала Тогда
			ФактЮрАдрес = "юридический адрес: " + Строка(Выборка.ЮридическийАдрес_Филиала) + Символы.ПС +
							"фактический адрес: " + Строка(Выборка.Адрес_Филиала);
			ТекОбъект.Вставить("ФактЮрАдрес", ФактЮрАдрес);
		Иначе
			ТекОбъект.Вставить("ФактЮрАдрес", Выборка.Адрес_Филиала);
		КонецЕсли;
		ОбластьБланкФилиала.Параметры.Заполнить(ТекОбъект);
	КонецЕсли;
	
	Если ОбластьШапкаДляВывода = Неопределено Тогда
		ТабДок.Вывести(ОбластьБланкФилиала);
	КонецЕсли;
КонецПроцедуры

Функция ОкончаниеТесктаЗаросаПроверкаЭтапаПИР()
	
	ТекстЗапроса = ";
		|
		|////////////////////////////////////////////////////////////////////////////////
		|";
	
	ТекстЗапроса = ТекстЗапроса + 
		"ВЫБРАТЬ
		|	энргОбъемНачислений.Организация КАК Организация,
		|	энргОбъемНачислений.Район КАК Район,
		|	энргОбъемНачислений.Абонент КАК Абонент,
		|	энргОбъемНачислений.Услуга КАК Услуга,
		|	энргОбъемНачислений.Поставщик КАК Поставщик,
		|	МАКСИМУМ(энргОбъемНачислений.ТарифнаяЗона) КАК ТарифнаяЗона,
		|	МАКСИМУМ(энргОбъемНачислений.ЗначениеТарифа) КАК ЗначениеТарифа,
		|	МАКСИМУМ(энргОбъемНачислений.КлючПомещения) КАК КлючПомещения,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ энргОбъемНачислений.ТарифнаяЗона) КАК КоличествоТарифнаяЗона,
		|	энргОбъемНачислений.НормаПотребления КАК НормаПотребления
		|ПОМЕСТИТЬ ВТ_Оплаты
		|ИЗ
		|	ВТ_Долги КАК ВТ_Долги
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.энргОбъемНачислений КАК энргОбъемНачислений
		|		ПО ВТ_Долги.ПериодНачисления = энргОбъемНачислений.ПериодНачисления
		|			И ВТ_Долги.Услуга = энргОбъемНачислений.Услуга
		|ГДЕ
		|	энргОбъемНачислений.Организация = &Организация
		|	И энргОбъемНачислений.Район = &Район
		|	И НЕ энргОбъемНачислений.Распределение
		|	И энргОбъемНачислений.Строение = &Строение
		|	И энргОбъемНачислений.Помещение = &Помещение
		|	И энргОбъемНачислений.Абонент = &Абонент
		|
		|СГРУППИРОВАТЬ ПО
		|	энргОбъемНачислений.Организация,
		|	энргОбъемНачислений.Район,
		|	энргОбъемНачислений.Абонент,
		|	энргОбъемНачислений.Услуга,
		|	энргОбъемНачислений.Поставщик,
		|	энргОбъемНачислений.НормаПотребления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Оплаты.Организация КАК Организация,
		|	ВТ_Оплаты.Район КАК Район,
		|	ВТ_Оплаты.Абонент КАК Абонент,
		|	ВТ_Оплаты.Услуга КАК Услуга,
		|	ВТ_Оплаты.Поставщик КАК Поставщик,
		|	ВТ_Оплаты.КлючПомещения КАК КлючПомещения,
		|	ЗНАЧЕНИЕ(Справочник.энргТарифныеЗоны.БезРазбивки) КАК ТарифнаяЗона
		|ПОМЕСТИТЬ ВТ_ДанныеДляТарифа
		|ИЗ
		|	ВТ_Оплаты КАК ВТ_Оплаты
		|ГДЕ
		|	ВТ_Оплаты.КоличествоТарифнаяЗона > 1
		|	И &ИспользуютсяТарифныеЗоны
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргГруппыПотребителейАбонентовСрезПоследних.Организация КАК Организация,
		|	энргГруппыПотребителейАбонентовСрезПоследних.Район КАК Район,
		|	энргГруппыПотребителейАбонентовСрезПоследних.КлючПомещения КАК КлючПомещения,
		|	энргГруппыПотребителейАбонентовСрезПоследних.Услуга КАК Услуга,
		|	энргГруппыПотребителейАбонентовСрезПоследних.ГруппаПотребителей КАК ГруппаПотребителей
