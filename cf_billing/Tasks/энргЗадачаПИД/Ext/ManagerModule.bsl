 Функция ЗапросСроковПодэтапов(ДатаЗадачи, Объект)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргВидыОперацийПИД.Ссылка КАК Этап,
		|	ЕСТЬNULL(энргВидыОперацийПИДПодэтапы.Подэтап, ЗНАЧЕНИЕ(Справочник.энргВидыОперацийПИД.ПустаяСсылка)) КАК Подэтап,
		|	ЕСТЬNULL(энргВидыОперацийПИДПодэтапы.Порядок, 0) КАК Порядок,
		|	ЕСТЬNULL(энргВидыОперацийПИДПодэтапы.Параллельно, ЛОЖЬ) КАК Параллельно
		|ПОМЕСТИТЬ ВТ_Подэтапы
		|ИЗ
		|	Справочник.энргВидыОперацийПИД КАК энргВидыОперацийПИД
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыОперацийПИД.Подэтапы КАК энргВидыОперацийПИДПодэтапы
		|		ПО энргВидыОперацийПИД.Ссылка = энргВидыОперацийПИДПодэтапы.Ссылка
		|ГДЕ
		|	энргВидыОперацийПИД.Ссылка = &Этап
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Подэтапы.Этап КАК Этап,
		|	ВТ_Подэтапы.Подэтап КАК Подэтап,
		|	ВТ_Подэтапы.Порядок КАК Порядок,
		|	ВТ_Подэтапы.Параллельно КАК Параллельно,
		|	ЕСТЬNULL(СрокиЭтаповПИДСрезПоследних.Срок, 0) КАК Срок,
		|	2 КАК Приоритет
		|ПОМЕСТИТЬ ВТ_СрокиПодэтапов
		|ИЗ
		|	ВТ_Подэтапы КАК ВТ_Подэтапы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргСрокиЭтаповПИД.СрезПоследних(
		|				&Дата,
		|				Организация = &Организация
		|					И Район = &Район
		|					И Схема = &Схема
		|					И Юридическая = ЛОЖЬ
		|					И (Этап, Подэтап) В
		|						(ВЫБРАТЬ
		|							ВТ_Подэтапы.Этап КАК Этап,
		|							ВТ_Подэтапы.Подэтап КАК Подэтап
		|						ИЗ
		|							ВТ_Подэтапы КАК ВТ_Подэтапы)) КАК СрокиЭтаповПИДСрезПоследних
		|		ПО (СрокиЭтаповПИДСрезПоследних.Этап = ВТ_Подэтапы.Этап)
		|			И (СрокиЭтаповПИДСрезПоследних.Подэтап = ВТ_Подэтапы.Подэтап)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СрокиПодэтапов.Этап КАК Этап,
		|	ВТ_СрокиПодэтапов.Подэтап КАК Подэтап,
		|	ВТ_СрокиПодэтапов.Порядок КАК Порядок,
		|	ВТ_СрокиПодэтапов.Параллельно КАК Параллельно,
		|	МИНИМУМ(ВТ_СрокиПодэтапов.Приоритет) КАК Приоритет
		|ПОМЕСТИТЬ ВТ_ПолучитьНужныйПриоритет
		|ИЗ
		|	ВТ_СрокиПодэтапов КАК ВТ_СрокиПодэтапов
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_СрокиПодэтапов.Этап,
		|	ВТ_СрокиПодэтапов.Подэтап,
		|	ВТ_СрокиПодэтапов.Порядок,
		|	ВТ_СрокиПодэтапов.Параллельно
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СрокиПодэтапов.Этап КАК Этап,
		|	ВТ_СрокиПодэтапов.Подэтап КАК Подэтап,
		|	ВТ_СрокиПодэтапов.Порядок КАК Порядок,
		|	ВТ_СрокиПодэтапов.Параллельно КАК Параллельно,
		|	ВТ_СрокиПодэтапов.Срок КАК Продолжительность
		|ИЗ
		|	ВТ_СрокиПодэтапов КАК ВТ_СрокиПодэтапов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПолучитьНужныйПриоритет КАК ВТ_ПолучитьНужныйПриоритет
		|		ПО ВТ_СрокиПодэтапов.Этап = ВТ_ПолучитьНужныйПриоритет.Этап
		|			И ВТ_СрокиПодэтапов.Подэтап = ВТ_ПолучитьНужныйПриоритет.Подэтап
		|			И ВТ_СрокиПодэтапов.Порядок = ВТ_ПолучитьНужныйПриоритет.Порядок
		|			И ВТ_СрокиПодэтапов.Параллельно = ВТ_ПолучитьНужныйПриоритет.Параллельно
		|			И ВТ_СрокиПодэтапов.Приоритет = ВТ_ПолучитьНужныйПриоритет.Приоритет
		|
		|УПОРЯДОЧИТЬ ПО
		|	Порядок";
	
	Запрос.УстановитьПараметр("Дата",		 ДатаЗадачи);
	Запрос.УстановитьПараметр("Абонент",	 Объект.Абонент);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Район",		 Объект.Район);
	Запрос.УстановитьПараметр("Этап",		 Объект.Этап);
	Запрос.УстановитьПараметр("Схема",		 Объект.Схема);
	
	Возврат Запрос.Выполнить();

КонецФункции

 Функция ЗаполнитьСхемуОбъекта(Знач ДатаЗадачи, Объект)
	
	Перем Выборка, Запрос, РезультатЗапроса;
	
	Если ЗначениеЗаполнено(Объект.Схема) Тогда
		Возврат Истина;
	КонецЕсли;

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСхемыПИДОрганизацийСрезПоследних.Схема КАК Схема
		|ИЗ
		|	РегистрСведений.энргСхемыПИДОрганизаций.СрезПоследних(
		|			&ТекДата,
		|			Организация = &Организация
		|				И Район = &Район
		|				И МКД = &МКД
		|				И Абонент = &Абонент
		|				И Юридическая = ЛОЖЬ) КАК энргСхемыПИДОрганизацийСрезПоследних
		|ГДЕ
		|	энргСхемыПИДОрганизацийСрезПоследних.Схема <> ЗНАЧЕНИЕ(Справочник.энргСхемыПИД.ПустаяСсылка)";
	
	Если ЗначениеЗаполнено(Объект.Абонент) Тогда
		Запрос.УстановитьПараметр("Абонент", Объект.Абонент);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И Абонент = &Абонент","");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.МКД) Тогда  
		Запрос.УстановитьПараметр("МКД", Объект.МКД);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И МКД = &МКД","");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("ТекДата",	 ДатаЗадачи);
	Запрос.УстановитьПараметр("Район", Объект.Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда 
		Объект.Схема = Выборка.Схема;
		
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;
КонецФункции

 Процедура ВыводШапкиФилиала(ТабДок, Район, ОбластьШапкаДляВывода = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Константы.энргРеквизитФилиалаАдрес КАК энргРеквизитФилиалаАдрес,
		|	Константы.энргРеквизитФилиалаТелефон КАК энргРеквизитФилиалаТелефон,
