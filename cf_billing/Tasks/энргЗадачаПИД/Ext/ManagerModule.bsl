Процедура ЗаполнитьПомещениеИСтроениеПоАбоненту(Абонент, Строение, Помещение) 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргКлючиПомещений.Помещение КАК Помещение,
		|	энргКлючиПомещений.Строение КАК Строение
		|ИЗ
		|	Справочник.энргАбоненты КАК энргАбоненты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКлючиПомещений КАК энргКлючиПомещений
		|		ПО энргАбоненты.КлючПомещения = энргКлючиПомещений.Ссылка
		|ГДЕ
		|	энргАбоненты.Ссылка = &Абонент";
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда 
		Строение 	= ВыборкаДетальныеЗаписи.Строение;
		Помещение 	= ВыборкаДетальныеЗаписи.Помещение;
	Иначе
		Строение	= Справочники.энргСтроения.ПустаяСсылка();
		Помещение 	= Справочники.энргПомещения.ПустаяСсылка();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти





