#Область СлужебныйПрограммныйИнтерфейс

Функция ПолучитьЗадачиПринятыеВРаботуПоАбонентам(Период, Абоненты) Экспорт
	ИмяТаблицыЗадачПИД = "ЗадачиПИДАбонентов";
	
	Схема							= Неопределено;
	Параметры 						= Новый Структура;
	ПараметрыВТ 					= Новый Массив;
	ПараметрыОтбора					= Новый Массив;
	
	ОтборПоАбоненту 		= энргФормированиеТекстовЗапроса.ПараметрТипВСписке(Новый Структура("Абонент", 	"Абоненты"));
	ОтборПоЗадачамАбонента 	= энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица(ИмяТаблицыЗадачПИД, Новый Структура("Задача", "Задача"));
	ПараметрыВТ.Добавить(ОтборПоАбоненту);	
	ПараметрыВТ.Добавить(ОтборПоЗадачамАбонента);	
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);
	
	ОтборПоЗадачамАбонента 	= энргФормированиеТекстовЗапроса.ПараметрТипРавно(Новый Структура("Статус", "ПринятоВРаботу"));
	ПараметрыОтбора.Добавить(ОтборПоЗадачамАбонента);	
	Параметры.Вставить("ПараметрыОтбора", ПараметрыОтбора); 		
	
	ПолучитьЗадачиПИД(Схема, Параметры, ИмяТаблицыЗадачПИД);
	РегистрыСведений.энргСтатусЗадачи.СтатусЗадач(Схема, Параметры, "ЗадачиПринятыеВРаботуАбонентов");
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	ЗадачиПИДАбонентов.Задача КАК Задача,
		|	ЗадачиПИДАбонентов.Абонент КАК Абонент
		|ИЗ
		|	ЗадачиПИДАбонентов КАК ЗадачиПИДАбонентов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗадачиПринятыеВРаботуАбонентов КАК ЗадачиПринятыеВРаботуАбонентов
		|		ПО ЗадачиПИДАбонентов.Задача = ЗадачиПринятыеВРаботуАбонентов.Задача");
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Период"			, Период);
	ПараметрыЗапроса.Вставить("Абоненты"		, Абоненты); 	
	ПараметрыЗапроса.Вставить("ПринятоВРаботу"	, Перечисления.энргСтатусыЗадач.ПринятаВРаботу);
	
	Возврат энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);;	
КонецФункции 

Функция ПодчинённыеЗадачи(Задача)
	Результат = Новый Массив;
	
	// Получаем подчиненные задачи
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗадачаПИД.Ссылка КАК Ссылка
		|ИЗ
		|	Задача.энргЗадачаПИД КАК энргЗадачаПИД
		|ГДЕ
		|	энргЗадачаПИД.Основание = &Задача
		|	И НЕ энргЗадачаПИД.ПометкаУдаления
		|	И энргЗадачаПИД.Ссылка <> &Задача";
	
	Запрос.УстановитьПараметр("Задача", Задача);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Результат;		
КонецФункции

Процедура ПолучитьСписокНижележащихЗадач(Задача, СпиокЗадач) Экспорт 

	ПодчинЗадачи = ПодчинённыеЗадачи(Задача);
	Для каждого СледЗадача Из ПодчинЗадачи Цикл
		ПолучитьСписокНижележащихЗадач(СледЗадача, СпиокЗадач);
		СпиокЗадач.Добавить(СледЗадача);
	КонецЦикла;

КонецПроцедуры

Функция ПолучитьЗадачуПоОснованию(Основание) Экспорт 
	Задача = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗадачаПИДЗадачиПоИсполнителю.Ссылка КАК Ссылка
		|ИЗ
		|	Задача.энргЗадачаПИД КАК энргЗадачаПИДЗадачиПоИсполнителю
		|ГДЕ
		|	энргЗадачаПИДЗадачиПоИсполнителю.Основание = &Основание";
	
	Запрос.УстановитьПараметр("Основание", Основание);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Задача;
	КонецЕсли;	
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Задача = Выборка.Ссылка;
	
	Возврат Задача;

КонецФункции

Функция ПолучитьПараметрыФормыПеренаправления(Задача) Экспорт
	Результат = Новый Структура("ДатаСледующегоЭтапа, Комментарий, Пользователь");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(энргЗадачаПИДИсторияПеренаправленийЗадачи.НомерСтроки) КАК НомерСтроки,
		|	энргЗадачаПИДИсторияПеренаправленийЗадачи.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_СтрокаЗадачи
		|ИЗ
		|	Задача.энргЗадачаПИД.ИсторияПеренаправленийЗадачи КАК энргЗадачаПИДИсторияПеренаправленийЗадачи
		|ГДЕ
		|	энргЗадачаПИДИсторияПеренаправленийЗадачи.Ссылка = &Задача
		|
		|СГРУППИРОВАТЬ ПО
		|	энргЗадачаПИДИсторияПеренаправленийЗадачи.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗадачаПИДИсторияПеренаправленийЗадачи.ПланируемаяДатаВыполнения КАК ДатаСледующегоЭтапа,
		|	энргЗадачаПИДИсторияПеренаправленийЗадачи.Комментарий КАК Комментарий,
		|	энргЗадачаПИДИсторияПеренаправленийЗадачи.НовыйИсполнитель КАК Пользователь
		|ИЗ
		|	ВТ_СтрокаЗадачи КАК ВТ_СтрокаЗадачи
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.ИсторияПеренаправленийЗадачи КАК энргЗадачаПИДИсторияПеренаправленийЗадачи
		|		ПО ВТ_СтрокаЗадачи.Ссылка = энргЗадачаПИДИсторияПеренаправленийЗадачи.Ссылка
		|			И ВТ_СтрокаЗадачи.НомерСтроки = энргЗадачаПИДИсторияПеренаправленийЗадачи.НомерСтроки";
	
	Запрос.УстановитьПараметр("Задача", Задача);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
	КонецЦикла;

	Возврат Результат;
КонецФункции

Процедура ПодтвердитьПеренаправлениеЗадачи(Задача, ПарамПеренапр, ПодтвердитьПеренаправление = Ложь) Экспорт
	ОбъектЗадача = Задача.ПолучитьОбъект();
	
	Если ПодтвердитьПеренаправление И ЗначениеЗаполнено(ОбъектЗадача.ИсторияПеренаправленийЗадачи) Тогда
		СтрокаТЧ = ОбъектЗадача.ИсторияПеренаправленийЗадачи[ОбъектЗадача.ИсторияПеренаправленийЗадачи.Количество()-1];
	Иначе
		СтрокаТЧ = ОбъектЗадача.ИсторияПеренаправленийЗадачи.Добавить();
		
		СтрокаТЧ.ДатаПеренаправления = ТекущаяДатаСеанса();
		СтрокаТЧ.Роль				 = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектЗадача.Этап, "Роль");
		СтрокаТЧ.Перенаправил		 = ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(СтрокаТЧ, ПарамПеренапр);
	
	ОбъектЗадача.Роль					= СтрокаТЧ.Роль;
	ОбъектЗадача.ТребуетПодтверждения 	= Ложь;
	ОбъектЗадача.Исполнитель 			= ПарамПеренапр.НовыйИсполнитель;
	ОбъектЗадача.ПринятоВРаботу			= Ложь;
	ОбъектЗадача.ДатаПринятияВРаботу	= Неопределено;
	
	ОбъектЗадача.Комментарий = ПарамПеренапр.Комментарий;
	
	Если ЗначениеЗаполнено(ПарамПеренапр.ДатаСледЭтапа) Тогда
		ОбъектЗадача.ДатаСледЭтапа			= ПарамПеренапр.ДатаСледЭтапа;
		СтрокаТЧ.ПланируемаяДатаВыполнения	= ПарамПеренапр.ДатаСледЭтапа;
	КонецЕсли;
	
	ОбъектЗадача.Записать();
КонецПроцедуры

Функция ПолучитьСуммуПениЗадачи(Организация, Район, Договор, ДатаРасчетаПени, Задолженность, РасчетПени) Экспорт
	Если Не ЗначениеЗаполнено(Задолженность) Тогда
		Возврат 0;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Парам_Задолженность.ПериодНачисления КАК ПериодНачисления,
		|	Парам_Задолженность.Услуга КАК Услуга,
		|	Парам_Задолженность.Задолженность КАК Задолженность
		|ПОМЕСТИТЬ ТЧ_Задолженность
		|ИЗ
		|	&Задолженность КАК Парам_Задолженность
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргЗадачаПИДЗадолженность.ПериодНачисления КАК ПериодНачисления,
		|	СУММА(энргЗадачаПИДЗадолженность.Задолженность) КАК Задолженность,
		|	&Организация КАК Организация,
		|	&Район КАК Район,
		|	&Договор КАК Договор
		|ПОМЕСТИТЬ ВТ_СуммаДолгов
		|ИЗ
		|	ТЧ_Задолженность КАК энргЗадачаПИДЗадолженность
		|
		|СГРУППИРОВАТЬ ПО
		|	энргЗадачаПИДЗадолженность.ПериодНачисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СуммаДолгов.ПериодНачисления КАК ПериодНачисления,
		|	ВТ_СуммаДолгов.Задолженность КАК Задолженность,
		|	МАКСИМУМ(энргНастройкиНачисленияПени.Период) КАК Период_Отсрочка,
		|	ВТ_СуммаДолгов.Организация КАК Организация,
		|	ВТ_СуммаДолгов.Район КАК Район,
		|	ВТ_СуммаДолгов.Договор КАК Договор
		|ПОМЕСТИТЬ ВТ_Задолженность
		|ИЗ
		|	ВТ_СуммаДолгов КАК ВТ_СуммаДолгов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргНастройкиНачисленияПени КАК энргНастройкиНачисленияПени
		|		ПО ВТ_СуммаДолгов.ПериодНачисления >= энргНастройкиНачисленияПени.Период
		|			И ВТ_СуммаДолгов.Организация = энргНастройкиНачисленияПени.Организация
		|			И ВТ_СуммаДолгов.Район = энргНастройкиНачисленияПени.Район
		|ГДЕ
		|	ВТ_СуммаДолгов.Договор = ЗНАЧЕНИЕ(Справочник.энргДоговорыКонтрагентов.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_СуммаДолгов.ПериодНачисления,
		|	ВТ_СуммаДолгов.Организация,
		|	ВТ_СуммаДолгов.Район,
		|	ВТ_СуммаДолгов.Задолженность,
		|	ВТ_СуммаДолгов.Договор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Задолженность.ПериодНачисления КАК ПериодНачисления,
		|	ВТ_Задолженность.Задолженность КАК Задолженность,
		|	ВТ_Задолженность.Организация КАК Организация,
		|	ВТ_Задолженность.Район КАК Район,
		|	ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ВТ_Задолженность.ПериодНачисления, МЕСЯЦ), СЕКУНДА, 3600 * 24 * ЕСТЬNULL(энргНастройкиНачисленияПени.КрайнийСрокОплаты - 1, 0)) КАК Граница
		|ПОМЕСТИТЬ ВТ_ЗадолженностьСГраницей
		|ИЗ
		|	ВТ_Задолженность КАК ВТ_Задолженность
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргНастройкиНачисленияПени КАК энргНастройкиНачисленияПени
		|		ПО ВТ_Задолженность.Организация = энргНастройкиНачисленияПени.Организация
		|			И ВТ_Задолженность.Район = энргНастройкиНачисленияПени.Район
		|			И ВТ_Задолженность.Период_Отсрочка = энргНастройкиНачисленияПени.Период
		|ГДЕ
		|	ВТ_Задолженность.Договор = ЗНАЧЕНИЕ(Справочник.энргДоговорыКонтрагентов.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МИНИМУМ(ВТ_ЗадолженностьСГраницей.Граница) КАК НачалоРасчета,
		|	&ТекущаяДата КАК КонецРасчета
		|ПОМЕСТИТЬ ВТ_ГраницыРасчета
		|ИЗ
		|	ВТ_ЗадолженностьСГраницей КАК ВТ_ЗадолженностьСГраницей
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА энргСтавкиРефинансирования.Период > ВТ_ГраницыРасчета.НачалоРасчета
		|			ТОГДА энргСтавкиРефинансирования.Период
		|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
		|	КОНЕЦ КАК Период,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргСтавкиРефинансирования.Период <= ВТ_ГраницыРасчета.НачалоРасчета
		|				ТОГДА энргСтавкиРефинансирования.Период
		|			ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
		|		КОНЕЦ) КАК ПериодНаНачало,
		|	ВТ_ГраницыРасчета.НачалоРасчета КАК НачалоРасчета
		|ПОМЕСТИТЬ ВТ_ПериодыСтавкиРефенансирования
		|ИЗ
		|	РегистрСведений.энргСтавкиРефинансирования КАК энргСтавкиРефинансирования
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ГраницыРасчета КАК ВТ_ГраницыРасчета
		|		ПО энргСтавкиРефинансирования.Период < ВТ_ГраницыРасчета.КонецРасчета
		|
		|СГРУППИРОВАТЬ ПО
		|	ВЫБОР
		|		КОГДА энргСтавкиРефинансирования.Период > ВТ_ГраницыРасчета.НачалоРасчета
		|			ТОГДА энргСтавкиРефинансирования.Период
		|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
		|	КОНЕЦ,
		|	ВТ_ГраницыРасчета.НачалоРасчета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргСтавкиРефинансирования.Коэффициент КАК Коэффициент,
		|	ВТ_ПериодыСтавкиРефенансирования.НачалоРасчета КАК Период
		|ПОМЕСТИТЬ ВТ_ИзменениеСтавкиРефенансирования
		|ИЗ
		|	ВТ_ПериодыСтавкиРефенансирования КАК ВТ_ПериодыСтавкиРефенансирования
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргСтавкиРефинансирования КАК энргСтавкиРефинансирования
		|		ПО ВТ_ПериодыСтавкиРефенансирования.ПериодНаНачало = энргСтавкиРефинансирования.Период
		|ГДЕ
		|	ВТ_ПериодыСтавкиРефенансирования.Период = ДАТАВРЕМЯ(1, 1, 1)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	энргСтавкиРефинансирования.Коэффициент,
		|	КОНЕЦПЕРИОДА(энргСтавкиРефинансирования.Период, ДЕНЬ)
		|ИЗ
		|	ВТ_ПериодыСтавкиРефенансирования КАК ВТ_ПериодыСтавкиРефенансирования
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргСтавкиРефинансирования КАК энргСтавкиРефинансирования
		|		ПО ВТ_ПериодыСтавкиРефенансирования.Период = энргСтавкиРефинансирования.Период
		|ГДЕ
		|	ВТ_ПериодыСтавкиРефенансирования.Период <> ДАТАВРЕМЯ(1, 1, 1)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИзменениеСтавкиРефенансирования.Коэффициент КАК Коэффициент,
		|	ВТ_ИзменениеСтавкиРефенансирования.Период КАК ПериодОт,
		|	МИНИМУМ(ЕСТЬNULL(ВТ_ИзменениеСтавкиРефенансированияСлед.Период, &ТекущаяДата)) КАК ПериодДо
		|ПОМЕСТИТЬ ВТ_ПериодыДействияСтавРеф
		|ИЗ
		|	ВТ_ИзменениеСтавкиРефенансирования КАК ВТ_ИзменениеСтавкиРефенансирования
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ИзменениеСтавкиРефенансирования КАК ВТ_ИзменениеСтавкиРефенансированияСлед
		|		ПО ВТ_ИзменениеСтавкиРефенансирования.Период < ВТ_ИзменениеСтавкиРефенансированияСлед.Период
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ИзменениеСтавкиРефенансирования.Коэффициент,
		|	ВТ_ИзменениеСтавкиРефенансирования.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ЗадолженностьСГраницей.ПериодНачисления КАК ПериодНачисления,
		|	ВТ_ЗадолженностьСГраницей.Задолженность КАК Задолженность,
		|	ВТ_ЗадолженностьСГраницей.Организация КАК Организация,
		|	ВТ_ЗадолженностьСГраницей.Район КАК Район,
		|	ВТ_ЗадолженностьСГраницей.Граница КАК Граница,
		|	ВЫБОР
		|		КОГДА ВТ_ПериодыДействияСтавРеф.ПериодОт < ВТ_ЗадолженностьСГраницей.Граница
		|			ТОГДА ВТ_ЗадолженностьСГраницей.Граница
		|		ИНАЧЕ ВТ_ПериодыДействияСтавРеф.ПериодОт
		|	КОНЕЦ КАК ПериодОт,
		|	ВТ_ПериодыДействияСтавРеф.ПериодДо КАК ПериодДо,
		|	ВТ_ПериодыДействияСтавРеф.Коэффициент КАК Коэффициент,
		|	РАЗНОСТЬДАТ(ВТ_ЗадолженностьСГраницей.Граница, ВЫБОР
		|			КОГДА ВТ_ПериодыДействияСтавРеф.ПериодОт < ВТ_ЗадолженностьСГраницей.Граница
		|				ТОГДА ВТ_ЗадолженностьСГраницей.Граница
		|			ИНАЧЕ ВТ_ПериодыДействияСтавРеф.ПериодОт
		|		КОНЕЦ, ДЕНЬ) КАК ПросрочкаОт,
		|	РАЗНОСТЬДАТ(ВТ_ЗадолженностьСГраницей.Граница, ВТ_ПериодыДействияСтавРеф.ПериодДо, ДЕНЬ) КАК ПросрочкаДо
		|ПОМЕСТИТЬ ВТ_ЗадолженностьСоСтавРеф
		|ИЗ
		|	ВТ_ЗадолженностьСГраницей КАК ВТ_ЗадолженностьСГраницей
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПериодыДействияСтавРеф КАК ВТ_ПериодыДействияСтавРеф
		|		ПО ВТ_ЗадолженностьСГраницей.Граница <= ВТ_ПериодыДействияСтавРеф.ПериодДо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА РасчетПени.От > 0
		|			ТОГДА РасчетПени.От - 1
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК От,
		|	РасчетПени.До КАК До,
		|	РасчетПени.Числитель КАК Числитель,
		|	РасчетПени.Знаменатель КАК Знаменатель
		|ПОМЕСТИТЬ ВТ_НастройкаРасчетаПени
		|ИЗ
		|	&РасчетПени КАК РасчетПени
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ЗадолженностьСоСтавРеф.ПериодНачисления КАК ПериодНачисления,
		|	ВТ_ЗадолженностьСоСтавРеф.Организация КАК Организация,
		|	ВТ_ЗадолженностьСоСтавРеф.Район КАК Район,
		|	ВТ_ЗадолженностьСоСтавРеф.Граница КАК Граница,
		|	ВТ_ЗадолженностьСоСтавРеф.ПериодОт КАК ПериодОт,
		|	ВТ_ЗадолженностьСоСтавРеф.ПериодДо КАК ПериодДо,
		|	ВТ_НастройкаРасчетаПени.От КАК От_Пеня,
		|	ВТ_ЗадолженностьСоСтавРеф.ПросрочкаОт КАК ПросрочкаОт,
		|	ВЫБОР
		|		КОГДА ВТ_ЗадолженностьСоСтавРеф.ПросрочкаОт < ВТ_НастройкаРасчетаПени.От
		|			ТОГДА ВТ_НастройкаРасчетаПени.От
		|		ИНАЧЕ ВТ_ЗадолженностьСоСтавРеф.ПросрочкаОт
		|	КОНЕЦ КАК От,
		|	ВТ_ЗадолженностьСоСтавРеф.ПросрочкаДо КАК ПросрочкаДо,
		|	ВЫБОР
		|		КОГДА ВТ_НастройкаРасчетаПени.До <> 9999
		|				И ВТ_ЗадолженностьСоСтавРеф.ПросрочкаДо > ВТ_НастройкаРасчетаПени.До
		|			ТОГДА ВТ_НастройкаРасчетаПени.До
		|		ИНАЧЕ ВТ_ЗадолженностьСоСтавРеф.ПросрочкаДо
		|	КОНЕЦ КАК До,
		|	ВТ_НастройкаРасчетаПени.До КАК До_Пеня,
		|	ВТ_ЗадолженностьСоСтавРеф.Задолженность КАК Задолженность,
		|	ВЫБОР
		|		КОГДА ВТ_НастройкаРасчетаПени.До <> 9999
		|				И ВТ_ЗадолженностьСоСтавРеф.ПросрочкаДо > ВТ_НастройкаРасчетаПени.До
		|			ТОГДА ВТ_НастройкаРасчетаПени.До
		|		ИНАЧЕ ВТ_ЗадолженностьСоСтавРеф.ПросрочкаДо
		|	КОНЕЦ - ВЫБОР
		|		КОГДА ВТ_ЗадолженностьСоСтавРеф.ПросрочкаОт < ВТ_НастройкаРасчетаПени.От
		|			ТОГДА ВТ_НастройкаРасчетаПени.От
		|		ИНАЧЕ ВТ_ЗадолженностьСоСтавРеф.ПросрочкаОт
		|	КОНЕЦ КАК КоличествоДней,
		|	ВТ_ЗадолженностьСоСтавРеф.Коэффициент КАК Коэффициент,
		|	ВТ_НастройкаРасчетаПени.Числитель КАК Числитель,
		|	ВТ_НастройкаРасчетаПени.Знаменатель КАК Знаменатель,
		|	ВЫБОР
		|		КОГДА ВТ_НастройкаРасчетаПени.Знаменатель = 0
		|			ТОГДА 0
		|		ИНАЧЕ (ВЫБОР
		|				КОГДА ВТ_НастройкаРасчетаПени.До <> 9999
		|						И ВТ_ЗадолженностьСоСтавРеф.ПросрочкаДо > ВТ_НастройкаРасчетаПени.До
		|					ТОГДА ВТ_НастройкаРасчетаПени.До
		|				ИНАЧЕ ВТ_ЗадолженностьСоСтавРеф.ПросрочкаДо
		|			КОНЕЦ - ВЫБОР
		|				КОГДА ВТ_ЗадолженностьСоСтавРеф.ПросрочкаОт < ВТ_НастройкаРасчетаПени.От
		|					ТОГДА ВТ_НастройкаРасчетаПени.От
		|				ИНАЧЕ ВТ_ЗадолженностьСоСтавРеф.ПросрочкаОт
		|			КОНЕЦ) * ВТ_ЗадолженностьСоСтавРеф.Задолженность * ВТ_ЗадолженностьСоСтавРеф.Коэффициент * ВТ_НастройкаРасчетаПени.Числитель / (100 * ВТ_НастройкаРасчетаПени.Знаменатель)
		|	КОНЕЦ КАК Сумма
		|ИЗ
		|	ВТ_ЗадолженностьСоСтавРеф КАК ВТ_ЗадолженностьСоСтавРеф
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_НастройкаРасчетаПени КАК ВТ_НастройкаРасчетаПени
		|		ПО ВТ_ЗадолженностьСоСтавРеф.ПросрочкаДо >= ВТ_НастройкаРасчетаПени.От
		|			И (ВТ_НастройкаРасчетаПени.До = 9999
		|				ИЛИ ВТ_ЗадолженностьСоСтавРеф.ПросрочкаОт <= ВТ_НастройкаРасчетаПени.До)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПериодНачисления,
		|	ПросрочкаОт
		|ИТОГИ
		|	СУММА(Сумма)
		|ПО
		|	ОБЩИЕ,
		|	ПериодНачисления";
	
	Запрос.УстановитьПараметр("Организация",  	Организация);
	Запрос.УстановитьПараметр("Район",  		Район);
	Запрос.УстановитьПараметр("ТекущаяДата",	КонецДня(ДатаРасчетаПени));
	Запрос.УстановитьПараметр("Задолженность",	Задолженность);
	Запрос.УстановитьПараметр("РасчетПени", 	РасчетПени);
	Запрос.УстановитьПараметр("Договор", 		Договор);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаИтог = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Если ВыборкаИтог.Следующий() И ЗначениеЗаполнено(ВыборкаИтог.Сумма) Тогда
	
		Возврат Окр(ВыборкаИтог.Сумма, 2, РежимОкругления.Окр15как20);
		
	Иначе
		
		Возврат 0;
	
	КонецЕсли;
КонецФункции

Функция ПолучитьЗадолженность(Задолженность, Параметры, ДляДерева = Истина) Экспорт

	Если Не ЗначениеЗаполнено(Задолженность) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос  = Новый Запрос;
	Договор = Неопределено;
	Если Параметры.Свойство("Договор", Договор) И ЗначениеЗаполнено(Договор) Тогда
		Запрос.УстановитьПараметр("Договор",	 Договор);
		
		ТекстЗапросаДолга = 
			"ВЫБРАТЬ // Замена
			|	бестВзаиморасчётыПоУслугамЮрЛицаОстатки.ПериодНачисления КАК ПериодНачисления,
			|	бестВзаиморасчётыПоУслугамЮрЛицаОстатки.Услуга КАК Услуга,
			|	0 КАК СуммаДо,
			|	бестВзаиморасчётыПоУслугамЮрЛицаОстатки.СуммаОстаток + бестВзаиморасчётыПоУслугамЮрЛицаОстатки.СуммаНДСОстаток КАК СуммаОстаток
			|ПОМЕСТИТЬ ВТ_Долги
			|ИЗ
			|	РегистрНакопления.бестВзаиморасчетыПоУслугамЮрЛица.Остатки(
			|			,
			|			Организация = &Организация
			|				И Район = &Район
			|				И Договор = &Договор
			|				И ПериодНачисления = &ПериодНачисления
			|				И Услуга = &Услуга) КАК бестВзаиморасчётыПоУслугамЮрЛицаОстатки
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	&ПериодНачисления,
			|	&Услуга,
			|	&СуммаДо,
			|	0";
	Иначе
		Запрос.УстановитьПараметр("МКД",		 Параметры.МКД);
		Запрос.УстановитьПараметр("Абонент",	 Параметры.Абонент);
		
		ТекстЗапросаДолга = 
			"ВЫБРАТЬ // Замена
			|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления КАК ПериодНачисления,
			|	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
			|	0 КАК СуммаДо,
			|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток КАК СуммаОстаток
			|ПОМЕСТИТЬ ВТ_Долги
			|ИЗ
			|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
			|			,
			|			Организация = &Организация
			|				И Район = &Район
			|				//И МКД = &МКД
			|				И Абонент = &Абонент
			|				И ПериодНачисления = &ПериодНачисления
			|				И Услуга = &Услуга) КАК энргВзаиморасчетыПоМесяцамОстатки
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	&ПериодНачисления,
			|	&Услуга,
			|	&СуммаДо,
			|	0";
	КонецЕсли;
	
	
	Сч = 1;
	ТекстОбъединения = "";
	Для каждого Отбор Из Задолженность Цикл
		Постфикс = "_" + Формат(Сч, "ЧГ=0");
		
		ТекПодзапрос = СтрЗаменить(ТекстЗапросаДолга, "&ПериодНачисления", 	"&ПериодНачисления" + Постфикс);
		ТекПодзапрос = СтрЗаменить(ТекПодзапрос, 	  "&Услуга", 			"&Услуга" + Постфикс);
		ТекПодзапрос = СтрЗаменить(ТекПодзапрос, 	  "&СуммаДо", 			"&СуммаДо" + Постфикс);
		
		Запрос.УстановитьПараметр("ПериодНачисления" + Постфикс, Отбор.ПериодНачисления);
		Запрос.УстановитьПараметр("Услуга" + Постфикс, 			 Отбор.Услуга);
		ПредДолг	 = ?(Отбор.Свойство("СуммаДо"), Отбор.СуммаДо, 0);
		Запрос.УстановитьПараметр("СуммаДо" + Постфикс, 		 ПредДолг);
		
		ТекстОбъединения = ТекстОбъединения + ТекПодзапрос;
		
		Если Сч = 1 Тогда
			ТекстЗапросаДолга = СтрЗаменить(ТекстЗапросаДолга, "ВЫБРАТЬ // Замена", Символы.ПС + "ОБЪЕДИНИТЬ ВСЕ ВЫБРАТЬ");
			ТекстЗапросаДолга = СтрЗаменить(ТекстЗапросаДолга, "ПОМЕСТИТЬ ВТ_Долги", 	"");
			ТекстЗапросаДолга = СтрЗаменить(ТекстЗапросаДолга, "КАК ПериодНачисления", 	"");
			ТекстЗапросаДолга = СтрЗаменить(ТекстЗапросаДолга, "КАК Услуга", 			"");
			ТекстЗапросаДолга = СтрЗаменить(ТекстЗапросаДолга, "КАК СуммаОстаток", 		"");
		КонецЕсли;
		
		Сч = Сч + 1;
	КонецЦикла;
	
	Запрос.Текст = 
		ТекстОбъединения + Символы.ПС +
		"
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|" +
		" ВЫБРАТЬ
		|	ВТ_Долги.ПериодНачисления КАК ПериодНачисления,
		|	ВТ_Долги.Услуга КАК Услуга,
		|	СУММА(ВТ_Долги.СуммаОстаток) КАК Задолженность,
		|	СУММА(ВТ_Долги.СуммаДо - ВТ_Долги.СуммаОстаток) КАК Оплата,
		|	СУММА(ВТ_Долги.СуммаДо) КАК СуммаДо
		|ИЗ
		|	ВТ_Долги КАК ВТ_Долги
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Долги.ПериодНачисления,
		|	ВТ_Долги.Услуга
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПериодНачисления";
	Если ДляДерева Тогда 
		Запрос.Текст = Запрос.Текст + "
		|
		|ИТОГИ
		|	СУММА(Задолженность),
		|	СУММА(Оплата),
		|	СУММА(СуммаДо)
		|ПО
		|	ОБЩИЕ,
		|	ПериодНачисления";
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	Запрос.УстановитьПараметр("Район",		 Параметры.Район);
	
	Возврат Запрос.Выполнить();
КонецФункции 

Функция ПолучитьСписокЖильцовЛС(Абонент) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргАбоненты.ФизЛицо КАК ФизЛицо,
		|	энргАбоненты.КлючПомещения КАК КлючПомещения,
		|	энргАбоненты.Организация КАК Организация,
		|	энргАбоненты.Район КАК Район
		|ПОМЕСТИТЬ ВТ_Абоненты
		|ИЗ
		|	Справочник.энргАбоненты КАК энргАбоненты
		|ГДЕ
		|	энргАбоненты.Ссылка = &Абонент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргПроживаниеЖильцовСрезПоследних.Жилец КАК Жилец
		|ПОМЕСТИТЬ ВТ_Жильцы
		|ИЗ
		|	РегистрСведений.энргПроживаниеЖильцов.СрезПоследних(
		|			,
		|			(Организация, Район, КлючПомещения) В
		|				(ВЫБРАТЬ
		|					ВТ_Абоненты.Организация КАК Организация,
		|					ВТ_Абоненты.Район КАК Район,
		|					ВТ_Абоненты.КлючПомещения КАК КлючПомещения
		|				ИЗ
		|					ВТ_Абоненты КАК ВТ_Абоненты)) КАК энргПроживаниеЖильцовСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_Абоненты.ФизЛицо
		|ИЗ
		|	ВТ_Абоненты КАК ВТ_Абоненты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_Жильцы.Жилец КАК Жилец
		|ИЗ
		|	ВТ_Жильцы КАК ВТ_Жильцы";
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
КонецФункции

Функция ПолучитьГраницуПросрочки(Знач ТекДата, Знач Организация, Знач Район, Знач Абонент) Экспорт
	
	Если Не ЗначениеЗаполнено(ТекДата) Тогда
		ТекДата = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА энргАбоненты.КоличествоДнейОтсрочки > 0
		|			ТОГДА КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(&ТекДата, ДЕНЬ, -энргАбоненты.КоличествоДнейОтсрочки), МЕСЯЦ, -1), МЕСЯЦ)
		|		ИНАЧЕ КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(&ТекДата, ДЕНЬ, -энргНастройкиНачисленияПениСрезПоследних.КрайнийСрокОплаты), МЕСЯЦ, -1), МЕСЯЦ)
		|	КОНЕЦ КАК ГраницаНачислений
		|ИЗ
		|	РегистрСведений.энргНастройкиНачисленияПени.СрезПоследних(
		|			&ТекДата,
		|			Организация = &Организация
		|				И Район = &Район) КАК энргНастройкиНачисленияПениСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		|		ПО энргНастройкиНачисленияПениСрезПоследних.Организация = энргАбоненты.Организация
		|			И энргНастройкиНачисленияПениСрезПоследних.Район = энргАбоненты.Район
		|ГДЕ
		|	энргАбоненты.Ссылка = &Абонент";
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Организация = &Организация", "ИСТИНА");
	Иначе
		Запрос.УстановитьПараметр("Организация", Организация);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Район) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Район = &Район", "ИСТИНА");
	Иначе
		Запрос.УстановитьПараметр("Район", Район);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ТекДата", ТекДата);
	Запрос.УстановитьПараметр("Абонент", Абонент);

	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.ГраницаНачислений;
	Иначе	
		Возврат НачалоМесяца(ТекДата) - 1;
	КонецЕсли;
КонецФункции

Процедура ПрикрепитьФайлы(СтартоваяЗадача, СписокФайлов, Квитанция = Ложь) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗадачаПИДПрисоединенныеФайлы.Ссылка КАК Ссылка,
		|	энргЗадачаПИДПрисоединенныеФайлы.ПометкаУдаления КАК ПометкаУдаления,
		|	энргЗадачаПИДПрисоединенныеФайлы.Наименование КАК Наименование,
		|	энргЗадачаПИДПрисоединенныеФайлы.Расширение КАК Расширение,
		|	энргЗадачаПИДПрисоединенныеФайлы.ПериодНачисления КАК ПериодНачисления
		|ИЗ
		|	Справочник.энргЗадачаПИДПрисоединенныеФайлы КАК энргЗадачаПИДПрисоединенныеФайлы
		|ГДЕ
		|	энргЗадачаПИДПрисоединенныеФайлы.ВладелецФайла = &СтартоваяЗадача
		|	И энргЗадачаПИДПрисоединенныеФайлы.Квитанция = &Квитанция";
	
	Запрос.УстановитьПараметр("Квитанция", Квитанция);
	Запрос.УстановитьПараметр("СтартоваяЗадача", СтартоваяЗадача);
	
	СписокПрикрепленныхФайлов = Запрос.Выполнить().Выгрузить();

	Для каждого ПарамФайла Из СписокФайлов Цикл
	
		РасширениеФайла  = Справочники.энргКомментарииКСудебномуДелу.ПолучитьРасширениеФайла(ПарамФайла.Представление);
		ИмяБезРасширения = СтрЗаменить(ПарамФайла.Представление, "." + РасширениеФайла, "");
		
		ДатаМодификацииФайла		= ТекущаяДата();
		ПараметрыДобавляемогоФайла	= Новый Структура;
		ПараметрыДобавляемогоФайла.Вставить("ВладелецФайлов",	 			СтартоваяЗадача);
		ПараметрыДобавляемогоФайла.Вставить("Автор",						Строка(ПараметрыСеанса.ТекущийПользователь));
		ПараметрыДобавляемогоФайла.Вставить("ИмяБезРасширения",				ИмяБезРасширения);
		ПараметрыДобавляемогоФайла.Вставить("РасширениеБезТочки",			РасширениеФайла);
		ПараметрыДобавляемогоФайла.Вставить("ВремяИзменения",				МестноеВремя(ДатаМодификацииФайла, ЧасовойПоясСеанса()));
		ПараметрыДобавляемогоФайла.Вставить("ВремяИзмененияУниверсальное",	ДатаМодификацииФайла);
		
		
		Если Квитанция Тогда
			Отбор = Новый Структура("ПериодНачисления", ПарамФайла.ПериодНачисления);
		Иначе
			Отбор = Новый Структура("Наименование, Расширение", ИмяБезРасширения, РасширениеФайла);
		КонецЕсли;
		
		СтрокиТЗ = СписокПрикрепленныхФайлов.НайтиСтроки(Отбор);
		
		ТекФайл = Неопределено;
		СнятьПометку = Ложь;
		Если ЗначениеЗаполнено(СтрокиТЗ) Тогда
			ТекФайл = СтрокиТЗ[0].Ссылка;
			ПараметрыДобавляемогоФайла.Вставить("АдресФайлаВоВременномХранилище", ПарамФайла.Значение); 
		 	РаботаСФайлами.ОбновитьФайл(ТекФайл, ПараметрыДобавляемогоФайла);
			СнятьПометку = СтрокиТЗ[0].ПометкаУдаления;
		Иначе
			ТекФайл = РаботаСФайлами.ДобавитьФайл(ПараметрыДобавляемогоФайла, 	ПарамФайла.Значение);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТекФайл) Тогда
			ТекФайлОбъект = ТекФайл.ПолучитьОбъект(); 
			Если СнятьПометку Тогда
				ТекФайлОбъект.УстановитьПометкуУдаления(Ложь);
			ИначеЕсли Квитанция Тогда
			
				ТекФайлОбъект.ПериодНачисления 	= ПарамФайла.ПериодНачисления;
				ТекФайлОбъект.Квитанция			= Истина;
				ТекФайлОбъект.Записать();
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьЗадолженностьИОплаты(Задача, Перерасчет) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗадачаПИД.Организация КАК Организация,
		|	энргЗадачаПИД.Район КАК Район,
		|	энргЗадачаПИД.МКД КАК МКД,
		|	энргЗадачаПИД.Абонент КАК Абонент,
		|	энргЗадачаПИДЗадолженность.Услуга КАК Услуга,
		|	энргЗадачаПИДЗадолженность.ПериодНачисления КАК ПериодНачисления,
		|	энргЗадачаПИД.Дата КАК Дата
		|ПОМЕСТИТЬ ВТ_ОтслеживаемаяЗадолженность
		|ИЗ
		|	Задача.энргЗадачаПИД.Задолженность КАК энргЗадачаПИДЗадолженность
		|		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД КАК энргЗадачаПИД
		|		ПО энргЗадачаПИДЗадолженность.Ссылка = энргЗадачаПИД.Ссылка
		|ГДЕ
		|	энргЗадачаПИД.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргВзаиморасчетыПоМесяцамОстатки.Организация КАК Организация,
		|	энргВзаиморасчетыПоМесяцамОстатки.Район КАК Район,
		|	энргВзаиморасчетыПоМесяцамОстатки.МКД КАК МКД,
		|	энргВзаиморасчетыПоМесяцамОстатки.Абонент КАК Абонент,
		|	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
		|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления КАК ПериодНачисления,
		|	энргВзаиморасчетыПоМесяцамОстатки.Поставщик КАК Поставщик,
		|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток КАК СуммаОстаток,
		|	0 КАК Пеня
		|ПОМЕСТИТЬ ВТ_Начисления
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
		|			&ТекДата,
		|			(Организация, Район, Абонент, Услуга, ПериодНачисления) В
		|				(ВЫБРАТЬ
		|					ВТ_ОтслеживаемаяЗадолженность.Организация КАК Организация,
		|					ВТ_ОтслеживаемаяЗадолженность.Район КАК Район,
		//|					ВТ_ОтслеживаемаяЗадолженность.МКД КАК МКД,
		|					ВТ_ОтслеживаемаяЗадолженность.Абонент КАК Абонент,
		|					ВТ_ОтслеживаемаяЗадолженность.Услуга КАК Услуга,
		|					ВТ_ОтслеживаемаяЗадолженность.ПериодНачисления КАК ПериодНачисления
		|				ИЗ
		|					ВТ_ОтслеживаемаяЗадолженность КАК ВТ_ОтслеживаемаяЗадолженность)) КАК энргВзаиморасчетыПоМесяцамОстатки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	энргОбъемыПениОбороты.Организация,
		|	энргОбъемыПениОбороты.Район,
		|	энргОбъемыПениОбороты.МКД,
		|	энргОбъемыПениОбороты.Абонент,
		|	энргОбъемыПениОбороты.Услуга,
		|	энргОбъемыПениОбороты.ПериодНачисления,
		|	NULL,
		|	0,
		|	энргОбъемыПениОбороты.СуммаОстаток
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчетыПоПени.Остатки(
		|			&ТекДата,
		|			(Организация, Район, МКД, Абонент, Услуга, ПериодНачисления) В
		|				(ВЫБРАТЬ
		|					ВТ_ОтслеживаемаяЗадолженность.Организация КАК Организация,
		|					ВТ_ОтслеживаемаяЗадолженность.Район КАК Район,
		|					ВТ_ОтслеживаемаяЗадолженность.МКД КАК МКД,
		|					ВТ_ОтслеживаемаяЗадолженность.Абонент КАК Абонент,
		|					ВТ_ОтслеживаемаяЗадолженность.Услуга КАК Услуга,
		|					ВТ_ОтслеживаемаяЗадолженность.ПериодНачисления КАК ПериодНачисления
		|				ИЗ
		|					ВТ_ОтслеживаемаяЗадолженность КАК ВТ_ОтслеживаемаяЗадолженность)) КАК энргОбъемыПениОбороты
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	энргВзаиморасчетыПоМесяцам.Организация,
		|	энргВзаиморасчетыПоМесяцам.Район,
		|	энргВзаиморасчетыПоМесяцам.МКД,
		|	энргВзаиморасчетыПоМесяцам.Абонент,
		|	энргВзаиморасчетыПоМесяцам.Услуга,
		|	энргВзаиморасчетыПоМесяцам.ПериодНачисления,
		|	энргВзаиморасчетыПоМесяцам.Поставщик,
		|	энргВзаиморасчетыПоМесяцам.Сумма,
		|	NULL
		|ИЗ
		|	ВТ_ОтслеживаемаяЗадолженность КАК ВТ_ОтслеживаемаяЗадолженность
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.энргВзаиморасчетыПоМесяцам КАК энргВзаиморасчетыПоМесяцам
		|		ПО ВТ_ОтслеживаемаяЗадолженность.Организация = энргВзаиморасчетыПоМесяцам.Организация
		|			И ВТ_ОтслеживаемаяЗадолженность.Район = энргВзаиморасчетыПоМесяцам.Район
		|			И ВТ_ОтслеживаемаяЗадолженность.МКД = энргВзаиморасчетыПоМесяцам.МКД
		|			И ВТ_ОтслеживаемаяЗадолженность.Абонент = энргВзаиморасчетыПоМесяцам.Абонент
		|			И ВТ_ОтслеживаемаяЗадолженность.Услуга = энргВзаиморасчетыПоМесяцам.Услуга
		|			И ВТ_ОтслеживаемаяЗадолженность.ПериодНачисления = энргВзаиморасчетыПоМесяцам.ПериодНачисления
		|ГДЕ
		|	энргВзаиморасчетыПоМесяцам.Регистратор = &Перерасчет
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	энргВзаиморасчетыПоПени.Организация,
		|	энргВзаиморасчетыПоПени.Район,
		|	энргВзаиморасчетыПоПени.МКД,
		|	энргВзаиморасчетыПоПени.Абонент,
		|	энргВзаиморасчетыПоПени.Услуга,
		|	энргВзаиморасчетыПоПени.ПериодНачисления,
		|	NULL,
		|	NULL,
		|	энргВзаиморасчетыПоПени.Сумма
		|ИЗ
		|	ВТ_ОтслеживаемаяЗадолженность КАК ВТ_ОтслеживаемаяЗадолженность
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.энргВзаиморасчетыПоПени КАК энргВзаиморасчетыПоПени
		|		ПО ВТ_ОтслеживаемаяЗадолженность.Организация = энргВзаиморасчетыПоПени.Организация
		|			И ВТ_ОтслеживаемаяЗадолженность.Район = энргВзаиморасчетыПоПени.Район
		|			И ВТ_ОтслеживаемаяЗадолженность.МКД = энргВзаиморасчетыПоПени.МКД
		|			И ВТ_ОтслеживаемаяЗадолженность.Абонент = энргВзаиморасчетыПоПени.Абонент
		|			И ВТ_ОтслеживаемаяЗадолженность.Услуга = энргВзаиморасчетыПоПени.Услуга
		|			И ВТ_ОтслеживаемаяЗадолженность.ПериодНачисления = энргВзаиморасчетыПоПени.ПериодНачисления
		|ГДЕ
		|	энргВзаиморасчетыПоПени.Регистратор = &Перерасчет
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргВзаиморасчетыПоМесяцам.Регистратор КАК Регистратор,
		|	СУММА(энргВзаиморасчетыПоМесяцам.Сумма) КАК Сумма,
		|	ЛОЖЬ КАК Флаг,
		|	энргВзаиморасчетыПоМесяцам.Период КАК Дата,
		|	0 КАК Пеня
		|ПОМЕСТИТЬ ВТ_Оплаты
		|ИЗ
		|	ВТ_ОтслеживаемаяЗадолженность КАК ВТ_ОтслеживаемаяЗадолженность
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.энргВзаиморасчетыПоМесяцам КАК энргВзаиморасчетыПоМесяцам
		|		ПО ВТ_ОтслеживаемаяЗадолженность.Организация = энргВзаиморасчетыПоМесяцам.Организация
		|			И ВТ_ОтслеживаемаяЗадолженность.Район = энргВзаиморасчетыПоМесяцам.Район
		|			И ВТ_ОтслеживаемаяЗадолженность.МКД = энргВзаиморасчетыПоМесяцам.МКД
		|			И ВТ_ОтслеживаемаяЗадолженность.Абонент = энргВзаиморасчетыПоМесяцам.Абонент
		|			И ВТ_ОтслеживаемаяЗадолженность.Услуга = энргВзаиморасчетыПоМесяцам.Услуга
		|			И ВТ_ОтслеживаемаяЗадолженность.ПериодНачисления = энргВзаиморасчетыПоМесяцам.ПериодНачисления
		|			И ВТ_ОтслеживаемаяЗадолженность.Дата < энргВзаиморасчетыПоМесяцам.Регистратор.Дата
		|ГДЕ
		|	энргВзаиморасчетыПоМесяцам.Регистратор.Дата <= &ТекДата
		|	И энргВзаиморасчетыПоМесяцам.Регистратор <> &Перерасчет
		|
		|СГРУППИРОВАТЬ ПО
		|	энргВзаиморасчетыПоМесяцам.Регистратор,
		|	энргВзаиморасчетыПоМесяцам.Период
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	энргВзаиморасчетыПоПени.Регистратор,
		|	0,
		|	ЛОЖЬ,
		|	энргВзаиморасчетыПоПени.Период,
		|	энргВзаиморасчетыПоПени.Сумма
		|ИЗ
		|	РегистрНакопления.энргВзаиморасчетыПоПени КАК энргВзаиморасчетыПоПени
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ОтслеживаемаяЗадолженность КАК ВТ_ОтслеживаемаяЗадолженность
		|		ПО энргВзаиморасчетыПоПени.Организация = ВТ_ОтслеживаемаяЗадолженность.Организация
		|			И энргВзаиморасчетыПоПени.Район = ВТ_ОтслеживаемаяЗадолженность.Район
		|			И энргВзаиморасчетыПоПени.ПериодНачисления = ВТ_ОтслеживаемаяЗадолженность.ПериодНачисления
		|			И энргВзаиморасчетыПоПени.МКД = ВТ_ОтслеживаемаяЗадолженность.МКД
		|			И энргВзаиморасчетыПоПени.Абонент = ВТ_ОтслеживаемаяЗадолженность.Абонент
		|			И энргВзаиморасчетыПоПени.Регистратор.Дата > ВТ_ОтслеживаемаяЗадолженность.Дата
		|ГДЕ
		|	энргВзаиморасчетыПоПени.Регистратор.Дата <= &ТекДата
		|	И энргВзаиморасчетыПоПени.Регистратор <> &Перерасчет
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Начисления.Организация КАК Организация,
		|	ВТ_Начисления.Район КАК Район,
		|	ВТ_Начисления.МКД КАК МКД,
		|	ВТ_Начисления.Абонент КАК Абонент,
		|	ВТ_Начисления.Услуга КАК Услуга,
		|	ВТ_Начисления.ПериодНачисления КАК ПериодНачисления,
		|	МАКСИМУМ(ВТ_Начисления.Поставщик) КАК Поставщик,
		|	СУММА(ВТ_Начисления.Пеня) КАК Пеня
		|ПОМЕСТИТЬ ВТ_ПеняПоставщиком
		|ИЗ
		|	ВТ_Начисления КАК ВТ_Начисления
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Начисления.Организация,
		|	ВТ_Начисления.Район,
		|	ВТ_Начисления.МКД,
		|	ВТ_Начисления.Абонент,
		|	ВТ_Начисления.Услуга,
		|	ВТ_Начисления.ПериодНачисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Начисления.Организация КАК Организация,
		|	ВТ_Начисления.Район КАК Район,
		|	ВТ_Начисления.МКД КАК МКД,
		|	ВТ_Начисления.Абонент КАК Абонент,
		|	ВТ_Начисления.Услуга КАК Услуга,
		|	ВТ_Начисления.ПериодНачисления КАК ПериодНачисления,
		|	ЕСТЬNULL(ВТ_Начисления.Поставщик, ВТ_ПеняПоставщиком.Поставщик) КАК Поставщик,
		|	СУММА(ВТ_Начисления.СуммаОстаток) КАК СуммаОстаток,
		|	СУММА(ВТ_Начисления.Пеня) КАК Пеня,
		|	0 КАК СуммаНДС
		|ИЗ
		|	ВТ_Начисления КАК ВТ_Начисления
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПеняПоставщиком КАК ВТ_ПеняПоставщиком
		|		ПО ВТ_Начисления.Организация = ВТ_ПеняПоставщиком.Организация
		|			И ВТ_Начисления.Район = ВТ_ПеняПоставщиком.Район
		|			И ВТ_Начисления.МКД = ВТ_ПеняПоставщиком.МКД
		|			И ВТ_Начисления.Абонент = ВТ_ПеняПоставщиком.Абонент
		|			И ВТ_Начисления.Услуга = ВТ_ПеняПоставщиком.Услуга
		|			И ВТ_Начисления.ПериодНачисления = ВТ_ПеняПоставщиком.ПериодНачисления
		|			И (ВТ_Начисления.СуммаОстаток = 0)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Начисления.Организация,
		|	ВТ_Начисления.Район,
		|	ВТ_Начисления.МКД,
		|	ВТ_Начисления.Абонент,
		|	ВТ_Начисления.Услуга,
		|	ВТ_Начисления.ПериодНачисления,
		|	ЕСТЬNULL(ВТ_Начисления.Поставщик, ВТ_ПеняПоставщиком.Поставщик)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПериодНачисления,
		|	Услуга
		|АВТОУПОРЯДОЧИВАНИЕ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Оплаты.Регистратор КАК Регистратор,
		|	СУММА(ВТ_Оплаты.Сумма) КАК Сумма,
		|	ВТ_Оплаты.Флаг КАК Флаг,
		|	ВТ_Оплаты.Дата КАК Дата,
		|	СУММА(ВТ_Оплаты.Пеня) КАК Пеня
		|ИЗ
		|	ВТ_Оплаты КАК ВТ_Оплаты
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Оплаты.Регистратор,
		|	ВТ_Оплаты.Флаг,
		|	ВТ_Оплаты.Дата";
	
	Запрос.УстановитьПараметр("Ссылка", Задача);
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
	Запрос.УстановитьПараметр("Перерасчет", Перерасчет);
	
	Возврат Запрос.ВыполнитьПакет();
КонецФункции

Функция ПолучитьЗадолженностьДляПерерасчета(ТекДата, Организация, Район, Строение, Абонент) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
			"ВЫБРАТЬ
			|	энргВзаиморасчетыПоМесяцамОстатки.Абонент КАК Абонент,
			|	энргВзаиморасчетыПоМесяцамОстатки.Услуга КАК Услуга,
			|	энргВзаиморасчетыПоМесяцамОстатки.ПериодНачисления КАК ПериодНачисления,
			|	энргВзаиморасчетыПоМесяцамОстатки.Поставщик КАК Поставщик,
			|	энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток КАК Долг,
			|	0 КАК Пеня
			|ПОМЕСТИТЬ ВТ_Задолженность
			|ИЗ
			|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
			|			&ТекДата,
			|			Организация = &Организация
			|				И Район = &Район
			|				И МКД = &МКД
			|				И Абонент = &Абонент) КАК энргВзаиморасчетыПоМесяцамОстатки
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	энргВзаиморасчетыПоПениОстатки.Абонент,
			|	NULL,
			|	энргВзаиморасчетыПоПениОстатки.ПериодНачисления,
			|	NULL,
			|	0,
			|	энргВзаиморасчетыПоПениОстатки.СуммаОстаток
			|ИЗ
			|	РегистрНакопления.энргВзаиморасчетыПоПени.Остатки(
			|			&ТекДата,
			|			Организация = &Организация
			|				И Район = &Район
			|				И МКД = &МКД
			|				И Абонент = &Абонент) КАК энргВзаиморасчетыПоПениОстатки
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТ_Задолженность.Абонент КАК Абонент,
			|	ВТ_Задолженность.Услуга КАК Услуга,
			|	ВТ_Задолженность.ПериодНачисления КАК ПериодНачисления,
			|	ВТ_Задолженность.Поставщик КАК Поставщик,
			|	СУММА(ВТ_Задолженность.Долг) КАК СуммаПерерасчет,
			|	СУММА(ВТ_Задолженность.Пеня) КАК Пеня
			|ИЗ
			|	ВТ_Задолженность КАК ВТ_Задолженность
			|
			|СГРУППИРОВАТЬ ПО
			|	ВТ_Задолженность.Абонент,
			|	ВТ_Задолженность.Услуга,
			|	ВТ_Задолженность.ПериодНачисления,
			|	ВТ_Задолженность.Поставщик";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("МКД", Строение);
	Запрос.УстановитьПараметр("Абонент", Абонент);
	Запрос.УстановитьПараметр("ТекДата", ТекДата);
	
	Возврат Запрос.Выполнить();
КонецФункции

Процедура ЗаполнитьНаименованиеИЭтап(Объект, ПредЭтап = Неопределено, ЭтапНовЗадачи = Неопределено) Экспорт 
	Перем Реквизит, СледЗадача;
	
	СтрукОчистки = Новый Структура("Наименование, ДатаСледЭтапа, Роль");
	ЗаполнитьЗначенияСвойств(Объект, СтрукОчистки);
	
	ДатаЗадачи = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
	Если НЕ ЗначениеЗаполнено(Объект.Схема) Тогда
		Если Не ЗаполнитьСхемуОбъекта(ДатаЗадачи, Объект) Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтапНовЗадачи = Неопределено Тогда
		Если ПредЭтап = Неопределено И Не ЗначениеЗаполнено(Объект.Основание) Тогда
			ПредЭтап = Справочники.энргВидыОперацийПИД.ПустаяСсылка();
			Если ЗначениеЗаполнено(Объект.Схема.Этапы) Тогда
				Объект.Этап = Объект.Схема.Этапы[0];
			КонецЕсли;
		КонецЕсли;
		Если ПредЭтап <> Неопределено Тогда
			Объект.Этап = Справочники.энргСхемыПИД.ПолучитьСледующийЭтап(Объект.Схема, ПредЭтап);
		КонецЕсли;	
	Иначе
		Объект.Этап = ЭтапНовЗадачи;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Этап) Тогда
		Возврат;
	КонецЕсли;
	Объект.Роль = Объект.Этап.Роль;
	
//подэтапы
	Если Объект.Этап.ЕстьПодэтапы Тогда
		
		РезультатЗапроса = ЗапросСроковПодэтапов(ДатаЗадачи, Объект);
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Первая = Истина;
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ = Объект.Подэтапы.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
			СтрокаТЧ.IDЭтапа = Новый УникальныйИдентификатор;
			Если Первая Тогда
				СтрокаТЧ.Текущий	= Истина;
				СтрокаТЧ.ДатаНачала = ДатаЗадачи;
				Если ЗначениеЗаполнено(СтрокаТЧ.Продолжительность) Тогда
					СтрокаТЧ.ДатаОкончания = ДатаЗадачи + СтрокаТЧ.Продолжительность*24*3600;
				КонецЕсли;
			КонецЕсли;
			
			Первая = ?(СтрокаТЧ.Параллельно, Первая, Ложь);
		КонецЦикла;
	Иначе
		РезультатЗапроса = ЗапросСроковПодэтапов(ДатаЗадачи, Объект);
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Продолжительность) Тогда 
			Объект.ДатаСледЭтапа = ДатаЗадачи + 24 * 3600 * Выборка.Продолжительность;
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.ЗадачаЮЛ Тогда
		Если Объект.Этап.Тип = Перечисления.энргТипыЭтапов.СудебнаяРабота Тогда
			Объект.Наименование = "Судебное дело по договору """ + Объект.Договор + """ под номером """ + Объект.НомерСудебногоДела;
		ИначеЕсли Объект.Этап.Тип = Перечисления.энргТипыЭтапов.Банкротство Тогда
			Объект.Наименование = "Дело о банкротстве по договору """ + Объект.Договор + """ на этапе """ + Объект.Этап;
		ИначеЕсли Объект.Этап.Тип = Перечисления.энргТипыЭтапов.СписаниеЗадолженности Тогда
			Объект.Наименование = "Дело о списании задолженности по договору """ + Объект.Договор + """ на этапе """ + Объект.Этап;
		Иначе
			Объект.Наименование = "Договор """ + Объект.Договор + """ на этапе """ + Объект.Этап;
		КонецЕсли;
	Иначе
		Если Объект.Этап.Тип = Перечисления.энргТипыЭтапов.СудебнаяРабота Тогда
			Объект.Наименование = "Судебное дело по абоненту """ + Объект.Абонент + """ под номером """ + Объект.НомерСудебногоДела + """";
		Иначе
			Объект.Наименование = "Абонент """ + Объект.Абонент + """ на этапе """ + Объект.Этап + """";
		КонецЕсли;
	КонецЕсли;
	Объект.ДополнительныеСвойства.Вставить("НеМояЗадача", Истина);
КонецПроцедуры

Функция СоздатьПодчиненнуюЗадачу(Отказ, Знач СледЭтап, Знач ОбъектЗадача, Знач ПарамСудебнойРаботы = Неопределено, Знач Задолженность = Неопределено, Знач ЗначРеквизитов = Неопределено, ПропуститьПроверкуНаДублирование = Ложь) Экспорт
	
	Перем Реквизит, СледЗадача;
	
	ЭтоСтрук  	  = ТипЗнч(ОбъектЗадача) = Тип("Структура");
	МетаРеквизиты = Метаданные.Задачи.энргЗадачаПИД.Реквизиты;
	МетаТаблицы	  = Метаданные.Задачи.энргЗадачаПИД.ТабличныеЧасти;
	
	// Добавлено для возврата!-->
	ЕстьСледЗадача = Ложь;

	СледЗадачаПомеченная = ПолучитьЗадачуПоОснованию(ОбъектЗадача.Ссылка);
	Если не СледЗадачаПомеченная = Неопределено Тогда
		СледЗадача 					= СледЗадачаПомеченная.ПолучитьОбъект();
		СледЗадача.ПометкаУдаления 	= Ложь;
		СледЗадача.Исполнитель		= Неопределено;
		
		ЕстьСледЗадача				= Истина;
		
		Для каждого ТабличнаяЧасть Из МетаТаблицы Цикл
			СледЗадача[ТабличнаяЧасть.Имя].Очистить();
		КонецЦикла;
	Иначе
		СледЗадача = Задачи.энргЗадачаПИД.СоздатьЗадачу();
	КонецЕсли;
	
	СледЗадача.ДополнительныеСвойства.Вставить("ПропуститьПроверкуНаДублирование", ПропуститьПроверкуНаДублирование);
	// <--Добавлено для возврата!
		
	Для каждого Реквизит Из МетаРеквизиты Цикл
		Если ЭтоСтрук Тогда
			ОбъектЗадача.Свойство(Реквизит.Имя, СледЗадача[Реквизит.Имя]);
		Иначе
			СледЗадача[Реквизит.Имя] = ОбъектЗадача[Реквизит.Имя]
		КонецЕсли;
	КонецЦикла;
 	СледЗадача.Основание 			= ОбъектЗадача.Ссылка;
	СледЗадача.Этап		 			= СледЭтап;
	СледЗадача.ПринятоВРаботу 		= Ложь;
	СледЗадача.Комментарий 			= "";
	СледЗадача.ТребуетПодтверждения = Ложь;
	СледЗадача.Перерасчет			= Неопределено;
	
	СледЗадача.Дата		 = ТекущаяДатаСеанса();
	
	Если ТипЗнч(ЗначРеквизитов) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(СледЗадача, ЗначРеквизитов);
	КонецЕсли;
	
	СледЗадача.ДополнительныеСвойства.Вставить("НеМояЗадача", Истина);
	
	ЗаполнитьНаименованиеИЭтап(СледЗадача,, СледЭтап);
	
	// Перенос задолженности
	СписокДолгов = ?(Задолженность = Неопределено, ОбъектЗадача.Задолженность, Задолженность);

	СледЗадача.Задолженность.Очистить();
	Для каждого СтрокаДолг Из СписокДолгов Цикл
		СтрокаТЧ = СледЗадача.Задолженность.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаДолг);
	КонецЦикла;
	
	Если СледЭтап.Тип = Перечисления.энргТипыЭтапов.СудебнаяРабота Тогда
		СледЗадача.СтатусСудебногоДела = Справочники.энргСтатусыДелСудебнойРаботы.НаРассмотрении;
	КонецЕсли;

	Начисления = Новый Структура("Начисления");
	ЗаполнитьЗначенияСвойств(Начисления, ОбъектЗадача);
	Начисления = Начисления.Начисления;
	Если Начисления <> Неопределено Тогда
		Для каждого ТекРегистратор Из Начисления Цикл
			Если ТипЗнч(Начисления) = Тип("ЗадачаТабличнаяЧасть.энргЗадачаПИД.Начисления") Тогда
				СтрокаТЧ = СледЗадача.Начисления.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, ТекРегистратор);
			Иначе
				СтрокаТЧ = СледЗадача.Начисления.Добавить();
				СтрокаТЧ.Регистратор = ТекРегистратор;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	
	Если ПарамСудебнойРаботы <> Неопределено Тогда
	    ЗаполнитьЗначенияСвойств(СледЗадача, ПарамСудебнойРаботы);
		
		Регистраторы = Неопределено;
		Если ПарамСудебнойРаботы.Свойство("Регистраторы", Регистраторы) Тогда
			СледЗадача.Начисления.Очистить();
			Для каждого ТекРегистратор Из Регистраторы Цикл
				Если ЗначениеЗаполнено(ТекРегистратор.Регистратор) Тогда
					СтрокаТЧ = СледЗадача.Начисления.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЧ, ТекРегистратор); 
				КонецЕсли;
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
	
	СледЗадача.ТаблицаРасчётаПени.Очистить();
	Если СледЭтап.Тип = Перечисления.энргТипыЭтапов.СудебнаяРабота ИЛИ СледЭтап.Тип = Перечисления.энргТипыЭтапов.ИсполнительнаяРабота Тогда
		ПарамПени = Новый Структура("ТаблицаРасчётаПени", Неопределено);
		ЗаполнитьЗначенияСвойств(ПарамПени, ОбъектЗадача);
		
		Если ЗначениеЗаполнено(ПарамПени.ТаблицаРасчётаПени) Тогда
			
			Для каждого СтрокаТЗ Из ПарамПени.ТаблицаРасчётаПени Цикл
				СтрокаТЧ = СледЗадача.ТаблицаРасчётаПени.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТЗ);
			КонецЦикла;
			
		Иначе
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	энргНастройкаРасчетаПениСрезПоследних.Организация КАК Организация,
				|	энргНастройкаРасчетаПениСрезПоследних.НастройкаРасчета КАК НастройкаРасчета
				|ИЗ
				|	РегистрСведений.энргНастройкаРасчетаПени.СрезПоследних(&ТекДата, Организация = &Организация) КАК энргНастройкаРасчетаПениСрезПоследних";
			
			Запрос.УстановитьПараметр("Организация", СледЗадача.Организация);
			Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Выборка = РезультатЗапроса.Выбрать();
			
			Если Выборка.Следующий() Тогда
				ТаблицаРасчётаПени = Выборка.НастройкаРасчета.Получить();
				
				Для каждого СтрокаТЗ Из ТаблицаРасчётаПени Цикл
				
					СтрокаТЧ = СледЗадача.ТаблицаРасчётаПени.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТЗ);
				
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	СледЗадача.ТаблицаРасчётаПени.Сортировать("От");	
	
	Для каждого СтрокаТЗ Из ОбъектЗадача.СудебныеИнстанции Цикл
		СтрокаТЧ = СледЗадача.СудебныеИнстанции.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТЗ);
	КонецЦикла;
	
	Для каждого СтрокаТЗ Из ОбъектЗадача.Суд Цикл
		СтрокаТЧ = СледЗадача.Суд.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТЗ);
	КонецЦикла;

	Попытка
		СледЗадача.Записать();		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		Отказ = Истина;
		Возврат Неопределено;
	КонецПопытки;
	
	// Отправка на почту если это судебное дело и повторная задача
	Если ЕстьСледЗадача и СледЭтап.Тип = Перечисления.энргТипыЭтапов.СудебнаяРабота Тогда
		Результат 	= РегистрыСведений.энргНастройкиЮрОтдела.ПолучитьНачальника(СледЗадача.Организация,СледЗадача.Район);
		Выборка 	= Результат.Выбрать();
		
		Запрос = новый Запрос;
		Запрос.Текст =" 
			|ВЫБРАТЬ
			|	УчетныеЗаписиЭлектроннойПочты.Ссылка КАК Отправитель
			|ИЗ
			|	Справочник.УчетныеЗаписиЭлектроннойПочты КАК УчетныеЗаписиЭлектроннойПочты
			|ГДЕ
			|	УчетныеЗаписиЭлектроннойПочты.Ссылка = ЗНАЧЕНИЕ(Справочник.УчетныеЗАписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты)";
		РезультатОтправитель = Запрос.Выполнить();
		ВыборкаОтправитель 	= РезультатОтправитель.Выбрать();
		ВыборкаОтправитель.следующий();
		Отправитель 		= ВыборкаОтправитель.Отправитель;
		Если не ЗначениеЗаполнено(Отправитель) Тогда
			ЗаписьЖурналаРегистрации("Уведомление пользователей юридического отдела",УровеньЖурналаРегистрации.Ошибка,,,"Не заполнена системная учетная запись.");
			Возврат Неопределено;
		КонецЕсли;
		
		Пока Выборка.Следующий() Цикл
			Попытка 	
				
				Если не ЗначениеЗаполнено(СокрЛП(Выборка.Почта)) Тогда
					//ВызватьИсключение "Не указана почта у пользователя: " + Выборка.Начальник;
					Продолжить;
				КонецЕсли;
				
				Тело 				= "Сотрудник: " + ОбъектЗадача.Ссылка.Исполнитель + " передал юристу: " + СледЗадача.Исполнитель + " изменный пакет документов по абоненту: " + СокрЛП(СледЗадача.Абонент) + "(" + СокрЛП(СледЗадача.ЛицевойСчет) + ") в срок: " + Формат(СледЗадача.СрокВыполненияЗадачи,"ДФ=dd.MM.yyyy");
				ПараметрыОтправки 	= Новый Структура("Кому, Тема, Тело", Выборка.Почта, "Уведомление о возврате на доработку", Тело);
				
				РаботаСПочтовымиСообщениями.ОтправитьПочтовоеСообщение(Отправитель, ПараметрыОтправки);
				
				УровеньЖурнала 	 = УровеньЖурналаРегистрации.Информация;
				ТекстДляЖурнала  = "Успешно отправлено по начальнику: " + Выборка.Начальник;
				
			Исключение
				УровеньЖурнала 	 = УровеньЖурналаРегистрации.Ошибка;
				ТекстДляЖурнала  = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());			
			КонецПопытки;
			
			ЗаписьЖурналаРегистрации("Уведомление пользователей юридического отдела",УровеньЖурнала,,,ТекстДляЖурнала);
		КонецЦикла;		
	КонецЕсли;
	
	Возврат СледЗадача.Ссылка;
	
КонецФункции

#Область ЗаполнениеПечатныхФорм

Функция ПечатьЗаявлениеОВынесенииСудебногоПриказа(Задача, СписокПрикреплённыхДокументов = Неопределено, СтруктураДолга = Неопределено) Экспорт 

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗадачаПИД.Ссылка КАК Задача,
		|	энргЗадачаПИД.Абонент КАК Абонент,
		|	энргЗадачаПИДСудебныеИнстанции.СудебнаяИинстанция КАК Суд,
		|	Организации.Ссылка КАК Организация,
		|	Организации.НаименованиеПолное КАК НаименованиеПолноеОрганизация,
		|	энргАбоненты.ФизЛицо КАК ФизЛицо,
		|	энргЗадачаПИД.СуммаЗадолженности КАК СуммаЗадолженности,
		|	энргЗадачаПИД.ПериодЗадолженностиНачало КАК ПериодЗадолженностиНачало,
		|	энргЗадачаПИД.ПериодЗадолженностиКонец КАК ПериодЗадолженностиКонец,
		|	энргЗадачаПИД.Дата КАК Дата,
		|	энргЗадачаПИД.СтартоваяЗадача КАК СтартоваяЗадача,
		|	энргАбоненты.ВидОбъекта КАК ВидОбъекта,
		|	энргАбоненты.КлючПомещения КАК КлючПомещения,
		|	энргАбонентыКонтактнаяИнформация.Представление КАК АдресОбъекта,
		|	энргЗадачаПИД.Район КАК Район
		|ПОМЕСТИТЬ ВТ_Задача
		|ИЗ
		|	Задача.энргЗадачаПИД КАК энргЗадачаПИД
		|		ЛЕВОЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.СудебныеИнстанции КАК энргЗадачаПИДСудебныеИнстанции
		|		ПО энргЗадачаПИД.Ссылка = энргЗадачаПИДСудебныеИнстанции.Ссылка
		|			И (энргЗадачаПИДСудебныеИнстанции.Текущая)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
		|		ПО энргЗадачаПИД.Организация = Организации.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
		|			ПО энргАбоненты.Ссылка = энргАбонентыКонтактнаяИнформация.Ссылка
		|				И (энргАбонентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(справочник.ВидыконтактнойИнформации.АдресОбъекта))
		|		ПО энргЗадачаПИД.Абонент = энргАбоненты.Ссылка
		|ГДЕ
		|	энргЗадачаПИД.Ссылка = &Задача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Задача.Организация КАК Организация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК АдресОрганизация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ТелефонОрганизация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ФаксОрганизация,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК АдресЭлектроннойПочтыОрганизация
		|ПОМЕСТИТЬ ВТ_ДанныеОрганизации
		|ИЗ
		|	ВТ_Задача КАК ВТ_Задача
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
		|		ПО ВТ_Задача.Организация = ОрганизацииКонтактнаяИнформация.Ссылка
		|			И (ОрганизацииКонтактнаяИнформация.Вид В (ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонОрганизации), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксОрганизации), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailОрганизации)))
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Задача.Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Задача.ФизЛицо КАК ФизЛицо,
		|	энргКонтрагенты.бестФамилия КАК Фамилия,
		|	энргКонтрагенты.бестИмя КАК Имя,
		|	энргКонтрагенты.бестОтчество КАК Отчество,
		|	энргКонтрагенты.НаименованиеПолное КАК НаименованиеПолное,
		|	энргКонтрагенты.ИНН КАК ИНН,
		|	энргКонтрагенты.бестДатаРождения КАК ДатаРождения,
		|	энргКонтрагенты.МестоРождения КАК МестоРождения
		|ПОМЕСТИТЬ ВТ_ДанныеФизЛица
		|ИЗ
		|	ВТ_Задача КАК ВТ_Задача
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
		|		ПО ВТ_Задача.ФизЛицо = энргКонтрагенты.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ДанныеФизЛица.ФизЛицо КАК ФизЛицо,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ЮрАдресАбонента,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ФактАдресАбонента,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ТелефонАбонента,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ФаксАбонента,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргКонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтрагента)
		|				ТОГДА энргКонтрагентыКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ЭлАдресАбонента
		|ПОМЕСТИТЬ ВТ_ДанныеКонтрагента
		|ИЗ
		|	ВТ_ДанныеФизЛица КАК ВТ_ДанныеФизЛица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты.КонтактнаяИнформация КАК энргКонтрагентыКонтактнаяИнформация
		|		ПО ВТ_ДанныеФизЛица.ФизЛицо = энргКонтрагентыКонтактнаяИнформация.Ссылка
		|			И (энргКонтрагентыКонтактнаяИнформация.Вид В (ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксКонтрагента), ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтрагента)))
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ДанныеФизЛица.ФизЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыФизическихЛицСрезПоследних.Контрагент КАК Абонент,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ДокументыФизическихЛицСрезПоследних.ВидДокумента = ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.ПаспортРФ)
		|				ТОГДА ДокументыФизическихЛицСрезПоследних.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК Паспорт,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ДокументыФизическихЛицСрезПоследних.ВидДокумента = ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.СНИЛС)
		|				ТОГДА ДокументыФизическихЛицСрезПоследних.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК СНИЛС
		|ПОМЕСТИТЬ ВТ_ДокументыАбонента
