		ПараметрыШапки.Вставить("АбонентФИОКраткое", АбонентФИОКраткое);

		// Данные абонента
		АдресАбонента = "";
		Префикс		  = "";
		Если ЗначениеЗаполнено(Выборка.ЮрАдресАбонента) Тогда
			АдресАбонента = "Адрес: " + Выборка.АдресОрганизация;
			Префикс		  = "; ";
		ИначеЕсли ЗначениеЗаполнено(Выборка.ФактАдресАбонента) Тогда
			АдресАбонента = "Адрес: " + Выборка.ФактАдресАбонента;
			Префикс		  = "; ";
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ТелефонАбонента) Тогда
			АдресАбонента = АдресАбонента + Префикс + "Тел.: " + Выборка.ТелефонАбонента;
			Префикс		  = "; ";
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ФаксАбонента) Тогда
			АдресАбонента = АдресАбонента + Префикс + "Факс: " + Выборка.ФаксАбонента;
			Префикс			 = "; ";
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ЭлАдресАбонента) Тогда
			АдресАбонента = АдресАбонента + Префикс + "Email: " + Выборка.ЭлАдресАбонента;
		КонецЕсли;
		ПараметрыШапки.Вставить("АдресАбонента", АдресАбонента);
		
		// Паспортные данные абонента
		АбонентПаспортныеДанные = АбонентФИОКраткое;
		Если ЗначениеЗаполнено(Выборка.ДатаРождения) Тогда
			АбонентПаспортныеДанные = АбонентПаспортныеДанные + ", " + Выборка.ДатаРождения +
				?(ЗначениеЗаполнено(Выборка.МестоРождения), " в " + Выборка.МестоРождения, "");
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.Паспорт) Тогда	
			АбонентПаспортныеДанные = АбонентПаспортныеДанные + ", паспорт " + Выборка.Паспорт;
		ИначеЕсли ЗначениеЗаполнено(Выборка.ИНН) Тогда	
			АбонентПаспортныеДанные = АбонентПаспортныеДанные + ", ИНН №" + Выборка.ИНН;
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.СНИЛС) Тогда	
			АбонентПаспортныеДанные = АбонентПаспортныеДанные + ", СНИЛС " + Выборка.СНИЛС;
		КонецЕсли;
		ПараметрыШапки.Вставить("АбонентПаспортныеДанные", АбонентПаспортныеДанные);
		
		// Вид и доля собственности
		Префикс = "";
		Если ЗначениеЗаполнено(Выборка.ВидОбъекта) Тогда
			Если ЗначениеЗаполнено(Выборка.ДоляСобственностиЗнаменатель) И Выборка.ДоляСобственностиЧислитель <> Выборка.ДоляСобственностиЗнаменатель Тогда
				ДоляАбонента = НРег((Выборка.ВидОбъекта)) + ?(ЗначениеЗаполнено(Выборка.ДоляСобственностиЗнаменатель),
						" в доле " + Выборка.ДоляСобственностиЧислитель + "/" + Выборка.ДоляСобственностиЗнаменатель, "");
			Иначе
				ДоляАбонента = Выборка.ВидОбъекта;
			КонецЕсли;
		КонецЕсли;
		ПараметрыШапки.Вставить("ДоляАбонента", ДоляАбонента);
		
		// Жильцы абонента
		ВыборкаЖильцы.Сбросить();
		Отбор 		= Новый Структура("Задача", Выборка.Задача);
		Префикс		= "";
		ПрефиксФИО	= "";
		ПрефиксРод	= "";
		Пока ВыборкаЖильцы.НайтиСледующий(Отбор) Цикл
			АбонентыФИОсДМР = АбонентыФИОсДМР + Префикс + ?(ЗначениеЗаполнено(ВыборкаЖильцы.бестФамилия), ВыборкаЖильцы.бестФамилия + 
								?(ЗначениеЗаполнено(ВыборкаЖильцы.бестИмя), " " + Лев(ВыборкаЖильцы.бестИмя, 1)+".", "")  +
								?(ЗначениеЗаполнено(ВыборкаЖильцы.бестОтчество), " " + Лев(ВыборкаЖильцы.бестОтчество, 1), "")+".", ВыборкаЖильцы.Жилец) +
					?(ЗначениеЗаполнено(ВыборкаЖильцы.бестДатаРождения), ", д.р. " + Формат(ВыборкаЖильцы.бестДатаРождения, "ДФ=dd.MM.yyyy"), "") +
					?(ЗначениеЗаполнено(ВыборкаЖильцы.МестоРождения), ", м.р. " + Формат(ВыборкаЖильцы.МестоРождения, "ДФ=dd.MM.yyyy"), "");
		    Префикс = ", " + Символы.ПС;
			
			ДолжникиФИО = ДолжникиФИО + ПрефиксФИО + ?(ЗначениеЗаполнено(ВыборкаЖильцы.бестФамилия), ВыборкаЖильцы.бестФамилия + 
								?(ЗначениеЗаполнено(ВыборкаЖильцы.бестИмя), " " + Лев(ВыборкаЖильцы.бестИмя, 1), "")+"." + 
								?(ЗначениеЗаполнено(ВыборкаЖильцы.бестОтчество), " " + Лев(ВыборкаЖильцы.бестОтчество, 1), "")+".", ВыборкаЖильцы.Жилец);
			ПрефиксФИО = ", ";
			Если Выборка.ФизЛицо <> ВыборкаЖильцы.Жилец Тогда
			
				РодственикиАбонента = РодственикиАбонента + ПрефиксРод + ?(ЗначениеЗаполнено(ВыборкаЖильцы.бестФамилия), ВыборкаЖильцы.бестФамилия + 
								?(ЗначениеЗаполнено(ВыборкаЖильцы.бестИмя), " " + Лев(ВыборкаЖильцы.бестИмя, 1), "")+"." + 
								?(ЗначениеЗаполнено(ВыборкаЖильцы.бестОтчество), " " + Лев(ВыборкаЖильцы.бестОтчество, 1), "")+".", ВыборкаЖильцы.Жилец);
								
				ПрефиксРод = ", ";				
			КонецЕсли;
		КонецЦикла;
		ПараметрыШапки.Вставить("АбонентыФИОсДМР", АбонентыФИОсДМР);
		ПараметрыШапки.Вставить("ДолжникиФИО", ДолжникиФИО);
		ПараметрыШапки.Вставить("РодственикиАбонента", РодственикиАбонента);
		
		// Услуги абонента
		ВыборкаУслуги.Сбросить();
		Префикс		= "";
		Пока ВыборкаУслуги.НайтиСледующий(Отбор) Цикл
			ОказываемыеУслуги = ОказываемыеУслуги + Префикс + НРег(ВыборкаУслуги.Услуги);
			Префикс = ", ";
		КонецЦикла;
		ПараметрыШапки.Вставить("ОказываемыеУслуги", ОказываемыеУслуги);
		
		// Период и сумма задолженности
		Если ЗначениеЗаполнено(Выборка.ПериодЗадолженностиНачало) Тогда
			НачалоЗадолженности = Формат(Выборка.ПериодЗадолженностиНачало, "ДЛФ=DD");
		КонецЕсли;
		ПараметрыШапки.Вставить("НачалоЗадолженности", НРег(НачалоЗадолженности));

		Если ЗначениеЗаполнено(Выборка.ПериодЗадолженностиКонец) Тогда
			КонецЗадолженности = Формат(Выборка.ПериодЗадолженностиКонец, "ДЛФ=DD");
		КонецЕсли;
		ПараметрыШапки.Вставить("КонецЗадолженности", НРег(КонецЗадолженности));
		
		ФормСтрока  = "Л = ru_RU; ДП = Истина";
		ПарПредмета ="рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2";
		СтруктураДолга.Свойство("СуммаОсновногоДолга", СуммаОсновногоДолга);
		СтруктураДолга.Свойство("Госпошлина", Госпошлина);
		СтруктураДолга.Свойство("Пеня", Пеня);
		Если ЗначениеЗаполнено(СуммаОсновногоДолга) Тогда
			СуммаЗадолженностиПрописью = Строка(СуммаОсновногоДолга) + "руб. (" + ЧислоПрописью(СуммаОсновногоДолга, ФормСтрока, ПарПредмета) + ")";
		Иначе
			СуммаЗадолженностиПрописью = "0 руб. (ноль рублей)";
		КонецЕсли;
		ПараметрыШапки.Вставить("СуммаЗадолженностиПрописью", НРег(СуммаЗадолженностиПрописью));
		
		Если ЗначениеЗаполнено(Госпошлина) Тогда
			СуммаГоспошлиныПрописью = Строка(Госпошлина) + "руб. (" + ЧислоПрописью(Госпошлина, ФормСтрока, ПарПредмета) + ")";
		Иначе
			СуммаГоспошлиныПрописью = "0 руб. (ноль рублей)";
		КонецЕсли;
		ПараметрыШапки.Вставить("СуммаГоспошлиныПрописью", НРег(СуммаГоспошлиныПрописью));
		
		Если ЗначениеЗаполнено(Пеня) Тогда
			СуммаПениПрописью = Строка(Пеня) + "руб. (" + ЧислоПрописью(Пеня, ФормСтрока, ПарПредмета) + ")";
		Иначе
			СуммаПениПрописью = "0 руб. (ноль рублей)";
		КонецЕсли;
		ПараметрыШапки.Вставить("СуммаПениПрописью", НРег(СуммаПениПрописью));
		
		ОбластьШапка.Параметры.Заполнить(Выборка);
		ОбластьШапка.Параметры.Заполнить(ПараметрыШапки);
		
		ТабДок.Вывести(ОбластьШапка);
		
		// Вывод приложения
		Если ЗначениеЗаполнено(СписокПрикреплённыхДокументов) Тогда 
			Сч = 1;
			ТабДок.Вывести(ОбластьПриложениеШапка);
			
			Для каждого СтрокаПриложения Из СписокПрикреплённыхДокументов Цикл
				Приложение = "" + Сч + ". " + СтрокаПриложения;
				ОбластьПриложениеСтрока.Параметры.Приложение = Приложение;
				ТабДок.Вывести(ОбластьПриложениеСтрока);
			    Сч = Сч + 1;
			КонецЦикла;
		КонецЕсли;
		
		// Вывод подвала
		ОбластьПодвал.Параметры.ДатаЗаявления = ТекДата;
		ОбластьПодвал.Параметры.Пользователь  = ПараметрыСеанса.ТекущийПользователь;
		ТабДок.Вывести(ОбластьПодвал);
	КонецЦикла;
	
	Возврат ТабДок;

КонецФункции

Функция ПечатьЗаявленияОВозбужденииИсполнительногоПроизводстваНаСервере(Задача, СтруктураДолга = Неопределено) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргЗадачаПИД.Ссылка КАК Задача,
		|	энргЗадачаПИД.Дата КАК Дата,
		|	энргЗадачаПИД.ДатаИсполительногоЛиста КАК ДатаИсполительногоЛиста,
		|	энргЗадачаПИД.НомерИсполнительногоЛиста КАК НомерИсполнительногоЛиста,
		|	энргЗадачаПИД.ВыданИсполнительныйЛист КАК ВыданИсполнительныйЛист,
		|	энргСлужбыСудебныхПристовов.НачальникРОСП КАК НачальникРОСП,
		|	энргСлужбыСудебныхПристововКонтактнаяИнформация.Представление КАК АдресСтруктурногоПодразделенияФСПП,
		|	энргЗадачаПИД.НомерСудебногоДела КАК НомерСудебногоДела,
		|	энргАбоненты.ФизЛицо КАК ФизЛицо,
		|	энргКонтрагенты.бестФамилия КАК бестФамилия,
		|	энргКонтрагенты.бестИмя КАК бестИмя,
		|	энргКонтрагенты.бестОтчество КАК бестОтчество,
		|	энргАбонентыКонтактнаяИнформация.Представление КАК АдресОбъекта,
		|	энргЗадачаПИД.СуммаЗадолженности КАК СуммаЗадолженности,
		|	энргФилиалыАбонентовСрезПоследних.Филиал КАК Филиал,
		|	энргЗадачаПИД.Организация КАК Организация
		|ПОМЕСТИТЬ ВТ_Задача
		|ИЗ
		|	Задача.энргЗадачаПИД КАК энргЗадачаПИД
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
		|			ПО энргАбоненты.Ссылка = энргАбонентыКонтактнаяИнформация.Ссылка
		|				И (энргАбонентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(справочник.ВидыконтактнойИнформации.АдресОбъекта))
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргКонтрагенты КАК энргКонтрагенты
		|			ПО энргАбоненты.ФизЛицо = энргКонтрагенты.Ссылка
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргФилиалыАбонентов.СрезПоследних КАК энргФилиалыАбонентовСрезПоследних
		|			ПО энргАбоненты.Ссылка = энргФилиалыАбонентовСрезПоследних.Абонент
		|		ПО энргЗадачаПИД.Абонент = энргАбоненты.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСлужбыСудебныхПристовов КАК энргСлужбыСудебныхПристовов
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСлужбыСудебныхПристовов.КонтактнаяИнформация КАК энргСлужбыСудебныхПристововКонтактнаяИнформация
		|			ПО энргСлужбыСудебныхПристовов.Ссылка = энргСлужбыСудебныхПристововКонтактнаяИнформация.Ссылка
		|				И (энргСлужбыСудебныхПристововКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресСлужбыСудебныйПристовов))
		|		ПО энргЗадачаПИД.СлужбаСудебныхПристовов = энргСлужбыСудебныхПристовов.Ссылка
		|ГДЕ
		|	энргЗадачаПИД.Ссылка = &Задача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонОрганизации)
		|				ТОГДА ОрганизацииКонтактнаяИнформация.Представление
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК ТелефонОрганизации,
		|	МАКСИМУМ(КлассификаторБанков.Наименование) КАК НаименованиеБанкаПолучателя,
		|	МАКСИМУМ(КлассификаторБанков.Код) КАК БИКБанкаПолучателя,
		|	МАКСИМУМ(КлассификаторБанков.КоррСчет) КАК СчетБанкаПолучателя,
		|	Организации.Ссылка КАК Организация
		|ПОМЕСТИТЬ ВТ_КонтактныеДанныеОрганизации
		|ИЗ
		|	Справочник.Организации КАК Организации
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Задача КАК ВТ_Задача
		|		ПО Организации.Ссылка = ВТ_Задача.Организация
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
		|		ПО Организации.Ссылка = ОрганизацииКонтактнаяИнформация.Ссылка
		|			И (ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонОрганизации))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчета
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторБанков КАК КлассификаторБанков
		|			ПО БанковскиеСчета.Банк = КлассификаторБанков.Ссылка
		|		ПО Организации.ОсновнойБанковскийСчет = БанковскиеСчета.Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	Организации.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Задача.Задача КАК Задача,
		|	энргЗадачаПИДЗадачиПоИсполнителю.Ссылка КАК Ссылка,
		|	энргВидыОперацийПИД.Тип КАК Тип,
		|	энргЗадачаПИДЗадачиПоИсполнителю.НомерИсполнительногоЛиста КАК НомерИсполнительногоЛиста,
		|	энргЗадачаПИДЗадачиПоИсполнителю.ДатаИсполительногоЛиста КАК ДатаИсполительногоЛиста,
		|	энргЗадачаПИДЗадачиПоИсполнителю.СлужбаСудебныхПристовов КАК СлужбаСудебныхПристовов
		|ИЗ
		|	Задача.энргЗадачаПИД.ЗадачиПоИсполнителю КАК энргЗадачаПИДЗадачиПоИсполнителю
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Задача КАК ВТ_Задача
		|		ПО энргЗадачаПИДЗадачиПоИсполнителю.Ссылка <> ВТ_Задача.Задача
		|			И энргЗадачаПИДЗадачиПоИсполнителю.Абонент.ФизЛицо = ВТ_Задача.ФизЛицо
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыОперацийПИД КАК энргВидыОперацийПИД
		|		ПО энргЗадачаПИДЗадачиПоИсполнителю.Этап = энргВидыОперацийПИД.Ссылка
		|ГДЕ
		|	НЕ энргЗадачаПИДЗадачиПоИсполнителю.Выполнена
		|	И энргВидыОперацийПИД.Тип = ЗНАЧЕНИЕ(Перечисление.энргТипыЭтапов.ИсполнительнаяРабота)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаИсполительногоЛиста
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Задача.Задача КАК Задача,
		|	ВТ_Задача.НачальникРОСП КАК НачальникРОСП,
		|	ВТ_Задача.АдресСтруктурногоПодразделенияФСПП КАК АдресСтруктурногоПодразделенияФСПП,
		|	ВТ_Задача.ДатаИсполительногоЛиста КАК ДатаИсполительногоЛиста,
		|	ВТ_Задача.НомерИсполнительногоЛиста КАК НомерИсполнительногоЛиста,
		|	ВТ_Задача.ВыданИсполнительныйЛист КАК ВыданИсполнительныйЛист,
		|	ВТ_Задача.НомерСудебногоДела КАК НомерСудебногоДела,
		|	ВТ_Задача.Дата КАК ДатаСудебногоДела,
		|	ВТ_Задача.ФизЛицо КАК Абонент,
		|	ВТ_Задача.бестФамилия КАК ФамилияАбонента,
		|	ВТ_Задача.бестИмя КАК ИмяАбонента,
		|	ВТ_Задача.бестОтчество КАК ОтчествоАбонента,
		|	ВТ_Задача.АдресОбъекта КАК АдресОбъекта,
		|	ВТ_Задача.СуммаЗадолженности КАК СуммаЗадолженности,
		|	ВТ_Задача.Филиал КАК Филиал,
		|	ВТ_КонтактныеДанныеОрганизации.ТелефонОрганизации КАК ТелефонОрганизации,
		|	ВТ_КонтактныеДанныеОрганизации.НаименованиеБанкаПолучателя КАК НаименованиеБанкаПолучателя,
		|	ВТ_КонтактныеДанныеОрганизации.БИКБанкаПолучателя КАК БИКБанкаПолучателя,
		|	ВТ_КонтактныеДанныеОрганизации.СчетБанкаПолучателя КАК СчетБанкаПолучателя
		|ИЗ
		|	ВТ_Задача КАК ВТ_Задача
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтактныеДанныеОрганизации КАК ВТ_КонтактныеДанныеОрганизации
		|		ПО ВТ_Задача.Организация = ВТ_КонтактныеДанныеОрганизации.Организация";
	
	ТекДата = ТекущаяДатаСеанса();    
	Запрос.УстановитьПараметр("ТекДата", ТекДата);
	Запрос.УстановитьПараметр("Задача", Задача);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	КолПакет		 = РезультатЗапроса.Количество();
	
	Выборка	= РезультатЗапроса[КолПакет-1].Выбрать();
	ВыборкаСводноеДело = РезультатЗапроса[КолПакет-2].Выбрать();
	Если СтруктураДолга = Неопределено Тогда
		СтруктураДолга = Новый Структура;
	КонецЕсли;
	СуммаЗадолженности = Неопределено;
	СтруктураДолга.Свойство("СуммаОсновногоДолга", СуммаЗадолженности);
		
	Пока Выборка.Следующий() Цикл
		ШапкаПарам = Новый Структура("НачальникРОСП, АдресСтруктурногоПодразделенияФСПП, ВыданИсполнительныйЛист, АдресОбъекта, ТелефонОрганизации");
		ЗаполнитьЗначенияСвойств(ШапкаПарам, Выборка);
		
		ШапкаПарам.Вставить("СуммаЗадолженности", СуммаЗадолженности);
		ШапкаПарам.Вставить("Пользователь", ПараметрыСеанса.ТекущийПользователь);
		ШапкаПарам.Вставить("Пользователь1", ПараметрыСеанса.ТекущийПользователь);
		ШапкаПарам.Вставить("ДатаНомерИсполнительногоЛиста", "№" + Выборка.НомерИсполнительногоЛиста + " от " + Формат(Выборка.ДатаИсполительногоЛиста, "ДФ=dd.MM.yyyy"));
		ШапкаПарам.Вставить("ДатаНомерСудебногоДела", "№" + Выборка.НомерСудебногоДела + " от " + Формат(Выборка.ДатаСудебногоДела, "ДФ=dd.MM.yyyy"));
		
		// ФИО абонента
		Если ЗначениеЗаполнено(Выборка.ФамилияАбонента) Тогда
			АбонентФИОКраткое = Выборка.ФамилияАбонента + ?(ЗначениеЗаполнено(Выборка.ИмяАбонента), " " + Лев(Выборка.ИмяАбонента, 1) + ".", "") 
									+ ?(ЗначениеЗаполнено(Выборка.ОтчествоАбонента), " " + Лев(Выборка.ОтчествоАбонента, 1) + ".", "");
		Иначе
			АбонентФИОКраткое = Выборка.Абонент;
		КонецЕсли;
		ШапкаПарам.Вставить("АбонентФИОКраткое", АбонентФИОКраткое);
		
		БанковскиеРеквизитыОрг = Строка(Выборка.Филиал) + " на р/с " + Выборка.СчетБанкаПолучателя + ", БИК "
									+ Выборка.БИКБанкаПолучателя + ", " + Выборка.НаименованиеБанкаПолучателя;
		ШапкаПарам.Вставить("БанковскиеРеквизитыОрг", БанковскиеРеквизитыОрг);
		
		// Поиск сводного дела
		ВыборкаСводноеДело.Сбросить();
		Отбор 		= Новый Структура("Задача", Выборка.Задача);
		Если ВыборкаСводноеДело.НайтиСледующий(Отбор) Тогда 
			СводноеДело = "Прошу, приобщить исполнительное производство к сводному №" + ВыборкаСводноеДело.НомерИсполнительногоЛиста
				+ " от " + Формат(ВыборкаСводноеДело.ДатаИсполительногоЛиста, "ДФ=dd.MM.yyyy") + ", которое находится на исполнении в " 
				+ ВыборкаСводноеДело.СлужбаСудебныхПристовов; 
			ШапкаПарам.Вставить("СводноеДело", СводноеДело);
		Иначе
			ШапкаПарам.Вставить("СводноеДело", "");
		КонецЕсли;
		
		// получаем макет из объекта обработки
		СсылкаМакет = ПолучитьМакет("МакетЗаявлениеОВозбужденииИсполнительногоПроизводства");

		АдресХранилища = Новый УникальныйИдентификатор();
		ВременныйФайл = ПолучитьИмяВременногоФайла("doc"); 
		СсылкаМакет.Записать(ВременныйФайл);
		
		Адрес = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ВременныйФайл), АдресХранилища); 
		УдалитьФайлы(ВременныйФайл); 
		
		Возврат Новый Структура("АдресХранилища, ПараметрыШапки", Адрес, ШапкаПарам);
	КонецЦикла;
КонецФункции

Функция ПечатьВыпискиСЛицевогоСчета(Задача, НачПериод, КонПериод) Экспорт
	
	// Заполнение шапки выписки
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргАбоненты.КлючПомещения КАК КлючПомещения,
		|	энргАбоненты.ФизЛицо КАК ФизЛицо,
		|	энргАбонентыКонтактнаяИнформация.Представление КАК АдресОбъекта
		|ПОМЕСТИТЬ ВТ_КлючПомещения
		|ИЗ
		|	Справочник.энргАбоненты КАК энргАбоненты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
		|		ПО энргАбоненты.Ссылка = энргАбонентыКонтактнаяИнформация.Ссылка
		|			И (энргАбонентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(справочник.ВидыконтактнойИнформации.АдресОбъекта))
		|ГДЕ
		|	энргАбоненты.Ссылка = &Абонент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗначенияПлощадейСрезПоследних.ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадь)
		|				ТОГДА энргЗначенияПлощадейСрезПоследних.Площадь
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ОбщаяПлощадь,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА энргЗначенияПлощадейСрезПоследних.ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ЖилаяПлощадь)
		|				ТОГДА энргЗначенияПлощадейСрезПоследних.Площадь
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ЖилаяПлощадь,
		|	NULL КАК КоличествоЖильцов,
		|	NULL КАК ТипСобственности,
		|	NULL КАК СтатусСудебногоДела,
		|	NULL КАК КоличествоЛьготников,
		|	NULL КАК ФизЛицо,
		|	NULL КАК АдресОбъекта
		|ПОМЕСТИТЬ ВТ_Данные
		|ИЗ
		|	РегистрСведений.энргЗначенияПлощадей.СрезПоследних(
		|			&ДатаЗаявки,
		|			КлючПомещения В
		|					(ВЫБРАТЬ
		|						ВТ_КлючПомещения.КлючПомещения КАК КлючПомещения
		|					ИЗ
		|						ВТ_КлючПомещения КАК ВТ_КлючПомещения)
		|				И Организация = &Организация
		|				И Район = &Район
		|				И ВидПлощади В (ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадь), ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ЖилаяПлощадь))) КАК энргЗначенияПлощадейСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	NULL,
		|	NULL,
		|	энргКоличествоПроживающихСрезПоследних.Количество,
		|	NULL,
		|	NULL,
		|	NULL,
		|	NULL,
		|	NULL
		|ИЗ
		|	РегистрСведений.энргКоличествоПроживающих.СрезПоследних(
		|			&ДатаЗаявки,
		|			КлючПомещения В
		|					(ВЫБРАТЬ
		|						ВТ_КлючПомещения.КлючПомещения КАК КлючПомещения
		|					ИЗ
		|						ВТ_КлючПомещения КАК ВТ_КлючПомещения)
		|				И Организация = &Организация
		|				И Район = &Район) КАК энргКоличествоПроживающихСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	NULL,
		|	NULL,
		|	NULL,
		|	энргТипСобственностиАбонентовСрезПоследних.ТипСобственности,
		|	NULL,
		|	NULL,
		|	NULL,
		|	NULL
		|ИЗ
		|	РегистрСведений.энргТипСобственностиАбонентов.СрезПоследних(
		|			&ДатаЗаявки,
		|			КлючПомещения В
		|					(ВЫБРАТЬ
		|						ВТ_КлючПомещения.КлючПомещения КАК КлючПомещения
		|					ИЗ
		|						ВТ_КлючПомещения КАК ВТ_КлючПомещения)
		|				И Организация = &Организация
		|				И Район = &Район) КАК энргТипСобственностиАбонентовСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	NULL,
		|	NULL,
		|	NULL,
		|	NULL,
		|	МАКСИМУМ(энргСтатусыСудебныхДелСрезПоследних.Статус),
		|	NULL,
		|	NULL,
		|	NULL
		|ИЗ
		|	РегистрСведений.энргСтатусыСудебныхДел.СрезПоследних(, СудебноеДело = &Ссылка) КАК энргСтатусыСудебныхДелСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	NULL,
		|	NULL,
		|	NULL,
		|	NULL,
		|	NULL,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ энргЖильцыЛьготныхКатегорийСрезПоследних.Жилец),
		|	NULL,
		|	NULL
		|ИЗ
		|	РегистрСведений.энргПроживаниеЖильцов.СрезПоследних(
		|			&ДатаЗаявки,
		|			КлючПомещения В
		|					(ВЫБРАТЬ
		|						ВТ_КлючПомещения.КлючПомещения КАК КлючПомещения
		|					ИЗ
		|						ВТ_КлючПомещения КАК ВТ_КлючПомещения)
		|				И Организация = &Организация
		|				И Район = &Район) КАК энргПроживаниеЖильцовСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргЖильцыЛьготныхКатегорий.СрезПоследних(&ДатаЗаявки, ) КАК энргЖильцыЛьготныхКатегорийСрезПоследних
		|		ПО энргПроживаниеЖильцовСрезПоследних.Жилец = энргЖильцыЛьготныхКатегорийСрезПоследних.Жилец
		|ГДЕ
		|	энргПроживаниеЖильцовСрезПоследних.Состояние = ЗНАЧЕНИЕ(перечисление.энргСостояниеЖильцов.Регистрация)
		|	И энргЖильцыЛьготныхКатегорийСрезПоследних.Состояние
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	NULL,
		|	NULL,
		|	NULL,
		|	NULL,
		|	NULL,
		|	NULL,
		|	ВТ_КлючПомещения.ФизЛицо,
		|	ВТ_КлючПомещения.АдресОбъекта
		|ИЗ
		|	ВТ_КлючПомещения КАК ВТ_КлючПомещения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВТ_Данные.ОбщаяПлощадь) КАК ОбщаяПлощадь,
		|	МАКСИМУМ(ВТ_Данные.ЖилаяПлощадь) КАК ЖилаяПлощадь,
		|	МАКСИМУМ(ВТ_Данные.КоличествоЖильцов) КАК КоличествоЖильцов,
		|	МАКСИМУМ(ВТ_Данные.ТипСобственности) КАК ТипСобственности,
		|	МАКСИМУМ(ВТ_Данные.СтатусСудебногоДела) КАК СтатусСудебногоДела,
		|	МАКСИМУМ(ВТ_Данные.КоличествоЛьготников) КАК КоличествоЛьготников,
		|	МАКСИМУМ(ВТ_Данные.ФизЛицо) КАК ФизЛицо,
		|	МАКСИМУМ(ВТ_Данные.АдресОбъекта) КАК АдресОбъекта
		|ИЗ
		|	ВТ_Данные КАК ВТ_Данные";
	
	Запрос.УстановитьПараметр("Абонент",	 Задача.Абонент);
	Запрос.УстановитьПараметр("ДатаЗаявки",  Задача.Дата);
	Запрос.УстановитьПараметр("Организация", Задача.Организация);
	Запрос.УстановитьПараметр("Район",		 Задача.Район);
	Запрос.УстановитьПараметр("Ссылка",		 Задача.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
