	Если СтруктураДолга = Неопределено Тогда
		СтруктураДолга = Новый Структура;
	КонецЕсли;
	ТекДата = ТекущаяДатаСеанса();
	Запрос.УстановитьПараметр("ТекДата", ТекДата);
	Запрос.УстановитьПараметр("Задача", Задача);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	КолПакет		 = РезультатЗапроса.Количество();
	Макет			 = ПолучитьМакет("МакетЗаявленияОВыдачеСудебногоПриказаОВзыскании");
	
	ОбластьШапка	 		= Макет.ПолучитьОбласть("Шапка");
	ОбластьПриложениеШапка	= Макет.ПолучитьОбласть("ПриложениеШапка");
	ОбластьПриложениеСтрока	= Макет.ПолучитьОбласть("ПриложениеСтрока");
	ОбластьПодвал			= Макет.ПолучитьОбласть("Подвал");
	
	Выборка			= РезультатЗапроса[КолПакет-3].Выбрать();
	ВыборкаЖильцы	= РезультатЗапроса[КолПакет-2].Выбрать();
	ВыборкаУслуги	= РезультатЗапроса[КолПакет-1].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
		ТабДок.АвтоМасштаб = Истина;
		
		ВыводШапкиФилиала(ТабДок, Выборка.Район, ОбластьШапка);
		ОбластьШапка.Параметры.Заполнить(Выборка);
		
		ПараметрыШапки = Новый Структура("ОтветНаПритензию", ОтветНаПритензию);

		АдресОрганизации = "";
		Префикс			 = "";
		АбонентФИО		 = "";
		АбонентФИОКраткое = "";
		АдресАбонента	 = "";
		АбонентПаспортныеДанные = "";
		ДоляАбонента = "";
		АбонентыФИОсДМР = "";
		НачалоЗадолженности = "";
		КонецЗадолженности = "";
		СуммаГоспошлиныПрописью = "";
		СуммаЗадолженностиПрописью = "";
		СуммаПениПрописью = "";
		ТипСобственника = "";
		ДатаДоговораСоцНайма = "";
		ДатаПредписания = "";
		ДолжникиФИО = "";
		ДоговорОбслуживания = "";
		ОснованиеПраваСобственности = "";
		ОказываемыеУслуги = "";
		РодственикиАбонента = "";
		СуммаОсновногоДолга = Неопределено;
		Госпошлина = Неопределено;
		Пеня = Неопределено;
		
		Если ЗначениеЗаполнено(Выборка.ДатаДоговораОбслуживания) Тогда
			ОснованиеПраваСобственности = "свидетельства о регистрации №" + Выборка.СвидетельствоОРегистрацииСерия + " " + Выборка.СвидетельствоОРегистрацииНомер + " от " + Формат(Выборка.СвидетельствоОРегистрацииДата, "ДФ=dd.MM.yyyy");
		КонецЕсли;
		ПараметрыШапки.Вставить("ОснованиеПраваСобственности", ОснованиеПраваСобственности);
		
		Если ЗначениеЗаполнено(Выборка.ДатаДоговораОбслуживания) Тогда
			ДоговорОбслуживания = "договора обслуживания №" + Выборка.НомерДоговораОбслуживания + " от " + Формат(Выборка.ДатаДоговораОбслуживания, "ДФ=dd.MM.yyyy");
		КонецЕсли;
		ПараметрыШапки.Вставить("ДоговорОбслуживания", ДоговорОбслуживания);
		
		Если ЗначениеЗаполнено(Выборка.ДатаПослПредписания) Тогда
			ДатаПредписания = Формат(Выборка.ДатаПослПредписания, "ДФ=dd.MM.yyyy");
		КонецЕсли;
		ПараметрыШапки.Вставить("ДатаПредписания", ДатаПредписания);
		
		Если ЗначениеЗаполнено(Выборка.ДатаДоговораСоцНайма) Тогда
			ДатаДоговораСоцНайма = Формат(Выборка.ДатаДоговораСоцНайма, "ДФ=dd.MM.yyyy");
