				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	энргСобытия.ТипСобытия КАК ТипСобытия,
	энргСобытия.Период КАК Дата,
	энргСобытия.ПланируемаяДатаОтправки КАК ПланируемаяДатаОтправки,
	энргЗадачаПИДПодэтапы.Подэтап КАК Подэтап,
	ВЫБОР
		КОГДА энргСобытия.Успех
			ТОГДА "Выполнен"
		ИНАЧЕ ""
	КОНЕЦ КАК Статус,
	энргСобытия.Результат КАК Результат
ИЗ
	РегистрСведений.энргСобытия КАК энргСобытия
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД КАК энргЗадачаПИД
		ПО энргСобытия.Основание = энргЗадачаПИД.Ссылка
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Задача.энргЗадачаПИД.Подэтапы КАК энргЗадачаПИДПодэтапы
		ПО энргСобытия.Основание = энргЗадачаПИДПодэтапы.Ссылка
			И энргСобытия.IDЭтапа = энргЗадачаПИДПодэтапы.IDЭтапа
ГДЕ
