
#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	бестЛокализацияСервер.ПриСозданииНаСервере_энргЗадачаПИД(ЭтотОбъект);
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Задолженность,"НачалоПериода",	НачалоМесяца(Объект.ПериодЗадолженностиНачало));
	//ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Задолженность,"КонецПериода",	КонецМесяца(КонецДня(Объект.ПериодЗадолженностиКонец)));
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Задолженность,"Организация",		Объект.Организация);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Задолженность,"Район",			Объект.Район);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Задолженность,"Договор",			Объект.Договор);
	
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Пеня,"НачалоПериода",	НачалоМесяца(Объект.ПериодЗадолженностиНачало));
	//ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Пеня,"КонецПериода",		КонецМесяца(КонецДня(Объект.ПериодЗадолженностиКонец)));
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Пеня,"Организация",		Объект.Организация);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Пеня,"Район",			Объект.Район);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Пеня,"Договор",			Объект.Договор);

	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(СобытияПоЭтапу,"Ссылка",	Объект.Ссылка);
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(РеструктуризацияЗадолженности,"Организация",		Объект.Организация);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(РеструктуризацияЗадолженности,"Район",			Объект.Район);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(РеструктуризацияЗадолженности,"Договор",			Объект.Договор);
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Банкротство,"Организация",		Объект.Организация);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Банкротство,"Район",				Объект.Район);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Банкротство,"Договор",			Объект.Договор);
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(СписаниеЗадолженности,"Организация",		Объект.Организация);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(СписаниеЗадолженности,"Район",			Объект.Район);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(СписаниеЗадолженности,"Договор",			Объект.Договор);
	
	КатегорияДебитора 		= РегистрыСведений.бестНастройкиКатегорийДебитора.ПолучитьКатегориюДебитора(Объект.Дата, Объект.Организация, (Объект.ПериодЗадолженностиКонец - Объект.ПериодЗадолженностиНачало) / 86400);
	
	РезультатЗадолженность = бестВзаиморасчетыЮрЛицаСервер.ПолучитьФактическуюЗадолженностьНаДату(Объект.Организация, Объект.Район, Объект.ПериодЗадолженностиКонец, Объект.Договор);
	Выборка = РезультатЗадолженность.Выбрать(); 
	Если Выборка.Следующий() Тогда
		СуммаЗадолженностиШапка = Выборка.Сумма;
	КонецЕсли;
	РезультатПеня				= бестВзаиморасчетыЮрЛицаСервер.ПолучитьПенюНаДату(Объект.Организация, Объект.Район, Объект.ПериодЗадолженностиКонец, Объект.Договор);
	Выборка = РезультатПеня.Выбрать(); 
	Если Выборка.Следующий() Тогда
		ПеняШапка = Выборка.Сумма;
	КонецЕсли;
	
	НастроитьВидимостьИДоступность();
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Этап, "Тип") <> Перечисления.энргТипыЭтапов.Банкротство Тогда
		ЗаполнитьСудебныеИнстанции();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередВыполнением(Отказ, СледующийЭтап = Неопределено)
	Если Объект.ПометкаУдаления Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нельзя выполнить помеченную на удаление задачу.");
		Возврат;                                                                       
	КонецЕсли;

	Если ПроверитьПодэтапы() Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Задача не может быть выполнена. Заполните события по всем подэтапам.");
		Возврат;
	КонецЕсли;
	
	ПерейтиНаСледующийЭтапКлиент(Отказ, СледующийЭтап = Неопределено);	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	СоздатьКоманды();
	ЗаполнитьСуммуИска();
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	ЗаполнитьТекстовыеПоля();
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ЗаполнитьТекстовыеПоля();
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовФормы

&НаКлиенте
Процедура СуммаЗадолженности1ПриИзменении(Элемент)
	ЗаполнитьСуммуИска();
КонецПроцедуры

&НаКлиенте
Процедура СуммаПени1ПриИзменении(Элемент)
	ЗаполнитьСуммуИска();
КонецПроцедуры

&НаКлиенте
Процедура ПрочиеПриИзменении(Элемент)
	ЗаполнитьСуммуИска();
КонецПроцедуры

&НаКлиенте
Процедура ВидСудопроизводстваПриИзменении(Элемент)
	ЗаполнитьСуммуИска();
КонецПроцедуры

&НаКлиенте
Процедура ДатаРасчетаПениПриИзменении(Элемент)
	ПерерассчитатьПеню();
	ЗаполнитьСуммуИска();
КонецПроцедуры

&НаКлиенте
Процедура ЗадолженностьВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ОткрытьФорму("Документ.бестПлатежныйДокумент.ФормаОбъекта", Новый Структура("Ключ", Элементы.Задолженность.ТекущиеДанные.ПлатежныйДокумент));
КонецПроцедуры

&НаКлиенте
Процедура СудебныеИнстанцииВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "СудебныеИнстанцииВзысканиеГП" Тогда
		
		ТекущиеДанные			= Элементы.СудебныеИнстанции.ТекущиеДанные;
		Если Не ЗначениеЗаполнено(ТекущиеДанные.IDСтроки) Тогда
			ТекущиеДанные.IDСтроки  = Новый УникальныйИдентификатор();
		КонецЕсли;
		
		ОписаниеОповещения 	= Новый ОписаниеОповещения("ВзысканиеГПЗавершение", ЭтотОбъект, Новый Структура("ТекущиеДанные", ТекущиеДанные));
		ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ВзысканиеГП", ПолучитьВходныеДанныеВзысканиеГП(ТекущиеДанные.IDСтроки),,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;	
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаСервере
Процедура НастроитьВидимостьИДоступность()
	Тип = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Этап, "Тип");
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаИнформацияОСудебномДеле", "Видимость", Тип = Перечисления.энргТипыЭтапов.СудебнаяРабота ИЛИ Тип = Перечисления.энргТипыЭтапов.ИсполнительнаяРабота ИЛИ Тип = Перечисления.энргТипыЭтапов.Банкротство  ИЛИ Тип = Перечисления.энргТипыЭтапов.СписаниеЗадолженности);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСудебныеИнстанции", "Видимость", Тип = Перечисления.энргТипыЭтапов.СудебнаяРабота ИЛИ Тип = Перечисления.энргТипыЭтапов.СписаниеЗадолженности);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаКонкурснаяМасса", "Видимость", Тип = Перечисления.энргТипыЭтапов.Банкротство ИЛИ Тип = Перечисления.энргТипыЭтапов.СписаниеЗадолженности);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаИнформацияОБанкротстве", "Видимость", Тип = Перечисления.энргТипыЭтапов.Банкротство ИЛИ Тип = Перечисления.энргТипыЭтапов.СписаниеЗадолженности);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаБанкротство", "Видимость", Тип = Перечисления.энргТипыЭтапов.Банкротство ИЛИ Тип = Перечисления.энргТипыЭтапов.СписаниеЗадолженности);
	//ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаИнформацияОДолжнике", "Видимость", Тип = Перечисления.энргТипыЭтапов.ДосудебнаяРабота ИЛИ Тип = Перечисления.энргТипыЭтапов.ОграничениеРежимаПотребления);
	//ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПодэтапы", "Видимость", Тип = Перечисления.энргТипыЭтапов.ДосудебнаяРабота);
	//ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаЗадолженность", "Видимость", Тип = Перечисления.энргТипыЭтапов.ДосудебнаяРабота);
	//ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСобытияПоЭтапу", "Видимость", Тип = Перечисления.энргТипыЭтапов.СудебнаяРабота ИЛИ Тип = Перечисления.энргТипыЭтапов.ДосудебнаяРабота ИЛИ Тип = Перечисления.энргТипыЭтапов.ОграничениеРежимаПотребления);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаИнформацияОбИсполнительномПроизводстве", "Видимость", Тип = Перечисления.энргТипыЭтапов.ИсполнительнаяРабота ИЛИ Тип = Перечисления.энргТипыЭтапов.Банкротство ИЛИ Тип = Перечисления.энргТипыЭтапов.СписаниеЗадолженности);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаИсполнительныеДокументы", "Видимость", Тип = Перечисления.энргТипыЭтапов.ИсполнительнаяРабота);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаФиксированнаяЗадолженность", "Видимость", Тип = Перечисления.энргТипыЭтапов.ДосудебнаяРабота ИЛИ Тип = Перечисления.энргТипыЭтапов.ОграничениеРежимаПотребления);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСписаниеЗадолженности", "Видимость", Тип = Перечисления.энргТипыЭтапов.СписаниеЗадолженности);
	
	ТекПользователь 	= Пользователи.ТекущийПользователь();
	МассивРолей 		= Новый Массив;
	МассивРолей.Добавить(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Этап, "Роль"));
	РезультатЗапроса	= энргОбщегоНазначения.ПолучитьПользователейСОтборомПоРолям(Объект.Организация, Объект.Район, МассивРолей);
	мПользователей		= РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Пользователь");
	
	Если (НЕ Объект.Выполнена И Объект.ПринятоВРаботу И Объект.Исполнитель <> ТекПользователь) ИЛИ (Объект.Выполнена ИЛИ мПользователей.Найти(ТекПользователь)= Неопределено)  Тогда
		ТолькоПросмотр	= Истина;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаПринятьКИсполнению", "Доступность",  Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СоздатьСобытие", "Доступность",  Ложь);
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСтандартныеКнопки", "Доступность",  Объект.Исполнитель = ТекПользователь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СоздатьСобытие", "Доступность",  НЕ Объект.Выполнена И ЗначениеЗаполнено(Объект.Исполнитель));
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "БанкротствоСоздатьСписаниеВосстановлениеЗадолженности", "Доступность",  НЕ Объект.Выполнена И ЗначениеЗаполнено(Объект.Исполнитель));
	КонецЕсли;

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаПередатьЗадачу", "Видимость",  НЕ Объект.Выполнена И ЗначениеЗаполнено(Объект.Исполнитель));
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаПринятьКИсполнению", "Видимость",  НЕ ЗначениеЗаполнено(Объект.Исполнитель));
КонецПроцедуры

&НаСервере
Процедура ПринятьКИсполнениюНаСервере()
	ТекОбъект	= РеквизитФормыВЗначение("Объект");
	ТекОбъект.ПринятьКИсполнению();
	ЗначениеВРеквизитФормы(ТекОбъект, "Объект");
	НастроитьВидимостьИДоступность();
КонецПроцедуры

&НаСервере
Функция ПроверитьПодэтапы()
	Отбор = Новый Структура();
	Отбор.Вставить("Результат","");
	СтрокиБезСобытия = Объект.Подэтапы.НайтиСтроки(Отбор);
	Возврат СтрокиБезСобытия.Количество() <> 0;
КонецФункции

&НаСервере
Процедура ЗаполнитьСуммуИска()
	 СуммаИска 					= Объект.СуммаЗадолженности + Объект.СуммаПени + Объект.Прочие;
	 Объект.СуммаГоспошлина 	= РегистрыСведений.энргНастройкаРасчетаГоспошлины.РассчитатьГоспошлину(СуммаИска, Объект.Дата, Объект.ВидСудопроизводства);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораСхемыБанкротства(Схема, ДополнительныеПараметры) Экспорт
	
	Если Схема <> Неопределено Тогда
		Задача = СоздатьЗадачуБанкротства(Схема);
		
		Если ЗначениеЗаполнено(Задача) Тогда
			ПоказатьЗначение(, Задача);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция СоздатьЗадачуБанкротства(Схема)

	НовЗадача = Задачи.энргЗадачаПИД.СоздатьЗадачу();
	НовЗадача.Схема = Схема;
	НовЗадача.Дата = ТекущаяДата();
	
	ЗаполнитьЗначенияСвойств(НовЗадача, Объект, "Договор, Организация, Район, ЗадачаЮЛ, ПериодЗадолженностиНачало, ПериодЗадолженностиКонец,
	|ВидСудопроизводства,НомерСудебногоДела,ДатаРасчетаПени,ИскСдан,ДатаСдачиИска,СуммаЗадолженности,
	|СуммаПени,Прочие,СуммаГоспошлина,НомерИсполнительногоПроизводства,СтадияИсполнения,
	|ДатаЗаказаИД,ВыданИсполнительныйЛист,ДатаИсполительногоЛиста,ВидИсполнения,
	|ДатаОтправкиЗаявления,СлужбаСудебныхПристовов,ДатаПодачиЗаявленияВСудОБанкротсве,
	|ДатаПубликацииОБанкротстве,ПризнанБанкротом");
	Для Каждого стр Из Объект.Задолженность Цикл
		ЗаполнитьЗначенияСвойств(НовЗадача.Задолженность.Добавить(), стр);
	КонецЦикла;
	Для Каждого стр Из Объект.СудебныеИнстанции Цикл
		ЗаполнитьЗначенияСвойств(НовЗадача.СудебныеИнстанции.Добавить(), стр);
	КонецЦикла;
	Для Каждого стр Из Объект.Суд Цикл
		ЗаполнитьЗначенияСвойств(НовЗадача.Суд.Добавить(), стр);
	КонецЦикла;
	Задачи.энргЗадачаПИД.ЗаполнитьНаименованиеИЭтап(НовЗадача);
	Попытка
		НовЗадача.Записать();
		
		Возврат НовЗадача.Ссылка;
	Исключение
		//ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось создать задачу ОРП по причине: " + ОписаниеОшибки());
	КонецПопытки;
КонецФункции

