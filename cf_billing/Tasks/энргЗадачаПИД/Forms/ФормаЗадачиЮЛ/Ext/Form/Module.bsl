&НаСервере
Процедура ПерерассчитатьПеню()
	РезультатПеня				= бестВзаиморасчетыЮрЛицаСервер.ПолучитьПенюНаДату(Объект.Организация, Объект.Район, КонецДня(Объект.ДатаРасчетаПени), Объект.Договор);
	Выборка = РезультатПеня.Выбрать(); 
	Если Выборка.Следующий() Тогда
		Объект.СуммаПени = Выборка.Сумма;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиНаСледующийЭтапКлиент(Отказ, СледующийЭтап = Неопределено, ПереходНаСудебнуюДеятельность = Ложь)
	 ВыбранСледующийЭтап = ЗначениеЗаполнено(СледующийЭтап);
		
	РекомендуемыйЭтап	= Неопределено;
	СписокЗначений		= ПолучитьИменаКомандЭтапов();
	СледЭтап 			= ?(ВыбранСледующийЭтап, СледующийЭтап, ПолучитьСледующийЭтап(Объект.Схема, Объект.Этап));
	
	
	Досудебный 		= Ложь;
	СудебнаяРабота	= Ложь;
	ИсполнительныйИлиСудебныйЭтап(Объект.Этап, , СудебнаяРабота, Досудебный);
	
	СледЭтапИсполнитльный = Ложь;
	СледЭтапСудебный	  = Ложь;
	ИсполнительныйИлиСудебныйЭтап(СледЭтап, СледЭтапИсполнитльный, СледЭтапСудебный);

	
	Если СписокЗначений.Количество() <> 0 И Не ВыбранСледующийЭтап Тогда 
		//Отказ = Истина;

		СписокЗначений.ПоказатьВыборЭлемента(Новый ОписаниеОповещения("ОбработкаВыбораЭтапа", ЭтотОбъект, Новый Структура("ВыполнитьЗадачу",Истина)), "Выберите следующий этап.", РекомендуемыйЭтап);
		Возврат;
	КонецЕсли;
	
	Если Не Отказ И ЗначениеЗаполнено(СледЭтап) Тогда
	
		ПроверкаНаСоответствиеТребованиямСледующегоЭтапа(Отказ, СледЭтап);
	КонецЕсли;
	
	Если Не Отказ Тогда
		Если Досудебный И СледЭтапСудебный Тогда
			ПереходНаСудебнуюДеятельность = Истина;
			ОткрытьФормуПереходаНаСудебнуюРаботу(СледЭтап);
		КонецЕсли;
	КонецЕсли;
	
	Если СудебнаяРабота И Не Отказ И энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Этап,"Тип") <> ПредопределенноеЗначение("Перечисление.энргТипыЭтапов.Банкротство") Тогда
		Для каждого СтрокаТЧ Из Объект.СудебныеИнстанции Цикл
		
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Дата) Тогда
				Отказ = Истина;
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Перед переходом на следующий этап должна быть заполнена дата в судебной инстанции.";
				Сообщение.Поле = "Объект.СудебныеИнстанции[" + (СтрокаТЧ.НомерСтроки-1) + "].Дата";
				Сообщение.УстановитьДанные(ЭтаФорма);
				Сообщение.Сообщить();
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Номер) Тогда
				Отказ = Истина;
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Перед переходом на следующий этап должен быть заполнен номер в судебной инстанции.";
				Сообщение.Поле = "Объект.СудебныеИнстанции[" + (СтрокаТЧ.НомерСтроки-1) + "].Номер";
				Сообщение.УстановитьДанные(ЭтаФорма);
				Сообщение.Сообщить();
			КонецЕсли;

		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьВходныеДанныеВзысканиеГП(IDСтроки)
	ИдентификаторФормы 				= ЭтаФорма.УникальныйИдентификатор;	
	Возврат Новый Структура("ВзысканиеГП",ПоместитьВоВременноеХранилище(Объект.ВзысканиеГП.Выгрузить(Новый Структура("IDСтроки", IDСтроки)), ИдентификаторФормы))
КонецФункции

&НаКлиенте
Процедура ВзысканиеГПЗавершение(Результат, ДополнительныеПараметры) Экспорт	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭтаФорма.Модифицированность = Истина;
	ТекущиеДанные 				= ДополнительныеПараметры.ТекущиеДанные;
	
	ВзысканиеГП = "Не заполнено";
	ЗаполнитьПотериИзРезультата(ТекущиеДанные.IDСтроки, Результат, ВзысканиеГП);
	ТекущиеДанные.ВзысканиеГП 		= ВзысканиеГП;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПотериИзРезультата(IDСтроки, Результат, ВзысканиеГП)
	энргОбщегоНазначения.ОчиститьТаблицуПоУсловию(Объект.ВзысканиеГП, Новый Структура("IDСтроки", IDСтроки));
	
	ПотериРезультат = ПолучитьИзВременногоХранилища(Результат.ВзысканиеГП);
	ПотериРезультат.Колонки.Добавить("IDСтроки");
	ПотериРезультат.ЗаполнитьЗначения(IDСтроки, "IDСтроки");
	Объект.ВзысканиеГП.Загрузить(ПотериРезультат); 	
	
	Если ПотериРезультат.Количество() > 0 Тогда
		ВзысканиеГП = "Заполнено";	
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекстовыеПоля()
	Для Каждого ТекСтрока ИЗ Объект.СудебныеИнстанции Цикл
		СтрокиВзыскания = Объект.ВзысканиеГП.НайтиСтроки(Новый Структура("IDСтроки",ТекСтрока.IDСтроки));
		ТекСтрока.ВзысканиеГП = ?(СтрокиВзыскания.Количество() > 0, "Заполнено", "Не заполнено");
	КонецЦикла;
КонецПроцедуры

