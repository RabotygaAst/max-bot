&НаКлиенте
Процедура ОткрытьФормуРедактированияШага()
	
	Перем ОписОпов, ПарамФормы, РекФормы;
	
	ТекСтрока = Элементы.Подэтапы.ТекущиеДанные;
	
	РекФормы	= Новый Структура("Задача, Этап, СтартоваяЗадача, IDЭтапа, Подэтап, ДатаНачала, ДатаОкончания, Выполнен, Текущий, Результат, Отменен",
			Объект.Ссылка, Объект.Этап, Объект.СтартоваяЗадача);
	ЗаполнитьЗначенияСвойств(РекФормы, ТекСтрока);		
	
	ПарамФормы  = Новый Структура("РеквизитыФормы", РекФормы);
	ОписОпов	= Новый  ОписаниеОповещения("ЗавершениеЭтапа", ЭтотОбъект);
	ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ФормаВыполнениеШага", ПарамФормы, ЭтаФорма,,,, ОписОпов, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

