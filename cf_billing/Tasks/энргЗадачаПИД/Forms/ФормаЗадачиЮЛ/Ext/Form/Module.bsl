&НаСервере
Процедура ЗаполнитьСудебныеИнстанции()
	
	Если Объект.СудебныеИнстанции.Количество() <> 0 Тогда
		
		ПромежуточнаяТаблица = Новый ТаблицаЗначений;
		ПромежуточнаяТаблица = Объект.СудебныеИнстанции.Выгрузить(,"СудебнаяИинстанция");
		ПромежуточнаяТаблица.Свернуть("СудебнаяИинстанция");
		СписокСудебныеИнстанции.Загрузить(ПромежуточнаяТаблица);
		
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура СписокСудебныеИнстанцииПриАктивизацииСтроки(Элемент)
	Если Объект.СудебныеИнстанции.Количество() <> 0 Тогда
		
		СудебнаяИнстанция = Элементы.СписокСудебныеИнстанции.ТекущиеДанные.СудебнаяИинстанция;
		
		Если ЗначениеЗаполнено(СудебнаяИнстанция) Тогда
			
			Поиск = Новый Структура;
			Поиск.Вставить("СудебнаяИинстанция",СудебнаяИнстанция);
			Элементы.СудебныеИнстанции.ОтборСтрок = Новый ФиксированнаяСтруктура(Поиск);
			
		Иначе
			
