&НаКлиенте
Процедура ВозвращниеНаДоработку(ПарамВыбора, ДополнительныеПараметры) Экспорт
	
	Если ПарамВыбора <> Неопределено Тогда
		Объект.ПометкаУдаления = Истина;
		Записать();
		Если Не ВернутьВРаботуОснование(Объект.Основание, ПарамВыбора) Тогда 
			Объект.ПометкаУдаления = Ложь;
			Записать();
		КонецЕсли;
		НастроитьВидимостьИДоступность();
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВернутьВРаботуОснование(Основание, ПарамВозвращения)
	Попытка
		ОбъкетЗадача = Основание.ПолучитьОбъект();
		ОбъкетЗадача.Выполнена = Ложь;
		ЗаполнитьЗначенияСвойств(ОбъкетЗадача, ПарамВозвращения);
		ОбъкетЗадача.Исполнитель = ПарамВозвращения.НовыйИсполнитель;
		
		СтрокаТЧ = ОбъкетЗадача.ИсторияПеренаправленийЗадачи.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, ПарамВозвращения);
		СтрокаТЧ.Перенаправил				= ПолучитьТекущегоПользователя();
		СтрокаТЧ.ДатаПеренаправления		= ТекущаяДатаСеанса();
		СтрокаТЧ.ПланируемаяДатаВыполнения	= ПарамВозвращения.ДатаСледЭтапа;
		
		ОбъкетЗадача.Записать();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось вернуть в работу предыдущую задачу по причине: " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;	
КонецФункции

&НаКлиенте
Процедура Текущая(Команда)
	ТекСтрока = Элементы.СудебныеИнстанции.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	УстановитьПроверитьТекущуюСудебнуюИнстанцию(ТекСтрока.НомерСтроки);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПроверитьТекущуюСудебнуюИнстанцию(НомерСтроки = Неопределено)
	Если НомерСтроки = Неопределено Тогда
		НомерСтроки = 1;
		Для каждого СтрокаТЧ Из Объект.СудебныеИнстанции Цикл
			Если СтрокаТЧ.Текущая Тогда
				НомерСтроки = СтрокаТЧ.НомерСтроки;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Для каждого СтрокаТЧ Из Объект.СудебныеИнстанции Цикл
		СтрокаТЧ.Текущая = СтрокаТЧ.НомерСтроки = НомерСтроки;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура СудебныеИнстанцииПриИзменении(Элемент)
	ТекДанные = Элементы.СписокСудебныеИнстанции.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ИмяТаблицыТочек 						= "СудебныеИнстанции";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ТекущиеДанные.СудебнаяИинстанция = ТекДанные.СудебнаяИинстанция;
КонецПроцедуры

&НаКлиенте
Процедура НачатьОРП(Команда)
	ОписОпов = Новый ОписаниеОповещения("ОбработкаВыбораСхемыОРП", ЭтаФорма);
	ПарамФормы = Новый Структура("СхемаОРП", Истина);
	
	ОткрытьФорму("Справочник.энргСхемыПИД.ФормаВыбора", ПарамФормы, ЭтаФорма,,,, ОписОпов, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораСхемыОРП(Схема, ДополнительныеПараметры) Экспорт
	
	Если Схема <> Неопределено Тогда
		Задача = СоздатьЗадачуОРП(Схема);
		
		Если ЗначениеЗаполнено(Задача) Тогда
			ПоказатьЗначение(, Задача);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция СоздатьЗадачуОРП(Схема)

	НовЗадача = Задачи.энргЗадачаПИД.СоздатьЗадачу();
	НовЗадача.Схема = Схема;
	НовЗадача.Дата = ТекущаяДата();
	
	ЗаполнитьЗначенияСвойств(НовЗадача, Объект, "Договор, Организация, Район, ЗадачаЮЛ, ПериодЗадолженностиНачало, ПериодЗадолженностиКонец");
	Для Каждого стр Из Объект.Задолженность Цикл
		ЗаполнитьЗначенияСвойств(НовЗадача.Задолженность.Добавить(), стр);
	КонецЦикла;
	
	Задачи.энргЗадачаПИД.ЗаполнитьНаименованиеИЭтап(НовЗадача);
	Попытка
		НовЗадача.Записать();
		
		Возврат НовЗадача.Ссылка;
	Исключение
		//ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось создать задачу ОРП по причине: " + ОписаниеОшибки());
	КонецПопытки;
КонецФункции

&НаКлиенте
Процедура ПерейтиНаСледующийЭтап(Команда)
	ПерейтиНаСледующийЭтапКлиент(Ложь);
	
	ОбщегоНазначенияКлиент.СообщитьПользователю("Переход выполнен");
КонецПроцедуры

#КонецОбласти
