&НаСервере
Функция ПовторитьЭтапНаСервере()
	Отказ = Ложь;
	
	Попытка
		Задачи.энргЗадачаПИД.СоздатьПодчиненнуюЗадачу(Отказ, Объект.Этап, Объект,,,, Истина);
		Если Не Отказ Тогда
			ОбъектЗадача = РеквизитФормыВЗначение("Объект");
			ОбъектЗадача.ВыполнитьЗадачуИнтерактивно();
			ЗначениеВРеквизитФормы(ОбъектЗадача, "Объект");
		КонецЕсли;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Не Отказ;
КонецФункции

&НаКлиенте
Процедура СохранитьИзмененияПередВыполнениемКоманды(Команда)
	
	Перем ОписаниеОповещения;
	
	Если Модифицированность Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаОтветаНаСохранение", ЭтотОбъект, Новый Структура("Команда", Команда));
		ПоказатьВопрос(ОписаниеОповещения, "Сохранить изменения?", РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	
	ОсновноеДействиеКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОтветаНаСохранение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Записать();
		Команда = ДополнительныеПараметры.Команда;
		ОсновноеДействиеКоманды(Команда);
	КонецЕсли;
КонецПроцедуры

