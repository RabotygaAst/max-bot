&НаСервере
Функция ПолучитьИменаКомандЭтапов()

	СписокЗначений = Новый СписокЗначений;
	
	Для каждого КомандаЭтап Из Элементы.ФормаГруппаПерейтиНаЭтап.ПодчиненныеЭлементы Цикл
		Если КомандаЭтап.Доступность Тогда
			СписокЗначений.Добавить(КомандаЭтап.ИмяКоманды, Команды.Найти(КомандаЭтап.ИмяКоманды).Заголовок);
		КонецЕсли;
	КонецЦикла;
	
	Возврат СписокЗначений;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСледующийЭтап(Схема, Этап)

	Возврат Справочники.энргСхемыПИД.ПолучитьСледующийЭтап(Схема, Этап);
КонецФункции

&НаСервереБезКонтекста
Процедура ИсполнительныйИлиСудебныйЭтап(Этап, Исполнитльный = Ложь, Судебный = Ложь, Исполнительный = Ложь)
	
	Задачи.энргЗадачаПИД.ИсполнительныйИлиСудебныйЭтап(Этап, Исполнитльный, Судебный, Исполнительный);
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаНаСоответствиеТребованиямСледующегоЭтапа(Отказ, Знач СледЭтап)
	
	Перем Ответ, ПоСледЭтап, СписокОшибок, ТестОшибки;
	
	СписокОшибок = ЭтапПИР_СоответствуетТребованиям(СледЭтап);
	
	Если ЗначениеЗаполнено(СписокОшибок) Тогда
		Отказ = Истина;
		
		Для каждого ТестОшибки Из СписокОшибок Цикл
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТестОшибки);
			
		КонецЦикла;
		Если Не ЭтапОбязателен(СледЭтап) Тогда 
			ПоСледЭтап = ПолучитьСледующийЭтап(СледЭтап, Объект.Этап);
			Если ЗначениеЗаполнено(ПоСледЭтап) Тогда
				Ответ = Неопределено;
				
				ПоказатьВопрос(Новый ОписаниеОповещения("ОбработкаОтветаОПропускеЭтапа", ЭтотОбъект, Новый Структура("ПоСледЭтап", ПоСледЭтап)), "Нельзя перейти на этап """ + СледЭтап + """. Пропустить?", РежимДиалогаВопрос.ДаНет);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	КонецПроцедуры

&НаКлиенте
Функция ОткрытьФормуПереходаНаСудебнуюРаботу(СледЭтап)
	ПарамФормы = Новый Структура("Задача, СледующийЭтап, Абонент, ПериодЗадолженностиКонец, Организация, Район", Объект.Ссылка, СледЭтап);
	ПарамФормы.Вставить("ДатаЗадачи", Объект.Дата);
	ЗаполнитьЗначенияСвойств(ПарамФормы, Объект);
	ОписОпов = Новый ОписаниеОповещения("ПерейтиНаСудебнуюРаботу", ЭтаФорма);
	ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ФормаПереходаНаСудебнуюРаботу", ПарамФормы, ЭтаФорма,,,, ОписОпов);

	Возврат Истина;
КонецФункции 

&НаСервере
Функция ЭтапКоманды(ИмяКоманды)
	//Команда = Команды.Найти(ИмяКоманды);
	
	НомерЭтапа = Число(СтрЗаменить(ИмяКоманды, "КомандаЭтап", ""));
	
	Возврат Справочники.энргСхемыПИД.ПолучитьЭтапПоНомеру(Объект.Схема, НомерЭтапа);
КонецФункции

&НаСервере
Функция ПерейтиНаЭтапНаСервере(ИмяКоманды)
	Попытка
		Команда = Команды.Найти(ИмяКоманды);
		НачатьТранзакцию();
		ОбъектЗадача = РеквизитФормыВЗначение("Объект");
		Если Модифицированность Тогда
			ОбъектЗадача.Записать();
		КонецЕсли;
		
		СледЭтап = Справочники.энргВидыОперацийПИД.НайтиПоНаименованию(Команда.Заголовок, Истина);
		Если Не ЗначениеЗаполнено(СледЭтап) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден этап """ + Команда.Заголовок + """.");
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецЕсли;
		
		Отказ = Ложь;
		Задачи.энргЗадачаПИД.СоздатьПодчиненнуюЗадачу(Отказ, СледЭтап, ОбъектЗадача,,,, Истина);
		Если Отказ Тогда
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецЕсли;
		//ОбъектЗадача.ВыполнитьЗадачуИнтерактивно();
		
		ЗафиксироватьТранзакцию();
		ЗначениеВРеквизитФормы(ОбъектЗадача, "Объект");
		Модифицированность = Ложь;
		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		ОтменитьТранзакцию();
		Возврат Ложь;
	КонецПопытки;

	Возврат Истина;
КонецФункции

&НаСервере
Функция ЭтапПИР_СоответствуетТребованиям(Этап)

	Возврат Задачи.энргЗадачаПИД.ЭтапПИР_СоответствуетТребованиям(Объект, Этап);

КонецФункции

