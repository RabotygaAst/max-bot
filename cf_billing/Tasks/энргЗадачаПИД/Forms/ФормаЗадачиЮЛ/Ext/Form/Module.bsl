		ЭлементыОтбора = Новый Структура("ВидОперации, Договор, Организация, Район, ДатаОперации, ДатаПубликации", ЗначениеВыбора.Значение, Объект.Договор, Объект.Организация, Объект.Район, Объект.ДатаПодачиЗаявленияВСудОБанкротсве, Объект.ДатаПубликацииОБанкротстве);
		ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
		ОткрытьФорму("Документ.бестРегистрацияБанкротства.ФормаОбъекта", ПараметрыФормы);
