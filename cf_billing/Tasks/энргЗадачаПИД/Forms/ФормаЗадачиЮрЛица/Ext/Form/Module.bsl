&НаКлиенте
Процедура ВыводЗаявленияОВыдачеСудебногоПриказаОВзыскании(Результат, ДополнительныеПараметры) Экспорт
	Если Результат <> Неопределено Тогда
		ПечатьЗаявленияОВыдачеСудебногоПриказаОВзысканииНаСервере(Результат.СписокДок, Результат.ОтветНаПритензию).Показать("Заявления о выдаче судебного приказа о взыскании");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЭтап(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент <> Неопределено Тогда
		ОбновитьНаименованиеНаСервере(ВыбранныйЭлемент.Значение);
	КонецЕсли;
	СоздатьКоманды();
	ОтобразатьКнопкуПечати();

КонецПроцедуры

&НаКлиенте
Процедура УстановкаЭтапаНачальнойЗадачи()
	Перем СписокЭтапов;
	
	СписокЭтапов = ПолучитьСписокЭтапов(Объект.Схема);
	
	Если СписокЭтапов.Количество() > 1 Тогда
		СписокЭтапов.ПоказатьВыборЭлемента(Новый ОписаниеОповещения("УстановитьЭтап", ЭтотОбъект), "Этап", СписокЭтапов[0]);
	Иначе
		СоздатьКоманды();
		ОтобразатьКнопкуПечати();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция ОткрытьФормуПереходаНаСудебнуюРаботу(СледЭтап)
	ПарамФормы = Новый Структура("Задача, СледующийЭтап, Договор, ПериодЗадолженностиКонец, Организация, Район", Объект.Ссылка, СледЭтап);
	ПарамФормы.Вставить("ДатаЗадачи", Объект.Дата);
	ЗаполнитьЗначенияСвойств(ПарамФормы, Объект);
	ОписОпов = Новый ОписаниеОповещения("ПерейтиНаСудебнуюРаботу", ЭтаФорма);
	ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ФормаПереходаНаСудебнуюРаботу", ПарамФормы, ЭтаФорма,,,, ОписОпов);

	Возврат Истина;
КонецФункции 

&НаКлиенте
Процедура ОбработкаДобавленияЗадолженности(СтрокиЗадолженности, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(СтрокиЗадолженности) Тогда
		Для каждого НовДолг Из СтрокиЗадолженности Цикл
			СтрокаТЧ = Объект.Задолженность.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, НовДолг);
		КонецЦикла;
		
		Модифицированность = Истина;
		ОбновитьЗадолженностьНаСервере();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиНаСудебнуюРаботу(ПарамСудебнойРаботы, ДополнительныеПараметры) Экспорт
	
	Если ПарамСудебнойРаботы <> Неопределено Тогда
		Если ПерейтиНаСудебнуюРаботуНаСервере(ПарамСудебнойРаботы) Тогда
			ПрикрепитьФайлыКСудебнойРаботеНаКлиенте();
			УстановитьДоступностьЭлементов();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СменаИсполнителя(ПарамВыбора, ДополнительныеПараметры) Экспорт
	
	Если ПарамВыбора <> Неопределено Тогда
		Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("ПодтверждениеПередачи") Тогда
		 	ПодтверждениеПередачи = Истина;
		Иначе
		    ПодтверждениеПередачи = Ложь;
		КонецЕсли;
		
		Модифицированность = Истина;
		
		Если ПодтверждениеПередачи И ЗначениеЗаполнено(Объект.ИсторияПеренаправленийЗадачи) Тогда
			СтрокаТЧ = Объект.ИсторияПеренаправленийЗадачи[Объект.ИсторияПеренаправленийЗадачи.Количество()-1];
		Иначе
			СтрокаТЧ = Объект.ИсторияПеренаправленийЗадачи.Добавить();
			
			СтрокаТЧ.ДатаПеренаправления = ПолучитьДатуСеанса();
			СтрокаТЧ.Роль				 = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Этап, "Роль");
			СтрокаТЧ.Перенаправил		 = ПолучитьТекущегоПользователя();
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, ПарамВыбора);
		
		РольРуководителя = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Роль, "РольРуководителя");
		
		Если ПодтверждениеПередачи Тогда
			Объект.Роль					= СтрокаТЧ.Роль;
			Объект.ТребуетПодтверждения = Ложь;
			Объект.Исполнитель 			= ПарамВыбора.НовыйИсполнитель;
		ИначеЕсли ЗначениеЗаполнено(РольРуководителя) Тогда
			Объект.Исполнитель 			= Неопределено;
			Объект.Роль					= РольРуководителя;
			Объект.ТребуетПодтверждения = Истина;
		Иначе
			Объект.Исполнитель = ПарамВыбора.НовыйИсполнитель;
		КонецЕсли;
		
		Объект.Комментарий		= ПарамВыбора.Комментарий;
		Объект.ПринятоВРаботу   = Ложь;
		Объект.ДатаПринятияВРаботу = Неопределено;
		
		Если ЗначениеЗаполнено(ПарамВыбора.ДатаСледЭтапа) Тогда
			Объект.ДатаСледЭтапа			   = ПарамВыбора.ДатаСледЭтапа;
			СтрокаТЧ.ПланируемаяДатаВыполнения = ПарамВыбора.ДатаСледЭтапа;
		КонецЕсли;
		
		//Если ПодтверждениеПередачи Тогда
		
			Записать();
			Закрыть();
		
		//КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СменаИсполнителяНаСотрудникаУКЗ(ПарамВыбора, ДополнительныеПараметры) Экспорт
	
	Если ПарамВыбора <> Неопределено Тогда
		Модифицированность = Ложь;
		
		СтрокаТЧ = Объект.ИсторияПеренаправленийЗадачи.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, ПарамВыбора);
		СтрокаТЧ.Перенаправил		 = ПолучитьТекущегоПользователя();
		СтрокаТЧ.ДатаПеренаправления = ПолучитьДатуСеанса();
		
		Объект.Исполнитель = ПарамВыбора.НовыйИсполнитель;
		Объект.Комментарий = ПарамВыбора.Комментарий;
		
		ДатаСледЭтапа = ?(ЗначениеЗаполнено(ПарамВыбора.ДатаСледЭтапа), ПарамВыбора.ДатаСледЭтапа, НачалоДня(ТекущаяДата() + 7*24+3600));
		Объект.ДатаСледЭтапа			   = ДатаСледЭтапа;
		СтрокаТЧ.ПланируемаяДатаВыполнения = ДатаСледЭтапа;
		
		Записать();
		Закрыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВозвращниеНаДоработку(ПарамВыбора, ДополнительныеПараметры) Экспорт
	
	Если ПарамВыбора <> Неопределено Тогда
		Объект.ПометкаУдаления = Истина;
		Записать();
		Если Не ВернутьВРаботуОснование(Объект.Основание, ПарамВыбора) Тогда 
			Объект.ПометкаУдаления = Ложь;
			Записать();
		КонецЕсли;
		УстановитьДоступностьЭлементов();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТЧ_Задолженность(Ветвь)
	Ветви = Ветвь.ПолучитьЭлементы();
	
	Если ЗначениеЗаполнено(Ветви) Тогда
		Для каждого Подветвь Из Ветви Цикл
			ЗаполнитьТЧ_Задолженность(Подветвь);
		КонецЦикла;
	Иначе
		Если ЗначениеЗаполнено(Ветвь.Задолженность) Тогда 
			СтрокаТЧ = Объект.Задолженность.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, Ветвь);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ОтобразатьКнопкуПечати()
	Элементы.ФормаПечать.Видимость = Ложь;
	ИмяМакета = "";
	
	Префикс = "КомандаЭтап_";
	Для каждого ТекКоманда Из Элементы.ГрппаКнопкиОтправкиЭП.ПодчиненныеЭлементы Цикл
		Если Лев(ТекКоманда.Имя, СтрДлина(Префикс)) <> Префикс Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяЭтапа = СтрЗаменить(ТекКоманда.Имя, Префикс, "ЭтапПретензионноИсковойДеятельности_");
		Если Объект.Этап = ПредопределенноеЗначение("Справочник.энргВидыОперацийПИД." + ИмяЭтапа) Тогда
			ТекКоманда.Видимость = Истина;
			Элементы.ФормаПечать.Видимость = Истина;
			ИмяМакета = СтрЗаменить(ТекКоманда.Имя, Префикс, "ПФ_MXL_");
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПроверитьТекущуюСудебнуюИнстанцию(НомерСтроки = Неопределено)
	Если НомерСтроки = Неопределено Тогда
		НомерСтроки = 1;
		Для каждого СтрокаТЧ Из Объект.СудебныеИнстанции Цикл
			Если СтрокаТЧ.Текущая Тогда
				НомерСтроки = СтрокаТЧ.НомерСтроки;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Для каждого СтрокаТЧ Из Объект.СудебныеИнстанции Цикл
		СтрокаТЧ.Текущая = СтрокаТЧ.НомерСтроки = НомерСтроки;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьтолькоПросмотрДляЭлементов()
	
	Если ЗначениеЗаполнено(Объект.Основание) Тогда
		Элементы.Организация.ТолькоПросмотр = Истина;
		Элементы.Поставщик.ТолькоПросмотр	= Истина;
		Элементы.Схема.ТолькоПросмотр		= Истина;
		Элементы.Абонент.ТолькоПросмотр		= Истина;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокБанкротства(ПарамВыбора, ДополнительныеПараметры) Экспорт
	УстановитьПараметрыИВидимостьБанкротства();
КонецПроцедуры

&НаКлиенте
Процедура ПрикрепитьФайлыКСудебнойРаботеНаКлиенте()
	
	ПутьКФайлам = ПолучитьПапкуДляПрикрепленияФайловСудебнойРаботы();
	Если НЕ ЗначениеЗаполнено(ПутьКФайлам) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ВладелецФайла", ?(ЗначениеЗаполнено(Объект.СтартоваяЗадача), Объект.СтартоваяЗадача, Объект.Ссылка));
	ДополнительныеПараметры.Вставить("ГруппаФайлов", Неопределено);
	ДополнительныеПараметры.Вставить("ИдентификаторФормы", УникальныйИдентификатор);
	ДополнительныеПараметры.Вставить("Фильтр", "");
	ДополнительныеПараметры.Вставить("МассоваяЗагрузка", Истина);
	ДополнительныеПараметры.Вставить("ПутьКФайлам", ПутьКФайлам);
	
	РаботаСФайламиСлужебныйКлиент.ДобавитьФайлыРасширениеПредложено(Истина, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСостояниеПодэтапов()

	Для каждого СтрокаТЧ Из Объект.Подэтапы Цикл
		Если СтрокаТЧ.Выполнен Тогда
			СтрокаТЧ.Состояние = "Завершен";
		ИначеЕсли СтрокаТЧ.Текущий Тогда
			СтрокаТЧ.Состояние = "Текущий";
		ИначеЕсли СтрокаТЧ.Отменен Тогда
			СтрокаТЧ.Состояние = "Отменен";
		Иначе
			СтрокаТЧ.Состояние = "Запланирован";
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

