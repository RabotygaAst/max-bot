&НаСервере
Функция ПерейтиНаСудебнуюРаботуНаСервере(ПарамСудебнойРаботы)
	Попытка
		НачатьТранзакцию();
		ОбъектЗадача = РеквизитФормыВЗначение("Объект");
		Если Модифицированность Тогда
			ОбъектЗадача.Записать();
		КонецЕсли;
		
		СледЭтап = ПарамСудебнойРаботы.СледующийЭтап;
		Если Не ЗначениеЗаполнено(СледЭтап) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не определён следующий этап.");
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецЕсли;
		
		Отказ = Ложь;
		Задачи.энргЗадачаПИД.СоздатьПодчиненнуюЗадачу(Отказ, СледЭтап, ОбъектЗадача, ПарамСудебнойРаботы, ПарамСудебнойРаботы.Задолженность);
		Если Отказ Тогда
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецЕсли;
		ОбъектЗадача.ВыполнитьЗадачуИнтерактивно();
		
		ЗначениеВРеквизитФормы(ОбъектЗадача, "Объект");
		Модифицированность = Ложь;
		
		СтартоваяЗадача = ?(ЗначениеЗаполнено(Объект.СтартоваяЗадача), Объект.СтартоваяЗадача, Объект.Ссылка);
		
		// Прикрепление файлов из документа
		Для каждого Справочник Из ПарамСудебнойРаботы.ПрикрепляемыеФайлы Цикл		
			ПараметрыДобавляемогоФайла	= Новый Структура;
			ПараметрыДобавляемогоФайла.Вставить("ВладелецФайлов", СтартоваяЗадача);
			ПараметрыДобавляемогоФайла.Вставить("Автор", Справочник.Автор);
			ПараметрыДобавляемогоФайла.Вставить("ИмяБезРасширения", Справочник.Наименование);
			ПараметрыДобавляемогоФайла.Вставить("РасширениеБезТочки", Справочник.Расширение);
			ПараметрыДобавляемогоФайла.Вставить("ВремяИзменения", МестноеВремя(Справочник.ДатаМодификацииУниверсальная, ЧасовойПоясСеанса()));
			ПараметрыДобавляемогоФайла.Вставить("ВремяИзмененияУниверсальное", Справочник.ДатаМодификацииУниверсальная);
			    
			ЗаписьИсточник = РегистрыСведений.ДвоичныеДанныеФайлов.СоздатьМенеджерЗаписи();
			ЗаписьИсточник.Файл = Справочник;
			ЗаписьИсточник.Прочитать();
			ДвоичныйФайл = ЗаписьИсточник.ДвоичныеДанныеФайла.Получить();
			АдресХранилищаОтчета = ПоместитьВоВременноеХранилище(ДвоичныйФайл);
			
			РаботаСФайлами.ДобавитьФайл(ПараметрыДобавляемогоФайла, АдресХранилищаОтчета);
		КонецЦикла;
		
		ИмяКаталогаОтчета	= СтрЗаменить(ПолучитьИмяВременногоФайла(".tmp"), ".tmp", "");

		// Создание временного каталога
		Отказ = Ложь;
		Попытка
			СоздатьКаталог(ИмяКаталогаОтчета);
		Исключение
			Отказ = Истина;
		КонецПопытки;

		// Добавление в файлы "Уведомления"
		ТабДок = СформироватьТабДокУведомление(Объект.Ссылка, Ложь);
		Если ТабДок <> Неопределено Тогда
			
			ИмяФайла = ИмяКаталогаОтчета + "\Уведомление.pdf";
			
			// Создание временного каталога
			Попытка
				ТабДок.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.PDF);
				
				ФайлОтчета 				= Новый ДвоичныеДанные(ИмяФайла); 
				АдресХранилищаОтчета 	= ПоместитьВоВременноеХранилище(ФайлОтчета);
				
				ДатаМодификацииФайла		= ТекущаяДатаСеанса();
				ПараметрыДобавляемогоФайла	= Новый Структура;
				ПараметрыДобавляемогоФайла.Вставить("ВладелецФайлов"				, СтартоваяЗадача);
				ПараметрыДобавляемогоФайла.Вставить("Автор"							, Строка(ПараметрыСеанса.ТекущийПользователь));
				ПараметрыДобавляемогоФайла.Вставить("ИмяБезРасширения"				, "Уведомление");
				ПараметрыДобавляемогоФайла.Вставить("РасширениеБезТочки"			, "pdf");
				ПараметрыДобавляемогоФайла.Вставить("ВремяИзменения"				, МестноеВремя(ДатаМодификацииФайла, ЧасовойПоясСеанса()));
				ПараметрыДобавляемогоФайла.Вставить("ВремяИзмененияУниверсальное"	, ДатаМодификацииФайла);
				РаботаСФайлами.ДобавитьФайл(ПараметрыДобавляемогоФайла, АдресХранилищаОтчета); 
			Исключение
			КонецПопытки;
		КонецЕсли;
		Если ЗначениеЗаполнено(ИмяКаталогаОтчета) Тогда
			Попытка
				УдалитьФайлы(ИмяКаталогаОтчета);
			Исключение
			КонецПопытки;
		КонецЕсли;

		ЗафиксироватьТранзакцию();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		ОтменитьТранзакцию();
		Возврат Ложь;
	КонецПопытки;

	Возврат Истина;
КонецФункции

&НаСервереБезКонтекста
Функция СформироватьТабДокУведомление(Задача, ТолькоКвитанцию = Истина)
	ИмяМакета = "ПФ_MXL_Уведомление";
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	Если ТолькоКвитанцию Тогда
		ОбластиМакета = Новый Структура("Квитанция");
	Иначе
		ОбластиМакета = Новый Структура("БланкФилиала, Шапка");
	КонецЕсли;
	
	ЕстьКвит = Справочники.энргВидыОперацийПИД.СформироватьПечатнуюФормуЭтапа(Задача, ИмяМакета, ТабличныйДокумент, ОбластиМакета);

	Если ЕстьКвит Тогда 
		Возврат ТабличныйДокумент;
	Иначе	
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

&НаСервереБезКонтекста
Функция ВернутьВРаботуОснование(Основание, ПарамВозвращения)
	Попытка
		ОбъкетЗадача = Основание.ПолучитьОбъект();
		ОбъкетЗадача.Выполнена = Ложь;
		ЗаполнитьЗначенияСвойств(ОбъкетЗадача, ПарамВозвращения);
		ОбъкетЗадача.Исполнитель = ПарамВозвращения.НовыйИсполнитель;
		
		СтрокаТЧ = ОбъкетЗадача.ИсторияПеренаправленийЗадачи.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, ПарамВозвращения);
		СтрокаТЧ.Перенаправил				= ПолучитьТекущегоПользователя();
		СтрокаТЧ.ДатаПеренаправления		= ТекущаяДатаСеанса();
		СтрокаТЧ.ПланируемаяДатаВыполнения	= ПарамВозвращения.ДатаСледЭтапа;
		
		ОбъкетЗадача.Записать();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось вернуть в работу предыдущую задачу по причине: " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьДатуСледСтатусОтчёта(Дело)

	Если Не ЗначениеЗаполнено(Дело) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргКомментарииКСудебномуДелу.Период КАК Период,
		|	энргКомментарииКСудебномуДелу.ДатаСледующегоОтчёта КАК ДатаСледующегоОтчёта,
		|	энргКомментарииКСудебномуДелу.Ссылка КАК СтатусОтчёт
		|ПОМЕСТИТЬ ВТ_СтатусОтчёт
		|ИЗ
		|	Справочник.энргКомментарииКСудебномуДелу КАК энргКомментарииКСудебномуДелу
		|ГДЕ
		|	энргКомментарииКСудебномуДелу.Дело = &Дело
		|	И энргКомментарииКСудебномуДелу.СтатусОтчет
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВТ_СтатусОтчёт.Период) КАК Период
		|ПОМЕСТИТЬ ВТ_ДатаПослОтчёта
		|ИЗ
		|	ВТ_СтатусОтчёт КАК ВТ_СтатусОтчёт
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВТ_СтатусОтчёт.ДатаСледующегоОтчёта) КАК ДатаСледующегоОтчёта
		|ИЗ
		|	ВТ_ДатаПослОтчёта КАК ВТ_ДатаПослОтчёта
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СтатусОтчёт КАК ВТ_СтатусОтчёт
		|		ПО ВТ_ДатаПослОтчёта.Период = ВТ_СтатусОтчёт.Период";
	
	Запрос.УстановитьПараметр("Дело", Дело);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ДатаСледующегоОтчёта;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции 

