&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	УстановитьДоступностьЭлементов();
	УстановитьПараметрыКомментарии();
	УстановитьтолькоПросмотрДляЭлементов();
	УстановитьСостояниеПодэтапов();
КонецПроцедуры

&НаКлиенте
Процедура ПередВыполнением(Отказ)
	Если Объект.ПометкаУдаления Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нельзя выполнить помеченную на удаление задачу.");
		Возврат;
	КонецЕсли;
	
	Если ЗадачаПоПереговорам И Объект.СуммаЗадолженности = 0 Тогда
		Отказ = Истина;
		ПрекратитьПИД(Неопределено);
		Возврат;
	КонецЕсли;
	
	РекомендуемыйЭтап	= Неопределено;
	СписокЗначений		= ПолучитьИменаКомандЭтапов();

	ТипЭтапа = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Этап, "Тип");
	СудебнаяРабота = ПредопределенноеЗначение("Перечисление.энргТипыЭтапов.СудебнаяРабота") = ТипЭтапа;
	
	Если Не СудебнаяРабота И СписокЗначений.Количество() <> 0 Тогда 
		Отказ = Истина;

		СписокЗначений.ПоказатьВыборЭлемента(Новый ОписаниеОповещения("ОбработкаВыбораЭтапа", ЭтотОбъект), "Выберите следующий этап.", РекомендуемыйЭтап);
	КонецЕсли;
	
	Если Не Отказ Тогда
		СледЭтап = ПолучитьСледующийЭтап(Объект.Схема, Объект.Этап);
		Если НачалоСудебнойРаботы(Объект.Этап, СледЭтап) Тогда
			Отказ = Истина;
			ОткрытьФормуПереходаНаСудебнуюРаботу(СледЭтап);
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтоСудебнаяРабота И Не Отказ Тогда
		Для каждого СтрокаТЧ Из Объект.СудебныеИнстанции Цикл
		
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Дата) Тогда
				Отказ = Истина;
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Перед переходом на следующий этап должна быть заполнена дата в судебной инстанции.";
				Сообщение.Поле = "Объект.СудебныеИнстанции[" + (СтрокаТЧ.НомерСтроки-1) + "].Дата";
				Сообщение.УстановитьДанные(ЭтаФорма);
				Сообщение.Сообщить();
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Номер) Тогда
				Отказ = Истина;
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Перед переходом на следующий этап должен быть заполнен номер в судебной инстанции.";
				Сообщение.Поле = "Объект.СудебныеИнстанции[" + (СтрокаТЧ.НомерСтроки-1) + "].Номер";
				Сообщение.УстановитьДанные(ЭтаФорма);
				Сообщение.Сообщить();
			КонецЕсли;

		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "УстановитьДатуЭП" Тогда
		ОбновитьДатуОтправки("ДатаОповещенияПоЭП", ПредопределенноеЗначение("Справочник.энргСпособСвязи.ОтправкаПисьмаНаЭлектроннуюПочту"));
		УстановитьДоступностьЭлементов();
	ИначеЕсли ИмяСобытия = "УстановитьДатуSMS" Тогда
		ОбновитьДатуОтправки("ДатаОтправкиSMS", ПредопределенноеЗначение("Справочник.энргСпособСвязи.ОтправкаСМС"));
		УстановитьДоступностьЭлементов();
	ИначеЕсли ИмяСобытия = "ВернутьВРаботу" Тогда
		ВернутьВРаботу(Неопределено);
	ИначеЕсли ИмяСобытия = "ОбновитьСобытия" Тогда
		УстановитьДоступностьЭлементов();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ОбновитьЗадолженностьНаСервере();
	ЗаполнитьСуммуИска();
	УстановитьПараметрыВнешВоздействие();
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Не ЭтоИсполнительнаяРабота И Не ЭтоСудебнаяРабота Тогда
		Объект.Задолженность.Очистить();
		ЗаполнитьТЧ_Задолженность(ДеревоЗадолженности);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

