#Область ТабличнаяЧастьНепогашенныеНачисления

&НаКлиенте
Процедура НепогашенныеНачисленияПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ 		 = Истина;
	СписокДолгов = Новый Массив;
	
	Для каждого СтрокаТЧ Из Объект.Задолженность Цикл
		СписокДолгов.Добавить(Новый Структура("ПериодНачисления, Услуга", СтрокаТЧ.ПериодНачисления, СтрокаТЧ.Услуга));
	КонецЦикла;
	
	ПарамФормы = Новый Структура("Организация, Район, Договор");
	ЗаполнитьЗначенияСвойств(ПарамФормы, Объект);
	ПарамФормы.Вставить("Задача", Объект.Ссылка);
	ПарамФормы.Вставить("СписокЗадолженности", СписокДолгов);
	                                        
	ОписОпов = Новый ОписаниеОповещения("ОбработкаДобавленияЗадолженности", ЭтаФорма);
	ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ФормаДобавленияЗадолженности", ПарамФормы, ЭтаФорма,,,, ОписОпов);
КонецПроцедуры

