&НаКлиенте
Процедура ЗавершениеЭтапа(Результат, ДополнительныеПараметры) Экспорт
	Перем IDЭтапа;
	
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("IDЭтапа", IDЭтапа) Тогда 
		Отбор = Новый Структура("IDЭтапа", IDЭтапа);
		
		СтрокиТЗ = Объект.Подэтапы.НайтиСтроки(Отбор);
		Если ЗначениеЗаполнено(СтрокиТЗ) Тогда
			ТекСтрока = СтрокиТЗ[0];
		Иначе
			Возврат;
		КонецЕсли;
		
		Модифицированность = Истина;
		ЗаполнитьЗначенияСвойств(ТекСтрока, Результат);
		//ТекСтрока.Результат		  = Результат.Результат;
		//ТекСтрока.ДатаОкончания   = Результат.ДатаОкончания;
		
		СписокФайловШага = Неопределено;
		Если Результат.Свойство("СписокФайловШага", СписокФайловШага) Тогда
			ФайлыЭтапа = Объект.ФайлыПодэтапов.НайтиСтроки(Отбор);
			
			Для каждого ТекСтрока Из ФайлыЭтапа Цикл
				Объект.ФайлыПодэтапов.Удалить(ТекСтрока);
			КонецЦикла;
			
			Для каждого ТекФайл Из СписокФайловШага Цикл
			
				СтрокаТЧ = Объект.ФайлыПодэтапов.Добавить();
				СтрокаТЧ.IDЭтапа = IDЭтапа;
				СтрокаТЧ.Файл	 = ТекФайл;
			
			КонецЦикла;
			
		КонецЕсли;
		
		//ТекСтрока.Текущий		  = Ложь;
		//ТекСтрока.Отменен		  = Ложь;
		Если ТекСтрока.Выполнен И Не ЗначениеЗаполнено(ТекСтрока.ДатаОкончания) Тогда
			ТекСтрока.ДатаОкончания = ТекущаяДата();
		КонецЕсли;
		Если (ТекСтрока.Выполнен Или ТекСтрока.Текущий) И Не ЗначениеЗаполнено(ТекСтрока.ДатаНачала) Тогда
			ТекСтрока.ДатаНачала = ТекущаяДата();
		КонецЕсли;
		
		СтрокиТЗ = Объект.Подэтапы.НайтиСтроки(Новый Структура("Текущий", Истина));
		НайденаСледующая = Ложь;
		Если Не ЗначениеЗаполнено(СтрокиТЗ) Тогда
		    Объект.Подэтапы.Сортировать("Порядок Возр");
			
			Для каждого ТекСтрока Из Объект.Подэтапы Цикл
			
				Если НайденаСледующая И Не ТекСтрока.Параллельно Тогда
					Прервать;
				КонецЕсли;
				
				Если Не (ТекСтрока.Выполнен Или ТекСтрока.Отменен) Тогда
					ТекСтрока.Текущий		= Истина;
					ТекСтрока.ДатаНачала	= ТекущаяДата();
					ТекСтрока.ДатаОкончания	= ?(ЗначениеЗаполнено(ТекСтрока.Продолжительность), ТекущаяДата()+24*3600*ТекСтрока.Продолжительность, Неопределено);
					
					НайденаСледующая		= Истина;
				КонецЕсли;
			КонецЦикла;
		Иначе
			НайденаСледующая = Истина;
		КонецЕсли;
		
		УстановитьСостояниеПодэтапов();
		ПодэтапыПриАктивизацииСтроки(Неопределено);
		//Модифицированность = Ложь;
		Записать();
		
		Если Не НайденаСледующая Тогда
		    Ответ = Неопределено;

		    ПоказатьВопрос(Новый ОписаниеОповещения("ОбработкаОтветаНаВыполнениеЗадачи", ЭтотОбъект), "Все шаги завершены. Перейти к следующему этапу?", РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

