&НаКлиенте
Процедура ИсполнительныеДокументыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	ПерваяЗапись = Не ЗначениеЗаполнено(Объект.ИсполнительныеДокументы);
	СтрокаТЧ	 = Объект.ИсполнительныеДокументы.Добавить();
	
	СтрокаТЧ.ИсполнительныйДокумент = ?(Объект.ВидСудопроизводства = ПредопределенноеЗначение("Перечисление.энргВидыСудопроизводства.ПриказноеПроизводство"),
					ПредопределенноеЗначение("Перечисление.энргСтатусыСудебногоАкта.СудебныйПриказ"),
					ПредопределенноеЗначение("Перечисление.энргСтатусыСудебногоАкта.ИсполнительныйЛист"));
					
	Если ПерваяЗапись Тогда
		СтрокаТЧ.Предъявлен = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "Контрагент");
		СтрокаТЧ.Долг		= Объект.СуммаЗадолженности;
		СтрокаТЧ.Пеня		= Объект.СуммаПени;
		СтрокаТЧ.Госпошлина	= Объект.СуммаГоспошлина;
		СтрокаТЧ.Прочие		= Объект.Прочие;
		
		ЗаполнитьСуммуИска();
		УстановитьДоступностьСуммИспол();
	КонецЕсли;
КонецПроцедуры

