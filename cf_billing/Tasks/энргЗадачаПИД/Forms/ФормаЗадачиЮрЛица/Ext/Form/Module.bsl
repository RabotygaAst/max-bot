КонецПроцедуры

&НаКлиенте
Процедура ПланПогашенияЗадолженностиДатаПриИзменении(Элемент)
	ТекСтрока = Элементы.ПланПогашенияЗадолженности.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекСтрока.Дата < Объект.Дата Тогда
		ТекСтрока.Дата = Объект.Дата;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата плановой выплаты не может быть раньше даты задачи.");
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура СудебныеИнстанцииПриИзменении(Элемент)
	УстановитьПроверитьТекущуюСудебнуюИнстанцию();
КонецПроцедуры

&НаКлиенте
Процедура СудебныеИнстанцииПослеУдаления(Элемент)
	УстановитьПроверитьТекущуюСудебнуюИнстанцию();
КонецПроцедуры

&НаКлиенте
Процедура ВидИсполненияПриИзменении(Элемент)
	Элементы.ГруппаИсполнительноеПроизводство.Видимость	= Объект.ВидИсполнения = ПредопределенноеЗначение("Перечисление.энргВидыИсполнительногоПроизводства.ФССП");
КонецПроцедуры

&НаКлиенте
Процедура СтатусСудебногоДелаПриИзменении(Элемент)
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура СудебныеЗаседанияПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	СохрнаитьИзмененияПередВыполнениемКоманды(Команды.Найти("НачатьБанкротство"));
КонецПроцедуры
#КонецОбласти

#Область ОбработкиКомандФормы

&НаКлиенте
Процедура Создать(Команда)
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьЗадолженность(Команда)
	Модифицированность = Истина;
	УстановитьПараметрыИВидимостьБанкротства();
КонецПроцедуры

&НаКлиенте
Процедура ВернутьВРаботу(Команда)
	Если Не Объект.Выполнена Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Задача находится в работе.");
		Возврат;
	КонецЕсли;
	
	СписокЗадач = ПодчинённыеЗадачи(Объект.Ссылка);
	Если СписокЗадач.Количество() > 0 Тогда
		ПарамФормы = Новый Структура("СписокЗадач", СписокЗадач);
		ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ФормаПоследующиеЗадачи", ПарамФормы, ЭтаФорма);
		Возврат;
	КонецЕсли;
	
	Объект.Выполнена = Ложь;
	СоздатьКоманды();
	Записать();
КонецПроцедуры

&НаКлиенте
Процедура ПовторитьЭтап(Команда)
	Если Модифицированность Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Перед созданием подчиненной задачи, необходимо записать изменения.");
		Возврат;
	КонецЕсли;
	
	Если ПовторитьЭтапНаСервере() Тогда 
		УстановитьДоступностьЭлементов();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПрекратитьПИД(Команда)
	Если ПрекратитьПИДНаСервере(Истина) Тогда
		УстановитьДоступностьЭлементов();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВозобновитьПИД(Команда)
	Если ПрекратитьПИДНаСервере(Ложь) Тогда
		УстановитьДоступностьЭлементов();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВзятьВРаботу(Команда)
	Объект.Исполнитель = ПользователиКлиентСервер.АвторизованныйПользователь();
	Объект.ПринятоВРаботу = Истина; 
	Объект.ДатаПринятияВРаботу = ТекущаяДата();
	
	Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиНаЭтап(Команда)
	СледЭтап = ЭтапКоманды(Команда.Имя);
	
	Если НачалоСудебнойРаботы(Объект.Этап, СледЭтап) Тогда
		ОткрытьФормуПереходаНаСудебнуюРаботу(СледЭтап);
	Иначе
		Если ПерейтиНаЭтапНаСервере(Команда.Имя) Тогда
			УстановитьДоступностьЭлементов();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Печать(Команда)
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьНаПочту(Команда)
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьПисьмо(Команда)
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСМС(Команда)
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ПередатьЗадачуДругомуПользователю(Команда)
	ОписОпов = Новый ОписаниеОповещения("СменаИсполнителя", ЭтаФорма);
	ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ФормаСменыИсполнителя",, ЭтаФорма,,,, ОписОпов);
КонецПроцедуры

&НаКлиенте
Процедура ВернутьНаДоработку(Команда)
	Если Объект.Выполнена Тогда
		Возврат;
	КонецЕсли;
	
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ТекущаяСудебнаяИнстанция(Команда)
	ТекСтрока = Элементы.СудебныеИнстанции.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	УстановитьПроверитьТекущуюСудебнуюИнстанцию(ТекСтрока.НомерСтроки);
КонецПроцедуры

&НаКлиенте
Процедура ПечатьЗаявлениеОВынесенииСудебногоПриказа(Команда)
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ПечатьЗаявленияОВыдачеСудебногоПриказаОВзыскании(Команда)
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ПечатьЗаявленияОВозбужденииИсполнительногоПроизводства(Команда)
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ТолькоВажныеКомментарии(Команда)
	Если Команда = Команды.Найти("ТолькоВажныеКомментарии") Тогда
		Элемент = Элементы.КомментарииКДелуТолькоВажныеКомментарии;
	    ДинамСписок = "КомментарииКДелу"; 
	ИначеЕсли Команда = Команды.Найти("ТолькоВажныеСтатусОтчеты") Тогда
		Элемент = Элементы.СтатусОтчетыТолькоВажныеСтатусОтчеты;
		ДинамСписок = "СтатусОтчеты";
	Иначе
		Возврат;
	КонецЕсли;
	
	ТолькоВажные = Элемент.Заголовок = "Только важные";                  
	
	УстановитьПризнакОтоброжатьТолькоВажные(ДинамСписок, ТолькоВажные);
	Элемент.Заголовок = ?(ТолькоВажные, "Отобразить все", "Только важные");
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗадолженность(Команда)
	
	ОбновитьЗадолженностьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСуммыИска(Команда)
	СохрнаитьИзмененияПередВыполнениемКоманды(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьУслугу(Команда)
	ОсновноеДействиеКоманды(Команда);
КонецПроцедуры

#КонецОбласти

#Область ДополнительныеФункцииНаКлиенте

&НаКлиенте
Процедура УстановитьДоступностьЭлементов() 
	
	Элементы.СобытияПоЭтапу.Обновить();
	ТипЭтапа 				= энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Этап, "Тип");
	ВыпИлиПометУдал 		= Объект.Выполнена Или Объект.ПометкаУдаления Или Не Объект.ПринятоВРаботу;
	СудебнаяРабота		 	= ЭтоСудебнаяРабота;
	ИсполнительнаяРабота 	= ЭтоИсполнительнаяРабота;
	
	ПринятоВРаботу = Объект.ПринятоВРаботу; 
	Если ЕстьСобытияПоЗадаче(Объект.Ссылка) И Объект.ПринятоВРаботу Тогда 
		МожноВыполнить = Истина;
	иначе 
		МожноВыполнить = Ложь;
	КонецЕсли;
	
	Элементы.ФормаВыполнить.Доступность = МожноВыполнить;
	Элементы.ФормаВыполнитьИЗакрыть.Доступность = МожноВыполнить;
	
	ДатаСледующегоОтчёта 	= ПолучитьДатуСледСтатусОтчёта(Объект.Ссылка);	 
	
	Элементы.ФормаГруппаПерейтиНаЭтап.Видимость				  = Не СудебнаяРабота И Не ИсполнительнаяРабота;  
	Элементы.ГруппаЭтап.Видимость							  = Не СудебнаяРабота И Не ИсполнительнаяРабота;
	Элементы.ГруппаДатаНомер.Видимость						  = Не СудебнаяРабота И Не ИсполнительнаяРабота;
	Элементы.ГруппаШапкаДела.Видимость						  = СудебнаяРабота Или ИсполнительнаяРабота;
	Элементы.ГруппаСуммыСуд.Видимость						  = СудебнаяРабота Или ИсполнительнаяРабота;
	Элементы.Схема.Видимость								  = Не СудебнаяРабота И Не ИсполнительнаяРабота;
	Элементы.ГруппаСуммаЗадолжности.Видимость				  = Не СудебнаяРабота И Не ИсполнительнаяРабота;
	Элементы.ГруппаПериод.Видимость							  = Не СудебнаяРабота И Не ИсполнительнаяРабота;
	Элементы.СтраниицаСудебныеИнстанции.Видимость			  = СудебнаяРабота Или ИсполнительнаяРабота;
	Элементы.СтраницаИсполнительныеДокументы.Видимость		  = ИсполнительнаяРабота;
	
	//Элементы.СтраницаКомментарии.Видимость					  = СудебнаяРабота;
	Элементы.ВидСудопроизводства.Видимость					  = СудебнаяРабота;
	//Пока убираем  
	//Элементы.СтраницаСтатусОтчеты.Видимость					  = СудебнаяРабота;
	//
	
	//Элементы.СтатусСудебногоДела.Видимость	  				  = СудебнаяРабота;
	Элементы.ФормаПодменюПечать.Видимость					  = СудебнаяРабота Или ИсполнительнаяРабота;
	//Элементы.СтраницаЮрист.Видимость						  = СудебнаяРабота Или ИсполнительнаяРабота;
	Элементы.ГруппаИсполнительноеПроизводство.Видимость		  = ИсполнительнаяРабота И 
									Объект.ВидИсполнения = ПредопределенноеЗначение("Перечисление.энргВидыИсполнительногоПроизводства.ФССП");
	Элементы.ВидИсполнения.Видимость		  				  = ИсполнительнаяРабота;
	Элементы.ФормаПечатьЗаявленияОВозбужденииИсполнительногоПроизводства.Видимость = ИсполнительнаяРабота;
	Элементы.ФормаПечатьЗаявлениеОВынесенииСудебногоПриказа.Видимость = СудебнаяРабота;
	Элементы.ФормаПечатьЗаявленияОВыдачеСудебногоПриказаОВзыскании.Видимость = СудебнаяРабота;
	Элементы.ГруппаИсполнительногоЛиста.Видимость			  = ИсполнительнаяРабота;
	Элементы.ГруппаПредыдущиеСудебныеИнстанции.Видимость	  = ИсполнительнаяРабота;
	Элементы.СудебныеИнстанции.Видимость	  				  = НЕ ИсполнительнаяРабота;
	Элементы.ДатаУчётаНачислений.Видимость					  = СудебнаяРабота ИЛИ ИсполнительнаяРабота;	
	Элементы.ДатаРасчетаПени.Видимость						  = СудебнаяРабота ИЛИ ИсполнительнаяРабота;
	
	Элементы.ГруппаОбязательныеПоля.ТолькоПросмотр			  = ВыпИлиПометУдал;
	Элементы.ГруппаАбонент.ТолькоПросмотр					  = ВыпИлиПометУдал;
	Элементы.ГруппаШапкаДела.ТолькоПросмотр					  = ВыпИлиПометУдал;
	Элементы.СобытияПоЭтапу.ТолькоПросмотр					  = ВыпИлиПометУдал;
	Элементы.СудебныеИнстанции.ТолькоПросмотр				  = ВыпИлиПометУдал;
	Элементы.КомментарииКДелу.ТолькоПросмотр				  = ВыпИлиПометУдал;
	Элементы.СтатусОтчеты.ТолькоПросмотр					  = ВыпИлиПометУдал;
	Элементы.СтраницаЮрист.ТолькоПросмотр					  = ВыпИлиПометУдал;
	Элементы.СтраницаБанкротство.ТолькоПросмотр				  = ВыпИлиПометУдал;
	Элементы.ГруппаСуммаЗадолжности.ТолькоПросмотр	 		  = ВыпИлиПометУдал;
	Элементы.ГруппаДатаНомер.ТолькоПросмотр					  = ВыпИлиПометУдал;
	Элементы.СудебныеИнстанцииТекущаяСудебнаяИнстанция.Доступность = Не ВыпИлиПометУдал;
	Элементы.Комментарий.ТолькоПросмотр						  = Не СудебнаяРабота Или ВыпИлиПометУдал;
	Элементы.ГруппаИсполнительногоЛиста.ТолькоПросмотр		  = ВыпИлиПометУдал;
	Элементы.ФормаПередатьСотрудникуУКЗ.Видимость			  = ИсполнительнаяРабота И Не ВыпИлиПометУдал;
	Элементы.ДатаУчётаНачислений.ТолькоПросмотр				  = НЕ СудебнаяРабота;
	Элементы.ДатаРасчетаПени.ТолькоПросмотр					  = НЕ СудебнаяРабота;
	Элементы.СобытияПоЭтапуСоздать.Доступность	 			  = Не ВыпИлиПометУдал;
	//Элементы.ФормаПрикреплениеКвитанций.Видимость			  = НЕ ВыпИлиПометУдал;
	
	Элементы.ФормаВернутьВРаботу.Видимость					  = Объект.Выполнена;
	
	Если СудебнаяРабота Или ИсполнительнаяРабота Тогда
	
		АвтоЗаголовок = Ложь;
		Заголовок = Объект.Наименование;
	
	КонецЕсли;
	
	Элементы.ФормаПередатьЗадачуДругомуПользователю.Видимость = Не ВыпИлиПометУдал;
	Элементы.ФормаПовторитьЭтап.Видимость		 			  = Не ВыпИлиПометУдал И Не СудебнаяРабота И Не ИсполнительнаяРабота;
	Элементы.ФормаПрекратитьПИД.Видимость		 			  = Не ВыпИлиПометУдал;
	Элементы.ФормаВернутьНаДоработку.Видимость	 			  = Не ВыпИлиПометУдал И ЗначениеЗаполнено(Объект.Основание);
	Элементы.РассчитатьЗадолженность.Доступность	 		  = Не ВыпИлиПометУдал;
	
	Элементы.ДатаСледЭтапа.Видимость			 			  = Не Объект.Выполнена И Не СудебнаяРабота;
	Элементы.ДатаСледующегоОтчёта.Видимость                   = ЗначениеЗаполнено(ДатаСледующегоОтчёта);
	Элементы.ДатаВыполнения.Видимость			 			  = Объект.Выполнена И Не СудебнаяРабота;
	Для каждого КомандаЭтап Из Элементы.ФормаГруппаПерейтиНаЭтап.ПодчиненныеЭлементы Цикл
		КомандаЭтап.Видимость = Не Объект.Выполнена;
	КонецЦикла;
	
	Элементы.ФормаВозобновитьПИД.Видимость		 = Не Объект.ПометкаУдаления И Объект.ПрекращенаДеятельность;
	Элементы.ФормаВыполнитьИЗакрыть.Видимость	 = Не ВыпИлиПометУдал;
	Элементы.ФормаЗаписать.Видимость			 = Не ВыпИлиПометУдал;
	Элементы.ФормаВыполнить.Видимость			 = Не ВыпИлиПометУдал;
	Элементы.ФормаВзятьВРаботу.Видимость		 = Не Объект.Выполнена И Не Объект.ПометкаУдаления И (Не Объект.ПринятоВРаботу Или Объект.Исполнитель <> ПолучитьТекущегоПользователя());
	Элементы.ФормаНачатьБанкротство.Видимость	 = Не ВыпИлиПометУдал;
	Элементы.ФормаОтключитьУслугу.Видимость		 = Не ВыпИлиПометУдал;
	
	ЗадачаПоПереговорам							 = Объект.Этап = ПредопределенноеЗначение("Справочник.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Переговоры");
	Элементы.ПланПогашенияЗадолженности.Видимость= ЗадачаПоПереговорам;
	
	ОтобразатьКнопкуПечати();
	ОбновитьДатуОтправки("ДатаОповещенияПоЭП", ПредопределенноеЗначение("Справочник.энргСпособСвязи.ОтправкаПисьмаНаЭлектроннуюПочту"));
	ОбновитьДатуОтправки("ДатаОтправкиSMS", ПредопределенноеЗначение("Справочник.энргСпособСвязи.ОтправкаСМС"));
	
	//ИНТЕГРАЦИЯ
	Элементы.ИнтеграцияФССП.Видимость = Не ВыпИлиПометУдал И ИсполнительнаяРабота;
	
	// Передача пакетов документов
	ЭтоПередачаПакетовДокументов 								= Объект.Этап = ПредопределенноеЗначение("Справочник.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_ПередачаПакетаДокументовЮристам");
	Элементы.СтатусСудебногоДелаДляПередачиДокументов.Видимость	= ЭтоПередачаПакетовДокументов;
	Если ЭтоПередачаПакетовДокументов Тогда
		ЗаполнитьСтатусСудДела();		
	КонецЕсли;
	           	
	Элементы.ГРСтатусыСудебныхДел.Видимость				 = СудебнаяРабота;
	// Судебное дело

	// Настройка видимости списка задолженности
	Элементы.СтраницаНепогашенныеНачисления.Видимость		  		= Не СудебнаяРабота И Не ИсполнительнаяРабота;
	Элементы.ГруппаПодэтапы.Видимость 								= ЗначениеЗаполнено(Объект.Подэтапы);
	Элементы.ФормаПодтвердитьПеренаправление.Видимость	 			= Объект.ТребуетПодтверждения И Не ВыпИлиПометУдал;
	Элементы.НепогашенныеНачисления.ИзменятьСоставСтрок  			= Не ВыпИлиПометУдал;
	Элементы.НепогашенныеНачисленияОбновитьЗадолженность.Видимость  = Не ВыпИлиПометУдал;
	
	Элементы.СтраницаЗадолженность.Видимость                        = СудебнаяРабота;
	Элементы.СтраницаРасчетПени.Видимость                        	= СудебнаяРабота;
	Элементы.ЗадолженностьЗадолженность.ТолькоПросмотр  			= ВыпИлиПометУдал;
	Элементы.ИсполнительныеДокументы.ТолькоПросмотр					= ВыпИлиПометУдал;

	// Доступность полей Суммы
	Элементы.ОбновитьСуммыИска.Видимость							= СудебнаяРабота;
	УстановитьДоступностьСуммИспол();

КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьСуммИспол()
	
	Перем ТолькоПросмотрСумм;
	
	ТолькоПросмотрСумм	= Не ЭтоИсполнительнаяРабота Или ЗначениеЗаполнено(Объект.ИсполнительныеДокументы) Или Объект.Выполнена Или Не Объект.ПринятоВРаботу;
	
	Элементы.СуммаОсновногоДолга.ТолькоПросмотр	= ТолькоПросмотрСумм;
	Элементы.Пеня.ТолькоПросмотр				= ТолькоПросмотрСумм;
	Элементы.Прочие.ТолькоПросмотр				= ТолькоПросмотрСумм И (Не ЭтоСудебнаяРабота Или Объект.Выполнена Или Не Объект.ПринятоВРаботу);
	Элементы.СуммаИска.ТолькоПросмотр			= ТолькоПросмотрСумм;
	Элементы.СуммаГоспошлина.ТолькоПросмотр		= ТолькоПросмотрСумм;

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораЭтапа(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	ВыбранныйЭтап = ВыбранныйЭлемент;
	
	Если ВыбранныйЭтап <> Неопределено Тогда
		СледЭтап = ЭтапКоманды(ВыбранныйЭтап.Значение);
		Если НачалоСудебнойРаботы(Объект.Этап, СледЭтап) Тогда
			//Отказ = Истина;
			ОткрытьФормуПереходаНаСудебнуюРаботу(СледЭтап);
		Иначе
			ПерейтиНаЭтапНаСервере(ВыбранныйЭтап.Значение);
			Если ЭтаФорма.Открыта() Тогда
				Закрыть();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОтветаНаСохранение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Записать();
		Команда = ДополнительныеПараметры.Команда;
		ОсновноеДействиеКоманды(Команда);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуПечати()
	Перем ПараметрыФормы;
	
	ПараметрыФормы = Новый Структура("Задача, ИмяМакета, Этап", Объект.Ссылка, ИмяМакета, Объект.Этап);
	ОткрытьФорму("Задача.энргЗадачаПИД.Форма.ФормаПечати", ПараметрыФормы, ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура СохрнаитьИзмененияПередВыполнениемКоманды(Команда)
	
	Перем ОписаниеОповещения;
	
	Если Модифицированность Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаОтветаНаСохранение", ЭтотОбъект, Новый Структура("Команда", Команда));
		ПоказатьВопрос(ОписаниеОповещения, "Сохранить изменения?", РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	
	ОсновноеДействиеКоманды(Команда);
КонецПроцедуры

#Если НЕ МобильныйКлиент Тогда

&НаКлиенте
Процедура ОсновноеДействиеКоманды(Знач Команда)
	Префикс = "КомандаЭтап_";
	
	Если Команда = Команды.Найти("Печать") Тогда 
		ОткрытьФормуПечати();
		
	// события письмо, внеш воздействие 	
