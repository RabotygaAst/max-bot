		ПередВыполнением(Отказ);
		Если Не Отказ Тогда
			Записать(Новый Структура("ВыполнитьЗадачу", Истина));
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти


Процедура ОсуществитьЗапросКСервису(ТекстЗапроса,МетодВызова,УровеньЖурнала)
	Модифицированность 	= Истина;
	Токен 				= "jtvB6OIPlyhn";
	ИтоговоыйТекст 		= МетодВызова + "?token=" + Токен + ТекстЗапроса;
	Сообщение			= "Запрос выполнен успешно";	
	
	Попытка 	
		
		ssl 		= Новый ЗащищенноеСоединениеOpenSSL( неопределено, неопределено );	
		Соединение 	= Новый HTTPСоединение("api-ip.fssprus.ru/api/v1.0",,,,,,ssl);	
		
		HTTPЗапрос 					= Новый HTTPЗапрос(ИтоговоыйТекст);		
		Результат 					= Соединение.Получить(HTTPЗапрос);		
		
		ЧтениеJSON 					= Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку());			
		ДанныеИзЗапроса 			= ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		// Получение корректного текста из результата 
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ДанныеИзЗАпроса);
		Тело		= ЗаписьJSON.Закрыть();
		
		ДопОписание = "";
		Если Результат.КодСостояния = 200 Тогда
			ОпределитьРезультат(МетодВызова,ДанныеИзЗапроса,ДопОписание,Тело);
		Иначе 
			ВызватьИсключение "Код ответа: " + Результат.КодСостояния + "; " + Тело;
		КонецЕсли;
		
		ИнформацияДляВывода = "Полный ответ: " + Тело + Символы.ПС + "Дополнительно - " + ДопОписание;
		УровеньЖурнала 		= УровеньЖурналаРегистрации.Информация;
	Исключение
		ИнформацияДляВывода = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Сообщение			= "Во время запроса произошла ошибка. " + ИнформацияДляВывода;
		УровеньЖурнала 		= УровеньЖурналаРегистрации.Ошибка;
	КонецПопытки;
	
	ИнформацияДляВывода = "Задача:" + Объект.Номер + ";" + Объект.Дата + ". Метод: " + МетодВызова + Символы.ПС + ИнформацияДляВывода;
	
	ЗаписьЖурналаРегистрации("Интеграция с ФССП",УровеньЖурнала,,,ИнформацияДляВывода);
	ОбщегоНазначения.СообщитьПользователю(Сообщение); 	
	
КонецПроцедуры

Процедура ОпределитьРезультат(МетодВызова,ДанныеИзЗапроса,ДопОписание,Тело)
	
	Если МетодВызова = "/search/physical" Тогда
		Объект.Task = ДанныеИзЗапроса.response.task;
		ДопОписание = "Task: " + Объект.Task;
	ИначеЕсли МетодВызова = "/result" Тогда
		
		ЗарегистрироватьСобытие(Тело);		
		Элементы.СобытияПоЭтапу.Обновить();
	КонецЕсли;	
	
КонецПроцедуры


#Область ВПОМОГАТЕЛЬНЫЕ_МЕТОДЫ	
Процедура ЗарегистрироватьСобытие(Тело)
	ДокСобытие = Неопределено;
	ТипСобытия = Справочники.энргСпособСвязи.НайтиПоКоду("000000005");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСобытиеАбоненты.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.энргСобытие.Абоненты КАК энргСобытиеАбоненты
		|ГДЕ
		|	энргСобытиеАбоненты.Абонент = &Абонент
		|	И энргСобытиеАбоненты.Основание = &Основание
		|	И энргСобытиеАбоненты.Ссылка.ТипСобытия = &ТипСобытия";
	
	Запрос.УстановитьПараметр("Абонент"		, Объект.Абонент);
	Запрос.УстановитьПараметр("Основание"	, Объект.Ссылка);
	Запрос.УстановитьПараметр("ТипСобытия"	, ТипСобытия);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ДокСобытие = Документы.энргСобытие.СоздатьДокумент();
		ДокСобытие.Дата	 					= ТекущаяДата(); 		
		ДокСобытие.ТипСобытия	 			= ТипСобытия; 		
		ДокСобытие.ПланируемаяДатаОтправки 	= ДокСобытие.Дата;
		ДокСобытие.ТемаСобытия 				= "Интеграция с ФССП";
		ДокСобытие.Организация 				= Объект.Организация;
	иначе
		Выборка 					= РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ДокСобытие 					= Выборка.Ссылка.ПолучитьОбъект();
		ДокСобытие.ПометкаУдаления 	= Ложь;
	КонецЕсли;
	
	ДокСобытие.ТекстШаблона = Тело;
	
	ТЧАбонентов = ДокСобытие.Абоненты;
	
	// Предварительный обход необходим, чтобы предыдущие записи не очистились из регистра. 
	Для Каждого ТекСтрока из ТЧАбонентов Цикл
		ТекСтрока.Успех 	= Истина;
	КонецЦикла;
	
	// Добавляем новый результат метода /result
	НоваяСтрока = ТЧАбонентов.Добавить();
	НоваяСтрока.Абонент 	= Объект.Абонент;
	НоваяСтрока.Основание 	= Объект.Ссылка;		
	НоваяСтрока.Результат 	= Тело;
	НоваяСтрока.Статус 		= "Выполнено";  	
	ДокСобытие.Записать();

КонецПроцедуры

