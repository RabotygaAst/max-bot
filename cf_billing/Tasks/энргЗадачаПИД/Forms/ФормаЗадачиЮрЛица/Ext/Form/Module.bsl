&НаСервере
Функция ОтправитьНаПочтуНаСервере(ИмяМакета)
	ТипСобытия = ПредопределенноеЗначение("Справочник.энргСпособСвязи.ОтправкаПисьмаНаЭлектроннуюПочту");
	
	Возврат Документы.энргСобытие.СоздатьИВыполнитьСобытиеНаОсновеЗадачи(Объект.Ссылка, ТипСобытия,,, ИмяМакета);
КонецФункции

&НаСервере
Процедура ОбновитьДатуОтправки(ИмяЭлемента, ТипСобытия)

	Элементы[ИмяЭлемента].Видимость = Ложь;
	ЭтаФорма[ИмяЭлемента] = "";
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСобытияСрезПоследних.Период КАК Период,
		|	энргСобытияСрезПоследних.Успех КАК Успех,
		|	энргСобытияСрезПоследних.Результат КАК Результат
		|ИЗ
		|	РегистрСведений.энргСобытия.СрезПоследних(
		|			,
		|			ТипСобытия = &ТипСобытия
		|				И Основание = &Ссылка) КАК энргСобытияСрезПоследних";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("ТипСобытия", ТипСобытия);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Элементы[ИмяЭлемента].Видимость = Истина;
		ЭтаФорма[ИмяЭлемента] = Формат(Выборка.Период, "ДФ=dd.MM.yyyy") + ?(Выборка.Успех, " (доставлено)", " (не доставлено)");
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСписокЭтапов(Схема)

	Результат = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСхемыПИДЭтапы.Этап КАК Этап,
		|	энргСхемыПИДЭтапы.НомерСтроки КАК НомерСтроки,
		|	энргСхемыПИДЭтапы.Необязательный КАК Необязательный,
		|	ЕСТЬNULL(энргСхемыПИДЭтапы1.Этап, НЕОПРЕДЕЛЕНО) КАК ПредЭтап
		|ИЗ
		|	Справочник.энргСхемыПИД.Этапы КАК энргСхемыПИДЭтапы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСхемыПИД.Этапы КАК энргСхемыПИДЭтапы1
		|		ПО энргСхемыПИДЭтапы.Ссылка = энргСхемыПИДЭтапы1.Ссылка
		|			И (энргСхемыПИДЭтапы.НомерСтроки - 1 = энргСхемыПИДЭтапы1.НомерСтроки)
		|ГДЕ
		|	энргСхемыПИДЭтапы.Ссылка = &Схема
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
	
	Запрос.УстановитьПараметр("Схема", Схема);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.ПредЭтап, Строка(Выборка.Этап));
		Если Не Выборка.Необязательный Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;
КонецФункции

