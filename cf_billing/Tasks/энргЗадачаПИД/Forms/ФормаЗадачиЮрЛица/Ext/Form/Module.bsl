&НаСервере
Процедура ОбновитьЗадолженностьНаСервере()
	Если ЭтоСудебнаяРабота Или ЭтоИсполнительнаяРабота Тогда
		Возврат;
	КонецЕсли;
	
	СписокДолгов = Новый Массив;
	
	Для каждого СтрокаТЧ Из Объект.Задолженность Цикл
		СписокДолгов.Добавить(Новый Структура("ПериодНачисления, Услуга, СуммаДо", СтрокаТЧ.ПериодНачисления, СтрокаТЧ.Услуга, СтрокаТЧ.Задолженность));
	КонецЦикла;
	
	ПарамЗапроса = Новый Структура("Организация, Район, Договор");
	ЗаполнитьЗначенияСвойств(ПарамЗапроса, Объект);
	
	РезультатДерево = Задачи.энргЗадачаПИД.ПолучитьЗадолженность(СписокДолгов, ПарамЗапроса);
	Если РезультатДерево = Неопределено Тогда
		Возврат;
	КонецЕсли;
	РезультатДерево = РезультатДерево.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	ЗначениеВРеквизитФормы(РезультатДерево, "ДеревоЗадолженности");
	
	Ветви = ДеревоЗадолженности.ПолучитьЭлементы();
	НовСуммаЗадолженности = ?(ЗначениеЗаполнено(Ветви), Ветви[0].Задолженность, 0);
	Если НовСуммаЗадолженности <> Объект.СуммаЗадолженности И Не ЭтоИсполнительнаяРабота И Не ЭтоСудебнаяРабота Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сумма задолженности изменена.");
		Объект.СуммаЗадолженности = НовСуммаЗадолженности;
		Модифицированность = Истина;
	КонецЕсли;
КонецПроцедуры


&НаСервере
Процедура ЗаполнитьСтатусСудДела()
	ЗадачаСудебногоДела = задачи.энргЗадачаПИД.ПолучитьЗадачуПоОснованию(Объект.Ссылка);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСтатусыСудебныхДелСрезПоследних.Статус КАК Статус
		|ИЗ
		|	РегистрСведений.энргСтатусыСудебныхДел.СрезПоследних(&ТекДата, СудебноеДело = &СудебноеДело) КАК энргСтатусыСудебныхДелСрезПоследних";
	
	Запрос.УстановитьПараметр("СудебноеДело", ЗадачаСудебногоДела);
	Запрос.УстановитьПараметр("ТекДата"		, ТекущаяДата());
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		СтатусСудебногоДелаДляПередачиДокументов = Справочники.энргСтатусыДелСудебнойРаботы.ПустаяСсылка();
	КонецЕсли; 	
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	СтатусСудебногоДелаДляПередачиДокументов = Выборка.Статус;
	
КонецПроцедуры

