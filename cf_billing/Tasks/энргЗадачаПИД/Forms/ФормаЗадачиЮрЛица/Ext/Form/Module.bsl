&НаСервере
Функция ПечатьВыпискиСЛицевогоСчетаНаСервере()

	НачПериод = Объект.Дата;
	КонПериод = Дата(1,1,1);
	Для каждого СтрокаТЧ Из Объект.Задолженность Цикл
		НачПериод = Мин(СтрокаТЧ.ПериодНачисления, НачПериод);
		КонПериод = Макс(КонецМесяца(СтрокаТЧ.ПериодНачисления), КонПериод);
	КонецЦикла;
	
	Возврат Задачи.энргЗадачаПИД.ПечатьВыпискиСЛицевогоСчета(Объект, НачПериод, КонПериод);
КонецФункции

&НаСервере
Процедура УстановитьПараметрыИВидимостьБанкротства()

	СудебныеЗаседания.Параметры.УстановитьЗначениеПараметра("ПериодЗадолженностиНачало", Объект.ПериодЗадолженностиНачало);
	СудебныеЗаседания.Параметры.УстановитьЗначениеПараметра("ПериодЗадолженностиКонец",	 Объект.ПериодЗадолженностиКонец);
	СудебныеЗаседания.Параметры.УстановитьЗначениеПараметра("Абонент",					 Объект.Абонент);
	СудебныеЗаседания.Параметры.УстановитьЗначениеПараметра("Организация",				 Объект.Организация);
	СудебныеЗаседания.Параметры.УстановитьЗначениеПараметра("Район",					 Объект.Район);
	Элементы.СудебныеЗаседания.Обновить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = СудебныеЗаседания.ТекстЗапроса;
	Запрос.УстановитьПараметр("ПериодЗадолженностиНачало",	Объект.ПериодЗадолженностиНачало);
	Запрос.УстановитьПараметр("ПериодЗадолженностиКонец",	Объект.ПериодЗадолженностиКонец);
	Запрос.УстановитьПараметр("Абонент",					Объект.Абонент);
	Запрос.УстановитьПараметр("Организация",				Объект.Организация);
	Запрос.УстановитьПараметр("Район",					 	Объект.Район);
	
	Банкротство = Не Запрос.Выполнить().Пустой();
	Элементы.СтраницаБанкротство.Видимость = Банкротство;
КонецПроцедуры

