&НаКлиенте
Перем ЗадачаПоПереговорам;

#Если Сервер Или ТолстыйКлиентОбычноеПредложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	//// Востанавление последовательности для получения актуальной задолженности
	//Если ЗначениеЗаполнено(Объект.Абонент) И Не Объект.Выполнена И Не Объект.ПометкаУдаления Тогда
	//	Попытка
	//	    ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(ТекущаяДата(), Объект.Организация);
	//		энргРаботаСПоследовательностями.ВосстановитьПоследовательностьВзаиморасчеты(Объект.Организация, ПериодНачисления, Объект.Район, Объект.МКД, Объект.Абонент);
	//	Исключение
	//		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить актуальную задолженность по причине: " + ОписаниеОшибки());
	//	КонецПопытки;
	//КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Поставщик = энргОбщегоНазначенияСерверПовтИспол.ПолучитьЗначениеКонстанты("энргПоставщикПоУмолчанию");
		Объект.ПериодНачисления = Обработки.энргГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса()), Объект.Организация,Объект.Район);
		
		СтатусыСудебныхДел.Параметры.УстановитьЗначениеПараметра("СудебноеДело", Неопределено);
	иначе
		СтатусыСудебныхДел.Параметры.УстановитьЗначениеПараметра("СудебноеДело", Объект.Ссылка);		
	КонецЕсли;
	НовОбъект = Неопределено;
	Если Параметры.Свойство("ПараметрыОбъекта", НовОбъект) Тогда
		ЗаполнитьЗначенияСвойств(Объект, НовОбъект);
		Задачи.энргЗадачаПИД.ЗаполнитьНаименованиеИЭтап(Объект, Справочники.энргВидыОперацийПИД.ПустаяСсылка());
	КонецЕсли;
	
	УстановитьПараметрыВнешВоздействие();
	// Создание команд планировния отправки ЭП
	СпрЭтаповПИД  = Справочники.энргВидыОперацийПИД;
	СписокМакетов = СпрЭтаповПИД.ПолучитьСписокМакетовПечати();
	
	Для каждого ТекМакет Из СписокМакетов Цикл
		Префикс	 = "ПФ_MXL_";
		ИмяЭтапа = СтрЗаменить(ТекМакет.Значение, Префикс, "ЭтапПретензионноИсковойДеятельности_");
		ИмяКмд	 = СтрЗаменить(ТекМакет.Значение, Префикс, "КомандаЭтап_");
		Этап	 = СпрЭтаповПИД[ИмяЭтапа];
		
		// Добавление команды
		Кмд			  = ЭтаФорма.Команды.Добавить(ИмяКмд);
		Кмд.Действие  = "ОтправитьНаПочту";
		Кмд.Заголовок = Строка(Этап);
		
		// Добавление новой кнопки
		ЭлементКМД			   = Элементы.Добавить(ИмяКмд, Тип("КнопкаФормы"), Элементы.ГрппаКнопкиОтправкиЭП);
		ЭлементКМД.Вид		   = ВидКнопкиФормы.ОбычнаяКнопка;
		ЭлементКМД.ИмяКоманды  = ИмяКмд;
		ЭлементКМД.Картинка	   = БиблиотекаКартинок.ОтправитьЭлектронноеПисьмо;
		ЭлементКМД.Отображение = ОтображениеКнопки.КартинкаИТекст;
		ЭлементКМД.Видимость   = Ложь;
	КонецЦикла;

	// Установка площадей
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(энргСтатусыСудебныхДелСрезПоследних.Статус) КАК СтатусСудебногоДела
		|ПОМЕСТИТЬ ВТ_Данные
		|ИЗ
		|	РегистрСведений.энргСтатусыСудебныхДел.СрезПоследних(, СудебноеДело = &Ссылка) КАК энргСтатусыСудебныхДелСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВТ_Данные.СтатусСудебногоДела) КАК СтатусСудебногоДела
		|ИЗ
		|	ВТ_Данные КАК ВТ_Данные";
	
	Запрос.УстановитьПараметр("Ссылка",		 Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ЭтаФорма, Выборка);
	КонецЦикла;
	
	УстановитьПараметрыКомментарии();
	УстановитьПарметрыПредыдущиеСудебныеИнстанции();
	УстановитьПараметрыВнешВоздействие();
	// Запуск расчёта пени
	ЭтоСудебнаяРабота		= Перечисления.энргТипыЭтапов.СудебнаяРабота = Объект.Этап.Тип;
	ЭтоИсполнительнаяРабота = Перечисления.энргТипыЭтапов.ИсполнительнаяРабота = Объект.Этап.Тип;
	ЗаполнитьСуммуИска();

	
	УстановитьПараметрыИВидимостьБанкротства();
	ОбновитьЗадолженностьНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСуммуИска()
	
	Если ЭтоСудебнаяРабота Или ЭтоИсполнительнаяРабота Тогда
		Если ЭтоИсполнительнаяРабота И ЗначениеЗаполнено(Объект.ИсполнительныеДокументы) Тогда
		    Объект.СуммаЗадолженности 	= 0;
			Объект.СуммаПени			= 0;
			Объект.СуммаГоспошлина		= 0;
			Объект.Прочие				= 0;
			
			Для каждого СтрокаТЧ Из Объект.ИсполнительныеДокументы Цикл
				Объект.СуммаЗадолженности 	= Объект.СуммаЗадолженности + СтрокаТЧ.Долг;
				Объект.СуммаПени 			= Объект.СуммаПени + СтрокаТЧ.Пеня;
				Объект.СуммаГоспошлина 		= Объект.СуммаГоспошлина + СтрокаТЧ.Госпошлина;
				Объект.Прочие 				= Объект.Прочие + СтрокаТЧ.Прочие;
			КонецЦикла;
		КонецЕсли;
		
		СуммаИска   = Объект.СуммаЗадолженности + Объект.СуммаПени + Объект.Прочие;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	ТекущийОбъект.ДополнительныеСвойства.Вставить("СтатусСудебногоДела", СтатусСудебногоДела);
КонецПроцедуры

