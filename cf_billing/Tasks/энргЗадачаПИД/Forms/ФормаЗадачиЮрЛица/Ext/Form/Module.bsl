КонецФункции

&НаСервере
Функция ПовторитьЭтапНаСервере()
	Отказ = Ложь;
	
	Попытка
		Задачи.энргЗадачаПИД.СоздатьПодчиненнуюЗадачу(Отказ, Объект.Этап, Объект);
		Если Не Отказ Тогда
			ОбъектЗадача = РеквизитФормыВЗначение("Объект");
			ОбъектЗадача.ВыполнитьЗадачуИнтерактивно();
			ЗначениеВРеквизитФормы(ОбъектЗадача, "Объект");
		КонецЕсли;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Не Отказ;
КонецФункции

&НаСервере
Функция ПрекратитьПИДНаСервере(ПрекращенаДеятельность=Истина)
	Попытка
		ОбъектЗадача = РеквизитФормыВЗначение("Объект");
		ОбъектЗадача.ПрекращенаДеятельность = ПрекращенаДеятельность;
		Если ПрекращенаДеятельность Тогда
			ОбъектЗадача.ВыполнитьЗадачуИнтерактивно();
		Иначе
			ОбъектЗадача.Выполнена = Ложь;
			ОбъектЗадача.Записать();
		КонецЕсли;
		
		ЗначениеВРеквизитФормы(ОбъектЗадача, "Объект");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
	Модифицированность = Ложь;
	Возврат Истина;
КонецФункции

&НаСервере
Функция ПерейтиНаЭтапНаСервере(ИмяКоманды)
	Попытка
		Команда = Команды.Найти(ИмяКоманды);
		НачатьТранзакцию();
		ОбъектЗадача = РеквизитФормыВЗначение("Объект");
		Если Модифицированность Тогда
			ОбъектЗадача.Записать();
		КонецЕсли;
		
		СледЭтап = Справочники.энргВидыОперацийПИД.НайтиПоНаименованию(Команда.Заголовок, Истина);
		Если Не ЗначениеЗаполнено(СледЭтап) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден этап """ + Команда.Заголовок + """.");
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецЕсли;
		
		Отказ = Ложь;
		Задачи.энргЗадачаПИД.СоздатьПодчиненнуюЗадачу(Отказ, СледЭтап, ОбъектЗадача);
		Если Отказ Тогда
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецЕсли;
		ОбъектЗадача.ВыполнитьЗадачуИнтерактивно();
		
		ЗафиксироватьТранзакцию();
		ЗначениеВРеквизитФормы(ОбъектЗадача, "Объект");
		Модифицированность = Ложь;
		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		ОтменитьТранзакцию();
		Возврат Ложь;
	КонецПопытки;

	Возврат Истина;
КонецФункции

&НаСервере
Процедура СоздатьКоманды()
	// Удаление старых команд
	КомандыЭтапов = Новый Массив;
	ЗадачаПоПереговорам	= Объект.Этап = ПредопределенноеЗначение("Справочник.энргВидыОперацийПИД.ЭтапПретензионноИсковойДеятельности_Переговоры");
	Для каждого КомандаЭтапа Из Элементы.ФормаГруппаПерейтиНаЭтап.ПодчиненныеЭлементы Цикл
		КомандыЭтапов.Добавить(КомандаЭтапа); 
	КонецЦикла;
	
	Для каждого КомандаЭтапа Из КомандыЭтапов Цикл
		ЭтаФорма.Команды.Удалить(ЭтаФорма.Команды.Найти(КомандаЭтапа.ИмяКоманды));
		Элементы.Удалить(КомандаЭтапа);
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(Объект.Этап) Или Не ЗначениеЗаполнено(Объект.Схема)  Или Не ЗначениеЗаполнено(Объект.Организация) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСхемыПИДЭтапы.Ссылка КАК Ссылка,
		|	энргСхемыПИДЭтапы.Этап КАК Этап,
		|	энргСхемыПИДЭтапы.НомерСтроки КАК НомерСтроки,
		|	энргСхемыПИДЭтапы.Необязательный КАК Необязательный
		|ПОМЕСТИТЬ ВТ_НомерЭтапа
		|ИЗ
		|	Справочник.энргСхемыПИД.Этапы КАК энргСхемыПИДЭтапы
		|ГДЕ
		|	энргСхемыПИДЭтапы.Ссылка = &Схема
		|	И энргСхемыПИДЭтапы.Этап = &Этап
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	энргСхемыПИДЭтапы.Этап КАК Этап,
		|	энргСхемыПИДЭтапы.НомерСтроки КАК НомерСтроки,
		|	энргСхемыПИДЭтапы.Этап.Наименование КАК Наименование,
		|	энргСхемыПИДЭтапы.Необязательный КАК Необязательный
		|ИЗ
		|	ВТ_НомерЭтапа КАК ВТ_НомерЭтапа
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргСхемыПИД.Этапы КАК энргСхемыПИДЭтапы
		|		ПО ВТ_НомерЭтапа.Ссылка = энргСхемыПИДЭтапы.Ссылка
		|			И ВТ_НомерЭтапа.НомерСтроки < энргСхемыПИДЭтапы.НомерСтроки
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|ИТОГИ ПО
		|	Этап";
	
	Если ЗадачаПоПереговорам Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТ_НомерЭтапа.НомерСтроки <", "ВТ_НомерЭтапа.НомерСтроки <=");
	КонецЕсли;	
	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("Схема", Объект.Схема);
	Запрос.УстановитьПараметр("Этап", Объект.Этап);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаЭтап = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ЭтоПервый	 = Истина;
	ЭтоПоследний = Ложь;
	Сч = 1;
	Пока ВыборкаЭтап.Следующий() Цикл
		Выборка = ВыборкаЭтап.Выбрать();
	
		Если Выборка.Следующий() Тогда
			Если Не Выборка.Необязательный Тогда
				Если ЭтоПервый И ЗадачаПоПереговорам Тогда
				ИначеЕсли ЭтоПервый И Не ЗадачаПоПереговорам Тогда
					Прервать;
				Иначе
				    ЭтоПоследний = Истина;
				КонецЕсли;
			КонецЕсли;
			
			// Добавление команды
			ИмяКмд = "КомандаЭтап" + Формат(Сч, "ЧГ=0");
			
			Кмд = ЭтаФорма.Команды.Добавить(ИмяКмд);
			Кмд.Действие = "ПерейтиНаЭтап";
			Кмд.Заголовок = Выборка.Наименование;
			
			// Добавление новой кнопки
			ЭлементКМД = Элементы.Добавить(ИмяКмд, Тип("КнопкаФормы"), Элементы.ФормаГруппаПерейтиНаЭтап);
			ЭлементКМД.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
			ЭлементКМД.ИмяКоманды = ИмяКмд;
			
			Сч = Сч + 1;
			ЭтоПервый = Ложь;
			Если ЭтоПоследний Тогда
				Прервать;			
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Для каждого КомандаЭтап Из Элементы.ФормаГруппаПерейтиНаЭтап.ПодчиненныеЭлементы Цикл
		КомандаЭтап.Доступность = Не Объект.Выполнена;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПолучитьИменаКомандЭтапов()

	СписокЗначений = Новый СписокЗначений;
	
	Для каждого КомандаЭтап Из Элементы.ФормаГруппаПерейтиНаЭтап.ПодчиненныеЭлементы Цикл
		Если КомандаЭтап.Доступность Тогда
			СписокЗначений.Добавить(КомандаЭтап.ИмяКоманды, Команды.Найти(КомандаЭтап.ИмяКоманды).Заголовок);
		КонецЕсли;
	КонецЦикла;
	
	Возврат СписокЗначений;
КонецФункции

