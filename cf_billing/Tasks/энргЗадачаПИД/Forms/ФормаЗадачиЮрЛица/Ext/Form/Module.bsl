&НаСервере
Функция ПолучитьСписокСУ(СудУчасток)
	
	СписокУслуг = Новый СписокЗначений;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	отэкСуды.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.энргСуды.СтроенияИСудебныеУчастки КАК отэкСудыСтроенияИСудебныеУчастки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргСуды КАК отэкСуды
	|		ПО отэкСудыСтроенияИСудебныеУчастки.Ссылка = отэкСуды.Ссылка
	|ГДЕ
	|	отэкСудыСтроенияИСудебныеУчастки.СудебныйУчасток = &СудебныйУчасток";
	
	Запрос.УстановитьПараметр("СудебныйУчасток", СудУчасток);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СписокУслуг.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	
	Возврат СписокУслуг;
	
КонецФункции


