			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	бестВзаиморасчетыПоМесяцамЭЭОстатки.Организация КАК Организация,
	бестВзаиморасчетыПоМесяцамЭЭОстатки.Район КАК Район,
	бестВзаиморасчетыПоМесяцамЭЭОстатки.Договор КАК Договор,
	бестВзаиморасчетыПоМесяцамЭЭОстатки.СуммаОстаток КАК Сумма,
	бестПлатежныйДокумент.Дата КАК ДатаВозникновенияЗадолженности,
	бестВзаиморасчетыПоМесяцамЭЭОстатки.ПериодНачисления КАК ПериодНачисления,
	бестВзаиморасчетыПоМесяцамЭЭОстатки.ПлатежныйДокумент КАК ПлатежныйДокумент
ПОМЕСТИТЬ Задолженность
ИЗ
	РегистрНакопления.бестВзаиморасчетыПоМесяцамЭЭ.Остатки(
			&amp;Период,
			Организация = &amp;Организация
				И Район = &amp;Район) КАК бестВзаиморасчетыПоМесяцамЭЭОстатки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестПлатежныйДокумент КАК бестПлатежныйДокумент
		ПО бестВзаиморасчетыПоМесяцамЭЭОстатки.ПлатежныйДокумент = бестПлатежныйДокумент.Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Организация КАК Организация,
	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Район КАК Район,
	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.Договор КАК Договор,
	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.ДеньФормирования КАК ДеньФормирования,
	бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних.СрокОплаты КАК СрокОплаты
ПОМЕСТИТЬ ДеньОплаты
ИЗ
	РегистрСведений.бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорам.СрезПоследних(
			&amp;Период,
			ТипОплаты = ЗНАЧЕНИЕ(Перечисление.бестВидыРасчета.Фактический)
				И (Организация, Район, Договор) В
					(ВЫБРАТЬ
						Задолженность.Организация КАК Организация,
						Задолженность.Район КАК Район,
						Задолженность.Договор КАК Договор
					ИЗ
						Задолженность КАК Задолженность)) КАК бестНастройкиСроковИПроцентовОплатыПотребленияПоДоговорамСрезПоследних
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Задолженность.Договор КАК Договор,
	СУММА(Задолженность.Сумма) КАК Сумма,
	Задолженность.ПериодНачисления КАК ПериодНачисления,
	ДеньОплаты.СрокОплаты КАК СрокОплаты,
	энргДоговорыКонтрагентов.Контрагент КАК Контрагент,
	Задолженность.ПлатежныйДокумент КАК ПлатежныйДокумент
ИЗ
	Задолженность КАК Задолженность
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДеньОплаты КАК ДеньОплаты
		ПО Задолженность.Организация = ДеньОплаты.Организация
			И Задолженность.Район = ДеньОплаты.Район
			И Задолженность.Договор = ДеньОплаты.Договор
			И (РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(Задолженность.ДатаВозникновенияЗадолженности, МЕСЯЦ), МЕСЯЦ, 1), ДЕНЬ, ДеньОплаты.ДеньФормирования - 1), &amp;Период, ДЕНЬ) &lt; 0)
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргДоговорыКонтрагентов КАК энргДоговорыКонтрагентов
		ПО Задолженность.Договор = энргДоговорыКонтрагентов.Ссылка

СГРУППИРОВАТЬ ПО
	Задолженность.Договор,
	Задолженность.ПериодНачисления,
	ДеньОплаты.СрокОплаты,
	энргДоговорыКонтрагентов.Контрагент,
	Задолженность.ПлатежныйДокумент</QueryText>
