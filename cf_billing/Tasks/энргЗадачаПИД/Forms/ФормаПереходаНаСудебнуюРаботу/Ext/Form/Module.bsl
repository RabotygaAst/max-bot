#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Параметры.Свойство("Задача", 						Задача);
	Параметры.Свойство("СледующийЭтап", 				СледующийЭтап);
	Параметры.Свойство("Абонент", 						Абонент);
	Параметры.Свойство("Организация", 					Организация);
	Параметры.Свойство("Договор", 						Договор);
	Параметры.Свойство("Район", 						Район);
	Если Параметры.Свойство("ПериодЗадолженностиКонец", ПериодЗадолженностиКонец) Тогда 
		ПериодЗадолженностиКонец = КонецДня(ПериодЗадолженностиКонец);
	КонецЕсли;
	
	ДатаЗадачи = ТекущаяДатаСеанса();
	
	Если ЗначениеЗаполнено(Задача) Тогда
		ОбъектЗадача = Задача.ПолучитьОбъект();
		ЗначениеВРеквизитФормы(ОбъектЗадача, "Объект");
	КонецЕсли;
	ЗаполнитьТЗ_ПросроченнаяЗадолженность();
	ЗаполнитьТЗ_ФайлыДокументов();
	РольСледЭтапа = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(СледующийЭтап, "Роль");
	ЗаполнитьПользователей(Задача, РольСледЭтапа);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПользователей(Задача, РольСледЭтапа)
	//ЕстьСледЗадача = Истина;
	
	Если ЗначениеЗаполнено(Задача) Тогда
		СледЗадачаПомеченная 	= Задачи.энргЗадачаПИД.ПолучитьЗадачуПоОснованию(Задача);
		
		Если ЗначениеЗаполнено(СледЗадачаПомеченная) Тогда
			Пользователь		= энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(СледЗадачаПомеченная, "Исполнитель");		
		КонецЕсли;
	КонецЕсли;  	
	
	//Элементы.Пользователь.Видимость 			= не ЕстьСледЗадача;	
	//Элементы.СрокВыполненияЗадачи.Видимость 	= ЕстьСледЗадача;	
	Элементы.Пользователь.СписокВыбора.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргРолиПользователей.Пользователь КАК Пользователь
		|ИЗ
		|	РегистрСведений.энргРолиПользователей КАК энргРолиПользователей
		|ГДЕ
		|	энргРолиПользователей.Роль = &Роль
		|	И энргРолиПользователей.Организация = &Организация
		|	И энргРолиПользователей.Район = &Район";
	
	Запрос.УстановитьПараметр("Роль", 			РольСледЭтапа);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	
	РезультатЗапроса = Запрос.Выполнить();	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Элементы.Пользователь.СписокВыбора.Добавить(Выборка.Пользователь, Выборка.Пользователь);
	КонецЦикла;	

КонецПроцедуры

#КонецОбласти

