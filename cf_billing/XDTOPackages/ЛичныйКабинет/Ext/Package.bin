<package xmlns="http://v8.1c.ru/8.1/xdto" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://www.LK.ru" elementFormQualified="true" attributeFormQualified="false">
	<valueType name="LoadTypes" base="xs:string" variety="Atomic">
		<enumeration>Household</enumeration>
		<enumeration>Commercial</enumeration>
	</valueType>
	<valueType name="ProcessingStatuses" base="xs:string" variety="Atomic">
		<enumeration>OK</enumeration>
		<enumeration>Error</enumeration>
	</valueType>
	<valueType name="ReliabilityCategorys" base="xs:string" variety="Atomic">
		<enumeration>I</enumeration>
		<enumeration>II</enumeration>
		<enumeration>III</enumeration>
	</valueType>
	<valueType name="Sexes" base="xs:string" variety="Atomic">
		<enumeration>Man</enumeration>
		<enumeration>Woman</enumeration>
	</valueType>
	<objectType name="ArrayOfBanks">
		<property xmlns:d3p1="http://www.LK.ru" name="Banks" type="d3p1:Bank" lowerBound="0" upperBound="-1" nillable="true"/>
	</objectType>
	<objectType name="ArrayOfClients">
		<property xmlns:d3p1="http://www.LK.ru" name="Clients" type="d3p1:Client" lowerBound="0" upperBound="-1" nillable="true"/>
	</objectType>
	<objectType name="ArrayOfContacts">
		<property xmlns:d3p1="http://www.LK.ru" name="Contacts" type="d3p1:Contact" lowerBound="0" upperBound="-1" nillable="true"/>
	</objectType>
	<objectType name="ArrayOfData">
		<property xmlns:d3p1="http://www.LK.ru" name="Banks" type="d3p1:Bank" lowerBound="0" upperBound="-1" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="Clients" type="d3p1:Client" lowerBound="0" upperBound="-1" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="Contacts" type="d3p1:Contact" lowerBound="0" upperBound="-1" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="Objects" type="d3p1:Client" lowerBound="0" upperBound="-1" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="Requests" type="d3p1:Requests" lowerBound="0" upperBound="-1" nillable="true"/>
	</objectType>
	<objectType name="ArrayOfObjects">
		<property xmlns:d3p1="http://www.LK.ru" name="Objects" type="d3p1:Client" lowerBound="0" upperBound="-1" nillable="true"/>
	</objectType>
	<objectType name="ArrayOfRequest">
		<property xmlns:d3p1="http://www.LK.ru" name="Requests" type="d3p1:Requests" lowerBound="0" upperBound="-1" nillable="true"/>
	</objectType>
	<objectType name="ArrayOfResponses">
		<property xmlns:d3p1="http://www.LK.ru" name="Responses" type="d3p1:Response" lowerBound="0" upperBound="-1" nillable="true"/>
	</objectType>
	<objectType name="Bank">
		<property name="GUID" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="ID" type="xs:string" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="ClientRef" type="d3p1:Client" lowerBound="0" nillable="true"/>
		<property name="Name" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="BIK" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Account" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="AdjAccount" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Del" type="xs:boolean"/>
		<property name="MessageNumber" type="xs:int" lowerBound="0" nillable="true"/>
	</objectType>
	<objectType name="Client">
		<property name="GUID" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="ID" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Name" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="FullName" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="KPP" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="INN" type="xs:string" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="Passport" type="d3p1:PassportData" lowerBound="0" nillable="true"/>
		<property name="Email" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="PhoneNum" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Login" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Password" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Del" type="xs:boolean"/>
		<property name="MessageNumber" type="xs:int" lowerBound="0" nillable="true"/>
	</objectType>
	<objectType name="Contact">
		<property name="GUID" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="ID" type="xs:string" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="ClientRef" type="d3p1:Client" lowerBound="0" nillable="true"/>
		<property name="FIO" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Post" type="xs:string" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="Sex" type="d3p1:Sexes" lowerBound="0" nillable="true"/>
		<property name="Main" type="xs:boolean" lowerBound="0" nillable="true"/>
		<property name="Del" type="xs:boolean"/>
		<property name="MessageNumber" type="xs:int" lowerBound="0" nillable="true"/>
	</objectType>
	<objectType name="FileInfo">
		<property name="Content" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="ContentType" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="FileName" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Name" type="xs:string" lowerBound="0" nillable="true"/>
	</objectType>
	<objectType name="Object">
		<property name="ID" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="GUID" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Name" type="xs:string" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="ClientRef" type="d3p1:Client" lowerBound="0" nillable="true"/>
		<property name="Address" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="CadastralNumObj" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="CadastralNumArea" type="xs:string" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="ReliabilityCategory" type="d3p1:ReliabilityCategorys" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="LoadType" type="d3p1:LoadTypes" lowerBound="0" nillable="true"/>
		<property name="MKJD" type="xs:boolean" lowerBound="0" nillable="true"/>
		<property name="ConnectedPower" type="xs:decimal" lowerBound="0" nillable="true"/>
		<property name="Del" type="xs:boolean"/>
		<property name="MessageNumber" type="xs:int" lowerBound="0" nillable="true"/>
	</objectType>
	<objectType name="PassportData">
		<property name="Series" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Number" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Date" type="xs:date" lowerBound="0" nillable="true"/>
		<property name="IssuedBy" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="CodePO" type="xs:string" lowerBound="0" nillable="true"/>
	</objectType>
	<objectType name="Requests">
		<property name="ID" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="GUID" type="xs:string" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="ObjectRef" type="d3p1:Object" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="ClientRef" type="d3p1:Client" lowerBound="0" nillable="true"/>
		<property name="Reason" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="SO" type="xs:boolean" lowerBound="0" nillable="true"/>
		<property name="Provider" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Region" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="Status" type="xs:string" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="Files" type="d3p1:FileInfo" lowerBound="0" upperBound="-1" nillable="true"/>
		<property name="Del" type="xs:boolean"/>
		<property name="MessageNumber" type="xs:int" lowerBound="0" nillable="true"/>
	</objectType>
	<objectType name="Response">
		<property xmlns:d3p1="http://www.LK.ru" name="Status" type="d3p1:ProcessingStatuses"/>
		<property name="Message" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="ID" type="xs:string" lowerBound="0" nillable="true"/>
		<property name="GUID" type="xs:string" lowerBound="0" nillable="true"/>
	</objectType>
	<objectType name="TPStages">
		<property name="Stage" type="xs:int" lowerBound="0" nillable="true"/>
		<property name="ProjectDate" type="xs:date" lowerBound="0" upperBound="-1" nillable="true"/>
		<property name="ExploitationDate" type="xs:date" lowerBound="0" upperBound="-1" nillable="true"/>
		<property name="ConnectedPower" type="xs:decimal" lowerBound="0" nillable="true"/>
		<property name="AmountOfPoints" type="xs:int" lowerBound="0" nillable="true"/>
		<property xmlns:d3p1="http://www.LK.ru" name="ReliabilityCategory" type="d3p1:ReliabilityCategorys" lowerBound="0" nillable="true"/>
		<property name="VoltageLevel" type="xs:string" lowerBound="0" nillable="true"/>
	</objectType>
	<objectType name="ArrayOfPokazaniay">
		<property name="Licevoy" type="xs:string"/>
		<property name="Pokazaniay" type="xs:string"/>
	</objectType>
</package>