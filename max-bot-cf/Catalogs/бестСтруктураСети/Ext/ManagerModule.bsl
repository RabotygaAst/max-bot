#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Функция ПолучитьСхемуПрисоединения(ТекСтруктураСети) Экспорт
	пСтруктураСети = ТекСтруктураСети;
	Результат = АктуальныеДанныеСтруктурыСети().Выгрузить();
	
	СхемаПрисоединения = Строка(пСтруктураСети);
	ЗаполнитьСхемуПрисоединения(пСтруктураСети, Результат, СхемаПрисоединения);
	Возврат Строка(СхемаПрисоединения);

КонецФункции

Функция АктуальныеДанныеСтруктурыСети() Экспорт 
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РегистрСведенийбестСтруктураСетиСрезПоследних.Источник КАК Источник,
	|	РегистрСведенийбестСтруктураСетиСрезПоследних.Приемник КАК Приемник,
	|	ВЫБОР
	|		КОГДА РегистрСведенийбестСтруктураСетиСрезПоследних.Приемник.ПометкаУдаления
	|			ТОГДА 4
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК ИндексКартинки,
	|	РегистрСведенийбестСтруктураСетиСрезПоследних.ВерхнийУровень КАК ВерхнийУровень
	|ПОМЕСТИТЬ ДанныеРегистра
	|ИЗ
	|	РегистрСведений.бестСтруктураСети.СрезПоследних КАК РегистрСведенийбестСтруктураСетиСрезПоследних
	|ГДЕ
	|	РегистрСведенийбестСтруктураСетиСрезПоследних.Актуальность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестСтруктураСети.Ссылка КАК Приемник,
	|	ИСТИНА КАК ВерхнийУровень,
	|	ВЫБОР
	|		КОГДА бестСтруктураСети.ПометкаУдаления
	|			ТОГДА 4
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК ИндексКартинки,
	|	ЗНАЧЕНИЕ(Справочник.бестСтруктураСети.ПустаяСсылка) КАК Источник
	|ПОМЕСТИТЬ ОставшиесяЭлементыСтруктурыСети
	|ИЗ
	|	Справочник.бестСтруктураСети КАК бестСтруктураСети
	|ГДЕ
	|	НЕ бестСтруктураСети.Ссылка В
	|				(ВЫБРАТЬ
	|					ДанныеРегистра.Приемник КАК Приемник
	|				ИЗ
	|					ДанныеРегистра КАК ДанныеРегистра)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеРегистра.Источник КАК Источник,
	|	ДанныеРегистра.ИндексКартинки КАК ИндексКартинки,
	|	ДанныеРегистра.Приемник КАК Приемник, 
	|	ДанныеРегистра.Приемник.Наименование КАК ПриемникНаименование,
	|	ДанныеРегистра.ВерхнийУровень КАК ВерхнийУровень,
	|	ДанныеРегистра.Источник.Представление КАК ИсточникПредставление
	|ИЗ
	|	ДанныеРегистра КАК ДанныеРегистра
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОставшиесяЭлементыСтруктурыСети.Источник,
	|	ОставшиесяЭлементыСтруктурыСети.ИндексКартинки,
	|	ОставшиесяЭлементыСтруктурыСети.Приемник,
	|	ОставшиесяЭлементыСтруктурыСети.Приемник.Наименование КАК ПриемникНаименование,
	|	ОставшиесяЭлементыСтруктурыСети.ВерхнийУровень,
	|	ОставшиесяЭлементыСтруктурыСети.Источник.Представление
	|ИЗ
	|	ОставшиесяЭлементыСтруктурыСети КАК ОставшиесяЭлементыСтруктурыСети
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВерхнийУровень УБЫВ";
	
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса;
КонецФункции

Процедура ЗаполнитьСхемуПрисоединения(СтруктураСети, Результат, СхемаПрисоединения) Экспорт 
	МассивПодчиненных	= Результат.НайтиСтроки(Новый Структура("Приемник", СтруктураСети));
	Для Каждого ТекСтрока Из МассивПодчиненных Цикл
		Если ЗначениеЗаполнено(ТекСтрока.Источник) Тогда
			СтруктураСети 		= ТекСтрока.Источник;
			СхемаПрисоединения = ТекСтрока.ИсточникПредставление + ", " + СхемаПрисоединения;
			ЗаполнитьСхемуПрисоединения(СтруктураСети, Результат, СхемаПрисоединения);
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры 

#КонецОбласти

#КонецЕсли