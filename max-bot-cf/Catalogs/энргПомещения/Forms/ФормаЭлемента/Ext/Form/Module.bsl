	//Если Соответствие["ТипСтроения"] <> ПредопределенноеЗначение("Перечисление.энргТипыСтроений.МКД") Тогда
	//	Элементы.Фиктивное.Видимость = Истина;
	//Иначе
	//	Элементы.Фиктивное.Видимость = Ложь;
	//КонецЕсли;
КонецПроцедуры

