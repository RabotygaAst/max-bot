			КонецЦикла;
			
			Если ЗначениеЗаполнено(НаселенныйПунктДетально.houseNumber) Или НаселенныйПунктДетально.buildings.Количество() > 0 Тогда
				НаселенныйПунктДетально.admLevels.Добавить("house");
			КонецЕсли;
			
