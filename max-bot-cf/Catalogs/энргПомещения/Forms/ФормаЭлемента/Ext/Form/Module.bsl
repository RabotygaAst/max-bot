#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗаполнитьЗначенияСвойств(Объект, Параметры);
	Если ЗначениеЗаполнено(Объект.Строение) и Объект.Строение.КонтактнаяИнформация.Количество() > 0 и Объект.КонтактнаяИнформация.Количество() = 0 Тогда		
		НоваяСтрока = Объект.КонтактнаяИнформация.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Объект.Строение.КонтактнаяИнформация[0]); 
		НоваяСтрока.Вид = Справочники.ВидыКонтактнойИнформации.АдресПомещения;
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		МодульУправлениеКонтактнойИнформацией = ОбщегоНазначения.ОбщийМодуль("УправлениеКонтактнойИнформацией");
		МодульУправлениеКонтактнойИнформацией.ПриСозданииНаСервере(ЭтотОбъект, Объект, "КонтактнаяИнформация");
	КонецЕсли;
	
	РезультатЗапроса = РегистрыСведений.энргТехническаяВозможностьОРП.ПолучитьВозможностьОРП(Объект.Строение, Объект.Ссылка);
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда 
		ТехническаяВозможностьПроведенияОРП = Выборка.ЕстьВозможность;
	Иначе
		ТехническаяВозможностьПроведенияОРП = Ложь;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		МодульУправлениеКонтактнойИнформацией = ОбщегоНазначения.ОбщийМодуль("УправлениеКонтактнойИнформацией");
		МодульУправлениеКонтактнойИнформацией.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		МодульУправлениеКонтактнойИнформацией = ОбщегоНазначения.ОбщийМодуль("УправлениеКонтактнойИнформацией");
		МодульУправлениеКонтактнойИнформацией.ОбработкаПроверкиЗаполненияНаСервере(ЭтотОбъект, Объект, Отказ);	
		
		Если Не Отказ Тогда
			Если НЕ ЗначениеЗаполнено(Объект.Наименование) Тогда
				Отказ = Истина;	
				Если ЭтаФорма.ПодчиненныеЭлементы.КонтактнаяИнформация.ПодчиненныеЭлементы.Количество() > 0 И 
					ЭтаФорма.ПодчиненныеЭлементы.КонтактнаяИнформация.ПодчиненныеЭлементы[0].ПодчиненныеЭлементы.Количество() > 0 Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан номер квартиры",,ЭтаФорма.ПодчиненныеЭлементы.КонтактнаяИнформация.ПодчиненныеЭлементы[0].ПодчиненныеЭлементы[0].Имя,,);
				Иначе
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан номер квартиры");
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		МодульУправлениеКонтактнойИнформацией = ОбщегоНазначения.ОбщийМодуль("УправлениеКонтактнойИнформацией");
		МодульУправлениеКонтактнойИнформацией.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	РС = РегистрыСведений.энргТехническаяВозможностьОРП;
	РезультатЗапроса = РС.ПолучитьВозможностьОРП(Объект.Строение, Объект.Ссылка);
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда 
		ТекТехническаяВозможностьПроведенияОРП = Выборка.ЕстьВозможность;
	Иначе
		ТекТехническаяВозможностьПроведенияОРП = Ложь;
	КонецЕсли;
	
	Если ТекТехническаяВозможностьПроведенияОРП <> ТехническаяВозможностьПроведенияОРП Тогда
		РС.УстановитьВозможностьОРП(Объект.Строение, Объект.Ссылка, ТехническаяВозможностьПроведенияОРП);
	КонецЕсли
	
КонецПроцедуры

&НаСервере
Процедура СтроениеПриИзмененииНаСервере()
	Если ЗначениеЗаполнено(Объект.Строение) Тогда
		СтрокиКИ 							= Объект.Строение.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид",Справочники.ВидыКонтактнойИнформации.АдресДома));
		Если СтрокиКИ.количество() > 0 тогда
			ОбъектТек = РеквизитФормыВЗначение("Объект");
			Если ЗначениеЗаполнено(Объект.Строение.УлицаНедобавленнаяВФИАС) Тогда
				СтрокиКИ = Объект.Строение.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид",Справочники.ВидыКонтактнойИнформации.АдресДома));
				Если СтрокиКИ.количество() > 0 тогда
					НовСтр = ОбъектТек.КонтактнаяИнформация.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтр, СтрокиКИ[0]);
					НовСтр.Вид =   Справочники.ВидыКонтактнойИнформации.АдресПомещения;
				КонецЕсли;
			Иначе
				//УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектТек, СтрокиКИ[0].Представление, Справочники.ВидыКонтактнойИнформации.АдресПомещения);
				УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектТек, СтрокиКИ[0].Значение, Справочники.ВидыКонтактнойИнформации.АдресПомещения);
			КонецЕсли;
			УправлениеКонтактнойИнформацией.ПриЧтенииНаСервере(ЭтаФорма, ОбъектТек);
			ЗначениеВРеквизитФормы(ОбъектТек,"Объект");
			//Если НЕ ЗначениеЗаполнено(Объект.Наименование) Тогда
			СтрокаАдреса = Объект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", Справочники.ВидыКонтактнойИнформации.АдресПомещения));
			Если ЗначениеЗаполнено(СтрокаАдреса) Тогда
				Объект.Наименование = Справочники.энргПомещения.СформироватьНаименование(СтрокаАдреса[0].Значение);
			КонецЕсли;
			//КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СтроениеПриИзменении(Элемент)
	СтроениеПриИзмененииНаСервере();
	УстановитьВидимостьФиктивногоПомещения();
КонецПроцедуры

&НаСервере
Процедура ИзменитьАдресНаСервере()
	Если ЗначениеЗаполнено(Объект.Родитель) Тогда
		ВидКИ 		= Справочники.ВидыКонтактнойИнформации.АдресПомещения;	
		СтрокиКИ 	= Объект.Родитель.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", ВидКИ));
		Если СтрокиКИ.количество() > 0 тогда
			ОбъектТек = РеквизитФормыВЗначение("Объект");
			
			СтрокаJSON = СтрокиКИ[0].Значение;
			Если Объект.ТипПомещения = Перечисления.энргТипыПомещений.Комната Или Объект.ТипПомещения = Перечисления.энргТипыПомещений.КойкоМесто Тогда
				СтруктураJSON 		= УправлениеКонтактнойИнформациейСлужебный.СтрокуJSONВСтруктуру(СтрокаJSON);
				ДанныеКомнаты 		= ПрочитатьДанныеКомнаты(ВидКИ, СокрЛП(Объект.ТипПомещения), 0); 
				СтруктураJSON.apartments.Добавить(ДанныеКомнаты);
				//Если не СтруктураJSON.Свойство("locality") Тогда
				//	СтруктураJSON.Вставить("locality", "");
				//КонецЕсли; 
				
				НаселенныйПунктДетально = РаботаСАдресамиКлиентСервер.ОписаниеНовойКонтактнойИнформации(Перечисления.ТипыКонтактнойИнформации.Адрес); 
				ЗаполнитьЗначенияСвойств(НаселенныйПунктДетально, СтруктураJSON);
				
				ЗаполнениеПолейАдресаДляРанееВведенныхАдресов(НаселенныйПунктДетально);   											
				СтруктураJSON.value = РаботаСАдресамиКлиентСервер.ПредставлениеАдреса(НаселенныйПунктДетально, ВидКИ.ВключатьСтрануВПредставление);  
				СтрокаJSON 			= УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(СтруктураJSON);
			КонецЕсли;
		
			УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектТек, СтрокаJSON, ВидКИ);
			УправлениеКонтактнойИнформацией.ПриЧтенииНаСервере(ЭтаФорма, ОбъектТек);
			ЗначениеВРеквизитФормы(ОбъектТек,"Объект");
			//Если НЕ ЗначениеЗаполнено(Объект.Наименование) Тогда
			СтрокаАдреса = Объект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", ВидКИ));
			Если ЗначениеЗаполнено(СтрокаАдреса) Тогда
				Объект.Наименование = Справочники.энргПомещения.СформироватьНаименование(СтрокаАдреса[0].Значение);
			КонецЕсли;
			//КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры 

&НаСервере
Функция ПрочитатьДанныеКомнаты(ВидКИ, ТипПомещения, НомерПоУмолчанию)
	Ответ 			= Новый Структура("type,number", СокрЛП(Объект.ТипПомещения), "0");
	КИСуществует 	= ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтотОбъект, "КонтактнаяИнформацияОписаниеДополнительныхРеквизитов");
	Если КИСуществует Тогда
		СтрокиКИ 	= ЭтотОбъект.КонтактнаяИнформацияОписаниеДополнительныхРеквизитов.НайтиСтроки(Новый Структура("Вид", ВидКИ));
		Если СтрокиКИ.Количество() > 0 Тогда
			СтрокаАдреса 	= СтрокиКИ[0];
			СтруктураJSON 	= УправлениеКонтактнойИнформациейСлужебный.СтрокуJSONВСтруктуру(СтрокаАдреса.Значение);
			Для Каждого ТекСтрокаКИ из СтруктураJSON.apartments Цикл
				Если ТекСтрокаКИ.type = ТипПомещения Тогда
					Ответ.number = ТекСтрокаКИ.number;
				КонецЕсли;			
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

&НаКлиенте
Процедура РодительПриИзменении(Элемент)
