	|ИЗ
	|	ВТ_Объект КАК ВТ_Объект
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестУчастиеОбъектовВРаспределенииРесурсовВМКД.СрезПоследних(
	|				,
	|				ОбъектРасчета В
	|					(ВЫБРАТЬ
	|						ВТ.Ссылка
	|					ИЗ
	|						ВТ_Объект КАК ВТ)) КАК бестУчастиеОбъектовВРаспределенииРесурсовВМКДСрезПоследних
	|		ПО ВТ_Объект.Ссылка = бестУчастиеОбъектовВРаспределенииРесурсовВМКДСрезПоследних.ОбъектРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Площадь КАК ВТ_Площадь
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Температура КАК ВТ_Температура
	|		ПО (ИСТИНА)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВсеЗаписи.Услуга КАК Услуга,
	|	ВТ_ВсеЗаписи.Нагрузка КАК Нагрузка
	|ИЗ
	|	ВТ_ВсеЗаписи КАК ВТ_ВсеЗаписи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МаксРегистратор КАК ВТ_МаксРегистратор
	|		ПО ВТ_ВсеЗаписи.Период = ВТ_МаксРегистратор.Период
	|			И ВТ_ВсеЗаписи.Услуга = ВТ_МаксРегистратор.Услуга
	|			И ВТ_ВсеЗаписи.Регистратор = ВТ_МаксРегистратор.Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Вт_ВсеПотребителейГВС.Тип КАК Тип,
	|	Вт_ВсеПотребителейГВС.Количество КАК Количество,
	|	Вт_ВсеПотребителейГВС.КоличествоРабочихЧасовВДень КАК КоличествоРабочихЧасовВДень,
	|	Вт_ВсеПотребителейГВС.ТипНормы КАК ТипНормы
	|ИЗ
	|	Вт_ВсеПотребителейГВС КАК Вт_ВсеПотребителейГВС
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МаксРегистраторПотребителейГВС КАК ВТ_МаксРегистраторПотребителейГВС
	|		ПО Вт_ВсеПотребителейГВС.Период = ВТ_МаксРегистраторПотребителейГВС.Период
	|			И Вт_ВсеПотребителейГВС.Регистратор = ВТ_МаксРегистраторПотребителейГВС.Регистратор
	|			И Вт_ВсеПотребителейГВС.Тип = ВТ_МаксРегистраторПотребителейГВС.Тип
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВсеЗаписиОбъемов.Услуга КАК Услуга,
	|	ВТ_ВсеЗаписиОбъемов.Месяц КАК Месяц,
	|	ВТ_ВсеЗаписиОбъемов.ОбъемУслуги КАК ОбъемУслуги,
	|	ВТ_ВсеЗаписиОбъемов.Год КАК Год,
	|	ВТ_ВсеЗаписиОбъемов.Месяц КАК МесяцЧислом
	|ИЗ
	|	ВТ_ВсеЗаписиОбъемов КАК ВТ_ВсеЗаписиОбъемов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МаксРегистраторОбъемов КАК ВТ_МаксРегистраторОбъемов
	|		ПО ВТ_ВсеЗаписиОбъемов.Период = ВТ_МаксРегистраторОбъемов.Период
	|			И ВТ_ВсеЗаписиОбъемов.Регистратор = ВТ_МаксРегистраторОбъемов.Регистратор
	|			И ВТ_ВсеЗаписиОбъемов.Услуга = ВТ_МаксРегистраторОбъемов.Услуга
	|			И ВТ_ВсеЗаписиОбъемов.Месяц = ВТ_МаксРегистраторОбъемов.Месяц
	|
	|УПОРЯДОЧИТЬ ПО
	|	Услуга,
	|	Год,
	|	МесяцЧислом
	|ИТОГИ ПО
	|	Услуга,
	|	Год";
	Запрос.УстановитьПараметр("ОбъектРасчета", ОбъектРасчета);
	Пакет = Запрос.ВыполнитьПакет();
	
	// данные по объекту
	СтруктураОбъекта = Новый Структура("НаименованиеОбъектаРасчета,МКД,НазначениеНП,КатегорияОбъекта,Площадь,ГруппаПотребителей,Участвует,ТемператураВнутриПомещения, АдресОбъекта, АдресОбъектаЗначение,Контролер,Помещение,Организация,ГруппаОбъектовРасчета, НаружныйОбъемЗдания");
	Результат = Пакет[Пакет.Количество()-4].Выбрать();
	Если Результат.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураОбъекта, Результат);
		
		Если ЗначениеЗаполнено(СтруктураОбъекта.АдресОбъектаЗначение) Тогда
			ОбъектКИ = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияВСтруктуруJSON(СтруктураОбъекта.АдресОбъектаЗначение, Перечисления.ТипыКонтактнойИнформации.Адрес);
			СтруктураОбъекта.АдресОбъектаЗначение = УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(ОбъектКИ);
		КонецЕсли;
	КонецЕсли;
	
	// данные по нагрузкам
	СоответствиеНагрузок = Новый Соответствие;
	Результат = Пакет[Пакет.Количество()-3].Выбрать();
	Пока Результат.Следующий() Цикл
		СоответствиеНагрузок.Вставить(Результат.Услуга, Результат.Нагрузка);
	КонецЦикла;
	
	// данные по потребителям ГВС
	СоответствиеПотребителей = Новый Соответствие;
	Результат = Пакет[Пакет.Количество()-2].Выбрать();
	Пока Результат.Следующий() Цикл
		СтруктураПотребителей = Новый Структура("Количество,КоличествоРабочихЧасовВДень,ТипНормы");
		ЗаполнитьЗначенияСвойств(СтруктураПотребителей, Результат);
		СоответствиеПотребителей.Вставить(Результат.Тип, СтруктураПотребителей);
	КонецЦикла;
	
	// данные по тарифным категориям
	СоответствиеТарифныхКатегорий = Новый Соответствие;
	Результат = Пакет[Пакет.Количество()-6].Выбрать();
	Пока Результат.Следующий() Цикл
		СоответствиеТарифныхКатегорий.Вставить(Результат.Услуга, Результат.ТарифнаяКатегория);
	КонецЦикла;

	
	// данные по объемам
	МассивОбъемов			= Новый Массив;
	МассивМесяцев			= Новый Массив;
	МассивМесяцев.Добавить("Январь");	МассивМесяцев.Добавить("Февраль");	МассивМесяцев.Добавить("Март");
	МассивМесяцев.Добавить("Апрель");	МассивМесяцев.Добавить("Май");		МассивМесяцев.Добавить("Июнь");
	МассивМесяцев.Добавить("Июль");		МассивМесяцев.Добавить("Август");	МассивМесяцев.Добавить("Сентябрь");
	МассивМесяцев.Добавить("Октябрь");	МассивМесяцев.Добавить("Ноябрь");	МассивМесяцев.Добавить("Декабрь");
	
	РезультатУслуга = Пакет[Пакет.Количество()-1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока РезультатУслуга.Следующий() Цикл 
		РезультатГод = РезультатУслуга.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока РезультатГод.Следующий() Цикл
			СтруктураОбъема	= Новый Структура("Год,Услуга,Январь,Февраль,Март,Апрель,Май,Июнь,Июль,Август,Сентябрь,Октябрь,Ноябрь,Декабрь");
			ЗаполнитьЗначенияСвойств(СтруктураОбъема, РезультатГод);
			Результат = РезультатГод.Выбрать();
			Пока Результат.Следующий() Цикл
				СтруктураОбъема[МассивМесяцев[Результат.МесяцЧислом-1]] = Результат.ОбъемУслуги;
			КонецЦикла;
			МассивОбъемов.Добавить(СтруктураОбъема);
		КонецЦикла;
	КонецЦикла;
	
	// данные по потерям
	МассивОбъемовПотерь		= Новый Массив;
	МассивМесяцевПотерь		= Новый Массив;
	МассивМесяцевПотерь.Добавить("Январь");	МассивМесяцевПотерь.Добавить("Февраль");	МассивМесяцевПотерь.Добавить("Март");
	МассивМесяцевПотерь.Добавить("Апрель");	МассивМесяцевПотерь.Добавить("Май");		МассивМесяцевПотерь.Добавить("Июнь");
	МассивМесяцевПотерь.Добавить("Июль");		МассивМесяцевПотерь.Добавить("Август");	МассивМесяцевПотерь.Добавить("Сентябрь");
	МассивМесяцевПотерь.Добавить("Октябрь");	МассивМесяцевПотерь.Добавить("Ноябрь");	МассивМесяцевПотерь.Добавить("Декабрь");
	
	РезультатУслуга = Пакет[Пакет.Количество()-5].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока РезультатУслуга.Следующий() Цикл 
		РезультатГод = РезультатУслуга.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока РезультатГод.Следующий() Цикл
			СтруктураОбъема	= Новый Структура("Год,Услуга,Январь,Февраль,Март,Апрель,Май,Июнь,Июль,Август,Сентябрь,Октябрь,Ноябрь,Декабрь");
			ЗаполнитьЗначенияСвойств(СтруктураОбъема, РезультатГод);
			Результат = РезультатГод.Выбрать();
			Пока Результат.Следующий() Цикл
				СтруктураОбъема[МассивМесяцевПотерь[Результат.МесяцЧислом-1]] = Результат.ОбъемУслуги;
			КонецЦикла;
			МассивОбъемовПотерь.Добавить(СтруктураОбъема);
		КонецЦикла;
	КонецЦикла;

	
	СтруктураРезультат = Новый Структура("СтруктураОбъекта,СоответствиеНагрузок,СоответствиеПотребителей,МассивОбъемов, МассивПотерь, СоответствиеТарифныхКатегорий",СтруктураОбъекта,СоответствиеНагрузок,СоответствиеПотребителей,МассивОбъемов,МассивОбъемовПотерь, СоответствиеТарифныхКатегорий);
	Возврат СтруктураРезультат;
КонецФункции

// Функция - Вернуть адрес объекта расчета
//
// Параметры:
//  ОбъектРасчета - СправочникСсылка.бестОбъектыРасчета - объект расчета
// Возвращаемое значение:
//	Представление
//
Функция ВернутьАдресОбъектаРасчета(ОбъектРасчета) Экспорт
	
	Возврат УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(ОбъектРасчета, Справочники.ВидыКонтактнойИнформации.АдресОбъектаРасчета);	
	
КонецФункции

#КонецОбласти   

#Область СлужебныеПроцедурыИФункции

Функция ЗаполнитьРеквизитыОбъектаРасчета(ОбъектРасчетаОбъект,ДанныеОбъектаРасчета)
	
	Если ДанныеОбъектаРасчета.Свойство("Наименование") Тогда 
		ОбъектРасчетаОбъект.Наименование					= ДанныеОбъектаРасчета.Наименование;
	КонецЕсли;
	
	Если ДанныеОбъектаРасчета.Свойство("НазначениеНП") Тогда 
		ОбъектРасчетаОбъект.НазначениеНП					= ДанныеОбъектаРасчета.НазначениеНП;
	КонецЕсли;
	
	Если ДанныеОбъектаРасчета.Свойство("ГруппаОбъектовРасчета") Тогда 
		ОбъектРасчетаОбъект.ГруппаОбъектовРасчета			= ДанныеОбъектаРасчета.ГруппаОбъектовРасчета;
	КонецЕсли;

	Если ДанныеОбъектаРасчета.Свойство("КатегорияОбъекта") Тогда 
		ОбъектРасчетаОбъект.КатегорияПомещения				= ДанныеОбъектаРасчета.КатегорияОбъекта;
	КонецЕсли;
	
	Если ДанныеОбъектаРасчета.Свойство("МКД") Тогда 
		ОбъектРасчетаОбъект.МКД								= ДанныеОбъектаРасчета.МКД;
		Если ЗначениеЗаполнено(ОбъектРасчетаОбъект.МКД) Тогда
			ОбъектРасчетаОбъект.Строение						= ДанныеОбъектаРасчета.МКД;	
		КонецЕсли; 
		
	КонецЕсли;
	
	Если ДанныеОбъектаРасчета.Свойство("Помещение") Тогда 
		ОбъектРасчетаОбъект.Помещение						= ДанныеОбъектаРасчета.Помещение;
	КонецЕсли;
	
	Если ДанныеОбъектаРасчета.Свойство("Контролер") Тогда 
		ОбъектРасчетаОбъект.Контролер						= ДанныеОбъектаРасчета.Контролер;
	КонецЕсли;
	
	Если ДанныеОбъектаРасчета.Свойство("Организация") Тогда 
		ОбъектРасчетаОбъект.Организация						= ДанныеОбъектаРасчета.Организация;
	КонецЕсли;
	
	СтрокиКИ												= ОбъектРасчетаОбъект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип,Вид",Перечисления.ТипыКонтактнойИнформации.Адрес,Справочники.ВидыКонтактнойИнформации.АдресОбъектаРасчета));
	Для Каждого СтрокаКИ Из СтрокиКИ Цикл
		ОбъектРасчетаОбъект.КонтактнаяИнформация.Удалить(СтрокаКИ); 
	КонецЦикла;

	Если ДанныеОбъектаРасчета.Свойство("МКД") и ЗначениеЗаполнено(ДанныеОбъектаРасчета.МКД) Тогда 
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектРасчетаОбъект, ДанныеОбъектаРасчета.МКД.Наименование, Справочники.ВидыКонтактнойИнформации.АдресОбъектаРасчета);  
	ИначеЕсли ДанныеОбъектаРасчета.Свойство("АдресОбъектаЗначение") Тогда
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектРасчетаОбъект, ДанныеОбъектаРасчета.АдресОбъектаЗначение, Справочники.ВидыКонтактнойИнформации.АдресОбъектаРасчета);  
	КонецЕсли;
	
	Попытка	
		ОбъектРасчетаОбъект.Записать();
		Возврат ОбъектРасчетаОбъект.Ссылка;
	Исключение
		ОписаниеОшибки  				= ИнформацияОбОшибке();
		ВызватьИсключение "Не удалось создать объект расчета";
	КонецПопытки;
	
КонецФункции

Функция ДанныеОбъектаИзСтрокиJSON(ОписаниеОбъекта)
			
	Чтение  			= Новый ЧтениеJSON;	
	Чтение.УстановитьСтроку(ОписаниеОбъекта);
	ДанныеОбъекта 			= ПрочитатьJSON(Чтение);
	
	Результат 			= Новый Структура;	
	
	Если ДанныеОбъекта.Свойство("Наименование") Тогда
		Результат.Вставить("Наименование", 					Строка(ДанныеОбъекта.Наименование));
	КонецЕсли;
	
	Если ДанныеОбъекта.Свойство("НазначениеНП") Тогда
		Результат.Вставить("НазначениеНП", 					Справочники.бестНазначениеНежилогоПомещения.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбъекта.НазначениеНП)));
	КонецЕсли;
	
	Если ДанныеОбъекта.Свойство("ГруппаОбъектовРасчета") Тогда
		Результат.Вставить("ГруппаОбъектовРасчета", 			Справочники.бестГруппыОбъектовРасчета.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбъекта.ГруппаОбъектовРасчета)));
	КонецЕсли;
	
	Если ДанныеОбъекта.Свойство("КатегорияОбъекта") Тогда
		Результат.Вставить("КатегорияОбъекта", 				Справочники.энргКатегорииПомещений.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбъекта.КатегорияОбъекта)));
	КонецЕсли;

	Если ДанныеОбъекта.Свойство("МКД") Тогда
		Результат.Вставить("МКД", 					Справочники.энргСтроения.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбъекта.МКД)));
	КонецЕсли;
	
	Если ДанныеОбъекта.Свойство("Помещение") Тогда
		Результат.Вставить("Помещение", 			Справочники.энргПомещения.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбъекта.Помещение)));
	КонецЕсли;
	
	Если ДанныеОбъекта.Свойство("Контролер") Тогда
		Результат.Вставить("Контролер", 			Справочники.энргСотрудники.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбъекта.Контролер)));
	КонецЕсли;
	
	Если ДанныеОбъекта.Свойство("Организация") Тогда
		Результат.Вставить("Организация", 			Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбъекта.Организация)));
	КонецЕсли;

	Если ДанныеОбъекта.Свойство("Договор") Тогда
		Результат.Вставить("Договор", 			Справочники.энргДоговорыКонтрагентов.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОбъекта.Договор)));
	КонецЕсли;
	
	Если ДанныеОбъекта.Свойство("АдресОбъекта") Тогда
		Результат.Вставить("АдресОбъекта", 						ДанныеОбъекта.АдресОбъекта);
		Результат.Вставить("АдресОбъектаЗначение", 				ДанныеОбъекта.АдресОбъектаЗначение);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДобавитьПериодВСтруктуру(ПорядковыйНомерМесяца, ОбъемПотерь, ОбъемыПотерьПоМесяцам)
	
	Если ПорядковыйНомерМесяца = 1 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Январь", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 2 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Февраль", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 3 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Март", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 4 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Апрель", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 5 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Май", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 6 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Июнь", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 7 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Июль", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 8 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Август", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 9 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Сентябрь", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 10 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Октябрь", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 11 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Ноябрь", ОбъемПотерь);
	ИначеЕсли ПорядковыйНомерМесяца = 12 Тогда
		ОбъемыПотерьПоМесяцам.Вставить("Декабрь", ОбъемПотерь);
	КонецЕсли;
	
	Возврат ОбъемыПотерьПоМесяцам;

КонецФункции

