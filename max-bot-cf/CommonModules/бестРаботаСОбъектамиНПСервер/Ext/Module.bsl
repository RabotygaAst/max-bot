#Область ПрограммныйИнтерфейс

// Функция - Действующие услуги по объекту
//
// Параметры:
//  Период			 - Дата 
//  Организация		 - СправочникСсылка.Организации  
//  Район			 - СправочникСсылка.энргЗоныОтвественности 
//  ОбъектРасчета	 - СправочникСсылка.бестОбъектыРасчета 
// 
// Возвращаемое значение:
//   РезультатЗапроса 
//
Функция ДействующиеУслугиПоОбъекту(Период,Организация,Район,ОбъектРасчета) Экспорт 
		
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",				ОбъектРасчета);
	
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаОбъекта
	|ИЗ
	|	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета) КАК бестАктивностьТочекУчетаНПСрезПоследних
	|ГДЕ
	|	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга,
	|	бестУслугиТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ АктивныеТочкиУслуги
	|ИЗ
	|	АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестУслугиТочекУчетаНП.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район
	|					И ОбъектРасчета = &ОбъектРасчета
	|					И ТочкаУчета В
	|						(ВЫБРАТЬ
	|							АктивныеТочкиУчетаОбъекта.ТочкаУчета
	|						ИЗ
	|							АктивныеТочкиУчетаОбъекта)) КАК бестУслугиТочекУчетаНПСрезПоследних
	|		ПО АктивныеТочкиУчетаОбъекта.ОбъектРасчета = бестУслугиТочекУчетаНПСрезПоследних.ОбъектРасчета
	|			И АктивныеТочкиУчетаОбъекта.ТочкаУчета = бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктивныеТочкиУслуги.ОбъектРасчета КАК ОбъектРасчета,
	|	АктивныеТочкиУслуги.ТочкаУчета КАК ТочкаУчета,
	|	ВЫБОР
	|		КОГДА АктивныеТочкиУслуги.Услуга.СоставнаяУслуга
	|			ТОГДА энргВидыУслугСоставляющиеУслуг.Услуга
	|		ИНАЧЕ АктивныеТочкиУслуги.Услуга
	|	КОНЕЦ КАК Услуга
	|ИЗ
	|	АктивныеТочкиУслуги КАК АктивныеТочкиУслуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|		ПО АктивныеТочкиУслуги.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка";	
	Результат  = Запрос.Выполнить();
	Возврат Результат;
КонецФункции

// Функция - Действующие услуги по объекту с договорными объемами
//
// Параметры:
//  Период			 - Дата 
//  Организация		 - СправочникСсылка.Организации 
//  Район			 - СправочникСсылка.энргЗоныОтвественности 
//  ОбъектРасчета	 - СправочникСсылка.бестОбъектыРасчета 
// 
// Возвращаемое значение:
//   РезультатЗапроса 
//
Функция ДействующиеУслугиПоОбъектуСДоговорнымиОбъемами(Период,Организация,Район,ОбъектРасчета) Экспорт 
		
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("Период",					Новый Граница(Период,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Организация",			Организация);
	Запрос.УстановитьПараметр("Район",					Район);
	Запрос.УстановитьПараметр("ОбъектРасчета",				ОбъектРасчета);
	
	Запрос.Текст 	=
	"ВЫБРАТЬ
	|	бестАктивностьТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестАктивностьТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ АктивныеТочкиУчетаОбъекта
	|ИЗ
	|	РегистрСведений.бестАктивностьТочекУчетаНП.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ОбъектРасчета = &ОбъектРасчета) КАК бестАктивностьТочекУчетаНПСрезПоследних
	|ГДЕ
	|	бестАктивностьТочекУчетаНПСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеТочекУчета.Включена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	бестУслугиТочекУчетаНПСрезПоследних.Услуга КАК Услуга,
	|	бестУслугиТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ АктивныеТочкиУслуги
	|ИЗ
	|	АктивныеТочкиУчетаОбъекта КАК АктивныеТочкиУчетаОбъекта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестУслугиТочекУчетаНП.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район
	|					И ОбъектРасчета = &ОбъектРасчета
	|					И ТочкаУчета В
	|						(ВЫБРАТЬ
	|							АктивныеТочкиУчетаОбъекта.ТочкаУчета
	|						ИЗ
	|							АктивныеТочкиУчетаОбъекта)) КАК бестУслугиТочекУчетаНПСрезПоследних
	|		ПО АктивныеТочкиУчетаОбъекта.ОбъектРасчета = бестУслугиТочекУчетаНПСрезПоследних.ОбъектРасчета
	|			И АктивныеТочкиУчетаОбъекта.ТочкаУчета = бестУслугиТочекУчетаНПСрезПоследних.ТочкаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктивныеТочкиУслуги.ОбъектРасчета КАК ОбъектРасчета,
	|	ВЫБОР
	|		КОГДА АктивныеТочкиУслуги.Услуга.СоставнаяУслуга
	|			ТОГДА энргВидыУслугСоставляющиеУслуг.Услуга
	|		ИНАЧЕ АктивныеТочкиУслуги.Услуга
	|	КОНЕЦ КАК Услуга,
	|	АктивныеТочкиУслуги.ТочкаУчета КАК ТочкаУчета
	|ПОМЕСТИТЬ ВТ_ТочкиИУслуги
	|ИЗ
	|	АктивныеТочкиУслуги КАК АктивныеТочкиУслуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|		ПО АктивныеТочкиУслуги.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(бестГарантированныеОбъемыСрезПоследних.Месяц, 1) КАК Месяц,
	|	ЕСТЬNULL(бестГарантированныеОбъемыСрезПоследних.ОбъемУслуги, 0) КАК ОбъемУслуги,
	|	ВТ_ТочкиИУслуги.Услуга КАК Услуга
	|ИЗ
	|	ВТ_ТочкиИУслуги КАК ВТ_ТочкиИУслуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестГарантированныеОбъемы.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район
	|					И ОбъектРасчета = &ОбъектРасчета) КАК бестГарантированныеОбъемыСрезПоследних
	|		ПО ВТ_ТочкиИУслуги.ОбъектРасчета = бестГарантированныеОбъемыСрезПоследних.ОбъектРасчета
	|			И ВТ_ТочкиИУслуги.Услуга = бестГарантированныеОбъемыСрезПоследних.Услуга
	|ГДЕ
	|	НЕ ЕСТЬNULL(ВТ_ТочкиИУслуги.Услуга.ИспользоватьРасчетРеактивнойЭнергии, ЛОЖЬ)";	
	Результат  = Запрос.Выполнить();
	Возврат Результат;
КонецФункции

// Функция - Распределенные значения потерь.
//
// Параметры:
//  Организация		 		  - СправочникСсылка.Организации 
//  Район			 		  - СправочникСсылка.энргЗоныОтвественности 
//  ГодДляРаспределения 	  - Дата
//  ГодовойОбъемПотерь 		  - Документы.бестЗаключениеДоговоровСЮридическимиЛицами.УслугиРаспределенияПотерь.ГодовойОбъемПотерь
//  СпособРаспределенияПотерь - Перечисления.бестСпособыРаспределенияПотерь
//
// Возвращаемое значение:
//	 ОбъемыПотерьПоМесяцам - Число
//
Функция РаспределенныеЗначенияПотерь(Организация,Район, ГодДляРаспределения, ГодовойОбъемПотерь, СпособРаспределенияПотерь) Экспорт
	
	ОбъемыПотерьПоМесяцам = Новый Структура();
	
	Если СпособРаспределенияПотерь = Перечисления.бестСпособыРаспределенияПотерь.Ежемесячно Тогда
		
		РаспределенныйОбъемПотерь = 0;
		
		Для Сч = 0 По 11 Цикл
			
			Если Сч = 11 Тогда
				ОбъемПотерь = ГодовойОбъемПотерь - РаспределенныйОбъемПотерь;
			Иначе
				ОбъемПотерь = ГодовойОбъемПотерь / 12;
			КонецЕсли;
			
			ДобавитьПериодВСтруктуру(Сч + 1, ОбъемПотерь,ОбъемыПотерьПоМесяцам);
			
			РаспределенныйОбъемПотерь = РаспределенныйОбъемПотерь + ОбъемПотерь;
			
		КонецЦикла;
		
	ИначеЕсли СпособРаспределенияПотерь = Перечисления.бестСпособыРаспределенияПотерь.ПоФакту Тогда
		
		Запрос = Новый Запрос;
		
		Текст = "ВЫБРАТЬ
		        |	ВложенныйЗапрос.Сезонность КАК Сезонность,
		        |	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), ГОД, ВложенныйЗапрос.ГодНачало - 1), МЕСЯЦ, ВложенныйЗапрос.МесяцНачала - 1), ДЕНЬ, ВложенныйЗапрос.ДеньНачала - 1) КАК НачалоПериодаДействия,
		        |	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), ГОД, ВложенныйЗапрос.ГодОкончания - 1), МЕСЯЦ, ВложенныйЗапрос.МесяцОкончания - 1), ДЕНЬ, ВложенныйЗапрос.ДеньОкончания - 1) КАК КонецПериодаДействия
		        |ПОМЕСТИТЬ ОтопительныйПериод
		        |ИЗ
		        |	(ВЫБРАТЬ
		        |		энргДлительностиПериодов.Сезонность КАК Сезонность,
		        |		ВЫБОР
		        |			КОГДА МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) > МЕСЯЦ(энргДлительностиПериодов.КонецПериода)
		        |				ТОГДА ДЕНЬ(&НачалоПериодаРасчета)
		        |		КОНЕЦ КАК ДеньНачала,
		        |		ВЫБОР
		        |			КОГДА МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) > МЕСЯЦ(энргДлительностиПериодов.КонецПериода)
		        |				ТОГДА МЕСЯЦ(&НачалоПериодаРасчета)
		        |		КОНЕЦ КАК МесяцНачала,
		        |		ДЕНЬ(энргДлительностиПериодов.КонецПериода) КАК ДеньОкончания,
		        |		МЕСЯЦ(энргДлительностиПериодов.КонецПериода) КАК МесяцОкончания,
		        |		ГОД(&КонецПериодаРасчета) КАК ГодНачало,
		        |		ГОД(&КонецПериодаРасчета) КАК ГодОкончания
		        |	ИЗ
		        |		РегистрСведений.энргДлительностиПериодов.СрезПоследних(
		        |				&НачалоПериодаРасчета,
		        |				Организация = &Организация
		        |					И район = &район) КАК энргДлительностиПериодов
		        |	
		        |	ОБЪЕДИНИТЬ ВСЕ
		        |	
		        |	ВЫБРАТЬ
		        |		энргДлительностиПериодов.Сезонность,
		        |		ДЕНЬ(энргДлительностиПериодов.НачалоПериода),
		        |		МЕСЯЦ(энргДлительностиПериодов.НачалоПериода),
		        |		ВЫБОР
		        |			КОГДА МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) > МЕСЯЦ(энргДлительностиПериодов.КонецПериода)
		        |				ТОГДА ДЕНЬ(&КонецПериодаРасчета)
		        |		КОНЕЦ,
		        |		ВЫБОР
		        |			КОГДА МЕСЯЦ(энргДлительностиПериодов.НачалоПериода) > МЕСЯЦ(энргДлительностиПериодов.КонецПериода)
		        |				ТОГДА МЕСЯЦ(&КонецПериодаРасчета)
		        |		КОНЕЦ,
		        |		ГОД(&КонецПериодаРасчета),
		        |		ГОД(&КонецПериодаРасчета)
		        |	ИЗ
		        |		РегистрСведений.энргДлительностиПериодов.СрезПоследних(
		        |				&НачалоПериодаРасчета,
		        |				Организация = &Организация
		        |					И район = &район) КАК энргДлительностиПериодов) КАК ВложенныйЗапрос
		        |;
		        |
		        |////////////////////////////////////////////////////////////////////////////////
		        |ВЫБРАТЬ
		        |	ОтопительныйПериод.Сезонность КАК Сезонность,
		        |	ОтопительныйПериод.НачалоПериодаДействия КАК НачалоПериодаДействия,
		        |	ОтопительныйПериод.КонецПериодаДействия КАК КонецПериодаДействия,
		        |	РАЗНОСТЬДАТ(ОтопительныйПериод.НачалоПериодаДействия, ОтопительныйПериод.КонецПериодаДействия, ДЕНЬ) + 1 КАК КоличествоДней
		        |ПОМЕСТИТЬ ОтопительныйПериодКоличествоДней
		        |ИЗ
		        |	ОтопительныйПериод КАК ОтопительныйПериод
		        |;
		        |
		        |////////////////////////////////////////////////////////////////////////////////
		        |ВЫБРАТЬ
		        |	ОтопительныйПериодКоличествоДней.Сезонность КАК Сезонность,
		        |	СУММА(ОтопительныйПериодКоличествоДней.КоличествоДней) КАК КоличествоДней
		        |ПОМЕСТИТЬ СуммарноеКоличествоДней
		        |ИЗ
		        |	ОтопительныйПериодКоличествоДней КАК ОтопительныйПериодКоличествоДней
		        |
		        |СГРУППИРОВАТЬ ПО
		        |	ОтопительныйПериодКоличествоДней.Сезонность
		        |;
		        |
		        |////////////////////////////////////////////////////////////////////////////////
		        |ВЫБРАТЬ
		        |	ОтопительныйПериодКоличествоДней.Сезонность КАК Сезонность,
		        |	ОтопительныйПериодКоличествоДней.НачалоПериодаДействия КАК НачалоПериодаДействия,
		        |	ОтопительныйПериодКоличествоДней.КонецПериодаДействия КАК КонецПериодаДействия,
		        |	СуммарноеКоличествоДней.КоличествоДней КАК СуммарноеКоличествоДней
		        |ИЗ
		        |	СуммарноеКоличествоДней КАК СуммарноеКоличествоДней
		        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОтопительныйПериодКоличествоДней КАК ОтопительныйПериодКоличествоДней
		        |		ПО (ОтопительныйПериодКоличествоДней.Сезонность = СуммарноеКоличествоДней.Сезонность)";
		
		Запрос.Текст = Текст;
		
		Запрос.УстановитьПараметр("НачалоПериодаРасчета", Дата(ГодДляРаспределения, 1, 1));
		Запрос.УстановитьПараметр("КонецПериодаРасчета", Дата(ГодДляРаспределения, 12, 31));
		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.УстановитьПараметр("Район", Район);
		
		Результат = Запрос.Выполнить();
		
		Выборка = Результат.Выбрать();
		
		Пока Выборка.Следующий() Цикл

			Мес = НачалоМесяца(Выборка.НачалоПериодаДействия);
			Пока Мес <= Выборка.КонецПериодаДействия Цикл
				НачалоПериода = Макс(Выборка.НачалоПериодаДействия,Мес);
				КонецПериода = Мин(Выборка.КонецПериодаДействия,КонецМесяца(Мес));
				Мес = ДобавитьМесяц(Мес, 1);
				КоличествоДней = (НачалоДня(КонецПериода) - НачалоДня(НачалоПериода)) / (60 * 60 * 24) + 1;
				ОбъемПотерь = КоличествоДней/ Выборка.СуммарноеКоличествоДней * ГодовойОбъемПотерь;
				ДобавитьПериодВСтруктуру(Месяц(КонецПериода), ОбъемПотерь,ОбъемыПотерьПоМесяцам);

			КонецЦикла;     
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ОбъемыПотерьПоМесяцам;	
	
КонецФункции

// Функция - Заполнить текст информации объекта
//
// Параметры:
//	 ТекСтрока - Справочники.бестОбъектыРасчета.НазначениеНП
//
// Возвращаемое значение:
//	 СокрЛП - Строка
Функция ЗаполнитьТекстИнформацииОбъекта(ТекСтрока) Экспорт
	Текст = "Назначение: " + ТекСтрока.НазначениеНП + Символы.ПС;
	Текст = Текст + "Колво раб дней: " + ТекСтрока.КоличествоРабочихДней + Символы.ПС;	
	Текст = Текст + "Колво раб часов: " + ТекСтрока.КоличествоРабочихЧасовВДень + Символы.ПС;
	Возврат СокрЛП(Текст);
КонецФункции

// Процедура - Проверить и создать объекты расчета.
//
// Параметры:
//  ТекущийОбъект	 - ФормаКлиентскогоПриложения 
//  ИмяКоллекции	 - Строка 
//
Процедура ПроверитьИСоздатьОбъектыРасчета(ТекущийОбъект,ИмяКоллекции) Экспорт 
	
	НовыеОбъектыРасчета 						= Новый Массив;
	
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеОбъектыРасчета") Тогда
		НовыеОбъектыРасчета 						= ТекущийОбъект.ДополнительныеСвойства.НовыеОбъектыРасчета; 
	КонецЕсли;
	
	для Каждого стр из ТекущийОбъект[ИмяКоллекции] цикл
			
		ДанныеОбъекта 			= ДанныеОбъектаИзСтрокиJSON(стр.ОписаниеОбъекта);
		
		Если ДанныеОбъекта.Свойство("АдресОбъектаЗначение") И ЗначениеЗаполнено(ДанныеОбъекта.АдресОбъектаЗначение) Тогда
			Чтение  			= Новый ЧтениеJSON();
			Чтение.УстановитьСтроку(ДанныеОбъекта.АдресОбъектаЗначение);
			ДанныеАдреса		= ПрочитатьJSON(Чтение);
		КонецЕсли;
		
		Если НЕ НовыеОбъектыРасчета.Найти(стр.НомерСтроки) = Неопределено Тогда
			ОбъектРасчетаОбъект 					= Справочники.бестОбъектыРасчета.СоздатьЭлемент();
		    ОбъектРасчетаОбъект.УстановитьСсылкуНового(стр.ОбъектРасчета);
		Иначе
			ОбъектРасчетаОбъект  					= стр.ОбъектРасчета.получитьОбъект();
		КонецЕсли;
		
		ЗаполнитьРеквизитыОбъектаРасчета(ОбъектРасчетаОбъект,ДанныеОбъекта);
			 
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Прочитать данные объекта.
//
// Параметры:
//	Форма 		 - ФормаКлиентскогоПриложения
//	ИмяКоллекции - Строка
//
Процедура ПрочитатьДанныеОбъекта(Форма, ИмяКоллекции) Экспорт 
	
	Коллекция 				= Форма.Объект[ИмяКоллекции];
	Запрос 					= Новый Запрос;
	Запрос.УстановитьПараметр("ДанныеТабЧасти",Коллекция.Выгрузить()); 
	Запрос.Текст 			= 
	"ВЫБРАТЬ
	|	ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|	ДанныеТабЧасти.ОбъектРасчета КАК ОбъектРасчета
	|ПОМЕСТИТЬ ДанныеТабЧасти
	|ИЗ
	|	&ДанныеТабЧасти КАК ДанныеТабЧасти
	|ГДЕ
	|	НЕ ДанныеТабЧасти.ОбъектРасчета = ЗНАЧЕНИЕ(Справочник.бестОбъектыРасчета.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестОбъектыРасчетаКонтактнаяИнформация.Представление КАК АдресОбъекта,
	|	бестОбъектыРасчетаКонтактнаяИнформация.ЗначенияПолей КАК АдресОбъектаПредставлениеПолей,
	|	ВложенныйЗапрос.Наименование КАК НаименованиеОбъектаРасчета,
	|	ВложенныйЗапрос.НазначениеНП КАК НазначениеНП,
	|	ВложенныйЗапрос.МКД КАК МКД,
	|	ВложенныйЗапрос.ОбъектРасчета КАК ОбъектРасчета,
	|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
	|	ВложенныйЗапрос.КатегорияОбъекта КАК КатегорияОбъекта,
	|	ВложенныйЗапрос.ГруппаОбъектовРасчета КАК ГруппаОбъектовРасчета,
	|	ВложенныйЗапрос.Помещение КАК Помещение,
	|	ВложенныйЗапрос.Контролер КАК Контролер,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.НаружныйОбъемЗдания КАК НаружныйОбъемЗдания
	|ИЗ
	|	(ВЫБРАТЬ
	|		бестОбъектыРасчета.Наименование КАК Наименование,
	|		бестОбъектыРасчета.НазначениеНП КАК НазначениеНП,
	|		бестОбъектыРасчета.МКД КАК МКД,
	|		ДанныеТабЧасти.ОбъектРасчета КАК ОбъектРасчета,
	|		ДанныеТабЧасти.НомерСтроки КАК НомерСтроки,
	|		бестОбъектыРасчета.КатегорияПомещения КАК КатегорияОбъекта,
	|		бестОбъектыРасчета.ГруппаОбъектовРасчета КАК ГруппаОбъектовРасчета,
	|		бестОбъектыРасчета.Помещение КАК Помещение,
	|		бестОбъектыРасчета.Контролер КАК Контролер,
	|		бестОбъектыРасчета.Организация КАК Организация,
	|		бестОбъектыРасчета.НаружныйОбъемЗдания КАК НаружныйОбъемЗдания
	|	ИЗ
	|		ДанныеТабЧасти КАК ДанныеТабЧасти
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|			ПО ДанныеТабЧасти.ОбъектРасчета = бестОбъектыРасчета.Ссылка) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета.КонтактнаяИнформация КАК бестОбъектыРасчетаКонтактнаяИнформация
	|		ПО ВложенныйЗапрос.ОбъектРасчета = бестОбъектыРасчетаКонтактнаяИнформация.Ссылка
	|ГДЕ
	|	бестОбъектыРасчетаКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|	И бестОбъектыРасчетаКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресОбъектаРасчета)";
	
	Результат  									= Запрос.Выполнить();
	Выборка 									= Результат.Выбрать();
	                       	
	Пока Выборка.Следующий() Цикл
		СтрокаДляЗаполнения 					= Коллекция[Выборка.НомерСтроки - 1];
		ЗаполнитьЗначенияСвойств(СтрокаДляЗаполнения, Выборка,,"НомерСтроки");
	КонецЦикла;
	
	Для Каждого СтрокаТочки Из Коллекция Цикл
		//Если ЗначениеЗаполнено(СтрокаТочки.ОбъектРасчета) Тогда
		//	Продолжить;
		//КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТочки.ОписаниеОбъекта) Тогда
			Продолжить;
		КонецЕсли;
		
		Чтение 									= Новый ЧтениеJSON();
		Чтение.УстановитьСтроку(СтрокаТочки.ОписаниеОбъекта);
		ОписаниеОбъекта						= ПрочитатьJSON(Чтение);
		Для Каждого КлючЗначение Из ОписаниеОбъекта Цикл
			Если КлючЗначение.Ключ = "Наименование" Тогда
				СтрокаТочки.НаименованиеОбъектаРасчета = КлючЗначение.Значение;  
			ИначеЕсли КлючЗначение.Ключ = "НазначениеНП" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.бестНазначениеНежилогоПомещения.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "ГруппаОбъектовРасчета" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.бестГруппыОбъектовРасчета.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));	
			ИначеЕсли КлючЗначение.Ключ = "ГруппаПотребителей" Тогда
				//СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.бестГруппыОбъектовРасчета.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));	
			ИначеЕсли КлючЗначение.Ключ = "КатегорияОбъекта" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргКатегорииПомещений.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));	
			ИначеЕсли КлючЗначение.Ключ = "МКД" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргСтроения.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "Контролер" Тогда
				СтрокаТочки[КлючЗначение.Ключ] 	= Справочники.энргСотрудники.ПолучитьСсылку(Новый УникальныйИдентификатор(КлючЗначение.Значение));
			ИначеЕсли КлючЗначение.Ключ = "Организация" ИЛИ КлючЗначение.Ключ = "Помещение" ИЛИ КлючЗначение.Ключ = "Договор" Тогда
				Продолжить;
			Иначе
				СтрокаТочки[КлючЗначение.Ключ] 	= КлючЗначение.Значение;        
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла;	
	
КонецПроцедуры

// Функция - Получить информацию по объекту.
//
// Параметры:
//	ОбъектРасчета - СправочникСсылка.бестОбъектыРасчета - объект расчета
//
// Возвращаемое значение:
//	СтруктураРезультат - Структура
//
Функция ПолучитьИнформациюПоОбъекту(ОбъектРасчета) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестОбъектыРасчета.НазначениеНП КАК НазначениеНП,
	|	бестОбъектыРасчета.МКД КАК МКД,
	|	бестОбъектыРасчета.Ссылка КАК Ссылка,
	|	бестОбъектыРасчета.КатегорияПомещения КАК КатегорияОбъекта,
	|	бестОбъектыРасчета.ГруппаОбъектовРасчета КАК ГруппаОбъектовРасчета,
	|	ВЫРАЗИТЬ(бестОбъектыРасчетаКонтактнаяИнформация.Представление КАК СТРОКА(300)) КАК АдресОбъекта,
	|	бестОбъектыРасчетаКонтактнаяИнформация.ЗначенияПолей КАК АдресОбъектаЗначение,
	|	бестОбъектыРасчета.Контролер КАК Контролер,
	|	бестОбъектыРасчета.Наименование КАК Наименование,
	|	бестОбъектыРасчета.Помещение КАК Помещение,
	|	бестОбъектыРасчета.Организация КАК Организация,
	|	бестОбъектыРасчета.НаружныйОбъемЗдания КАК НаружныйОбъемЗдания
	|ПОМЕСТИТЬ ВТ_Объект
	|ИЗ
	|	Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета.КонтактнаяИнформация КАК бестОбъектыРасчетаКонтактнаяИнформация
	|		ПО (бестОбъектыРасчетаКонтактнаяИнформация.Ссылка = бестОбъектыРасчета.Ссылка)
	|ГДЕ
	|	бестОбъектыРасчета.Ссылка = &ОбъектРасчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестЗначенияПлощадейНПСрезПоследних.Период КАК Период,
	|	бестЗначенияПлощадейНПСрезПоследних.Регистратор КАК Регистратор,
	|	бестЗначенияПлощадейНПСрезПоследних.Площадь КАК Площадь
	|ПОМЕСТИТЬ ВТ_ВсеЗаписиПлощади
	|ИЗ
	|	РегистрСведений.бестЗначенияПлощадейНП.СрезПоследних(
	|			,
	|			ОбъектРасчета В
	|					(ВЫБРАТЬ
	|						ВТ.Ссылка
	|					ИЗ
	|						ВТ_Объект КАК ВТ)
	|				И ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадьНП)) КАК бестЗначенияПлощадейНПСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВТ_ВсеЗаписиПлощади.Период) КАК Период
	|ПОМЕСТИТЬ ВТ_МаксПлощадь
	|ИЗ
	|	ВТ_ВсеЗаписиПлощади КАК ВТ_ВсеЗаписиПлощади
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВТ_ВсеЗаписиПлощади.Регистратор) КАК Регистратор,
	|	ВТ_ВсеЗаписиПлощади.Период КАК Период
	|ПОМЕСТИТЬ ВТ_МаксРегистраторПлощадь
	|ИЗ
	|	ВТ_МаксПлощадь КАК ВТ_МаксПлощадь
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ВсеЗаписиПлощади КАК ВТ_ВсеЗаписиПлощади
	|		ПО ВТ_МаксПлощадь.Период = ВТ_ВсеЗаписиПлощади.Период
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ВсеЗаписиПлощади.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВсеЗаписиПлощади.Площадь КАК Площадь
	|ПОМЕСТИТЬ ВТ_Площадь
	|ИЗ
	|	ВТ_ВсеЗаписиПлощади КАК ВТ_ВсеЗаписиПлощади
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МаксРегистраторПлощадь КАК ВТ_МаксРегистраторПлощадь
	|		ПО ВТ_ВсеЗаписиПлощади.Период = ВТ_МаксРегистраторПлощадь.Период
	|			И ВТ_ВсеЗаписиПлощади.Регистратор = ВТ_МаксРегистраторПлощадь.Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестРасчетнаяТемператураВнутриПомещенияСрезПоследних.Период КАК Период,
	|	бестРасчетнаяТемператураВнутриПомещенияСрезПоследних.Регистратор КАК Регистратор,
	|	бестРасчетнаяТемператураВнутриПомещенияСрезПоследних.ТемператураВнутриПомещения КАК ТемператураВнутриПомещения
	|ПОМЕСТИТЬ ВТ_ВсеЗаписиТемпературы
	|ИЗ
	|	РегистрСведений.бестРасчетнаяТемператураВнутриПомещения.СрезПоследних(
	|			,
	|			ОбъектРасчета В
	|				(ВЫБРАТЬ
	|					ВТ.Ссылка
	|				ИЗ
	|					ВТ_Объект КАК ВТ)) КАК бестРасчетнаяТемператураВнутриПомещенияСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВТ_ВсеЗаписиТемпературы.Период) КАК Период
	|ПОМЕСТИТЬ ВТ_МаксПериодТемпературы
	|ИЗ
	|	ВТ_ВсеЗаписиТемпературы КАК ВТ_ВсеЗаписиТемпературы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВТ_ВсеЗаписиТемпературы.Регистратор) КАК Регистратор,
	|	ВТ_ВсеЗаписиТемпературы.Период КАК Период
	|ПОМЕСТИТЬ ВТ_МаксРегистраторТемпературы
	|ИЗ
	|	ВТ_МаксПериодТемпературы КАК ВТ_МаксПериодТемпературы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ВсеЗаписиТемпературы КАК ВТ_ВсеЗаписиТемпературы
	|		ПО ВТ_МаксПериодТемпературы.Период = ВТ_ВсеЗаписиТемпературы.Период
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ВсеЗаписиТемпературы.Период
	|;
	|
