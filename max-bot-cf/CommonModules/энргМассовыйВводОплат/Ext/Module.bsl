#Область ФоновоеВыполнениеЗадачиСменаЗависимыхРеквизитов

Функция ЗапуститьФоновоеЗаданиеСменаЗависимыхРеквизитов(ДокументОснование, ЗависимыеРеквизиты, ДополнительныеПараметры = Неопределено) Экспорт 
	
	ИмяМетода = "Документы.энргПлатежноеПоручениеВходящие.УстановитьЗависимыеРеквизитыОтДокументаОснования";
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ПараметрыВыполнения.ОжидатьЗавершение = 0; // запускать сразу
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Смена зависимых реквизитов оплат'");
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения, 
		ИмяМетода,
		ДокументОснование, 
		ЗависимыеРеквизиты);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

#КонецОбласти

