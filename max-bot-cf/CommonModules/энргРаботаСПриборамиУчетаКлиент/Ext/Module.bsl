#Область ПрограммныйИнтерфейс

#Область ДобавлениеПуКУзлам

Функция ВернутьНачальныеПараметрыПередачиДляУзлов(Форма, ТекущиеДанные, ТекущийОбъект) Экспорт 
	ДополнительныеПараметры = новый Структура;
	ДополнительныеПараметры.Вставить("IDСтроки"		, ТекущиеДанные.IDСтроки);
	ДополнительныеПараметры.Вставить("ТекущийОбъект", ТекущийОбъект);
	ДополнительныеПараметры.Вставить("Форма"		, Форма);
	
	ПараметрыПередачи = новый Структура;
	ПараметрыПередачи.Вставить("IDСтроки"			,ТекущиеДанные.IDСтроки); 
	ПараметрыПередачи.Вставить("Услуга"				,ТекущиеДанные.Услуга);
	
	Возврат Новый Структура("ПараметрыПередачи,ДополнительныеПараметры",ПараметрыПередачи,ДополнительныеПараметры);
КонецФункции

Процедура ДобавитьПриборыУчета(СтруктураОтвета) Экспорт 
	
	ДополнительныеПараметры = СтруктураОтвета.ДополнительныеПараметры;
	ПараметрыПередачи 		= СтруктураОтвета.ПараметрыПередачи;	
	ОписаниеЗаверешения  	= Новый ОписаниеОповещения("ЗавершениеРаботыСФормойПриборовУзловУчета",ЭтотОбъект,ДополнительныеПараметры);	
	
	ОткрытьФорму("ОбщаяФорма.энргОперацииСПриборамиУчета",ПараметрыПередачи,,,,,ОписаниеЗаверешения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

Процедура ЗавершениеРаботыСФормойПриборовУзловУчета(Результат, ДополнительныеПараметры) Экспорт 
	
	Если не Результат = Неопределено Тогда
		ДополнительныеПараметры.Форма.Модифицированность 	= Истина;
		ТекущийОбъект 										= ДополнительныеПараметры.ТекущийОбъект;
		
		// Очистка всех зависимых строк по ТУ
		ВыполнитьОчисткуЗависимыхСтрокПоIDСтроки(ДополнительныеПараметры.IDСтроки, ТекущийОбъект);
		
		// Добавление строк
		Для Каждого ТекСтрока из Результат Цикл
			ЗаполнитьТЧИзПараметров(ТекСтрока.Значение,ТекущийОбъект[ТекСтрока.Ключ]);
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры


Процедура ВыполнитьОчисткуЗависимыхСтрокПоIDСтроки(IDСтроки, ТекущийОбъект) Экспорт 
	ОтборIDСтрокиТочкиУчета = Новый Структура("IDСтрокиТочкиУчета"	,IDСтроки);
	ОтборIDСтроки 			= Новый Структура("IDСтроки"			,IDСтроки);
	
	УдалитьЗависимыеСтрокиПоСквозномуID(ТекущийОбъект.ПриборыУзловУчета			,ОтборIDСтроки);
	УдалитьЗависимыеСтрокиПоСквозномуID(ТекущийОбъект.ПоказанияПриборовУчета	,ОтборIDСтрокиТочкиУчета);
	УдалитьЗависимыеСтрокиПоСквозномуID(ТекущийОбъект.ШкалыПриборовУчета		,ОтборIDСтрокиТочкиУчета);
	УдалитьЗависимыеСтрокиПоСквозномуID(ТекущийОбъект.ШкалыУслуг				,ОтборIDСтроки); 	
	УдалитьЗависимыеСтрокиПоСквозномуID(ТекущийОбъект.ФормулыРасчетаУслуг		,ОтборIDСтрокиТочкиУчета);
	Если ТипЗнч(ТекущийОбъект.Ссылка) = Тип("ДокументСсылка.энргОткрытиеМКД") ИЛИ 
		ТипЗнч(ТекущийОбъект.Ссылка) = Тип("ДокументСсылка.энргОперацияСУслугамиМКД") Тогда
		УдалитьЗависимыеСтрокиПоСквозномуID(ТекущийОбъект.ТочкиПоставок		,ОтборIDСтроки);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область РаботаСПуРегистрирующихОбъемы

#Область РаботаСВидимостьюИДоступностью

// Работа с видимостью и доступностью строк ПУ. Необходимо для Замены ПУ.
// Когда нужно установить видимость для выводимого ПУ и для вводимого.
//
// Параметры:
//  РегистрируетОбъем				-	Булево.
//  ИспользоватьТарифныеЗоны		-	Булево.
//  ИспользоватьШкалыПриборовУчета	-	Булево.
//  Форма							-	ФормаКлиентскогоПриложения.
//  ДопПараметры					-	Структура:
//   * РегистрируетОбъем		-	Булево.
//   * ЭтоВводПУ				-	Булево.
//   * НеРегистрацияОбъема		-	Булево.
//
Процедура РаботаСВидимостьюИДоступностьюСтрокПУ(РегистрируетОбъем,ИспользоватьТарифныеЗоны,ИспользоватьШкалыПриборовУчета,Форма,ДопПараметры = Неопределено) Экспорт 
	ЕстьДопПараметры 											= не ДопПараметры = Неопределено;
	
	Если ЕстьДопПараметры и ДопПараметры.Свойство("ЭтоВводПУ") Тогда
		ЭтоВводПУ 												= ДопПараметры.ЭтоВводПУ;
	Иначе
		ЭтоВводПУ 												= Ложь;
	КонецЕсли;
	
	Если ЕстьДопПараметры и ДопПараметры.Свойство("ЭтоЗаменаПУ") Тогда
		ЭтоЗаменаПУ 											= ДопПараметры.ЭтоЗаменаПУ;
	Иначе
		ЭтоЗаменаПУ 												= Ложь;
	КонецЕсли;
		  	
	Если ИспользоватьТарифныеЗоны и ИспользоватьШкалыПриборовУчета Тогда
		Префикс 												= "ПоказанияПриборовУчетаЕстьШкалыЕстьТарифныеЗоны";		
	ИначеЕсли ИспользоватьТарифныеЗоны Тогда
		Префикс 												= "ПоказанияПриборовУчетаНетШкалЕстьТарифныеЗоны";				
	ИначеЕсли ИспользоватьШкалыПриборовУчета Тогда	
		Префикс 												= "ШкалыПриборовУчетаЕстьШкалыНетТарифныхЗон";						
	Иначе
		Префикс 												= "ТочкиУчетаНетШкалНетТарифныхЗон";		
	КонецЕсли;
	
	ЭлементФормы 												= Форма.Элементы;
	
	Если ЭтоЗаменаПУ Тогда
		ПрефиксВвод = Префикс  + "Ввод";
		ЭлементФормы[ПрефиксВвод  + "ТекущиеПоказания"].Видимость	= НЕ РегистрируетОбъем;
		
		ПрефиксВывод = Префикс  + "Вывод";
		ЭлементФормы[ПрефиксВывод  + "ПредыдущиеПоказания"].Видимость 	= НЕ РегистрируетОбъем;
		ЭлементФормы[ПрефиксВывод  + "ТекущиеПоказания"].Видимость 		= НЕ РегистрируетОбъем;
		ЭлементФормы[ПрефиксВывод  + "Переворот"].Видимость 			= НЕ РегистрируетОбъем;
		ЭлементФормы[ПрефиксВывод  + "Разница"].ТолькоПросмотр			= НЕ РегистрируетОбъем;	
	Иначе
		Если ЭтоВводПУ Тогда
			ЭлементФормы[Префикс  + "ТекущиеПоказания"].Видимость	= НЕ РегистрируетОбъем;	 
		Иначе   	
			ЭлементФормы[Префикс  + "ПредыдущиеПоказания"].Видимость 	= НЕ РегистрируетОбъем;
			ЭлементФормы[Префикс  + "ТекущиеПоказания"].Видимость 		= НЕ РегистрируетОбъем;
			ЭлементФормы[Префикс  + "Переворот"].Видимость 				= НЕ РегистрируетОбъем;
			ЭлементФормы[Префикс  + "Разница"].ТолькоПросмотр			= НЕ РегистрируетОбъем;
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементФормы, Префикс  + "Группа3", "ТолькоПросмотр", Ложь);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура УдалитьЗависимыеСтрокиПоСквозномуID(Таблица,Отбор)
	
	СтрокиТЧ 	= Таблица.найтиСтроки(Отбор);
	для Каждого СтрокаТЧ из СтрокиТЧ цикл
		Таблица.удалить(СтрокаТЧ);
	КонецЦикла;   	  
	
КонецПроцедуры

Процедура ЗаполнитьТЧИзПараметров(ТабЧастьИзДокумента,Таблица)
	Для Каждого ТекСтрока из ТабЧастьИзДокумента Цикл
		НоваяСтрока = Таблица.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,ТекСтрока);
	КонецЦикла;
КонецПроцедуры

#КонецОбласти