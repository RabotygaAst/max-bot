#Область ПрограммныйИнтерфейс

// Вид дифференцированности при активации строки.
//
// Параметры:
//  ТаблицаФормы		-	ДанныеФормыКоллекция.
//  ТаблицаФормулы		-	Строка.
//  IDСтроки			-	УникальныйИдентификатор.
//  ВыводПрибораУчета	-	Булево.
//  ПостФиксКолонки		-	Строка.
//
Процедура ВидДифференцированностиПриАктивацииСтроки(ТаблицаФормы, ТаблицаФормулы, IDСтроки, ВыводПрибораУчета = Неопределено, ПостФиксКолонки = "") Экспорт 
		
	Если не ЗначениеЗаполнено(IDСтроки) тогда
		IDСтроки					= Новый УникальныйИдентификатор;
	КонецЕсли;    
	
	Если ВыводПрибораУчета <> Неопределено Тогда 
		ТаблицаФормы.ОтборСтрок		= Новый ФиксированнаяСтруктура("IDСтроки" + ПостФиксКолонки + ",ВыводПрибораУчета", IDСтроки, ВыводПрибораУчета);
	Иначе
		ТаблицаФормы.ОтборСтрок		= Новый ФиксированнаяСтруктура("IDСтроки" + ПостФиксКолонки, IDСтроки);
	КонецЕсли;
			
КонецПроцедуры

// Вид канальности при активации строки.
//
// Параметры:
//  ТаблицаФормы	-	ДанныеФормыКоллекция.
//  ПолеОтбор		-	Строка.
//  IDСтроки		-	УникальныйИдентификатор.
//
Процедура ВидКанальностиПриАктивацииСтроки(ТаблицаФормы,ПолеОтбор,IDСтроки) Экспорт 
		
	Если не ЗначениеЗаполнено(IDСтроки) тогда
		IDСтроки				= Новый УникальныйИдентификатор;
	КонецЕсли;    
	
	ТаблицаФормы.ОтборСтрок		= Новый ФиксированнаяСтруктура(ПолеОтбор, IDСтроки);
				
КонецПроцедуры

// Точка учета при активации строки.
//
// Параметры:
//  ТаблицаФормы	-	ДанныеФормыКоллекция.
//  ПолеОтбор		-	Строка.
//  IDСтроки		-	УникальныйИдентификатор.
//
Процедура ТочкаУчетаПриАктивацииСтроки(ТаблицаФормы,ПолеОтбор,IDСтроки) Экспорт 
		
	Если не ЗначениеЗаполнено(IDСтроки) тогда
		IDСтроки				= Новый УникальныйИдентификатор;
	КонецЕсли;    
	
	ТаблицаФормы.ОтборСтрок		= Новый ФиксированнаяСтруктура(ПолеОтбор, IDСтроки);
				
КонецПроцедуры

// Точка учета перед удалением.
//
// Параметры:
//  ТаблицаОбъекта	-	ДанныеФормыКоллекция.
//  ТекДанные		-	ДанныеФормыЭлементКоллекции.
//  КолонкаПоиска	-	Строка.
//
Процедура ТочкаУчетаПередУдалением(ТаблицаОбъекта,ТекДанные, КолонкаПоиска = "IDСтроки") Экспорт 
	
	СтрокиТЧ 	= ТаблицаОбъекта.найтиСтроки(Новый Структура(КолонкаПоиска,ТекДанные.IDСтроки));
	для Каждого СтрокаТЧ из СтрокиТЧ цикл
		 ТаблицаОбъекта.удалить(СтрокаТЧ);
	КонецЦикла;
	
КонецПроцедуры

// Создает наименования ТУ.
//
// Параметры:
//  ТекСтрока	-	ДанныеФормыЭлементКоллекции.
//
Процедура СозданиеНаименованияТУ(ТекСтрока) Экспорт
	ТекСтрока.НаименованиеТочки = Строка(ТекСтрока.Расположение) + "_" + Строка(ТекСтрока.Услуга);
КонецПроцедуры

// Открывает форму установки формулы.
//
// Параметры:
//  ДанныеУстановкиФормулыРасчета	-	Произвольный.
//
Процедура ОткрытьФормуУстановкиФормулы(ДанныеУстановкиФормулыРасчета) Экспорт 
	ПараметрыОтрытия  	= Новый Структура;
	ПараметрыОтрытия.Вставить("ЗаполнитьДокумент",Истина);
	Если ДанныеУстановкиФормулыРасчета.свойство("Ключ") тогда
		ПараметрыОтрытия.Вставить("Ключ",ДанныеУстановкиФормулыРасчета.ключ);
	КонецЕсли;
	ДанныеЗаполненияФормулыРасчета  = Новый Структура;
	ПараметрыОтрытия.Вставить("ЗначенияЗаполнения",ДанныеУстановкиФормулыРасчета.ДанныеЗаполнения);		
	ФормаФормулы  		= ОткрытьФорму("Документ.энргУстановитьФормулуРасчетаТочекУчета.ФормаОбъекта",ПараметрыОтрытия);
КонецПроцедуры

// При изменении вида дифференцированности.
//
// Параметры:
//  Форма				-	ФормаКлиентскогоПриложения
//  IDСтроки			-	УникальныйИдентификатор.
//  Состав				-	Массив из СправочникСсылка.энргШкалыПриборовУчета.
//  ИмяТабЧасти			-	Строка.
//  ИмяТабЧастиФормулы	-	Строка.
//  ДанныеФормы			-	Булево.
//  ВыводПрибораУчета	-	Булево.
//
Процедура ПриИзмененииВидаДифференцированности(Форма,IDСтроки,Состав,ИмяТабЧасти,ИмяТабЧастиФормулы,ДанныеФормы  = Ложь, ВыводПрибораУчета = Неопределено) Экспорт 
		
	СоотвествиеПоказаний 							= Новый Соответствие;
	
	Если не ЗначениеЗаполнено(IDСтроки) тогда
		IDСтроки 					= Новый УникальныйИдентификатор;
	КонецЕсли;
		
	Если не ДанныеФормы тогда 
		Коллекция 									= Форма.Объект[ИмяТабЧасти];
	иначе
		Коллекция 									= Форма[ИмяТабЧасти];
	КонецЕсли;
	
	// Ищем строки по индентификатору
	СтруктураПоиска  								= Новый Структура("IDСтроки",IDСтроки);
	Если ВыводПрибораУчета <> Неопределено тогда
		СтруктураПоиска.Вставить("ВыводПрибораУчета", ВыводПрибораУчета);
	КонецЕсли;
	
	СтрокиСоотвествия 								= Коллекция.НайтиСтроки(СтруктураПоиска);	
	 
	для Каждого СтрокаСоотвествия из СтрокиСоотвествия цикл
		СоотвествиеПоказаний.Вставить(СтрокаСоотвествия.ТарифнаяЗона,СтрокаСоотвествия.ТекущиеПоказания);
		Коллекция.Удалить(СтрокаСоотвествия);
	КонецЦикла;  	 
		
	для Каждого СтрокаСостава из Состав цикл		
		СтрокаПоказаний 							= Коллекция.добавить();
		СтрокаПоказаний.IDСтроки 					= IDСтроки;
		СтрокаПоказаний.ТарифнаяЗона 				= СтрокаСостава;
		Если СоотвествиеПоказаний[СтрокаСостава] <> Неопределено тогда
			СтрокаПоказаний.ТекущиеПоказания 	= СоотвествиеПоказаний[СтрокаСостава];
		КонецЕсли; 
		
		Если ВыводПрибораУчета<>Неопределено тогда
			 СтрокаПоказаний.ВыводПрибораУчета 		= ВыводПрибораУчета;
		КонецЕсли;
		
	КонецЦикла;
		 
КонецПроцедуры

// При изменении вида канальности.
//
// Параметры:
//  Форма				-	ФормаКлиентскогоПриложения.
//  IDСтроки			-	УникальныйИдентификатор.
//  Шкалы				-	Массив из СправочникСсылка.энргШкалыПриборовУчета.
//  ИмяТаблицыШкалы		-	Строка.
//  ИмяТаблицыПоказания	-	Строка.
//
Процедура ПриИзмененииВидаКанальности(Форма,IDСтроки,Шкалы,ИмяТаблицыШкалы,ИмяТаблицыПоказания) Экспорт 
		
	Если не ЗначениеЗаполнено(IDСтроки) тогда
		IDСтроки 								= Новый УникальныйИдентификатор;
	КонецЕсли;
	
	КоллекцияШкалы								= Форма.Объект[ИмяТаблицыШкалы];
	КоллекцияТарифныеЗоны						= Форма.Объект[ИмяТаблицыПоказания];
		
	// Ищем строки по индентификатору
	СтруктураПоиска  							= Новый Структура("IDСтрокиТочкиУчета",IDСтроки);
		
	СтрокиШкалыУдалить							= КоллекцияШкалы.НайтиСтроки(СтруктураПоиска);	
	 
	для Каждого СтрокаШкалаУдалить из СтрокиШкалыУдалить цикл		
		СтрокиТарифныхЗон 						= КоллекцияТарифныеЗоны.НайтиСтроки(Новый Структура("IDСтроки", СтрокаШкалаУдалить["IDСтроки"]));
		для Каждого СтрокаТарифнойЗоны из СтрокиТарифныхЗон цикл
			КоллекцияТарифныеЗоны.Удалить(СтрокаТарифнойЗоны);
		КонецЦикла;   		
		КоллекцияШкалы.Удалить(СтрокаШкалаУдалить);		
	КонецЦикла;  	 
		
	для Каждого Шкала из Шкалы цикл		
		СтрокаШкалы 							= КоллекцияШкалы.добавить();
		СтрокаШкалы["IDСтрокиТочкиУчета"]		= IDСтроки;
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаШкалы, "IDСтроки") Тогда
			СтрокаШкалы["IDСтроки"] 			= Новый УникальныйИдентификатор; 
		КонецЕсли; 		
		СтрокаШкалы.Шкала		 				= Шкала;				
	КонецЦикла;
 
КонецПроцедуры

// Открывает форму выбора направлений измерителей ТУ.
//
// Параметры:
//  Элемент				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//  Родитель			 - 	 - 
//
Процедура ОткрытьФормуВыбораНаправленийИзмерителейТУ(Элемент, СтандартнаяОбработка,Родитель = Неопределено) Экспорт
	СтандартнаяОбработка 	= Ложь;
	Если Родитель = Неопределено тогда
		ПараметрыФормы 			= Новый Структура("Отбор", Новый Структура("Родитель", ПредопределенноеЗначение("Справочник.энргНаправлениеИспользованияТочекУчета.ПустаяСсылка")));
	Иначе 
		ПараметрыФормы 			= Новый Структура("Отбор", Новый Структура("Родитель",Родитель));
	КонецЕсли;
	ОткрытьФорму("Справочник.энргНаправлениеИспользованияТочекУчета.ФормаВыбора", ПараметрыФормы, Элемент);
КонецПроцедуры

// При изменении дат действия коммерческого учета.
//
// Параметры:
//  ТекДанные				-	ДанныеФормыЭлементКоллекции.
//  НаименованиеРеквизита	-	Строка.
//
Процедура ПриИзмененииДатДействияКоммерческогоУчета(ТекДанные, НаименованиеРеквизита) Экспорт
	
	Если НЕ ТекДанные.КонецДействияКоммерскогоУчета = Дата(1,1,1) И ТекДанные.НачалоДействияКоммерскогоУчета > ТекДанные.КонецДействияКоммерскогоУчета Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Начало действия коммерческого учета не может превышать конец");
		ТекДанные[НаименованиеРеквизита] = Дата(1,1,1);
	КонецЕсли;
	
КонецПроцедуры

#Область РаботаСУзлами

// Открывает форму редактирования услуг.
//
// Параметры:
//  СтруктураВходныхДанных			-	Структура.
//  ИмяПроцедурыОписаниеЗаверешения	-	Строка.
//
Процедура ОткрытьФормуРедактированияУслуг(СтруктураВходныхДанных, ИмяПроцедурыОписаниеЗаверешения) Экспорт
	ОписаниеЗаверешения  	= Новый ОписаниеОповещения(ИмяПроцедурыОписаниеЗаверешения, ЭтотОбъект, СтруктураВходныхДанных.ДополнительныеПараметры);		
	ОткрытьФорму("Обработка.энргОперацияУзламиУчета.Форма", СтруктураВходныхДанных.ПараметрыПередачи,,,,, ОписаниеЗаверешения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
КонецПроцедуры

// Открывает форму редактирования средств измерений.
//
// Параметры:
//  СтруктураВходныхДанных			-	Структура.
//  ИмяПроцедурыОписаниеЗаверешения	-	Строка.
//  Постфикс						-	Строка.
//
Процедура ОткрытьФормуРедактированияСредствИзмерений(СтруктураВходныхДанных, ИмяПроцедурыОписаниеЗаверешения, Постфикс = "") Экспорт	
	ОписаниеЗаверешения  	= Новый ОписаниеОповещения(ИмяПроцедурыОписаниеЗаверешения, ЭтотОбъект, СтруктураВходныхДанных.ДополнительныеПараметры);		
	ОткрытьФорму("Обработка.энргОперацияУзламиУчета.Форма.ФормаСредстваИзмерения" + Постфикс, СтруктураВходныхДанных.ПараметрыПередачи,,,,, ОписаниеЗаверешения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
КонецПроцедуры

#Область ФизЛица

// Открывает форму заполнения услуг.
//
// Параметры:
//  СтруктураВходныхДанных	-	Структура.
//
Процедура ОткрытьФормуЗаполненияУслуг(СтруктураВходныхДанных) Экспорт
	ОткрытьФормуРедактированияУслуг(СтруктураВходныхДанных, "ЗавершениеРаботыСФормойЗаполненияУслуг");
КонецПроцедуры

// Открывает форму измерители направлений.
//
// Параметры:
//  СтруктураВходныхДанных	-	Структура.
//
Процедура ОткрытьФормуИзмерителиНаправлений(СтруктураВходныхДанных) Экспорт
	ОписаниеЗаверешения  	= Новый ОписаниеОповещения("ЗавершениеРаботыСФормойСредстваИзмерения", ЭтотОбъект, СтруктураВходныхДанных.ДополнительныеПараметры);		
	ОткрытьФорму("Обработка.энргОперацияУзламиУчета.Форма.ФормаСредстваИзмерения", СтруктураВходныхДанных.ПараметрыПередачи,,,,, ОписаниеЗаверешения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
КонецПроцедуры

// Открывает форму заполнения средств измерений.
//
// Параметры:
//  СтруктураВходныхДанных	-	Структура.
//  Постфикс				-	Строка.
//
Процедура ОткрытьФормуЗаполненияСредствИзмерений(СтруктураВходныхДанных, Постфикс = "") Экспорт
	ОткрытьФормуРедактированияСредствИзмерений(СтруктураВходныхДанных, "ЗавершениеРаботыСФормойЗаполненияСредствИзмерений" + Постфикс, Постфикс);
КонецПроцедуры

#Область ПолучениеВходныхДанных

// Получает входные данные для заполнения услуг.
//
// Параметры:
//  Форма	-	ФормаКлиентскогоПриложения.
// 
// Возвращаемое значение:
//   Структура	-	см. ПолучитьОбщиеВходныеДанныеДляРедактированияУслуг.
//
Функция ПолучитьВходныеДанныеДляЗаполненияУслуг(Форма) Экспорт
	ВходныеДанные = ПолучитьОбщиеВходныеДанныеДляРедактированияУслуг(Форма, "ФизЛица");
	ВходныеДанные.ДополнительныеПараметры.Вставить("СоответствиеТаблицЗаполнения", СоответствиеТаблицЗаполненияФизЛица(ВходныеДанные.ПараметрыПередачи.ВидОперации));
	энргРаботаСТочкамиУчетаСервер.ПолучитьВходныеДанныеТабЧастейУзла(ВходныеДанные.ПараметрыПередачи, ВходныеДанные.ДополнительныеПараметры.ТекущийОбъект, ВходныеДанные.ДополнительныеПараметры.СоответствиеТаблицЗаполнения);
		
	Возврат ВходныеДанные;
	
КонецФункции

// Получает входные данные для заполнения средств измерений.
//
// Параметры:
//  Форма					-	ФормаКлиентскогоПриложения.
//  ВызывающаяПодсистема	-	Строка.
//  ИмяIDСтроки				-	Строка.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ПолучитьВходныеДанныеДляЗаполненияСредствИзмерений(Форма, ВызывающаяПодсистема = "", ИмяIDСтроки = "IDСтроки") Экспорт
	ТекущийОбъект		= Форма.Объект;
	ТекущиеДанные 		= Форма.Элементы.ТочкиУчета.ТекущиеДанные;
	КлючиДанных			= энргРаботаСТочкамиУчетаСервер.ПолучитьКлючиЗаполненияСредствИзмерений();
	
	ДопВходныеПараметры = "ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета";
	СредстваИзмерений 	= Новый Структура(КлючиДанных.Реквизиты + ", ВидОперации, " + КлючиДанных.Таблицы + ", " + ДопВходныеПараметры);
	
	ЗаполнитьЗначенияСвойств(СредстваИзмерений, ТекущиеДанные	, КлючиДанных.Реквизиты);
	ЗаполнитьЗначенияСвойств(СредстваИзмерений, Форма			, ДопВходныеПараметры);
	СредстваИзмерений.Вставить("ВызывающаяПодсистема", ВызывающаяПодсистема);
	
	энргРаботаСТочкамиУчетаСервер.ДополнитьТаблицыВВходныеДанныеСредствИзмерений(ТекущийОбъект, СредстваИзмерений, ТекущиеДанные[ИмяIDСтроки]);
	
	
	ПараметрыПередачи 		= Новый Структура("ВходныеПараметры", СредстваИзмерений);
	ДополнительныеПараметры = Новый Структура("Форма, ТекущиеДанные, КлючиДанных, ИмяIDСтроки", Форма, ТекущиеДанные, КлючиДанных, ИмяIDСтроки);
	
	Возврат Новый Структура("ПараметрыПередачи, ДополнительныеПараметры", ПараметрыПередачи, ДополнительныеПараметры);
  	
КонецФункции

// Возвращает соответствие таблиц заполнения физ лица.
//
// Параметры:
//  ВидОперации	-	ПеречислениеСсылка.энргВидыОпераций.
// 
// Возвращаемое значение:
//   Структура	-	см. энргРаботаСТочкамиУчетаСервер.СоответствиеТаблицЗаполненияОбщая.
//
Функция СоответствиеТаблицЗаполненияФизЛица(ВидОперации) Экспорт
	Соответствие = энргРаботаСТочкамиУчетаСервер.СоответствиеТаблицЗаполненияОбщая(); 	
	
	Если ВидОперации = ПредопределенноеЗначение("Перечисление.энргВидыОпераций.энргОперацияСПриборомУчета_ВводПУ") Тогда
		Соответствие.ЗначенияИзмерителей 		= "";
		Соответствие.ПоставщикиСоставныхУслуг 	= "";
		Соответствие.Потери 					= ""; 		
	КонецЕсли;	
	
	Возврат Соответствие;
КонецФункции

