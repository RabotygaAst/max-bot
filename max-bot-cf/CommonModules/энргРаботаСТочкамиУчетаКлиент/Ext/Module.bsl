// Завершает работы с формой редактирования услуг.
//
// Параметры:
//  Результат				-	Структура.
//  ДополнительныеПараметры	-	ДанныеФормыСтруктура.
//
Процедура ЗавершениеРаботыСФормойРедактированияУслуг(Результат, ДополнительныеПараметры)
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийОбъект 		= ДополнительныеПараметры.Форма.Объект;//ТекущийОбъект;
	СоответствиеТаблиц 	= ДополнительныеПараметры.СоответствиеТаблицЗаполнения;
	
	Для Каждого ТекКлючЗначение из Результат Цикл
		ИмяТаблицы = СоответствиеТаблиц[ТекКлючЗначение.Ключ];
		Если НЕ ТекущийОбъект.Свойство(ИмяТаблицы) Тогда
			Продолжить;
		КонецЕсли;
		
		ТекТаблица = ТекущийОбъект[ИмяТаблицы];
		ТекТаблица.Очистить();
		
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТекКлючЗначение.Значение, ТекТаблица); 
	КонецЦикла;
	
	ДополнительныеПараметры.Форма.ТочкиУчетаПриИзменении(Неопределено); 
			
КонецПроцедуры

#КонецОбласти