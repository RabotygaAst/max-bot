//
Процедура ЗавершениеРаботыСФормойРедактированияСредствИзмеренийМКД(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 	= ДополнительныеПараметры.ТекущиеДанные;
	КлючиДанных 	= ДополнительныеПараметры.КлючиДанных;
	
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, Результат, КлючиДанных.Реквизиты, "Услуга, НаименованиеТочки");
	ЗаполнитьТекстСредствИзмерений(ТекущиеДанные, Результат);
	
	ДанныеПУ 			= энргРаботаСТочкамиУчетаСервер.ПолучитьОписаниеСтруктурыДанныхПУ();
	ПераметрыОбновления = новый Структура("Результат, ДанныеПУ, IDСтроки", Результат, ДанныеПУ, ТекущиеДанные.IDСтроки);
	
	ДополнительныеПараметры.Форма.ОбновитьДанныеПоУслугамСервер(ПераметрыОбновления);
	
	// Заполняем описание узла
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, ПераметрыОбновления.ДанныеПУ);
	ТекущиеДанные.КоэффициентПУ = Результат.КоэффициентПУ; 
	Если ТекущиеДанные.Свойство("ДатаПриемки") Тогда
		ТекущиеДанные.ДатаПриемки = ПераметрыОбновления.ДанныеПУ.ДатаВыпуска;
	КонецЕсли; 	
		
