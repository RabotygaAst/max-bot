// Получает общие входные данные для редактирования услуг.
//
// Параметры:
//  Форма					-	ФормаКлиентскогоПриложения.
//  ВызывающаяПодсистема	-	Строка.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ПолучитьОбщиеВходныеДанныеДляРедактированияУслуг(Форма, ВызывающаяПодсистема) Экспорт
	ТекущийОбъект 	= Форма.Объект;
	ВидОперации		= Неопределено;
	Организация     = Неопределено;
	Район           = Неопределено;
	КлючПомещения   = Неопределено;
	ЕстьВидОперации	= ТекущийОбъект.Свойство("ВидОперации", ВидОперации);
	ЕстьОрганизация	= ТекущийОбъект.Свойство("Организация", Организация);
	ЕстьРайон	= ТекущийОбъект.Свойство("Район", Район);
	ЕстьКлючПомещения	= ТекущийОбъект.Свойство("КлючПомещения", КлючПомещения);
	
	ДополнительныеПараметры = новый Структура;
	ДополнительныеПараметры.Вставить("Форма"			, Форма);
	ДополнительныеПараметры.Вставить("ТекущийОбъект"	, ТекущийОбъект);	
	
	КлючиПараметровПередачи				= энргРаботаСТочкамиУчетаСервер.ПолучитьКлючиЗаполненияТочекУчета();	
	ПараметрыПередачи 					= Новый Структура(КлючиПараметровПередачи.Реквизиты + ", " + КлючиПараметровПередачи.Таблицы);
	ПараметрыПередачи.ЗаполнитьФорму 	= Истина;
	ПараметрыПередачи.Вставить("ВидОперации"			, ВидОперации);
	ПараметрыПередачи.Вставить("ВызывающаяПодсистема"	, ВызывающаяПодсистема);
	ПараметрыПередачи.Вставить("ИдентификаторФормы"		, Форма.УникальныйИдентификатор);
	ПараметрыПередачи.Вставить("Организация"			, Организация);
	ПараметрыПередачи.Вставить("Район"			        , Район);
	ПараметрыПередачи.Вставить("КлючПомещения"			, КлючПомещения);
		
	Возврат Новый Структура("ПараметрыПередачи, ДополнительныеПараметры", ПараметрыПередачи, ДополнительныеПараметры);
КонецФункции

// Получает общие входные данные для редактирования средств измерений.
//
// Параметры:
//  Форма	-	ФормаКлиентскогоПриложения.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ПолучитьОбщиеВходныеДанныеДляРедактированияСредствИзмерений(Форма) Экспорт
	ТекущийОбъект		= Форма.Объект;
	ТекущиеДанные 		= Форма.Элементы.ТочкиУчета.ТекущиеДанные;
	КлючиДанных			= энргРаботаСТочкамиУчетаСервер.ПолучитьКлючиЗаполненияСредствИзмерений();
	
	ДопВходныеПараметры = "ИспользоватьТарифныеЗоны, ИспользоватьШкалыПриборовУчета";
	СредстваИзмерений 	= Новый Структура(КлючиДанных.Реквизиты + ", ВидОперации, " + КлючиДанных.Таблицы + ", " + ДопВходныеПараметры);
	
	ЗаполнитьЗначенияСвойств(СредстваИзмерений, ТекущиеДанные	, КлючиДанных.Реквизиты);
	ЗаполнитьЗначенияСвойств(СредстваИзмерений, Форма			, ДопВходныеПараметры);
	
	энргРаботаСТочкамиУчетаСервер.ДополнитьТаблицыВВходныеДанныеСредствИзмерений(ТекущийОбъект, СредстваИзмерений, ТекущиеДанные.IDСтроки);
	
	Возврат Новый Структура("ПараметрыПередачи,ДополнительныеПараметры", Новый Структура("ВходныеПараметры", СредстваИзмерений), Новый Структура("Форма, ТекущиеДанные, КлючиДанных", Форма, ТекущиеДанные, КлючиДанных));
  	
КонецФункции

#КонецОбласти

#Область ОбщиеМетодыОбработкиРезультатов

#Область ВспомогательныеМетоды

// Заполняет текст данные услуги.
//
// Параметры:
//  Результат					-	Структура.
//  ПоставщикиСоставныхУслуг	-	Структура.
// 
// Возвращаемое значение:
//   Строка.
//
Функция ЗаполнитьТекстДанныеУслуги(Результат, ПоставщикиСоставныхУслуг) Экспорт
	СтруктураДанных = энргРаботаСТочкамиУчетаСервер.ПолучитьСтруктуруДанныхУслуги();
	ЗаполнитьЗначенияСвойств(СтруктураДанных, Результат);
	
	Если Результат.ЭтоСоставнаяУслуга Тогда
		ПредставлениеПоставщика  								= "";
		СтрокиТЧ 	= ПоставщикиСоставныхУслуг.НайтиСтроки(Новый Структура("IDСтроки",Результат.IDСтроки));
		Для Каждого Строка Из СтрокиТЧ Цикл
			Представление = Строка.Поставщик;
			ПредставлениеПоставщика 							= ПредставлениеПоставщика + ?(ЗначениеЗаполнено(ПредставлениеПоставщика),"/","") + Представление;
		КонецЦикла;
		Поставщик = ПредставлениеПоставщика;
	КонецЕсли;
	
	Возврат энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстДанныеУслуги(СтруктураДанных, Поставщик); 	
КонецФункции

// Заполняет текст данные расположения.
//
// Параметры:
//  Результат	-	Структура.
// 
// Возвращаемое значение:
//   Строка.
//
Функция ЗаполнитьТекстДанныеРасположения(Результат) Экспорт
	СтруктураДанных = энргРаботаСТочкамиУчетаСервер.ПолучитьСтруктуруДанныеРасположения();
	ЗаполнитьЗначенияСвойств(СтруктураДанных, Результат);
	Возврат энргРаботаСТочкамиУчетаСервер.ЗаполнитьТекстДанныеРасположения(СтруктураДанных);
