//   Структура	-	см. ПолучитьОбщиеВходныеДанныеДляРедактированияУслуг.
//
Функция ПолучитьВходныеДанныеДляЗаполненияУслугМКД(Форма) Экспорт
	Попытка
		ПризнакРаспределенияНаАбонентов = Форма.ПризнакРаспределенияНаАбонентов;
	Исключение
		ПризнакРаспределенияНаАбонентов = Ложь;
	КонецПопытки;
	
	ВходныеДанные = ПолучитьОбщиеВходныеДанныеДляРедактированияУслуг(Форма, "МКД");
	ВходныеДанные.ПараметрыПередачи.Вставить("ПризнакРаспределенияНаАбонентов", ПризнакРаспределенияНаАбонентов);	
	ВходныеДанные.ДополнительныеПараметры.Вставить("СоответствиеТаблицЗаполнения", энргРаботаСТочкамиУчетаСервер.СоответствиеТаблицЗаполненияМКД(ВходныеДанные.ПараметрыПередачи.ВидОперации));
	энргРаботаСТочкамиУчетаСервер.ПолучитьВходныеДанныеТабЧастейУзла(ВходныеДанные.ПараметрыПередачи, ВходныеДанные.ДополнительныеПараметры.ТекущийОбъект, ВходныеДанные.ДополнительныеПараметры.СоответствиеТаблицЗаполнения);
			
	Возврат ВходныеДанные;
КонецФункции

