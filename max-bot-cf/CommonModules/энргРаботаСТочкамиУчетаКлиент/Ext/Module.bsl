// Завершение работы с формой заполнения услуг.
//
// Параметры:
//  Результат				-	Структура.
//  ДополнительныеПараметры	-	ДанныеФормыСтруктура.
//
Процедура ЗавершениеРаботыСФормойЗаполненияУслуг(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Форма			= ДополнительныеПараметры.Форма;
	ТекущийОбъект 	= Форма.Объект;//ДополнительныеПараметры.ТекущийОбъект; 	
	
	Для Каждого ТекКлючЗначение из Результат Цикл
		Если НЕ ТекущийОбъект.Свойство(ТекКлючЗначение.Ключ) Тогда
			Продолжить;
		КонецЕсли;
		
		ТекТаблица = ТекущийОбъект[ТекКлючЗначение.Ключ];
		ТекТаблица.Очистить();
		
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТекКлючЗначение.Значение, ТекТаблица); 
	КонецЦикла;
	
	Форма.ОбновитьДанныеПоУслугам();
		
КонецПроцедуры

// Завершение работы с формой заполнения средств измерений.
//
// Параметры:
//  Результат				-	Структура.
//  ДополнительныеПараметры	-	ДанныеФормыСтруктура.
//
Процедура ЗавершениеРаботыСФормойЗаполненияСредствИзмерений(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 	= ДополнительныеПараметры.ТекущиеДанные;
	КлючиДанных 	= ДополнительныеПараметры.КлючиДанных;
	
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, Результат, КлючиДанных.Реквизиты, "Услуга, НаименованиеТочки");
	ЗаполнитьТекстСредствИзмерений(ТекущиеДанные, Результат);
	
	ДанныеПУ 			= энргРаботаСТочкамиУчетаСервер.ПолучитьОписаниеСтруктурыДанныхПУ();
	ПераметрыОбновления = новый Структура("Результат, ДанныеПУ, IDСтроки", Результат, ДанныеПУ, ТекущиеДанные.IDСтроки);
	
	ДополнительныеПараметры.Форма.ОбновитьДанныеПоУслугамСервер(ПераметрыОбновления);
	
	// Заполняем описание узла
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, ПераметрыОбновления.ДанныеПУ);
	ТекущиеДанные.КоэффициентПУ = Результат.КоэффициентПУ; 
	Если ТекущиеДанные.Свойство("ДатаПриемки") Тогда
		ТекущиеДанные.ДатаПриемки = ПераметрыОбновления.ДанныеПУ.ДатаВыпуска;
	КонецЕсли; 	
		
КонецПроцедуры

// Завершение работы с формой заполнения средств измерений вывод.
//
// Параметры:
//  Результат				-	Структура.
//  ДополнительныеПараметры	-	ДанныеФормыСтруктура.
//
Процедура ЗавершениеРаботыСФормойЗаполненияСредствИзмеренийВывод(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 	= ДополнительныеПараметры.ТекущиеДанные;
	КлючиДанных 	= ДополнительныеПараметры.КлючиДанных;
	ИмяIDСтроки 	= ДополнительныеПараметры.ИмяIDСтроки;
	
	ДанныеПУ 			= энргРаботаСТочкамиУчетаСервер.ПолучитьОписаниеСтруктурыДанныхПУ();
	ПераметрыОбновления = новый Структура("Результат, ДанныеПУ, IDСтроки", Результат, ДанныеПУ, ТекущиеДанные[ИмяIDСтроки]);
	
	ДополнительныеПараметры.Форма.ОбновитьДанныеПоУслугамСерверВывод(ПераметрыОбновления);
	
