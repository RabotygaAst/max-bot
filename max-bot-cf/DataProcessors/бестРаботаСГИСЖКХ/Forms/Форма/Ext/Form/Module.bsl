	               |	бестВыгруженныеЖДГИСЖКХСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)";
	
	Результат 		= Запрос.Выполнить();
	Выгрузка		= Результат.Выбрать();
	
	Пока Выгрузка.Следующий() Цикл
		Запись = РегистрыСведений.бестВыгруженныеЖДГИСЖКХ.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Выгрузка);
		Если стр.Статус = "ОК" Тогда
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ЗагруженоВГИСЖКХ;
		Иначе
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ОшибкаПриЗагрузкеВГИСЖХК;
			Запись.ОписаниеОшибки = Выгрузка.Статус;
		КонецЕсли;
		Запись.Записать();
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка данных об ЖД завершена!");
	
КонецПроцедуры	

#КонецОбласти

#Область ЛицевыеСчета

&НаКлиенте
Процедура ВыгрузкаЛицевыхСчетовКлиент()
	//  11.13.0.5
	НомерСтраницы = 1;
	
	ExcelApp = Новый COMОбъект("Excel.Application");
	ExcelApp.DisplayAlerts = False;
	Попытка
		Книга = ExcelApp.Workbooks.Open(Файл);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
		Возврат;
	КонецПопытки; 
	
	НомерСтроки 			= 3;	
	Страница 				= Книга.Worksheets(1);
	СчетчикДляИмениФайла 	= 1;
	
	ФайлДляЗаписи 			= Файл;
	ИмяФайла 				= Лев(ФайлДляЗаписи, Найти(ФайлДляЗаписи , ".xlsx")-1) + "_";		
	МассивЛС				= ВыгрузкаЛицевыхСчетовСервер();
	
	Для элмас = 0 по МассивЛС.Количество()-1 Цикл
		Страница 					= Книга.Worksheets(1);
		Если НомерСтроки 			= 50003 тогда 	   
			ФайлНовый = ИмяФайла + СчетчикДляИмениФайла + ".xlsx";
			КопироватьФайл(ФайлДляЗаписи , ФайлНовый);  
			Книга.SaveAs(ФайлДляЗаписи);
			ExcelApp.Quit();
			
			ExcelApp = Новый COMОбъект("Excel.Application");
			ExcelApp.DisplayAlerts = False;
			Попытка	
				Книга = ExcelApp.Workbooks.Open(ФайлНовый);	
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
				Возврат;
			КонецПопытки; 
			
			НомерСтроки 	=3;
			Страница = Книга.Worksheets(1);
			СчетчикДляИмениФайла = СчетчикДляИмениФайла+1;
			ФайлДляЗаписи = ФайлНовый;
			
		КонецЕсли;			
		
		// Основные сведения
		Страница.Cells(НомерСтроки,1).value 	= НомерСтроки-2;
		Страница.Cells(НомерСтроки,2).value 	= МассивЛС[элмас].ЛС;		
		Страница.Cells(НомерСтроки,3).value 	= МассивЛС[элмас].ИдентификаторЖКУ;
		Страница.Cells(НомерСтроки,4).value 	= "ЛС РСО";
		Страница.Cells(НомерСтроки,5).value 	= "Нет";
		Страница.Cells(НомерСтроки,6).value 	= "Нет";
		Страница.Cells(НомерСтроки,7).value 	= МассивЛС[элмас].Фамилия;
		Страница.Cells(НомерСтроки,8).value 	= МассивЛС[элмас].Имя;
		Страница.Cells(НомерСтроки,9).value 	= МассивЛС[элмас].Отчество;
		Страница.Cells(НомерСтроки,18).value 	= МассивЛС[элмас].ОтапливаемаяПлощадь;
		Страница.Cells(НомерСтроки,19).value 	= МассивЛС[элмас].ЖилаяПлощадь;
		Страница.Cells(НомерСтроки,20).value 	= МассивЛС[элмас].ОтапливаемаяПлощадь;	
		Страница.Cells(НомерСтроки,21).value 	= МассивЛС[элмас].КоличествоПроживающих;	
		
		// Помещения
		Страница = Книга.Worksheets(2);
		Страница.Cells(НомерСтроки,1).value 	= НомерСтроки-2;  
		Страница.Cells(НомерСтроки,2).value 	= МассивЛС[элмас].АдресПомещения;
		Страница.Cells(НомерСтроки,3).value 	= Строка(МассивЛС[элмас].ФИАС);
		Страница.Cells(НомерСтроки,4).value 	= МассивЛС[элмас].ВидПомещения;
		Страница.Cells(НомерСтроки,5).value 	= МассивЛС[элмас].НомерПомещения;
		
		//Основания
		Страница = Книга.Worksheets(3);
		Страница.Cells(НомерСтроки,1).value 	= НомерСтроки-2;  
		Страница.Cells(НомерСтроки,2).value 	= "Договор ресурсоснабжения (ЛС РСО или ЛС РЦ)";
		Страница.Cells(НомерСтроки,3).value 	= МассивЛС[элмас].ИдентификаторДоговора;
		
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	Книга.SaveAs(ФайлДляЗаписи);
	ExcelApp.Quit();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка лицевых счетов завершена " + ТекущаяДата());
	
	Возврат;	
КонецПроцедуры

&НаСервере
Функция ВыгрузкаЛицевыхСчетовСервер()
	Запрос = Новый Запрос;	
	ЗАпрос.Текст = ПолучитьТекстЗапросаВыгрузкиЛС();
	
	Запрос.УстановитьПараметр("Дата", 			ПериодВыгрузки);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("ПустойИдентификатор", Новый УникальныйИдентификатор); // выгружаем только уже принятые договоры ГИС ЖКХ
	
	мВидыПлощади = Новый Массив;
	мВидыПлощади.Добавить(Перечисления.энргВидыПлощадей.ЖилаяПлощадь);
	мВидыПлощади.Добавить(Перечисления.энргВидыПлощадей.ОбщаяПлощадь);	
	Запрос.УстановитьПараметр("ВидыПлощади",мВидыПлощади);
	
	Результат 			= Запрос.Выполнить();		
	Выборка 			= Результат.Выбрать();
	
	МассивСтруктур		= Новый Массив; 
	Пока Выборка.Следующий() Цикл
		Структура   	= Новый Структура;
		
		// Основные сведения
		Структура.Вставить("ЛС", 					СокрЛП(Выборка.ЛицевойСчет));
		Структура.Вставить("ИдентификаторЖКУ",		Выборка.ИдентификаторЖКУ);
		Структура.Вставить("Фамилия", 				Выборка.Фамилия);
		Структура.Вставить("Имя", 					Выборка.Имя);
		Структура.Вставить("Отчество", 				Выборка.Отчество);	
		Структура.Вставить("ЖилаяПлощадь", 			Выборка.ЖилаяПлощадь);
		Структура.Вставить("ОтапливаемаяПлощадь", 	Выборка.ОтапливаемаяПлощадь);
		Структура.Вставить("КоличествоПроживающих",	Выборка.КоличествоПроживающих);
		//======================================================================================================================
		// Помещения
		Структура.Вставить("АдресПомещения", 		Выборка.АдресОЖФ);
		Структура.Вставить("ФИАС",					Выборка.ФИАС);
		Структура.Вставить("ВидПомещения", 			Строка(Выборка.ВидПомещения));
		Структура.Вставить("НомерПомещения", 		Выборка.НомерПомещения);
		//======================================================================================================================	
		// Основания
		Структура.Вставить("ИдентификаторДоговора",	Выборка.ИдентификаторДоговораГИСЖКХ);	
		
		МассивСтруктур.Добавить(Структура);
	КонецЦикла;
	
	Возврат МассивСтруктур;	
КонецФункции

&НаСервере
Функция ПолучитьТекстЗапросаВыгрузкиЛС()
	Возврат "ВЫБРАТЬ
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.Абонент КАК Абонент,
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.Абонент.ЛицевойСчет КАК ЛицевойСчет,
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУ,
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.Абонент.ФизЛицо.бестФамилия КАК Фамилия,
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.Абонент.ФизЛицо.бестИмя КАК Имя,
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.Абонент.ФизЛицо.бестОтчество КАК Отчество,
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.ФИАС КАК ФИАС,
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.ВидПомещения КАК ВидПомещения,
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.НомерПомещения КАК НомерПомещения
	        |ПОМЕСТИТЬ ВТ_АбонентыКВыгрузке
	        |ИЗ
	        |	РегистрСведений.бестВыгруженныеЛСГИСЖКХ.СрезПоследних(
	        |			&Дата,
	        |			Организация = &Организация
	        |				И Район = &Район) КАК бестВыгруженныеЛСГИСЖКХСрезПоследних
	        |ГДЕ
	        |	бестВыгруженныеЛСГИСЖКХСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	энргИдентификаторыАбонентаГИСЖКХ.Абонент КАК Абонент,
	        |	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ
	        |ПОМЕСТИТЬ ВТ_Идентификаторы
	        |ИЗ
	        |	РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
	        |ГДЕ
	        |	энргИдентификаторыАбонентаГИСЖКХ.Абонент В
	        |			(ВЫБРАТЬ
	        |				ВТ.Абонент
	        |			ИЗ
	        |				ВТ_АбонентыКВыгрузке КАК ВТ)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	СУММА(ВЫБОР
	        |			КОГДА энргЗначенияПлощадейСрезПоследних.ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ЖилаяПлощадь)
	        |				ТОГДА энргЗначенияПлощадейСрезПоследних.Площадь
	        |			ИНАЧЕ 0
	        |		КОНЕЦ) КАК ЖилаяПлощадь,
	        |	СУММА(ВЫБОР
	        |			КОГДА энргЗначенияПлощадейСрезПоследних.ВидПлощади = ЗНАЧЕНИЕ(Перечисление.энргВидыПлощадей.ОбщаяПлощадь)
	        |				ТОГДА энргЗначенияПлощадейСрезПоследних.Площадь
	        |			ИНАЧЕ 0
	        |		КОНЕЦ) КАК ОтапливаемаяПлощадь,
	        |	СУММА(ЕСТЬNULL(энргКоличествоПроживающихСрезПоследних.Количество, 0)) КАК КоличествоПроживающих,
	        |	ВТ_АбонентыКВыгрузке.ЛицевойСчет КАК ЛицевойСчет,
	        |	ВТ_АбонентыКВыгрузке.ИдентификаторЖКУ КАК ИдентификаторЖКУ,
	        |	ВТ_АбонентыКВыгрузке.Фамилия КАК Фамилия,
	        |	ВТ_АбонентыКВыгрузке.Имя КАК Имя,
	        |	ВТ_АбонентыКВыгрузке.Отчество КАК Отчество,
	        |	ВТ_АбонентыКВыгрузке.ФИАС КАК ФИАС,
	        |	ВТ_АбонентыКВыгрузке.АдресОЖФ КАК АдресОЖФ,
	        |	ВТ_АбонентыКВыгрузке.ВидПомещения КАК ВидПомещения,
	        |	ВТ_АбонентыКВыгрузке.НомерПомещения КАК НомерПомещения,
	        |	ВТ_Идентификаторы.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ
	        |ИЗ
	        |	ВТ_АбонентыКВыгрузке КАК ВТ_АбонентыКВыгрузке
	        |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргЗначенияПлощадей.СрезПоследних(
	        |				&Дата,
	        |				(Организация, Район, Абонент) В
	        |						(ВЫБРАТЬ
	        |							&Организация КАК Организация,
	        |							&Район КАК Район,
	        |							ВТ_АбонентыКВыгрузке.Абонент КАК Абонент
	        |						ИЗ
	        |							ВТ_АбонентыКВыгрузке КАК ВТ_АбонентыКВыгрузке)
	        |					И ВидПлощади В (&ВидыПлощади)) КАК энргЗначенияПлощадейСрезПоследних
	        |		ПО ВТ_АбонентыКВыгрузке.Абонент = энргЗначенияПлощадейСрезПоследних.Абонент
	        |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргКоличествоПроживающих.СрезПоследних(
	        |				&Дата,
	        |				(Организация, Район, Абонент) В
	        |					(ВЫБРАТЬ
	        |						&Организация КАК Организация,
	        |						&Район КАК Район,
	        |						ВТ_АбонентыКВыгрузке.Абонент КАК Абонент
	        |					ИЗ
	        |						ВТ_АбонентыКВыгрузке КАК ВТ_АбонентыКВыгрузке)) КАК энргКоличествоПроживающихСрезПоследних
	        |		ПО ВТ_АбонентыКВыгрузке.Абонент = энргКоличествоПроживающихСрезПоследних.Абонент
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Идентификаторы КАК ВТ_Идентификаторы
	        |		ПО ВТ_АбонентыКВыгрузке.Абонент = ВТ_Идентификаторы.Абонент
	        |			И (ВТ_Идентификаторы.ИдентификаторДоговораГИСЖКХ <> """")
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ВТ_АбонентыКВыгрузке.Абонент,
	        |	ВТ_АбонентыКВыгрузке.ЛицевойСчет,
	        |	ВТ_АбонентыКВыгрузке.ИдентификаторЖКУ,
	        |	ВТ_АбонентыКВыгрузке.Фамилия,
	        |	ВТ_АбонентыКВыгрузке.Имя,
	        |	ВТ_АбонентыКВыгрузке.Отчество,
	        |	ВТ_АбонентыКВыгрузке.ФИАС,
	        |	ВТ_АбонентыКВыгрузке.АдресОЖФ,
	        |	ВТ_АбонентыКВыгрузке.ВидПомещения,
	        |	ВТ_АбонентыКВыгрузке.НомерПомещения,
	        |	ВТ_Идентификаторы.ИдентификаторДоговораГИСЖКХ";
КонецФункции

&НаКлиенте
Процедура ЗагрузкаОтветаПоЛСКлиент()
	НайденныеФайлы = НайтиФайлы(КаталогЗагрузки, "*.xlsx");
	
	ДанныеФайлов  = Новый Структура;
	
	Попытка
		СерверExcel 					= Новый COMОбъект("Excel.Application");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приложение excel не установлено");
		Возврат;
	КонецПопытки;
	
	СерверExcel.DisplayAlerts 			= 0;
	
	Для н =0 по НайденныеФайлы.Количество() - 1 Цикл
		
		ФайлХЛС			= СерверExcel.Application.Workbooks.Open(НайденныеФайлы[н].ПолноеИмя);
		
		ЛистЭксель		= ФайлХЛС.Sheets(1); // ЛС
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область			= СерверExcel.Range(ЛистЭксель.Cells(3,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));
		Страница1Книги	= Область.Value.Выгрузить();
		
		ФайлХЛС.close();
		
		ДанныеФайлов.Вставить("Файл" + СтрЗаменить(н, Символы.НПП,""),Страница1Книги);
		
	КонецЦикла;
	
	СерверExcel.quit();
	ЗагрузитьОтветПоВсемЛС(ДанныеФайлов);
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоВсемЛС(ДанныеФайлов)
	Для каждого стр из ДанныеФайлов Цикл
		ЗагрузитьОтветПоЛС(стр.Значение);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоЛС(ЛС)
	СоотвествиеКолонок  = Новый Соответствие;
	СоотвествиеКолонок.Вставить("ЛС", 						2-1);
	СоотвествиеКолонок.Вставить("ИдентификаторЖКУГИСЖКХ",	3-1);
	//СоотвествиеКолонок.Вставить("ИдентификаторЖКУГИСЖКХ",	22-1);
	СоотвествиеКолонок.Вставить("Статус",	23-1);
	
	ТЗ  = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("ЛС",						Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(18,ДопустимаяДлина.Фиксированная)));
	ТЗ.Колонки.Добавить("ИдентификаторЖКУГИСЖКХ",	Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(36)));
	ТЗ.Колонки.Добавить("Статус",					Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	ВсегоСтрок  = ЛС[0].количество()-1;
	Для Счетчик = 1 По ВсегоСтрок Цикл
		НоваяСтрока = ТЗ.Добавить();
	КонецЦикла;
	
	Для Каждого стр из СоотвествиеКолонок Цикл 
		ТЗ.ЗагрузитьКолонку(ЛС[стр.Значение], стр.Ключ);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Таблица", 	ТЗ);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("Дата", 		ПериодЗагрузки);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.ЛС КАК ЛС,
	|	Таблица.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	Таблица.Статус КАК Статус
	|ПОМЕСТИТЬ ВрТ0
	|ИЗ
	|	&Таблица КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВрТ0.ЛС КАК ЛС,
	|	ВрТ0.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	ВрТ0.Статус КАК Статус,
	|	энргАбоненты.Ссылка КАК Абонент
	|ПОМЕСТИТЬ ВТ_Абоненты
	|ИЗ
	|	ВрТ0 КАК ВрТ0
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|		ПО (энргАбоненты.ЛицевойСчет ПОДОБНО """" + ВрТ0.ЛС + ""%"")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВыгруженныеЛСГИСЖКХСрезПоследних.Период КАК Период,
	|	бестВыгруженныеЛСГИСЖКХСрезПоследних.Организация КАК Организация,
	|	бестВыгруженныеЛСГИСЖКХСрезПоследних.Район КАК Район,
	|	бестВыгруженныеЛСГИСЖКХСрезПоследних.Абонент КАК Абонент,
	|	бестВыгруженныеЛСГИСЖКХСрезПоследних.ВидПомещения КАК ВидПомещения,
	|	бестВыгруженныеЛСГИСЖКХСрезПоследних.ФИАС КАК ФИАС,
	|	бестВыгруженныеЛСГИСЖКХСрезПоследних.НомерПомещения КАК НомерПомещения,
	|	бестВыгруженныеЛСГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	|	ВТ_Абоненты.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	ВТ_Абоненты.Статус КАК Статус
	|ИЗ
	|	ВТ_Абоненты КАК ВТ_Абоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестВыгруженныеЛСГИСЖКХ.СрезПоследних(
	|				&Дата,
	|				Организация = &Организация
	|					И Район = &Район
	|					И Абонент В
	|						(ВЫБРАТЬ
	|							ВТ.Абонент
	|						ИЗ
	|							ВТ_Абоненты КАК ВТ)) КАК бестВыгруженныеЛСГИСЖКХСрезПоследних
	|		ПО ВТ_Абоненты.Абонент = бестВыгруженныеЛСГИСЖКХСрезПоследних.Абонент
	|ГДЕ
	|	бестВыгруженныеЛСГИСЖКХСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)";
	
	Результат 		= Запрос.Выполнить();
	Выгрузка		= Результат.Выбрать();
	
	Пока Выгрузка.Следующий() Цикл
		Запись = РегистрыСведений.бестВыгруженныеЛСГИСЖКХ.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Выгрузка);
		Если Выгрузка.Статус = "ОК" Тогда
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ЗагруженоВГИСЖКХ;
		Иначе
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ОшибкаПриЗагрузкеВГИСЖХК;
			Запись.ОписаниеОшибки = Выгрузка.Статус;
		КонецЕсли;
		Запись.Записать();
		
		Если ЗначениеЗаполнено(Выгрузка.ИдентификаторЖКУГИСЖКХ) Тогда
			НаборЗаписей = РегистрыСведений.энргИдентификаторыАбонентаГИСЖКХ.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Абонент.Установить(Выгрузка.Абонент);
			НаборЗаписей.Прочитать();
			Если НаборЗаписей.Количество() > 0 Тогда
				Запись = НаборЗаписей[0];
			Иначе 
				Запись = НаборЗаписей.Добавить();
				Запись.Абонент = Выгрузка.Абонент;
			КонецЕсли;
			Запись.ИдентификаторЖКУГИСЖКХ = Выгрузка.ИдентификаторЖКУГИСЖКХ;
			НаборЗаписей.Записать();
		КонецЕсли;
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка данных о ЛС завершена!");
	
КонецПроцедуры	

#КонецОбласти

#Область ОЖФ

&НаКлиенте
Процедура ЗагрузкаОЖФКлиент()
	НайденныеФайлы = НайтиФайлы(КаталогЗагрузки, "*.xlsx");
	
	ДанныеФайлов  = Новый Структура;
	
	Попытка
		СерверExcel 					= Новый COMОбъект("Excel.Application");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приложение excel не установлено");
		Возврат;
	КонецПопытки;
	
	СерверExcel.DisplayAlerts 			= 0;
	
	Для н =0 по НайденныеФайлы.Количество() - 1 Цикл
		
		ФайлХЛС			= СерверExcel.Application.Workbooks.Open(НайденныеФайлы[н].ПолноеИмя);
		
		ЛистЭксель		= ФайлХЛС.Sheets(1); // ЛС
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область			= СерверExcel.Range(ЛистЭксель.Cells(3,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));
		Страница1Книги	= Область.Value.Выгрузить();
		
		ФайлХЛС.close();
		
		ДанныеФайлов.Вставить("Файл" + СтрЗаменить(н, Символы.НПП,""),Страница1Книги);
		
	КонецЦикла;
	
	СерверExcel.quit();
	ЗагрузитьОтветПоВсемОЖФ(ДанныеФайлов);
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоВсемОЖФ(ДанныеФайлов)
	Для каждого стр из ДанныеФайлов Цикл
		ЗагрузитьОтветПоОЖФ(стр.Значение);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоОЖФ(ОЖФ)
	СоотвествиеКолонок  = Новый Соответствие;
	СоотвествиеКолонок.Вставить("ИдентификаторДоговораГИСЖКХ",	1-1);
	СоотвествиеКолонок.Вставить("УникальныйНомерДома",			7-1);
	СоотвествиеКолонок.Вставить("УникальныйНомерПомещения",		8-1);
	
	ТЗ  = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("ИдентификаторДоговораГИСЖКХ",	Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(36)));
	ТЗ.Колонки.Добавить("УникальныйНомерДома",			Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	ТЗ.Колонки.Добавить("УникальныйНомерПомещения",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	
	ВсегоСтрок  = ОЖФ[0].количество()-1;
	Для Счетчик = 1 По ВсегоСтрок Цикл
		НоваяСтрока = ТЗ.Добавить();
	КонецЦикла;
	
	Для Каждого стр из СоотвествиеКолонок Цикл 
		ТЗ.ЗагрузитьКолонку(ОЖФ[стр.Значение], стр.Ключ);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Таблица", 	ТЗ);
	Запрос.УстановитьПараметр("Дата", 		ПериодЗагрузки);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ,
	|	Таблица.УникальныйНомерДома КАК УникальныйНомерДома,
	|	Таблица.УникальныйНомерПомещения КАК УникальныйНомерПомещения
	|ПОМЕСТИТЬ ВрТ0
	|ИЗ
	|	&Таблица КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргИдентификаторыАбонентаГИСЖКХ.Абонент КАК Абонент,
	|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ,
	|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторДомаФИАС КАК ИдентификаторДомаФИАС,
	|	энргИдентификаторыАбонентаГИСЖКХ.ОКТМО КАК ОКТМО,
	|	ВрТ0.УникальныйНомерДома КАК УникальныйНомерДома,
	|	ВрТ0.УникальныйНомерПомещения КАК УникальныйНомерПомещения,
	|	ВрТ0.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ1,
	|	энргИдентификаторыАбонентаГИСЖКХ.Абонент.МКД КАК МКД
	|ИЗ
	|	ВрТ0 КАК ВрТ0
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
	|		ПО (энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторДоговораГИСЖКХ = ВрТ0.ИдентификаторДоговораГИСЖКХ)";
	
	Результат 		= Запрос.Выполнить();
	Выгрузка		= Результат.Выбрать();
	
	Пока Выгрузка.Следующий() Цикл
		Если Не ЗначениеЗаполнено(Выгрузка.Абонент) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден Абонент с идентификатором договора ГИС ЖКХ """ + Выгрузка.ИдентификаторДоговораГИСЖКХ1 + """");	
			Продолжить;
		КонецЕсли;
		
		НаборЗаписей = РегистрыСведений.энргИдентификаторыАбонентаГИСЖКХ.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Абонент.Установить(Выгрузка.Абонент);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() > 0 Тогда
			Запись = НаборЗаписей[0];
		Иначе 
			Запись = НаборЗаписей.Добавить();
			Запись.Абонент = Выгрузка.Абонент;
		КонецЕсли;
		Запись.УникальныйНомерДома		= Выгрузка.УникальныйНомерДома;
		Запись.УникальныйНомерПомещения	= Выгрузка.УникальныйНомерПомещения;
		НаборЗаписей.Записать();
		
		Если ЗначениеЗаполнено(Выгрузка.МКД) Тогда
			
			НаборЗаписей = РегистрыСведений.энргИдентификаторыМКДГИСЖКХ.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.МКД.Установить(Выгрузка.МКД);
			НаборЗаписей.Прочитать();
			Если НаборЗаписей.Количество() > 0 Тогда
				Запись = НаборЗаписей[0];
			Иначе 
				Запись = НаборЗаписей.Добавить();
				Запись.МКД = Выгрузка.МКД;
			КонецЕсли;
			Запись.УникальныйНомерДома		= Выгрузка.УникальныйНомерДома;
			НаборЗаписей.Записать();	
		КонецЕсли;
		
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка данных об ОЖФ договоров завершена!");
	
КонецПроцедуры	
#КонецОбласти

#Область ЗакрытиеЛицевыхСчетов

&НаКлиенте
Процедура ВыгрузкаЗакрытиеЛицевыхСчетовКлиент()
	//  11.11.0.17
	НомерСтраницы = 1;
	
	ExcelApp = Новый COMОбъект("Excel.Application");
	ExcelApp.DisplayAlerts = False;
	Попытка
		Книга = ExcelApp.Workbooks.Open(Файл);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
		Возврат;
	КонецПопытки; 
	
	НомерСтроки 			= 2;	
	Страница 				= Книга.Worksheets(1);
	СчетчикДляИмениФайла 	= 1;
	
	ФайлДляЗаписи 			= Файл;
	ИмяФайла 				= Лев(ФайлДляЗаписи, Найти(ФайлДляЗаписи , ".xlsx")-1) + "_";		
	МассивЛС				= ВыгрузкаЗакрытиеЛицевыхСчетовСервер();
	
	Для Каждого ТекЛС Из МассивЛС Цикл
		Страница 					= Книга.Worksheets(1);
		Если НомерСтроки 			= 5003 тогда 	   
			ФайлНовый = ИмяФайла + СчетчикДляИмениФайла + ".xlsx";
			КопироватьФайл(ФайлДляЗаписи , ФайлНовый);  
			Книга.SaveAs(ФайлДляЗаписи);
			ExcelApp.Quit();
			
			ExcelApp = Новый COMОбъект("Excel.Application");
			ExcelApp.DisplayAlerts = False;
			Попытка	
				Книга = ExcelApp.Workbooks.Open(ФайлНовый);	
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
				Возврат;
			КонецПопытки; 
			
			НомерСтроки 	=2;
			Страница = Книга.Worksheets(1);
			СчетчикДляИмениФайла = СчетчикДляИмениФайла+1;
			ФайлДляЗаписи = ФайлНовый;
			
		КонецЕсли;			
		
		Страница.Cells(НомерСтроки,1).value 	= ТекЛС.ЛицевойСчет;
		Страница.Cells(НомерСтроки,2).value 	= ТекЛС.ИдентификаторЖКУГИСЖКХ;		
		Страница.Cells(НомерСтроки,3).value 	= ТекЛС.АдресОЖФ;
		Страница.Cells(НомерСтроки,4).value 	= ТекЛС.ДатаЗакрытия;
		Страница.Cells(НомерСтроки,5).value 	= ТекЛС.ПричинаЗакрытия;
		Страница.Cells(НомерСтроки,6).value 	= ТекЛС.Примечание;
		
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	Книга.SaveAs(ФайлДляЗаписи);
	ExcelApp.Quit();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка закрытых лицевых счетов завершена " + ТекущаяДата());
	
КонецПроцедуры

&НаСервере
Функция ВыгрузкаЗакрытиеЛицевыхСчетовСервер()
	Запрос = НОвый Запрос;
	Запрос.УстановитьПараметр("Период", 		ПериодВыгрузки);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестВыгруженныеЗакрытыеЛССрезПоследних.Абонент.ЛицевойСчет КАК ЛицевойСчет,
	|	бестВыгруженныеЗакрытыеЛССрезПоследних.АдресОЖФ КАК АдресОЖФ,
	|	бестВыгруженныеЗакрытыеЛССрезПоследних.ДатаЗакрытия КАК ДатаЗакрытия,
	|	бестВыгруженныеЗакрытыеЛССрезПоследних.ПричинаЗакрытия КАК ПричинаЗакрытия,
	|	бестВыгруженныеЗакрытыеЛССрезПоследних.Примечание КАК Примечание,
	|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ
	|ИЗ
	|	РегистрСведений.бестВыгруженныеЗакрытыеЛСГИСЖКХ.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район) КАК бестВыгруженныеЗакрытыеЛССрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
	|		ПО бестВыгруженныеЗакрытыеЛССрезПоследних.Абонент = энргИдентификаторыАбонентаГИСЖКХ.Абонент
	|ГДЕ
	|	бестВыгруженныеЗакрытыеЛССрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)";
	Результат 			= Запрос.Выполнить();
	ВыборкаЛС 			= Результат.Выбрать();
	
	
	МассивЛС = Новый Массив;
	Пока ВыборкаЛС.Следующий() Цикл
		СтрукрутаЛС = Новый Структура;	
		
		СтрукрутаЛС.Вставить("ЛицевойСчет",				ВыборкаЛС.ЛицевойСчет);
		СтрукрутаЛС.Вставить("ИдентификаторЖКУГИСЖКХ",	ВыборкаЛС.ИдентификаторЖКУГИСЖКХ);
		СтрукрутаЛС.Вставить("АдресОЖФ",				ВыборкаЛС.АдресОЖФ);
		СтрукрутаЛС.Вставить("ДатаЗакрытия",			Формат(ВыборкаЛС.ДатаЗакрытия, "ДФ=dd.MM.yyyy"));
		СтрукрутаЛС.Вставить("ПричинаЗакрытия",			Строка(ВыборкаЛС.ПричинаЗакрытия));
		СтрукрутаЛС.Вставить("Примечание",				ВыборкаЛС.Примечание);
		
		МассивЛС.Добавить(СтрукрутаЛС);
	КонецЦикла;

	
	Возврат МассивЛС;	
КонецФункции

&НаКлиенте
Процедура ЗагрузкаОтветаПоЗакрытымЛСКлиент()
	НайденныеФайлы = НайтиФайлы(КаталогЗагрузки, "*.xlsx");
	
	ДанныеФайлов  = Новый Структура;
	
	Попытка
		СерверExcel 					= Новый COMОбъект("Excel.Application");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приложение excel не установлено");
		Возврат;
	КонецПопытки;
	
	СерверExcel.DisplayAlerts 			= 0;
	
	Для н =0 по НайденныеФайлы.Количество() - 1 Цикл
		
		ФайлХЛС			= СерверExcel.Application.Workbooks.Open(НайденныеФайлы[н].ПолноеИмя);
		
		ЛистЭксель		= ФайлХЛС.Sheets(1); // ЛС
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область			= СерверExcel.Range(ЛистЭксель.Cells(2,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));
		Страница1Книги	= Область.Value.Выгрузить();
		
		ФайлХЛС.close();
		
		ДанныеФайлов.Вставить("Файл" + СтрЗаменить(н, Символы.НПП,""),Страница1Книги);
		
	КонецЦикла;
	
	СерверExcel.quit();
	ЗагрузитьОтветПоВсемЗакрытымЛС(ДанныеФайлов);
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоВсемЗакрытымЛС(ДанныеФайлов)
	Для каждого стр из ДанныеФайлов Цикл
		ЗагрузитьОтветПоЗакрытымЛС(стр.Значение);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоЗакрытымЛС(ЛС)
	СоотвествиеКолонок  = Новый Соответствие;
	СоотвествиеКолонок.Вставить("ИдентификаторЖКУГИСЖКХ",	2-1);
	СоотвествиеКолонок.Вставить("Статус",					7-1);
	
	ТЗ  = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("ИдентификаторЖКУГИСЖКХ",	Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(36)));
	ТЗ.Колонки.Добавить("Статус",					Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	ВсегоСтрок  = ЛС[0].количество();
	Для Счетчик = 1 По ВсегоСтрок Цикл
		НоваяСтрока = ТЗ.Добавить();
	КонецЦикла;
	
	Для Каждого стр из СоотвествиеКолонок Цикл 
		ТЗ.ЗагрузитьКолонку(ЛС[стр.Значение], стр.Ключ);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Таблица", 	ТЗ);
	Запрос.УстановитьПараметр("Дата", 		ПериодЗагрузки);
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.УстановитьПараметр("Район",		Район);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	Таблица.Статус КАК Статус
	|ПОМЕСТИТЬ ВрТ0
	|ИЗ
	|	&Таблица КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргИдентификаторыАбонентаГИСЖКХ.Абонент КАК Абонент,
	|	ВрТ0.Статус КАК Статус
	|ПОМЕСТИТЬ ВТ_Абоненты
	|ИЗ
	|	ВрТ0 КАК ВрТ0
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
	|		ПО ВрТ0.ИдентификаторЖКУГИСЖКХ = энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Абоненты.Абонент КАК Абонент,
	|	ВТ_Абоненты.Статус КАК Статус,
	|	бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних.Организация КАК Организация,
	|	бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних.Район КАК Район,
	|	бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	|	бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних.ДатаЗакрытия КАК ДатаЗакрытия,
	|	бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних.ПричинаЗакрытия КАК ПричинаЗакрытия,
	|	бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних.Примечание КАК Примечание,
	|	бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних.Период КАК Период
	|ИЗ
	|	ВТ_Абоненты КАК ВТ_Абоненты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестВыгруженныеЗакрытыеЛСГИСЖКХ.СрезПоследних(
	|				&Дата,
	|				Организация = &Организация
	|					И Район = &Район
	|					И Абонент В
	|						(ВЫБРАТЬ
	|							ВТ.Абонент
	|						ИЗ
	|							ВТ_Абоненты КАК ВТ)) КАК бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних
	|		ПО ВТ_Абоненты.Абонент = бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних.Абонент
	|			И (бестВыгруженныеЗакрытыеЛСГИСЖКХСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись))";
	
	Результат 		= Запрос.Выполнить();
	Выгрузка		= Результат.Выбрать();
	
	Пока Выгрузка.Следующий() Цикл
		Запись = РегистрыСведений.бестВыгруженныеЗакрытыеЛСГИСЖКХ.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Выгрузка);
		Если Выгрузка.Статус = "ОК" Тогда
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ЗагруженоВГИСЖКХ;
		Иначе
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ОшибкаПриЗагрузкеВГИСЖХК;
			Запись.ОписаниеОшибки = Выгрузка.Статус;
		КонецЕсли;
		Запись.Записать();
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка данных о закрытых лицевых счетах завершена!");
КонецПроцедуры	

#КонецОбласти

#Область ПриборыУчета

&НаКлиенте
Процедура ВыгрузкаПриборовУчетаКлиент()
	// 11.13.0.10
	НомерСтраницы 			= 1;
	СтруктураФИО 			= Новый Структура;
	ExcelApp 				= Новый COMОбъект("Excel.Application");
	ExcelApp.DisplayAlerts 	= False;
	Попытка
		Книга 				= ExcelApp.Workbooks.Open(Файл);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
		Возврат;
	КонецПопытки;
	
	Страница 						= Книга.Worksheets(1);
	СтраницаДопУслуг				= Книга.Worksheets(2);
	НомерСтроки 					= 2;
	НомерСтрокиДопУслуг				= 2;
	СчетчикДляИмениФайла 			= 1;
	ФайлДляЗаписи 					= Файл;
	ИмяФайла 						= Лев(ФайлДляЗаписи, Найти(ФайлДляЗаписи , ".xlsx")-1) + "_";
	МассивПУ						= ВыгрузкаПриборовУчетаСервер();
	
	Для Каждого ВыборкаПриборов Из МассивПУ Цикл
		Если НомерСтроки 			= 5001 тогда 
			ФайлНовый 				= Лев(Файл, Найти(Файл , ".xlsx")-1) + "_" + СчетчикДляИмениФайла + ".xlsx";
			КопироватьФайл(ФайлДляЗаписи , ФайлНовый);  
			Книга.SaveAs(ФайлДляЗаписи);
			
			Попытка	
				Книга 				= ExcelApp.Workbooks.Open(ФайлНовый);	
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
				Возврат;
			КонецПопытки; 
			
			НомерСтроки 			= 2;
			НомерСтрокиДопУслуг		= 2;
			Страница 				= Книга.Worksheets(1);
			СтраницаДопУслуг		= Книга.Worksheets(2);
			СчетчикДляИмениФайла 	= СчетчикДляИмениФайла+1;
			ФайлДляЗаписи 			= ФайлНовый;
		КонецЕсли;
		
		Страница.Cells(НомерСтроки,1).value		= НомерСтроки-1;
		Страница.Cells(НомерСтроки,2).value		= ВыборкаПриборов.ЗаводскойНомер;
		Страница.Cells(НомерСтроки,3).value		= Строка(ВыборкаПриборов.ВидПУ);
		Страница.Cells(НомерСтроки,4).value		= Строка(ВыборкаПриборов.Марка);
		Страница.Cells(НомерСтроки,5).value		= Строка(ВыборкаПриборов.Модель);
		Страница.Cells(НомерСтроки,6).value		= ВыборкаПриборов.АдресОЖФ;
		Страница.Cells(НомерСтроки,7).value		= ВыборкаПриборов.УникальныйНомерДома;
		Страница.Cells(НомерСтроки,8).value		= ВыборкаПриборов.УникальныйНомерПомещения;
		Страница.Cells(НомерСтроки,10).value	= ВыборкаПриборов.ИдентификаторЖКУГИСЖКХ;
		Страница.Cells(НомерСтроки,11).value	= "нет";
		Страница.Cells(НомерСтроки,13).value	= "нет";
		
		Страница.Cells(НомерСтроки,16).value = Строка(ВыборкаПриборов.КоммунальныйРесурс);
		Страница.Cells(НомерСтроки,19).value = ВыборкаПриборов.Показание;
		Если ВыборкаПриборов.МассивДопУслуг.Количество() > 0 Тогда
			Для Каждого ТекДопУслуга Из ВыборкаПриборов.МассивДопУслуг Цикл
				СтраницаДопУслуг.Cells(НомерСтрокиДопУслуг,1).value = НомерСтроки-1;
				СтраницаДопУслуг.Cells(НомерСтрокиДопУслуг,2).value = ВыборкаПриборов.АдресОЖФ;
				СтраницаДопУслуг.Cells(НомерСтрокиДопУслуг,3).value = Строка(ТекДопУслуга.КоммунальныйРесурс);
				СтраницаДопУслуг.Cells(НомерСтрокиДопУслуг,5).value = Строка(ТекДопУслуга.Показание);
				
				
				НомерСтрокиДопУслуг = НомерСтрокиДопУслуг + 1;
			КонецЦикла;
		КонецЕсли;
		Страница.Cells(НомерСтроки,23).value = ВыборкаПриборов.ДатаУстановки;
		Страница.Cells(НомерСтроки,24).value = ВыборкаПриборов.ДатаУстановки;
		Страница.Cells(НомерСтроки,28).value = "нет";
		Страница.Cells(НомерСтроки,30).value = "нет";
		Страница.Cells(НомерСтроки,32).value = "нет";
		Страница.Cells(НомерСтроки,33).value = ВыборкаПриборов.НомерПУВГИСЖКХ;	
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	Книга.SaveAs(Файл);
	ExcelApp.Quit();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка приборов учета завершена " + Файл);
	
КонецПроцедуры

&НаСервере
Функция ВыгрузкаПриборовУчетаСервер()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", 		ПериодВыгрузки);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.Период КАК Период,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.АбонентМКД КАК Абонент,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.КоммунальныйРесурс КАК КоммунальныйРесурс,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.ВидПУ КАК ВидПУ,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.Показание КАК Показание,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.Статус КАК Статус,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.ПриборУчета.ТипПрибораУчета КАК Модель,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.ПриборУчета.ТипПрибораУчета.бестМаркаПУ КАК Марка,
	|	ВЫБОР
	|		КОГДА бестВыгруженныеПУВГИСЖКХСрезПоследних.ПриборУчета.Код = """"
	|			ТОГДА ""Без номера""
	|		ИНАЧЕ бестВыгруженныеПУВГИСЖКХСрезПоследних.ПриборУчета.Код
	|	КОНЕЦ КАК ЗаводскойНомер
	|ПОМЕСТИТЬ ВТ_ДанныеВыгрузки
	|ИЗ
	|	РегистрСведений.бестВыгруженныеПУВГИСЖКХ.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район) КАК бестВыгруженныеПУВГИСЖКХСрезПоследних
	|ГДЕ
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДанныеВыгрузки.Период КАК ДатаУстановки,
	|	ВТ_ДанныеВыгрузки.ПриборУчета КАК ПриборУчета,
	|	ВТ_ДанныеВыгрузки.Абонент КАК Абонент,
	|	ВТ_ДанныеВыгрузки.КоммунальныйРесурс КАК КоммунальныйРесурс,
	|	ВТ_ДанныеВыгрузки.ВидПУ КАК ВидПУ,
	|	ВТ_ДанныеВыгрузки.АдресОЖФ КАК АдресОЖФ,
	|	ВТ_ДанныеВыгрузки.Показание КАК Показание,
	|	ВТ_ДанныеВыгрузки.Модель КАК Модель,
	|	ВТ_ДанныеВыгрузки.Марка КАК Марка,
	|	ВТ_ДанныеВыгрузки.ЗаводскойНомер КАК ЗаводскойНомер,
	|	ВЫБОР
	|		КОГДА ВТ_ДанныеВыгрузки.Абонент ССЫЛКА Справочник.энргАбоненты
	|				И ВТ_ДанныеВыгрузки.Абонент.Домовладение
	|			ТОГДА энргИдентификаторыАбонентаГИСЖКХ.УникальныйНомерДома
	|		КОГДА ВТ_ДанныеВыгрузки.Абонент ССЫЛКА Справочник.энргАбоненты
	|			ТОГДА """"
	|		ИНАЧЕ энргИдентификаторыМКДГИСЖКХ.УникальныйНомерДома
	|	КОНЕЦ КАК УникальныйНомерДома,
	|	ВЫБОР
	|		КОГДА ВТ_ДанныеВыгрузки.Абонент ССЫЛКА Справочник.энргАбоненты
	|				И ВТ_ДанныеВыгрузки.Абонент.Домовладение
	|			ТОГДА """"
	|		КОГДА ВТ_ДанныеВыгрузки.Абонент ССЫЛКА Справочник.энргАбоненты
	|			ТОГДА энргИдентификаторыАбонентаГИСЖКХ.УникальныйНомерПомещения
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК УникальныйНомерПомещения,
	|	ЕСТЬNULL(энргИдентификаторыПУГИСЖКХ.НомерПрибораГИСЖКХ, """") КАК НомерПрибораГИСЖКХ,
	|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ
	|ИЗ
	|	ВТ_ДанныеВыгрузки КАК ВТ_ДанныеВыгрузки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
	|		ПО (ВТ_ДанныеВыгрузки.Абонент ССЫЛКА Справочник.энргАбоненты)
	|			И ВТ_ДанныеВыгрузки.Абонент = энргИдентификаторыАбонентаГИСЖКХ.Абонент
	|			И (энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ <> """"
	|				ИЛИ ВТ_ДанныеВыгрузки.Абонент ССЫЛКА Справочник.энргСтроения)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыМКДГИСЖКХ КАК энргИдентификаторыМКДГИСЖКХ
	|		ПО (ВТ_ДанныеВыгрузки.Абонент ССЫЛКА Справочник.энргСтроения)
	|			И ВТ_ДанныеВыгрузки.Абонент = энргИдентификаторыМКДГИСЖКХ.МКД
	|			И (энргИдентификаторыМКДГИСЖКХ.УникальныйНомерДома <> """"
	|				ИЛИ ВТ_ДанныеВыгрузки.Абонент ССЫЛКА Справочник.энргАбоненты)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыПУГИСЖКХ КАК энргИдентификаторыПУГИСЖКХ
	|		ПО ВТ_ДанныеВыгрузки.ПриборУчета = энргИдентификаторыПУГИСЖКХ.ПриборУчета
	|ИТОГИ
	|	МАКСИМУМ(ДатаУстановки),
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КоммунальныйРесурс),
	|	МАКСИМУМ(ВидПУ),
	|	МАКСИМУМ(АдресОЖФ),
	|	МАКСИМУМ(Модель),
	|	МАКСИМУМ(Марка),
	|	МАКСИМУМ(ЗаводскойНомер),
	|	МАКСИМУМ(УникальныйНомерДома),
	|	МАКСИМУМ(УникальныйНомерПомещения),
	|	МАКСИМУМ(НомерПрибораГИСЖКХ),
	|	МАКСИМУМ(ИдентификаторЖКУГИСЖКХ)
	|ПО
	|	ПриборУчета";
	
	
	Результат 	= Запрос.Выполнить();
	ВыборкаПриборов 	= Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	МассивПУ = Новый Массив;
	
	Пока ВыборкаПриборов.Следующий() Цикл
		Структура   	= Новый Структура;

		
		Структура.Вставить("ЗаводскойНомер",			ВыборкаПриборов.ЗаводскойНомер);
		Структура.Вставить("ВидПУ",						ВыборкаПриборов.ВидПУ);
		Структура.Вставить("Марка",						Строка(ВыборкаПриборов.Марка));
		Структура.Вставить("Модель",					Строка(ВыборкаПриборов.Модель));
		Структура.Вставить("АдресОЖФ",					ВыборкаПриборов.АдресОЖФ);
		Структура.Вставить("УникальныйНомерДома",		ВыборкаПриборов.УникальныйНомерДома);
		Структура.Вставить("УникальныйНомерПомещения",	ВыборкаПриборов.УникальныйНомерПомещения);
		Структура.Вставить("ИдентификаторЖКУГИСЖКХ",	ВыборкаПриборов.ИдентификаторЖКУГИСЖКХ);
		
		ВыборкаУслуг = ВыборкаПриборов.Выбрать();
		ВыборкаУслуг.Следующий();
		Структура.Вставить("КоммунальныйРесурс",		Строка(ВыборкаУслуг.КоммунальныйРесурс));
		Структура.Вставить("Показание",					ВыборкаУслуг.Показание);
		
		МассивДопУслуг = Новый Массив;
		Если ВыборкаПриборов.КоммунальныйРесурс > 1 Тогда
			
			Пока ВыборкаУслуг.Следующий() Цикл
				СтруктураДопУслуг   	= Новый Структура;

				СтруктураДопУслуг.Вставить("КоммунальныйРесурс",	Строка(ВыборкаУслуг.КоммунальныйРесурс));
				СтруктураДопУслуг.Вставить("Показание",				Строка(ВыборкаУслуг.Показание));
				МассивДопУслуг.Добавить(СтруктураДопУслуг);
			КонецЦикла;
		КонецЕсли;
		
		Структура.Вставить("МассивДопУслуг",			МассивДопУслуг);
		Структура.Вставить("ДатаУстановки",				ВыборкаПриборов.ДатаУстановки);
		Структура.Вставить("НомерПУВГИСЖКХ",			ВыборкаПриборов.НомерПрибораГИСЖКХ);
		
		МассивПУ.Добавить(Структура);
	КонецЦикла;
	
	Возврат МассивПУ;	
КонецФункции

&НаКлиенте
Процедура ЗагрузкаОтветаПоПриборыУчетаКлиент()
	НайденныеФайлы = НайтиФайлы(КаталогЗагрузки, "*.xlsx");
	
	ДанныеФайлов  = Новый Структура;
	
	Попытка
		СерверExcel 					= Новый COMОбъект("Excel.Application");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приложение excel не установлено");
		Возврат;
	КонецПопытки;
	
	СерверExcel.DisplayAlerts 			= 0;
	
	Для н =0 по НайденныеФайлы.Количество() - 1 Цикл
		
		ФайлХЛС			= СерверExcel.Application.Workbooks.Open(НайденныеФайлы[н].ПолноеИмя);
		
		ЛистЭксель		= ФайлХЛС.Sheets(1); // ПУ
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область			= СерверExcel.Range(ЛистЭксель.Cells(2,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));
		Страница1Книги	= Область.Value.Выгрузить();
		
		ФайлХЛС.close();
		
		ДанныеФайлов.Вставить("Файл" + СтрЗаменить(н, Символы.НПП,""),Страница1Книги);
		
	КонецЦикла;
	
	СерверExcel.quit();
	ЗагрузитьОтветПоВсемПУ(ДанныеФайлов);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоВсемПУ(ДанныеФайлов)
	Для каждого стр из ДанныеФайлов Цикл
		ЗагрузитьОтветПоПУ(стр.Значение);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоПУ(ПУ)
	СоотвествиеКолонок  = Новый Соответствие;
	
	СоотвествиеКолонок.Вставить("ЗаводскойНомер",			2-1);
	СоотвествиеКолонок.Вставить("ВидПУ",					3-1);
	СоотвествиеКолонок.Вставить("УникальныйНомерДома",		7-1);
	СоотвествиеКолонок.Вставить("ИдентификаторЖКУГИСЖКХ",	10-1);
	СоотвествиеКолонок.Вставить("КоммунальныйРесурс",		16-1);
	СоотвествиеКолонок.Вставить("НомерПрибораГИСЖКХ",		33-1);
	СоотвествиеКолонок.Вставить("Статус",					34-1);
	
	
	ТЗ  = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("ЗаводскойНомер",			Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(25)));
	ТЗ.Колонки.Добавить("ВидПУ",					Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	ТЗ.Колонки.Добавить("УникальныйНомерДома",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	ТЗ.Колонки.Добавить("ИдентификаторЖКУГИСЖКХ",	Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(13)));
	ТЗ.Колонки.Добавить("КоммунальныйРесурс",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(100)));
	ТЗ.Колонки.Добавить("НомерПрибораГИСЖКХ",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	ТЗ.Колонки.Добавить("Статус",					Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	ВсегоСтрок  = ПУ[0].количество();
	Для Счетчик = 1 По ВсегоСтрок Цикл
		НоваяСтрока = ТЗ.Добавить();
	КонецЦикла;
	
	Для Каждого стр из СоотвествиеКолонок Цикл 
		ТЗ.ЗагрузитьКолонку(ПУ[стр.Значение], стр.Ключ);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Таблица", 		ТЗ);
	Запрос.УстановитьПараметр("Дата", 			ПериодЗагрузки);
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.ЗаводскойНомер КАК ЗаводскойНомер,
	|	Таблица.ВидПУ КАК ВидПУ,
	|	Таблица.УникальныйНомерДома КАК УникальныйНомерДома,
	|	Таблица.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	Таблица.КоммунальныйРесурс КАК КоммунальныйРесурс,
	|	Таблица.НомерПрибораГИСЖКХ КАК НомерПрибораГИСЖКХ,
	|	Таблица.Статус КАК Статус
	|ПОМЕСТИТЬ ВрТ0
	|ИЗ
	|	&Таблица КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(энргИдентификаторыАбонентаГИСЖКХ.Абонент, энргИдентификаторыМКДГИСЖКХ.МКД) КАК Абонент,
	|	ВрТ0.ЗаводскойНомер КАК ЗаводскойНомер,
	|	бестКоммунальныеРесурсыЖКХ.Ссылка КАК КоммунальныйРесурс,
	|	ВрТ0.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	ВрТ0.НомерПрибораГИСЖКХ КАК НомерПрибораГИСЖКХ,
	|	ВрТ0.Статус КАК Статус,
	|	ВрТ0.УникальныйНомерДома КАК УникальныйНомерДома
	|ПОМЕСТИТЬ ВТ_ДанныеСАбонентами
	|ИЗ
	|	ВрТ0 КАК ВрТ0
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
	|		ПО (ВрТ0.ВидПУ <> ""Коллективный (общедомовой)"")
	|			И (энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ = ВрТ0.ИдентификаторЖКУГИСЖКХ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыМКДГИСЖКХ КАК энргИдентификаторыМКДГИСЖКХ
	|		ПО (ВрТ0.ВидПУ = ""Коллективный (общедомовой)"")
	|			И (энргИдентификаторыМКДГИСЖКХ.УникальныйНомерДома = ВрТ0.УникальныйНомерДома)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестКоммунальныеРесурсыЖКХ КАК бестКоммунальныеРесурсыЖКХ
	|		ПО (бестКоммунальныеРесурсыЖКХ.Наименование ПОДОБНО """" + ВрТ0.КоммунальныйРесурс + ""%"")
	|ГДЕ
	|	ВрТ0.ИдентификаторЖКУГИСЖКХ <> """"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.Период КАК Период,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.Организация КАК Организация,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.Район КАК Район,
	|	ВТ_ДанныеСАбонентами.Абонент КАК АбонентМКД,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.КоммунальныйРесурс КАК КоммунальныйРесурс,
	|	ВТ_ДанныеСАбонентами.ЗаводскойНомер КАК ЗаводскойНомер,
	|	ВТ_ДанныеСАбонентами.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.ВидПУ КАК ВидПУ,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	|	бестВыгруженныеПУВГИСЖКХСрезПоследних.Показание КАК Показание,
	|	ВТ_ДанныеСАбонентами.УникальныйНомерДома КАК УникальныйНомерДома,
	|	ВТ_ДанныеСАбонентами.Статус КАК Статус,
	|	ВТ_ДанныеСАбонентами.НомерПрибораГИСЖКХ КАК НомерПрибораГИСЖКХ
	|ИЗ
	|	ВТ_ДанныеСАбонентами КАК ВТ_ДанныеСАбонентами
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бестВыгруженныеПУВГИСЖКХ.СрезПоследних(
	|				&Дата,
	|				Организация = &Организация
	|					И Район = &Район
	|					И АбонентМКД В
	|						(ВЫБРАТЬ
	|							ВТ.Абонент
	|						ИЗ
	|							ВТ_ДанныеСАбонентами КАК ВТ)) КАК бестВыгруженныеПУВГИСЖКХСрезПоследних
	|		ПО ВТ_ДанныеСАбонентами.Абонент = бестВыгруженныеПУВГИСЖКХСрезПоследних.АбонентМКД
	|			И (бестВыгруженныеПУВГИСЖКХСрезПоследних.ПриборУчета.Код ПОДОБНО """" + ВТ_ДанныеСАбонентами.ЗаводскойНомер + ""%"")
	|			И ВТ_ДанныеСАбонентами.КоммунальныйРесурс = бестВыгруженныеПУВГИСЖКХСрезПоследних.КоммунальныйРесурс";
	
	Результат 		= Запрос.Выполнить();
	Выгрузка		= Результат.Выбрать();
	
	Пока Выгрузка.Следующий() Цикл
		Если Не ЗначениеЗаполнено(Выгрузка.АбонентМКД) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден Абонент (или МКД) с идентификатором ЖКУ ГИС ЖКХ """ + Выгрузка.ИдентификаторЖКУГИСЖКХ + """ и номером дома ГИС ЖКХ """ + Выгрузка.УникальныйНомерДома + """ или его ПУ """ + Выгрузка.ЗаводскойНомер + """");	
			Продолжить;
		КонецЕсли;
		
		Запись = РегистрыСведений.бестВыгруженныеПУВГИСЖКХ.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Выгрузка);
		Если Выгрузка.Статус = "ОК" Тогда
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ЗагруженоВГИСЖКХ;
		Иначе
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ОшибкаПриЗагрузкеВГИСЖХК;
			Запись.ОписаниеОшибки = Выгрузка.Статус;
		КонецЕсли;
		Запись.Записать();
		
		НаборЗаписей = РегистрыСведений.энргИдентификаторыПУГИСЖКХ.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ПриборУчета.Установить(Выгрузка.ПриборУчета);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() > 0 Тогда
			Запись = НаборЗаписей[0];
		Иначе 
			Запись = НаборЗаписей.Добавить();
			Запись.ПриборУчета = Выгрузка.ПриборУчета;
		КонецЕсли;
		Запись.НомерПрибораГИСЖКХ	= Выгрузка.НомерПрибораГИСЖКХ;
		Запись.КоммунальныйРесурс	= Выгрузка.КоммунальныйРесурс;
		НаборЗаписей.Записать();
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка данных об ПУ завершена!");
	
КонецПроцедуры

#КонецОбласти

#Область Показания

&НаКлиенте
Процедура ВыгрузкаПоказанийКлиент(ЭтоМКД)
	//  11.13.0.1
	НомерСтраницы 			= 1;
	СтруктураФИО 			= Новый Структура;
	ExcelApp 				= Новый COMОбъект("Excel.Application");
	ExcelApp.DisplayAlerts 	= False;
	Попытка
		Книга 				= ExcelApp.Workbooks.Open(Файл);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
		Возврат;
	КонецПопытки;
	
	Страница 						= Книга.Worksheets(1);
	НомерСтроки 					= 2;
	СчетчикДляИмениФайла 			= 1;
	ФайлДляЗаписи 					= Файл;
	ИмяФайла 						= Лев(ФайлДляЗаписи, Найти(ФайлДляЗаписи , ".xlsx")-1) + "_";
	МассивПоказаний						= ВыгрузкаПоказанийПУ(ЭтоМКД);
	
	Для Каждого ВыборкаПУ Из МассивПоказаний Цикл
		Если НомерСтроки 			= 20003 тогда 
			ФайлНовый 				= Лев(Файл, Найти(Файл , ".xlsx")-1) + "_" + СчетчикДляИмениФайла + ".xlsx";
			КопироватьФайл(ФайлДляЗаписи , ФайлНовый);  
			Книга.SaveAs(ФайлДляЗаписи);
			ExcelApp.Quit();
			
			ExcelApp 				= Новый COMОбъект("Excel.Application");
			ExcelApp.DisplayAlerts 	= False;
			Попытка	
				Книга 				= ExcelApp.Workbooks.Open(ФайлНовый);	
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
				Возврат;
			КонецПопытки; 
			
			НомерСтроки 			= 2;
			Страница 				= Книга.Worksheets(1);
			СчетчикДляИмениФайла 	= СчетчикДляИмениФайла+1;
			ФайлДляЗаписи 			= ФайлНовый;
		КонецЕсли;
		
		Страница.Cells(НомерСтроки,1).value = ВыборкаПУ.АдресОЖФ;
		Страница.Cells(НомерСтроки,2).value = ВыборкаПУ.НомерПрибораГИСЖКХ;
		Страница.Cells(НомерСтроки,3).value = ВыборкаПУ.КоммунальныйРесурс;
		Страница.Cells(НомерСтроки,4).value = ВыборкаПУ.Показание;
		Страница.Cells(НомерСтроки,7).value = ВыборкаПУ.ДатаСнятияПоказаний;
		Страница.Cells(НомерСтроки,8).value = "нет";
		
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	Книга.SaveAs(Файл);
	ExcelApp.Quit();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка завершена " + Файл);		
	
	
КонецПроцедуры

&НаСервере
Функция  ВыгрузкаПоказанийПУ(ЭтоМКД)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.КоммунальныйРесурс КАК КоммунальныйРесурс,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.Показание КАК Показание,
	|	энргИдентификаторыПУГИСЖКХ.НомерПрибораГИСЖКХ КАК НомерПрибораГИСЖКХ,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.ДатаСнятияПоказаний КАК ДатаСнятияПоказаний
	|ИЗ
	|	РегистрСведений.бестВыгруженныеПоказанияПУВГИСЖКХ.СрезПоследних(
	|			&Дата,
	|			Организация = &Организация
	|				И Район = &Район И ЭтоМКД = &ЭтоМКД) КАК бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыПУГИСЖКХ КАК энргИдентификаторыПУГИСЖКХ
	|		ПО бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.ПриборУчета = энргИдентификаторыПУГИСЖКХ.ПриборУчета
	|ГДЕ
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)";
	
	Запрос.УстановитьПараметр("Дата", 			ПериодВыгрузки);
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("ЭтоМКД", 		ЭтоМКД);
	Результат = Запрос.Выполнить();
	ВыборкаПУ = Результат.Выбрать();
	
	МассивПоказаний = Новый Массив;
	Пока ВыборкаПУ.Следующий() Цикл
		Структура = Новый Структура;
		
		Структура.Вставить("АдресОЖФ",				ВыборкаПУ.АдресОЖФ);
		Структура.Вставить("НомерПрибораГИСЖКХ",	ВыборкаПУ.НомерПрибораГИСЖКХ);
		Структура.Вставить("КоммунальныйРесурс",	Строка(ВыборкаПУ.КоммунальныйРесурс));
		Структура.Вставить("Показание",				ВыборкаПУ.Показание);
		Структура.Вставить("ДатаСнятияПоказаний",	Формат(ВыборкаПУ.ДатаСнятияПоказаний, "ДФ=dd.MM.yyyy"));
		МассивПоказаний.Добавить(Структура);
	КонецЦикла;

	Возврат МассивПоказаний;
	
КонецФункции

&НаКлиенте
Процедура ЗагрузкаОтветаПоПоказаниямКлиент()
	НайденныеФайлы = НайтиФайлы(КаталогЗагрузки, "*.xlsx");
	
	ДанныеФайлов  = Новый Структура;
	
	Попытка
		СерверExcel 					= Новый COMОбъект("Excel.Application");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приложение excel не установлено");
		Возврат;
	КонецПопытки;
	
	СерверExcel.DisplayAlerts 			= 0;
	
	Для н =0 по НайденныеФайлы.Количество() - 1 Цикл
		
		ФайлХЛС			= СерверExcel.Application.Workbooks.Open(НайденныеФайлы[н].ПолноеИмя);
		
		ЛистЭксель		= ФайлХЛС.Sheets(1); // ПУ
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область			= СерверExcel.Range(ЛистЭксель.Cells(2,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));
		Страница1Книги	= Область.Value.Выгрузить();
		
		ФайлХЛС.close();
		
		ДанныеФайлов.Вставить("Файл" + СтрЗаменить(н, Символы.НПП,""),Страница1Книги);
		
	КонецЦикла;
	
	СерверExcel.quit();
	ЗагрузитьОтветПоВсемПоказаниямПУ(ДанныеФайлов);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоВсемПоказаниямПУ(ДанныеФайлов)
	Для каждого стр из ДанныеФайлов Цикл
		ЗагрузкаОтветаПоПоказаниям(стр.Значение);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗагрузкаОтветаПоПоказаниям(ПУ)
	СоотвествиеКолонок  = Новый Соответствие;
	
	СоотвествиеКолонок.Вставить("НомерПрибораГИСЖКХ",		2-1);
	СоотвествиеКолонок.Вставить("КоммунальныйРесурс",		3-1);
	СоотвествиеКолонок.Вставить("Статус",					9-1);
	
	ТЗ  = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("КоммунальныйРесурс",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(100)));
	ТЗ.Колонки.Добавить("НомерПрибораГИСЖКХ",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	ТЗ.Колонки.Добавить("Статус",					Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	ВсегоСтрок  = ПУ[0].количество();
	Для Счетчик = 1 По ВсегоСтрок Цикл
		НоваяСтрока = ТЗ.Добавить();
	КонецЦикла;
	
	Для Каждого стр из СоотвествиеКолонок Цикл 
		ТЗ.ЗагрузитьКолонку(ПУ[стр.Значение], стр.Ключ);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Таблица", 		ТЗ);
	Запрос.УстановитьПараметр("Дата", 			ПериодЗагрузки);
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.НомерПрибораГИСЖКХ КАК НомерПрибораГИСЖКХ,
	|	Таблица.КоммунальныйРесурс КАК КоммунальныйРесурс,
	|	Таблица.Статус КАК Статус
	|ПОМЕСТИТЬ ВрТ0
	|ИЗ
	|	&Таблица КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестКоммунальныеРесурсыЖКХ.Ссылка КАК КоммунальныйРесурс,
	|	ВрТ0.НомерПрибораГИСЖКХ КАК НомерПрибораГИСЖКХ,
	|	ВрТ0.Статус КАК Статус,
	|	энргИдентификаторыПУГИСЖКХ.ПриборУчета КАК ПриборУчета
	|ПОМЕСТИТЬ ВТ_ДанныеСАбонентами
	|ИЗ
	|	ВрТ0 КАК ВрТ0
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бестКоммунальныеРесурсыЖКХ КАК бестКоммунальныеРесурсыЖКХ
	|		ПО (бестКоммунальныеРесурсыЖКХ.Наименование ПОДОБНО """" + ВрТ0.КоммунальныйРесурс + ""%"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыПУГИСЖКХ КАК энргИдентификаторыПУГИСЖКХ
	|		ПО ВрТ0.НомерПрибораГИСЖКХ = энргИдентификаторыПУГИСЖКХ.НомерПрибораГИСЖКХ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.Период КАК Период,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.Организация КАК Организация,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.Район КАК Район,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.ПриборУчета КАК ПриборУчета,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.КоммунальныйРесурс КАК КоммунальныйРесурс,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.Показание КАК Показание,
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.ДатаСнятияПоказаний КАК ДатаСнятияПоказаний,
	|	ВТ_ДанныеСАбонентами.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.бестВыгруженныеПоказанияПУВГИСЖКХ.СрезПоследних(
	|			&Дата,
	|			Организация = &Организация
	|				И Район = &Район
	|				И (ПриборУчета, КоммунальныйРесурс) В
	|					(ВЫБРАТЬ
	|						ВТ.ПриборУчета,
	|						ВТ.КоммунальныйРесурс
	|					ИЗ
	|						ВТ_ДанныеСАбонентами КАК ВТ)) КАК бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ДанныеСАбонентами КАК ВТ_ДанныеСАбонентами
	|		ПО бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.ПриборУчета = ВТ_ДанныеСАбонентами.ПриборУчета
	|			И бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.КоммунальныйРесурс = ВТ_ДанныеСАбонентами.КоммунальныйРесурс
	|ГДЕ
	|	бестВыгруженныеПоказанияПУВГИСЖКХСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)";
	
	Результат 		= Запрос.Выполнить();
	Выгрузка		= Результат.Выбрать();
	
	Пока Выгрузка.Следующий() Цикл
		
		Запись = РегистрыСведений.бестВыгруженныеПоказанияПУВГИСЖКХ.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Выгрузка);
		Если Выгрузка.Статус = "ОК" Тогда
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ЗагруженоВГИСЖКХ;
		Иначе
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ОшибкаПриЗагрузкеВГИСЖХК;
			Запись.ОписаниеОшибки = Выгрузка.Статус;
		КонецЕсли;
		Запись.Записать();
	КонецЦикла;
	
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка данных о показаниях завершена!");
	
КонецПроцедуры

#КонецОбласти

#Область ПлатежныеДокументы

&НаКлиенте
Процедура ВыгрузкаПлатежныхДокументовКлиент()
	РасчСчет = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ОсновнойБанковскийСчет");
	РасчСчетНомер = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(РасчСчет, "НомерСчета");
	БИК = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(РасчСчет, "Банк"), "Код");
	
	НомерСтраницы = 1;
	
	ExcelApp = Новый COMОбъект("Excel.Application");
	ExcelApp.DisplayAlerts = False;
	Попытка
		Книга = ExcelApp.Workbooks.Open(Файл);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
		Возврат;
	КонецПопытки; 
	
	НомерСтроки			= 4;
	НомерСтрокиУслуг	= 5;
	
	МассивПД = ВыгрузкаПлатежныхДокументов(НачалоМесяца(ПериодВыгрузки), КонецМесяца(ПериодВыгрузки));
	
	Страница = Книга.Worksheets(1);
	СчетчикДляИмениФайла = 1;
	
	ФайлДляЗаписи = Файл;
	ИмяФайла = Лев(ФайлДляЗаписи, Найти(ФайлДляЗаписи , ".xlsx")-1) + "_";
	ДЛя Каждого ВыборкаАбонентов Из МассивПД Цикл
		Страница = Книга.Worksheets(1);
		Если НомерСтроки = 50003 тогда 	   
			ФайлНовый = ИмяФайла + СчетчикДляИмениФайла + ".xlsx";
			КопироватьФайл(ФайлДляЗаписи , ФайлНовый);  
			Книга.SaveAs(ФайлДляЗаписи);
			ExcelApp.Quit();
			
			ExcelApp = Новый COMОбъект("Excel.Application");
			ExcelApp.DisplayAlerts = False;
			Попытка	
				Книга = ExcelApp.Workbooks.Open(ФайлНовый);	
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
				Возврат;
			КонецПопытки; 
			
			НомерСтроки 			= 4;
			НомерСтрокиУслуг		= 5;
			Страница 				= Книга.Worksheets(1);
			СчетчикДляИмениФайла 	= СчетчикДляИмениФайла+1;
			ФайлДляЗаписи 			= ФайлНовый;
		КонецЕсли;			
		
		//НомерПД									=МассивДоговоров[элмас].НомерПД + "-" + МассивДоговоров[элмас].ИдентификаторЖКУ; 
		
		Страница.Cells(НомерСтроки,1).value 	= ВыборкаАбонентов.ИдентификаторЖКУГИСЖКХ;
		Страница.Cells(НомерСтроки,2).value 	= "Текущий";		
		Страница.Cells(НомерСтроки,3).value 	= ВыборкаАбонентов.НомерПД;
		Страница.Cells(НомерСтроки,4).value 	= Формат(ПериодВыгрузки,"ДФ=MM.yyyy");
		Страница.Cells(НомерСтроки,9).value 	= ВыборкаАбонентов.Начислено;
		Страница.Cells(НомерСтроки,10).value 	= ВыборкаАбонентов.Задолженность;
		Страница.Cells(НомерСтроки,11).value 	= ВыборкаАбонентов.Аванс;
		Страница.Cells(НомерСтроки,12).value 	= ВыборкаАбонентов.Оплата;
		Страница.Cells(НомерСтроки,17).value	= Строка(РасчСчетНомер);
		Страница.Cells(НомерСтроки,18).value 	= БИК;
			
		Для Каждого ВыборкаУслуг Из ВыборкаАбонентов.МассивПДСуммы Цикл
			Страница = Книга.Worksheets(2);
			Страница.Cells(НомерСтрокиУслуг,1).value 	= ВыборкаАбонентов.НомерПД;
			Страница.Cells(НомерСтрокиУслуг,2).value 	= Строка(ВыборкаУслуг.Услуга);
			Страница.Cells(НомерСтрокиУслуг,5).value 	= ВыборкаУслуг.ОбъемИнд;
			Страница.Cells(НомерСтрокиУслуг,7).value 	= ВыборкаУслуг.ОбъемОДН;
			Страница.Cells(НомерСтрокиУслуг,8).value 	= ВыборкаУслуг.ЗначениеТарифа;
			Страница.Cells(НомерСтрокиУслуг,9).value 	= ВыборкаУслуг.СуммаИнд;
			Страница.Cells(НомерСтрокиУслуг,10).value 	= ВыборкаУслуг.СуммаОДН;
			Страница.Cells(НомерСтрокиУслуг,11).value 	= ВыборкаУслуг.СуммаВсего;
			Страница.Cells(НомерСтрокиУслуг,14).value 	= ВыборкаУслуг.Перерасчет;
			Страница.Cells(НомерСтрокиУслуг,30).value 	= ВыборкаУслуг.Начислено;
			НомерСтрокиУслуг = НомерСтрокиУслуг + 1;
		КонецЦикла;	
		
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	Книга.SaveAs(ФайлДляЗаписи);
	ExcelApp.Quit();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка платежных документов завершена " + ТекущаяДата());
	
	Возврат;		
КонецПроцедуры

&НаСервере
Функция  ВыгрузкаПлатежныхДокументов(ДатаНач, ДатаКон)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("ДатаНач",		ДатаНач);
	Запрос.УстановитьПараметр("ДатаКон",		ДатаКон);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.УстановитьПараметр("НомерМесяца",	Формат(ДатаНач,"ДФ=MMyyyy"));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргОбъемНачисленийОбороты.Абонент КАК Абонент,
	|	энргОбъемНачисленийОбороты.Услуга КАК Услуга,
	|	энргОбъемНачисленийОбороты.ЗначениеТарифа КАК ЗначениеТарифа,
	|	СУММА(энргОбъемНачисленийОбороты.СуммаОборот) КАК Сумма,
	|	СУММА(ВЫБОР
	|			КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Начисление)
	|				ТОГДА энргОбъемНачисленийОбороты.ОбъемУслугиОборот
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК ОбъемИнд,
	|	СУММА(ВЫБОР
	|			КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.НачислениеОДН)
	|				ТОГДА энргОбъемНачисленийОбороты.ОбъемУслугиОборот
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК ОбъемОДН,
	|	СУММА(ВЫБОР
	|			КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Начисление)
	|				ТОГДА энргОбъемНачисленийОбороты.СуммаОборот
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаИнд,
	|	СУММА(ВЫБОР
	|			КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.НачислениеОДН)
	|				ТОГДА энргОбъемНачисленийОбороты.СуммаОборот
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаОДН,
	|	СУММА(ВЫБОР
	|			КОГДА энргОбъемНачисленийОбороты.ВидНачисления <> ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Перерасчет)
	|				ТОГДА энргОбъемНачисленийОбороты.СуммаОборот
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаВсего,
	|	СУММА(ВЫБОР
	|			КОГДА энргОбъемНачисленийОбороты.ВидНачисления = ЗНАЧЕНИЕ(Перечисление.энргВидыНачислений.Перерасчет)
	|				ТОГДА энргОбъемНачисленийОбороты.СуммаОборот
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК Перерасчет,
	|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	&НомерМесяца + энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ КАК НомерПД
	|ПОМЕСТИТЬ ВТ_Начисления
	|ИЗ
	|	РегистрНакопления.энргОбъемНачислений.Обороты(
	|			&ДатаНач,
	|			&ДатаКон,
	|			,
	|			Организация = &Организация
	|				И Район = &Район) КАК энргОбъемНачисленийОбороты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
	|		ПО энргОбъемНачисленийОбороты.Абонент = энргИдентификаторыАбонентаГИСЖКХ.Абонент
	|
	|СГРУППИРОВАТЬ ПО
	|	энргОбъемНачисленийОбороты.Абонент,
	|	энргОбъемНачисленийОбороты.Услуга,
	|	энргОбъемНачисленийОбороты.ЗначениеТарифа,
	|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ,
	|	&НомерМесяца + энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргАвансыОстатки.Абонент КАК Абонент,
	|	СУММА(энргАвансыОстатки.СуммаОстаток) КАК Аванс
	|ПОМЕСТИТЬ ВТ_Авансы
	|ИЗ
	|	РегистрНакопления.энргАвансы.Остатки(
	|			&ДатаНач,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						ВТ.Абонент
	|					ИЗ
	|						вт_Начисления КАК ВТ)) КАК энргАвансыОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	энргАвансыОстатки.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргВзаиморасчетыПоМесяцамОстатки.Абонент КАК Абонент,
	|	СУММА(энргВзаиморасчетыПоМесяцамОстатки.СуммаОстаток) КАК Задолженность
	|ПОМЕСТИТЬ ВТ_Задолженность
	|ИЗ
	|	РегистрНакопления.энргВзаиморасчетыПоМесяцам.Остатки(
	|			&ДатаНач,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						ВТ.Абонент
	|					ИЗ
	|						вт_Начисления КАК ВТ)) КАК энргВзаиморасчетыПоМесяцамОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	энргВзаиморасчетыПоМесяцамОстатки.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	энргОплатаУслугОбороты.Абонент КАК Абонент,
	|	СУММА(энргОплатаУслугОбороты.СуммаОборот) КАК Оплата
	|ПОМЕСТИТЬ ВТ_Оплата
	|ИЗ
	|	РегистрНакопления.энргОплатаУслуг.Обороты(
	|			&ДатаНач,
	|			&ДатаКон,
	|			,
	|			Организация = &Организация
	|				И Район = &Район
	|				И Абонент В
	|					(ВЫБРАТЬ
	|						ВТ.Абонент
	|					ИЗ
	|						вт_Начисления КАК ВТ)) КАК энргОплатаУслугОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	энргОплатаУслугОбороты.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложеныйЗапрос.Абонент КАК Абонент,
	|	СУММА(ВложеныйЗапрос.Аванс) КАК Аванс,
	|	СУММА(ВложеныйЗапрос.Задолженность) КАК Задолженность,
	|	СУММА(ВложеныйЗапрос.Оплата) КАК Оплата
	|ПОМЕСТИТЬ ВТ_ДеньгиНачало
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВТ_Авансы.Абонент КАК Абонент,
	|		ВТ_Авансы.Аванс КАК Аванс,
	|		0 КАК Задолженность,
	|		0 КАК Оплата
	|	ИЗ
	|		ВТ_Авансы КАК ВТ_Авансы
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВТ_Задолженность.Абонент,
	|		0,
	|		ВТ_Задолженность.Задолженность,
	|		0
	|	ИЗ
	|		ВТ_Задолженность КАК ВТ_Задолженность
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВТ_Оплата.Абонент,
	|		0,
	|		0,
	|		ВТ_Оплата.Оплата
	|	ИЗ
	|		ВТ_Оплата КАК ВТ_Оплата) КАК ВложеныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложеныйЗапрос.Абонент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Начисления.Абонент КАК Абонент,
	|	ВТ_Начисления.Услуга.бестВидУслугиЖКХ КАК Услуга,
	|	ВТ_Начисления.ЗначениеТарифа КАК ЗначениеТарифа,
	|	ВТ_Начисления.Сумма КАК Начислено,
	|	ВТ_Начисления.ОбъемИнд КАК ОбъемИнд,
	|	ВТ_Начисления.ОбъемОДН КАК ОбъемОДН,
	|	ВТ_Начисления.СуммаИнд КАК СуммаИнд,
	|	ВТ_Начисления.СуммаОДН КАК СуммаОДН,
	|	ВТ_Начисления.СуммаВсего КАК СуммаВсего,
	|	ВТ_Начисления.Перерасчет КАК Перерасчет,
	|	ЕСТЬNULL(ВТ_ДеньгиНачало.Аванс, 0) КАК Аванс,
	|	ЕСТЬNULL(ВТ_ДеньгиНачало.Задолженность, 0) КАК Задолженность,
	|	ЕСТЬNULL(ВТ_ДеньгиНачало.Оплата, 0) КАК Оплата,
	|	ВТ_Начисления.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	ВТ_Начисления.НомерПД КАК НомерПД
	|ИЗ
	|	ВТ_Начисления КАК ВТ_Начисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДеньгиНачало КАК ВТ_ДеньгиНачало
	|		ПО (ВТ_ДеньгиНачало.Абонент = ВТ_Начисления.Абонент)
	|ИТОГИ
	|	СУММА(Начислено),
	|	МАКСИМУМ(Аванс),
	|	МАКСИМУМ(Задолженность),
	|	МАКСИМУМ(Оплата),
	|	МАКСИМУМ(ИдентификаторЖКУГИСЖКХ),
	|	МАКСИМУМ(НомерПД)
	|ПО
	|	Абонент";
	
	Результат = Запрос.Выполнить();
	ВыборкаАбонентов = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	МассивПД = Новый Массив;
	Пока ВыборкаАбонентов.Следующий() Цикл
		Структура = Новый Структура;
		Структура.Вставить("ИдентификаторЖКУГИСЖКХ",	ВыборкаАбонентов.ИдентификаторЖКУГИСЖКХ);
		Структура.Вставить("НомерПД",					ВыборкаАбонентов.НомерПД);
		Структура.Вставить("Начислено",					ВыборкаАбонентов.Начислено);
		Структура.Вставить("Задолженность",				ВыборкаАбонентов.Задолженность);
		Структура.Вставить("Аванс",						ВыборкаАбонентов.Аванс);
		Структура.Вставить("Оплата",					ВыборкаАбонентов.Оплата);
		
		НаборЗаписейСуммыПД = РегистрыСведений.бестВыгруженныеСуммыПДВГИСЖКХ.СоздатьНаборЗаписей();
		НаборЗаписейСуммыПД.Отбор.Организация.Установить(Организация);
		НаборЗаписейСуммыПД.Отбор.Район.Установить(Район);
		НаборЗаписейСуммыПД.Отбор.Абонент.Установить(ВыборкаАбонентов.Абонент);
		
		ЗаписьСуммыПД = НаборЗаписейСуммыПД.Добавить();
		ЗаполнитьЗначенияСвойств(ЗаписьСуммыПД, ВыборкаАбонентов);
		ЗаписьСуммыПД.Организация		= Организация;
		ЗаписьСуммыПД.Район				= Район;
		ЗаписьСуммыПД.Статус			= Перечисления.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись;
		НаборЗаписейСуммыПД.Записать();
		
		Выборка = ВыборкаАбонентов.Выбрать();
		МассивПДСуммы = Новый Массив;
		Пока Выборка.Следующий() Цикл
			СтруктураПД = Новый Структура;
			СтруктураПД.Вставить("Услуга",			Выборка.Услуга);
			СтруктураПД.Вставить("ОбъемИнд",		Выборка.ОбъемИнд);
			СтруктураПД.Вставить("ОбъемОДН",		Выборка.ОбъемОДН);
			СтруктураПД.Вставить("ЗначениеТарифа",	Выборка.ЗначениеТарифа);
			СтруктураПД.Вставить("СуммаИнд",		Выборка.СуммаИнд);
			СтруктураПД.Вставить("СуммаОДН",		Выборка.СуммаОДН);
			СтруктураПД.Вставить("СуммаВсего",		Выборка.СуммаВсего);
			СтруктураПД.Вставить("Перерасчет",		Выборка.Перерасчет);
			СтруктураПД.Вставить("Начислено",		Выборка.Начислено);
			МассивПДСуммы.Добавить(СтруктураПД);
			
			НаборЗаписейПД = РегистрыСведений.бестВыгруженныеПДВГИСЖКХ.СоздатьНаборЗаписей();
			НаборЗаписейПД.Отбор.Организация.Установить(Организация);
			НаборЗаписейПД.Отбор.Район.Установить(Район);
			НаборЗаписейПД.Отбор.Абонент.Установить(ВыборкаАбонентов.Абонент);
			НаборЗаписейПД.Отбор.Услуга.Установить(Выборка.Услуга);
			
			ЗаписьПД = НаборЗаписейПД.Добавить();
			ЗаполнитьЗначенияСвойств(ЗаписьПД, Выборка);
			ЗаписьПД.Организация		= Организация;
			ЗаписьПД.Район				= Район;
			ЗаписьПД.ПериодНачисления	= ДатаНач;	
			ЗаписьПД.Статус				= Перечисления.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись;
			НаборЗаписейПД.Записать();
		КонецЦикла;
		
		Структура.Вставить("МассивПДСуммы",			МассивПДСуммы);
		МассивПД.Добавить(Структура);
	КонецЦикла;
	
	Возврат МассивПД;
	
КонецФункции

&НаКлиенте
Процедура ЗагрузкаОтветаПоПДКлиент()
	Попытка
		СерверExcel 					= Новый COMОбъект("Excel.Application");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приложение excel не установлено");
		Возврат;
	КонецПопытки;
	
	НайденныеФайлы = НайтиФайлы(КаталогЗагрузки, "*.xlsx");
	
	ДанныеФайлов  = Новый Структура;
	Для н =0 по НайденныеФайлы.Количество() - 1 Цикл 					
		//СерверExcel.DisplayAlerts 			= 0;
		
		ФайлХЛС			= СерверExcel.Application.Workbooks.Open(НайденныеФайлы[н].ПолноеИмя);
		
		ЛистЭксель		= ФайлХЛС.Sheets(1); // суммы
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область			= СерверExcel.Range(ЛистЭксель.Cells(4,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));
		Страница1Книги	= Область.Value.Выгрузить();
		
		ЛистЭксель		= ФайлХЛС.Sheets(2);  // услуги
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область 		= СерверExcel.Range(ЛистЭксель.Cells(5,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));		
		Страница2Книги	= Область.Value.Выгрузить();
		
		ДанныеФайлов.Вставить("Файл" + СтрЗаменить(н, Символы.НПП,""),Новый Структура("Страница1,Страница2",Страница1Книги,Страница2Книги));
		
		ФайлХЛС.close();
		
	КонецЦикла;	
	
	СерверExcel.quit();
	ЗагрузитьОтветПоВсемПД(ДанныеФайлов);
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоВсемПД(ДанныеФайла)
	Для каждого стр из ДанныеФайла Цикл
		ЗагрузитьОтветПоПД(стр.Значение);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоПД(СтруктураСтраниц)
	
	Страница1 = СтруктураСтраниц.Страница1;	
	Страница2 = СтруктураСтраниц.Страница2;
	
	СоотвествиеКолонок  = Новый Соответствие;
	СоотвествиеКолонок.Вставить("НомерПД",						3-1);
	СоотвествиеКолонок.Вставить("ИдентификаторПД",				35-1);
	СоотвествиеКолонок.Вставить("Статус",						37-1);
	
	ТЗСтраница1  = Новый ТаблицаЗначений;
	ТЗСтраница1.Колонки.Добавить("НомерПД",				Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(30)));
	ТЗСтраница1.Колонки.Добавить("ИдентификаторПД",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(38)));
	ТЗСтраница1.Колонки.Добавить("Статус",				Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	
	ЗаполнитьТЗ(Страница1, СоотвествиеКолонок, ТЗСтраница1);
	
	СоотвествиеКолонок  = Новый Соответствие;
	СоотвествиеКолонок.Вставить("НомерПД",						1-1);
	СоотвествиеКолонок.Вставить("Услуга",						2-1);
	СоотвествиеКолонок.Вставить("Статус",						36-1);
	
	ТЗСтраница2  = Новый ТаблицаЗначений;
	ТЗСтраница2.Колонки.Добавить("НомерПД",				Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(30)));
	ТЗСтраница2.Колонки.Добавить("Услуга",				Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(150)));
	ТЗСтраница2.Колонки.Добавить("Статус",				Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	ЗаполнитьТЗ(Страница2, СоотвествиеКолонок, ТЗСтраница2);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Страница1", 			ТЗСтраница1);
	Запрос.УстановитьПараметр("Страница2", 			ТЗСтраница2);
	Запрос.УстановитьПараметр("ДатаЗагрузки", 	ПериодЗагрузки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Страница1.НомерПД КАК НомерПД,
	|	Страница1.ИдентификаторПД КАК ИдентификаторПД,
	|	Страница1.Статус КАК Статус
	|ПОМЕСТИТЬ ВрСтраница1
	|ИЗ
	|	&Страница1 КАК Страница1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Страница2.НомерПД КАК НомерПД,
	|	Страница2.Услуга КАК УслугаЖКХ,
	|	Страница2.Статус КАК Статус
	|ПОМЕСТИТЬ ВрСтраница2
	|ИЗ
	|	&Страница2 КАК Страница2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВрСтраница2.НомерПД КАК НомерПД,
	|	ВрСтраница2.УслугаЖКХ КАК УслугаЖКХ,
	|	ВрСтраница2.Статус КАК Статус,
	|	бестВидыУслугЖКХ.Ссылка КАК УслугаЖКХСсылка
	|ПОМЕСТИТЬ ВТ_Услуги
	|ИЗ
	|	ВрСтраница2 КАК ВрСтраница2
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестВидыУслугЖКХ КАК бестВидыУслугЖКХ
	|		ПО (бестВидыУслугЖКХ.Наименование ПОДОБНО """" + ВрСтраница2.УслугаЖКХ + ""%"")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВыгруженныеСуммыПДВГИСЖКХ.Организация КАК Организация,
	|	бестВыгруженныеСуммыПДВГИСЖКХ.Район КАК Район,
	|	бестВыгруженныеСуммыПДВГИСЖКХ.Абонент КАК Абонент,
	|	бестВыгруженныеСуммыПДВГИСЖКХ.НомерПД КАК НомерПД,
	|	бестВыгруженныеСуммыПДВГИСЖКХ.Задолженность КАК Задолженность,
	|	бестВыгруженныеСуммыПДВГИСЖКХ.Аванс КАК Аванс,
	|	бестВыгруженныеСуммыПДВГИСЖКХ.Начислено КАК Начислено,
	|	бестВыгруженныеСуммыПДВГИСЖКХ.Оплачено КАК Оплачено,
	|	ВрСтраница1.Статус КАК Статус,
	|	ВрСтраница1.ИдентификаторПД КАК ИдентификаторПД
	|ИЗ
	|	РегистрСведений.бестВыгруженныеСуммыПДВГИСЖКХ КАК бестВыгруженныеСуммыПДВГИСЖКХ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВрСтраница1 КАК ВрСтраница1
	|		ПО бестВыгруженныеСуммыПДВГИСЖКХ.НомерПД = ВрСтраница1.НомерПД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестВыгруженныеПДВГИСЖКХ.Организация КАК Организация,
	|	бестВыгруженныеПДВГИСЖКХ.Район КАК Район,
	|	бестВыгруженныеПДВГИСЖКХ.ПериодНачисления КАК ПериодНачисления,
	|	бестВыгруженныеПДВГИСЖКХ.Абонент КАК Абонент,
	|	бестВыгруженныеПДВГИСЖКХ.НомерПД КАК НомерПД,
	|	бестВыгруженныеПДВГИСЖКХ.Услуга КАК Услуга,
	|	бестВыгруженныеПДВГИСЖКХ.ЗначениеТарифа КАК ЗначениеТарифа,
	|	бестВыгруженныеПДВГИСЖКХ.ОбъемИнд КАК ОбъемИнд,
	|	бестВыгруженныеПДВГИСЖКХ.ОбъемОДН КАК ОбъемОДН,
	|	бестВыгруженныеПДВГИСЖКХ.СуммаИнд КАК СуммаИнд,
	|	бестВыгруженныеПДВГИСЖКХ.СуммаОДН КАК СуммаОДН,
	|	бестВыгруженныеПДВГИСЖКХ.СуммаВсего КАК СуммаВсего,
	|	бестВыгруженныеПДВГИСЖКХ.СуммаПерерасчет КАК СуммаПерерасчет,
	|	бестВыгруженныеПДВГИСЖКХ.Начислено КАК Начислено,
	|	ВТ_Услуги.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.бестВыгруженныеПДВГИСЖКХ КАК бестВыгруженныеПДВГИСЖКХ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Услуги КАК ВТ_Услуги
	|		ПО бестВыгруженныеПДВГИСЖКХ.Услуга = ВТ_Услуги.УслугаЖКХСсылка
	|			И бестВыгруженныеПДВГИСЖКХ.НомерПД = ВТ_Услуги.НомерПД";
	
	Пакет = Запрос.ВыполнитьПакет();
	Выборка			= Пакет[Пакет.Количество() - 2].Выбрать();
	ВыборкаУслуг	= Пакет[Пакет.Количество() - 1].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Запись = РегистрыСведений.бестВыгруженныеСуммыПДВГИСЖКХ.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Выборка);
		Если Выборка.Статус = "ОК" Тогда
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ЗагруженоВГИСЖКХ;
		Иначе
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ОшибкаПриЗагрузкеВГИСЖХК;
			Запись.ОписаниеОшибки = Выборка.Статус;
		КонецЕсли;
		Запись.Записать();	
	КонецЦикла;
	
	Пока ВыборкаУслуг.Следующий() Цикл
		Запись = РегистрыСведений.бестВыгруженныеПДВГИСЖКХ.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, ВыборкаУслуг);
		Если ВыборкаУслуг.Статус = "ОК" Тогда
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ЗагруженоВГИСЖКХ;
		Иначе
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ОшибкаПриЗагрузкеВГИСЖХК;
			Запись.ОписаниеОшибки = ВыборкаУслуг.Статус;
		КонецЕсли;
		Запись.Записать();	
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка данных о ПД завершена!");
	
КонецПроцедуры

#КонецОбласти

#Область Оплата

&НаКлиенте
Процедура ВыгрузкаОплатыКлиент()
	НомерСтраницы = 1;
	
	ExcelApp = Новый COMОбъект("Excel.Application");
	ExcelApp.DisplayAlerts = False;
	Попытка
		Книга = ExcelApp.Workbooks.Open(Файл);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
		Возврат;
	КонецПопытки; 
	
	НомерСтроки = 2;
	
	МассивОплат = ВыгрузкаОплаты();
	
	Страница = Книга.Worksheets(1);
	СчетчикДляИмениФайла = 1;
	
	ФайлДляЗаписи = Файл;
	ИмяФайла = Лев(ФайлДляЗаписи, Найти(ФайлДляЗаписи , ".xlsx")-1) + "_";
	Для Каждого ТекСтрока Из МассивОплат Цикл
		Страница = Книга.Worksheets(1);
		Если НомерСтроки = 50003 тогда 	   
			ФайлНовый = ИмяФайла + СчетчикДляИмениФайла + ".xlsx";
			КопироватьФайл(ФайлДляЗаписи , ФайлНовый);  
			Книга.SaveAs(ФайлДляЗаписи);
			ExcelApp.Quit();
			
			ExcelApp = Новый COMОбъект("Excel.Application");
			ExcelApp.DisplayAlerts = False;
			Попытка	
				Книга = ExcelApp.Workbooks.Open(ФайлНовый);	
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
				Возврат;
			КонецПопытки; 
			
			НомерСтроки 			= 2;
			Страница 				= Книга.Worksheets(1);
			СчетчикДляИмениФайла 	= СчетчикДляИмениФайла+1;
			ФайлДляЗаписи 			= ФайлНовый;
		КонецЕсли;			
		
		
		Страница.Cells(НомерСтроки,1).value 	= НомерСтроки - 1;
		Страница.Cells(НомерСтроки,2).value 	= ТекСтрока.СуммаПлатежа;		
		Страница.Cells(НомерСтроки,3).value 	= ТекСтрока.ДатаПлатежа;
		Страница.Cells(НомерСтроки,6).value 	= ТекСтрока.ИдентификаторЖКУГИСЖКХ;
		
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	Книга.SaveAs(ФайлДляЗаписи);
	ExcelApp.Quit();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка платежных документов завершена " + ТекущаяДата());
	
КонецПроцедуры

&НаСервере
Функция  ВыгрузкаОплаты()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.УстановитьПараметр("ДатаНач",		НачалоМесяца(ПериодВыгрузки));
	Запрос.УстановитьПараметр("ДатаКон",		КонецМесяца(ПериодВыгрузки));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	энргИсторияОплаты.ДатаПлатежа КАК ДатаПлатежа,
	|	СУММА(энргИсторияОплаты.СуммаПлатежа) КАК СуммаПлатежа,
	|	энргИсторияОплаты.Организация КАК Организация,
	|	энргИсторияОплаты.Район КАК Район,
	|	энргИсторияОплаты.Абонент КАК Абонент
	|ИЗ
	|	РегистрСведений.энргИсторияОплаты КАК энргИсторияОплаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
	|		ПО энргИсторияОплаты.Абонент = энргИдентификаторыАбонентаГИСЖКХ.Абонент
	|			И (энргИсторияОплаты.Организация = &Организация)
	|			И (энргИсторияОплаты.Район = &Район)
	|			И (энргИсторияОплаты.Период >= &ДатаНач)
	|			И (энргИсторияОплаты.Период <= &ДатаКон)
	|
	|СГРУППИРОВАТЬ ПО
	|	энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ,
	|	энргИсторияОплаты.ДатаПлатежа,
	|	энргИсторияОплаты.Организация,
	|	энргИсторияОплаты.Район,
	|	энргИсторияОплаты.Абонент";
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	МассивОплат = Новый Массив;
	Пока Выборка.Следующий() Цикл
	    СтруктураОплаты = Новый Структура;		
		СтруктураОплаты.Вставить("СуммаПлатежа",	Выборка.СуммаПлатежа);		
		СтруктураОплаты.Вставить("ДатаПлатежа",		Формат(Выборка.ДатаПлатежа,"ДФ=dd.MM.yy"));
		СтруктураОплаты.Вставить("ИдентификаторЖКУГИСЖКХ", Выборка.ИдентификаторЖКУГИСЖКХ);
		
		МассивОплат.Добавить(СтруктураОплаты);
		
		Запись = РегистрыСведений.бестИсторияОплатыГИСЖКХ.СоздатьМенеджерЗаписи();
		Запись.Организация	= Организация;
		Запись.Район		= Район;
		Запись.Абонент		= Выборка.Абонент;
		Запись.ДатаПлатежа	= Выборка.ДатаПлатежа;
		Запись.СуммаПлатежа	= Выборка.СуммаПлатежа;
		Запись.Статус		= Перечисления.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись;
		
		Запись.Записать();
	КонецЦикла;
	
	Возврат МассивОплат;
	
КонецФункции

&НаКлиенте
Процедура ЗагрузкаОтветаПоОплатеКлиент()
	Попытка
		СерверExcel 					= Новый COMОбъект("Excel.Application");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приложение excel не установлено");
		Возврат;
	КонецПопытки;
	
	НайденныеФайлы = НайтиФайлы(КаталогЗагрузки, "*.xlsx");
	
	ДанныеФайлов  = Новый Структура;
	Для н =0 по НайденныеФайлы.Количество() - 1 Цикл 					
		//СерверExcel.DisplayAlerts 			= 0;
		
		ФайлХЛС			= СерверExcel.Application.Workbooks.Open(НайденныеФайлы[н].ПолноеИмя);
		
		ЛистЭксель		= ФайлХЛС.Sheets(1); // суммы
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область			= СерверExcel.Range(ЛистЭксель.Cells(2,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));
		Страница1Книги	= Область.Value.Выгрузить();
		
		
		ДанныеФайлов.Вставить("Файл" + СтрЗаменить(н, Символы.НПП,""),Страница1Книги);
		
		ФайлХЛС.close();
		
	КонецЦикла;	
	
	СерверExcel.quit();
	ЗагрузитьОтветПоВсемОплатам(ДанныеФайлов);
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоВсемОплатам(ДанныеФайла)
	Для каждого стр из ДанныеФайла Цикл
		ЗагрузитьОтветПоОплате(стр.Значение);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоОплате(Страница)
	
	
	СоотвествиеКолонок  = Новый Соответствие;
	СоотвествиеКолонок.Вставить("ДатаПлатежа",					3-1);
	СоотвествиеКолонок.Вставить("ИдентификаторЖКУГИСЖКХ",		6-1);
	СоотвествиеКолонок.Вставить("Статус",						7-1);
	
	ТЗ  = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("ДатаПлатежа",					Новый ОписаниеТипов("Дата"));
	ТЗ.Колонки.Добавить("ИдентификаторЖКУГИСЖКХ",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(13)));
	ТЗ.Колонки.Добавить("Статус",						Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	ВсегоСтрок  = Страница[0].Количество();
	
	Для Счетчик = 1 По ВсегоСтрок Цикл
		НоваяСтрока = ТЗ.Добавить();
	КонецЦикла;
	
	Для Каждого стр из СоотвествиеКолонок Цикл 
		ТЗ.ЗагрузитьКолонку(Страница[стр.Значение], стр.Ключ);
		
	КонецЦикла;
	
	Для н = 0 По Страница[3-1].Количество() - 1 Цикл
		Значение			= ВернутьДатуИзСтроки(Страница[3-1][н]);
		Строка				= ТЗ[н];	
		Строка.ДатаПлатежа	= Значение;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТЗ", 			ТЗ);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗ.ДатаПлатежа КАК ДатаПлатежа,
	|	ТЗ.ИдентификаторЖКУГИСЖКХ КАК ИдентификаторЖКУГИСЖКХ,
	|	ТЗ.Статус КАК Статус
	|ПОМЕСТИТЬ ВрТ0
	|ИЗ
	|	&ТЗ КАК ТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВрТ0.ДатаПлатежа КАК ДатаПлатежа,
	|	ВрТ0.Статус КАК Статус,
	|	энргИдентификаторыАбонентаГИСЖКХ.Абонент КАК Абонент
	|ПОМЕСТИТЬ ВТ_Оплаты
	|ИЗ
	|	ВрТ0 КАК ВрТ0
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргИдентификаторыАбонентаГИСЖКХ КАК энргИдентификаторыАбонентаГИСЖКХ
	|		ПО ВрТ0.ИдентификаторЖКУГИСЖКХ = энргИдентификаторыАбонентаГИСЖКХ.ИдентификаторЖКУГИСЖКХ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бестИсторияОплатыГИСЖКХ.Организация КАК Организация,
	|	бестИсторияОплатыГИСЖКХ.Район КАК Район,
	|	бестИсторияОплатыГИСЖКХ.Абонент КАК Абонент,
	|	бестИсторияОплатыГИСЖКХ.ДатаПлатежа КАК ДатаПлатежа,
	|	бестИсторияОплатыГИСЖКХ.СуммаПлатежа КАК СуммаПлатежа,
	|	ВТ_Оплаты.Статус КАК Статус
	|ИЗ
	|	ВТ_Оплаты КАК ВТ_Оплаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестИсторияОплатыГИСЖКХ КАК бестИсторияОплатыГИСЖКХ
	|		ПО ВТ_Оплаты.Абонент = бестИсторияОплатыГИСЖКХ.Абонент
	|			И ВТ_Оплаты.ДатаПлатежа = бестИсторияОплатыГИСЖКХ.ДатаПлатежа
	|			И (бестИсторияОплатыГИСЖКХ.Организация = &Организация)
	|			И (бестИсторияОплатыГИСЖКХ.Район = &Район)";
	
	Результат = Запрос.Выполнить();
	Выборка  = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Запись = РегистрыСведений.бестИсторияОплатыГИСЖКХ.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Выборка);
		Если Выборка.Статус = "ОК" Тогда
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ЗагруженоВГИСЖКХ;
		Иначе
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ОшибкаПриЗагрузкеВГИСЖХК;
			Запись.ОписаниеОшибки = Выборка.Статус;
		КонецЕсли;
		Запись.Записать();	
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка данных об оплате завершена!");
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли