&НаКлиенте
Процедура ВыгрузкаМКДКлиент()
	// 11.1.0.2
	НомерСтраницы = 1;
	ExcelApp = Новый COMОбъект("Excel.Application");
	ExcelApp.DisplayAlerts = False;
	Попытка
		Книга = ExcelApp.Workbooks.Open(Файл);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
		Возврат;
	КонецПопытки;	
	
	МассивАдресовМКД	= ВыгрузкаМКДСервер();
	
	Страница = Книга.Worksheets(1);
	//Страница.Name = "Характеристики МКД";
	СчетчикДляИмениФайла = 1;
	НомерСтроки = 3;
	НомерСтрокиНежилых = 3;
	НомерСтрокиЖилых = 3;
	ФайлДляЗаписи = Файл;
	ИмяФайла = Лев(ФайлДляЗаписи, Найти(ФайлДляЗаписи , ".xlsx")-1) + "_";
	Для н = 0 по МассивАдресовМКД.Количество()-1 Цикл
		Страница = Книга.Worksheets(1);
		Если НомерСтроки = 50000 тогда
			Книга.SaveAs(Файл);
			ExcelApp.Quit();
			ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка завершена " + Файл);
			ФайлНовый = ИмяФайла + СчетчикДляИмениФайла + ".xlsx";
			КопироватьФайл(ФайлДляЗаписи , ФайлНовый);
			ФайлДляЗаписи = ФайлНовый;
			ExcelApp = Новый COMОбъект("Excel.Application");
			ExcelApp.DisplayAlerts = False;
			Попытка	
				Книга = ExcelApp.Workbooks.Open(ФайлДляЗаписи);	
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
				Возврат;
			КонецПопытки; 
			Страница = Книга.Worksheets(1);
			НомерСтроки			= 3;
			НомерСтрокиНежилых	= 3;
			НомерСтрокиЖилых	= 3;
			СчетчикДляИмениФайла = СчетчикДляИмениФайла+1;
		КонецЕсли;
		
		Страница.Cells(НомерСтроки,1).value = МассивАдресовМКД[н].Адрес;
		Страница.Cells(НомерСтроки,2).value = Строка(МассивАдресовМКД[н].ФИАС);
		Страница.Cells(НомерСтроки,3).value = МассивАдресовМКД[н].ОКТМО;
		Страница.Cells(НомерСтроки,4).value = МассивАдресовМКД[н].ЧасоваяЗона;
		
		Если МассивАдресовМКД[н].Нежилые.Количество() <> 0 Тогда
			Страница = Книга.Worksheets(2);	
			Для к = 0 По МассивАдресовМКД[н].Нежилые.Количество()-1 Цикл
				Страница.Cells(НомерСтрокиНежилых,1).value = МассивАдресовМКД[н].Адрес;
				Страница.Cells(НомерСтрокиНежилых,2).value = Строка(МассивАдресовМКД[н].Нежилые[к].НомерПомещения);
				НомерСтрокиНежилых = НомерСтрокиНежилых + 1;
			КонецЦикла;
		КонецЕсли;
		
		Если МассивАдресовМКД[н].Жилые.Количество() <> 0 Тогда
			Страница = Книга.Worksheets(3);	
			Для п = 0 По МассивАдресовМКД[н].Жилые.Количество()-1 Цикл
				Страница.Cells(НомерСтрокиЖилых,1).value = МассивАдресовМКД[н].Адрес;
				Страница.Cells(НомерСтрокиЖилых,2).value = Строка(МассивАдресовМКД[н].Жилые[п].НомерПомещения);
				НомерСтрокиЖилых = НомерСтрокиЖилых + 1;
			КонецЦикла;
		КонецЕсли;
		
		НомерСтроки 	= НомерСтроки + 1;
	КонецЦикла;
	
	Книга.SaveAs(Файл);
	ExcelApp.Quit();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка завершена " + Файл);
	
КонецПроцедуры

&НаСервере
Функция ВыгрузкаМКДСервер()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.УстановитьПараметр("Дата",			ПериодВыгрузки);
	Запрос.Текст = ПолучитьТекстЗапросаВыгрузкиМКД();
	
	Пакет = Запрос.ВыполнитьПакет();
	ВыборкаМКД =  Пакет[Пакет.Количество() - 2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаЗон =  Пакет[Пакет.Количество() - 1].Выбрать();
	ВыборкаЗон.Следующий();
	
	СтруктураСтраниц = Новый Структура;
	
	Массив 				= Новый Массив;
	Пока ВыборкаМКД.Следующий() Цикл
		СтруктураМКД = Новый Структура;
		СтруктураМКД.Вставить("Адрес", 			ВыборкаМКД.АдресОЖФ);
		СтруктураМКД.Вставить("ФИАС", 			ВыборкаМКД.ФИАС);
		СтруктураМКД.Вставить("ОКТМО", 			ВыборкаМКД.ОКТМО);
		СтруктураМКД.Вставить("ЧасоваяЗона", 	Строка(ВыборкаЗон.ЧасоваяЗонаOlson));
		
		МассивНежилых	= Новый Массив;
		МассивЖилых		= Новый Массив;
		ВыборкаВидаПомещений = ВыборкаМКД.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВидаПомещений.Следующий() Цикл
			ВыборкаПомещений = ВыборкаВидаПомещений.Выбрать();
			Пока ВыборкаПомещений.Следующий() Цикл
				Если ВыборкаВидаПомещений.ВидПомещения = Перечисления.бестВидыПомещенийГИСЖКХ.ЖилоеПомещение Тогда
					СтруктураКвартиры = Новый Структура;
					СтруктураКвартиры.Вставить("НомерПомещения", 			ВыборкаПомещений.НомерПомещения);
					
					МассивЖилых.Добавить(СтруктураКвартиры);
				ИначеЕсли ВыборкаВидаПомещений.ВидПомещения = Перечисления.бестВидыПомещенийГИСЖКХ.НежилоеПомещение Тогда
					СтруктураНежилая = Новый Структура;
					СтруктураНежилая.Вставить("НомерПомещения", 			ВыборкаПомещений.НомерПомещения);
					
					МассивНежилых.Добавить(СтруктураНежилая);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		СтруктураМКД.Вставить("Жилые", МассивЖилых);
		СтруктураМКД.Вставить("Нежилые", МассивНежилых);
		
		Массив.Добавить(СтруктураМКД);
	КонецЦикла;	
	
	Возврат Массив;
	
КонецФункции

&НаСервере
Функция ПолучитьТекстЗапросаВыгрузкиМКД()
	Возврат  "ВЫБРАТЬ
	         |	бестВыгруженныеМКДГИСЖКХСрезПоследних.МКД КАК МКД,
	         |	бестВыгруженныеМКДГИСЖКХСрезПоследних.ВидПомещения КАК ВидПомещения,
	         |	бестВыгруженныеМКДГИСЖКХСрезПоследних.НомерПомещения КАК НомерПомещения,
	         |	бестВыгруженныеМКДГИСЖКХСрезПоследних.ФИАС КАК ФИАС,
	         |	бестВыгруженныеМКДГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	         |	бестВыгруженныеМКДГИСЖКХСрезПоследних.ОКТМО КАК ОКТМО
	         |ИЗ
	         |	РегистрСведений.бестВыгруженныеМКДГИСЖКХ.СрезПоследних(
	         |			&Дата,
	         |			Организация = &Организация
	         |				И Район = &Район) КАК бестВыгруженныеМКДГИСЖКХСрезПоследних
	         |ГДЕ
