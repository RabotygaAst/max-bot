#Область ТиповыеПроцедурыФункции

&НаКлиенте
Процедура Выгрузить(Команда)
	Отказ = Ложь;
	Если НЕ ЗначениеЗаполнено(ВидВыгрузки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить вид выгрузки!");
		Отказ = Истина;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить организацию!");
		Отказ = Истина;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ПериодВыгрузки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить дату выгрузки!");
		Отказ = Истина;
	КонецЕсли;	
	
	Если НЕ Отказ Тогда
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ДоговорыРСО") тогда
			ВыгрузкаДоговоровКлиент();
		КонецЕсли;
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.МКД") Тогда
			ВыгрузкаМКДКлиент();
		КонецЕсли;
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ЖилыеДома") Тогда
			ВыгрузкаЖДКлиент();
		КонецЕсли;
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ЛицевыеСчета") Тогда
			ВыгрузкаЛицевыхСчетовКлиент();
		КонецЕсли;
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ЗакрытиеЛС") Тогда
			ВыгрузкаЗакрытиеЛицевыхСчетовКлиент();
		КонецЕсли;		
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ПриборыУчета") Тогда 
			ВыгрузкаПриборовУчетаКлиент();
		КонецЕсли;
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ПоказанияПриборовУчета") Тогда
			ВыгрузкаПоказанийКлиент(Ложь);
		КонецЕсли;
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ПоказанияОДПУ") Тогда
			ВыгрузкаПоказанийКлиент(Истина);
		КонецЕсли;
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ПлатежныеДокументы") Тогда
			ВыгрузкаПлатежныхДокументовКлиент();
		КонецЕсли;
		Если ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.Оплата") Тогда
			ВыгрузкаОплатыКлиент();
		КонецЕсли;		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Загрузить(Команда)
	Отказ = Ложь;
	Если НЕ ЗначениеЗаполнено(ВидЗагрузки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить вид загрузки!");
		Отказ = Истина;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить организацию!");
		Отказ = Истина;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ПериодЗагрузки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить дату загрузки!");
		Отказ = Истина;
	КонецЕсли;	
	
	Если НЕ Отказ Тогда
		Если ВидЗагрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ДоговорыРСО") тогда
			ЗагрузкаОтветаПоДоговорамКлиент();
		ИначеЕсли ВидЗагрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.МКД") Тогда
			ЗагрузкаОтветаПоМКДКлиент();
		ИначеЕсли ВидЗагрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ЖилыеДома") Тогда
			ЗагрузкаОтветаПоЖДКлиент();
		ИначеЕсли ВидЗагрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ЛицевыеСчета") Тогда
			ЗагрузкаОтветаПоЛСКлиент();
		ИначеЕсли ВидЗагрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ОЖФДоговоровРСО") Тогда
			ЗагрузкаОЖФКлиент();
		ИначеЕсли ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ЗакрытиеЛС") Тогда
			ЗагрузкаОтветаПоЗакрытымЛСКлиент();
		ИначеЕсли ВидЗагрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ПриборыУчета") Тогда 
			ЗагрузкаОтветаПоПриборыУчетаКлиент();
		ИначеЕсли ВидЗагрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ПоказанияПриборовУчета") Тогда
			ЗагрузкаОтветаПоПоказаниямКлиент();
		ИначеЕсли ВидЗагрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ПоказанияОДПУ") Тогда
			ЗагрузкаОтветаПоПоказаниямКлиент();
		ИначеЕсли ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.ПлатежныеДокументы") Тогда
			ЗагрузкаОтветаПоПДКлиент();
		ИначеЕсли ВидВыгрузки = ПредопределенноеЗначение("Перечисление.бестВидыОперацийГИСЖКХ.Оплата") Тогда
			ЗагрузкаОтветаПоОплатеКлиент();
		КонецЕсли;		
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВернутьДатуИзСтроки(Значение) 
	Если Не Значение = "NULL" Тогда
		Если СтрДлина(Значение) = 8 тогда
			Если Число(Прав(Значение,2)) <= 40 тогда
				ПрефиксГода  ="20";
			иначе
				ПрефиксГода  ="19";
			КонецЕсли; 		
			Год 			= Число(ПрефиксГода +  Прав(Значение,2));
			Месяц  			= Число(Сред(Значение,4,2));
			День 		 	= Число(Лев(Значение,2));
			Возврат Дата(Год,Месяц,День);
		ИначеЕсли СтрДлина(Значение) = 10 тогда
			Год 			= Прав(Значение,4);
			Месяц  			= Число(Сред(Значение,4,2));
			День 		 	= Число(Лев(Значение,2));
			Возврат Дата(Год,Месяц,День);
		ИначеЕсли СтрДлина(Значение) > 10 тогда
			Если Сред(Строка(Значение),3,1) = "." или Сред(Строка(Значение),3,1) = "," Тогда 
				Значение		= Лев(Строка(Значение),10);
				Год 			= Прав(Значение,4);
				Месяц  			= Число(Сред(Значение,4,2));
				День 		 	= Число(Лев(Значение,2));
			Иначе	Значение	= Лев(Строка(Значение),10);
				Год 			= Лев(Значение,4);
				Месяц  			= Число(Сред(Значение,6,2));
				День 		 	= Число(Прав(Значение,2));
				Возврат Дата(Год,Месяц,День);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ФайлНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ДиалогОткрытия = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогОткрытия.ПолноеИмяФайла = Файл;
	СтандартнаяОбработка = Ложь;
	Если ДиалогОткрытия.Выбрать() Тогда
		Файл = ДиалогОткрытия.ПолноеИмяФайла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КаталогЗагрузкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	Режим = РежимДиалогаВыбораФайла.ВыборКаталога; 
	ДиалогОткрытия = Новый ДиалогВыбораФайла(Режим);
	СтандартнаяОбработка = Ложь;
	ДиалогОткрытия.Каталог = ""; 
	ДиалогОткрытия.МножественныйВыбор = Ложь; 
	ДиалогОткрытия.Заголовок = "Выберите каталог"; 
	
	Если ДиалогОткрытия.Выбрать() Тогда 
		КаталогЗагрузки = ДиалогОткрытия.Каталог + "\"; 
	КонецЕсли;
КонецПроцедуры

