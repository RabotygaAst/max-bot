&НаКлиенте
Процедура ВыгрузкаЖДКлиент()
	НомерСтраницы = 1;
	ExcelApp = Новый COMОбъект("Excel.Application");
	ExcelApp.DisplayAlerts = False;
	Попытка
		Книга = ExcelApp.Workbooks.Open(Файл);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
		Возврат;
	КонецПопытки;	
	
	МассивАдресовЖД	= ВыгрузкаЖДСервер();
	
	Страница = Книга.Worksheets(1);
	СчетчикДляИмениФайла = 1;
	НомерСтроки = 3;
	ФайлДляЗаписи = Файл;
	ИмяФайла = Лев(ФайлДляЗаписи, Найти(ФайлДляЗаписи , ".xlsx")-1) + "_";
	Для н = 0 по МассивАдресовЖД.Количество()-1 Цикл
		Страница = Книга.Worksheets(1);
		Если НомерСтроки = 1002 тогда
			Книга.SaveAs(Файл);
			ExcelApp.Quit();
			ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка завершена " + Файл);
			ФайлНовый = ИмяФайла + СчетчикДляИмениФайла + ".xlsx";
			КопироватьФайл(ФайлДляЗаписи , ФайлНовый);
			ФайлДляЗаписи = ФайлНовый;
			ExcelApp = Новый COMОбъект("Excel.Application");
			ExcelApp.DisplayAlerts = False;
			Попытка	
				Книга = ExcelApp.Workbooks.Open(ФайлДляЗаписи);	
			Исключение
				ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось открыть файл. Возможно, он открыт в другом приложении.");
				Возврат;
			КонецПопытки; 
			Страница = Книга.Worksheets(1);
			НомерСтроки = 3;
			СчетчикДляИмениФайла = СчетчикДляИмениФайла+1;
		КонецЕсли;
		
		Страница.Cells(НомерСтроки,1).value = Строка(МассивАдресовЖД[н].Адрес);
		Страница.Cells(НомерСтроки,2).value = Строка(МассивАдресовЖД[н].ФИАС);
		Страница.Cells(НомерСтроки,3).value = "Нет";
		Страница.Cells(НомерСтроки,4).value = "Нет";
		Страница.Cells(НомерСтроки,5).value = МассивАдресовЖД[н].ОКТМО;
		Страница.Cells(НомерСтроки,6).value = Строка(МассивАдресовЖД[н].ЧасоваяЗона);
		
		НомерСтроки 	= НомерСтроки + 1;
	КонецЦикла;
	
	Книга.SaveAs(Файл);
	ExcelApp.Quit();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка завершена " + Файл);
КонецПроцедуры

&НаСервере
Функция ВыгрузкаЖДСервер()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.УстановитьПараметр("Дата",			ПериодВыгрузки);
	Запрос.Текст = ПолучитьТекстЗапросаВыгрузкиЖД();
	
	Пакет = Запрос.ВыполнитьПакет();
	ВыборкаЖД	=  Пакет[Пакет.Количество() - 2].Выбрать();
	ВыборкаЗон	=  Пакет[Пакет.Количество() - 1].Выбрать();
	ВыборкаЗон.Следующий();
	
	СтруктураСтраниц = Новый Структура;
	
	Массив 				= Новый Массив;
	Пока ВыборкаЖД.Следующий() Цикл
		СтруктураЖД = Новый Структура;
		СтруктураЖД.Вставить("Адрес", 			ВыборкаЖД.АдресОЖФ);
		СтруктураЖД.Вставить("ФИАС", 			ВыборкаЖД.ФИАС);
		СтруктураЖД.Вставить("ОКТМО", 			ВыборкаЖД.ОКТМО);
		СтруктураЖД.Вставить("ЧасоваяЗона", 	Строка(ВыборкаЗон.ЧасоваяЗонаOlson));
		Массив.Добавить(СтруктураЖД);
	КонецЦикла;	
	
	Возврат Массив;
КонецФункции

