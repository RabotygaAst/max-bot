&НаСервере
Процедура ЗагрузитьОтветПоМКД(МКД)
	СоотвествиеКолонок  = Новый Соответствие;
	СоотвествиеКолонок.Вставить("ФИАС", 	2-1);
	СоотвествиеКолонок.Вставить("Статус",	6-1);
	
	ТЗ  = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("ФИАС",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(36)));
	ТЗ.Колонки.Добавить("Статус",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	ВсегоСтрок  = МКД[0].количество();
	Для Счетчик = 1 По ВсегоСтрок Цикл
		НоваяСтрока = ТЗ.Добавить();
	КонецЦикла;
	
	Для Каждого стр из СоотвествиеКолонок Цикл 
		ТЗ.ЗагрузитьКолонку(МКД[стр.Значение], стр.Ключ);
	КонецЦикла;
	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Таблица", 	ТЗ);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 		Район);
	Запрос.УстановитьПараметр("Дата", 		ПериодЗагрузки);
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица.ФИАС КАК ФИАС,
	               |	Таблица.Статус КАК Статус
	               |ПОМЕСТИТЬ ВрТ0
	               |ИЗ
	               |	&Таблица КАК Таблица
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.Период КАК Период,
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.Организация КАК Организация,
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.Район КАК Район,
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.МКД КАК МКД,
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.ВидПомещения КАК ВидПомещения,
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.НомерПомещения КАК НомерПомещения,
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.ФИАС КАК ФИАС,
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.ОКТМО КАК ОКТМО,
	               |	ВрТ0.Статус КАК Статус
	               |ИЗ
	               |	ВрТ0 КАК ВрТ0
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бестВыгруженныеМКДГИСЖКХ.СрезПоследних(
	               |				&Дата,
	               |				Организация = &Организация
	               |					И Район = &Район
	               |					И ФИАС В
	               |						(ВЫБРАТЬ
	               |							ВТ.ФИАС
	               |						ИЗ
	               |							ВрТ0 КАК ВТ)) КАК бестВыгруженныеМКДГИСЖКХСрезПоследних
	               |		ПО ВрТ0.ФИАС = бестВыгруженныеМКДГИСЖКХСрезПоследних.ФИАС
	               |ГДЕ
	               |	бестВыгруженныеМКДГИСЖКХСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)";
	
	Результат 		= Запрос.Выполнить();
	Выгрузка		= Результат.Выбрать();
	
	Пока Выгрузка.Следующий() Цикл
		Запись = РегистрыСведений.бестВыгруженныеМКДГИСЖКХ.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Выгрузка);
		Если Выгрузка.Статус = "ОК" Тогда
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ЗагруженоВГИСЖКХ;
		Иначе
			Запись.Статус = Перечисления.бестСтатусыРаботыСГИСЖКХ.ОшибкаПриЗагрузкеВГИСЖХК;
			Запись.ОписаниеОшибки = Выгрузка.Статус;
		КонецЕсли;
		Запись.Записать();
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Загрузка данных об МКД завершена!");
КонецПроцедуры

