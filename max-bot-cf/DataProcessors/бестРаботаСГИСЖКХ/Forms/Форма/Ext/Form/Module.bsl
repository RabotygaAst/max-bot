		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	Книга.SaveAs(ФайлДляЗаписи);
	ExcelApp.Quit();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Выгрузка договоров завершена " + ТекущаяДата());
	
	Возврат;	
КонецПроцедуры

&НаСервере
Функция ВыгрузкаДоговоровСервер()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Район",			Район);
	Запрос.УстановитьПараметр("Дата",			ПериодВыгрузки);
	Запрос.Текст = ПолучитьТекстЗапросаВыгрузкиДоговоров();
	
	Пакет = Запрос.ВыполнитьПакет();
	ВыгрузкаАбонентов = Пакет[Пакет.Количество() - 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыгрузкаСроков = Пакет[Пакет.Количество() - 2].Выбрать();
	ВыгрузкаСроков.Следующий();
	
	
	Массив = Новый Массив;
	Пока ВыгрузкаАбонентов.Следующий() Цикл
		Структура = Новый Структура;
		
		Структура.Вставить("ИнойИдентификатор",					Строка(ВыгрузкаАбонентов.АбонентЛицевойСчет));
		Структура.Вставить("СрокПредставленияДокументов",		ВыгрузкаСроков.СрокПредставленияДокументов);
		Структура.Вставить("ТипСрокаПредставленияДокументов",	ВыгрузкаСроков.ТипСрокаПредставленияДокументов);
		Структура.Вставить("СрокОплаты",						ВыгрузкаСроков.СрокОплаты);
		Структура.Вставить("ТипСрокаОплаты",					ВыгрузкаСроков.ТипСрокаОплаты);
		Структура.Вставить("ИдентификаторДоговораГИСЖКХ",		Строка(ВыгрузкаАбонентов.ИдентификаторДоговораГИСЖКХ));
		Структура.Вставить("ФИАС",								Строка(ВыгрузкаАбонентов.ФИАС));
		Структура.Вставить("ТипДома",							ВыгрузкаАбонентов.ТипДома);
		Структура.Вставить("НомерПомещения",					ВыгрузкаАбонентов.НомерПомещения);
		//Структура.Вставить("Идентификатор",						ВыгрузкаАбонентов.ИдентификаторДома);
		Структура.Вставить("АдресОЖФ",							ВыгрузкаАбонентов.АдресОЖФ);
		Структура.Вставить("ДатаЗаключения",					ВыгрузкаАбонентов.ДатаЗаключения);
		Структура.Вставить("АбонентЛицевойСчет",				СокрЛП(ВыгрузкаАбонентов.АбонентЛицевойСчет));
		Структура.Вставить("ВтораяСторона",						ВыгрузкаАбонентов.ВтораяСторона);
		Структура.Вставить("ТипСхемы",							ВыгрузкаАбонентов.ТипСхемы);
		
		МассивУслуг = Новый Массив;
		ВыборкаУслуг = ВыгрузкаАбонентов.Выбрать();
		Пока ВыборкаУслуг.Следующий() Цикл
			СтруктураУслуги = Новый Структура;	
			СтруктураУслуги.Вставить("Услуга",					ВыборкаУслуг.Услуга);
			СтруктураУслуги.Вставить("УслугаЖКХ",				ВыборкаУслуг.УслугаЖКХ);
			СтруктураУслуги.Вставить("КоммунальныйРесурс",		ВыборкаУслуг.КоммунальныйРесурс);
			СтруктураУслуги.Вставить("ДатаНачалаПоставки",		?(ЗначениеЗаполнено(ВыборкаУслуг.ДатаНачалаПоставки),ВыборкаУслуг.ДатаНачалаПоставки,""));
			СтруктураУслуги.Вставить("ДатаОкончанияПоставки",	?(ЗначениеЗаполнено(ВыборкаУслуг.ДатаОкончанияПоставки),ВыборкаУслуг.ДатаОкончанияПоставки,""));
			МассивУслуг.Добавить(СтруктураУслуги);
		КонецЦикла;
		Структура.Вставить("Услуги",							МассивУслуг);
		
		
		Массив.Добавить(Структура);      
	КонецЦикла;
	Возврат Массив;
КонецФункции

&НаСервере
Функция ПолучитьТекстЗапросаВыгрузкиДоговоров()
	Возврат "ВЫБРАТЬ
	        |	бестВыгруженныеДоговорыГИСЖКХСрезПоследних.Абонент КАК Абонент,
	        |	бестВыгруженныеДоговорыГИСЖКХСрезПоследних.ФИАС КАК ФИАС,
	        |	бестВыгруженныеДоговорыГИСЖКХСрезПоследних.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ,
	        |	бестВыгруженныеДоговорыГИСЖКХСрезПоследних.ТипДома КАК ТипДома,
	        |	бестВыгруженныеДоговорыГИСЖКХСрезПоследних.НомерПомещения КАК НомерПомещения,
	        |	бестВыгруженныеДоговорыГИСЖКХСрезПоследних.АдресОЖФ КАК АдресОЖФ,
	        |	бестВыгруженныеДоговорыГИСЖКХСрезПоследних.ДатаЗаключения КАК ДатаЗаключения,
	        |	бестВыгруженныеДоговорыГИСЖКХСрезПоследних.ТипСхемы КАК ТипСхемы
	        |ПОМЕСТИТЬ ВТ_ДоговораКВыгрузке
	        |ИЗ
	        |	РегистрСведений.бестВыгруженныеДоговорыГИСЖКХ.СрезПоследних(
	        |			&Дата,
	        |			Организация = &Организация
	        |				И Район = &Район) КАК бестВыгруженныеДоговорыГИСЖКХСрезПоследних
	        |ГДЕ
	        |	бестВыгруженныеДоговорыГИСЖКХСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.бестСтатусыРаботыСГИСЖКХ.НоваяЗапись)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.Абонент КАК Абонент,
	        |	бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.Услуга КАК Услуга,
	        |	бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.УслугаЖКХ КАК УслугаЖКХ,
	        |	бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.КоммунальныйРесурс КАК КоммунальныйРесурс,
	        |	МАКСИМУМ(бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.ДатаНачалаПоставки) КАК ДатаНачалаПоставки,
	        |	МАКСИМУМ(бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.ДатаОкончанияПоставки) КАК ДатаОкончанияПоставки
	        |ПОМЕСТИТЬ ВТ_Услуги
	        |ИЗ
	        |	РегистрСведений.бестВыгруженныеУслугиДоговоровГИСЖКХ.СрезПоследних(
	        |			&Дата,
	        |			Организация = &Организация
	        |				И Район = &Район
	        |				И Абонент В
	        |					(ВЫБРАТЬ
	        |						ВТ.Абонент
	        |					ИЗ
	        |						ВТ_ДоговораКВыгрузке КАК ВТ)) КАК бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.Абонент,
	        |	бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.Услуга,
	        |	бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.УслугаЖКХ,
	        |	бестВыгруженныеУслугиДоговоровГИСЖКХСрезПоследних.КоммунальныйРесурс
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	МАКСИМУМ(бестСрокиВнесенияОплатыСрезПоследних.Срок) КАК СрокОплаты,
	        |	МАКСИМУМ(бестСрокиВнесенияОплатыСрезПоследних.ТипСрока) КАК ТипСрокаОплаты,
	        |	МАКСИМУМ(бестСрокиВыставленияПлатежныхДокументовСрезПоследних.Срок) КАК СрокПредставленияДокументов,
	        |	МАКСИМУМ(бестСрокиВыставленияПлатежныхДокументовСрезПоследних.ТипСрока) КАК ТипСрокаПредставленияДокументов
	        |ИЗ
	        |	РегистрСведений.бестСрокиВнесенияОплаты.СрезПоследних(
	        |			&Дата,
	        |			Организация = &Организация
	        |				И Район = &Район) КАК бестСрокиВнесенияОплатыСрезПоследних,
	        |	РегистрСведений.бестСрокиВыставленияПлатежныхДокументов.СрезПоследних(
	        |			&Дата,
	        |			Организация = &Организация
	        |				И Район = &Район) КАК бестСрокиВыставленияПлатежныхДокументовСрезПоследних
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВТ_ДоговораКВыгрузке.Абонент КАК Абонент,
	        |	ВТ_ДоговораКВыгрузке.ФИАС КАК ФИАС,
	        |	ВТ_ДоговораКВыгрузке.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ,
	        |	ВТ_Услуги.Услуга КАК Услуга,
	        |	ВТ_Услуги.УслугаЖКХ КАК УслугаЖКХ,
	        |	ВТ_Услуги.КоммунальныйРесурс КАК КоммунальныйРесурс,
	        |	ВТ_Услуги.ДатаНачалаПоставки КАК ДатаНачалаПоставки,
	        |	ВТ_ДоговораКВыгрузке.ТипДома КАК ТипДома,
	        |	ВТ_ДоговораКВыгрузке.НомерПомещения КАК НомерПомещения,
	        |	ВТ_ДоговораКВыгрузке.АдресОЖФ КАК АдресОЖФ,
	        |	ВТ_Услуги.ДатаОкончанияПоставки КАК ДатаОкончанияПоставки,
	        |	ВТ_ДоговораКВыгрузке.ДатаЗаключения КАК ДатаЗаключения,
	        |	ВТ_ДоговораКВыгрузке.Абонент.ЛицевойСчет КАК АбонентЛицевойСчет,
			//|	ВЫБОР
			//|		КОГДА ВТ_ДоговораКВыгрузке.Абонент.Домовладение
			//|			ТОГДА ""Собственник или пользователь жилого дома (домовладения)""
			//|		ИНАЧЕ ""Собственник или пользователь жилого (нежилого) помещения в МКД""
			//|	КОНЕЦ КАК ВтораяСторона,
			|	ВЫБОР
	        |		КОГДА ВТ_ДоговораКВыгрузке.ТипДома = ""ЖД""
	        |			ТОГДА ""Собственник или пользователь жилого дома (домовладения)""
	        |		ИНАЧЕ ""Собственник или пользователь жилого (нежилого) помещения в МКД""
	        |	КОНЕЦ КАК ВтораяСторона,
	        |	ВТ_ДоговораКВыгрузке.ТипСхемы КАК ТипСхемы
	        |ИЗ
	        |	ВТ_ДоговораКВыгрузке КАК ВТ_ДоговораКВыгрузке
	        |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Услуги КАК ВТ_Услуги
	        |		ПО ВТ_ДоговораКВыгрузке.Абонент = ВТ_Услуги.Абонент
	        |ИТОГИ
	        |	МАКСИМУМ(ФИАС),
	        |	МАКСИМУМ(ИдентификаторДоговораГИСЖКХ),
	        |	МАКСИМУМ(ТипДома),
	        |	МАКСИМУМ(НомерПомещения),
	        |	МАКСИМУМ(АдресОЖФ),
	        |	МАКСИМУМ(ДатаЗаключения),
	        |	МАКСИМУМ(АбонентЛицевойСчет),
	        |	МАКСИМУМ(ВтораяСторона),
	        |	МАКСИМУМ(ТипСхемы)
	        |ПО
	        |	Абонент";
	
КонецФункции

&НаКлиенте
Процедура ЗагрузкаОтветаПоДоговорамКлиент()
	
	Попытка
		СерверExcel 					= Новый COMОбъект("Excel.Application");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приложение excel не установлено");
		Возврат;
	КонецПопытки;
	
	НайденныеФайлы = НайтиФайлы(КаталогЗагрузки, "*.xlsx");
	
	ДанныеФайлов  = Новый Структура;
	Для н =0 по НайденныеФайлы.Количество() - 1 Цикл 					
		//СерверExcel.DisplayAlerts 			= 0;
		
		ФайлХЛС			= СерверExcel.Application.Workbooks.Open(НайденныеФайлы[н].ПолноеИмя);
		
		ЛистЭксель		= ФайлХЛС.Sheets(1); // договора
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область			= СерверExcel.Range(ЛистЭксель.Cells(3,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));
		Страница1Книги	= Область.Value.Выгрузить();
		
		ЛистЭксель		= ФайлХЛС.Sheets(3);  // услуги
		ВсегоСтрок		= ЛистЭксель.Cells.SpecialCells(11).Row;	
		ВсегоКолонок	= ЛистЭксель.Cells.SpecialCells(11).Column;
		Область 		= СерверExcel.Range(ЛистЭксель.Cells(2,1), ЛистЭксель.Cells(ВсегоСтрок,ВсегоКолонок));		
		Страница2Книги	= Область.Value.Выгрузить();
		
		ДанныеФайлов.Вставить("Файл" + СтрЗаменить(н, Символы.НПП,""),Новый Структура("Страница1,Страница2",Страница1Книги,Страница2Книги));
		
		ФайлХЛС.close();
		
	КонецЦикла;	
	
	СерверExcel.quit();
	ЗагрузитьОтвет(ДанныеФайлов);
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтвет(ДанныеФайла)
	Для каждого стр из ДанныеФайла Цикл
		ЗагрузитьОтветПоДоговорам(стр.Значение);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОтветПоДоговорам(СтруктураСтраниц)
	
	Страница1 = СтруктураСтраниц.Страница1;
	Страница2 = СтруктураСтраниц.Страница2;
	СоотвествиеКолонок  = Новый Соответствие;
	СоотвествиеКолонок.Вставить("ГУИДДоговора",					1-1);
	СоотвествиеКолонок.Вставить("ИдентификаторДоговораГИСЖКХ",	45-1);
	СоотвествиеКолонок.Вставить("Статус",						46-1);	
	
	ТЗСтраница1  = Новый ТаблицаЗначений;
	ТЗСтраница1.Колонки.Добавить("ГУИДДоговора",					Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(18,ДопустимаяДлина.Фиксированная)));
	ТЗСтраница1.Колонки.Добавить("ИдентификаторДоговораГИСЖКХ",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(36)));
	ТЗСтраница1.Колонки.Добавить("Статус",							Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	ЗаполнитьТЗ(Страница1, СоотвествиеКолонок, ТЗСтраница1);
	//Возврат;
	
	// нужно ли загружать подтверждение услуг???
	СоотвествиеКолонок  = Новый Соответствие;
	СоотвествиеКолонок.Вставить("ГУИДДоговора",			1-1);
	СоотвествиеКолонок.Вставить("УслугаЖКХ",			2-1);
	СоотвествиеКолонок.Вставить("КоммунальныйРесурс",	3-1);	
	СоотвествиеКолонок.Вставить("Статус",				9-1);
	
	ТЗСтраница2  = Новый ТаблицаЗначений;
	ТЗСтраница2.Колонки.Добавить("ГУИДДоговора",		Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(18, ДопустимаяДлина.Фиксированная)));
	ТЗСтраница2.Колонки.Добавить("УслугаЖКХ",			Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(100)));
	ТЗСтраница2.Колонки.Добавить("КоммунальныйРесурс",	Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(100)));
	ТЗСтраница2.Колонки.Добавить("Статус",				Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(250)));
	
	ЗаполнитьТЗ(Страница2, СоотвествиеКолонок, ТЗСтраница2);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", 		ПериодЗагрузки);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	Запрос.УстановитьПараметр("Район", 			Район);
	Запрос.УстановитьПараметр("Страница1", 		ТЗСтраница1);
	Запрос.УстановитьПараметр("Страница2", 		ТЗСтраница2);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Страница1.ГУИДДоговора КАК ЛС,
	|	Страница1.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ,
	|	Страница1.Статус КАК Статус
	|ПОМЕСТИТЬ ВрСтраница1
	|ИЗ
	|	&Страница1 КАК Страница1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВрСтраница1.ЛС КАК ЛС,
	|	ВрСтраница1.ИдентификаторДоговораГИСЖКХ КАК ИдентификаторДоговораГИСЖКХ,
	|	ВрСтраница1.Статус КАК Статус,
	|	энргАбоненты.Ссылка КАК Абонент
	|ПОМЕСТИТЬ ВТ_Абоненты
	|ИЗ
	|	ВрСтраница1 КАК ВрСтраница1
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|		ПО (энргАбоненты.ЛицевойСчет ПОДОБНО """" + ВрСтраница1.ЛС + ""%"")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Страница2.ГУИДДоговора КАК ГУИДДоговора,
	|	Страница2.УслугаЖКХ КАК УслугаЖКХ,
	|	Страница2.КоммунальныйРесурс КАК КоммунальныйРесурс,
	|	Страница2.Статус КАК Статус
	|ПОМЕСТИТЬ ВрСтраница2
	|ИЗ
	|	&Страница2 КАК Страница2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВрСтраница2.ГУИДДоговора КАК ГУИДДоговора,
