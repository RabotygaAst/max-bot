	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТаблицаДанныхФайла.IDСтроки КАК IDСтроки,
		|	ТаблицаДанныхФайла.ПриборУчета КАК НомерПрибораУчетаБыло,
		|	ТаблицаДанныхФайла.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ТаблицаДанныхФайла.Показания КАК ТекущиеПоказания,
		|	""Не найдена тарифная зона"" КАК ОписаниеОшибки
		|ПОМЕСТИТЬ НеНайденныеТарифныеЗоны
		|ИЗ
		|	ТаблицаДанныхФайла КАК ТаблицаДанныхФайла
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КоличествоСтрокПоПриборуИзВнешнихДанных КАК КоличествоСтрокПоПриборуИзВнешнихДанных
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ КоличествоСтрокПоПриборуИзВнутреннихДанных КАК КоличествоСтрокПоПриборуИзВнутреннихДанных
		|			ПО КоличествоСтрокПоПриборуИзВнешнихДанных.НомерПрибораУчетаБыло = КоличествоСтрокПоПриборуИзВнутреннихДанных.ЗаводскойНомер
		|				И НЕ КоличествоСтрокПоПриборуИзВнешнихДанных.КоличествоСтрок = КоличествоСтрокПоПриборуИзВнутреннихДанных.КоличествоСтрок
		|		ПО ТаблицаДанныхФайла.ПриборУчета = КоличествоСтрокПоПриборуИзВнешнихДанных.НомерПрибораУчетаБыло");
КонецПроцедуры

Процедура ДобавитьТекстЗапросаПриборУчетаНаНесколькихПомещениях(Схема)
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеПоПриборамИтог.ЗаводскойНомер КАК ЗаводскойНомер,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДанныеПоПриборамИтог.КлючПомещения) КАК КоличествоПомещений
	|ПОМЕСТИТЬ КоличествоПомещенийПоЗаводскомуНомеру
	|ИЗ
	|	ДанныеПоПриборамИтог КАК ДанныеПоПриборамИтог
	|ГДЕ
	|	НЕ ДанныеПоПриборамИтог.ЗаводскойНомер В
	|				(ВЫБРАТЬ
	|					НеНайденныеПриборы.НомерПрибораУчетаБыло КАК НомерПрибораУчетаБыло
	|				ИЗ
	|					НеНайденныеПриборы КАК НеНайденныеПриборы)
	|	И НЕ ДанныеПоПриборамИтог.ЗаводскойНомер В
	|				(ВЫБРАТЬ
	|					НеНайденныеТарифныеЗоны.НомерПрибораУчетаБыло КАК НомерПрибораУчетаБыло
	|				ИЗ
	|					НеНайденныеТарифныеЗоны КАК НеНайденныеТарифныеЗоны)
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеПоПриборамИтог.ЗаводскойНомер
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДанныеПоПриборамИтог.КлючПомещения) > 1");

	
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаДанныхФайла.IDСтроки КАК IDСтроки,
	|	ТаблицаДанныхФайла.ПриборУчета КАК НомерПрибораУчетаБыло,
	|	ТаблицаДанныхФайла.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ТаблицаДанныхФайла.Показания КАК ТекущиеПоказания,
	|	""Не найдена тарифная зона"" КАК ОписаниеОшибки
	|ПОМЕСТИТЬ ПриборыУчетаНаНесколькихПомещениях
	|ИЗ
	|	КоличествоПомещенийПоЗаводскомуНомеру КАК КоличествоПомещенийПоЗаводскомуНомеру
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаДанныхФайла КАК ТаблицаДанныхФайла
	|		ПО КоличествоПомещенийПоЗаводскомуНомеру.ЗаводскойНомер = ТаблицаДанныхФайла.ПриборУчета");
КонецПроцедуры

Процедура ДобавитьТекстЗапросаОбъединенияНенайденныхДанных(Схема)
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	ВложенныйЗапрос.IDСтроки КАК IDСтроки,
		|	ВложенныйЗапрос.НомерПрибораУчетаБыло КАК НомерПрибораУчетаБыло,
		|	ВложенныйЗапрос.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ВложенныйЗапрос.ТекущиеПоказания КАК ТекущиеПоказания,
		|	ВложенныйЗапрос.ОписаниеОшибки КАК ОписаниеОшибки
		|ПОМЕСТИТЬ НеНайденныеДанныеИзВнешнихДанных
		|ИЗ
		|	(ВЫБРАТЬ
		|		НеНайденныеПриборы.IDСтроки КАК IDСтроки,
		|		НеНайденныеПриборы.НомерПрибораУчетаБыло КАК НомерПрибораУчетаБыло,
		|		НеНайденныеПриборы.ТарифнаяЗона КАК ТарифнаяЗона,
		|		НеНайденныеПриборы.ТекущиеПоказания КАК ТекущиеПоказания,
		|		НеНайденныеПриборы.ОписаниеОшибки КАК ОписаниеОшибки
		|	ИЗ
		|		НеНайденныеПриборы КАК НеНайденныеПриборы
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		НеНайденныеТарифныеЗоны.IDСтроки,
		|		НеНайденныеТарифныеЗоны.НомерПрибораУчетаБыло,
		|		НеНайденныеТарифныеЗоны.ТарифнаяЗона,
		|		НеНайденныеТарифныеЗоны.ТекущиеПоказания,
		|		НеНайденныеТарифныеЗоны.ОписаниеОшибки
		|	ИЗ
		|		НеНайденныеТарифныеЗоны КАК НеНайденныеТарифныеЗоны
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ПриборыУчетаНаНесколькихПомещениях.IDСтроки,
		|		ПриборыУчетаНаНесколькихПомещениях.НомерПрибораУчетаБыло,
		|		ПриборыУчетаНаНесколькихПомещениях.ТарифнаяЗона,
		|		ПриборыУчетаНаНесколькихПомещениях.ТекущиеПоказания,
		|		ПриборыУчетаНаНесколькихПомещениях.ОписаниеОшибки
		|	ИЗ
		|		ПриборыУчетаНаНесколькихПомещениях КАК ПриборыУчетаНаНесколькихПомещениях) КАК ВложенныйЗапрос"); 	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаПриборыИзВнешнихДанныхДляСвязи(Схема)
	Пакет  			= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	ТаблицаДанныхФайла.IDСтроки КАК IDСтроки,
		|	ТаблицаДанныхФайла.ПриборУчета КАК ПриборУчета,
		|	ТаблицаДанныхФайла.ТарифнаяЗона КАК ТарифнаяЗона,
		|	ТаблицаДанныхФайла.Показания КАК Показания
		|ПОМЕСТИТЬ ВнешниеПриборыДляСвязи
		|ИЗ
		|	ТаблицаДанныхФайла КАК ТаблицаДанныхФайла
		|ГДЕ
		|	НЕ ТаблицаДанныхФайла.ПриборУчета В
		|				(ВЫБРАТЬ
		|					НеНайденныеДанныеИзВнешнихДанных.НомерПрибораУчетаБыло КАК НомерПрибораУчетаБыло
		|				ИЗ
		|					НеНайденныеДанныеИзВнешнихДанных КАК НеНайденныеДанныеИзВнешнихДанных)");
КонецПроцедуры


Функция НайтиСвязанныеДокументы(ДокументОснование) Экспорт
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргОбходнойЛист.Ссылка КАК Ссылка,
		|	энргОбходнойЛист.Район КАК Район
		|ИЗ
		|	Документ.энргОбходнойЛист КАК энргОбходнойЛист
		|ГДЕ
		|	энргОбходнойЛист.ДокументОснование = &ДокументОснование";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование.Ссылка);
	
	РезультатЗапроса 	= Запрос.Выполнить(); 	
	Выборка 			= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Район, Выборка.Ссылка.ПолучитьОбъект());
	КонецЦикла;
	
	Возврат Результат;		
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ДесериализацияДанных

Функция ДесериализоватьФайл(АдресВХ) Экспорт 
	ДвоичныеДанные 	= ПолучитьИзВременногоХранилища(АдресВХ); 	
	тПуть 			= ПолучитьИмяВременногоФайла("xml"); 
	ДвоичныеДанные.Записать(тПуть);
	
	Парсер = Новый ЧтениеXML;
	Парсер.ОткрытьФайл(тПуть);
	
	Построитель 	= Новый ПостроительDOM; 
	Документик 		= Построитель.Прочитать(Парсер); 	
	ТаблицаДанных 	= НоваяТаблицаДесериализированныхДанных();
	
	Сутки 	= Справочники.энргТарифныеЗоны.БезРазбивки;
	День 	= Справочники.энргТарифныеЗоны.День;
	Ночь 	= Справочники.энргТарифныеЗоны.Ночь;
	
	ИндексСтроки = -1;
	
	СписокЗаводскихНомеров = Документик.ПервыйДочерний.ПервыйДочерний.ДочерниеУзлы;
	Для Каждого ЭлементСекции из СписокЗаводскихНомеров Цикл
		Если ЭлементСекции.ИмяУзла = "element" и ЭлементСекции.Атрибуты.ПолучитьИменованныйЭлемент("measuringtype").Значение = "0" Тогда
			
			СекцияЗаводскойНомерПУ 	= ЭлементСекции.Атрибуты.ПолучитьИменованныйЭлемент("serial");
			
			ЗаводскойНомер			= СекцияЗаводскойНомерПУ.Значение;
			ИдентификаторСтроки		= "" + Новый УникальныйИдентификатор;
			СписокТарифныхЗон 		= СекцияЗаводскойНомерПУ.ЭлементВладелец.ДочерниеУзлы;
			
			КоличествоЗон = 0;
			Для Каждого ЭлементСекцииТарифныхЗон из СписокТарифныхЗон Цикл
				ВспомогательныеПараметры = Новый Структура("IDСтроки, ПриборУчета, ТарифнаяЗона", ИдентификаторСтроки, ЗаводскойНомер);
				АтрибутCode = ЭлементСекцииТарифныхЗон.Атрибуты.ПолучитьИменованныйЭлемент("code");
				
				Если АтрибутCode.Значение = "2021" Тогда
					// День/Сутки
					
					СписокПоказаний = АтрибутCode.ЭлементВладелец.ДочерниеУзлы;
					ВспомогательныеПараметры.ТарифнаяЗона = Сутки;
					ДобавитьСтрокуВТаблицуДанных(СписокПоказаний, ТаблицаДанных, ИндексСтроки, КоличествоЗон, ВспомогательныеПараметры);					
				ИначеЕсли  АтрибутCode.Значение = "2022" Тогда
					// Ночь					
					
					СписокПоказаний = АтрибутCode.ЭлементВладелец.ДочерниеУзлы;
					ВспомогательныеПараметры.ТарифнаяЗона = Ночь;
					ДобавитьСтрокуВТаблицуДанных(СписокПоказаний, ТаблицаДанных, ИндексСтроки, КоличествоЗон, ВспомогательныеПараметры);					
					
				Иначе
					Продолжить;					
				КонецЕсли; 
				
			КонецЦикла; 
			
			Если КоличествоЗон = 2 Тогда				
				
				// Если есть ночь, то прибор двухтарфиный и в первой строке надо заменить тарифную зону с суток на день				
				СтрокаСуток = ТаблицаДанных[ИндексСтроки - 1];
				Если СтрокаСуток.ТарифнаяЗона = Ночь Тогда 					 
					СтрокаСуток = ТаблицаДанных[ИндексСтроки];					
				КонецЕсли;
				СтрокаСуток.ТарифнаяЗона = День;
				
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЦикла;
	
	Парсер.Закрыть();
	
	Возврат ТаблицаДанных;	 	
КонецФункции

Процедура ДобавитьСтрокуВТаблицуДанных(СписокПоказаний, ТаблицаДанных, ИндексСтроки, КоличествоЗон, ВспомогательныеПараметры)
	
	КоличествоСтрок = СписокПоказаний.Количество();
	Если КоличествоСтрок = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	ПоследняяСтрокаПоказаний = СписокПоказаний[КоличествоСтрок - 1];
		
	НСтрока = ТаблицаДанных.Добавить();
	ЗаполнитьЗначенияСвойств(НСтрока, ВспомогательныеПараметры);	
	НСтрока.Показания = ПоследняяСтрокаПоказаний.ТекстовоеСодержимое;	
	
	ИндексСтроки 	= ИндексСтроки + 1;
	КоличествоЗон 	= КоличествоЗон + 1;
	
КонецПроцедуры

#КонецОбласти

Функция НоваяТаблицаДесериализированныхДанных() Экспорт
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("IDСтроки"			, ОбщегоНазначения.ОписаниеТипаСтрока(36));
	Таблица.Колонки.Добавить("ТарифнаяЗона"		, Новый ОписаниеТипов("СправочникСсылка.энргТарифныеЗоны"));
	Таблица.Колонки.Добавить("ПриборУчета"		, ОбщегоНазначения.ОписаниеТипаСтрока(50));
	Таблица.Колонки.Добавить("Показания"		, ОбщегоНазначения.ОписаниеТипаЧисло(15, 6));	
	Таблица.Колонки.Добавить("СтрокаЗаписана"	, Новый ОписаниеТипов("Булево"));	
	
	Возврат Таблица;
КонецФункции

