#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

#Область РегламентноеЗадание

// Только для загрузки из регламентного задания
//	- не использует транзакцию и попытку, они уже определены в вызывающей процедуре 
Процедура ЗагрузитьПоказанияИзРегламентногоЗадания(ДокументОснование, АдресВХ) Экспорт	
	ТаблицаДанных 			= ДесериализоватьФайл(АдресВХ);
	СвязанныеДокументы 		= НайтиСвязанныеДокументы(ДокументОснование);
	ДокументыПроведения 	= Новый Соответствие;
	РезультатПакет 			= ДействующиеТочкиИИхПриборы(ДокументОснование.Дата, ДокументОснование.Организация, ТаблицаДанных); 
	
	КоличествоПакетов 		= РезультатПакет.Количество();
	ЗафиксироватьНеНайденныеДанные(ДокументОснование, РезультатПакет[КоличествоПакетов - 2]);
	ЗафиксироватьНайденныеДанные(ДокументОснование, РезультатПакет[КоличествоПакетов - 1], СвязанныеДокументы, ДокументыПроведения);	
	ПровестиМодифицированныеДокументы(ДокументыПроведения);
КонецПроцедуры
	
#КонецОбласти

#Область ОбработчикиЗагрузки

Функция ЗагрузитьПоказания(ДокументОснование, АдресВХ) Экспорт
	ДокументОснование.НеЗагруженныеДанныеНеЗагруженныеПоказания.Очистить();
	ДокументОснование.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона.Очистить();
	
	ТаблицаДанных = ДесериализоватьФайл(АдресВХ);
	ОбработатьТаблицуВнешнихДанных(ДокументОснование, ТаблицаДанных);
КонецФункции
	
#КонецОбласти   

#Область ОбработкаДанных

Процедура ОбработатьТаблицуВнешнихДанных(ДокументОснование, ТаблицаДанных) Экспорт	
	СвязанныеДокументы 		= НайтиСвязанныеДокументы(ДокументОснование);
	ДокументыПроведения 	= Новый Соответствие;
	
	РезультатПакет 			= ДействующиеТочкиИИхПриборы(ДокументОснование.Дата, ДокументОснование.Организация, ТаблицаДанных);	
	КоличествоПакетов 		= РезультатПакет.Количество();
	
	МожноПереименоватьФайл 	= Ложь;
	НачатьТранзакцию();		
	Попытка
		ОчиститьТабличныеЧастиСвязанныхДокументов(СвязанныеДокументы);
		
		ЗафиксироватьНеНайденныеДанные(ДокументОснование, РезультатПакет[КоличествоПакетов - 2]);
		ЗафиксироватьНайденныеДанные(ДокументОснование, РезультатПакет[КоличествоПакетов - 1], СвязанныеДокументы, ДокументыПроведения);
		
		ПровестиМодифицированныеДокументы(ДокументыПроведения);
		ЗафиксироватьТранзакцию();
		
		МожноПереименоватьФайл = Истина;
	Исключение
		ОтменитьТранзакцию(); 	
		
		ИнфаОбОшибке 									= ИнформацияОбОшибке();
		ПараметрыЖурнала								= энргОбщегоНазначения.НеобязательныеПараметрыРегистацииОшибки();
		ПараметрыЖурнала.ВыводитьСообщениеПользователю 	= Истина;
		ПараметрыЖурнала.ТекстПользователю 				= "Не удалось провести документы по причине: " + КраткоеПредставлениеОшибки(ИнфаОбОшибке);
		энргОбщегоНазначения.ЗарегистрироватьОшибку("Загрузка показаний Пирамида", УровеньЖурналаРегистрации.Ошибка, ПодробноеПредставлениеОшибки(ИнфаОбОшибке), ПараметрыЖурнала); 
	КонецПопытки;
	
	
	Если МожноПереименоватьФайл Тогда 
		Попытка
			ОписаниеФайла = Новый Структура("ПолноеИмя", ДокументОснование.ФайлДляЧтения);
			НовоеИмяФайла = энргИнтеграцияСПирамидой.УстановитьПрефиксЗагруженногоФайла(ОписаниеФайла);			
			ДокументОснование.ФайлДляЧтения = НовоеИмяФайла;		
		Исключение 			
			ИнфаОбОшибке 		= ИнформацияОбОшибке();
			ПараметрыЖурнала 	= энргОбщегоНазначения.НеобязательныеПараметрыРегистацииОшибки();
			ПараметрыЖурнала.ВыводитьСообщениеПользователю 	= Истина;
			ПараметрыЖурнала.ТекстПользователю 				= "Не удалось переименовать загруженый файл по причине: " + КраткоеПредставлениеОшибки(ИнфаОбОшибке);
			энргОбщегоНазначения.ЗарегистрироватьОшибку("Загрузка показаний Пирамида", УровеньЖурналаРегистрации.Ошибка, ПодробноеПредставлениеОшибки(ИнфаОбОшибке), ПараметрыЖурнала);			
			
			ДокументОснование.Примечание = ДокументОснование.Примечание + " Не удалось переименовать загруженый файл";
		КонецПопытки;
	КонецЕсли;
КонецПроцедуры

Процедура ОчиститьТабличныеЧастиСвязанныхДокументов(СвязанныеДокументы)
	Для Каждого ТекКлючЗначение Из СвязанныеДокументы Цикл
		ДокументОбъект = ТекКлючЗначение.Значение; 		
		ДокументОбъект.ТочкиУчета.Очистить();
		ДокументОбъект.ШкалыПриборовУчета.Очистить();
		ДокументОбъект.ПоказанияПриборовУчета.Очистить();
		
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);		
	КонецЦикла;					
КонецПроцедуры

Процедура ЗафиксироватьНеНайденныеДанные(ДокументОснование, Результат) Экспорт 
	Если Результат.Пустой() Тогда 
		Возврат;
	КонецЕсли; 	
	
	ТекЗаводскойНомер	= Неопределено;
	ТаблицаПриборов 	= ДокументОснование.НеЗагруженныеДанныеНеЗагруженныеПоказания;
	ТаблицаТарифнойЗоны = ДокументОснование.НеЗагруженныеДанныеНеЗагруженныеПоказанияТарифнаяЗона;	
	
	ТаблицаПриборов.Очистить();
	ТаблицаТарифнойЗоны.Очистить();
	
	Выборка  			= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл 
		ИдентификаторСтроки = Новый УникальныйИдентификатор(Выборка.IDСтроки);
				
		Если НЕ ТекЗаводскойНомер = Выборка.НомерПрибораУчетаБыло Тогда		
			НСтрокаПрибора = ТаблицаПриборов.Добавить();
			ЗаполнитьЗначенияСвойств(НСтрокаПрибора, Выборка);
			НСтрокаПрибора.IDСтроки = ИдентификаторСтроки;
		КонецЕсли;
		
		НСтрокаТарифнойЗоны = ТаблицаТарифнойЗоны.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрокаТарифнойЗоны, Выборка);
		НСтрокаТарифнойЗоны.IDСтроки = ИдентификаторСтроки;
		
		ТекЗаводскойНомер = Выборка.НомерПрибораУчетаБыло;
	КонецЦикла; 	
КонецПроцедуры

Процедура ЗафиксироватьНайденныеДанные(ДокументОснование, Результат, СвязанныеДокументы, ДокументыПроведения, ОчищатьТЧЛиста = Истина) Экспорт 
	ВидОперации				= Перечисления.энргВидыОпераций.энргОбходнойЛист_ЗагрузкаПоказанийИзВнешнихИсточников;
	ЕстьНеЗагруженныеДанные	= ДокументОснование.НеЗагруженныеДанныеНеЗагруженныеПоказания.Количество() > 0;
	ОбходнойЛистОбъект		= Неопределено;
	ТекРайон 				= Неопределено;
	ТекТочкаУчета 			= Неопределено;
	ТекШкала 				= Неопределено;
	IDСтрокиТочки 			= Неопределено;
	IDСтрокиШкалы 			= Неопределено;	
	
	Выборка 	= Результат.выбрать();
	Примечание 	= ИмяСобытияЗагрузки();
	Пока Выборка.Следующий() Цикл 		
		
		Если НЕ ТекРайон = Выборка.Район Тогда
			ОбходнойЛистОбъект = СвязанныеДокументы[Выборка.Район];
			Если ОбходнойЛистОбъект = Неопределено Тогда 
				ОбходнойЛистОбъект = Документы.энргОбходнойЛист.СоздатьДокумент();
				ЗаполнитьЗначенияСвойств(ОбходнойЛистОбъект, Выборка);
				ОбходнойЛистОбъект.Дата 				= ДокументОснование.Дата;
				ОбходнойЛистОбъект.ВидОперации 			= ВидОперации;
				ОбходнойЛистОбъект.ИсточникПоказаний 	= ДокументОснование.ИсточникПоказаний;
				ОбходнойЛистОбъект.ДокументОснование 	= ДокументОснование.Ссылка;
				ОбходнойЛистОбъект.Примечание 			= Примечание;
			Иначе
				Если ОчищатьТЧЛиста Тогда 
					ОбходнойЛистОбъект.ТочкиУчета.Очистить();
					ОбходнойЛистОбъект.ШкалыПриборовУчета.Очистить();
					ОбходнойЛистОбъект.ПоказанияПриборовУчета.Очистить();
				КонецЕсли;
			КонецЕсли;
			
			ТаблицаТочекУчета		= ОбходнойЛистОбъект.ТочкиУчета;
			ТаблицаШкалы       		= ОбходнойЛистОбъект.ШкалыПриборовУчета;
			ТаблицаПоказания		= ОбходнойЛистОбъект.ПоказанияПриборовУчета;
			ДокументыПроведения.Вставить(Выборка.Район, ОбходнойЛистОбъект);
		КонецЕсли; 			
		
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда
			энргОбщегоНазначения.ОчиститьДанныеПоказанийПоТочкеУчета(Выборка.IDСтроки, ТаблицаТочекУчета, ТаблицаШкалы, ТаблицаПоказания);
			
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= ТаблицаТочекУчета.Добавить();
			IDСтрокиТочки 						= Новый УникальныйИдентификатор(Выборка.IDСтроки);
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;
			СтрокаТочкиУчета.КлючПомещения 		= Выборка.КлючПомещения;
			СтрокаТочкиУчета.Абонент 			= Выборка.Абонент;
			СтрокаТочкиУчета.ТочкаУчета 		= Выборка.ТочкаУчета;
			СтрокаТочкиУчета.Услуга 			= Выборка.Услуга;
			СтрокаТочкиУчета.ПриборУчета 		= Выборка.ПриборУчета;
		КонецЕсли;
		
		Если НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= ТаблицаШкалы.Добавить();
			IDСтрокиШкалы 						= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
		КонецЕсли;
		
		СтрокаПоказаний 						= ТаблицаПоказания.Добавить();
		СтрокаПоказаний.IDСтроки 				= IDСтрокиШкалы;
		СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		СтрокаПоказаний.ТекущиеПоказания 		= Выборка.ТекущиеПоказанияФайла;
		СтрокаПоказаний.ПоказанияПредоставлены	= Истина;
		
		ТекРайон 								= Выборка.Район;
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекПрибор 								= Выборка.ПриборУчета;
		ТекШкала 								= Выборка.Шкала;
	КонецЦикла; 
	
КонецПроцедуры


Процедура ПровестиМодифицированныеДокументы(ДокументыПроведения) Экспорт
	МенеджерПериода = Обработки.энргГраницыПериодаНачисленияМенеджер;
	Для Каждого ТекКлючЗначение Из ДокументыПроведения Цикл
		ДокументОбъект = ТекКлючЗначение.Значение;
		ДокументОбъект.ПериодНачисления = МенеджерПериода.ОпределитьПериодНачисления(ДокументОбъект.Дата, ДокументОбъект.Организация, ДокументОбъект.Район);
		ПрочитатьПредыдущиеПоказания(ДокументОбъект);		
		
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);		
	КонецЦикла;	
КонецПроцедуры

Процедура ПрочитатьПредыдущиеПоказания(ДокументОбъект)
	ТаблицаПоказанийДляЗаполнения 		= энргРаботаСПоказаниямиПриборовУчетаСервер.ТаблицаПоказаний(ДокументОбъект.Организация, ДокументОбъект.ТочкиУчета, ДокументОбъект.ШкалыПриборовУчета, ДокументОбъект.ПоказанияПриборовУчета, ДокументОбъект.Район);
	РезультатДанныеЗаполненияПоказаний 	= Обработки.энргПоказанияПриборовУчетаМенеджер.РезультатДанныеЗаполненияТаблицыПоказаний(ДокументОбъект.Организация, ДокументОбъект.Район, ТаблицаПоказанийДляЗаполнения, ДокументОбъект.Дата);
	энргРаботаСПоказаниямиПриборовУчетаСервер.ЗаполнитьТабличнуюЧастьПоказанийПриборовУчета(РезультатДанныеЗаполненияПоказаний, ТаблицаПоказанийДляЗаполнения, ДокументОбъект.ПоказанияПриборовУчета);			
КонецПроцедуры
	
#КонецОбласти 

#Область ИсправлениеЗагруженныхДанных

Процедура ОбработатьИсправленныеДанные(ДокументОснование, РезультатЗапроса, Успешно, ДополнительныеПараметры = Неопределено) Экспорт
	СвязанныеДокументы 		= НайтиСвязанныеДокументы(ДокументОснование);
	ДокументыПроведения 	= Новый Соответствие;
	//РезультатПакет 			= ДействующиеТочкиИИхПриборы(ДокументОснование.Дата, ДокументОснование.Организация, ТаблицаДанных); 
	
	//КоличествоПакетов 		= РезультатПакет.Количество();	
	//ЗафиксироватьНайденныеДанные(ДокументОснование, РезультатПакет[КоличествоПакетов - 1], СвязанныеДокументы, ДокументыПроведения, Ложь);	
	
	НачатьТранзакцию();		
	Попытка
		ЗафиксироватьНайденныеДанные(ДокументОснование, РезультатЗапроса, СвязанныеДокументы, ДокументыПроведения, Ложь);
		ПровестиМодифицированныеДокументы(ДокументыПроведения);
		ЗафиксироватьТранзакцию();		
		Успешно = Истина;
	Исключение
		ОтменитьТранзакцию(); 	
		
		ИнфаОбОшибке 									= ИнформацияОбОшибке();
		ПараметрыЖурнала								= энргОбщегоНазначения.НеобязательныеПараметрыРегистацииОшибки();
		ПараметрыЖурнала.ВыводитьСообщениеПользователю 	= Истина;
		ПараметрыЖурнала.ТекстПользователю 				= "Не удалось провести документы по причине: " + КраткоеПредставлениеОшибки(ИнфаОбОшибке);
		энргОбщегоНазначения.ЗарегистрироватьОшибку("Загрузка показаний Пирамида", УровеньЖурналаРегистрации.Ошибка, ПодробноеПредставлениеОшибки(ИнфаОбОшибке), ПараметрыЖурнала); 
	КонецПопытки;
КонецПроцедуры 

#КонецОбласти

#Область РаботаСБазой

Функция ДействующиеТочкиИИхПриборы(Период, Организация, ТаблицаДанных) Экспорт 	
	Схема			= Новый СхемаЗапроса;
	Параметры 		= Новый Структура;
	ПараметрыВТ 	= Новый Массив;
	ПараметрыВТ.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраРавно", Новый Структура("Организация", "Организация")	, Неопределено));	
	
	Параметры.Вставить("Период"		, Новый Структура("ИмяПараметра, ТипПараметра", "Период" ,"ТипПараметраГраницаИсключая"));
	Параметры.Вставить("ПараметрыВТ", ПараметрыВТ);	
	Параметры.Вставить("ВключаяОРП"	, Истина);
	
	ДобавитьТекстЗапросаТаблицаВнешнихДанных(Схема);
	энргСостояниеТочекУчета.ЗаполнитьСхемуДействующиеТочкиИИхПриборы(Схема, Параметры);
	ДобавитьТекстЗапросаКоличествоСтрокПоПриборуИзВнешнихДанных(Схема);
	ДобавитьТекстЗапросаКоличествоСтрокПоПриборуИзВнутреннихДанных(Схема);
	ДобавитьТекстЗапросаНеНайденныеПриборы(Схема);
	ДобавитьТекстЗапросаНесовпадениеТарифныхЗон(Схема);
	ДобавитьТекстЗапросаПриборУчетаНаНесколькихПомещениях(Схема);
	ДобавитьТекстЗапросаОбъединенияНенайденныхДанных(Схема);	
	ДобавитьТекстЗапросаПриборыИзВнешнихДанныхДляСвязи(Схема);	
	
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеПоПриборам.Район КАК Район,
	|	ДанныеПоПриборам.КлючПомещения КАК КлючПомещения,
	|	НеНайденныеДанныеИзВнешнихДанных.IDСтроки КАК IDСтроки,
	|	МАКСИМУМ(АбонентыПомещений.Абонент) КАК Абонент
	|ПОМЕСТИТЬ АбонентПрибораУчетаНЕНайденныхДанных
	|ИЗ
	|	ДанныеПоПриборам КАК ДанныеПоПриборам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НеНайденныеДанныеИзВнешнихДанных КАК НеНайденныеДанныеИзВнешнихДанных
	|		ПО ДанныеПоПриборам.ЗаводскойНомер = НеНайденныеДанныеИзВнешнихДанных.НомерПрибораУчетаБыло
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АбонентыПомещений КАК АбонентыПомещений
	|		ПО ДанныеПоПриборам.Организация = АбонентыПомещений.Организация
	|			И ДанныеПоПриборам.Район = АбонентыПомещений.Район
	|			И ДанныеПоПриборам.КлючПомещения = АбонентыПомещений.КлючПомещения
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеПоПриборам.Район,
	|	ДанныеПоПриборам.КлючПомещения,
	|	НеНайденныеДанныеИзВнешнихДанных.IDСтроки");
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	НеНайденныеДанныеИзВнешнихДанных.IDСтроки КАК IDСтроки,
	|	АбонентПрибораУчетаНЕНайденныхДанных.Район КАК Район,
	|	АбонентПрибораУчетаНЕНайденныхДанных.КлючПомещения КАК КлючПомещения,
	|	АбонентПрибораУчетаНЕНайденныхДанных.Абонент КАК Абонент,
	|	НеНайденныеДанныеИзВнешнихДанных.НомерПрибораУчетаБыло КАК НомерПрибораУчетаБыло,
	|	НеНайденныеДанныеИзВнешнихДанных.ТарифнаяЗона КАК ТарифнаяЗона,
	|	НеНайденныеДанныеИзВнешнихДанных.ТекущиеПоказания КАК ТекущиеПоказания,
	|	НеНайденныеДанныеИзВнешнихДанных.ОписаниеОшибки КАК ОписаниеОшибки,
	|	энргАбоненты.ЛицевойСчет КАК ЛицевойСчет
	|ИЗ
	|	НеНайденныеДанныеИзВнешнихДанных КАК НеНайденныеДанныеИзВнешнихДанных
	|		ЛЕВОЕ СОЕДИНЕНИЕ АбонентПрибораУчетаНЕНайденныхДанных КАК АбонентПрибораУчетаНЕНайденныхДанных
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
	|			ПО АбонентПрибораУчетаНЕНайденныхДанных.Абонент = энргАбоненты.Ссылка
	|		ПО НеНайденныеДанныеИзВнешнихДанных.IDСтроки = АбонентПрибораУчетаНЕНайденныхДанных.IDСтроки
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерПрибораУчетаБыло");
	
	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеПоПриборамИтог.Организация КАК Организация,
	|	ДанныеПоПриборамИтог.Район КАК Район,
	|	ДанныеПоПриборамИтог.КлючПомещения КАК КлючПомещения,
	|	ДанныеПоПриборамИтог.ТочкаУчета КАК ТочкаУчета,
	|	ДанныеПоПриборамИтог.ПриборУчета КАК ПриборУчета,
	|	ДанныеПоПриборамИтог.РодительТочкиУчета КАК РодительТочкиУчета,
	|	ДанныеПоПриборамИтог.Шкала КАК Шкала,
	|	ДанныеПоПриборамИтог.Услуга КАК Услуга,
	|	ДанныеПоПриборамИтог.РегистрируетОбъем КАК РегистрируетОбъем,
	|	ДанныеПоПриборамИтог.ВидДифференцированности КАК ВидДифференцированности,
	|	ДанныеПоПриборамИтог.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	ДанныеПоПриборамИтог.РасчетПоФормуле КАК РасчетПоФормуле,
	|	ДанныеПоПриборамИтог.ТарифнаяЗона КАК ТарифнаяЗона,
	|	ДанныеПоПриборамИтог.Поставщик КАК Поставщик,
	|	ДанныеПоПриборамИтог.НомерПломбы КАК НомерПломбы,
	|	ДанныеПоПриборамИтог.ДатаПоверки КАК ДатаПоверки,
	|	ДанныеПоПриборамИтог.СоставнаяУслуга КАК СоставнаяУслуга,
	|	ВнешниеПриборыДляСвязи.IDСтроки КАК IDСтроки,
	|	ВнешниеПриборыДляСвязи.ПриборУчета КАК НомерПрибораУчетаБыло,
	|	ВнешниеПриборыДляСвязи.ТарифнаяЗона КАК ТарифнаяЗонаФайла,
	|	ВнешниеПриборыДляСвязи.Показания КАК ТекущиеПоказанияФайла,
	|	АбонентыПомещений.Абонент КАК Абонент
	|ИЗ
	|	ДанныеПоПриборамИтог КАК ДанныеПоПриборамИтог
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВнешниеПриборыДляСвязи КАК ВнешниеПриборыДляСвязи
	|		ПО ДанныеПоПриборамИтог.ЗаводскойНомер = ВнешниеПриборыДляСвязи.ПриборУчета
	|			И ДанныеПоПриборамИтог.ТарифнаяЗона = ВнешниеПриборыДляСвязи.ТарифнаяЗона
	|		ЛЕВОЕ СОЕДИНЕНИЕ АбонентыПомещений КАК АбонентыПомещений
	|		ПО ДанныеПоПриборамИтог.Организация = АбонентыПомещений.Организация
	|			И ДанныеПоПриборамИтог.Район = АбонентыПомещений.Район
	|			И ДанныеПоПриборамИтог.КлючПомещения = АбонентыПомещений.КлючПомещения
	|			И ДанныеПоПриборамИтог.Услуга = АбонентыПомещений.Услуга
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Район,
	|	КлючПомещения,
	|	ТочкаУчета,
	|	ПриборУчета,
	|	Шкала");	
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Период"			, Период);
	ПараметрыЗапроса.Вставить("Организация"		, Организация);
	ПараметрыЗапроса.Вставить("ТаблицаДанных"	, ТаблицаДанных);
	
	//МВТ = Новый МенеджерВременныхТаблиц;
	Возврат энргСхемаЗапросаСервер.ВыполнитьПакет(Схема, ПараметрыЗапроса);			
КонецФункции

