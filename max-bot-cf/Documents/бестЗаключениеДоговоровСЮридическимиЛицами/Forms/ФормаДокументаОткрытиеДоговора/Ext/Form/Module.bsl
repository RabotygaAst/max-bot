&НаКлиенте
Процедура ПолучитьСхемуПид(СхемаПИД, ДополнительныеПараметры) Экспорт
	Если ЗначениеЗаполнено(СхемаПИД) Тогда
		Модифицированность = Истина;
		
	    Объект.ЭтапыПИД.Очистить();
		ДеревоПИР.ПолучитьЭлементы().Очистить();
	
		ЗаполнитьЭтапыПИР(СхемаПИД);
		ЗаполнитьДеревоПИР();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДеревоПИР()

	Ветви = ДеревоПИР.ПолучитьЭлементы();
	Объект.ЭтапыПИД.Сортировать("Порядок");
	
	ТекВетвь = Новый Структура("Этап");
	Для каждого СтрокаТЧ Из Объект.ЭтапыПИД Цикл
		Если СтрокаТЧ.Этап <> ТекВетвь.Этап Тогда
			ТекВетвь = Ветви.Добавить();
			
			ТекВетвь.Этап = СтрокаТЧ.Этап;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТЧ.Подэтап) Тогда
			ТекПодветвь = ТекВетвь.ПолучитьЭлементы().Добавить();
			
			ЗаполнитьЗначенияСвойств(ТекПодветвь, СтрокаТЧ);
		Иначе
			ТекВетвь.Срок 	 = СтрокаТЧ.Срок;
			ТекВетвь.Порядок = СтрокаТЧ.Порядок;
		КонецЕсли;		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ДеревоПИРПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	
	ОписОпов = Новый ОписаниеОповещения("ПолучитьЭтап", ЭтотОбъект);
	ОткрытьФорму("Справочник.энргВидыОперацийПИД.ФормаВыбора", , ЭтаФорма,,,, ОписОпов, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьЭтап(Этап, ДополнительныеПараметры) Экспорт
	Если ЗначениеЗаполнено(Этап) Тогда
		Модифицированность = Истина;
		Ветвь = ДеревоПИР.ПолучитьЭлементы().Добавить();
		Ветвь.Этап = Этап;
		
		ЗаполнитьПодэтапы(Ветвь.ПолучитьИдентификатор(), Этап);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПодэтапы(ИдВетвь, Этап)
	Ветвь = ДеревоПИР.НайтиПоИдентификатору(ИдВетвь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргВидыОперацийПИД.ЕстьПодэтапы КАК ЕстьПодэтапы,
		|	энргВидыОперацийПИДПодэтапы.НомерСтроки КАК Порядок,
		|	энргВидыОперацийПИДПодэтапы.Подэтап КАК Подэтап,
		|	энргВидыОперацийПИДПодэтапы.Параллельно КАК Параллельно,
		|	энргВидыОперацийПИД.Ссылка КАК Этап
		|ИЗ
		|	Справочник.энргВидыОперацийПИД КАК энргВидыОперацийПИД
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыОперацийПИД.Подэтапы КАК энргВидыОперацийПИДПодэтапы
		|		ПО энргВидыОперацийПИД.Ссылка = энргВидыОперацийПИДПодэтапы.Ссылка
		|ГДЕ
		|	энргВидыОперацийПИД.Ссылка = &Этап
		|	И энргВидыОперацийПИД.ЕстьПодэтапы
		|
		|УПОРЯДОЧИТЬ ПО
		|	Порядок";
	
	Запрос.УстановитьПараметр("Этап", Этап);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Подветвь = Ветвь.ПолучитьЭлементы().Добавить();
		ЗаполнитьЗначенияСвойств(Подветвь, Выборка);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПодэтапПИР(Команда)
	ТекСтрока = Элементы.ДеревоПИР.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекВетвь  = ДеревоПИР.НайтиПоИдентификатору(Элементы.ДеревоПИР.ТекущаяСтрока);
	Пока ТекВетвь.ПолучитьРодителя() <> Неопределено Цикл 
		ТекВетвь = ТекВетвь.ПолучитьРодителя();
	КонецЦикла;
	
	ДопПарам = Новый Структура("ИдСтроки, Этап", ТекВетвь.ПолучитьИдентификатор(), ТекВетвь.Этап);
	ОписОпов = Новый ОписаниеОповещения("ПолучитьПодэтап", ЭтотОбъект, ДопПарам);
	ОткрытьФорму("Справочник.энргВидыОперацийПИД.ФормаВыбора", , ЭтаФорма,,,, ОписОпов, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьПодэтап(Подэтап, ДополнительныеПараметры) Экспорт
	Если ЗначениеЗаполнено(Подэтап) Тогда
		Модифицированность = Истина;
		
		ИдСтроки = ДополнительныеПараметры.ИдСтроки;
		Этап	 = ДополнительныеПараметры.Этап;
		Ветвь 	 = ДеревоПИР.НайтиПоИдентификатору(ИдСтроки);
		
		Подветвь = Ветвь.ПолучитьЭлементы().Добавить();
		Подветвь.Этап	 = Этап;
		Подветвь.Подэтап = Подэтап;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьПараметрыПИР()
	Объект.ЭтапыПИД.Очистить();
	
	СчВетвь = 1;
	Для каждого Ветвь Из ДеревоПИР.ПолучитьЭлементы() Цикл
		Подветви = Ветвь.ПолучитьЭлементы();
		Если ЗначениеЗаполнено(Подветви) Тогда
			Сч = 1;
		
			Для каждого Подветвь Из Подветви Цикл
				СтрокаТЧ = Объект.ЭтапыПИД.Добавить();
				
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, Подветвь);
				СтрокаТЧ.Порядок = СчВетвь * 100 + Сч;
				
				Сч = Сч + 1;
			КонецЦикла;
		Иначе
			СтрокаТЧ = Объект.ЭтапыПИД.Добавить();
			
			СтрокаТЧ.Этап 	 = Ветвь.Этап;
			СтрокаТЧ.Срок 	 = Ветвь.Срок;
			СтрокаТЧ.Порядок = СчВетвь * 100;
		КонецЕсли;
		
		СчВетвь = СчВетвь + 1;	
	КонецЦикла;
КонецПроцедуры 

