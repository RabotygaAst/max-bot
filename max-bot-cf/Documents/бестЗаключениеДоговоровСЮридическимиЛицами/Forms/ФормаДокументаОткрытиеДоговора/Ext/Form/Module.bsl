&НаСервере
Процедура РаспределитьПотериНаСервере()
	
	Объект.ОбъемыРаспределенияПотерь.Очистить();
	
	Для Каждого Стр Из Объект.УслугиРаспределенияПотерь Цикл
		
		СтрокаПотери  					= Объект.ОбъемыРаспределенияПотерь.Добавить();
		
		ОбъемПотерьПоМесяцам = бестРаботаСОбъектамиНПСервер.РаспределенныеЗначенияПотерь(Объект.Район,объект.Организация, Стр.Год, Стр.ГодовойОбъемПотерь, Стр.СпособРаспределенияПотерь);
		
		Для Каждого МесячныйОбъем ИЗ ОбъемПотерьПоМесяцам Цикл
			
			СтрокаПотери[МесячныйОбъем.Ключ] = МесячныйОбъем.Значение;
			
		КонецЦикла;
		
		СтрокаПотери.IDСтроки =  Стр.IDСтроки;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокУслугДляВыбора(IDСтрокиОбъекта)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("IDСтрокиВладельца", IDСтрокиОбъекта);
	НайденныеСтроки = Объект.ТочкиУчета.НайтиСтроки(ПараметрыОтбора);
	СписокУслуг = Новый СписокЗначений;
	
	Для Каждого Стр Из НайденныеСтроки Цикл
		СписокУслуг.Добавить(Стр.Услуга);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргВидыУслугСоставляющиеУслуг.Услуга КАК Услуга
	|ИЗ
	|	Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|ГДЕ
	|	энргВидыУслугСоставляющиеУслуг.Ссылка В(&СписокУслуг)";
	
	Запрос.УстановитьПараметр("СписокУслуг", СписокУслуг);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СписокУслуг.Добавить(ВыборкаДетальныеЗаписи.Услуга);
	КонецЦикла;
	
	Возврат СписокУслуг;
	
КонецФункции

&НаКлиенте
Процедура СуммаПоКварталу()
	ТекСтрока 				= Элементы.ГарантированныеОбъемы.ТекущиеДанные;
	Если НЕ ТекСтрока		= Неопределено ТОгда
		ИтогПервыйКвартал 		= ТекСтрока.Январь + ТекСтрока.Февраль + ТекСтрока.Март;
		ИтогВторойКвартал 		= ТекСтрока.Апрель + ТекСтрока.Май + ТекСтрока.Июнь;
		ИтогТретийКвартал 		= ТекСтрока.Июль + ТекСтрока.Август + ТекСтрока.Сентябрь;
		ИтогЧетвертыйКвартал 	= ТекСтрока.Октябрь + ТекСтрока.Ноябрь + ТекСтрока.Декабрь;
		//ИтогГод 				= ИтогПервыйКвартал + ИтогВторойКвартал + ИтогТретийКвартал + ИтогЧетвертыйКвартал;
		
		ТекСтрока.ГарантированныйОбъемИтогПервыйКвартал 	= ИтогПервыйКвартал;
		ТекСтрока.ГарантированныйОбъемИтогВторойКвартал 	= ИтогВторойКвартал;
		ТекСтрока.ГарантированныйОбъемИтогТретийКвартал 	= ИтогТретийКвартал;
		ТекСтрока.ГарантированныйОбъемИтогЧетвертыйКвартал 	= ИтогЧетвертыйКвартал;
		ТекСтрока.ГарантированныйОбъемИтогГод				= ИтогПервыйКвартал+ИтогВторойКвартал +ИтогТретийКвартал + ИтогЧетвертыйКвартал;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПолучитьСтруктуруОбязательныхРеквизитов(Структура)
	Структура.Вставить("Район", 		Объект.Район);
	Структура.Вставить("Организация", 	Объект.Организация);	
	Структура.Вставить("Договор", 		Объект.Договор);
	Структура.Вставить("Контрагент", 	Объект.Контрагент);
КонецПроцедуры

&НаСервере
Процедура ПолучитьМассивТЧ(Структура)
	Структура.Вставить("ОбъектыРасчета",				Объект.ОбъектыРасчета);
	Структура.Вставить("Услуги",						Объект.ТочкиУчета);

КонецПроцедуры

&НаКлиенте
Процедура ПроверкаУдаленияСтроки(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросУдаленияСтроки",ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Удалить всю строку вместо значения ячейки?",РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросУдаленияСтроки(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			Если ДополнительныеПараметры.ТЧ = "ОбъектыРасчета" Тогда
				УдалитьСвязанныеСОбъектомСтроки(ДополнительныеПараметры.IDСтроки);
			ИначеЕсли ДополнительныеПараметры.ТЧ = "ТочкиУчета" Тогда
				ТаблицыФормы	= Новый Массив;
				ТаблицыФормы.Добавить("ПоказанияПриборовУчета");
				ТаблицыФормы.Добавить("ФормулыРасчетаУслуг");
				ТаблицыФормы.Добавить("ШкалыПриборовУчета"); 
				ТаблицыФормы.Добавить("ШкалыИзмерителей");
				ТаблицыФормы.Добавить("НомераПломб");
				ТаблицыФормы.Добавить("Измерители"); 
				энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(ДополнительныеПараметры.IDСтроки, Объект, ТаблицыФормы,"ТочкиУчета");
				
				
				ТаблицыФормы	= Новый Массив;
				ТаблицыФормы.Добавить("ОбъемыРаспределенияПотерь");
				ТаблицыФормы.Добавить("ПоставщикиСоставныхУслуг");
				
				
				энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(ДополнительныеПараметры.IDСтроки, Объект, ТаблицыФормы);
				
				ТочкиУчетаПриИзмененииСервер(ДополнительныеПараметры.IDСтроки, Неопределено);
			ИначеЕсли ДополнительныеПараметры.ТЧ = "УслугиРаспределенияПотерь" Тогда
				
				ТаблицыФормы				= Новый Массив;	
				ТаблицыФормы.Добавить("ОбъемыРаспределенияПотерь");
				
				энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(Элементы.ОбъектыРасчета.ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы);
			КонецЕсли;
			УдалитьСтроку(ДополнительныеПараметры);
			
			Если ДополнительныеПараметры.ТЧ = "ОбъектыРасчета" ИЛИ ДополнительныеПараметры.ТЧ = "ТочкиУчета" Тогда
				
				ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
				Если ТекДанные = Неопределено Тогда
					Отказ = Истина;
					Возврат;
				КонецЕсли;
				
				ТочкиУчетаПриИзмененииСервер(ТекДанные.IDСтроки, ТекДанные.МКД);
			КонецЕсли;
			ДоступностьТЧТУ();
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура УдалитьСтроку(ДополнительныеПараметры)
	Объект[ДополнительныеПараметры.ТЧ].Удалить(ДополнительныеПараметры.НомерСтроки);	
КонецПроцедуры

&НаСервере
Процедура ПроверкаДублированияНаименованийОбъектовРасчета(Отказ)
	МассивОбъектовРасчета = Новый ТаблицаЗначений;
	МассивОбъектовРасчета.Колонки.Добавить("НаименованиеОбъектаРасчета");
	МассивОбъектовРасчета.Колонки.Добавить("АдресОбъекта");
	Для каждого стр из Объект.ОбъектыРасчета Цикл
		Отбор		= Новый Структура("НаименованиеОбъектаРасчета, АдресОбъекта", стр.НаименованиеОбъектаРасчета, стр.АдресОбъекта);
		ИщемСтроки 	= МассивОбъектовРасчета.НайтиСтроки(ОТбор);
		Если ИщемСтроки.Количество()> 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В ТЧ 'Объекты расчета' обнаружено несколько объектов с наименованием '" + стр.НаименованиеОбъектаРасчета + "' и адресом: " + стр.АдресОбъекта + "! Необходимо переименовать объект расчета");
			Отказ = Истина;
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(МассивОбъектовРасчета.Добавить(), Отбор);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеКварталов() 
	
	ОбновитьСуммуПоКварталу();

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьКоэфициент(ТекущиеДанные) 	
	Если ТекущиеДанные.КоэффициентПУ = 0 тогда
		Если ЗначениеЗаполнено(ТекущиеДанные.ЗаводскойНомер) или ЗначениеЗаполнено(ТекущиеДанные.ДатаПоверкиСчетчика) или ЗначениеЗаполнено(ТекущиеДанные.ТипПрибораУчета) Тогда
			ТекущиеДанные.КоэффициентПУ = 1;
		КонецЕсли; 	
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.ВидКанальности) тогда
		Если ЗначениеЗаполнено(ТекущиеДанные.ЗаводскойНомер) или ЗначениеЗаполнено(ТекущиеДанные.ДатаПоверкиСчетчика) или ЗначениеЗаполнено(ТекущиеДанные.ТипПрибораУчета) Тогда
			ТекущиеДанные.ВидКанальности = ПредопределенноеЗначение("Справочник.энргВидыКанальности.Одноканальный");
		КонецЕсли; 	
	КонецЕсли;
	
КонецПроцедуры
		
