&НаСервере
Процедура ПроставитьДатыКомУчетаДляПУ(IDСтрокиТУ, ДатаКомУчета, ЭтоНачалоКомУчета)
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("IDСтроки", IDСтрокиТУ);
	НайденныеСтроки = Объект.ПриборыУзловУчета.НайтиСтроки(ПараметрыОтбора);
	Для каждого стр из НайденныеСтроки Цикл
		Если ЭтоНачалоКомУчета Тогда
			стр.НачалоДействияКоммерскогоУчета = ДатаКомУчета;
		Иначе
			стр.КонецДействияКоммерскогоУчета = ДатаКомУчета;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСвязанныеСОбъектомСтроки(IDСтроки)
	ТаблицыФормы = Новый Массив;	
	ТаблицыФормы.Добавить("УслугиОбъектов");
	ТаблицыФормы.Добавить("СезонныеНагрузки");
	ТаблицыФормы.Добавить("ПотребителиГВС");
	ТаблицыФормы.Добавить("ГарантированныеОбъемы");
	ТаблицыФормы.Добавить("ТемпературныеГрафикиОбъектов");
	ТаблицыФормы.Добавить("УслугиРаспределенияПотерь");
	ТаблицыФормы.Добавить("ТарифныеКатегорииУслуги");
	
	
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(IDСтроки, Объект, ТаблицыФормы);
	
	СтруктураПоиска  				= Новый Структура("IDСтрокиВладельца", IDСтроки);
	Коллекция  					= Объект["ТочкиУчета"];
	Строки  					= Коллекция.НайтиСтроки(СтруктураПоиска);
	ТаблицыФормы	= Новый Массив;
	ТаблицыФормы.Добавить("ПоказанияПриборовУчета");
	Для Каждого УдаляемаяСтрока из Строки Цикл
		энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(УдаляемаяСтрока.IDСтроки, Объект, ТаблицыФормы,"ТочкиУчета");
	КонецЦикла;	
	ТаблицыФормы.Очистить();
	ТаблицыФормы.Добавить("ТочкиУчета");
	ТаблицыФормыВторогоУровня	= Новый Массив;
	ТаблицыФормыВторогоУровня.Добавить("ОбъемыРаспределенияПотерь");
	
	ТаблицыФормыВторогоУровня.Добавить("ПоставщикиСоставныхУслуг");
	ТаблицыФормыВторогоУровня.Добавить("ШкалыПриборовУчета");
	ТаблицыФормыВторогоУровня.Добавить("ШкалыУслуг");
	ТаблицыФормыВторогоУровня.Добавить("ПриборыУзловУчета");
	
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(IDСтроки, Объект, ТаблицыФормы,"Владельца", ТаблицыФормыВторогоУровня);
	
	
	ТаблицыФормы.Очистить();
	ТаблицыФормыВторогоУровня.Очистить();
	ТаблицыФормы.Добавить("ДополнительныеНачисленияТУ");
	ТаблицыФормыВторогоУровня.Добавить("ДополнительныеНачисленияЗначения");
	
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(IDСтроки, Объект, ТаблицыФормы,"Владельца", ТаблицыФормыВторогоУровня);
КонецПроцедуры

