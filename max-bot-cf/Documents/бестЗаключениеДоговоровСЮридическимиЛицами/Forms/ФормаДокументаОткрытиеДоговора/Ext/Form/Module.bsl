		НовыеИзмерители 					= Новый Массив;
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеИзмерители") Тогда
			НовыеИзмерители 				= ТекущийОбъект.ДополнительныеСвойства.НовыеИзмерители;
		КонецЕсли;
		
		ТУОбъектовУК						= Новый Массив;
		Для Каждого СтрокаТочки Из ТекущийОбъект.ТочкиУчета Цикл
			Если СтрокаТочки.ОбъектУК Тогда
				ТУОбъектовУК.Добавить(СтрокаТочки.IDСтроки);
				Продолжить;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаТочки.ПриборУчета) Тогда
				ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,НовыеПриборыУчета, СтрокаТочки.ПриборУчета, СтрокаТочки.ОписаниеПрибора, СтрокаТочки.НомерСтроки);
			КонецЕсли;			
		КонецЦикла;
		
		Для Каждого СтрокаИзмерителя Из ТекущийОбъект.Измерители Цикл
			Если ТУОбъектовУК.Найти(СтрокаИзмерителя.IDСтрокиТочкиУчета) <> Неопределено Тогда
				Продолжить;
			КонецЕсли; 
				ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,НовыеИзмерители, СтрокаИзмерителя.ПриборУчета, СтрокаИзмерителя.ОписаниеПрибора, СтрокаИзмерителя.НомерСтроки);							
		КонецЦикла;
		////КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	ПрименитьПараметрыПИР();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ОбновитьДанныеОбъектаРасчета" Тогда
		
		ПараметрыОтбора = Новый Структура("ОбъектРасчета", Параметр);
		НайденныеСтроки = Объект.ОбъектыРасчета.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() > 0 Тогда
			ОбновитьДанныеОбъектаРасчета(НайденныеСтроки[0]);
		КонецЕсли;
	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовШапки

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		ЗаполнитьПериодНачисленияСервер();		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	бестРаботаСВидамиОперацийКлиент.ПриИзмененииВидаОперации("бестЗаключениеДоговоровСЮридическимиЛицами",Объект,Параметры.Ключ);
	Модифицированность = Ложь;
	ЭтаФорма.Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура ДоговорКонтрагентаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Договор) тогда
		бестПользовательскийВводКлиент.ПриИзмененииДоговораКонтрагента(Объект, "ДатаФактическогоСобытия");
		ЗаполнитьДанныеДоговораСервер(Ложь);
		//--СДЕЛАНО ВРЕМЕННО
		Если ПолучитьТипДоговора() = ПредопределенноеЗначение("Перечисление.бестТипыДоговоров.УправляющаяКомпания") Тогда
			
			Для Каждого ТекСтрока Из Объект.ТочкиУчета Цикл
				ТекущиеДанные 							= ТекСтрока; 
				
				энргРаботаСТочкамиУчетаКлиент.СозданиеНаименованияТУ(ТекущиеДанные);				
				ОписаниеУслуги = энргРаботаСПоставщикамиСервер.ОписаниеУслуги(ТекущиеДанные.Услуга); 				
				// энргРаботаСПоставщиками {
				бестРаботаСПоставщикамиКлиент.ПриИзмененииУслуги(ЭтаФорма,ТекущиеДанные,ОписаниеУслуги); 	
				// энргРаботаСПоставщиками } 				
				
				// энргРаботаСоСпособамиРасчетаНорматива {
				бестРаботаСоСпособомРасчетаНормативаКлиент.ПриИзмененииУслуги(ЭтаФорма,ТекущиеДанные,ОписаниеУслуги); 	
				// энргРаботаСоСпособамиРасчетаНорматива } 
				
				СоответствиеЗначенияПоУмолчанию = Новый Соответствие;
				СоответствиеЗначенияПоУмолчанию.Вставить("Договор", Объект.Договор);
				бестРаботаСоСпособомРасчетаНормативаКлиент.ПриИзмененииУслуги(ЭтаФорма,ТекущиеДанные,ОписаниеУслуги,"ДоговорыСоставныхУслуг",СоответствиеЗначенияПоУмолчанию);
	
				Если ИспользоватьШкалыПриборовУчета Тогда
					СоставУслуги = энргРаботаСПоставщикамиСервер.ПолучитьСоставУслугиСоШкалами(ТекущиеДанные.Услуга, ТекущиеДанные.ВидКанальности);
					бестРаботаСТочкамиУчетаНПКлиент.ПриИзмененииВидаКанальности(ЭтаФорма, ТекущиеДанные, СоставУслуги, "ШкалыУслуг");	
				КонецЕсли;
				
				
			КонецЦикла;	
			ЗаполнитьПоставщика();
			
			УстановитьУсловноеОФормлениеФормыКлиент("Поставщик","ПараметрыПоставщиков");
			УстановитьУсловноеОФормлениеФормыКлиент("Договор","ПараметрыДоговоров");
		КонецЕсли;
		//--СДЕЛАНО ВРЕМЕННО
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	Объект.Организация = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Район,"Организация");
	ЗаполнитьПериодНачисленияСервер();
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда		
		ЗаполнитьПериодНачисленияСервер(); 		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СобытияТабличнойЧастиОбъектыРасчета

&НаКлиенте
Процедура ОбъектыРасчетаПриАктивизацииСтроки(Элемент)
		
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекОбъектРасчета = ТекДанные.ОбъектРасчета;
	
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.УслугиОбъектов,						Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.СезонныеНагрузки,						Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПотребителиГВС,						Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ГарантированныеОбъемы,					Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы["ТочкиУчета"],	Неопределено,		ТекДанные.IDСтроки,, "Владельца");
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ТемпературныеГрафикиОбъектов,			Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.УслугиРаспределенияПотерь,				Неопределено,		ТекДанные.IDСтроки,, "Владельца");
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ТарифныеКатегорииУслуги,				Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.МаксимальныеНагрузки	,				Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ДополнительныеНачисленияТУ	,			Неопределено,		ТекДанные.IDСтроки,, "Владельца");

	Если Объект.ОбъемыИНагрузкиВРазрезеДоговора И ТекДанные.НомерСтроки > 1 Тогда
		Элементы.ГарантированныеОбъемы.ТолькоПросмотр = Истина;
		Элементы.УслугиОбъектов.ТолькоПросмотр = Истина;
	Иначе
		Элементы.ГарантированныеОбъемы.ТолькоПросмотр = Ложь;
		энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ИтогиДоговорныхОбъемов,				Неопределено,		ТекДанные.IDСтроки);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаНаименованиеОбъектаРасчетаПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекДанные.НаименованиеОбъектаРасчета) и НЕ ЗначениеЗаполнено(ТекДанные.ОбъектРасчета) Тогда
		Если НЕ ЗначениеЗаполнено(ТекДанные.Собственник) Тогда
			ТекДанные.Собственник	= Объект.Контрагент;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаОбъектРасчетаПриИзменении(Элемент)
	
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	ОбновитьДанныеОбъектаРасчета(ТекДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаПередУдалением(Элемент, Отказ)
	Отказ 			= Истина;
	ДопПараметры	= Новый Структура;
	ДопПараметры.Вставить("ТЧ", 			"ОбъектыРасчета");
	ДопПараметры.Вставить("НомерСтроки", 	Элемент.ТекущиеДанные.НомерСтроки-1);
	ДопПараметры.Вставить("IDСтроки", 		Элементы.ОбъектыРасчета.ТекущиеДанные.IDСтроки);
	ПроверкаУдаленияСтроки(ДопПараметры);	
	
		
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Если Копирование Тогда
		Отказ = Истина;	
		НоваяСтрока = Объект.ОбъектыРасчета.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент.ТекущиеДанные);
		НоваяСтрока.idСтроки = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаполнениеДанных(Отказ)
	СтруктураОбязательныхРеквизитов = Новый Структура;
	ПолучитьСтруктуруОбязательныхРеквизитов(СтруктураОбязательныхРеквизитов);
	СтруктураОбязательныхТЧ = Новый Структура;
	ПолучитьМассивТЧ(СтруктураОбязательныхТЧ);
	
	Для каждого стр из СтруктураОбязательныхРеквизитов Цикл
		Если Не ЗначениеЗаполнено(стр.Значение) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено значение реквизита '" + стр.Ключ +"'");
			Отказ = Истина;		
		КонецЕсли;
	КонецЦикла;
	
	Для каждого стр из СтруктураОбязательныхТЧ Цикл
		Если стр.Значение.Количество() = 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена ТЧ '" + стр.Ключ +"'");
			Отказ = Истина;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаАдресОбъектаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;

	МодульУправлениеКонтактнойИнформациейКлиент 		= ОбщегоНазначенияКлиент.ОбщийМодуль("УправлениеКонтактнойИнформациейКлиент");
	
	ПараметрыФормыКонтактнойИнформации 					= МодульУправлениеКонтактнойИнформациейКлиент.ПараметрыФормыКонтактнойИнформации(ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресОбъектаРасчета"),""); 
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяРеквизита", Элемент.Имя);
		
	ДанныеСтроки 										= Новый Структура("Представление,ЗначенияПолей",ТекДанные.АдресОбъекта,ТекДанные.АдресОбъектаЗначение);
	
	ПараметрыФормыКонтактнойИнформации.Значение 		= ДанныеСтроки.ЗначенияПолей;
	ПараметрыФормыКонтактнойИнформации.Представление 	= ДанныеСтроки.Представление;
	
	Оповещение 											= Новый ОписаниеОповещения("ОбъектыРасчетаАдресОбъектаНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура);
	Оповещение.ДополнительныеПараметры.Вставить("ДанныеЗаполнения",  ДанныеСтроки);
	Оповещение.ДополнительныеПараметры.Вставить("ЭтоТабличнаяЧасть", Истина);
	Оповещение.ДополнительныеПараметры.Вставить("КлючСтроки", 		 Элементы.ОбъектыРасчета.ТекущаяСтрока);
	Оповещение.ДополнительныеПараметры.Вставить("Элемент",           Элемент);
	Оповещение.ДополнительныеПараметры.Вставить("ДанныеСтроки",      ДанныеСтроки);		
	Оповещение.ДополнительныеПараметры.Вставить("Результат",         Результат);
	Оповещение.ДополнительныеПараметры.Вставить("Форма",             ЭтаФорма);
	
	
	МодульУправлениеКонтактнойИнформациейКлиент.ОткрытьФормуКонтактнойИнформации(ПараметрыФормыКонтактнойИнформации,,Оповещение);


КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаАдресОбъектаНачалоВыбораЗавершение(Знач РезультатЗакрытия, Знач ДополнительныеПараметры) Экспорт 
		
	Если ТипЗнч(РезультатЗакрытия) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 									= Объект.ОбъектыРасчета.НайтиПоИдентификатору(ДополнительныеПараметры.КлючСтроки);	
	
	ТекущиеДанные.АдресОбъекта 						= РезультатЗакрытия.Представление;
	ТекущиеДанные.АдресОбъектаЗначение 				= РезультатЗакрытия.Значение; 
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаАдресОбъектаПриИзменении(Элемент)
	
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;

	ТекДанные.АдресОбъектаЗначение = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(ТекДанные.АдресОбъекта, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресОбъектаРасчета"));
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаМКДПриИзменении(Элемент)
	Элементы.ОбъектыРасчета.ТекущиеДанные.АдресОбъекта 	= ПолучитьАдресМКД(Элементы.ОбъектыРасчета.ТекущиеДанные.МКД,ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресДома")); 
	Элементы.ОбъектыРасчета.ТекущиеДанные.Участвует		= Истина;
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "ОбъектыРасчетаДополнительнаяИнформация" Тогда
		ТекущиеДанные		= Элементы.ОбъектыРасчета.ТекущиеДанные;
		КлючДанных 			= бестПользовательскийВводКлиент.ПолучитьКлючЗаполненияИнформацииОбъекта();
		ВходныеДанные		= Новый Структура(КлючДанных);
		ЗаполнитьЗначенияСвойств(ВходныеДанные,ТекущиеДанные);
		
		ОписаниеОповещения 	= Новый ОписаниеОповещения("ИнформацияОбъектаЗавершение", ЭтотОбъект, Новый Структура("ТекущиеДанные", ТекущиеДанные));
		ОткрытьФорму("ОбщаяФорма.бестИнформацияОбъекта", Новый Структура("ВходныеДанные,КлючДанных",ВходныеДанные,КлючДанных),,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СобытияТабличнойЧастиГарантированныеОбъемы

&НаКлиенте
Процедура ГарантированныеОбъемыПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекДанныеОбъемы = Элементы.ГарантированныеОбъемы.ТекущиеДанные;
	Если ТекДанныеОбъемы = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	
	ТекДанныеОбъемы.IDСтроки = ТекДанные.IDСтроки;

	ЗаполнитьИтогиДоговорныхОбъемов();
	ЗаполнитьИтогиДоговорныхОбъемовПоДоговору();
	
КонецПроцедуры

&НаКлиенте
Процедура ГарантированныеОбъемыЯнварьПриИзменении(Элемент)
	СуммаПоКварталу()
КонецПроцедуры

&НаКлиенте
Процедура ГарантированныеОбъемыУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;	
	
	ТекДанные = Элементы.ГарантированныеОбъемы.ТекущиеДанные;
	
	СписокУслуг = ПолучитьСписокУслугДляВыбора(ТекДанные.IDСтроки);
	ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", Новый Структура("СписокУслуг", СписокУслуг), Элемент);	
КонецПроцедуры

#КонецОбласти

#Область СобытияТабличнойЧастиУслугиОбъектов

&НаКлиенте
Процедура УслугиОбъектовУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;	
	
	ТекДанные = Элементы.УслугиОбъектов.ТекущиеДанные;
	
	СписокУслуг = ПолучитьСписокУслугДляВыбора(ТекДанные.IDСтроки);
	ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", Новый Структура("СписокУслуг", СписокУслуг), Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура УслугиОбъектовПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	Если Элементы.УслугиОбъектов.ТекущиеДанные.Услуга.Пустая()=Истина Тогда
		//Отказ=Истина;
	Иначе
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("IDСтроки", Элементы.УслугиОбъектов.ТекущиеДанные.IDСтроки);
		ПараметрыОтбора.Вставить("Услуга", Элементы.УслугиОбъектов.ТекущиеДанные.Услуга);

		НайденныеСтроки = Объект.УслугиОбъектов.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество()> 1 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По услуге "+ Элементы.УслугиОбъектов.ТекущиеДанные.Услуга + " уже введена нагрузка");
			//Объект.УслугиОбъектов.Удалить(Элементы.УслугиОбъектов.ТекущаяСтрока);
			
			ИдентификаторСтроки = Элементы.УслугиОбъектов.ТекущаяСтрока;
			ЭлементКоллекции = Объект.УслугиОбъектов.НайтиПоИдентификатору(ИдентификаторСтроки);
			ИндексЭлементаКоллекции = Объект.УслугиОбъектов.Индекс(ЭлементКоллекции);
			Объект.УслугиОбъектов.Удалить(ИндексЭлементаКоллекции);
			
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УслугиОбъектовПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекДанныеУслуги = Элементы.УслугиОбъектов.ТекущиеДанные;
	Если ТекДанныеУслуги = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	ТекДанныеУслуги.IDСтроки = ТекДанные.IDСтроки;

КонецПроцедуры

&НаКлиенте
Процедура УслугиОбъектовПередУдалением(Элемент, Отказ)
	Отказ 			= Истина;
	ДопПараметры	= Новый Структура;
	ДопПараметры.Вставить("ТЧ", 			"УслугиОбъектов");
	ДопПараметры.Вставить("НомерСтроки", 	Элемент.ТекущиеДанные.НомерСтроки-1);
	ПроверкаУдаленияСтроки(ДопПараметры);
КонецПроцедуры

&НаКлиенте
Процедура УслугиОбъектовУслугаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	Если ЗначениеЗаполнено(Текст) Тогда
		СформироватьДанныеВыбораУслуги(Текст, ДанныеВыбора, СтандартнаяОбработка);	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

