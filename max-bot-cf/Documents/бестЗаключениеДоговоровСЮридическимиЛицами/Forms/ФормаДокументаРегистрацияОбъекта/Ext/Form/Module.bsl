		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#Область ЗАПОЛНИТЬ_УК

Процедура ЗаполнитьТочками(МКД, IDСтрокиВладельца)
	
	РезультатТП 								= Неопределено;
	Результат 									= энргРаботаСприборамиУчетаСервер.ПриборыВсехТочекУчетаМКД(Объект.Дата, Объект.Организация, Объект.Район, МКД, РезультатТП);
	Выборка  									= Результат.выбрать();
	ТекТочкаУчета 								= Неопределено;
	ТекПрибор 									= Неопределено;
	ТекШкала 									= Неопределено;
	IDСтрокиТочки 								= Неопределено;
	IDСтрокиШкалы 								= Неопределено;
	//ПоставщикПоУмолчанию	= ЭтаФорма.ПараметрыПоставщиков.ПоставщикПоУмолчанию;
	Пока Выборка.следующий() цикл		
		НоваяТочка = Ложь;
		Если НЕ ТекТочкаУчета = Выборка.ТочкаУчета Тогда 			
			НоваяТочка = Истина;
			СтрокаТочкиУчета  					= Объект.ТочкиУчета.Добавить();
			IDСтрокиТочки 						= Новый УникальныйИдентификатор;
			ЗаполнитьЗначенияСвойств(СтрокаТочкиУчета, Выборка);
			СтрокаТочкиУчета.IDСтроки 			= IDСтрокиТочки;			
			СтрокаТочкиУчета.IDСтрокиВладельца	= IDСтрокиВладельца;
			//СтрокаТочкиУчета.Поставщик			= ПоставщикПоУмолчанию;
			СтрокаТочкиУчета.Расположение		= Выборка.ТочкаУчета.Расположение;
			СтрокаТочкиУчета.Головная			= Выборка.ТочкаУчета.Головная;;
			СтрокаТочкиУчета.ОбъектУК			= Истина;
			Если ЗначениеЗаполнено( Выборка.УзелУчета) Тогда
				СтрокаТочкиУчета.ТипУзлаУчета		= Выборка.УзелУчета.ТипУзлаУчета;
			КонецЕсли;
						
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) и НЕ ТекПрибор = Выборка.ПриборУчета Тогда 			
			
			СтрокаПриборов  					= Объект.ПриборыУзловУчета.Добавить();
			IDСтрокиШкалы						= Новый УникальныйИдентификатор;
			ЗаполнитьЗначенияСвойств(СтрокаПриборов, Выборка);
			СтрокаПриборов.IDСтроки 			= IDСтрокиТочки;
			СтрокаПриборов.IDСтрокиШкалы 		= IDСтрокиШкалы;		
			
			ЗаполнитьДанныеПрибора(СтрокаПриборов,Выборка.ПриборУчета,МКД);
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ПриборУчета) Тогда //НоваяТочка Или НЕ ТекШкала = Выборка.Шкала Тогда
			СтрокаШкалы  						= Объект.ШкалыПриборовУчета.Добавить();
			IDСтрокиТарифнаяЗона				= Новый УникальныйИдентификатор;
			СтрокаШкалы.IDСтрокиТочкиУчета 		= IDСтрокиТочки;
			СтрокаШкалы.IDСтроки 				= IDСтрокиШкалы;
			СтрокаШкалы.IDСтрокиТарифнаяЗона 	= IDСтрокиТарифнаяЗона;
			СтрокаШкалы.Шкала 					= Выборка.Шкала;
			СтрокаШкалы.ВидПараметра 			= Выборка.ВидПараметра;			
			СтрокаШкалы.ВидДифференцированности = Выборка.ВидДифференцированности;
			
			СтрокаПоказаний 						= Объект.ПоказанияПриборовУчета.Добавить();
			СтрокаПоказаний.IDСтрокиТочкиУчета		= IDСтрокиТочки;
			СтрокаПоказаний.IDСтроки 				= IDСтрокиТарифнаяЗона;
			СтрокаПоказаний.ТарифнаяЗона 			= Выборка.ТарифнаяЗона;
		КонецЕсли; 		
		
		ТекТочкаУчета 							= Выборка.ТочкаУчета;
		ТекШкала 								= Выборка.Шкала;
		ТекПрибор 								= Выборка.ПриборУчета;
	КонецЦикла;
	
	ВыборкаТП = РезультатТП.Выбрать();
	Пока ВыборкаТП.Следующий() Цикл
		СтрокаТП = Объект.ТочкиПоставки.Добавить();
		СтрокаТП.IDСтроки = IDСтрокиВладельца;
		СтрокаТП.ОбъектУК = Истина;
		ЗаполнитьЗначенияСвойств(СтрокаТП, ВыборкаТП);
	КонецЦикла;
	
	ЗаполнитьПараметрыТочекПоставки();
	ЗаполнитьТекстовыеПоля();
	
КонецПроцедуры

Процедура ЗаполнитьДанныеПрибора(ТекСтрока, ПриборУчета, МКД)
	Запрос = Новый Запрос;
	Запрос.Текст =	
	"ВЫБРАТЬ
	|	энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ПриборУчета.Код КАК ЗаводскойНомер,
	|	энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ПриборУчета.ТипПрибораУчета КАК ТипПрибораУчета,
	|	энргДатыПоверкиПрибораУчетаСрезПоследних.ПериодРегистрации КАК ДатаВыпуска,
	|	энргДатыПоверкиПрибораУчетаСрезПоследних.ДатаПоверки КАК ДатаПоверкиСчетчика,
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.НомерПломбы КАК НомерПломбы,
	|	энргНомерПломбПриборовУчетаМКДСрезПоследних.Период КАК ДатаУстановкиПломбы,
	|	энргДопускПриборовУчетаККоммерческомуУчетуМКДСрезПоследних.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	|	энргДопускПриборовУчетаККоммерческомуУчетуМКДСрезПоследних.КонецПериодаКоммерскогоУчета КАК КонецДействияКоммерскогоУчета
	|ИЗ
	|	РегистрСведений.энргСостояниеПриборовУзловУчетаМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И ПриборУчета = &ПриборУчета) КАК энргСостояниеПриборовУзловУчетаМКДСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргДатыПоверкиПрибораУчета.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район
	|					И КлючПомещения = &МКД
	|					И ПриборУчета = &ПриборУчета) КАК энргДатыПоверкиПрибораУчетаСрезПоследних
	|		ПО энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ПриборУчета = энргДатыПоверкиПрибораУчетаСрезПоследних.ПриборУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргНомерПломбПриборовУчетаМКД.СрезПоследних(
	|				&Период,
	|				Организация = &Организация
	|					И Район = &Район
	|					И МКД = &МКД
	|					И ПриборУчета = &ПриборУчета) КАК энргНомерПломбПриборовУчетаМКДСрезПоследних
	|		ПО энргСостояниеПриборовУзловУчетаМКДСрезПоследних.ПриборУчета = энргНомерПломбПриборовУчетаМКДСрезПоследних.ПриборУчета,
	|	РегистрСведений.энргДопускПриборовУчетаККоммерческомуУчетуМКД.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И МКД = &МКД
	|				И ПриборУчета = &ПриборУчета) КАК энргДопускПриборовУчетаККоммерческомуУчетуМКДСрезПоследних
	|ГДЕ
	|	энргСостояниеПриборовУзловУчетаМКДСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод)";
	
	Запрос.УстановитьПараметр("МКД"				, МКД);
	Запрос.УстановитьПараметр("Организация"		, Объект.Организация);
	Запрос.УстановитьПараметр("Период"			, Новый Граница(Объект.Дата,ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Район"			, Объект.Район);
	Запрос.УстановитьПараметр("ПриборУчета"		, ПриборУчета);
	
	РезультатЗапроса 	= Запрос.Выполнить();	
	ВыборкаТочкиУчета	= РезультатЗапроса.Выбрать();
	Пока  ВыборкаТочкиУчета.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ТекСтрока, ВыборкаТочкиУчета);
	КонецЦикла;
	
	
КонецПроцедуры

