&НаСервере
Процедура ЗаполнитьГрафикиРежимаОграничения()
	Объект.ГрафикиРежимаОграничения.Сортировать("КодРежима");
	КодРежима = Неопределено;
	Для каждого стр из Объект.ГрафикиРежимаОграничения Цикл
		Если стр.КодРежима <> КодРежима Тогда
			НовСтр = ТЗГрафикиРежимаОграничения.Добавить();
		КонецЕсли;
		КодРежима = стр.КодРежима;
		ЗаполнитьЗначенияСвойств(НовСтр, стр); 
		НовСтр["Значение" + стр.Месяц] = стр.Значение;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаписатьГрафикиРежимаОграничения()
	Объект.ГрафикиРежимаОграничения.Очистить();
	Для каждого стр Из ТЗГрафикиРежимаОграничения Цикл
		ТекущийЧас = 1;
		Пока ТекущийЧас <= 12 Цикл
			Если стр["Значение" + ТекущийЧас] <> 0 Тогда
				НовСтр 				= Объект.ГрафикиРежимаОграничения.Добавить();
				НовСтр.Услуга 		= стр.Услуга;
				НовСтр.КодРежима 	= стр.КодРежима;
				НовСтр.IDСтроки 	= стр.IDСтроки;
				НовСтр.Значение 	= стр["Значение" + ТекущийЧас];
				НовСтр.Месяц 		= ТекущийЧас;
			КонецЕсли;
			ТекущийЧас = ТекущийЧас + 1;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

