&НаКлиенте
Процедура ИнформацияОбъектаЗавершение(Результат, ДополнительныеПараметры) Экспорт	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 	= ДополнительныеПараметры.ТекущиеДанные;
	
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, Результат);
	ТекущиеДанные.ДополнительнаяИнформация 		= бестРаботаСОбъектамиНПСервер.ЗаполнитьТекстИнформацииОбъекта(Результат);
КонецПроцедуры

&НаКлиенте
Процедура НастроитьВидимостьЭлементов()
	ЭтоЗаявка = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение");
	//Элементы.ГруппаНастройкиОплаты.Видимость 		= ЭтоЗаявка;
	Элементы.ГруппаДанныеЗаявки.Видимость 			= ЭтоЗаявка;
	Элементы.ЗаключениеДоговораДоТП.Видимость 		= ЭтоЗаявка;
	Элементы.ФормаСоздатьНаОсновании.Видимость 		= ЭтоЗаявка;

	Элементы.ДокументОснование.Видимость			= ЗначениеЗаполнено(Объект.ДокументОснование);
	
	Если ЭтоЗаявка Тогда
		НастроитьВидимостьДанныхОТП();
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Группа1", "Видимость", Объект.РассчитыватьПени);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПотребителей", "Видимость", Объект.РассчитыватьПени);
	Если Объект.РассчитыватьПени и НЕ Объект.ВариантРасчета = ПредопределенноеЗначение("Перечисление.бестВариантыРасчетаПени.ОтСтавкиРефинансирования") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПотребителей", "Видимость", Ложь);
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПроцентПени", "Видимость", Объект.ВариантРасчета = ПредопределенноеЗначение("Перечисление.бестВариантыРасчетаПени.ОтСуммы"));

	НезависимыйСбыт = бестРаботаСНезависимымСбытом.ПолучитьУчетНезависимыйСбыт();
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаГруппа3", "Видимость", Не НезависимыйСбыт);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаНастройкиТарифа", "Видимость", НезависимыйСбыт);
КонецПроцедуры

&НаКлиенте
Процедура НастроитьВидимостьДанныхОТП()
	Элементы.ЗаявкаНаТехнологическоеПрисоединение.Видимость = Объект.ЗаключениеДоговораДоТП;
