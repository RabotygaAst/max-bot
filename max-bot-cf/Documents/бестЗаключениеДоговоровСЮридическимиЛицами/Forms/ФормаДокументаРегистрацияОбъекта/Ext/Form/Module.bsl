&НаСервере
Процедура ЗаполнитьДанныеДоговораСервер(НеПерезаполнятьОбъекты)
	
	Если Не Объект.Договор.ТипДоговора = ПредопределенноеЗначение("Перечисление.бестТипыДоговоров.УправляющаяКомпания") Тогда
		Возврат;	
	КонецЕсли; 
	
	Если НЕ НеПерезаполнятьОбъекты Тогда
		Объект.ОбъектыРасчета.Очистить();
	КонецЕсли;
	Объект.ТочкиПоставки.Очистить();
	Объект.ТочкиУчета.Очистить();
	Объект.ПоставщикиСоставныхУслуг.Очистить();
	Объект.ШкалыПриборовУчета.Очистить();
	Объект.ШкалыУслуг.Очистить();
	Объект.ПоказанияПриборовУчета.Очистить();
	Объект.ПриборыУзловУчета.Очистить();
	
	Результат 									= ПолучитьОбъектыРасчетаУправляющейКомпании(Объект.Дата, Объект.Организация, Объект.Район, Объект.Контрагент, Объект.Договор);
	Выборка  									= Результат.Выбрать();	
	Пока Выборка.Следующий() Цикл		
		Если НеПерезаполнятьОбъекты Тогда
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("МКД", Выборка.МКД);
			НайденныеСтроки = Объект.ОбъектыРасчета.НайтиСтроки(ПараметрыОтбора);
			Если НайденныеСтроки.Количество() > 0 Тогда
				НовСтр = НайденныеСтроки[0];
			Иначе
				НовСтр = Объект.ОбъектыРасчета.Добавить();
				НовСтр.МКД							= Выборка.МКД;
				НовСтр.ГруппаОбъектовРасчета		= Выборка.ГруппаПотребителейПоУмолчанию;
				НовСтр.НаименованиеОбъектаРасчета	= Выборка.МКД;
				НовСтр.Площадь						= Выборка.Площадь;
				НовСтр.IDСтроки						= Новый УникальныйИдентификатор;
			КонецЕсли;
		Иначе
			НовСтр = Объект.ОбъектыРасчета.Добавить();
			НовСтр.МКД							= Выборка.МКД;
			НовСтр.ГруппаОбъектовРасчета		= Выборка.ГруппаПотребителейПоУмолчанию;
			НовСтр.НаименованиеОбъектаРасчета	= Выборка.МКД;
			НовСтр.Площадь						= Выборка.Площадь;
			НовСтр.IDСтроки						= Новый УникальныйИдентификатор;
		КонецЕсли;
		
		НовСтр.ОбъектУК						= Истина;
		//ЗаполнитьУслугиМКД(НовСтр.МКД,НовСтр.IDСтроки);
		
		ЗаполнитьТочками(НовСтр.МКД, НовСтр.IDСтроки);
		
		энргРаботаСПоказаниямиПриборовУчетаСервер.ОбновитьПоказанияПриборовУчетаМКД(Объект.ТочкиУчета,Объект.ШкалыПриборовУчета,Объект.ПоказанияПриборовУчета,Объект.Дата,Объект.Организация, Объект.Район,НовСтр.МКД,Ложь);
		
	КонецЦикла;
	
	энргРаботаСТочкамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
	//энргРаботаСприборамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
	
КонецПроцедуры

&НаСервере
Функция ЗаписатьОписаниеОбъекта(СтруктураОбъекта)
	Запись  									= Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	Запись.ЗаписатьНачалоОбъекта();
	
	Запись.ЗаписатьИмяСвойства("Наименование");
	Запись.ЗаписатьЗначение(СтруктураОбъекта.НаименованиеОбъектаРасчета);
	Запись.ЗаписатьИмяСвойства("НазначениеНП");
	Запись.ЗаписатьЗначение("" + СтруктураОбъекта.НазначениеНП.УникальныйИдентификатор());
	Запись.ЗаписатьИмяСвойства("ГруппаОбъектовРасчета");
	Запись.ЗаписатьЗначение("" + СтруктураОбъекта.ГруппаОбъектовРасчета.УникальныйИдентификатор());
	Запись.ЗаписатьИмяСвойства("КатегорияОбъекта");
	Запись.ЗаписатьЗначение("" + СтруктураОбъекта.КатегорияОбъекта.УникальныйИдентификатор());			
	Запись.ЗаписатьИмяСвойства("МКД");
	Запись.ЗаписатьЗначение("" + СтруктураОбъекта.МКД.УникальныйИдентификатор());
	Запись.ЗаписатьИмяСвойства("Контролер");
	Запись.ЗаписатьЗначение("" + СтруктураОбъекта.Контролер.УникальныйИдентификатор());
	Запись.ЗаписатьИмяСвойства("Организация");
	Запись.ЗаписатьЗначение("" + СтруктураОбъекта.Организация.УникальныйИдентификатор());
	Запись.ЗаписатьИмяСвойства("АдресОбъекта");
	Запись.ЗаписатьЗначение(?(ЗначениеЗаполнено(СтруктураОбъекта.АдресОбъекта), СтруктураОбъекта.АдресОбъекта,""));
	Запись.ЗаписатьИмяСвойства("АдресОбъектаЗначение");
	Запись.ЗаписатьЗначение(?(ЗначениеЗаполнено(СтруктураОбъекта.АдресОбъектаЗначение), СтруктураОбъекта.АдресОбъектаЗначение,""));
	
	Запись.ЗаписатьКонецОбъекта();
	Возврат Запись.Закрыть();	
	
КонецФункции

&НаКлиенте
Процедура ОбновитьСуммуПоКварталу()
	Для каждого ТекСтрока из Объект.ГарантированныеОбъемы Цикл
		ИтогПервыйКвартал 		= ТекСтрока.Январь + ТекСтрока.Февраль + ТекСтрока.Март;
		ИтогВторойКвартал 		= ТекСтрока.Апрель + ТекСтрока.Май + ТекСтрока.Июнь;
		ИтогТретийКвартал 		= ТекСтрока.Июль + ТекСтрока.Август + ТекСтрока.Сентябрь;
		ИтогЧетвертыйКвартал 	= ТекСтрока.Октябрь + ТекСтрока.Ноябрь + ТекСтрока.Декабрь;
		//ИтогГод 				= ИтогПервыйКвартал + ИтогВторойКвартал + ИтогТретийКвартал + ИтогЧетвертыйКвартал;
		
		ТекСтрока.ГарантированныйОбъемИтогПервыйКвартал 	= ИтогПервыйКвартал;
		ТекСтрока.ГарантированныйОбъемИтогВторойКвартал 	= ИтогВторойКвартал;
		ТекСтрока.ГарантированныйОбъемИтогТретийКвартал 	= ИтогТретийКвартал;
		ТекСтрока.ГарантированныйОбъемИтогЧетвертыйКвартал 	= ИтогЧетвертыйКвартал;
		ТекСтрока.ГарантированныйОбъемИтогГод				= ИтогПервыйКвартал+ИтогВторойКвартал +ИтогТретийКвартал + ИтогЧетвертыйКвартал;	
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПроставитьДатыКомУчетаДляПУ(IDСтрокиТУ, ДатаКомУчета, ЭтоНачалоКомУчета)
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("IDСтроки", IDСтрокиТУ);
	НайденныеСтроки = Объект.ПриборыУзловУчета.НайтиСтроки(ПараметрыОтбора);
	Для каждого стр из НайденныеСтроки Цикл
		Если ЭтоНачалоКомУчета Тогда
			стр.НачалоДействияКоммерскогоУчета = ДатаКомУчета;
		Иначе
			стр.КонецДействияКоммерскогоУчета = ДатаКомУчета;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСвязанныеСОбъектомСтроки(IDСтроки)
	ТаблицыФормы = Новый Массив;	
	ТаблицыФормы.Добавить("ГарантированныеОбъемы");
	ТаблицыФормы.Добавить("ТочкиПоставки");
	ТаблицыФормы.Добавить("ГрафикиРежимаОграничения");
	ТаблицыФормы.Добавить("ВеличинаБрони");
	
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(IDСтроки, Объект, ТаблицыФормы);
	
	ТаблицыФормы = Новый Массив;	
	ТаблицыФормы.Добавить("ПостоянныйРасходТУ"); 
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(IDСтроки, Объект, ТаблицыФормы, "ОбъектРасчета");
	
	СтруктураПоиска  			= Новый Структура("IDСтрокиВладельца", IDСтроки);
	Коллекция  					= Объект["ТочкиУчета"];
	Строки  					= Коллекция.НайтиСтроки(СтруктураПоиска);
	
	
	ТаблицыФормы	= Новый Массив;
	ТаблицыФормы.Добавить("ПоказанияПриборовУчета");
	Для Каждого УдаляемаяСтрока из Строки Цикл
		энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(УдаляемаяСтрока.IDСтроки, Объект, ТаблицыФормы,"ТочкиУчета");
	КонецЦикла;	
	
	ТаблицыФормы	= Новый Массив;
	ТаблицыФормы.Добавить("ТочкиПоставки");
	Для Каждого УдаляемаяСтрока из Строки Цикл
		энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(УдаляемаяСтрока.IDСтроки, Объект, ТаблицыФормы);
	КонецЦикла;	
	ТаблицыФормы.Очистить();
	
	
	ТаблицыФормы.Добавить("ТочкиУчета");
	ТаблицыФормыВторогоУровня	= Новый Массив;
	ТаблицыФормыВторогоУровня.Добавить("ОбъемыРаспределенияПотерь");
	ТаблицыФормыВторогоУровня.Добавить("ПоставщикиСоставныхУслуг");
	
	Для Каждого УдаляемаяСтрока из Строки Цикл
		энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(УдаляемаяСтрока.IDСтроки, Объект, ТаблицыФормы,"Владельца", ТаблицыФормыВторогоУровня);
		Коллекция.Удалить(УдаляемаяСтрока);
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПараметрыТочекПоставки(ТекТочкаПоставки = Неопределено)
	
	Если ЗначениеЗаполнено(ТекТочкаПоставки) Тогда
		мТочек = Новый Массив;
		мТочек.Добавить(ТекТочкаПоставки);
	Иначе
		мТочек = Объект.ТочкиПоставки.Выгрузить().ВыгрузитьКолонку("ТочкаПоставки");
	КонецЕсли;
	
	РезультатЗапроса 				= РегистрыСведений.энргПараметрыТочекПоставки.АктуальныеПараметрыТочкиПоставкиПоСсылке(мТочек);
	
	СоответствиеКатегорийНапряжения = РегистрыСведений.энргКатегорииНадежностиТочекПоставок.ПолучитьКатегорииНапряжения(Объект.Дата, мТочек);
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("ТочкаПоставки", Выборка.ТочкаПоставки);
		мСтрок = Объект.ТочкиПоставки.НайтиСтроки(ПараметрыОтбора);
		Для каждого стр из мСтрок Цикл
			ЗаполнитьЗначенияСвойств(Стр, Выборка);
			Если СоответствиеКатегорийНапряжения[Выборка.ТочкаПоставки] <> Неопределено Тогда
				Стр.КатегорияНадежности = СоответствиеКатегорийНапряжения[Выборка.ТочкаПоставки];
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьИтогиТочекПоставки(IDСтрокиОбъектРасчета)
	ПараметрыОтбора = Новый Структура("IDСтроки", IDСтрокиОбъектРасчета);
	мСтрок =Объект.ТочкиПоставки.НайтиСтроки(ПараметрыОтбора);
	ПрисоединеннаяМощностьИтог 	= 0;
	МаксимальнаяМощностьИтог 	= 0;
	Для каждого стр из мСтрок Цикл
		ПрисоединеннаяМощностьИтог 	= ПрисоединеннаяМощностьИтог + стр.ПрисоединеннаяМощность;
		МаксимальнаяМощностьИтог	= МаксимальнаяМощностьИтог + стр.МаксимальнаяМощность;
	КонецЦикла;
	
	Элементы.ИнформацияОМощности.Заголовок = бестРаботаСТочкамиУчетаНПКлиент.ПолучитьРасшифровкуМощности(МаксимальнаяМощностьИтог);
КонецПроцедуры

