#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПрефиксТочекУчета = "";
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Если не ЗначениеЗаполнено(Объект.ПериодНачисления) Тогда
			Объект.ПериодНачисления = Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
		КонецЕсли;
	КонецЕсли;
		
	// энргРаботаСПоставщиками {
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма);
	// энргРаботаСПоставщиками }
	
	// энргРаботаСоСпособамиРасчетаНорматива {
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма,"СпособРасчетаНорматива","СпособыРасчетаНормативаСоставныхУслуг","ПараметрыСпособовРасчетаНорматива");
	// энргРаботаСоСпособамиРасчетаНорматива }
	
	энргРаботаСПоставщикамиСервер.ПриСозданииФормыНаСервере(ЭтаФорма,"Договор","ДоговорыСоставныхУслуг","ПараметрыДоговоров");
	
	// ВводНаОсновании
	ВводНаОсновании.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюСоздатьНаОсновании);
	// Конец ВводНаОсновании
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодменюОтчеты;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("бестИспользоватьТарифныеЗоны");
		яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("бестИспользоватьШкалыПриборовУчета");
		энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета);
		Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
			энргРаботаСТочкамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
			
			энргРаботаСприборамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
			
			бестРаботаСОбъектамиНПСервер.ПрочитатьДанныеОбъекта(ЭтотОбъект, "ОбъектыРасчета");
		КонецЕсли;	
	КонецЕсли;
	ПрефиксТочекУчета = "";
	ЗаполнитьТекстовыеПоля();
	ЗаполнитьГрафикиРежимаОграничения();
	ЗаполнитьПараметрыТочекПоставки();
	ЗаполнитьТУВПостоянномРасходе();
	бестЛокализацияСервер.ПриСозданииНаСервере_бестЗаключениеДоговоровСЮридическимиЛицами(ЭтотОбъект);
	
	ПриСозданииНаСервереПереопределяемый(Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	энргРаботаСТочкамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");

	энргРаботаСприборамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");

	бестРаботаСОбъектамиНПСервер.ПрочитатьДанныеОбъекта(ЭтотОбъект, "ОбъектыРасчета");
	
	яИспользоватьТарифныеЗоны 		= Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("бестИспользоватьТарифныеЗоны");
	яИспользоватьШкалыПриборовУчета = Обработки.энргКонстантыМенеджер.ЗначениеФункциональнойОпции("бестИспользоватьШкалыПриборовУчета");
	энргШкалыТарифныеЗоныСервер.ПриСозданииЧтенииНаСервере(ЭтотОбъект,яИспользоватьТарифныеЗоны,яИспользоватьШкалыПриборовУчета,ТекущийОбъект);
	
	ЗаполнитьСвойстваПриборовУчета(ТекущийОбъект);
	ЗаполнитьСвойстваИзмерителей(ТекущийОбъект);
	ЗаполнитьТекстовыеПоля(); 	
КонецПроцедуры  

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ЗаполнитьДанныеКварталов();
	НастроитьВидимостьЭлементов();
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	ЗаписатьГрафикиРежимаОграничения(); 
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ПроверкаДублированияНаименованийОбъектовРасчета(Отказ);			
	//энргРаботаСприборамиУчетаСервер.ЗаписатьПараметрыТочек_Узлов_Приборов(Объект.ТочкиУчета, Объект.ПриборыУзловУчета, ТекущийОбъект);
	СоответствиеСтрок 						= Новый Соответствие;	
	ЗаписатьПараметрыТочекИПриборовУчета(ТекущийОбъект, СоответствиеСтрок);
	бестПользовательскийВводСервер.ЗаписатьПараметрыОбъекта(Объект.ОбъектыРасчета, ТекущийОбъект);
	
	// Добавлено для УК!
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение и Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение") Тогда
		
		ПроверитьЗаполнениеДанных(Отказ);
		
		НовыеОбъектыРасчета					= Новый Массив;
		
		Сч = 0;
		Для Каждого СтрокаОбъектовРасчета Из ТекущийОбъект.ОбъектыРасчета Цикл
			Если СтрокаОбъектовРасчета.ОписаниеОбъекта <> Объект.ОбъектыРасчета[Сч].ОписаниеОбъекта И Не ПустаяСтрока(Объект.ОбъектыРасчета[Сч].ОписаниеОбъекта)	Тогда
				//Если НЕ ЗначениеЗаполнено(СтрокаОбъектовРасчета.ОбъектРасчета) Тогда
					СтрокаОбъектовРасчета.ОписаниеОбъекта	= Объект.ОбъектыРасчета[Сч].ОписаниеОбъекта;
				//КонецЕсли;
				СтрокаОбъектовРасчета.ОбъектРасчета	= Объект.ОбъектыРасчета[Сч].ОбъектРасчета;
			КонецЕсли;
			Если Не ПустаяСтрока(СтрокаОбъектовРасчета.ОписаниеОбъекта) И НЕ ЗначениеЗаполнено(СтрокаОбъектовРасчета.ОбъектРасчета) Тогда
				СтрокаОбъектовРасчета.ОбъектРасчета = Справочники.бестОбъектыРасчета.ПолучитьСсылку(Новый УникальныйИдентификатор);
				НовыеОбъектыРасчета.Добавить(СтрокаОбъектовРасчета.НомерСтроки);
			КонецЕсли;			
			Сч = Сч +1;
		КонецЦикла;
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеОбъектыРасчета",НовыеОбъектыРасчета);
		Если Объект.Договор.ТипДоговора <> Перечисления.бестТипыДоговоров.УправляющаяКомпания Тогда
					
			Справочники.энргПриборыУчетаАбонента.НайтиПриборыУчетаПоПараметрам(ТекущийОбъект,"ТочкиУчета",Отказ);
			// TODO FIX ME
			Справочники.энргПриборыУчетаАбонента.НайтиПриборыУчетаПоПараметрам(ТекущийОбъект,"Измерители",Отказ);
			
			НовыеТочкиУчета						= Новый Массив;
			НовыеУзлыУчета 						= Новый Массив;
			НовыеПриборыУчета 					= Новый Массив;
			НовыеИзмерители 					= Новый Массив;
			СоответствиеПрибора 				= Новый Соответствие;
			
			Для Каждого СтрокаТочкиУчета Из ТекущийОбъект.ТочкиУчета Цикл
				Если Не ЗначениеЗаполнено(СтрокаТочкиУчета.ТочкаУчета) Тогда
					СтрокаТочкиУчета.ТочкаУчета = Справочники.энргТочкиУчета.ПолучитьСсылку(Новый УникальныйИдентификатор);
					НовыеТочкиУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
				КонецЕсли;
				
				// Теперь это для узлов --
				//Если Не ПустаяСтрока(СтрокаТочкиУчета.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаТочкиУчета.ПриборУчета) Тогда
				//	СтрокаТочкиУчета.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
				//	НовыеУзлыУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
				//КонецЕсли;
				Если Не ПустаяСтрока(СтрокаТочкиУчета.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаТочкиУчета.ПриборУчета) Тогда
					СтрокаТочкиУчета.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
					НовыеПриборыУчета.Добавить(СтрокаТочкиУчета.НомерСтроки);
					
					ЗаводскойНомерЗначение = СоответствиеСтрок[СтрокаТочкиУчета.IDСтроки];
					СоответствиеПрибора.Вставить(ЗаводскойНомерЗначение, СтрокаТочкиУчета.ПриборУчета);
				КонецЕсли;
				// --Теперь это для узлов					
				
			КонецЦикла;
			
			//Для Каждого СтрокаПриборовУчета Из ТекущийОбъект.ПриборыУзловУчета Цикл
			//	
			//	Если Не ПустаяСтрока(СтрокаПриборовУчета.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаПриборовУчета.ПриборУчета) Тогда
			//		СтрокаПриборовУчета.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
			//		НовыеПриборыУчета.Добавить(СтрокаПриборовУчета.НомерСтроки);
			//	КонецЕсли;			
			//	
			//КонецЦикла;
			
			Для Каждого СтрокаИзмерителя Из ТекущийОбъект.Измерители Цикл
				Если Не ПустаяСтрока(СтрокаИзмерителя.ОписаниеПрибора) И НЕ ЗначениеЗаполнено(СтрокаИзмерителя.ПриборУчета) Тогда
					//СтрокаИзмерителя.ПриборУчета = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
					//НовыеИзмерители.Добавить(СтрокаИзмерителя.НомерСтроки);
					
					ПриборУчетаЗначение = СоответствиеПрибора[СтрокаИзмерителя.ЗаводскойНомер];
					СоздаватьНовый 		= ПриборУчетаЗначение = Неопределено ИЛИ СтрокаИзмерителя.ВспомогательноеОборудование;
					
					Если СоздаватьНовый Тогда
						ПриборУчетаЗначение = Справочники.энргПриборыУчетаАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор);
						НовыеИзмерители.Добавить(СтрокаИзмерителя.НомерСтроки);
					КонецЕсли;			
					
					СтрокаИзмерителя.ПриборУчета = ПриборУчетаЗначение;
				КонецЕсли;			
			КонецЦикла;

			
			
			ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеТочкиУчета", 	НовыеТочкиУчета);
			//ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеУзлыУчета", 	НовыеУзлыУчета);
			ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеИзмерители", 	НовыеИзмерители);
			ТекущийОбъект.ДополнительныеСвойства.Вставить("НовыеПриборыУчета", 	НовыеПриборыУчета);
			
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение и Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение") Тогда
		Для каждого стр из Объект.ОбъектыРасчета Цикл
			бестРаботаСПоследовательностямиНП.ВосстановитьПоследовательностьПоНП(Объект.Организация, Объект.ПериодНачисления,Объект.Район,стр.ОбъектРасчета);
		КонецЦикла;
	КонецЕсли;
	
	//Пока нет
	
	//ДопСвойства  = ТекущийОбъект.ДополнительныеСвойства;
	//Если ДопСвойства.свойство("УстановкаФормулыРасчета") тогда
	//	ДанныеУстановкиФормулыРасчета = ДопСвойства.УстановкаФормулыРасчета;		 
	//иначе
	//	ДанныеУстановкиФормулыРасчета = Неопределено;
	//КонецЕсли;
	//	
	//Если ДопСвойства.свойство("ДанныеДляПерерасчета") тогда
	//	ДанныеДляПерерасчета = ДопСвойства.ДанныеДляПерерасчета;		 
	//иначе
	//	ДанныеДляПерерасчета = Неопределено;
	//КонецЕсли;

	//Пока нет

	энргРаботаСТочкамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
	
	энргРаботаСприборамиУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, "ТочкиУчета");
	
	бестРаботаСОбъектамиНПСервер.ПрочитатьДанныеОбъекта(ЭтотОбъект, "ОбъектыРасчета");
	
	ЗаполнитьСвойстваПриборовУчета(ТекущийОбъект);
	ЗаполнитьСвойстваИзмерителей(ТекущийОбъект);
	
	ЗаполнитьПараметрыТочекПоставки();
	
	ЗаполнитьТекстовыеПоля();
	ЗаполнитьТУВПостоянномРасходе();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	//Пока нет

	//Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение тогда
		//энргРаботаСТочкамиУчетаСервер.ЗаполнитьДанныеДляФормулРасчета(ТекущийОбъект);
		//энргРаботаСПериодомДействия.ЗаполнитьДанныеДляПерерасчета(ТекущийОбъект);
	//КонецЕсли;
	
	//Пока нет
	
	Если Не Отказ и ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение и Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.бестВидыОпераций.ОперацияСДоговором_ЗаявкаНаЗаключение") Тогда 
		бестРаботаСОбъектамиНПСервер.ПроверитьИСоздатьОбъектыРасчета(ТекущийОбъект,"ОбъектыРасчета");
		// Добавлено для УК!
		Если Объект.Договор.ТипДоговора <> Перечисления.бестТипыДоговоров.УправляющаяКомпания Тогда
			энргРаботаСТочкамиУчетаСервер.СоздатьТочкиУчета(ТекущийОбъект,"ТочкиУчета" ,Отказ);
			
			НовыеПриборыУчета 					= Новый Массив;
			Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеПриборыУчета") Тогда
				НовыеПриборыУчета 				= ТекущийОбъект.ДополнительныеСвойства.НовыеПриборыУчета;
			КонецЕсли;
			
			НовыеИзмерители 					= Новый Массив;
			Если ТекущийОбъект.ДополнительныеСвойства.Свойство("НовыеИзмерители") Тогда
				НовыеИзмерители 				= ТекущийОбъект.ДополнительныеСвойства.НовыеИзмерители;
			КонецЕсли;
			
			Для Каждого СтрокаТочки Из ТекущийОбъект.ТочкиУчета Цикл
				Если ЗначениеЗаполнено(СтрокаТочки.ПриборУчета) Тогда
					ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,НовыеПриборыУчета, СтрокаТочки.ПриборУчета, СтрокаТочки.ОписаниеПрибора, СтрокаТочки.НомерСтроки);
				КонецЕсли;			
			КонецЦикла;
			
			Для Каждого СтрокаИзмерителя Из ТекущийОбъект.Измерители Цикл
				ЗаполнитьДанныеПрибораУчетаВСтроке(Отказ,НовыеИзмерители, СтрокаИзмерителя.ПриборУчета, СтрокаИзмерителя.ОписаниеПрибора, СтрокаИзмерителя.НомерСтроки);						
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Для каждого стр из Объект.ОбъектыРасчета Цикл
		ОповеститьОбИзменении(стр.ОбъектРасчета);		
	КонецЦикла;
		
	ОбновитьСуммуПоКварталу();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		ПриИзмененииДатыИлиДоговора();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	бестРаботаСВидамиОперацийКлиент.ПриИзмененииВидаОперации("бестЗаключениеДоговоровСЮридическимиЛицами",Объект,Параметры.Ключ);
	Модифицированность = Ложь;
	ЭтаФорма.Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура ДоговорКонтрагентаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Договор) тогда
		бестПользовательскийВводКлиент.ПриИзмененииДоговораКонтрагента(Объект, "ДатаФактическогоСобытия");
		ПриИзмененииДатыИлиДоговора();
		ЗаполнитьРеквизитыПоДоговору();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ДоговорКонтрагентаСоздание(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ПараметрыФормы = Новый Структура("БлокЮридическихЛиц", Истина);
	ОткрытьФорму("Справочник.энргДоговорыКонтрагентов.ФормаОбъекта", ПараметрыФормы);
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда		
		ЗаполнитьПериодНачисленияСервер(); 		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	Объект.Организация = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Район,"Организация");
	ЗаполнитьПериодНачисленияСервер();
КонецПроцедуры

&НаКлиенте
Процедура РассчитыватьПениПриИзменении(Элемент)
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Группа1", "Видимость", Объект.РассчитыватьПени);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПотребителей", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПроцентПени", "Видимость",  Не Объект.РассчитыватьПени);
	Объект.ВариантРасчета = ПредопределенноеЗначение("Перечисление.бестВариантыРасчетаПени.ПустаяСсылка");
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантРасчетаПриИзменении(Элемент)
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПроцентПени", "Видимость", Объект.ВариантРасчета = ПредопределенноеЗначение("Перечисление.бестВариантыРасчетаПени.ОтСуммы"));
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПотребителей", "Видимость", Объект.ВариантРасчета = ПредопределенноеЗначение("Перечисление.бестВариантыРасчетаПени.ОтСтавкиРефинансирования"));
		
КонецПроцедуры

&НаКлиенте
Процедура ТочкаУчетаДоТППриИзменении(Элемент)
	
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекДанные.ТочкаУчетаДоТП = ТочкаУчетаДоТП;
	НастроитьВидимостьДанныхОТПДляОбъектовРасчета();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаявкаНаТПДляОбъектаРасчетаПриИзменении(Элемент)
	
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекДанные.ЗаявкаНаТехнологическоеПрисоединение = ЗаявкаНаТПДляОбъектаРасчета;
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговорТПДляОбъектаРасчетаПриИзменении(Элемент)
	
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекДанные.ДоговорТехнологическогоПрисоединения = ДоговорТПДляОбъектаРасчета;
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговорКонтрагентаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	бестПользовательскийВводКлиент.НачалоВыбораДоговора(Элемент,Объект.Организация,Объект.Контрагент,СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	Объект.Договор = Неопределено;
КонецПроцедуры

&НаКлиенте
Процедура ЗаключениеДоговораДоТППриИзменении(Элемент)
	НастроитьВидимостьДанныхОТП();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОбъектыРасчета

&НаКлиенте
Процедура ОбъектыРасчетаПриАктивизацииСтроки(Элемент)
		
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекОбъектРасчета = ТекДанные.ОбъектРасчета;
	
	ТочкаУчетаДоТП = ТекДанные.ТочкаУчетаДоТП;
	ЗаявкаНаТПДляОбъектаРасчета = ТекДанные.ЗаявкаНаТехнологическоеПрисоединение;
	ДоговорТПДляОбъектаРасчета = ТекДанные.ДоговорТехнологическогоПрисоединения;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкаУчетаДоТП", "Видимость", Истина);
	НастроитьВидимостьДанныхОТПДляОбъектовРасчета();
	
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ГарантированныеОбъемы,					Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ТЗГрафикиРежимаОграничения,			Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ВеличинаБрони,			                Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы["ТочкиУчета"],	Неопределено,		ТекДанные.IDСтроки,, "Владельца");
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы["ТочкиПоставокОбъектовРасчета"],	Неопределено,		ТекДанные.IDСтроки);
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПостоянныйРасходТУ,	Неопределено,	ТекДанные.IDСтроки,, "ОбъектРасчета");
	ЗаполнитьИтогиТочекПоставки(ТекДанные.IDСтроки);
	УстановитьПараметрыВыбораУслуги();
	
	Элементы.ТочкиУчета.КоманднаяПанель.ПодчиненныеЭлементы.ТочкиУчетаДобавить.Доступность = Не ТекДанные.ОбъектУК;
	Элементы.ТочкиУчета.КоманднаяПанель.ПодчиненныеЭлементы.ТочкиУчетаУдалить.Доступность = Не ТекДанные.ОбъектУК;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаТочкиПоставки", "ТолькоПросмотр", ТекДанные.ОбъектУК);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаГруппа17", "ТолькоПросмотр", ТекДанные.ОбъектУК);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаТУ4", "ТолькоПросмотр", ТекДанные.ОбъектУК);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаСредстваИзмерения", "ТолькоПросмотр", ТекДанные.ОбъектУК);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаТехническиеСвойстваТУ", "ТолькоПросмотр", ТекДанные.ОбъектУК);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаОбъемы", "ТолькоПросмотр", ТекДанные.ОбъектУК);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаГрафикиРежимаОграничения", "ТолькоПросмотр", ТекДанные.ОбъектУК);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаВеличинаБрони", "ТолькоПросмотр", ТекДанные.ОбъектУК);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТочкиУчетаДобавитьСубабонентов", "Доступность", Не ТекДанные.ОбъектУК);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаНаименованиеОбъектаРасчетаПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекДанные.НаименованиеОбъектаРасчета) и НЕ ЗначениеЗаполнено(ТекДанные.ОбъектРасчета) Тогда
		Если НЕ ЗначениеЗаполнено(ТекДанные.Собственник) Тогда
			ТекДанные.Собственник	= Объект.Контрагент;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаОбъектРасчетаПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекДанные.ОбъектРасчета) Тогда
		
		ТекСтрока 	= 	ТекДанные.ПолучитьИдентификатор();
		Отбор		= 	Новый Структура("ОбъектРасчета", ТекДанные.ОбъектРасчета);
		ИщемСтроки	=	Объект.ОбъектыРасчета.НайтиСтроки(Отбор);
		Если ИщемСтроки.Количество()>1 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Данные по объекту расчета " + ТекДанные.ОбъектРасчета + " уже введены. Строка не будет добавлена");
			Объект.ОбъектыРасчета.Удалить(ТекДанные.НомерСтроки-1);
			Возврат;
		КонецЕсли;		
		
		Если ТекОбъектРасчета = ТекДанные.ОбъектРасчета Тогда
			ДанныеОбъекта = бестРаботаСОбъектамиНПСервер.ПолучитьИнформациюПоОбъекту(ТекДанные.ОбъектРасчета);
			ЗаполнитьЗначенияСвойств(ТекДанные, ДанныеОбъекта.СтруктураОбъекта);
			ТекДанные.ОписаниеОбъекта = ЗаписатьОписаниеОбъекта(ДанныеОбъекта.СтруктураОбъекта);
		Иначе	
			// Ищем строки по индентификатору
			ТаблицыФормы				= Новый Массив;	
			ТаблицыФормы.Добавить("ГарантированныеОбъемы");
		
			энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(Элементы.ОбъектыРасчета.ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы);
			
			ТаблицыФормы				= Новый Массив;	
			ТаблицыФормы.Добавить("ТочкиУчета");
			энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(Элементы.ОбъектыРасчета.ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы, "Владельца");
				
			ДанныеОбъекта = бестРаботаСОбъектамиНПСервер.ПолучитьИнформациюПоОбъекту(ТекДанные.ОбъектРасчета);
			ЗаполнитьЗначенияСвойств(ТекДанные, ДанныеОбъекта.СтруктураОбъекта);
					
			МассивОбъемов = ДанныеОбъекта.МассивОбъемов;
			Для Каждого ТекОбъем Из МассивОбъемов Цикл
				НовСтрока = Объект.ГарантированныеОбъемы.Добавить();
				НовСтрока.IDСтроки	= ТекДанные.IDСтроки;
				ЗаполнитьЗначенияСвойств(НовСтрока, ТекОбъем);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	ОбъектыРасчетаОбъектРасчетаПриИзмененииПереопределяемый(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаПередУдалением(Элемент, Отказ)
	Отказ 			= Истина;
	ДопПараметры	= Новый Структура;
	ДопПараметры.Вставить("ТЧ", 			"ОбъектыРасчета");
	ДопПараметры.Вставить("НомерСтроки", 	Элемент.ТекущиеДанные.НомерСтроки-1);
	ДопПараметры.Вставить("IDСтроки", 		Элементы.ОбъектыРасчета.ТекущиеДанные.IDСтроки);
	ПроверкаУдаленияСтроки(ДопПараметры);
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Если Копирование Тогда
		Отказ = Истина;	
		НоваяСтрока = Объект.ОбъектыРасчета.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент.ТекущиеДанные);
		НоваяСтрока.idСтроки = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаАдресОбъектаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;

	МодульУправлениеКонтактнойИнформациейКлиент 		= ОбщегоНазначенияКлиент.ОбщийМодуль("УправлениеКонтактнойИнформациейКлиент");
	
	ПараметрыФормыКонтактнойИнформации 					= МодульУправлениеКонтактнойИнформациейКлиент.ПараметрыФормыКонтактнойИнформации(ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресОбъектаРасчета"),""); 
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяРеквизита", Элемент.Имя);
		
	ДанныеСтроки 										= Новый Структура("Представление,ЗначенияПолей",ТекДанные.АдресОбъекта,ТекДанные.АдресОбъектаЗначение);
	
	ПараметрыФормыКонтактнойИнформации.Значение 		= ДанныеСтроки.ЗначенияПолей;
	ПараметрыФормыКонтактнойИнформации.Представление 	= ДанныеСтроки.Представление;
	
	Оповещение 											= Новый ОписаниеОповещения("ОбъектыРасчетаАдресОбъектаНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура);
	Оповещение.ДополнительныеПараметры.Вставить("ДанныеЗаполнения",  ДанныеСтроки);
	Оповещение.ДополнительныеПараметры.Вставить("ЭтоТабличнаяЧасть", Истина);
	Оповещение.ДополнительныеПараметры.Вставить("КлючСтроки", 		 Элементы.ОбъектыРасчета.ТекущаяСтрока);
	Оповещение.ДополнительныеПараметры.Вставить("Элемент",           Элемент);
	Оповещение.ДополнительныеПараметры.Вставить("ДанныеСтроки",      ДанныеСтроки);		
	Оповещение.ДополнительныеПараметры.Вставить("Результат",         Результат);
	Оповещение.ДополнительныеПараметры.Вставить("Форма",             ЭтаФорма);
	
	
	МодульУправлениеКонтактнойИнформациейКлиент.ОткрытьФормуКонтактнойИнформации(ПараметрыФормыКонтактнойИнформации,,Оповещение);


КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаАдресОбъектаНачалоВыбораЗавершение(Знач РезультатЗакрытия, Знач ДополнительныеПараметры) Экспорт 
		
	Если ТипЗнч(РезультатЗакрытия) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные 									= Объект.ОбъектыРасчета.НайтиПоИдентификатору(ДополнительныеПараметры.КлючСтроки);	
	
	ТекущиеДанные.АдресОбъекта 						= РезультатЗакрытия.Представление;
	ТекущиеДанные.АдресОбъектаЗначение 				= РезультатЗакрытия.Значение; 
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаАдресОбъектаПриИзменении(Элемент)
	
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;

	ТекДанные.АдресОбъектаЗначение = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(ТекДанные.АдресОбъекта, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресОбъектаРасчета"));
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаМКДПриИзменении(Элемент)
	Элементы.ОбъектыРасчета.ТекущиеДанные.АдресОбъекта = ПолучитьАдресМКД(Элементы.ОбъектыРасчета.ТекущиеДанные.МКД,ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.АдресДома")); 
	Элементы.ОбъектыРасчета.ТекущиеДанные.Участвует		= Истина;
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка) 
	Если Элементы.ОбъектыРасчета.ТекущиеДанные.ОбъектУК Тогда
		Возврат;
	КонецЕсли;
	Если Поле.Имя = "ОбъектыРасчетаДополнительнаяИнформация" Тогда
		ТекущиеДанные		= Элементы.ОбъектыРасчета.ТекущиеДанные;
		КлючДанных 			= бестПользовательскийВводКлиент.ПолучитьКлючЗаполненияИнформацииОбъекта();
		ВходныеДанные		= Новый Структура(КлючДанных);
		ЗаполнитьЗначенияСвойств(ВходныеДанные,ТекущиеДанные);
		
		ОписаниеОповещения 	= Новый ОписаниеОповещения("ИнформацияОбъектаЗавершение", ЭтотОбъект, Новый Структура("ТекущиеДанные", ТекущиеДанные));
		ОткрытьФорму("ОбщаяФорма.бестИнформацияОбъекта", Новый Структура("ВходныеДанные,КлючДанных",ВходныеДанные,КлючДанных),,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыГарантированныеОбъемы

&НаКлиенте
Процедура ГарантированныеОбъемыПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекДанныеОбъемы = Элементы.ГарантированныеОбъемы.ТекущиеДанные;
	Если ТекДанныеОбъемы = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	
	ТекДанныеОбъемы.IDСтроки = ТекДанные.IDСтроки;
	
КонецПроцедуры

&НаКлиенте
Процедура ГарантированныеОбъемыЯнварьПриИзменении(Элемент)
	СуммаПоКварталу()
КонецПроцедуры

&НаКлиенте
Процедура ГарантированныеОбъемыПриАктивизацииСтроки(Элемент)
	УстановитьПараметрыВыбораУслуги();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыВеличинаБрони

&НаКлиенте
Процедура ВеличинаБрониПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекДанныеОбъемы = Элементы.ВеличинаБрони.ТекущиеДанные;
	Если ТекДанныеОбъемы = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	
	ТекДанныеОбъемы.IDСтроки = ТекДанные.IDСтроки;

КонецПроцедуры

&НаКлиенте
Процедура ВеличинаБрониУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;	
	
	ТекДанные = Элементы.ВеличинаБрони.ТекущиеДанные;
	
	СписокУслуг = ПолучитьСписокУслугДляВыбора(ТекДанные.IDСтроки);
	ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", Новый Структура("СписокУслуг", СписокУслуг), Элемент);	

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТочкиУчета

&НаКлиенте
Процедура ТочкиУчетаПриАктивизацииСтроки(Элемент)
	
	ТаблицаТочкиПоставок	= Элементы.ТочкиПоставки;	
	ТекущиеДанные 			= Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(ТаблицаТочкиПоставок,"IDСтроки",ТекущиеДанные.IDСтроки);
	
	УстановитьВидимостьТарифнойКатегории(ТекущиеДанные.ЦеноваяКатегория);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаВидКанальностиПриИзменении(Элемент)
	
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	ВидКанальности 							= ТекущиеДанные.ВидКанальности;
	СоставКанальности 						= энргРаботаСТочкамиУчетаСервер.СоставКанальности(ВидКанальности);
	// энргРаботаСВидомКанальности {
	энргРаботаСТочкамиУчетаКлиент.ПриИзмененииВидаКанальности(ЭтаФорма,ТекущиеДанные.IDСтроки,СоставКанальности,"ШкалыПриборовУчета","ПоказанияПриборовУчета"); 
	// энргРаботаСВидомКанальности }
	
	СоставУслуги = энргРаботаСПоставщикамиСервер.ПолучитьСоставУслугиСоШкалами(ТекущиеДанные.Услуга, ВидКанальности);
	бестРаботаСТочкамиУчетаНПКлиент.ПриИзмененииВидаКанальности(ЭтаФорма, ТекущиеДанные, СоставУслуги, "ШкалыУслуг");	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаУслугаПриИзменении(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	
	энргРаботаСТочкамиУчетаКлиент.СозданиеНаименованияТУ(ТекущиеДанные);
	
	ОписаниеУслуги = энргРаботаСПоставщикамиСервер.ОписаниеУслуги(ТекущиеДанные.Услуга);
	
	// энргРаботаСПоставщиками {
	бестРаботаСПоставщикамиКлиент.ПриИзмененииУслуги(ЭтаФорма,ТекущиеДанные,ОписаниеУслуги); 	
	// энргРаботаСПоставщиками } 
	
	УстановитьУсловноеОФормлениеФормыКлиент("Поставщик","ПараметрыПоставщиков");
	// энргРаботаСоСпособамиРасчетаНорматива {
	бестРаботаСоСпособомРасчетаНормативаКлиент.ПриИзмененииУслуги(ЭтаФорма,ТекущиеДанные,ОписаниеУслуги); 	
	// энргРаботаСоСпособамиРасчетаНорматива }
	
	СоответствиеЗначенияПоУмолчанию = Новый Соответствие;
	ДоговорОснование = энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "ОснованиеДопСоглашения");
	СоответствиеЗначенияПоУмолчанию.Вставить("Договор", 
		?(ЗначениеЗаполнено(ДоговорОснование), ДоговорОснование, Объект.Договор));
	
	бестРаботаСоСпособомРасчетаНормативаКлиент.ПриИзмененииУслуги(ЭтаФорма,ТекущиеДанные,ОписаниеУслуги,"ДоговорыСоставныхУслуг",СоответствиеЗначенияПоУмолчанию);
	УстановитьУсловноеОФормлениеФормыКлиент("Договор","ПараметрыДоговоров");
	
	Если ИспользоватьШкалыПриборовУчета Тогда
		СоставУслуги = энргРаботаСПоставщикамиСервер.ПолучитьСоставУслугиСоШкалами(ТекущиеДанные.Услуга, ТекущиеДанные.ВидКанальности);
		бестРаботаСТочкамиУчетаНПКлиент.ПриИзмененииВидаКанальности(ЭтаФорма, ТекущиеДанные, СоставУслуги, "ШкалыУслуг");	
	КонецЕсли;
	
	Объект.ГарантированныеОбъемы.Очистить();
	УстановитьПараметрыВыбораУслуги();
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПоставщикАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	энргРаботаСПоставщикамиКлиент.ПоставщикАвтоПодбор(ЭтаФорма,ТекущиеДанные);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЗаводскойНомерПриИзменении(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;	
	ЗаполнитьКоэфициент(ТекущиеДанные);

КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТипПрибораУчетаПриИзменении(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;	
	ЗаполнитьКоэфициент(ТекущиеДанные);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЕстьШкалыЕстьТарифныеЗоныПередУдалением(Элемент, Отказ)
	Отказ 			= Истина;
	ДопПараметры	= Новый Структура;
	ДопПараметры.Вставить("ТЧ", 			"ТочкиУчета");
	ДопПараметры.Вставить("НомерСтроки", 	Элемент.ТекущиеДанные.НомерСтроки-1);
	ДопПараметры.Вставить("IDСтроки", 		Элементы.ТочкиУчета.ТекущиеДанные.IDСтроки);
	ПроверкаУдаленияСтроки(ДопПараметры);	
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ТекущиеДанные.IDСтрокиВладельца = ТекДанные.IDСтроки;
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаСпособРасчетаНормативаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	энргРаботаСПоставщикамиКлиент.ПоставщикАвтоПодбор(ЭтаФорма,ТекущиеДанные,Новый Структура("ИмяСвойстваПоставщик","СпособРасчетаНорматива"),"СпособыРасчетаНормативаСоставныхУслуг","бестФормаВыбораСпособаРасчетаНорматива","ПараметрыСпособовРасчетаНорматива");
	//бестРаботаСоСпособомРасчетаНормативаКлиент.СпособРасчетаНормативаАвтоПодбор(ЭтаФорма,ТекСтрока);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаСпособРасчетаНормативаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	Если не ТекущиеДанные.ЭтоСоставнаяУслуга тогда
		Возврат
	КонецЕсли;	
	СтандартнаяОбработка 		= Ложь;
	энргРаботаСПоставщикамиКлиент.ПоставщикАвтоПодбор(ЭтаФорма,ТекущиеДанные,Новый Структура("ИмяСвойстваПоставщик","СпособРасчетаНорматива"),"СпособыРасчетаНормативаСоставныхУслуг","бестФормаВыбораСпособаРасчетаНорматива","ПараметрыСпособовРасчетаНорматива");

КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЕстьШкалыЕстьТарифныеЗоныНачалоДействияКоммерскогоУчета1ПриИзменении(Элемент)
	
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	
	ОписаниеУслуги = энргРаботаСПоставщикамиСервер.ОписаниеУслуги(ТекущиеДанные.Услуга);
	
	Если ОписаниеУслуги.ЭтоСоставнаяУслуга тогда
		энргРаботаСТочкамиУчетаКлиент.ПриИзмененииДатДействияКоммерческогоУчета(ТекущиеДанные, "НачалоДействияКоммерскогоУчета");
	КонецЕсли;
	
	ПроставитьДатыКомУчетаДляПУ(ТекущиеДанные.IDСтроки, ТекущиеДанные.НачалоДействияКоммерскогоУчета, Истина);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЕстьШкалыЕстьТарифныеЗоныКонецДействияКоммерскогоУчета1ПриИзменении(Элемент)
	
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
		
	ОписаниеУслуги = энргРаботаСПоставщикамиСервер.ОписаниеУслуги(ТекущиеДанные.Услуга);
	
	//	Если ОписаниеУслуги.ЭтоСоставнаяУслуга тогда
	энргРаботаСТочкамиУчетаКлиент.ПриИзмененииДатДействияКоммерческогоУчета(ТекущиеДанные, "КонецДействияКоммерскогоУчета");
	//КонецЕсли;
	ПроставитьДатыКомУчетаДляПУ(ТекущиеДанные.IDСтроки, ТекущиеДанные.КонецДействияКоммерскогоУчета, Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаРасположениеПриИзменении(Элемент)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	энргРаботаСТочкамиУчетаКлиент.СозданиеНаименованияТУ(ТекущиеДанные);

КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда
		ТекущиеДанные 							= Элементы["ТочкиУчета"].ТекущиеДанные;		
		ТекущиеДанные.IDСтроки					= Новый УникальныйИдентификатор;
		ТекущиеДанные.СредстваИзмерения 		= "Не заполнены";
		ТекущиеДанные.ТехническиеСвойстваТУ		= "Не заполнены"; 
		ТекущиеДанные.НастройкиТарифа		    = "Не заполнены";
		ЗаполнитьРеквизитыПоДоговору(ТекущиеДанные);
	КонецЕсли;
	
	Если Копирование Тогда
		ТекущиеДанные 							= Элементы["ТочкиУчета"].ТекущиеДанные;
		ТекущиеДанные.IDСтроки					= Новый УникальныйИдентификатор;
		ТекущиеДанные.ВидДифференцированности   = Неопределено;
		ТекущиеДанные.ВидКанальности            = Неопределено;
		ТекущиеДанные.ВидДифференцированности   = Неопределено;
		ТекущиеДанные.ДатаВыпуска               = Неопределено;
		ТекущиеДанные.ДатаПоверкиСчетчика       = Неопределено;
		ТекущиеДанные.ДатаУстановкиПломбы       = Неопределено;
		ТекущиеДанные.ЗаводскойНомер            = "";
		ТекущиеДанные.КонецДействияКоммерскогоУчета = Неопределено;
		ТекущиеДанные.КоэффициентПУ             = 1;
		ТекущиеДанные.НаименованиеТочки         = "";
		ТекущиеДанные.НачалоДействияКоммерскогоУчета = Неопределено;
		ТекущиеДанные.НетТехническойВозможностиУстановкиПУ = Ложь;
		ТекущиеДанные.НомерПломбы               = "";
		ТекущиеДанные.ОписаниеПрибора 			= "";
		ТекущиеДанные.ОписаниеТочки 			= "";
		ТекущиеДанные.ПриборУчета               = "";
		ТекущиеДанные.Расположение              = Неопределено;
		ТекущиеДанные.ТекущиеПоказания          = 0;
		ТекущиеДанные.ТочкаУчета                = Неопределено;
		ТекущиеДанные.УзелУчета                 = Неопределено;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЕстьШкалыЕстьТарифныеЗоныТипУзлаУчета1ПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ТочкиУчета.ТекущиеДанные;		
	Если ЗначениеЗаполнено(ТекущиеДанные.ТипУзлаУчета) Тогда
		Если не ЗначениеЗаполнено(ТекущиеДанные.ВладелецУзлаУчета) Тогда
			ТекущиеДанные.ВладелецУзлаУчета = Объект.Контрагент;
		КонецЕсли;
	Иначе		
		ТекущиеДанные.ВладелецУзлаУчета = ПредопределенноеЗначение("Справочник.энргКонтрагенты.ПустаяСсылка");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСубабонентов(Команда)
	ТекущиеДанные = Элементы["ТочкиУчета"].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	СтруктураОтвета = бестРаботаСТочкамиУчетаНПКлиент.ВернутьНачальныеПараметрыПередачиДляУзлов(ЭтаФорма, ТекущиеДанные, Объект, Истина);
	ПолучитьДанныеТЧСубабонентов(СтруктураОтвета.ПараметрыПередачи);
	бестРаботаСТочкамиУчетаНПКлиент.ДобавитьСубабонентов(СтруктураОтвета);
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЦеноваяКатегорияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ДоступныеЦеновыеКатегории = бестРаботаСТочкамиУчетаНПКлиент.ПолучитьСписокЦК(МаксимальнаяМощностьИтог);
	Элемент.СписокВыбора.ЗагрузитьЗначения(ДоступныеЦеновыеКатегории);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаСтруктураСетиПриИзменении(Элемент)
	ТекущиеДанные						= Элементы.ТочкиУчета.ТекущиеДанные;
	ТекущиеДанные.ДанныеРасположения 	= ПолучитьСхемуПрисоединения(ТекущиеДанные.СтруктураСети);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТочкаПоставкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ДоступныеТочкиПоставки 	 = ПолучитьСписокПодключенныхТП();
	Элемент.СписокВыбора.ЗагрузитьЗначения(ДоступныеТочкиПоставки);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТочкаПоставкиПриИзменении(Элемент)
	ТекущиеДанные		= Элементы.ТочкиУчета.ТекущиеДанные;
	
	СтруктураПоиска  			= Новый Структура("ТочкаПоставки", ТекущиеДанные.ТочкаПоставки);
	Коллекция  					= Объект["ТочкиПоставки"];
	Строки  					= Коллекция.НайтиСтроки(СтруктураПоиска);
	
	
	Для Каждого Стр из Строки Цикл
		Если ЗначениеЗаполнено(Стр.СтруктураСети) Тогда
			ТекущиеДанные.СтруктураСети 		= Стр.СтруктураСети;
			ТекущиеДанные.ДанныеРасположения 	= ПолучитьСхемуПрисоединения(Стр.СтруктураСети);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаДоговорНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ИмяТаблицыТочек 						= "ТочкиУчета" + ПрефиксТочекУчета;
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	Если не ТекущиеДанные.ЭтоСоставнаяУслуга тогда
		Возврат
	КонецЕсли;	
	СтандартнаяОбработка 		= Ложь;
	энргРаботаСПоставщикамиКлиент.ПоставщикАвтоПодбор(ЭтаФорма,ТекущиеДанные,Новый Структура("ИмяСвойстваПоставщик","Договор"),"ДоговорыСоставныхУслуг","бестФормаВыбораДоговоров","ПараметрыДоговоров");
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаДоговорАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	ИмяТаблицыТочек 						= "ТочкиУчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;

	энргРаботаСПоставщикамиКлиент.ПоставщикАвтоПодбор(ЭтаФорма,ТекущиеДанные,Новый Структура("ИмяСвойстваПоставщик","Договор"),"ДоговорыСоставныхУслуг","бестФормаВыбораДоговоров","ПараметрыДоговоров");
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаЦеноваяКатегорияПриИзменении(Элемент)
	ТекущиеДанные 			= Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	УстановитьВидимостьТарифнойКатегории(ТекущиеДанные.ЦеноваяКатегория);
	НайденныеСтроки = НайтиСвязанныеТУНаселения(ТекущиеДанные);
	Если НайденныеСтроки.Количество() <> 0 Тогда
		ТекущиеДанные.ТарифнаяКатегория = НайденныеСтроки[0].ТарифнаяКатегория;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТарифнаяКатегорияПриИзменении(Элемент)
	ТекущиеДанные 			= Элементы.ТочкиУчета.ТекущиеДанные;
	НайденныеСтроки = НайтиСвязанныеТУНаселения(ТекущиеДанные);
	Для каждого Строка Из НайденныеСтроки Цикл
		Строка.ТарифнаяКатегория = ТекущиеДанные.ТарифнаяКатегория;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "ТочкиУчетаСредстваИзмерения" Тогда
		СтруктураЗаполнения = энргРаботаСТочкамиУчетаКлиент.ПолучитьВходныеДанныеДляЗаполненияСредствИзмерений(ЭтотОбъект, "ЮЛ");
		энргРаботаСТочкамиУчетаКлиент.ОткрытьФормуЗаполненияСредствИзмерений(СтруктураЗаполнения);
	ИначеЕсли Поле.Имя = "ТочкиУчетаТехническиеСвойстваТУ" Тогда
		ОткрытьФормуТехническихСвойствТУ();
	ИначеЕсли Поле.Имя = "ТочкиУчетаНастройкиТарифа" Тогда
        ОткрытьФормуНастройкиТарифа();
	КонецЕсли;
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыГрафикиРежимаОграничения

&НаКлиенте
Процедура ГрафикиРежимаОграниченияПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТекДанныеОбъемы = Элементы.ТЗГрафикиРежимаОграничения.ТекущиеДанные;
	Если ТекДанныеОбъемы = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	
	ТекДанныеОбъемы.IDСтроки = ТекДанные.IDСтроки;
	
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ТЗГрафикиРежимаОграниченияУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;	
	
	ТекДанные = Элементы.ТЗГрафикиРежимаОграничения.ТекущиеДанные;
	
	СписокУслуг = ПолучитьСписокУслугДляВыбора(ТекДанные.IDСтроки);
	ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", Новый Структура("СписокУслуг", СписокУслуг), Элемент);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТочкиПоставок

&НаКлиенте
Процедура ТочкиПоставокТочкаПоставкиПриИзменении(Элемент)
	ТекДанные						= Элементы.ТочкиПоставокОбъектовРасчета.ТекущиеДанные;
	ЗаполнитьПараметрыТочекПоставки(ТекДанные.ТочкаПоставки);
	
	ТекДанныеОбъектРасчета = Элементы.ОбъектыРасчета.ТекущиеДанные;
	ЗаполнитьИтогиТочекПоставки(ТекДанныеОбъектРасчета.IDСтроки);

КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставокПриИзменении(Элемент)
	ТекДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ИмяТаблицыТочек 						= "ТочкиПоставокОбъектовРасчета";
	ТекущиеДанные 							= Элементы[ИмяТаблицыТочек].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ТекущиеДанные.IDСтроки = ТекДанные.IDСтроки;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставкиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	ТекущиеДанные 							= Элементы.ТочкиУчета.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(,"Выберите точку учета");
		Возврат;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставкиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда		
		ТекущиеДанные 							= Элементы.ТочкиУчета.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		Элемент.ТекущиеДанные.IDСтроки			= ТекущиеДанные.IDСтроки;
		энргРаботаСТочкамиУчетаКлиент.ВидКанальностиПриАктивацииСтроки(Элементы.ТочкиПоставки,"IDСтроки",ТекущиеДанные.IDСтроки);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставкиТочкаПоставкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ДоступныеТочкиПоставки 	 = ПолучитьСписокПодключенныхТП();
	Элемент.СписокВыбора.ЗагрузитьЗначения(ДоступныеТочкиПоставки);
КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставкиТочкаПоставкиПриИзменении(Элемент)
	ТекущиеДанные		= Элементы.ТочкиУчета.ТекущиеДанные;
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.СтруктураСети) Тогда
		СтруктураПоиска  			= Новый Структура("ТочкаПоставки", Элементы.ТочкиПоставки.ТекущиеДанные.ТочкаПоставки);
		Коллекция  					= Объект["ТочкиПоставки"];
		Строки  					= Коллекция.НайтиСтроки(СтруктураПоиска);
		
		
		Для Каждого Стр из Строки Цикл
			Если ЗначениеЗаполнено(Стр.СтруктураСети) Тогда
				ТекущиеДанные.СтруктураСети 		= Стр.СтруктураСети;
				ТекущиеДанные.ДанныеРасположения 	= ПолучитьСхемуПрисоединения(Стр.СтруктураСети);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкиПоставокОбъектовРасчетаПослеУдаления(Элемент)
	ТекДанныеОбъектРасчета = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если Не ТекДанныеОбъектРасчета = Неопределено Тогда
		ЗаполнитьИтогиТочекПоставки(ТекДанныеОбъектРасчета.IDСтроки);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыНастройкиОплаты

&НаКлиенте
Процедура НастройкиОплатыБазаРасчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекДанные = Элементы.НастройкиОплаты.ТекущиеДанные;
	
	Если ТекДанные.ТипОплаты <> ПредопределенноеЗначение("Перечисление.бестВидыРасчета.Авансовый") Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Базы расчета задаются только для авансового типа оплаты.");
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПостоянныйРасходТУ

&НаКлиенте
Процедура ПостоянныйРасходТУТочкаУчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элементы.ОбъектыРасчета.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено Тогда
		
		ДанныеВыбора = Новый СписокЗначений;
		
		ЗаполнитьСписокТочек(ДанныеВыбора, ТекущиеДанные.IDСтроки);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПостоянныйРасходТУТочкаУчетаПриИзменении(Элемент)
	ТекущиеДанныеПостоянногоРасхода = Элементы.ПостоянныйРасходТУ.ТекущиеДанные;
	
	СтруктураПоиска  				= Новый Структура("IDСтрокиВладельца, НаименованиеТочки",
		ТекущиеДанныеПостоянногоРасхода.IDСтрокиОбъектРасчета, ТекущиеДанныеПостоянногоРасхода.ТочкаУчета);
	Строки  					= Объект.ТочкиУчета.НайтиСтроки(СтруктураПоиска);
	Если Строки.Количество() > 0 Тогда
		ТекущиеДанныеПостоянногоРасхода.IDСтрокиТочкиУчета = Строки[0].IDСтроки;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПостоянныйРасходТУПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	ТекущиеДанныеОбъектРасчета = Элементы.ОбъектыРасчета.ТекущиеДанные;
	Если ТекущиеДанныеОбъектРасчета = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если НоваяСтрока Или Копирование Тогда
		ТекущиеДанные = Элементы.ПостоянныйРасходТУ.ТекущиеДанные;
		ТекущиеДанные.IDСтрокиОбъектРасчета = ТекущиеДанныеОбъектРасчета.IDСтроки;
    	ТекущиеДанные.IDСтроки = Новый УникальныйИдентификатор;
		ЗаполнитьТЧОбъемов(ТекущиеДанные.IDСтроки);	
		энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПостоянныйРасходОбъемы, Неопределено, ТекущиеДанные.IDСтроки);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПостоянныйРасходТУПриАктивизацииСтроки(Элемент)    
	ТекущиеДанные = Элементы.ПостоянныйРасходТУ.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	энргРаботаСТочкамиУчетаКлиент.ВидДифференцированностиПриАктивацииСтроки(Элементы.ПостоянныйРасходОбъемы, Неопределено, ТекущиеДанные.IDСтроки);
КонецПроцедуры

&НаКлиенте
Процедура ПостоянныйРасходТУУслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)	
	
	ТекущиеДанные = Элементы.ПостоянныйРасходТУ.ТекущиеДанные;
	
	СписокУслуг = ПолучитьСписокУслугДляВыбораПостоянныйРасход(ТекущиеДанные.IDСтрокиТочкиУчета);
	
	МассивПараметровВыбора = Новый Массив;
	ПараметрВыбора = Новый ПараметрВыбора("Отбор.Ссылка", СписокУслуг);
	МассивПараметровВыбора.Добавить(ПараметрВыбора);
	Элементы.ПостоянныйРасходТУУслуга.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметровВыбора);
КонецПроцедуры

&НаКлиенте
Процедура ПостоянныйРасходТУПередУдалением(Элемент, Отказ) 
	ТекущиеДанные = Элементы.ПостоянныйРасходТУ.ТекущиеДанные;
	ТаблицыФормы	= Новый Массив;
	
	ТаблицыФормы.Добавить("ПостоянныйРасходОбъемы");
	
	энргПользовательскийВводКлиент.УдалитьЗависимыеСтроки(ТекущиеДанные.IDСтроки, Объект, ТаблицыФормы);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПостоянныйРасходОбъемы

&НаКлиенте
Процедура ПостоянныйРасходОбъемыПередУдалением(Элемент, Отказ)
	  Отказ = Истина;
