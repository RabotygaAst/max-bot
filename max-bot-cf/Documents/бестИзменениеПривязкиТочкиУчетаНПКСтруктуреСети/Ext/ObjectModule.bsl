#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	Ответственный = Пользователи.ТекущийПользователь();
	
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	
	//ПроверитьНаличиеСуществующихЗаписей(Отказ);
	
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	ДанныеТочекУчета = ПолучитьДанныеТочекУчета();
	
	бестПроведениеСерверНП.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеТочекУчета,				Движения.бестСтруктураСетиТочекУчетаНП);	
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
			
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	Если Не ЗначениеЗаполнено(ОбъектыРасчета) тогда 
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("ТЧ не может быть пустой");	
	Иначе 
		Для Каждого СтрокаТЧ из ОбъектыРасчета цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ОбъектРасчета)  Тогда
				Отказ 		= Истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле ""Объект расчета""",ЭтотОбъект,"ОбъектыРасчета["+(СтрокаТЧ.НомерСтроки-1)+"].ОбъектРасчета");				
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ТочкаУчета)  Тогда
				Отказ 		= Истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле ""Точка учета""",ЭтотОбъект,"ОбъектыРасчета["+(СтрокаТЧ.НомерСтроки-1)+"].ТочкаУчета");				
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.СтруктураСети)  Тогда
				Отказ 		= Истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке " + СтрокаТЧ.НомерСтроки + " не заполнено поле ""Структура сети""",ЭтотОбъект,"ОбъектыРасчета["+(СтрокаТЧ.НомерСтроки-1)+"].СтруктураСети");				
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьДанныеТочекУчета()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Регистратор", 		Ссылка);
	Запрос.УстановитьПараметр("Организация", 		Организация);
	Запрос.УстановитьПараметр("Район", 				Район);
	Запрос.УстановитьПараметр("Регистратор", 		Ссылка);
	Запрос.УстановитьПараметр("Период", 			?(ЗначениеЗаполнено(ДатаФактическогоСобытия), ДатаФактическогоСобытия, Дата));
	Запрос.УстановитьПараметр("ПериодНачисления", 	ПериодНачисления);
	Запрос.УстановитьПараметр("ПериодРегистрации", 	Дата);
	Запрос.Текст = "ВЫБРАТЬ
	               |	бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСетиОбъектыРасчета.ОбъектРасчета КАК ОбъектРасчета,
	               |	бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСетиОбъектыРасчета.ТочкаУчета КАК ТочкаУчета,
	               |	бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСети.СтруктураСети КАК СтруктураСети,
	               |	&Регистратор КАК Регистратор,
	               |	&Организация КАК Организация,
	               |	&Район КАК Район,
	               |	&Период КАК Период,
	               |	&ПериодНачисления КАК ПериодНачисления,
	               |	&ПериодРегистрации КАК ПериодРегистрации,
	               |	бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСетиОбъектыРасчета.ОбъектРасчета.МКД КАК МКД
	               |ИЗ
	               |	Документ.бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСети.ОбъектыРасчета КАК бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСетиОбъектыРасчета
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСети КАК бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСети
	               |		ПО бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСетиОбъектыРасчета.Ссылка = бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСети.Ссылка
	               |ГДЕ
	               |	бестИзменениеПривязкиТочкиУчетаНПКСтруктуреСетиОбъектыРасчета.Ссылка = &Регистратор";
	
	Результат = Запрос.Выполнить();
	
	Возврат Результат; 
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли