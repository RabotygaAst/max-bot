#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	ДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ЭтотОбъект,Отказ,РежимЗаписи,РежимПроведения);
	
	Ответственный 				= Пользователи.ТекущийПользователь();
	энргДатаПоследнегоИзменения	= ТекущаяДата();

	бестПроведениеСерверНП.ПередЗаписьюОбъекта(ЭтотОбъект);
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	бестПроведениеСерверНП.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	РезультатЗапроса = ПолучитьДанныеДляПроведения();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВидОперации 							= Перечисления.бестВидыОпераций.ИзменитьДанныеДляДополнительногоРасчета_ПревышениеПДК Тогда 
			Движение 								= Движения.бестПревышениеПДК.Добавить();
			Движение.КоличествоЗагрязняющихВеществ 	= ВыборкаДетальныеЗаписи.Коэффициент;
		ИначеЕсли ВидОперации 						= Перечисления.бестВидыОпераций.ИзменитьДанныеДляДополнительногоРасчета_ПрочиеДополнительныеНачисления Тогда
			Движение 								= Движения.бестПрочиеДополнительныеНачисления.Добавить();
			Движение.Процент 						= ВыборкаДетальныеЗаписи.Коэффициент;
		КонецЕсли;		
		ЗаполнитьЗначенияСвойств(Движение,Ссылка);
		ЗаполнитьЗначенияСвойств(Движение,ВыборкаДетальныеЗаписи);
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьДанныеДляПроведения()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестИзменитьДанныеДляДополнительногоРасчета.Организация КАК Организация,
		|	бестИзменитьДанныеДляДополнительногоРасчета.Район КАК Район,
		|	бестИзменитьДанныеДляДополнительногоРасчета.Дата КАК Период,
		|	бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета.ОбъектРасчета КАК ОбъектРасчета,
		|	бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета.ТочкаУчета КАК ТочкаУчета,
		|	бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета.Услуга КАК Услуга,
		|	НАЧАЛОПЕРИОДА(бестИзменитьДанныеДляДополнительногоРасчетаПериодыЗначений.Период, МЕСЯЦ) КАК ПериодНачисления,
		|	бестИзменитьДанныеДляДополнительногоРасчетаПериодыЗначений.Коэффициент КАК Коэффициент,
		|	бестОбъектыРасчета.МКД КАК МКД,
		|	бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета.ТарифнаяКатегория КАК ТарифнаяКатегория,
		|	бестИзменитьДанныеДляДополнительногоРасчетаПериодыЗначений.Сезонность КАК Сезонность,
		|	бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета.ТипДополнительногоНачисления КАК ТипДополнительногоНачисления
		|ИЗ
		|	Документ.бестИзменитьДанныеДляДополнительногоРасчета.ДанныеДляРасчета КАК бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестИзменитьДанныеДляДополнительногоРасчета КАК бестИзменитьДанныеДляДополнительногоРасчета
		|		ПО бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета.Ссылка = бестИзменитьДанныеДляДополнительногоРасчета.Ссылка
		|			И бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета.Ссылка = бестИзменитьДанныеДляДополнительногоРасчета.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бестИзменитьДанныеДляДополнительногоРасчета.ПериодыЗначений КАК бестИзменитьДанныеДляДополнительногоРасчетаПериодыЗначений
		|		ПО бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета.IDСтроки = бестИзменитьДанныеДляДополнительногоРасчетаПериодыЗначений.IDСтроки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бестОбъектыРасчета КАК бестОбъектыРасчета
		|		ПО бестИзменитьДанныеДляДополнительногоРасчетаДанныеДляРасчета.ОбъектРасчета = бестОбъектыРасчета.Ссылка
		|ГДЕ
		|	бестИзменитьДанныеДляДополнительногоРасчета.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить();
	
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли