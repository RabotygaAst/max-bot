#Область СобытияФормы

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	МодульПодключаемыеКомандыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиент");
	МодульПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат)
	МодульПодключаемыеКоманды = ОбщегоНазначения.ОбщийМодуль("ПодключаемыеКоманды");
	МодульПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	МодульПодключаемыеКомандыКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("ПодключаемыеКомандыКлиентСервер");
	МодульПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры

#КонецОбласти

#Область ПроцедурыИФункции

&НаСервере
Процедура РайонПриИзмененииНаСервере()
	Объект.Организация = Объект.Район.Организация;
	Если ЗначениеЗаполнено(Объект.Организация) Тогда 		
		Объект.ПериодНачисления = Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	РайонПриИзмененииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	ЗаполнитьПериодНачисления();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПериодНачисления() 
	
	Объект.ПериодНачисления = Обработки.бестГраницыПериодаНачисленияМенеджер.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация,Объект.Район);
		
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Организация) Тогда 		
		Объект.ПериодНачисления = энргРаботаСПериодомДействия.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация);		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЧНаСервере(ТекСтрока)
	Результат = бестРаботаСприборамиУчетаСервер.ДанныеДляМассовогоВвода(Объект.Дата,Объект.ПериодНачисления,Объект.Организация,Объект.Район, Договор, МКД, ОбъектРасчета, ТочкаУчета, Услуга, Контролер);
	Выборка	= Результат.Выбрать();
	
	ТЧ					= Объект.ТочкиУчета;
	
	Дубль					= Неопределено;
	Пока Выборка.Следующий() Цикл		
		Если Дубль	= Неопределено Тогда
			Для каждого стр из ТЧ Цикл			
				Если Выборка.ПриборУчета = стр.ПриборУчета Тогда
					Дубль = Истина;
					НайденнаяСтрока	= стр.ПолучитьИдентификатор();
					Прервать;
				КонецЕсли;									
			КонецЦикла;
		Иначе
			Прервать;
		КонецЕсли;			
	КонецЦикла;
	Если Дубль = Неопределено Тогда
		Выборка.Сбросить();
		Пока Выборка.Следующий() Цикл
			НовСтрока = ТЧ.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрока, Выборка);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТЧ(Команда)
	ТекСтрока		= Неопределено;
	ЗаполнитьТЧНаСервере(ТекСтрока);
	Если не ТекСтрока = Неопределено Тогда
		Отказ 			= Истина;
		ДопПараметры	= Новый Структура;
		ДопПараметры.Вставить("ТекущийОбъект", 	Объект.Ссылка);
		ДопПараметры.Вставить("ТЧ", 			"ТочкиУчета");
		ДопПараметры.Вставить("ТекСтрока", 		ТекСтрока);
		ПоказанияУжеВведеныВопрос(ДопПараметры);			
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТочкиУчетаТекущиеПоказанияПриИзменении(Элемент)
	
	текСтрока = Элементы.ТочкиУчета.ТекущиеДанные;
	
	бестРаботаСПоказаниямиПриборовУчетаНПКлиентСервер.ПересчитатьСтрокуПриборовУчета(текСтрока,Объект.Дата,Ложь);	
	
	Если текСтрока.СостояниеПоказаний 	= ПредопределенноеЗначение("Перечисление.энргСостояниеПоказаний.Отклонены") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Показания отклонены"); 		
	КонецЕсли;	
	
	ПровестиАнализаПолученногоРасхода(ТекСтрока);

КонецПроцедуры

&НаКлиенте
Процедура УслугаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;	
	
	СписокУслуг = бестПользовательскийВводСервер.ПолучитьСписокУслугДляВыбора(?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия),КонецДня(Объект.ДатаФактическогоСобытия),Объект.Дата), Объект.Организация, Объект.Район, ОбъектРасчета, ТочкаУчета);
	ОткрытьФорму("Справочник.энргВидыУслуг.ФормаВыбора", Новый Структура("СписокУслуг", СписокУслуг), Элемент);

КонецПроцедуры

&НаКлиенте
Процедура ТочкаУчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	//энргПользовательскийВводКлиент.НачалоВыбораТочкиУчета(Элемент, Новый Структура("ТочкиСПриборами", Истина));
		СтандартнаяОбработка = Ложь;
	
	ВыборУслугиИТочкиУчета(Новый Структура, Элемент);

КонецПроцедуры

&НаКлиенте
Процедура ВыборУслугиИТочкиУчета(ТекДанные, Элемент)
	СтруктураОтбора = Новый Структура("Период,Организация,Район,ОбъектРасчета, ПростыеУслуги",КонецДня(Объект.ДатаФактическогоСобытия));
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,Объект);
	ЗаполнитьЗначенияСвойств(СтруктураОтбора,ТекДанные);
	СтруктураОтбора.Период = ?(ЗначениеЗаполнено(Объект.ДатаФактическогоСобытия), КонецДня(Объект.ДатаФактическогоСобытия), КонецДня(Объект.Дата));
	
	Если ТипЗнч(ТекДанные) = Тип("Структура") Тогда
		СтруктураОтбора.ОбъектРасчета = Объект.ОбъектРасчета;
	Иначе
		СтруктураОтбора.ОбъектРасчета = ТекДанные.ОбъектРасчета;
	КонецЕсли;
	
	СтруктураОтбора.ПростыеУслуги = Истина;	
	
	ПараметрыВыбораФормы	= Новый Структура("СтруктураОтбора,ТипВладельца", СтруктураОтбора, "НП");
	ОписаниеОповещения 		= Новый ОписаниеОповещения("ТочкаУчетаОкончаниеВыбора",ЭтаФорма,Новый Структура("ТекДанные", ТекДанные));
	
	ОткрытьФорму("ОбщаяФорма.бестФормаВыбораТочкиУчета",ПараметрыВыбораФормы, ЭтаФорма,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

&НаКлиенте
Процедура ТочкаУчетаОкончаниеВыбора(РезультатЗакрытия,ДополнительныеПараметры) Экспорт  
	
	Если РезультатЗакрытия <> Неопределено Тогда 
		Модифицированность	= Истина;
		ТекДанные			= ДополнительныеПараметры.ТекДанные;
		
		Если ТипЗнч(ТекДанные) = Тип("Структура") Тогда
			ТочкаУчета = РезультатЗакрытия.ТочкаУчета;
		Иначе
			ТекДанные.ТочкаУчета = РезультатЗакрытия.ТочкаУчета;
			ТекДанные.Услуга = РезультатЗакрытия.Услуга;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ТочкиУчетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Элемент.ТекущиеДанные <> Неопределено Тогда
		
		Если  Поле.Имя = "ТочкиУчетаОбъектРасчета" Тогда
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,Элемент.ТекущиеДанные.ОбъектРасчета); 
		ИначеЕсли  Поле.Имя = "ТочкиУчетаТочкаУчета" Тогда
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,Элемент.ТекущиеДанные.ТочкаУчета); 
		ИначеЕсли  Поле.Имя = "ТочкиУчетаУслуга" Тогда
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,Элемент.ТекущиеДанные.Услуга);
		ИначеЕсли  Поле.Имя = "ТочкиУчетаПриборУчета" Тогда
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,Элемент.ТекущиеДанные.ПриборУчета); 
		ИначеЕсли  Поле.Имя = "ТочкиУчетаШкала" Тогда
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,Элемент.ТекущиеДанные.Шкала); 
		ИначеЕсли  Поле.Имя = "ТочкиУчетаВидДифференцированности" Тогда
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,Элемент.ТекущиеДанные.ВидДифференцированности); 
		ИначеЕсли  Поле.Имя = "ТочкиУчетаТарифнаяЗона" Тогда
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,Элемент.ТекущиеДанные.ТарифнаяЗона); 
		Иначе
			СтандартнаяОбработка = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПровестиАнализаПолученногоРасхода(ТекСтрока)
	
	Если ТекСтрока.РасходЗаПредМесяц <> 0 Тогда
		ТекСтрока.ПроцентОтклоненияОтПредМесяца = (ТекСтрока.Разница - ТекСтрока.РасходЗаПредМесяц)/ТекСтрока.РасходЗаПредМесяц * 100;
	Иначе
		ТекСтрока.ПроцентОтклоненияОтПредМесяца = 0;
	КонецЕсли;
	
	Если ТекСтрока.РасходЗаАналогичныйПериодПредГода <> 0 Тогда
		ТекСтрока.ПроцентОтклоненияОтАналогичногоПериодаПредГода = (ТекСтрока.Разница - ТекСтрока.РасходЗаАналогичныйПериодПредГода)/ТекСтрока.РасходЗаАналогичныйПериодПредГода * 100;
	Иначе
		ТекСтрока.ПроцентОтклоненияОтАналогичногоПериодаПредГода = 0;
	КонецЕсли;
	
	Если ТекСтрока.СреднийРасход <> 0 Тогда
		ТекСтрока.ПроцентОтклоненияОтСреднегоРасхода = (ТекСтрока.Разница - ТекСтрока.СреднийРасход)/ТекСтрока.СреднийРасход * 100;
	Иначе
		ТекСтрока.ПроцентОтклоненияОтСреднегоРасхода = 0;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузкаВExcelБезПоказаний(Команда)
	ВыгрузитьВEXCELРегистрацияПоказаний(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузкаВExcelСПоказаниями(Команда)
	ВыгрузитьВEXCELРегистрацияПоказаний(Истина);
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьВEXCELРегистрацияПоказаний(ПоказыватьТекПоказания)
	ТабДок 					= Новый ТабличныйДокумент;
	МассивДок 				= Новый Массив;
	МассивДок.Добавить(Объект.Ссылка);
	ВыгрузкаВEXCELНаСервере(МассивДок, ТабДок, ПоказыватьТекПоказания);
	КаталогВыгрузки 		= ПолучитьКаталогВыгрузки();
	ПолноеИмяФайла			= КаталогВыгрузки + "Контрольный_съём_" + ?(ПоказыватьТекПоказания, "с_показаниями_№", "без_показаний_№")  + Строка(Объект.Номер) + "_от_" + Формат(Объект.Дата, "ДФ=dd.MM.yyyy") + ".xlsx";
	
	ТабДок.Вывод			= ИспользованиеВывода.Разрешить;
	ТабДок.Записать(ПолноеИмяФайла, ТипФайлаТабличногоДокумента.XLSX);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Файл " + ПолноеИмяФайла + " записан");
КонецПроцедуры

&НаКлиенте
Функция ПолучитьКаталогВыгрузки()
	ТекКаталогВыгрузки	= ""; 
	#Если ВебКлиент Тогда

		ДиалогВыбораФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	    
	    ДиалогВыбораФайла.Каталог = ТекКаталогВыгрузки;
	    ДиалогВыбораФайла.Заголовок = "Выберите каталог";
	    
	    ПараметрыСценария = Новый Структура;
	    Оповещение = Новый ОписаниеОповещения("КаталогНачалоВыбораЗавершение", ЭтаФорма);
	    ПараметрыСценария.Вставить("Оповещение_ПослеЗакрытияДиалогаВыбораФайла", Оповещение);
	    ПараметрыСценария.Вставить("ДиалогВыбораФайла", ДиалогВыбораФайла);
	                                
	    ВыполнитьСценарийВыбораФайла(, ПараметрыСценария);
	#Иначе
		Режим = РежимДиалогаВыбораФайла.ВыборКаталога; 
		ДиалогОткрытия = Новый ДиалогВыбораФайла(Режим);
		СтандартнаяОбработка = Ложь;
		ДиалогОткрытия.Каталог = ""; 
		ДиалогОткрытия.МножественныйВыбор = Ложь; 
		ДиалогОткрытия.Заголовок = "Выберите каталог"; 
		
		Если ДиалогОткрытия.Выбрать() Тогда 
			ТекКаталогВыгрузки = ДиалогОткрытия.Каталог + "\"; 
		КонецЕсли;
	#КонецЕсли	
	
	Возврат ТекКаталогВыгрузки;	
КонецФункции

&НаСервере
Процедура ВыгрузкаВEXCELНаСервере(МассивДок, ТабДок, ПоказыватьТекПоказания)
	Документы.бестРегистрацияПоказанийНПОбщий.СформироватьПечатнуюФорму(МассивДок, ТабДок, ПоказыватьТекПоказания);	
КонецПроцедуры

&НаКлиенте
Процедура КаталогНачалоВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
    Если Результат = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    КаталогВыгрузки = Результат[0]+"\";   
КонецПроцедуры

&НаКлиенте
Процедура НачатьОтсчетШагов(ПараметрыСценария)
	
	Если ПараметрыСценария = Неопределено Тогда
		ПараметрыСценария = Новый Структура;
	КонецЕсли;
	
	Если НЕ ПараметрыСценария.Свойство("ПредыдущийШаг") Тогда
		// при первом запуске основной процедуры это свойство отстуствует
		ПараметрыСценария.Вставить("ПредыдущийШаг", 0);
	КонецЕсли;
	
	ПараметрыСценария.Вставить("ТекущийШаг", 0);
	
КонецПроцедуры

&НаКлиенте
Функция ЭтотШагЕщеНеВыполнялся(ПараметрыСценария)
	
	ПараметрыСценария.ТекущийШаг = ПараметрыСценария.ТекущийШаг + 1;

	Если ПараметрыСценария.ПредыдущийШаг >= ПараметрыСценария.ТекущийШаг Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПараметрыСценария.ПредыдущийШаг = ПараметрыСценария.ТекущийШаг;
	
	Возврат Истина;
	
КонецФункции

&НаКлиенте
Функция ЭтоРезультатВыполненногоШага(ПараметрыСценария)

	Возврат ПараметрыСценария.ПредыдущийШаг = ПараметрыСценария.ТекущийШаг;
	
КонецФункции

&НаКлиенте
Процедура ВыполнитьСценарийВыбораФайла(Результат = Неопределено, ПараметрыСценария = Неопределено) Экспорт
    
    НачатьОтсчетШагов(ПараметрыСценария);
    
    Оповещение = Новый ОписаниеОповещения("ВыполнитьСценарийВыбораФайла", ЭтаФорма, ПараметрыСценария);
    
    // подключить расширение работы с файлами
    Если ЭтотШагЕщеНеВыполнялся(ПараметрыСценария) Тогда
            НачатьПодключениеРасширенияРаботыСФайлами(Оповещение);
            Возврат;
        
    ИначеЕсли ЭтоРезультатВыполненногоШага(ПараметрыСценария) Тогда
        
        // если расширение подключилось, перейти к следующему шагу
        Если Результат = Истина Тогда
            
        // если расширение не подключилось, задать вопрос об его установке
        ИначеЕсли Результат = Ложь Тогда
            ТекстСообщения = "Расширение для работы с файлами не установлено. Установить?";
            ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет);
            Возврат;
            
        // пользователь отказался от установки расширения по работе с файлами
        ИначеЕсли Результат <> КодВозвратаДиалога.Да Тогда
            Возврат;
            
        // пользователь подтвердил установку расширения по работе с файлами
        ИначеЕсли Результат = КодВозвратаДиалога.Да Тогда
            НачатьУстановкуРасширенияРаботыСФайлами();
            Возврат;
            
        КонецЕсли;
            
    КонецЕсли;
    
    // открыть диалог выбора файла
    Если ЭтотШагЕщеНеВыполнялся(ПараметрыСценария) Тогда
        
        // переадресовываем результат на прикладную процедуру
        ПараметрыСценария.ДиалогВыбораФайла.Показать(ПараметрыСценария.Оповещение_ПослеЗакрытияДиалогаВыбораФайла);
        Возврат;
        
    КонецЕсли;
    
КонецПроцедуры

&НаКлиенте
Процедура ПоказанияУжеВведеныВопрос(ДопПараметры)
	ОписаниеОповещения  = Новый ОписаниеОповещения("ВопросПереходаКСтроке",ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОписаниеОповещения,"Показания уже введены. Перейти к строке?",РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПереходаКСтроке(РезультатВопроса,ДополнительныеПараметры) Экспорт 
	Если ТипЗнч(РезультатВопроса) = Тип("КодВозвратаДиалога") тогда		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			ПерейтиКСтроке(ДополнительныеПараметры);			
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ПерейтиКСтроке(ДополнительныеПараметры)
	Элементы[ДополнительныеПараметры.ТЧ].ТекущаяСтрока = ДополнительныеПараметры.ТекСтрока;
	Элементы[ДополнительныеПараметры.ТЧ].ТекущийЭлемент = Элементы[ДополнительныеПараметры.ТЧ + "ТекущиеПоказания"];	
КонецПроцедуры

&НаКлиенте
Процедура Печать(Команда)
	ТабДок 						= Новый ТабличныйДокумент;
	МассивДокументов 			= Новый Массив;
	МассивДокументов.Добавить(Объект.Ссылка);
	ПечатьНаСервере(МассивДокументов, ТабДок);
	ТабДок.АвтоМасштаб 			= Истина;
	ТабДок.Защита 				= Истина;
	ТабДок.ОтображатьСетку 		= Ложь;
	ТабДок.Показать("Регистрация показаний юр.лиц");	
КонецПроцедуры

&НаСервере
Процедура ПечатьНаСервере(МассивДокументов, ТабДок)
	Документы.бестРегистрацияПоказанийНПОбщий.СформироватьПечатнуюФорму53(МассивДокументов, ТабДок);
КонецПроцедуры

