// Функция - Получает данные структуры сети по точке
//
// Параметры:
//  ДолеваяТочкаУчета	 - СправочникСсылка.энргТочкиУчета
//  Услуга				 - СправочникСсылка.энргВидыУслуг 
//  ОбъектРасчета		 - СправочникСсылка.бестОбъектыРасчета 
//  Район				 - СправочникСсылка.энргЗоныОтвественности
//  Организация			 - СправочникСсылка.Организации
//  Период				 - Дата
// 
// Возвращаемое значение:
//   - РезультатЗапроса
//
Функция ПолучитьДанныеСтруктурыСетиПоТочке(ДолеваяТочкаУчета, Услуга, ОбъектРасчета, Район, Организация, Период) Экспорт
	ГоловнаяСтруктураСети = ПолучитьГоловнуюСтруктуруСети(ДолеваяТочкаУчета,Услуга,ОбъектРасчета,Район,Организация,Период);
	Если ГоловнаяСтруктураСети <> Неопределено Тогда
		МассивПодчиненныхЭл = Новый Массив;
		МассивПодчиненныхЭл.Добавить(ГоловнаяСтруктураСети);
		ОбойтиПодчиненныеЭлементыСтруктурыСети(МассивПодчиненныхЭл, ГоловнаяСтруктураСети, Период);
		ОбщегоНазначенияКлиентСервер.СвернутьМассив(МассивПодчиненныхЭл);
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	бестСтруктураСетиТочекУчетаНПСрезПоследних.ТочкаУчета КАК ТочкаУчета,
		|	бестСтруктураСетиТочекУчетаНПСрезПоследних.Услуга КАК Услуга,
		|	бестСтруктураСетиТочекУчетаНПСрезПоследних.ОбъектРасчета КАК ОбъектРасчета
		|ИЗ
		|	РегистрСведений.бестСтруктураСетиТочекУчетаНП.СрезПоследних(&Период, СтруктураСети В (&мСтруктураСети)) КАК бестСтруктураСетиТочекУчетаНПСрезПоследних";
		
		Запрос.УстановитьПараметр("мСтруктураСети", МассивПодчиненныхЭл);
		Запрос.УстановитьПараметр("Период", Период);
		
		Возврат Запрос.Выполнить();
	КонецЕсли;
КонецФункции

// Функция - Получает головную структуру сети
//
// Параметры:
//  ДолеваяТочкаУчета	 - СправочникСсылка.энргТочкиУчета
//  Услуга				 - СправочникСсылка.энргВидыУслуг 
//  ОбъектРасчета		 - СправочникСсылка.бестОбъектыРасчета 
//  Район				 - СправочникСсылка.энргЗоныОтвественности
//  Организация			 - СправочникСсылка.Организации
//  Период				 - Дата 
// 
// Возвращаемое значение:
//   - СправочникСсылка.бестСтруктураСети
//
Функция ПолучитьГоловнуюСтруктуруСети(ДолеваяТочкаУчета, Услуга, ОбъектРасчета, Район, Организация, Период) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСтруктураСетиТочекУчетаНПСрезПоследних.СтруктураСети КАК СтруктураСети
		|ИЗ
		|	РегистрСведений.бестСтруктураСетиТочекУчетаНП.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И Район = &Район
		|				И Услуга = &Услуга
		|				И ТочкаУчета = &ТочкаУчета) КАК бестСтруктураСетиТочекУчетаНПСрезПоследних";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Район", Район);
	Запрос.УстановитьПараметр("ТочкаУчета", ДолеваяТочкаУчета);
	Запрос.УстановитьПараметр("Услуга", Услуга);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.СтруктураСети;
	КонецЦикла;
	
	Возврат Неопределено;

КонецФункции

#Область РеализацияИнтерфейса_ДоступныеВидыОпераций

// Функция - Заполняет список возможных операций для формы списка
// 
// Возвращаемое значение:
//   - СписокЗначений
//
Функция ЗаполнитьСписокВозможныхОперацийФормаСписка() Экспорт 
	СписокОпераций = Новый СписокЗначений;
	СписокОпераций.Добавить(Перечисления.бестВидыОпераций.бестУстановитьФормулуРасчетаТочекУчетаНП_НачислениеПоФормуле, НСтр("ru = 'Начисление по формуле'"));
	СписокОпераций.Добавить(Перечисления.бестВидыОпераций.бестУстановитьФормулуРасчетаТочекУчетаНП_ОтменаНачисленийПоФормуле, НСтр("ru = 'Отмена начислений по формуле'"));
		
	Возврат СписокОпераций;
КонецФункции

// Функция - Заполняет соответствие возможных операций и префиксов форм 
// 
// Возвращаемое значение:
//   - Соответствие
//
Функция ПрефиксФормы() Экспорт	
	Соотвествие = Новый Соответствие;
	Соотвествие.Вставить(Перечисления.бестВидыОпераций.бестУстановитьФормулуРасчетаТочекУчетаНП_НачислениеПоФормуле, "НачислениеПоФормуле");
	Соотвествие.Вставить(Перечисления.бестВидыОпераций.бестУстановитьФормулуРасчетаТочекУчетаНП_ОтменаНачисленийПоФормуле, "ОтменаНачисленийПоФормуле");;
	
	Возврат Соотвествие;	
КонецФункции

// Функция - Заполняет массив возможных операций
// 
// Возвращаемое значение:
//   - Массив
//
Функция ВидыОпераций() Экспорт 
	ВидыОпераций = Новый Массив;
	ВидыОпераций.Добавить(Перечисления.бестВидыОпераций.бестУстановитьФормулуРасчетаТочекУчетаНП_НачислениеПоФормуле);
	ВидыОпераций.Добавить(Перечисления.бестВидыОпераций.бестУстановитьФормулуРасчетаТочекУчетаНП_ОтменаНачисленийПоФормуле);
	
	Возврат ВидыОпераций;	
КонецФункции
	
