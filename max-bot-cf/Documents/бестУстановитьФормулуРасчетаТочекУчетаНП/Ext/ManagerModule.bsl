#Область СлужебныеПроцедурыИФункции

Процедура ОбойтиПодчиненныеЭлементыСтруктурыСети(МассивПодчиненныхЭл, Источник, Период)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	бестСтруктураСетиСрезПоследних.Приемник КАК Приемник
		|ИЗ
		|	РегистрСведений.бестСтруктураСети.СрезПоследних(&Период, Источник = &Источник) КАК бестСтруктураСетиСрезПоследних
		|ГДЕ
		|	бестСтруктураСетиСрезПоследних.Актуальность";
	
	Запрос.УстановитьПараметр("Источник", Источник);
	Запрос.УстановитьПараметр("Период", Период);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивПодчиненныхЭл.Добавить(ВыборкаДетальныеЗаписи.Приемник);
		ОбойтиПодчиненныеЭлементыСтруктурыСети(МассивПодчиненныхЭл, ВыборкаДетальныеЗаписи.Приемник, Период);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли