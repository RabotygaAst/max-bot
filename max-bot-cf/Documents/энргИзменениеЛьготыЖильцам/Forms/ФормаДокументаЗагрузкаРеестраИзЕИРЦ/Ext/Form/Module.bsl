КонецПроцедуры

&НаСервере
Процедура ИсправитьДанныеНаСервере()
	
	Для Каждого Стр из НезагруженныеДанныеНенайденныеЛьготники Цикл
		Если Стр.Исправлен ИЛИ НЕ ЗначениеЗаполнено(Стр.КодСоциальнойЗащиты) ИЛИ НЕ ЗначениеЗаполнено(Стр.КлючПомещения) 
			ИЛИ НЕ ЗначениеЗаполнено(Стр.Абонент) Тогда
			Продолжить;
		КонецЕсли;	
		
		Если НЕ ЗначениеЗаполнено(Стр.Жилец) Тогда
			ОбщегоНазначения.СообщитьПользователю("Не выбран жилец по абоненту с кодом соцзащиты " + Стр.КодСоциальнойЗащиты); 
			Продолжить;
		КонецЕсли;
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("КодСоциальнойЗащиты", Стр.КодСоциальнойЗащиты);
		НайденныеСтроки = Объект.НеЗагруженныеДанные.НайтиСтроки(ПараметрыОтбора);
		
		Если НайденныеСтроки.Количество() > 0  Тогда
			
			СтрокаДанных = НайденныеСтроки[0];
			
			МодульэнргРаботаСЛьготникамиЕИРЦ = ОбщегоНазначения.ОбщийМодуль("энргРаботаСЛьготникамиЕИРЦ");
			
			МодульэнргРаботаСЛьготникамиЕИРЦ.ЗарегистрироватьСоответствиеКодаСоцЗащитыИЛьготника(Стр.КодСоциальнойЗащиты, Стр.Жилец);
			
			ЗаполнитьЗначенияСвойств(СтрокаДанных, Стр,, "НомерСтроки"); 
			СтрокаДанных.Исправлен = Истина;
			
			СтрЗагруженныеДанные = Объект.ЗагруженныеДанные.Добавить();			
			ЗаполнитьЗначенияСвойств(СтрЗагруженныеДанные, СтрокаДанных,, "НомерСтроки");
			
		КонецЕсли;
	КонецЦикла;
	
	ЗаполнитьПредставлениеНеЗагруженныхДанныхСервер(Объект);
		
КонецПроцедуры

&НаСервере
Процедура ИсправитьАдресНаСервере()
	
	Для Каждого Стр из НезагруженныеДанныеНесоответствиеАдреса Цикл
		Если Стр.Исправлен ИЛИ НЕ ЗначениеЗаполнено(Стр.КодСоциальнойЗащиты) ИЛИ НЕ ЗначениеЗаполнено(Стр.КлючПомещенияСтало) ИЛИ НЕ ЗначениеЗаполнено(Стр.Абонент) Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Стр.Жилец) Тогда
			ОбщегоНазначения.СообщитьПользователю("Не выбран жилец по абоненту с кодом соцзащиты " + Стр.КодСоциальнойЗащиты); 
			Продолжить;
		КонецЕсли;
		
		ПараметрыОтбора = Новый Структура;
		//ПараметрыОтбора.Вставить("НомерСтроки", Стр.НомерСтроки);
		ПараметрыОтбора.Вставить("КодСоциальнойЗащиты", Стр.КодСоциальнойЗащиты);
		НайденныеСтроки = Объект.НеЗагруженныеДанные.НайтиСтроки(ПараметрыОтбора);   
		
		Если НайденныеСтроки.Количество() > 0  Тогда
			
			Стр.Исправлен = Истина;
			
			СтрокаДанных = НайденныеСтроки[0];
			
			МодульэнргРаботаСЛьготникамиЕИРЦ = ОбщегоНазначения.ОбщийМодуль("энргРаботаСЛьготникамиЕИРЦ");
			
			МодульэнргРаботаСЛьготникамиЕИРЦ.ЗарегистрироватьСоответствиеКодаСоцЗащитыИЛьготника(Стр.КодСоциальнойЗащиты, Стр.Жилец);
			
			ЗаполнитьЗначенияСвойств(СтрокаДанных, Стр,, "НомерСтроки");
			СтрокаДанных.Исправлен = Истина;			
			
			СтрЗагруженныеДанные = Объект.ЗагруженныеДанные.Добавить();			
			ЗаполнитьЗначенияСвойств(СтрЗагруженныеДанные, СтрокаДанных,, "НомерСтроки");			
			СтрЗагруженныеДанные.КлючПомещения = СтрокаДанных.КлючПомещенияСтало;
			
		КонецЕсли;
				
	КонецЦикла;
	
	ЗаполнитьПредставлениеНеЗагруженныхДанныхСервер(Объект);
	
КонецПроцедуры

#КонецОбласти

