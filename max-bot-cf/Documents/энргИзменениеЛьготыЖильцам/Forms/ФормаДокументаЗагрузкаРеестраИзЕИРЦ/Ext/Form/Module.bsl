	Если ДатаВвода = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Объект.ПериодРегистрацииЛьготы = НачалоМесяца(ДатаВвода);
	
КонецПроцедуры 

#КонецОбласти

#Область ПереносАбонентовНаВкладкуВнеЗоныГП

&НаСервере
Процедура ПеренестиЖильцовВнеЗоныГПНаСервере()
	
	Для Каждого СтрокаНабора из НезагруженныеДанныеНесоответствиеАдреса Цикл
		
		Если НЕ СтрокаНабора.ВнеЗоныГП Тогда 
			Продолжить;
		КонецЕсли; 		
		
		ПараметрыОтбора = Новый Структура;
		//ПараметрыОтбора.Вставить("НомерСтроки", СтрокаНеЗагружено.НомерСтроки);
		ПараметрыОтбора.Вставить("КодСоциальнойЗащиты", СтрокаНабора.КодСоциальнойЗащиты);
		НайденныеСтроки = Объект.НеЗагруженныеДанные.НайтиСтроки(ПараметрыОтбора);   
		Для Каждого НайденнаяСтрока из НайденныеСтроки Цикл
			НайденнаяСтрока.ВнеЗоныГП = Истина;
		КонецЦикла;	
		
	КонецЦикла;
	
	ЗаполнитьПредставлениеНеЗагруженныхДанныхСервер(Объект);

КонецПроцедуры  
	
#КонецОбласти

&НаКлиенте
Процедура ФайлДляЧтенияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	Ошибки = Новый Массив;
	ПроверитьОбработкуЗагрузки(Ошибки); 	
	Если Ошибки.Количество() > 0 Тогда
		ТекстПредупреждение = СтрСоединить(Ошибки, ". ");
		ПоказатьПредупреждение(, ТекстПредупреждение);
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка 		= Ложь;
	Диалог 						= Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр 				= ПолучитьФильтрФайлов();
	Если Диалог.Выбрать() тогда
		Объект.ФайлДляЧтения 	= Диалог.ПолноеИмяФайла;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ОчиститьТЧ()
	Объект.ЗагруженныеДанные.Очистить();
	Объект.НезагруженныеДанные.Очистить();
КонецПроцедуры

&НаКлиенте
Функция ЕстьНеЗагруженныеДанные()
	
	ЕстьДанные = Ложь;
	Для Каждого СтрокаНабора из Объект.НезагруженныеДанные Цикл 
		ЕстьДанные = Истина;
		Прервать;
	КонецЦикла;
	
	Возврат ЕстьДанные;
	
КонецФункции

&НаКлиенте
Процедура НезагруженныеДанныеНенайденныеЛьготникиЛицевойСчетПриИзменении(Элемент)
	
	ТекДанные 						= Элементы.НезагруженныеДанныеНенайденныеЛьготники.ТекущиеДанные;	
	ОтветАбонентИСвязанныеСвойства 	= ОтветАбонентИСвязанныеСвойства();
	Если ПустаяСтрока(ТекДанные.ЛицевойСчет) Тогда
		ЗаполнитьЗначенияСвойств(ТекДанные, ОтветАбонентИСвязанныеСвойства);		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан лицевой счет");
		Возврат;
	КонецЕсли;
	
	ОпределитьАбонентаИСвязанныеСвойства(ТекДанные.ЛицевойСчет, ОтветАбонентИСвязанныеСвойства);
	ЗаполнитьЗначенияСвойств(ТекДанные, ОтветАбонентИСвязанныеСвойства);

КонецПроцедуры


&НаСервереБезКонтекста
Процедура ОпределитьАбонентаИСвязанныеСвойства(ЛицевойСчет, Результат)
	Результат.Абонент 	= Справочники.энргАбоненты.НайтиПоРеквизиту("ЛицевойСчет", ЛицевойСчет);	
	
	РеквизитыАбонента	= Обработки.энргАбонентыМенеджер.ЗначенияРеквизитовОбъекта(Результат.Абонент, "Район, КлючПомещения");
	Результат.КлючПомещения	= РеквизитыАбонента.КлючПомещения;
	
	ДанныеПомещенияРезультат 	= Обработки.энргКлючиПомещенийМенеджер.РезультатДанныеПомещенияПоКлючу(Результат.КлючПомещения);
	
	Если Не ДанныеПомещенияРезультат.Пустой() Тогда
		ДанныеПомещенияВыборка  = ДанныеПомещенияРезультат.Выбрать();
		ДанныеПомещенияВыборка.Следующий();
		ЗаполнитьЗначенияСвойств(Результат,ДанныеПомещенияВыборка,"Строение,Помещение");
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОтветАбонентИСвязанныеСвойства()
	Результат = Новый Структура;
	Результат.Вставить("Абонент"		, Справочники.энргАбоненты.ПустаяСсылка());
	Результат.Вставить("КлючПомещения"	, Справочники.энргКлючиПомещений.ПустаяСсылка());
	Результат.Вставить("Строение"		, Справочники.энргСтроения.ПустаяСсылка());
	Результат.Вставить("Помещение"		, Справочники.энргПомещения.ПустаяСсылка());
	
	Возврат Результат;
КонецФункции

&НаКлиенте
Функция ПолучитьКаталогВыгрузки()
	ТекКаталогВыгрузки	= ""; 
	#Если ВебКлиент Тогда

		ДиалогВыбораФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	    
	    ДиалогВыбораФайла.Каталог = ТекКаталогВыгрузки;
	    ДиалогВыбораФайла.Заголовок = "Выберите каталог";
	    
	    ПараметрыСценария = Новый Структура;
	    Оповещение = Новый ОписаниеОповещения("КаталогНачалоВыбораЗавершение", ЭтаФорма);
	    ПараметрыСценария.Вставить("Оповещение_ПослеЗакрытияДиалогаВыбораФайла", Оповещение);
	    ПараметрыСценария.Вставить("ДиалогВыбораФайла", ДиалогВыбораФайла);
	
	#Иначе
		Режим = РежимДиалогаВыбораФайла.ВыборКаталога; 
		ДиалогОткрытия = Новый ДиалогВыбораФайла(Режим);
		СтандартнаяОбработка = Ложь;
		ДиалогОткрытия.Каталог = ""; 
		ДиалогОткрытия.МножественныйВыбор = Ложь; 
		ДиалогОткрытия.Заголовок = "Выберите каталог"; 
		
		Если ДиалогОткрытия.Выбрать() Тогда 
			ТекКаталогВыгрузки = ДиалогОткрытия.Каталог + "\"; 
		КонецЕсли;
	#КонецЕсли	
	
	Возврат ТекКаталогВыгрузки;	
КонецФункции

&НаСервере
Функция ПолучитьИмяФайлаЗагрузки()
	
	ПолноеИмяФайла = Объект.ФайлДляЧтения;
	НовыйФайл = Новый Файл(ПолноеИмяФайла);
	ИмяФайла = "ВыгрузкаЕИРЦ";
	Если НовыйФайл.Существует() Тогда
		ИмяФайла = НовыйФайл.ИмяБезРасширения;
		Возврат ИмяФайла;
	КонецЕсли;
	
	МассивСтрок = СтрРазделить(ПолноеИмяФайла, "\", Ложь);
	Если МассивСтрок.Количество() > 0 Тогда
		ПоследняяСтрока = МассивСтрок[МассивСтрок.Количество()- 1];
		
		МассивСтрок = СтрРазделить(ПоследняяСтрока, ".", Ложь);
		Если МассивСтрок.Количество() > 0 Тогда
			ИмяФайла = МассивСтрок[0];
			Возврат ИмяФайла;
		КонецЕсли;
		
	КонецЕсли; 	
		
	Возврат ИмяФайла;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПредставлениеНеЗагруженныхДанныхСервер(Знач ТекущийОбъект)
	
	НезагруженныеДанныеНенайденныеЛьготники.Очистить();
	НезагруженныеДанныеНесоответствиеАдреса.Очистить();
	НезагруженныеДанныеВнеЗоныГП.Очистить();
	
	Для Каждого СтрокаНеЗагружено Из ТекущийОбъект.НезагруженныеДанные Цикл
		
		Если СтрокаНеЗагружено.Исправлен Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаНеЗагружено.ВнеЗоныГП Тогда
			СтрокаТаблицы			= НезагруженныеДанныеВнеЗоныГП.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаНеЗагружено,, "НомерСтроки");	
		ИначеЕсли СтрокаНеЗагружено.КодОшибки = 1 Тогда	
			СтрокаТаблицы			= НезагруженныеДанныеНенайденныеЛьготники.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаНеЗагружено,, "НомерСтроки");	
		ИначеЕсли СтрокаНеЗагружено.КодОшибки = 2 Тогда	
			СтрокаТаблицы			= НезагруженныеДанныеНесоответствиеАдреса.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаНеЗагружено,, "НомерСтроки");	
		Иначе
			Продолжить;
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьДанныеПоНомеруДомаИКвартире(Команда)
	ОбработатьДанныеПоНомеруДомаИКвартиреНаСервере();
	ЭтотОбъект.Модифицированность = Истина;
КонецПроцедуры

&НаСервере
Процедура ОбработатьДанныеПоНомеруДомаИКвартиреНаСервере()
	
	Для Каждого Стр из НезагруженныеДанныеНесоответствиеАдреса Цикл
		
		Если НЕ ЗначениеЗаполнено(Стр.Жилец) Тогда
			Продолжить;
		КонецЕсли;
		
		Если НРег(Стр.ДомЕИРЦ) = ПолучитьНомерДома(Строка(Стр.Строение)) 
			И Стр.ПомещениеЕИРЦ = ПолучитьНомерПомещения(Строка(Стр.Помещение)) Тогда				
			
			ПараметрыОтбора = Новый Структура;
			//ПараметрыОтбора.Вставить("НомерСтроки", СтрокаНеЗагружено.НомерСтроки);
			ПараметрыОтбора.Вставить("КодСоциальнойЗащиты", Стр.КодСоциальнойЗащиты);
			НайденныеСтроки = Объект.НеЗагруженныеДанные.НайтиСтроки(ПараметрыОтбора);   
			
			Если НайденныеСтроки.Количество() > 0 Тогда
				
				Стр.Исправлен = Истина;
				
				НайденнаяСтрока = НайденныеСтроки[0];
				ЗаполнитьЗначенияСвойств(НайденнаяСтрока, Стр,, "НомерСтроки");
				НайденнаяСтрока.Исправлен = Истина;
				
				СтрЗагруженныеДанные = Объект.ЗагруженныеДанные.Добавить();				
				ЗаполнитьЗначенияСвойств(СтрЗагруженныеДанные, НайденнаяСтрока,, "НомерСтроки");
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаполнитьПредставлениеНеЗагруженныхДанныхСервер(Объект);

КонецПроцедуры

&НаСервере
Функция ПолучитьНомерДома(НаименованиеСтроения)
	
	Разделитель = ",";
	
	ПозицияНомерДома =  СтрНайти(НаименованиеСтроения, "Дом № "); 
	
	Если ПозицияНомерДома > 0 Тогда
		ПозицияРазделителя = СтрНайти(НаименованиеСтроения,Разделитель, НаправлениеПоиска.СНачала, ПозицияНомерДома + 6);
		
		Если ПозицияРазделителя > 0 Тогда
		СтрНомерДома = Сред(НаименованиеСтроения, ПозицияНомерДома + 6, ПозицияРазделителя - (ПозицияНомерДома + 6));
	Иначе
		  СтрНомерДома = Прав(НаименованиеСтроения, СтрДлина(НаименованиеСтроения) -  (ПозицияНомерДома + 6) + 1);
		  КонецЕсли;
		
		Возврат НРег(СтрНомерДома);
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПолучитьНомерПомещения(НаименованиеПомещения)
	
	ПозицияНомерКвартиры =  СтрНайти(НаименованиеПомещения, "Квартира "); 
	
	Если ПозицияНомерКвартиры > 0 Тогда
		
		СтрНомерКвартиры = Сред(НаименованиеПомещения, ПозицияНомерКвартиры + 9, СтрДлина(НаименованиеПомещения) - ПозицияНомерКвартиры);
		
		Возврат СокрЛП(СтрНомерКвартиры);
	Иначе
		Возврат НаименованиеПомещения;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ОпределитьЖильцовВнеЗоныГП(Команда)
	ОпределитьЖильцовВнеЗоныГПНаСервере();
	ЭтотОбъект.Модифицированность = Истина;
КонецПроцедуры

&НаСервере
Процедура ОпределитьЖильцовВнеЗоныГПНаСервере()
	
	МассивНаселенныхПунктовБиллинг = ПолучитьМассивНаселенныхПунктовБиллинг();
	
	Если МассивНаселенныхПунктовБиллинг.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаНеЗагружено из НезагруженныеДанныеНенайденныеЛьготники Цикл
		
		Если СтрокаНеЗагружено.ВнеЗоныГП = Истина Тогда 
			
			ПараметрыОтбора = Новый Структура;
			//ПараметрыОтбора.Вставить("НомерСтроки", СтрокаНеЗагружено.НомерСтроки);
			ПараметрыОтбора.Вставить("КодСоциальнойЗащиты", СтрокаНеЗагружено.КодСоциальнойЗащиты);
			НайденныеСтроки = Объект.НеЗагруженныеДанные.НайтиСтроки(ПараметрыОтбора);   
			
			Если НайденныеСтроки.Количество() > 0  Тогда
				Если НайденныеСтроки[0].ВнеЗоныГП = Истина Тогда
					Продолжить;
				Иначе
					ЗаполнитьЗначенияСвойств(НайденныеСтроки[0], СтрокаНеЗагружено,, "НомерСтроки");
					НайденныеСтроки[0].ВнеЗоныГП = Истина;				
				КонецЕсли;
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		Если МассивНаселенныхПунктовБиллинг.Найти(СтрокаНеЗагружено.НаселенныйПунктЕИРЦ) = Неопределено Тогда 
			
			ПараметрыОтбора = Новый Структура;
			//ПараметрыОтбора.Вставить("НомерСтроки", СтрокаНеЗагружено.НомерСтроки);
			ПараметрыОтбора.Вставить("КодСоциальнойЗащиты", СтрокаНеЗагружено.КодСоциальнойЗащиты);
			НайденныеСтроки = Объект.НеЗагруженныеДанные.НайтиСтроки(ПараметрыОтбора);   
			
			Если НайденныеСтроки.Количество() > 0  Тогда
				Если НайденныеСтроки[0].ВнеЗоныГП = Истина Тогда
					Продолжить;
				Иначе
					ЗаполнитьЗначенияСвойств(НайденныеСтроки[0], СтрокаНеЗагружено,, "НомерСтроки");
					НайденныеСтроки[0].ВнеЗоныГП = Истина;				
				КонецЕсли;
			КонецЕсли;

			
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаполнитьПредставлениеНеЗагруженныхДанныхСервер(Объект);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивНаселенныхПунктовБиллинг()
	
	МассивНП = Новый Массив;
	 	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргСтроения.Ссылка КАК Ссылка,
		|	энргСтроенияКонтактнаяИнформация.Значение КАК Значение
		|ИЗ
		|	Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргСтроения КАК энргСтроения
		|		ПО энргСтроенияКонтактнаяИнформация.Ссылка = энргСтроения.Ссылка
		|			И (энргСтроенияКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес))
		|ГДЕ
		|	НЕ энргСтроения.ПометкаУдаления
		|	И энргСтроения.Район = &Район";
	
	Запрос.УстановитьПараметр("Район", Объект.Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
		СтруктураJSON			= УправлениеКонтактнойИнформациейСлужебный.JSONВКонтактнуюИнформациюПоПолям(ВыборкаДетальныеЗаписи.Значение, Перечисления.ТипыКонтактнойИнформации.Адрес);
		
		Город			= СтруктураJSON.City;
		ГородТип		= НРег(СтруктураJSON.CityType);
		
		НаселПункт      = СтруктураJSON.Locality;
		НаселПунктТип   = НРег(СтруктураJSON.LocalityType);

		
		Если ЗначениеЗаполнено(Город) Тогда
			
			СтрГород = ВРег(ГородТип + " " + Город);
			НайденныйИндекс = МассивНП.Найти(СтрГород);
			Если НайденныйИндекс = Неопределено Тогда
				МассивНП.Добавить(СтрГород);
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НаселПункт) Тогда
			
			СтрНаселПункт = ВРег(НаселПунктТип + " " + НаселПункт);
			НайденныйИндекс = МассивНП.Найти(СтрНаселПункт);
			Если НайденныйИндекс = Неопределено Тогда
				МассивНП.Добавить(СтрНаселПункт);
			КонецЕсли;
		КонецЕсли;

	КонецЦикла;
	
	Возврат МассивНП;
	
КонецФункции


&НаКлиенте
Процедура ВернутьЛьготникаНаОбработку(Команда)
	ВернутьЛьготникаНаОбработкуНаСервере();
	ЭтотОбъект.Модифицированность = Истина;
КонецПроцедуры

&НаСервере
Процедура ВернутьЛьготникаНаОбработкуНаСервере()
	
	Для Каждого СтрокаНеЗагружено из НезагруженныеДанныеВнеЗоныГП Цикл
		
		Если СтрокаНеЗагружено.ВнеЗоныГП = Ложь Тогда 
			
			ПараметрыОтбора = Новый Структура;
			//ПараметрыОтбора.Вставить("НомерСтроки", СтрокаНеЗагружено.НомерСтроки);
			ПараметрыОтбора.Вставить("КодСоциальнойЗащиты", СтрокаНеЗагружено.КодСоциальнойЗащиты);
			НайденныеСтроки = Объект.НеЗагруженныеДанные.НайтиСтроки(ПараметрыОтбора);   
			
			Если НайденныеСтроки.Количество() > 0 Тогда
				Если НайденныеСтроки[0].ВнеЗоныГП = Ложь Тогда
					Продолжить;
				Иначе
					ЗаполнитьЗначенияСвойств(НайденныеСтроки[0], СтрокаНеЗагружено,, "НомерСтроки");
					НайденныеСтроки[0].ВнеЗоныГП = Ложь;				
				КонецЕсли;
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
				
	КонецЦикла;
	
	ЗаполнитьПредставлениеНеЗагруженныхДанныхСервер(Объект);

КонецПроцедуры    

#КонецОбласти

Процедура ДополнитьТаблицу(ТаблицаИсточник, ТаблицаПриемник, КопияНеЗагруженные)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("КодСоциальнойЗащиты", Неопределено);
	
	Для Каждого СтрокаТаблицыИсточник Из ТаблицаИсточник Цикл
		НоваяСтрока = ТаблицаПриемник.Добавить();	
		
		ПараметрыОтбора.КодСоциальнойЗащиты = СтрокаТаблицыИсточник.КодСоциальнойЗащиты;
		НайденныеСтроки = КопияНеЗагруженные.НайтиСтроки(ПараметрыОтбора);		
		Если НайденныеСтроки.Количество() > 0 Тогда		
			ЗаполнитьЗначенияСвойств(НоваяСтрока, НайденныеСтроки[0],, "НомерСтроки");
		КонецЕсли; 		
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицыИсточник,, "НомерСтроки");
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСлужебныеДанные()
	
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект, "ЗагруженныеДанные");
	энргРаботаСЛицевымСчетомСервер.ПриЧтенииНаСервереДанныеПомещенияКоллекция(Объект, "НезагруженныеДанные");
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(АбонентыСОтлюченнойЛьготой, "Регистратор", Объект.Ссылка);
	
КонецПроцедуры

#КонецОбласти