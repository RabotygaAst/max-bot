#Область ПроверкаДанных

&НаКлиенте
Функция ПроверитьВозможностьЗагрузки(ПроверятьМодифицированность = Ложь)
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Результат.Добавить("Перед загрузкой необходимо записать документ. Записать данный документ?");
	КонецЕсли;
	Если ПроверятьМодифицированность И Модифицированность Тогда 
		Результат.Добавить("Документ изменен. Перед исправлением данных необходимо записать документ. Записать данный документ?");
	КонецЕсли;		
	
	ПроверитьОбработкуЗагрузки(Результат);
	
	Если НЕ ЗначениеЗаполнено(Объект.ФайлДляЧтения) Тогда
		Результат.Добавить("Укажите файл для чтения");
	КонецЕсли; 	
	
	Возврат СтрСоединить(Результат, ". ");
КонецФункции

&НаКлиенте
Функция ПроверитьОбработкуЗагрузки(Результат)
	Если ЗначениеЗаполнено(Объект.ВидРеестра) Тогда 		
		ОбработкаЗагрузки = СсылкаНаОбработкуЗагрузки(Объект.ВидРеестра);
		Если ОбработкаЗагрузки = ПредопределенноеЗначение("Справочник.ИдентификаторыОбъектовМетаданных.ПустаяСсылка") Тогда 
			Результат.Добавить("У вида реестра не указана обработка загрузки");
		КонецЕсли;
	Иначе 
		Результат.Добавить("Укажите вид реестра");
	КонецЕсли;
КонецФункции

#КонецОбласти

