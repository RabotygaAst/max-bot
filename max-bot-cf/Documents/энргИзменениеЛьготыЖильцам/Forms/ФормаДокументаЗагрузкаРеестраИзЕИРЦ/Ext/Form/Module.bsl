#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	УставновитьПериодНачисленияИРегистрацииЛьготы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	УставновитьПериодНачисленияИРегистрацииЛьготы();
	
КонецПроцедуры

&НаКлиенте
Процедура РайонПриИзменении(Элемент)
	
	УставновитьПериодНачисленияИРегистрацииЛьготы();
	
КонецПроцедуры

&НаКлиенте
Процедура УставновитьПериодНачисленияИРегистрацииЛьготы()
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда		
		Объект.ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Объект.Дата, Объект.Организация, Объект.Район); 		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.ПериодРегистрацииЛьготы) Тогда
		Объект.ПериодРегистрацииЛьготы = ДобавитьМесяц(Объект.ПериодНачисления, -1);
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ПериодРегистрацииЛьготыНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущаяДата = Объект.ПериодРегистрацииЛьготы;
	Подсказка 	= "Введите период регистрации льготы";
	ЧастьДаты 	= ЧастиДаты.Дата;
	Оповещение	= Новый ОписаниеОповещения("ПослеВводаПериодаРегистрацииЛьготы", ЭтотОбъект);
	ПоказатьВводДаты(Оповещение, ТекущаяДата, Подсказка, ЧастьДаты);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСтраницаНезагруженныеДанные

&НаКлиенте
Процедура НезагруженныеДанныеНенайденныеЛьготникиСтроениеБиллингПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.НезагруженныеДанныеНенайденныеЛьготники.ТекущиеДанные;
	ДействияПриИзмененииСтроения(ТекущиеДанные, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура НезагруженныеДанныеНенайденныеЛьготникиПомещениеБиллингПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.НезагруженныеДанныеНенайденныеЛьготники.ТекущиеДанные;
	ОпределитьКлючПомещенияАбонента(ТекущиеДанные, СоответствиеПолейОпределенияКлючаПомещения(Ложь));

КонецПроцедуры


&НаКлиенте
Процедура НезагруженныеДанныеНесоответствиеАдресаСтроениеБиллингСталоПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.НезагруженныеДанныеНесоответствиеАдреса.ТекущиеДанные;
	ДействияПриИзмененииСтроения(ТекущиеДанные, Истина); 	
		
КонецПроцедуры

&НаКлиенте
Процедура НезагруженныеДанныеНесоответствиеАдресаПомещениеБиллингСталоПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.НезагруженныеДанныеНесоответствиеАдреса.ТекущиеДанные;
	ОпределитьКлючПомещенияАбонента(ТекущиеДанные, СоответствиеПолейОпределенияКлючаПомещения(Истина));	
	
КонецПроцедуры


&НаКлиенте
Процедура ДействияПриИзмененииСтроения(ТекущиеДанные, ЭтоСтало)
	
	СоответствиеПолей = СоответствиеПолейОпределенияКлючаПомещения(ЭтоСтало);
	ДобавитьЗаписьВРССоответствиеСтроенийЕИРЦ(ТекущиеДанные[СоответствиеПолей.Строение], ТекущиеДанные.РайонЕИРЦ, ТекущиеДанные.НаселенныйПунктЕИРЦ, ТекущиеДанные.УлицаЕИРЦ, ТекущиеДанные.ДомЕИРЦ, ТекущиеДанные.КорпусЕИРЦ);		
	ОпределитьКлючПомещенияАбонента(ТекущиеДанные, СоответствиеПолей);
	
КонецПроцедуры

&НаКлиенте
Процедура ОпределитьКлючПомещенияАбонента(ТекущиеДанные, СоответствиеПолей)
	
	Строение 		= ТекущиеДанные[СоответствиеПолей.Строение];
	Помещение 		= ТекущиеДанные[СоответствиеПолей.Помещение];
	Если ЗначениеЗаполнено(Строение) Тогда 
		КлючПомещения 	= ПолучитьКлючПомещенияСервер(Строение, Помещение);
	Иначе 		
		КлючПомещения 	= ПредопределенноеЗначение("Справочник.энргКлючиПомещений.ПустаяСсылка");
	КонецЕсли;
	
	ТекущиеДанные[СоответствиеПолей.КлючПомещения] = КлючПомещения;
	ТекущиеДанные.Абонент  		= ПолучитьАбонентаПоКлючуПомещения(Объект.Организация, Объект.Район, КлючПомещения);
	ТекущиеДанные.ЛицевойСчет  	= ПолучитьЛицевойСчетАбонента(ТекущиеДанные.Абонент);
	
	МодульэнргРаботаСЛьготникамиЕИРЦ = ОбщегоНазначенияКлиент.ОбщийМодуль("энргРаботаСЛьготникамиЕИРЦ");
	
	ПараметрыКлючаПомещения = МодульэнргРаботаСЛьготникамиЕИРЦ.НоваяСтруктураПараметровПолученияЛьготника();
	ПараметрыКлючаПомещения.Организация 	= Объект.Организация;
	ПараметрыКлючаПомещения.Район 			= Объект.Район;
	ПараметрыКлючаПомещения.КлючПомещения 	= КлючПомещения;
	
	Если ЗначениеЗаполнено(КлючПомещения) Тогда
		ТекущиеДанные.Жилец = ПолучитьЖильцаАбонента(Объект.Дата, ПараметрыКлючаПомещения, ТекущиеДанные.Абонент,
		ТекущиеДанные.ФИОПоРеестру, ТекущиеДанные.КодСоциальнойЗащиты);
	Иначе 
		ТекущиеДанные.Жилец = ПредопределенноеЗначение("Справочник.энргКонтрагенты.ПустаяСсылка");
	КонецЕсли;
	
	НайденныеСтроки = Объект.НеЗагруженныеДанные.НайтиСтроки(Новый Структура("КодСоциальнойЗащиты", ТекущиеДанные.КодСоциальнойЗащиты));
	Если НайденныеСтроки.Количество() > 0 Тогда
		СтрокаДанных = НайденныеСтроки[0];
		СтрокаДанных[СоответствиеПолей.КлючПомещения] = КлючПомещения;
		СтрокаДанных[СоответствиеПолей.Строение]      = Строение;
		СтрокаДанных[СоответствиеПолей.Помещение]     = Помещение;
		СтрокаДанных.Абонент     = ТекущиеДанные.Абонент;
		СтрокаДанных.ЛицевойСчет = ТекущиеДанные.ЛицевойСчет;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция СоответствиеПолейОпределенияКлючаПомещения(ЭтоСтало)
	Результат = Новый Структура;
	Результат.Вставить("КлючПомещения"	, ?(ЭтоСтало, "КлючПомещенияСтало", "КлючПомещения"));
	Результат.Вставить("Строение"		, ?(ЭтоСтало, "СтроениеБиллингСтало", "Строение"));
	Результат.Вставить("Помещение"		, ?(ЭтоСтало, "ПомещениеБиллингСтало", "Помещение"));
	
	Возврат Результат;
КонецФункции


#Область ПоискСвязанныхДанных

&НаСервереБезКонтекста
Функция ПолучитьКлючПомещенияСервер(Знач Строение, Знач Помещение) 
	
	ДанныеКлючаПомещения = Обработки.энргКлючиПомещенийМенеджер.КлючПомещенияПоСтроениюИПомещению(Строение, Помещение);	
	Возврат ДанныеКлючаПомещения.КлючПомещения;
	
КонецФункции 

&НаСервереБезКонтекста
Функция ПолучитьАбонентаПоКлючуПомещения(Организация, Район, КлючПомещения) 
	
	Запрос = Новый Запрос;
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	энргАбонентыПомещений.Абонент КАК Абонент
		|ИЗ
		|	РегистрСведений.энргАбонентыПомещений КАК энргАбонентыПомещений
		|ГДЕ
		|	энргАбонентыПомещений.КлючПомещения = &КлючПомещения
		|	И энргАбонентыПомещений.Организация = &Организация
		|	И энргАбонентыПомещений.Район = &Район";
	
	Если Не ЗначениеЗаполнено(Район) Тогда
		  ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "энргАбонентыПомещений.Район = &Район", "ИСТИНА");
	  КонецЕсли;
	  
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("КлючПомещения", КлючПомещения);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Абонент;
	Иначе
		Возврат Справочники.энргАбоненты.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции 

&НаСервереБезКонтекста
Функция ПолучитьЛицевойСчетАбонента(Абонент)	
	Возврат энргОбщегоНазначения.ЗначениеРеквизитаОбъекта(Абонент, "ЛицевойСчет");	
КонецФункции 

&НаСервереБезКонтекста
Функция ПолучитьЖильцаАбонента(Период, ПараметрыКлючаПомещения, Абонент, ФИОПоРеестру, КодСоциальнойЗащиты) 
	
	МодульэнргРаботаСЛьготникамиЕИРЦ = ОбщегоНазначения.ОбщийМодуль("энргРаботаСЛьготникамиЕИРЦ");
	
	Возврат МодульэнргРаботаСЛьготникамиЕИРЦ.ПолучитьЛьготникаПоКлючам(Период, ПараметрыКлючаПомещения, Абонент, ФИОПоРеестру, КодСоциальнойЗащиты);
	
КонецФункции

&НаСервереБезКонтекста
Функция ДобавитьЗаписьВРССоответствиеСтроенийЕИРЦ(СтроениеБиллинг, РайонЕИРЦ, НаселенныйПунктЕИРЦ, УлицаЕИРЦ, ДомЕИРЦ, КорпусЕИРЦ);
	
	ДанныеРегистрации = РегистрыСведений.энргСоответствиеСтроенийЕИРЦ.ПолучитьОписаниеОбъекта();
	ДанныеРегистрации.Строение 				= СтроениеБиллинг;
	ДанныеРегистрации.РайонЕИРЦ 			= РайонЕИРЦ;
	ДанныеРегистрации.НаселенныйПунктЕИРЦ 	= НаселенныйПунктЕИРЦ;
	ДанныеРегистрации.УлицаЕИРЦ 			= УлицаЕИРЦ;
	ДанныеРегистрации.ДомЕИРЦ				= ДомЕИРЦ;
	ДанныеРегистрации.КорпусЕИРЦ 			= КорпусЕИРЦ;
	
	МодульэнргРаботаСЛьготникамиЕИРЦ = ОбщегоНазначения.ОбщийМодуль("энргРаботаСЛьготникамиЕИРЦ");
	
	МодульэнргРаботаСЛьготникамиЕИРЦ.ЗарегистрироватьСоответствиеАдреса(ДанныеРегистрации);	
		
КонецФункции
	
#КонецОбласти

#Область РегистрацияДанных

&НаКлиенте
Процедура СоздатьКонтрагентов(Команда)
	СписокКонтрагентов 		 = Новый Массив;
	
	МодульэнргРаботаСЛьготникамиЕИРЦ	= ОбщегоНазначенияКлиент.ОбщийМодуль("энргРаботаСЛьготникамиЕИРЦ");
	НовоеОписаниеКонтрагента			= МодульэнргРаботаСЛьготникамиЕИРЦ.НоваяСтруктураПолейКонтрагента();
	
	Для Каждого Стр Из НезагруженныеДанныеНесоответствиеАдреса Цикл
		Создавать = НЕ ЗначениеЗаполнено(Стр.Жилец) И ЗначениеЗаполнено(Стр.КлючПомещенияСтало) 
						И ЗначениеЗаполнено(Стр.ФИОПоРеестру) И ЗначениеЗаполнено(Стр.Абонент) И ЗначениеЗаполнено(Стр.КодСоциальнойЗащиты);
		
		Если НЕ Создавать Тогда 
			Продолжить;
		КонецЕсли; 			
		 
		ОписаниеКонтрагента = ОбщегоНазначенияКлиент.СкопироватьРекурсивно(НовоеОписаниеКонтрагента);
		ОписаниеКонтрагента.бестФамилия 	 = Стр.ФамилияЕИРЦ;
		ОписаниеКонтрагента.бестИмя 		 = Стр.ИмяЕИРЦ;
		ОписаниеКонтрагента.бестОтчество 	 = Стр.ОтчествоЕИРЦ;
		ОписаниеКонтрагента.Наименование 	 = Стр.ФИОПоРеестру;
		ОписаниеКонтрагента.бестДатаРождения = Стр.ДатаРожденияЕИРЦ;
		
		ОписаниеКонтрагента.Вставить("Идентификатор"		, Стр.НомерСтроки);
		ОписаниеКонтрагента.Вставить("КодСоциальнойЗащиты"	, Стр.КодСоциальнойЗащиты);
		ОписаниеКонтрагента.Вставить("Жилец"				, "");	
		
		СписокКонтрагентов.Добавить(ОписаниеКонтрагента);
	КонецЦикла;
	
	Если СписокКонтрагентов.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;   	
	
	ЭтотОбъект.Модифицированность = Истина;
	
	МодульэнргРаботаСЛьготникамиЕИРЦ.СоздатьСписокКонтрагентов(СписокКонтрагентов, ПредопределенноеЗначение("Перечисление.бестЮрФизЛицо.ФизЛицо"));
	
	ДобавитьСозданныхЖильцовВТаблицу(СписокКонтрагентов);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьСозданныхЖильцовВТаблицу(СписокКонтрагентов)
	
	Для Каждого СтрокаНабора Из СписокКонтрагентов Цикл
		
		//НайденныеСтроки = НезагруженныеДанныеНесоответствиеАдреса.НайтиСтроки(Новый Структура("НомерСтроки", СтрокаНабора.Идентификатор));
		НайденныеСтроки = НезагруженныеДанныеНесоответствиеАдреса.НайтиСтроки(Новый Структура("КодСоциальнойЗащиты", СтрокаНабора.КодСоциальнойЗащиты));
		Если НайденныеСтроки.Количество() > 0 Тогда
			НайденныеСтроки[0].Жилец = СтрокаНабора.Жилец;
		КонецЕсли; 	
		
	КонецЦикла;
	
КонецПроцедуры

