&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	КопияНеЗагруженные = ТекущийОбъект.НезагруженныеДанные.Выгрузить();
	КопияНеЗагруженные.Индексы.Добавить("КодСоциальнойЗащиты");
	
	ОсновнаяТаблица = ТекущийОбъект.НезагруженныеДанные;
	ОсновнаяТаблица.Очистить();
	
	ДополнитьТаблицу(НезагруженныеДанныеНенайденныеЛьготники, ОсновнаяТаблица, КопияНеЗагруженные);
	ДополнитьТаблицу(НезагруженныеДанныеНесоответствиеАдреса, ОсновнаяТаблица, КопияНеЗагруженные);
	ДополнитьТаблицу(НезагруженныеДанныеВнеЗоныГП, ОсновнаяТаблица, КопияНеЗагруженные);
	
	//ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НезагруженныеДанныеНенайденныеЛьготники, ОсновнаяТаблица);
	//ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НезагруженныеДанныеНесоответствиеАдреса, ОсновнаяТаблица);
	//ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НезагруженныеДанныеВнеЗоныГП, ОсновнаяТаблица);  		
	
КонецПроцедуры

