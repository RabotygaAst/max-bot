#Область ЗагрузкаДанных

&НаКлиенте
Процедура ЗагрузитьДанные(Команда)
	Ошибки = ПроверитьВозможностьЗагрузки();
	Если НЕ ПустаяСтрока(Ошибки) Тогда 
		НовоеОписаниеОповощение = Новый ОписаниеОповещения("ЗаполнитьДанныеПослеВопроса", ЭтотОбъект);
		ПоказатьВопрос(НовоеОписаниеОповощение,Ошибки,РежимДиалогаВопрос.ДаНет,,,,);
		Возврат;
	КонецЕсли;
	Если ЕстьНеЗагруженныеДанные() Тогда 
		НовоеОписаниеОповощение = Новый ОписаниеОповещения("ЗаполнитьДанныеПослеВопросаОчистки", ЭтотОбъект);
		ПоказатьВопрос(НовоеОписаниеОповощение, "Данные табличных частей документа будут очищены. Продолжить загрузку?", РежимДиалогаВопрос.ДаНет,,, "Очистка данных");
	Иначе 
		ЗагрузитьДанныеОбработкой();
	КонецЕсли;	
КонецПроцедуры

#КонецОбласти

#Область ВыгрузкаДанных

&НаКлиенте
Процедура ВыгрузитьДанныеВРеестр(Команда)
	
	Если Модифицированность Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Перед выгрузкой документ необходимо записать");
		Возврат;
	КонецЕсли;
	КаталогВыгрузки 		= ПолучитьКаталогВыгрузки();
	ИмяФайла                = ПолучитьИмяФайлаЗагрузки();
	ЗапуститьФоновоеЗаданиеФормированияДанныхВыгрузкиКлиент(КаталогВыгрузки, ИмяФайла);
		
КонецПроцедуры


&НаКлиенте
Функция ЗапуститьФоновоеЗаданиеФормированияДанныхВыгрузкиКлиент(КаталогВыгрузки, ИмяФайла)
	
	ИмяОбработкиВыгрузки = ИмяФайлаВыгрузкиДанных(Объект.ВидРеестра);
	
	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить("Ссылка"				, Объект.Ссылка);
	ПараметрыФункции.Вставить("Дата"				, Объект.Дата);
	ПараметрыФункции.Вставить("ПериодНачисления"	, Объект.ПериодРегистрацииЛьготы);
	ПараметрыФункции.Вставить("Организация"			, Объект.Организация);
	ПараметрыФункции.Вставить("Район"				, Объект.Район);
	
	// 1. Запуск фонового задания на сервере.
	ДлительнаяОперация = ЗапуститьФоновоеЗаданиеФормированияДанныхВыгрузки(УникальныйИдентификатор, ИмяОбработкиВыгрузки, ПараметрыФункции);
	
	// 2. Подключение обработчика завершения фонового задания.
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;
	ДополнительныеПараметры = Новый Структура("КаталогВыгрузки, ИмяФайла", КаталогВыгрузки, ИмяФайла);
	Оповещение = Новый ОписаниеОповещения("ПриЗавершенииПодготовкиДанныхВыгрузки", ЭтотОбъект, ДополнительныеПараметры);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗапуститьФоновоеЗаданиеФормированияДанныхВыгрузки(УникальныйИдентификатор, ИмяОбработкиВыгрузки, ПараметрыФункции)
	
	ИмяФункции = ИмяОбработкиВыгрузки + ".ПолучитьДанныеВыгрузки";
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);	
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения, 
		ИмяФункции,
		ПараметрыФункции);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

&НаКлиенте
Процедура ПриЗавершенииПодготовкиДанныхВыгрузки(РезультатВыполнения, ДополнительныеПараметры) Экспорт
	
	Если РезультатВыполнения = Неопределено Тогда 
		Возврат;
	КонецЕсли;
		
	Если РезультатВыполнения.Статус = "Ошибка" Тогда
		УдалитьИзВременногоХранилища(РезультатВыполнения.АдресРезультата);
		ПоказатьПредупреждение( ,РезультатВыполнения.КраткоеПредставлениеОшибки);
		
		Возврат;
	КонецЕсли;
	
	Файл = ПолучитьИзВременногоХранилища(РезультатВыполнения.АдресРезультата);  	
	Файл.Записать(ДополнительныеПараметры.КаталогВыгрузки + ДополнительныеПараметры.ИмяФайла + ".dbf");	
	УдалитьИзВременногоХранилища(РезультатВыполнения.АдресРезультата);                                 	
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Файл успешно выгружен");
	
КонецПроцедуры

