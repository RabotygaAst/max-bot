#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Ответственный 			= Пользователи.ТекущийПользователь();
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);	
	
	ДанныеШапки 		= ДанныеШапки();
	
	СоотвествиеКолонок 	= Новый Структура;
	СоотвествиеКолонок.Вставить("ПриборУчета",				"ПриборУчета");
	СоотвествиеКолонок.Вставить("ТекущиеПоказания",			"ТекущиеПоказания");
	СоотвествиеКолонок.Вставить("ТочкаУчета",				"ТочкаУчета");
	
	ДанныеПриборовТУ = ПолучитьДанныеТЧ();
	
	энргПроведениеСервер.ВыполнитьДвиженияПоРезультатуЗапроса(ДанныеПриборовТУ,	Движения.энргПлательщикиУслугАбонента);
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
			
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ПериодНачисления = энргГраницыПериодаНачисленияМенеджерВызовСервера.ОпределитьПериодНачисления(Дата, Организация, Район);	
КонецПроцедуры

Функция ДанныеШапки()
	ДанныеШапки = Новый Структура;
	ДанныеШапки.Вставить("Дата",					?(ЗначениеЗаполнено(ДатаФактическогоСобытия),КонецДня(ДатаФактическогоСобытия),Дата));
	ДанныеШапки.Вставить("Район",					Район); 
	ДанныеШапки.Вставить("Организация",				Организация);
	ДанныеШапки.Вставить("КлючПомещения",			КлючПомещения);
	ДанныеШапки.Вставить("ПериодРегистрации",		Дата);
	ДанныеШапки.Вставить("ПериодНачисления",		ПериодНачисления);
	ДанныеШапки.Вставить("Абонент",					Абонент);
	ДанныеШапки.Вставить("ТочкиУчета",				ТочкиУчета);
	ДанныеШапки.Вставить("Документ",				Ссылка);  	
	ДанныеШапки.Вставить("ИмяДокумента",			"энргСменаПлательщика");
	Возврат ДанныеШапки;	
КонецФункции

Функция ПолучитьДанныеТЧ()
	Запрос  	= Новый Запрос;
	Запрос.УстановитьПараметр("мДокументы",				Ссылка);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВложенныйЗапрос.Период КАК Период,
	               |	ВложенныйЗапрос.Организация КАК Организация,
	               |	ВложенныйЗапрос.Район КАК Район,
	               |	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	               |	ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	               |	ВЫБОР
	               |		КОГДА ВложенныйЗапрос.ЧастьСоставной
	               |			ТОГДА ЕСТЬNULL(энргИзменитьПлательщикаУслугиПлательщикиСоставныхУслуг.ЧастьСоставнойУслуги, ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.ПустаяСсылка))
	               |		ИНАЧЕ ВложенныйЗапрос.Услуга
	               |	КОНЕЦ КАК Услуга,
	               |	ВложенныйЗапрос.ЧастьСоставной КАК ЧастьСоставной,
	               |	ВложенныйЗапрос.ПериодРегистрации КАК ПериодРегистрации,
	               |	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	               |	энргИзменитьПлательщикаУслугиПлательщикиСоставныхУслуг.Ссылка КАК Ссылка,
	               |	ВЫБОР
	               |		КОГДА ВложенныйЗапрос.ЧастьСоставной
	               |			ТОГДА ВЫБОР
	               |					КОГДА энргИзменитьПлательщикаУслугиПлательщикиСоставныхУслуг.Плательщик = ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка)
	               |						ТОГДА ВложенныйЗапрос.Абонент
	               |					ИНАЧЕ энргИзменитьПлательщикаУслугиПлательщикиСоставныхУслуг.Плательщик
	               |				КОНЕЦ
	               |		ИНАЧЕ ВЫБОР
	               |				КОГДА ВложенныйЗапрос.Плательщик = ЗНАЧЕНИЕ(Справочник.энргАбоненты.ПустаяСсылка)
	               |					ТОГДА ВложенныйЗапрос.Абонент
	               |				ИНАЧЕ ВложенныйЗапрос.Плательщик
	               |			КОНЕЦ
	               |	КОНЕЦ КАК Плательщик
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ВЫБОР
	               |			КОГДА НЕ энргИзменитьПлательщикаУслуги.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	               |				ТОГДА энргИзменитьПлательщикаУслуги.ДатаФактическогоСобытия
	               |			ИНАЧЕ энргИзменитьПлательщикаУслуги.Дата
	               |		КОНЕЦ КАК Период,
	               |		энргИзменитьПлательщикаУслуги.Организация КАК Организация,
	               |		энргИзменитьПлательщикаУслуги.Район КАК Район,
	               |		энргИзменитьПлательщикаУслуги.КлючПомещения КАК КлючПомещения,
	               |		энргИзменитьПлательщикаУслугиТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	               |		энргИзменитьПлательщикаУслугиТочкиУчета.Услуга КАК Услуга,
	               |		энргИзменитьПлательщикаУслугиТочкиУчета.ЭтоСоставнаяУслуга КАК ЧастьСоставной,
	               |		энргИзменитьПлательщикаУслугиТочкиУчета.IDСтроки КАК IDСтроки,
	               |		энргИзменитьПлательщикаУслуги.Дата КАК ПериодРегистрации,
	               |		НАЧАЛОПЕРИОДА(энргИзменитьПлательщикаУслуги.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления,
	               |		энргИзменитьПлательщикаУслуги.Ссылка КАК Регистратор,
	               |		энргИзменитьПлательщикаУслуги.Абонент КАК Абонент,
	               |		энргИзменитьПлательщикаУслугиТочкиУчета.Плательщик КАК Плательщик
	               |	ИЗ
	               |		Документ.энргИзменитьПлательщикаУслуги КАК энргИзменитьПлательщикаУслуги
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргИзменитьПлательщикаУслуги.ТочкиУчета КАК энргИзменитьПлательщикаУслугиТочкиУчета
	               |			ПО энргИзменитьПлательщикаУслуги.Ссылка = энргИзменитьПлательщикаУслугиТочкиУчета.Ссылка
	               |				И (энргИзменитьПлательщикаУслуги.Ссылка В (&мДокументы))
	               |				И (энргИзменитьПлательщикаУслугиТочкиУчета.Ссылка В (&мДокументы))) КАК ВложенныйЗапрос
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргИзменитьПлательщикаУслуги.ПлательщикиСоставныхУслуг КАК энргИзменитьПлательщикаУслугиПлательщикиСоставныхУслуг
	               |		ПО ВложенныйЗапрос.Регистратор = энргИзменитьПлательщикаУслугиПлательщикиСоставныхУслуг.Ссылка
	               |			И ВложенныйЗапрос.IDСтроки = энргИзменитьПлательщикаУслугиПлательщикиСоставныхУслуг.IDСтроки";
	
	
	Возврат Запрос.Выполнить(); 
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли