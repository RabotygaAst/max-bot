#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Ответственный 				= Пользователи.ТекущийПользователь();
		
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	
	
	Момент 			= МоментВремени();
	СтрокаОтказа 	= "На дату операции";
	
	
	МКДОткрыт 			= Истина;		
	
	Если НЕ ДополнительныеСвойства.ДанныеСтроения.ЧастныйСектор тогда		
		Строение 		= ДополнительныеСвойства.ДанныеСтроения.Строение;
		МКДОткрыт 		= энргПроверкаДанныхАбонентаСервер.СостояниеМКД(Момент,Район,Строение,Организация);			
	КонецЕсли;
	
	Если не МКДОткрыт тогда
		Отказ			= истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + СтрокаОтказа + " мкд закрыт");
	КонецЕсли;
	
	Если Отказ тогда
		Возврат;
	КонецЕсли;
	
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	
	ДанныеШапки = ДанныеШапки();
	энргРаботаСТочкамиУчетаСервер.УстановитьТУНаСтруктуруСети(ДанныеШапки,Движения,"СтруктураСетиТУ");
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	энргОрганизацииСервер.ОбработкаЗаполнения(ЭтотОбъект, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка);
			
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДанныеШапки()
	ДанныеШапки  = Новый Структура;
	ДанныеШапки.Вставить("Документ", 				Ссылка);
	ДанныеШапки.Вставить("Дата",					Дата);
	ДанныеШапки.Вставить("Район",					Район);
	ДанныеШапки.Вставить("Организация",				Организация); 	
	ДанныеШапки.Вставить("ПериодРегистрации",		Дата);
	ДанныеШапки.Вставить("ПериодНачисления",		ПериодНачисления);
	ДанныеШапки.Вставить("КлючПомещения",			КлючПомещения);	
	ДанныеШапки.Вставить("СтруктураСетиТУ",			ДанныеСтруктураСети());
	

	Возврат ДанныеШапки;	
КонецФункции

Функция ДанныеСтруктураСети()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргИзменитьСтруктуруСетиТочекУчетаТочкиУчета.Ссылка КАК Ссылка,
		|	энргИзменитьСтруктуруСетиТочекУчетаТочкиУчета.НомерСтроки КАК НомерСтроки,
		|	энргИзменитьСтруктуруСетиТочекУчетаТочкиУчета.ТочкаУчета КАК ТочкаУчета,
		|	энргИзменитьСтруктуруСетиТочекУчетаТочкиУчета.Услуга КАК Услуга,
		|	энргИзменитьСтруктуруСетиТочекУчетаТочкиУчета.СтруктураСети КАК СтруктураСети
		|ИЗ
		|	Документ.энргИзменитьСтруктуруСетиТочекУчета.ТочкиУчета КАК энргИзменитьСтруктуруСетиТочекУчетаТочкиУчета
		|ГДЕ
		|	энргИзменитьСтруктуруСетиТочекУчетаТочкиУчета.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли