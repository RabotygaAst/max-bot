#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	Если не ДополнительныеСвойства.Свойство("ПроведениеРазрешено") тогда
		Отказ = истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ создается автоматически из меню ""Выполнение начислений""");
		Возврат;
	КонецЕсли;  
	
	Ответственный 							= Пользователи.ТекущийПользователь();
	
	ДополнительныеСвойства.Вставить("НеРегестрироватьВзаиморасчеты",Истина);
	ДополнительныеСвойства.Вставить("ГруппаАбонентов",Истина);
	ДополнительныеСвойства.Вставить("ПараметрыПроведения",Новый Структура());
	ДополнительныеСвойства.вставить("ДанныеОплаты",ДанныеОплаты());
	энргПроведениеСервер.ПередЗаписьюОбъекта(ЭтотОбъект);
	
	Если не ДополнительныеСвойства.ЭтоНовый и РежимЗаписи = РежимЗаписиДокумента.Проведение тогда
		НаборОтложенныхДвижений  			= РегистрыСведений.энргОтложенныеДвиженияДокументов.СоздатьНаборЗаписей();	
		НаборОтложенныхДвижений.Отбор.Докрегистратор.установить(Ссылка);
		НаборОтложенныхДвижений.Записать();
	КонецЕсли; 	
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)	
	энргПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	ПроведениеОбъемНачислений();
	ДобавитьДанныеСреднего();
	ОтложенныеДвижения();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОтложенныеДвижения()
	
	Набор  							= РегистрыСведений.энргОтложенныеДвиженияДокументов.СоздатьНаборЗаписей();
	
	СтрокаНабора  					= Набор.Добавить();
	СтрокаНабора.ПериодНачисления 	= НачалоМесяца(Дата);
	СтрокаНабора.Район 				= Район;
	СтрокаНабора.Организация 		= Организация;
	СтрокаНабора.РазделЗаписи		= Перечисления.энргРазделыЗаписи.Взаиморасчеты;
	СтрокаНабора.МКД 				= МКД;
	СтрокаНабора.ДатаРегистратора 	= Дата;
	СтрокаНабора.ДокРегистратор 	= Ссылка;
	
	Набор.Записать(Ложь);

КонецПроцедуры

Процедура ПроведениеОбъемНачислений()
	Для Каждого ТекСтрокаТочкаУчета Из ОбъемНачислений Цикл
		Движение 					= Движения.энргОбъемНачислений.Добавить();
		Движение.Период 			= Дата;
		Движение.Район 				= Район;
		Движение.Организация 		= Организация;
		Движение.МКД				= МКД;
		Движение.Абонент			= ТекСтрокаТочкаУчета.Абонент;
		Движение.Услуга				= ТекСтрокаТочкаУчета.Услуга;
		Движение.ТочкаУчета			= ТекСтрокаТочкаУчета.ТочкаУчета;
		Движение.ПриборУчета		= ТекСтрокаТочкаУчета.ПриборУчета;
		Движение.ВидНачисления		= Перечисления.энргВидыНачислений.Начисление;
		Движение.СпособНачисления	= ТекСтрокаТочкаУчета.СпособНачисления;
		Движение.ЗначениеТарифа 	= ТекСтрокаТочкаУчета.ЗначениеТарифа;
		Движение.Сумма 				= ТекСтрокаТочкаУчета.Сумма;
		Движение.ОбъемУслуги 		= ТекСтрокаТочкаУчета.ОбъемУслуги;
		Движение.Поставщик 			= ТекСтрокаТочкаУчета.Поставщик;
		Движение.ПериодНачисления 	= НачалоМесяца(Дата);
		Движение.ПериодРасчета	 	= НачалоМесяца(Дата);
		Движение.НачалоПериода	 	= ТекСтрокаТочкаУчета.НачалоПериода;
		Движение.КонецПериода	 	= ТекСтрокаТочкаУчета.КонецПериода;
		
		Движение 					= Движения.энргВзаиморасчеты.Добавить();
		Движение.Период 			= Дата;
		Движение.Район 				= Район;
		Движение.Организация 		= Организация;
		Движение.МКД				= МКД;
		Движение.Абонент			= ТекСтрокаТочкаУчета.Абонент;
		Движение.Сумма				= ТекСтрокаТочкаУчета.Сумма;
		Движение.ПериодНачисления 	= НачалоМесяца(Дата); 
		
		Если ТекСтрокаТочкаУчета.СписатьИзНормы тогда
			Запись  				= Движения.энргНачисленныйСреднийОбъем.ДобавитьРасход();
			Запись.Период 			= Дата;
			Запись.Район 			= Район;
			Запись.Организация 		= Организация;
			Запись.МКД				= МКД;
			Запись.Абонент			= ТекСтрокаТочкаУчета.Абонент;
			Запись.Сумма			= ТекСтрокаТочкаУчета.Сумма;
			Запись.ПериодНачисления = НачалоМесяца(Дата); 
			Запись.ТочкаУчета 		= ТекСтрокаТочкаУчета.ТочкаУчета; 
			Запись.Услуга 			= ТекСтрокаТочкаУчета.Услуга;
			Запись.ЗначениеТарифа	= ТекСтрокаТочкаУчета.ЗначениеТарифа;
			Запись.ПриборУчета		= ТекСтрокаТочкаУчета.ПриборУчета;
			Запись.Поставщик		= ТекСтрокаТочкаУчета.Поставщик;
			Запись.Сумма 			= -ТекСтрокаТочкаУчета.Сумма;
			Запись.ОбъемУслуги 		= -ТекСтрокаТочкаУчета.ОбъемУслуги;
		КонецЕсли; 				
	КонецЦикла; 	
КонецПроцедуры

Процедура ДобавитьДанныеСреднего()
	
	для Каждого ТекСтрокаТочкаУчета из НачисленияПоСреднему цикл
		Запись  					= Движения.энргНачисленныйСреднийОбъем.ДобавитьПриход();
		Запись.Период 				= Дата;
		Запись.Район 				= Район;
		Запись.Организация 			= Организация;
		Запись.МКД					= МКД;
		Запись.Абонент				= ТекСтрокаТочкаУчета.Абонент;
		Запись.Сумма				= ТекСтрокаТочкаУчета.Сумма;
		Запись.ПериодНачисления 	= НачалоМесяца(Дата); 
		Запись.ТочкаУчета 			= ТекСтрокаТочкаУчета.ТочкаУчета; 
		Запись.Услуга 				= ТекСтрокаТочкаУчета.Услуга;
		Запись.ЗначениеТарифа		= ТекСтрокаТочкаУчета.ЗначениеТарифа;
		Запись.ПриборУчета			= ТекСтрокаТочкаУчета.ПриборУчета;
		Запись.Поставщик			= ТекСтрокаТочкаУчета.Поставщик;
		Запись.ЗависимаяТочкаУчета 	= ТекСтрокаТочкаУчета.ЗависимаяТочкаУчета;
		Запись.ПриборЗависимой	 	= ТекСтрокаТочкаУчета.ПриборЗависимой;
		Запись.Сумма 				= ТекСтрокаТочкаУчета.Сумма;
		Запись.ОбъемУслуги 			= ТекСтрокаТочкаУчета.ОбъемУслуги;
	КонецЦикла;
	
	
КонецПроцедуры

Функция ДанныеОплаты();
	
	Запрос  		= Новый Запрос;
	Запрос.УстановитьПараметр("ОбъемНачислений",	ОбъемНачислений);
	Запрос.УстановитьПараметр("Дата",				Дата);
	Запрос.УстановитьПараметр("ПериодНачисления",	НачалоМесяца(Дата));
	Запрос.УстановитьПараметр("Район",				Район);
	Запрос.УстановитьПараметр("МКД",				МКД);
	Запрос.УстановитьПараметр("Ссылка",				Ссылка);
	Запрос.УстановитьПараметр("Организация",		Организация);
	Запрос.Текст 	= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	&Дата КАК Дата,
	|	&Район КАК Район,
	|	&Организация КАК Организация,
	|	&Ссылка КАК Регистратор,
	|	&МКД КАК МКД,
	|	&ПериодНачисления КАК ПериодНачисления,
	|	ОбъемНачислений.Абонент
	|ПОМЕСТИТЬ Шапка
	|ИЗ
	|	&ОбъемНачислений КАК ОбъемНачислений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Шапка.ПериодНачисления,
	|	Шапка.Район,
	|	Шапка.МКД КАК МКД,
	|	Шапка.Абонент КАК Абонент,
	|	0 КАК СуммаОплаты,
	|	ЛОЖЬ КАК ЭтоОплата,
	|	Шапка.ПериодНачисления КАК ПериодВзаиморасчетов,
	|	КОНЕЦПЕРИОДА(Шапка.ПериодНачисления, МЕСЯЦ) КАК ПериодВзаиморасчетовОкончание,
	|	ЗНАЧЕНИЕ(Справочник.энргВидыУслуг.Пустаяссылка) КАК Услуга,
	|	Шапка.Дата,
	|	Шапка.Регистратор
	|ИЗ
	|	Шапка КАК Шапка";
		
	Результат  = Запрос.Выполнить();
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.';
						|en = 'Invalid object call on the client.'");
#КонецЕсли