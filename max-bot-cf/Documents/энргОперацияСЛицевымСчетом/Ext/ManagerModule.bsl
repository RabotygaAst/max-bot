Процедура ПолучитьДанныеДляПроведенияПоСтабильнымПериодамОткрытиеЛицевогоСчета(Схема,ВыбираемыеТаблицы)
	перем Пакет;
	
	ИмяТаблицы 											= "ДанныеДокументовОткрытиеЛС";
	ВыбираемыеТаблицы.Добавить(ИмяТаблицы);
	
	врСхема 											= Новый СхемаЗапроса;
	врСхема.УстановитьТекстЗапроса(ТекстДляПроведенияПоСтабильнымПериодамОткрытиеЛицевогоСчета());
	
	Пакет 												= врСхема.ПакетЗапросов[врСхема.ПакетЗапросов.Количество() - 1];
	Пакет.ТаблицаДляПомещения 							= ИмяТаблицы;
	
	Для Каждого врПакет Из врСхема.ПакетЗапросов Цикл
		Если Схема = Неопределено Тогда
