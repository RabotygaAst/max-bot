#Область ПриборыУчета

Функция ТекстЗапросаПриборыУчетаДляПередачи()
	
	Текст =
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Ссылка КАК Ссылка,
	|	ВложенныйЗапрос.Дата КАК Дата,
	|	ВложенныйЗапрос.Абонент КАК Абонент,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВЫБОР
	|		КОГДА энргВидыУслуг.СоставнаяУслуга
	|				И НЕ энргВидыУслугСоставляющиеУслуг.Ссылка ЕСТЬ NULL
	|			ТОГДА энргВидыУслугСоставляющиеУслуг.Услуга
	|		ИНАЧЕ ВложенныйЗапрос.Услуга
	|	КОНЕЦ КАК Услуга,
	|	ВложенныйЗапрос.ВидДифференцированности КАК ВидДифференцированности,
	|	ВложенныйЗапрос.ТекущиеПоказания КАК ТекущиеПоказания,
	|	ВложенныйЗапрос.НаименованиеМодели КАК НаименованиеМодели,
	|	ВложенныйЗапрос.НаименованиеМарки КАК НаименованиеМарки,
	|	ВложенныйЗапрос.ЗаводскойНомер КАК ЗаводскойНомер,
	|	ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|	ВложенныйЗапрос.ДатаПоверки КАК ДатаПоверки,
	|	ВложенныйЗапрос.ДатаУстановки КАК ДатаУстановки,
	|	ВложенныйЗапрос.ТипПрибораУчета КАК ТипПрибораУчета
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.Ссылка КАК Ссылка,
	|		ВложенныйЗапрос.Дата КАК Дата,
	|		ВложенныйЗапрос.Абонент КАК Абонент,
	|		ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		ВложенныйЗапрос.Услуга КАК Услуга,
	|		ВложенныйЗапрос.ВидДифференцированности КАК ВидДифференцированности,
	|		табПоказанияПриборовУчета.ТекущиеПоказания КАК ТекущиеПоказания,
	|		ВложенныйЗапрос.НаименованиеМодели КАК НаименованиеМодели,
	|		ВложенныйЗапрос.НаименованиеМарки КАК НаименованиеМарки,
	|		ВложенныйЗапрос.ЗаводскойНомер КАК ЗаводскойНомер,
	|		ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|		ВложенныйЗапрос.ДатаПоверки КАК ДатаПоверки,
	|		ВложенныйЗапрос.ДатаУстановки КАК ДатаУстановки,
	|		ВложенныйЗапрос.ТипПрибораУчета КАК ТипПрибораУчета
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ВложенныйЗапрос.Ссылка КАК Ссылка,
	|			ВложенныйЗапрос.Дата КАК Дата,
	|			ВложенныйЗапрос.Абонент КАК Абонент,
	|			ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|			ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|			ВложенныйЗапрос.Услуга КАК Услуга,
	|			табШкалы.ВидДифференцированности КАК ВидДифференцированности,
	|			табШкалы.IDСтроки КАК IDСтрокиШкалы,
	|			ТипыПриборовУчета.Наименование КАК НаименованиеМодели,
	|			ТипыПриборовУчета.Ссылка КАК ТипПрибораУчета,
	|			ПРЕДСТАВЛЕНИЕ(ТипыПриборовУчета.МаркаПУ) КАК НаименованиеМарки,
	|			ВложенныйЗапрос.ЗаводскойНомер КАК ЗаводскойНомер,
	|			ВложенныйЗапрос.РегистрируетОбъем КАК РегистрируетОбъем,
	|			ДОБАВИТЬКДАТЕ(ВложенныйЗапрос.ДатаСледующейПоверкиСчетчика, МЕСЯЦ, -ТипыПриборовУчета.бестМежповерочныйИнтервал) КАК ДатаПоверки,
	|			ВложенныйЗапрос.ДатаУстановки КАК ДатаУстановки
	|		ИЗ
	|			(ВЫБРАТЬ
	|				Шапка.Ссылка КАК Ссылка,
	|				ВЫБОР
	|					КОГДА Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|						ТОГДА Шапка.Дата
	|					ИНАЧЕ Шапка.ДатаФактическогоСобытия
	|				КОНЕЦ КАК Дата,
	|				Шапка.Абонент КАК Абонент,
	|				Шапка.КлючПомещения КАК КлючПомещения,
	|				табТочкиУчета.ПриборУчета КАК ПриборУчета,
	|				табТочкиУчета.Услуга КАК Услуга,
	|				табТочкиУчета.IDСтроки КАК IDСтроки,
	|				табТочкиУчета.ДатаПоверкиСчетчика КАК ДатаСледующейПоверкиСчетчика,
	|				ВЫБОР
	|					КОГДА Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|						ТОГДА Шапка.Дата
	|					ИНАЧЕ Шапка.ДатаФактическогоСобытия
	|				КОНЕЦ КАК ДатаУстановки,
	|				ПриборыУчетаАбонента.Код КАК ЗаводскойНомер,
	|				ПриборыУчетаАбонента.ТипПрибораУчета КАК МодельПрибораУчета,
	|				ПриборыУчетаАбонента.РегистрируетОбъем КАК РегистрируетОбъем
	|			ИЗ
	|				Документ.энргОперацияСЛицевымСчетом.ТочкиУчета КАК табТочкиУчета
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом КАК Шапка
	|					ПО табТочкиУчета.Ссылка = Шапка.Ссылка
	|						И (Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС))
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК ПриборыУчетаАбонента
	|					ПО табТочкиУчета.ПриборУчета = ПриборыУчетаАбонента.Ссылка
	|			ГДЕ
	|				Шапка.Ссылка В(&мИзменения)
	|				И табТочкиУчета.Ссылка В(&мИзменения)) КАК ВложенныйЗапрос
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом.ШкалыПриборовУчета КАК табШкалы
	|				ПО ВложенныйЗапрос.Ссылка = табШкалы.Ссылка
	|					И ВложенныйЗапрос.IDСтроки = табШкалы.IDСтрокиТочкиУчета
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргТипыПриборовУчета КАК ТипыПриборовУчета
	|				ПО ВложенныйЗапрос.МодельПрибораУчета = ТипыПриборовУчета.Ссылка) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом.ПоказанияПриборовУчета КАК табПоказанияПриборовУчета
	|			ПО ВложенныйЗапрос.Ссылка = табПоказанияПриборовУчета.Ссылка
	|				И ВложенныйЗапрос.IDСтрокиШкалы = табПоказанияПриборовУчета.IDСтроки) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг.СоставляющиеУслуг КАК энргВидыУслугСоставляющиеУслуг
	|		ПО ВложенныйЗапрос.Услуга = энргВидыУслугСоставляющиеУслуг.Ссылка
	|			И (энргВидыУслугСоставляющиеУслуг.НомерСтроки = 1)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО ВложенныйЗапрос.Услуга = энргВидыУслуг.Ссылка";
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаПриборыУчетаДляОбновления()
	
	Текст = 
	"ВЫБРАТЬ
	|	Шапка.Ссылка КАК Ссылка,
	|	Шапка.АбонентСмена КАК Абонент,
	|	табТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	Шапка.КлючПомещения КАК КлючПомещения
	|ИЗ
	|	Документ.энргОперацияСЛицевымСчетом.ТочкиУчета КАК табТочкиУчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом КАК Шапка
	|		ПО табТочкиУчета.Ссылка = Шапка.Ссылка
	|			И (Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_СменаСобственника))
	|			И (НЕ табТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|ГДЕ
	|	Шапка.Ссылка В(&мИзменения)
	|	И табТочкиУчета.Ссылка В(&мИзменения)";
	
	
	Возврат Текст;
	
КонецФункции

Функция ТекстЗапросаПриборыУчетаДляАрхивации()
	
	Текст  =
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Ссылка КАК Ссылка,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|	ВложенныйЗапрос.ПричинаЗаменыПрибораУчета КАК ПричинаЗаменыПрибораУчета
	|ИЗ
	|	(ВЫБРАТЬ
	|		энргОперацияСЛицевымСчетом.Ссылка КАК Ссылка,
	|		энргОперацияСЛицевымСчетом.Организация КАК Организация,
	|		энргОперацияСЛицевымСчетомТочкиУчета.ПриборУчета КАК ПриборУчета,
	|		ЗНАЧЕНИЕ(Справочник.энргПричиныАрхивацииПУ.ПустаяСсылка) КАК ПричинаЗаменыПрибораУчета
	|	ИЗ
	|		Документ.энргОперацияСЛицевымСчетом.ТочкиУчета КАК энргОперацияСЛицевымСчетомТочкиУчета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом КАК энргОперацияСЛицевымСчетом
	|			ПО (энргОперацияСЛицевымСчетом.Ссылка = энргОперацияСЛицевымСчетом.Ссылка)
	|				И (энргОперацияСЛицевымСчетом.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_ЗакрытиеЛС))
	|				И (НЕ энргОперацияСЛицевымСчетомТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
	|	ГДЕ
	|		энргОперацияСЛицевымСчетом.Ссылка В(&мИзменения)
