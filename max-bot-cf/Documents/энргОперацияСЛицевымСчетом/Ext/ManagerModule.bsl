	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ энргОперацияСЛицевымСчетом.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА энргОперацияСЛицевымСчетом.ДатаФактическогоСобытия
	|		ИНАЧЕ энргОперацияСЛицевымСчетом.Дата
	|	КОНЕЦ,
	|	энргОперацияСЛицевымСчетом.АбонентСмена,
	|	энргОперацияСЛицевымСчетом.Договор
	|ИЗ
	|	ШапкаДокумента КАК энргОперацияСЛицевымСчетом
	|ГДЕ
	|	энргОперацияСЛицевымСчетом.Ссылка В(&мДокументы)
	|	И энргОперацияСЛицевымСчетом.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_СменаСобственника)
	|	И энргОперацияСЛицевымСчетом.Договор <> ЗНАЧЕНИЕ(Справочник.энргДоговорыКонтрагентов.ПустаяСсылка)";		
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

