#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияДанныхДокумента

Процедура ИнициализироватьИсходныеДанныеДокумента(Схема)
	ПолучитьШапкуДокумента(Схема);
	ПолучитьТаблицуТочекУчета(Схема);
КонецПроцедуры

Процедура ПолучитьШапкуДокумента(Схема)
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	Шапка.Дата КАК Дата,
	|	Шапка.ДатаФактическогоСобытия КАК ДатаФактическогоСобытия,
	|	Шапка.Организация КАК Организация,
	|	Шапка.ПериодНачисления КАК ПериодНачисления,
	|	Шапка.Район КАК Район,
	|	Шапка.Абонент КАК Абонент,
	|	Шапка.АбонентСмена КАК АбонентСмена,
	|	Шапка.ВидОперации КАК ВидОперации,
	|	Шапка.КлючПомещения КАК КлючПомещения,
	|	Шапка.КоличествоКомнат КАК КоличествоКомнат,
	|	Шапка.КоличествоПроживающих КАК КоличествоПроживающих,
	|	Шапка.КоличествоПрописанных КАК КоличествоПрописанных,
	|	Шапка.КоличествоСобственников КАК КоличествоСобственников,
	|	Шапка.Контроллер КАК Контроллер,
	|	Шапка.МаршрутКонтроллера КАК МаршрутКонтроллера,
	|	Шапка.Ссылка КАК Ссылка,
	|	Шапка.ТипСобственностиЖилья КАК ТипСобственностиЖилья,
	|	Шапка.ТипПлиты КАК ТипПлиты,
	|	Шапка.НомерДоговораСоцНайма КАК НомерДоговораСоцНайма,
	|	Шапка.ДатаДоговораСоцНайма КАК ДатаДоговораСоцНайма,
	|	Шапка.ДолеваяСобственность КАК ДолеваяСобственность,
	|	Шапка.Договор КАК Договор,
	|	Шапка.СпособДоставкиЕПД КАК СпособДоставкиЕПД,
	|	Шапка.ДоговорЗаключенДоТП КАК ДоговорЗаключенДоТП
	|ПОМЕСТИТЬ ШапкаДокумента
	|ИЗ
	|	Документ.энргОперацияСЛицевымСчетом КАК Шапка
	|ГДЕ
	|	Шапка.Ссылка В(&мДокументы)");	
КонецПроцедуры  

Процедура ПолучитьТаблицуТочекУчета(Схема)
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	энргОперацияСЛицевымСчетомТочкиУчета.Ссылка КАК Ссылка,
	|	энргОперацияСЛицевымСчетомТочкиУчета.IDСтроки КАК IDСтроки,
	|	энргОперацияСЛицевымСчетомТочкиУчета.IDСтрокиРодитель КАК IDСтрокиРодитель,
	|	энргОперацияСЛицевымСчетомТочкиУчета.ДатаПоверкиСчетчика КАК ДатаПоверкиСчетчика,
	|	энргОперацияСЛицевымСчетомТочкиУчета.ДатаПриемки КАК ДатаПриемки,
	|	энргОперацияСЛицевымСчетомТочкиУчета.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	|	энргОперацияСЛицевымСчетомТочкиУчета.ДатаУстановкиСчетчика КАК ДатаУстановкиСчетчика,
	|	энргОперацияСЛицевымСчетомТочкиУчета.ДиаметрСечения КАК ДиаметрСечения,
	|	энргОперацияСЛицевымСчетомТочкиУчета.КоэффициентПУ КАК КоэффициентПУ,
	|	энргОперацияСЛицевымСчетомТочкиУчета.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	энргОперацияСЛицевымСчетомТочкиУчета.НетВозможностьУстановкиПУ КАК НетВозможностьУстановкиПУ,
	|	энргОперацияСЛицевымСчетомТочкиУчета.НомерПломбы КАК НомерПломбы,
	|	энргОперацияСЛицевымСчетомТочкиУчета.Поставщик КАК Поставщик,
	|	энргОперацияСЛицевымСчетомТочкиУчета.ПриборУчета КАК ПриборУчета,
	|	энргОперацияСЛицевымСчетомТочкиУчета.РассчитыватьПоДиаметруСечения КАК РассчитыватьПоДиаметруСечения,
	|	энргОперацияСЛицевымСчетомТочкиУчета.СтруктураСети КАК СтруктураСети,
	|	энргОперацияСЛицевымСчетомТочкиУчета.Техническая КАК Техническая,
	|	энргОперацияСЛицевымСчетомТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|	энргОперацияСЛицевымСчетомТочкиУчета.Услуга КАК Услуга,
	|	энргОперацияСЛицевымСчетомТочкиУчета.Энергоназначение КАК Энергоназначение,
	|	энргОперацияСЛицевымСчетомТочкиУчета.ЭтоСоставнаяУслуга КАК ЭтоСоставнаяУслуга,
	|	энргОперацияСЛицевымСчетомТочкиУчета.РасчетТолькоПоПоказаниям КАК РасчетТолькоПоПоказаниям,
	|	энргОперацияСЛицевымСчетомТочкиУчета.Плательщик КАК Плательщик
	|ПОМЕСТИТЬ ТаблицаТочекУчета
	|ИЗ
	|	Документ.энргОперацияСЛицевымСчетом.ТочкиУчета КАК энргОперацияСЛицевымСчетомТочкиУчета
	|ГДЕ
	|	энргОперацияСЛицевымСчетомТочкиУчета.Ссылка В(&мДокументы)");	
КонецПроцедуры

#КонецОбласти

#Область ТекстыЗапроса

Процедура ДобавитьТекстЗапросаАбонентыПомещений(Схема, Регистры)
	
	ИмяРегистра = "энргАбонентыПомещений";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫБОР
	|		КОГДА НЕ Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА Шапка.ДатаФактическогоСобытия
	|		ИНАЧЕ Шапка.Дата
	|	КОНЕЦ КАК Период,
	|	Шапка.Организация КАК Организация,
	|	Шапка.Район КАК Район,
	|	Шапка.КлючПомещения КАК КлючПомещения,
	|	табТочкиУчета.Услуга КАК Услуга,
	|	ВЫБОР
	|		КОГДА Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_Сменасобственника)
	|			ТОГДА Шапка.АбонентСмена
	|		ИНАЧЕ Шапка.Абонент
	|	КОНЕЦ КАК Абонент,
	|	Шапка.Дата КАК ПериодРегистрации,
	|	НАЧАЛОПЕРИОДА(Шапка.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления
	|ИЗ
	|	ШапкаДокумента КАК Шапка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК табТочкиУчета
	|		ПО Шапка.Ссылка = табТочкиУчета.Ссылка
	|ГДЕ
	|	Шапка.Ссылка В(&мДокументы)
	|	И (Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС)
	|			ИЛИ Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_СменаСобственника))";		
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

