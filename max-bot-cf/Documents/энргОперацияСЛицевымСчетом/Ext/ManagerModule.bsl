	|				И ВложенныйЗапрос.IDСтрокиТочкиУчета = энргОперацияСЛицевымСчетомШкалыПриборовУчета.IDСтрокиТочкиУчета) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом.ПоказанияПриборовУчета КАК энргОперацияСЛицевымСчетомПоказанияПриборовУчета
	|		ПО ВложенныйЗапрос.Регистратор = энргОперацияСЛицевымСчетомПоказанияПриборовУчета.Ссылка
	|			И ВложенныйЗапрос.IDСтроки = энргОперацияСЛицевымСчетомПоказанияПриборовУчета.IDСтроки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ВложенныйЗапрос.ПриборУчета = энргПриборыУчетаАбонента.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Период,
	|	ВложенныйЗапрос.Организация,
	|	ВложенныйЗапрос.Район,
	|	ВложенныйЗапрос.КлючПомещения,
	|	ВложенныйЗапрос.ПриборУчета,
	|	ВложенныйЗапрос.Шкала,
	|	энргОперацияСЛицевымСчетомПоказанияПриборовУчета.ТарифнаяЗона,
	|	0,
	|	ВЫБОР
	|		КОГДА энргПриборыУчетаАбонента.РегистрируетОбъем
	|			ТОГДА энргОперацияСЛицевымСчетомПоказанияПриборовУчета.Разница
	|		ИНАЧЕ энргОперацияСЛицевымСчетомПоказанияПриборовУчета.ТекущиеПоказания
	|	КОНЕЦ,
	|	энргОперацияСЛицевымСчетомПоказанияПриборовУчета.СостояниеПоказаний,
	|	энргОперацияСЛицевымСчетомПоказанияПриборовУчета.ПричинаОтклонения,
	|	ЛОЖЬ,
	|	ЗНАЧЕНИЕ(Справочник.энргИсточникиПоказаний.ПустаяСсылка),
	|	ЛОЖЬ,
	|	ВложенныйЗапрос.ПериодНачисления,
	|	ВложенныйЗапрос.ПериодРегистрации,
	|	энргОперацияСЛицевымСчетомПоказанияПриборовУчета.НомерСтроки,
	|	ВложенныйЗапрос.ТочкаУчета
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.Период КАК Период,
	|		ВложенныйЗапрос.Организация КАК Организация,
	|		ВложенныйЗапрос.Район КАК Район,
	|		ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|		ВложенныйЗапрос.ТочкаУчета КАК ТочкаУчета,
	|		ВложенныйЗапрос.ПриборУчета КАК ПриборУчета,
	|		ВложенныйЗапрос.Состояние КАК Состояние,
	|		ВложенныйЗапрос.ПериодРегистрации КАК ПериодРегистрации,
	|		ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|		ВложенныйЗапрос.IDСтрокиТочкиУчета КАК IDСтрокиТочкиУчета,
	|		ВложенныйЗапрос.Регистратор КАК Регистратор,
	|		энргОперацияСЛицевымСчетомШкалыПриборовУчета.IDСтроки КАК IDСтроки,
	|		энргОперацияСЛицевымСчетомШкалыПриборовУчета.Шкала КАК Шкала
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ВЫБОР
	|				КОГДА НЕ энргОперацияСЛицевымСчетом.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА КОНЕЦПЕРИОДА(энргОперацияСЛицевымСчетом.ДатаФактическогоСобытия, ДЕНЬ)
	|				ИНАЧЕ энргОперацияСЛицевымСчетом.Дата
	|			КОНЕЦ КАК Период,
	|			энргОперацияСЛицевымСчетом.Организация КАК Организация,
	|			энргОперацияСЛицевымСчетом.Район КАК Район,
	|			энргОперацияСЛицевымСчетом.КлючПомещения КАК КлючПомещения,
	|			энргОперацияСЛицевымСчетомТочкиУчета.ТочкаУчета КАК ТочкаУчета,
	|			энргОперацияСЛицевымСчетомТочкиУчета.ПриборУчета КАК ПриборУчета,
	|			ЗНАЧЕНИЕ(Перечисление.энргСостояниеПриборовУчета.Ввод) КАК Состояние,
	|			энргОперацияСЛицевымСчетом.Дата КАК ПериодРегистрации,
	|			НАЧАЛОПЕРИОДА(энргОперацияСЛицевымСчетом.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления,
	|			энргОперацияСЛицевымСчетомТочкиУчета.IDСтроки КАК IDСтрокиТочкиУчета,
	|			энргОперацияСЛицевымСчетом.Ссылка КАК Регистратор
	|		ИЗ
	|			ШапкаДокумента КАК энргОперацияСЛицевымСчетом
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК энргОперацияСЛицевымСчетомТочкиУчета
	|				ПО энргОперацияСЛицевымСчетом.Ссылка = энргОперацияСЛицевымСчетомТочкиУчета.Ссылка
	|					И (энргОперацияСЛицевымСчетом.Ссылка В (&мДокументы))
	|					И (энргОперацияСЛицевымСчетомТочкиУчета.Ссылка В (&мДокументы))
	|					И (энргОперацияСЛицевымСчетом.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_СменаСобственника))
	|					И (НЕ энргОперацияСЛицевымСчетомТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))) КАК ВложенныйЗапрос
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом.ШкалыПриборовУчета КАК энргОперацияСЛицевымСчетомШкалыПриборовУчета
	|			ПО ВложенныйЗапрос.Регистратор = энргОперацияСЛицевымСчетомШкалыПриборовУчета.Ссылка
	|				И ВложенныйЗапрос.IDСтрокиТочкиУчета = энргОперацияСЛицевымСчетомШкалыПриборовУчета.IDСтрокиТочкиУчета) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОперацияСЛицевымСчетом.ПоказанияПриборовУчета КАК энргОперацияСЛицевымСчетомПоказанияПриборовУчета
	|		ПО ВложенныйЗапрос.Регистратор = энргОперацияСЛицевымСчетомПоказанияПриборовУчета.Ссылка
	|			И ВложенныйЗапрос.IDСтроки = энргОперацияСЛицевымСчетомПоказанияПриборовУчета.IDСтроки
	|			И (энргОперацияСЛицевымСчетомПоказанияПриборовУчета.ПоказанияПредоставлены)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргПриборыУчетаАбонента КАК энргПриборыУчетаАбонента
	|		ПО ВложенныйЗапрос.ПриборУчета = энргПриборыУчетаАбонента.Ссылка"; 	
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаРодителейТочекУчета(Схема, Регистры)
	
	ИмяРегистра = "энргРодительТочкиУчета";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ энргОперацияСЛицевымСчетом.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА энргОперацияСЛицевымСчетом.ДатаФактическогоСобытия
	|		ИНАЧЕ энргОперацияСЛицевымСчетом.Дата
	|	КОНЕЦ КАК Период,
	|	энргОперацияСЛицевымСчетом.Организация КАК Организация,
	|	энргОперацияСЛицевымСчетом.Район КАК Район,
	|	энргОперацияСЛицевымСчетом.КлючПомещения КАК КлючПомещения,
	|	энргОперацияСЛицевымСчетом.Дата КАК ПериодРегистрации,
	|	НАЧАЛОПЕРИОДА(энргОперацияСЛицевымСчетом.ПериодНачисления, МЕСЯЦ) КАК ПериодНачисления,
	|	ТаблицаТочекУчета.ТочкаУчета КАК ТочкаУчета,
	|	ЕСТЬNULL(ТаблицаРодителейТочекУчета.ТочкаУчета, ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка)) КАК РодительТочкиУчета
	|ИЗ
	|	ШапкаДокумента КАК энргОперацияСЛицевымСчетом
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК ТаблицаТочекУчета
	|			ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаТочекУчета КАК ТаблицаРодителейТочекУчета
	|			ПО ТаблицаТочекУчета.Ссылка = ТаблицаРодителейТочекУчета.Ссылка
	|				И (ТаблицаРодителейТочекУчета.Ссылка В (&мДокументы))
	|				И ТаблицаТочекУчета.IDСтрокиРодитель = ТаблицаРодителейТочекУчета.IDСтроки
	|		ПО энргОперацияСЛицевымСчетом.Ссылка = ТаблицаТочекУчета.Ссылка
	|			И (энргОперацияСЛицевымСчетом.Ссылка В (&мДокументы))
	|			И (ТаблицаТочекУчета.Ссылка В (&мДокументы))
	|			И (НЕ ТаблицаТочекУчета.ТочкаУчета = ЗНАЧЕНИЕ(Справочник.энргТочкиУчета.ПустаяСсылка))
	|ГДЕ
	|	энргОперацияСЛицевымСчетом.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС)";		
	
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаДоговорыАбонентов(Схема, Регистры)
	
	ИмяРегистра = "энргДоговорыАбонентов";
	
