// Получает льготу контрагента.
//
// Параметры:
//  Контрагент	-	СправочникСсылка.энргКонтрагенты.
//  Организация	-	СправочникСсылка.Организации.
//  Район		-	СправочникСсылка.энргЗоныОтвественности.
//  Период		-	Дата.
// 
// Возвращаемое значение:
//   СправочникСсылка.энргЛьготныеКатегории.
//
Функция ПолучитьЛьготуКонтрагента(Контрагент, Организация, Район, Период) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестЖильцыЛьготныхКатегорийСрезПоследних.ЛьготнаяКатегория КАК ЛьготнаяКатегория
	|ИЗ
	|	РегистрСведений.энргЖильцыЛьготныхКатегорий.СрезПоследних(
	|			&Период,
	|			Жилец = &Жилец
	|				И Организация = &Организация
	|				И Район = &Район) КАК бестЖильцыЛьготныхКатегорийСрезПоследних";
	
	Запрос.УстановитьПараметр("Жилец", Контрагент);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат  ВыборкаДетальныеЗаписи.ЛьготнаяКатегория;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

// Получает процент льготы.
//
// Параметры:
//  ЛьготнаяКатегория	-	СправочникСсылка.энргЛьготныеКатегории.
//  Организация			-	СправочникСсылка.Организации.
//  Район				-	СправочникСсылка.энргЗоныОтвественности.
//  Период				-	Дата.
// 
// Возвращаемое значение:
//   Число.
//
Функция ПолучитьПроцентЛьготы(ЛьготнаяКатегория, Организация, Район, Период) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бестЗначенияЛьготныхКатегорийСрезПоследних.ПроцентОтНачислений КАК ПроцентОтНачислений
	|ИЗ
	|	РегистрСведений.энргЗначенияЛьготныхКатегорий.СрезПоследних(
	|			&Период,
	|			Организация = &Организация
	|				И Район = &Район
	|				И ЛьготнаяКатегория = &ЛьготнаяКатегория) КАК бестЗначенияЛьготныхКатегорийСрезПоследних";
	
	Запрос.УстановитьПараметр("ЛьготнаяКатегория", ЛьготнаяКатегория);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Район", Район);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат  ВыборкаДетальныеЗаписи.ПроцентОтНачислений;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

