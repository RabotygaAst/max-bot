// Получает документ открытия лицевого счета с договором до ТП.
//
// Параметры:
//  Абонент	-	СправочникСсылка.энргАбоненты.
// 
// Возвращаемое значение:
//   ДокументСсылка.энргОперацияСЛицевымСчетом.
//
Функция ДокументОткрытияЛицевогоСчетаСДоговоромДоТП(Абонент) Экспорт 
	
	Результат = ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	энргОперацияСЛицевымСчетом.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.энргОперацияСЛицевымСчетом КАК энргОперацияСЛицевымСчетом
		|ГДЕ
		|	энргОперацияСЛицевымСчетом.Проведен
		|	И энргОперацияСЛицевымСчетом.ДоговорЗаключенДоТП
		|	И энргОперацияСЛицевымСчетом.Абонент = &Абонент";
	
	Запрос.УстановитьПараметр("Абонент", Абонент);
	
	РезультатЗапроса = Запрос.Выполнить(); 	
	Если РезультатЗапроса.Пустой() Тогда
		Результат  = Документы.энргВводНачальныхОстатков.ПолучениеДанныхЛицевогоСчетаСДоговоромДоТП(Абонент);
		Возврат Результат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Результат = Выборка.Ссылка;
	
	Возврат Результат;
	
КонецФункции 

