#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет список команд отчетов.
// 
// Параметры:
//   КомандыОтчетов - ТаблицаЗначений - состав полей см. в функции МенюОтчеты.СоздатьКоллекциюКомандОтчетов.
//   Параметры		- Структура передаваемых параметров.
//
Процедура ДобавитьКомандыОтчетов(КомандыОтчетов, Параметры= Неопределено) Экспорт
	
	энргВариантыОтчетовПереопределяемый.ДобавитьКомандуСтруктураПодчиненности(КомандыОтчетов);
	
КонецПроцедуры

// Заполняет список команд создания на основании.
// 
// Параметры:
//   КомандыСоздатьНаОсновании - состав команд.
// Возвращаемое значение:
//	 ТаблицаЗначений
//
Функция ДобавитьКомандыСозданияНаОсновании(КомандыСоздатьНаОсновании) Экспорт
	
	Возврат Документы.энргПерерасчет.ДобавитьКомандуСоздатьНаОснованииОперацииСЛС(КомандыСоздатьНаОсновании);
	
	Возврат Документы.энргОперацияСЛицевымСчетом.ДобавитьКомандуСоздатьНаОснованииЗакрытияЛС(КомандыСоздатьНаОсновании);
	
КонецФункции

// Заполняет список команд создания на основании закрытие ЛС.
// 
// Параметры:
//   КомандыСоздатьНаОсновании - состав команд.
// Возвращаемое значение:
//	 СтрокаТаблицыЗначений
//
Функция ДобавитьКомандуСоздатьНаОснованииЗакрытияЛС(КомандыСоздатьНаОсновании) Экспорт
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.энргОперацияСЛицевымСчетом) Тогда
		КомандаСоздатьНаОсновании 					= КомандыСоздатьНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Обработчик 		= "ВводНаОснованииБиллингКлиент.ОткрытиеЛицевогоСчетаНаОснованииЗакрытияЛС";
		КомандаСоздатьНаОсновании.Идентификатор 	= "ОткрытиеЛицевогоСчетаНаОснованииЗакрытияЛС";
		КомандаСоздатьНаОсновании.Представление 	= НСтр("ru = 'Открытие лс'");
		КомандаСоздатьНаОсновании.ПроверкаПроведенияПередСозданиемНаОсновании = Истина;
		
		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

// Заполняет список команд создания на основании договора контрагента.
// 
// Параметры:
//   КомандыСоздатьНаОсновании - состав команд.
// Возвращаемое значение:
//	 СтрокаТаблицыЗначений
//
Функция ДобавитьКомандуСоздатьНаОснованииДоговораКонтрагента(КомандыСоздатьНаОсновании) Экспорт
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.энргОперацияСЛицевымСчетом) Тогда
		КомандаСоздатьНаОсновании 					= КомандыСоздатьНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Обработчик 		= "бестВводНаОснованииКлиент.ОткрытиеЛицевогоСчетаНаОснованииДоговораКонтрагента";
		КомандаСоздатьНаОсновании.Идентификатор 	= "ОткрытиеЛицевогоСчетаНаОснованииДоговораКонтрагента";
		КомандаСоздатьНаОсновании.Представление 	= НСтр("ru = 'Открытие лс'");
		КомандаСоздатьНаОсновании.ПроверкаПроведенияПередСозданиемНаОсновании = Истина;
		
		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Заполняет список команд создания открытия ЛС на основании.
// 
// Параметры:
//   КомандыСоздатьНаОсновании - состав команд.
// Возвращаемое значение:
//	 ТаблицаЗначений
//
Функция ДобавитьКомандыСозданияОткрытияЛицевогоСчетаНаОсновании(КомандыСоздатьНаОсновании) Экспорт
	
	Возврат Документы.энргПерерасчет.ДобавитьКомандуСоздатьНаОснованииОперацииСЛС(КомандыСоздатьНаОсновании);
	
КонецФункции

// Заполняет ключи помещения и строения.
//
// Параметры:
//	 Ссылка - энргОперацияСЛицевымСчетом.Ссылка
//
// Возвращаемое значение:
//	 Массив
Функция ПроверкаИзмененийДанныхДокумента (Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргОперацияСЛицевымСчетом.КлючПомещения.Строение КАК КлючПомещенияСтроение,
	|	энргОперацияСЛицевымСчетом.КлючПомещения.Помещение КАК КлючПомещенияПомещение
	|ИЗ
	|	Документ.энргОперацияСЛицевымСчетом КАК энргОперацияСЛицевымСчетом
	|ГДЕ
	|	энргОперацияСЛицевымСчетом.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Результат = Запрос.Выполнить();
	Возврат Результат;
	
КонецФункции

#Область РеализацияИнтерфейса_СозданиеНаОсновании

// Получает данные заполнения на основании операции с лицевым счетом.
//
// Параметры:
//  ДокументСсылка	-	ДокументСсылка.энргОперацияСЛицевымСчетом.
// 
// Возвращаемое значение:
//   Структура.
//
Функция ДанныеЗполненияНаОснованииОперацииСЛицевымСчетом(ДокументСсылка) Экспорт 
	
	Текст 						= 
	"ВЫБРАТЬ
	|	энргОперацияСЛицевымСчетом.Организация КАК Организация,
	|	энргОперацияСЛицевымСчетом.Район КАК Район,
	|	энргОперацияСЛицевымСчетом.КлючПомещения КАК КлючПомещения
	|ПОМЕСТИТЬ ДанныеШапки
	|ИЗ
	|	Документ.энргОперацияСЛицевымСчетом КАК энргОперацияСЛицевымСчетом
	|ГДЕ
	|	энргОперацияСЛицевымСчетом.Ссылка = &ДокументСсылка";
	
	Схема  						= Новый СхемаЗапроса;
	Пакет 						= Схема.ПакетЗапросов[0];
	Пакет.УстановитьТекстЗапроса(Текст);
	
	ПараметрыКлючиПомещений		= Новый Структура;
	ПараметрыКлючиПомещений.Вставить("Отбор", Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраВременнаяТаблица", Новый Структура("КлючПомещения","КлючПомещения"), "ДанныеШапки"));
	РегистрыСведений.энргКлючиПомещений.ДанныеПомещения(Схема,ПараметрыКлючиПомещений,"ДанныеПомещения");
	
	ПараметрыПомещения 			= Новый Структура;
	ПараметрыПомещения.Вставить("ПараметрыВТ", Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраВременнаяТаблица", Новый Структура("Организация,Район,КлючПомещения","Организация","Район","КлючПомещения"), "ДанныеШапки"));
	
	РегистрыСведений.энргКоличествоКомнат.ТекстСрезПоследних(Схема,			ПараметрыПомещения,	"КоличествоКомнатПомещения");
	РегистрыСведений.энргКоличествоПроживающих.КоличествоПроживающихПомещения(Схема,	ПараметрыПомещения,	"КоличествоПроживающихПомещения");
	РегистрыСведений.энргКоличествоПрописанных.КоличествоПрописанныхПомещения(Схема,	ПараметрыПомещения,	"КоличествоПрописанныхПомещения");
	РегистрыСведений.энргКоличествоСобственников.КоличествоСобственниковПомещения(Схема,	ПараметрыПомещения,	"КоличествоСобственниковПомещения");
	РегистрыСведений.энргТипСобственностиАбонентов.ТекстСрезПоследних(Схема,ПараметрыПомещения,	"ТипСобственностиПомещения");
	
	ПараметрыВТМКД 				= Новый Массив;
	ПараметрыВТМКД.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраВременнаяТаблица", Новый Структура("Организация,Район","Организация","Район"), "ДанныеШапки"));
	ПараметрыВТМКД.Добавить(Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраВременнаяТаблица", Новый Структура("МКД","МКД"), "ДанныеПомещения"));
	ПараметрыМКД 				= Новый Структура;
	ПараметрыМКД.Вставить("ПараметрыВТ", ПараметрыВТМКД);
	РегистрыСведений.бестРабочиеПостановленияМКД.ТекстСрезПоследних(Схема,	ПараметрыМКД,	"РабочиеПостановленияМКД");
	
	ПараметрыМаршрутПомещения 	= Новый Структура;
	ПараметрыМаршрутПомещения.Вставить("Отбор", Новый Структура("ТипПараметра, СоотвествиеПолей, ТаблицаИсточник", "ТипПараметраВременнаяТаблица", Новый Структура("КлючПомещения","КлючПомещения"), "ДанныеШапки"));
	Справочники.энргМаршрутыКонтроллеров.ТекстМаршрутПоКлючуПомещения(Схема, ПараметрыМаршрутПомещения, "МаршрутКонтроллера");
	
	ПакетСвойстваПомещения		= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	ПакетСвойстваПомещения.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.КлючПомещения КАК КлючПомещения,
	|	МАКСИМУМ(ВложенныйЗапрос.КоличествоКомнат) КАК КоличествоКомнат,
	|	МАКСИМУМ(ВложенныйЗапрос.КоличествоПроживающих) КАК КоличествоПроживающих,
	|	МАКСИМУМ(ВложенныйЗапрос.КоличествоПрописанных) КАК КоличествоПрописанных,
	|	МАКСИМУМ(ВложенныйЗапрос.КоличествоСобственников) КАК КоличествоСобственников,
	|	МАКСИМУМ(ВложенныйЗапрос.ТипСобственностиЖилья) КАК ТипСобственностиЖилья,
	|	МАКСИМУМ(ВложенныйЗапрос.НомерДоговораСоцНайма) КАК НомерДоговораСоцНайма,
	|	МАКСИМУМ(ВложенныйЗапрос.ДатаДоговораСоцНайма) КАК ДатаДоговораСоцНайм
	|ПОМЕСТИТЬ СвойстваПомещения
	|ИЗ
	|	(ВЫБРАТЬ
	|		КоличествоКомнатПомещения.Организация КАК Организация,
	|		КоличествоКомнатПомещения.Район КАК Район,
	|		КоличествоКомнатПомещения.КлючПомещения КАК КлючПомещения,
	|		КоличествоКомнатПомещения.Количество КАК КоличествоКомнат,
	|		0 КАК КоличествоПроживающих,
	|		0 КАК КоличествоПрописанных,
	|		0 КАК КоличествоСобственников,
	|		ЗНАЧЕНИЕ(Перечисление.энргТипыСобственниковЖилья.ПустаяСсылка) КАК ТипСобственностиЖилья,
	|		"""" КАК НомерДоговораСоцНайма,
	|		ДАТАВРЕМЯ(1, 1, 1) КАК ДатаДоговораСоцНайма
	|	ИЗ
	|		КоличествоКомнатПомещения КАК КоличествоКомнатПомещения
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КоличествоПроживающихПомещения.Организация,
	|		КоличествоПроживающихПомещения.Район,
	|		КоличествоПроживающихПомещения.КлючПомещения,
	|		0,
	|		КоличествоПроживающихПомещения.Количество,
	|		0,
	|		0,
	|		ЗНАЧЕНИЕ(Перечисление.энргТипыСобственниковЖилья.ПустаяСсылка),
	|		"""",
	|		ДАТАВРЕМЯ(1, 1, 1)
	|	ИЗ
	|		КоличествоПроживающихПомещения КАК КоличествоПроживающихПомещения
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КоличествоПрописанныхПомещения.Организация,
	|		КоличествоПрописанныхПомещения.Район,
	|		КоличествоПрописанныхПомещения.КлючПомещения,
	|		0,
	|		0,
	|		КоличествоПрописанныхПомещения.Количество,
	|		0,
	|		ЗНАЧЕНИЕ(Перечисление.энргТипыСобственниковЖилья.ПустаяСсылка),
	|		"""",
	|		ДАТАВРЕМЯ(1, 1, 1)
	|	ИЗ
	|		КоличествоПрописанныхПомещения КАК КоличествоПрописанныхПомещения
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КоличествоСобственниковПомещения.Организация,
	|		КоличествоСобственниковПомещения.Район,
	|		КоличествоСобственниковПомещения.КлючПомещения,
	|		0,
	|		0,
	|		0,
	|		КоличествоСобственниковПомещения.Количество,
	|		ЗНАЧЕНИЕ(Перечисление.энргТипыСобственниковЖилья.ПустаяСсылка),
	|		"""",
	|		ДАТАВРЕМЯ(1, 1, 1)
	|	ИЗ
	|		КоличествоСобственниковПомещения КАК КоличествоСобственниковПомещения
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РабочиеПостановленияМКД.Организация,
	|		РабочиеПостановленияМКД.Район,
	|		ДанныеПомещения.КлючПомещения,
	|		0,
	|		0,
	|		0,
	|		0,
	|		ЗНАЧЕНИЕ(Перечисление.энргТипыСобственниковЖилья.ПустаяСсылка),
	|		"""",
	|		ДАТАВРЕМЯ(1, 1, 1)
	|	ИЗ
	|		РабочиеПостановленияМКД КАК РабочиеПостановленияМКД
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеПомещения КАК ДанныеПомещения
	|			ПО РабочиеПостановленияМКД.МКД = ДанныеПомещения.МКД
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ТипСобственностиПомещения.Организация,
	|		ТипСобственностиПомещения.Район,
	|		ТипСобственностиПомещения.КлючПомещения,
	|		0,
	|		0,
	|		0,
	|		0,
	|		ТипСобственностиПомещения.ТипСобственности,
	|		ТипСобственностиПомещения.НомерДоговораСоцНайма,
	|		ТипСобственностиПомещения.ДатаДоговораСоцНайма
	|	ИЗ
	|		ТипСобственностиПомещения КАК ТипСобственностиПомещения) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Организация,
	|	ВложенныйЗапрос.Район,
	|	ВложенныйЗапрос.КлючПомещения");  			
	
	ПакетРезультирующий 		= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	ПакетРезультирующий.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеШапки.Организация КАК Организация,
	|	ДанныеШапки.Район КАК Район,
	|	ДанныеШапки.КлючПомещения КАК КлючПомещения,
	|	ДанныеПомещения.ЧастныйСектор КАК ЧастныйСектор,
	|	ДанныеПомещения.Строение КАК Строение,
	|	ДанныеПомещения.Помещение КАК Помещение,
	|	СвойстваПомещения.КоличествоКомнат КАК КоличествоКомнат,
	|	СвойстваПомещения.КоличествоПроживающих КАК КоличествоПроживающих,
	|	СвойстваПомещения.КоличествоПрописанных КАК КоличествоПрописанных,
	|	СвойстваПомещения.КоличествоСобственников КАК КоличествоСобственников,
	|	СвойстваПомещения.ТипСобственностиЖилья КАК ТипСобственностиЖилья,
	|	СвойстваПомещения.ВидОбъекта КАК ВидОбъекта,
	|	СвойстваПомещения.НомерДоговораСоцНайма КАК НомерДоговораСоцНайма,
	|	СвойстваПомещения.ДатаДоговораСоцНайма КАК ДатаДоговораСоцНайма,
	|	МаршрутКонтроллера.Контроллер КАК Контроллер,
	|	МаршрутКонтроллера.МаршрутКонтроллера КАК МаршрутКонтроллера
	|ИЗ
	|	ДанныеШапки КАК ДанныеШапки
	|		ЛЕВОЕ СОЕДИНЕНИЕ СвойстваПомещения КАК СвойстваПомещения
	|		ПО ДанныеШапки.Организация = СвойстваПомещения.Организация
	|			И ДанныеШапки.Район = СвойстваПомещения.Район
	|			И ДанныеШапки.КлючПомещения = СвойстваПомещения.КлючПомещения
	|		ЛЕВОЕ СОЕДИНЕНИЕ МаршрутКонтроллера КАК МаршрутКонтроллера
	|		ПО ДанныеШапки.КлючПомещения = МаршрутКонтроллера.КлючПомещения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеПомещения КАК ДанныеПомещения
	|		ПО ДанныеШапки.КлючПомещения = ДанныеПомещения.КлючПомещения");
	
	ДанныеЗаполнения 		= Новый Структура;
	Запрос 					= Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Результат		 		= Запрос.Выполнить();	
	Если Результат.Пустой() Тогда
		Возврат ДанныеЗаполнения;
	КонецЕсли;
	
	Выборка 				= Результат.Выбрать();
	Выборка.Следующий();
	
	Для Каждого КолонкаРезультат Из Результат.Колонки Цикл
		ДанныеЗаполнения.Вставить(КолонкаРезультат.Имя, Выборка[КолонкаРезультат.Имя]);
	КонецЦикла;
	
	Возврат ДанныеЗаполнения;
	
КонецФункции

#КонецОбласти

