Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	Поля.добавить("Номер");
	Поля.добавить("Дата");
	Поля.добавить("ВидОперации");
	СтандартнаяОбработка = Ложь; 	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	Представление 			="" + Данные.ВидОперации + " №" + Данные.номер + " от " +  Данные.дата;
	СтандартнаяОбработка 	= Ложь;
КонецПроцедуры

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	ЕстьЗначенияЗаполнения  	= Параметры.свойство("ЗначенияЗаполнения");
	
	ВидОперацииВыбран  			= Ложь;
	
	Если ЕстьЗначенияЗАполнения тогда
		ВидОперацииВыбран 		= Параметры.ЗначенияЗаполнения.свойство("видоперации");
	КонецЕсли;
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка 	= Ложь;
		Основание				= Неопределено;
		Если Параметры.свойство("Ключ") тогда
			ВидОперации 		= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.ключ, "ВидОперации");//Параметры.ключ.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОперацияСЛицевымСчетом",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		ИначеЕсли  Параметры.свойство("ЗначениеКопирования") тогда
			ВидОперации 		= Параметры.ЗначениеКопирования.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОперацияСЛицевымСчетом",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы; 			
		ИначеЕсли  ЕстьЗначенияЗАполнения и ВидОперацииВыбран тогда
			ВидОперации 		= Параметры.ЗначенияЗаполнения.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОперацияСЛицевымСчетом",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;			
		ИначеЕсли  Параметры.свойство("Основание", Основание) И ТипЗнч(Основание) = Тип("СправочникСсылка.энргДоговорыКонтрагентов") Тогда
			ВидОперации 		= Перечисления.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОперацияСЛицевымСчетом",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		иначе
			ВыбраннаяФорма 		= "ОбщаяФорма.энргФормаВыбораОперации";
			Параметры.вставить("ИмяДокумента","энргОперацияСЛицевымСчетом");
			Параметры.вставить("ВыборОперации",Истина);
		КонецЕсли; 		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Инициализирует данные документа.
//
// Параметры:
//  ДокументСсылка			-	ДокументСсылка.энргОперацияСЛицевымСчетом.
//  ДополнительныеСвойства	-	Структура.
//  Регистры				-	Произвольный.
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт
	
	ПараметрыЗапроса  			= Новый Структура;
	Схема 						= Неопределено;
	ИнициализироватьИсходныеДанныеДокумента(Схема);
	
	ДобавитьТекстЗапросаАбонентыПомещений(Схема, Регистры);
	ДобавитьТекстЗапросаСостояниеЛС(Схема, Регистры);
	ДобавитьТекстЗапросаЗакрытиеЛС(Схема, Регистры);
	ДобавитьТекстЗапросаКоличествоПроживающих(Схема, Регистры);
	ДобавитьТекстЗапросаКоличествоПрописанных(Схема, Регистры);
	ДобавитьТекстЗапросаКоличествоСобственников(Схема, Регистры);
	ДобавитьТекстЗапросаКоличествоКомнат(Схема, Регистры);
	ДобавитьТекстЗапросаСобственникиПомещений(Схема, Регистры);
	ДобавитьТекстЗапросаТипСобственностиАбонентов(Схема, Регистры);
	
	ДобавитьТекстЗапросаПроживаниеЖильцов(Схема, Регистры);
	
	ДобавитьТекстЗапросаЗначенияПлощадей(Схема, Регистры);
	ДобавитьТекстЗапросаВидБлагоустройствАбонента(Схема, Регистры);
	ДобавитьТекстЗапросаГруппыПотребителейАбонентов(Схема, Регистры);
	
	ДобавитьТекстЗапросаВладельцыТочекУчета(Схема, Регистры);
	ДобавитьТекстЗапросаРодителейТочекУчета(Схема, Регистры);
	ДобавитьТекстЗапросаАктивностьТочекУчета(Схема, Регистры);
	ДобавитьТекстЗапросаУслугиТочекУчета(Схема, Регистры);
	ДобавитьТекстЗапросаПриборыТочекУчета(Схема, Регистры);
	ДобавитьТекстЗапросаТехническаяВозможностьУстановкиПУ(Схема, Регистры);
