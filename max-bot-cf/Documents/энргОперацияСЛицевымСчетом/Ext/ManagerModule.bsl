// Получает изменяемые параметры расчета.
// 
// Возвращаемое значение:
//   Соответсвие.
//
Функция ИзменяемыеПараметрыРасчета() Экспорт 
	
	ИзменяемыеПараметрыРасчета = Новый Соответствие; 
	
	ИзменяемыеПараметры = Новый Массив;
	ИзменяемыеПараметры.Добавить("*");
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСЛС_ОткрытиеЛС, ИзменяемыеПараметры);
	
	ИзменяемыеПараметры = Новый Массив;
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета,Услуга","ЛСОткрыт,УслугаПодключена,ДатаСостоянияЛицевогоСчета,Плательщик"));
	ИзменяемыеПараметры.Добавить(Новый Структура("Ключи,Ресурсы","ТочкаУчета,Услуга","Абонент,ЛСОткрыт,УслугаПодключена,ДатаСостоянияПрибора,КоличествоПроживающих,КоличествоПрописанных,КоличествоСобственников,ДатаСостоянияЛицевогоСчета,Плательщик, ДопСоциальнаяНормаПотребления"));
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСЛС_СменаСобственника, ИзменяемыеПараметры);
	
	ИзменяемыеПараметры = Новый Массив; 
	ИзменяемыеПараметры.Добавить(Новый Структура("Ресурсы","ЛСОткрыт,УслугаПодключена,ПриборВведен,ДатаСостоянияЛицевогоСчета,ПериодНачисленияВыводаПрибора"));
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.энргОперацияСЛС_ЗакрытиеЛС, ИзменяемыеПараметры); 	
	
	// Для связанных помещений вид операции будет пустой
	ИзменяемыеПараметры = Новый Массив;
	ИзменяемыеПараметры.Добавить(Новый Структура("Ресурсы,СвойстваСоставаЖильцов", "СоставЖильцов, КоличествоКомнат", "КоличествоПроживающих,КоличествоПрописанных,КоличествоСобственников"));
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.ПустаяСсылка(), ИзменяемыеПараметры);
	
	Возврат ИзменяемыеПараметрыРасчета;
КонецФункции

