	|				ПО СостояниеУзлов.Ссылка = КоллекцияШкалПриборовУчета.Ссылка
	|					И (КоллекцияШкалПриборовУчета.Ссылка В (&мДокументы))
	|					И СостояниеУзлов.IDСтроки = КоллекцияШкалПриборовУчета.IDСтрокиТочкиУчета
	|					И (СостояниеУзлов.Ссылка В (&мДокументы))
	|			ПО Шапка.Ссылка = СостояниеУзлов.Ссылка
	|				И (Шапка.Ссылка В (&мДокументы))
