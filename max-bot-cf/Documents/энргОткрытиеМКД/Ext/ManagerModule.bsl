#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка 	= Ложь;
		если Параметры.свойство("Ключ") тогда
			ВидОперации 		= Параметры.ключ.видоперации;
			ПрефиксФормы  		= энргРаботаСВидамиОперацийСервер.ПрефиксФормы("энргОткрытиеМКД",ВидОперации);
			ВыбраннаяФорма 		= "ФормаДокумента" + ПрефиксФормы;
		иначе
			ВыбраннаяФорма 		= "ОбщаяФорма.энргФормаВыбораОперации";
			Параметры.вставить("ИмяДокумента","энргОткрытиеМКД");
			Параметры.вставить("ВыборОперации",Истина);
		КонецЕсли; 		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
		
	ПараметрыЗапроса  			= Новый Структура;
	Схема 						= Неопределено;
	ИнициализироватьИсходныеДанныеДокумента(Схема);
	ЗаполнитьСхемуЗапроса(Схема, Регистры);
			
	Если ДополнительныеСвойства.Свойство("ТаблицыПодмены") Тогда		
		ВспомогательныеПараметры 	= Новый Структура;
		энргФормированиеТекстовЗапроса.УстановитьПерехватОбращенияКТаблицам(Схема, ДополнительныеСвойства.ТаблицыПодмены, ВспомогательныеПараметры); 
	КонецЕсли;
	
	ИспользоватьУзлыМКД = энргРаботаСТочкамиУчетаСервер.ИспользоватьУзлыМКД();
	КлючиТаблицДвижений = энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы"						, ДокументСсылка);
	ПараметрыЗапроса.Вставить("ПустойУникальныйИдентификатор"	, Новый УникальныйИдентификатор());
	ПараметрыЗапроса.Вставить("ИспользоватьУзлыМКД"				, ИспользоватьУзлыМКД);
		
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		энргСхемаЗапросаСервер.ВыполнитьПакет(Схема,ПараметрыЗапроса));
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

Процедура ИнициализироватьТаблицыДляКонтроля(ДокументСсылка, ДополнительныеСвойства) Экспорт 
	
	Схема  										= Неопределено;
	Параметры 									= Новый Структура;
	
	ДобавитьТекстЗапросаПараметрыКонтроля(Схема);
	ДобавитьТекстЗапросаКонтрольСостояниеМКД(Схема, Параметры, ДополнительныеСвойства);
		
	КлючиТаблицКонтроля  						= Новый Структура;
			
	Для Сч = 0 По Схема.ПакетЗапросов.Количество() - 1  Цикл
		Пакет 									= Схема.ПакетЗапросов[Сч];		
		Если Не ПустаяСтрока(Пакет.ТаблицаДляПомещения) И СтрНачинаетсяС(Пакет.ТаблицаДляПомещения, "Контроль") Тогда			
			КлючиТаблицКонтроля.Вставить(Прав(Пакет.ТаблицаДляПомещения,СтрДлина(Пакет.ТаблицаДляПомещения) - СтрДлина("Контроль")),Сч);			
			Пакет.ТаблицаДляПомещения 			= "";
		КонецЕсли;		
	КонецЦикла;
	ТекстСообщенияМногоквартирныйДомЗакрыт 		= НСтр("ru = 'На дату операции мкд закрыт'");
	ТекстСообщенияОткрытыхЛС 					= НСтр("ru = 'По данному МКД есть незакрытые лицевые счета'");

	Запрос = Новый Запрос(Схема.ПолучитьТекстЗапроса());
	Запрос.УстановитьПараметр("мДокументы", 								ДокументСсылка);
	Запрос.УстановитьПараметр("ТекстСообщенияМногоквартирныйДомЗакрыт", 	ТекстСообщенияМногоквартирныйДомЗакрыт);
	Запрос.УстановитьПараметр("ТекстСообщенияОткрытыхЛС", 					ТекстСообщенияОткрытыхЛС);
	Запрос.УстановитьПараметр("Период", 									ДополнительныеСвойства.МоментВремени);
	Запрос.УстановитьПараметр("Организация", 								ДополнительныеСвойства.ПараметрыПроведения.Организация);
	Запрос.УстановитьПараметр("Район", 										ДополнительныеСвойства.ПараметрыПроведения.Район);
	Запрос.УстановитьПараметр("МКД", 										ДополнительныеСвойства.ПараметрыПроведения.МКД);
	
	ДополнительныеСвойства.Вставить("ТаблицыДляКонтроля", 					Запрос.ВыполнитьПакет());
	ДополнительныеСвойства.Вставить("КлючиТаблицКонтроля", 					КлючиТаблицКонтроля);
	
КонецПроцедуры

Функция СвойстваСтроенияИзСтрокиJSON(ОписаниеСтроения, ПолучаемыеСвойства) Экспорт 
			
	Чтение  							= Новый ЧтениеJSON;	
	Чтение.УстановитьСтроку(ОписаниеСтроения);
	ДанныеМКД 							= ПрочитатьJSON(Чтение);
	
	Результат 							= Новый Структура(ПолучаемыеСвойства);
	
	Если ДанныеМКД.Свойство("Организация") и Результат.Свойство("Организация")  Тогда
		Результат.Организация 			= Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.Организация));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("Район") и Результат.Свойство("Район") Тогда
		Результат.Район 							= Справочники.энргЗоныОтвественности.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.Район));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("Бойлер") и Результат.Свойство("Бойлер") Тогда
		Результат.Бойлер							= Булево(ДанныеМКД.Бойлер);
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ГодПостройки") и Результат.Свойство("ГодПостройки") Тогда
		Результат.ГодПостройки 						= Число(ДанныеМКД.ГодПостройки);
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ВидОбъектаАбонентов") и Результат.Свойство("ВидОбъектаАбонентов") Тогда
		Результат.ВидОбъектаАбонентов 				= Справочники.энргВидыОбъектовАбонента.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.ВидОбъектаАбонентов));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ГруппаПотребителейПоУмолчанию") и Результат.Свойство("ГруппаПотребителейПоУмолчанию") Тогда
		Результат.ГруппаПотребителейПоУмолчанию 	= Справочники.энргГруппыПотребителей.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.ГруппаПотребителейПоУмолчанию));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("КоличествоЭтажей") и Результат.Свойство("КоличествоЭтажей") Тогда
		Результат.КоличествоЭтажей 					= Число(ДанныеМКД.КоличествоЭтажей);
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ОКТМО") и Результат.Свойство("ОКТМО") Тогда
		Результат.ОКТМО 							= ДанныеМКД.ОКТМО;
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ТипПлиты") и Результат.Свойство("ТипПлиты") Тогда
		Результат.ТипПлиты 							= Перечисления.энргТипыПлит[ДанныеМКД.ТипПлиты];
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("АдресОбъекта") и Результат.Свойство("АдресОбъекта")  Тогда
		Результат.АдресОбъекта 						= ДанныеМКД.АдресОбъекта;		
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("АдресОбъектаЗначение") и Результат.Свойство("АдресОбъектаЗначение")  Тогда
		Результат.АдресОбъектаЗначение 				= ДанныеМКД.АдресОбъектаЗначение;		
	КонецЕсли;
		
	Если ДанныеМКД.Свойство("АдресОбъектаСтроительный") и Результат.Свойство("АдресОбъектаСтроительный") Тогда
		Результат.АдресОбъектаСтроительный 			= ДанныеМКД.АдресОбъектаСтроительный;		
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("АдресОбъектаСтроительныйЗначение") и Результат.Свойство("АдресОбъектаСтроительныйЗначение") Тогда
		Результат.АдресОбъектаСтроительныйЗначение 	= ДанныеМКД.АдресОбъектаСтроительныйЗначение;		
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("Филиал") и Результат.Свойство("Филиал") Тогда
		Результат.Филиал 							= Справочники.энргФилиалы.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.Филиал));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("МаршрутКонтроллера") и Результат.Свойство("МаршрутКонтроллера") Тогда
		Результат.МаршрутКонтроллера 				= Справочники.энргМаршрутыКонтроллеров.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.МаршрутКонтроллера));
	КонецЕсли;

	Если ДанныеМКД.Свойство("Контролер") и Результат.Свойство("Контролер") Тогда
		Результат.Контролер 						= Справочники.энргСотрудники.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеМКД.Контролер));
	КонецЕсли;
	
	Если ДанныеМКД.Свойство("ВидыБлагоустройстваТарифныеКатегории") и Результат.Свойство("ВидыБлагоустройстваТарифныеКатегории") Тогда
		
		МассивВидов = Новый Массив;
		Для Каждого Строка Из ДанныеМКД.ВидыБлагоустройстваТарифныеКатегории Цикл
			Структура = Новый Структура;
			Если Строка.Свойство("Услуга") Тогда
				Структура.Вставить("Услуга", Справочники.энргВидыУслуг.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.Услуга)));
			КонецЕсли;
			Если Строка.Свойство("ВидБлагоустройстваИндивидуальный") Тогда
				Структура.Вставить("ВидБлагоустройстваИндивидуальный", Справочники.энргВидыБлагоустройств.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.ВидБлагоустройстваИндивидуальный)));
			КонецЕсли;
			Если Строка.Свойство("ВидБлагоустройстваОбщедомовой") Тогда
				Структура.Вставить("ВидБлагоустройстваОбщедомовой", Справочники.энргВидыБлагоустройств.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.ВидБлагоустройстваОбщедомовой)));
			КонецЕсли;
			Если Строка.Свойство("ТарифнаяКатегория") Тогда
				Структура.Вставить("ТарифнаяКатегория", Справочники.энргГруппыПотребителей.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.ТарифнаяКатегория)));
			КонецЕсли;
			МассивВидов.Добавить(Структура);
		КонецЦикла; 
		
		Результат.Вставить("ВидыБлагоустройстваТарифныеКатегории", МассивВидов);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция АктуальныеПараметрыТочкиПоставки(Ссылка) Экспорт	
	
	Схема  	= Новый СхемаЗапроса;
	
	Пакет 	= Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаДанныеДокументаОткрытиеМКД());
	ТаблицаДляПомещения			= "ДанныеДокумента";
	Пакет.ТаблицаДляПомещения 	= ТаблицаДляПомещения;
	СоотвествиеПолей = Новый Структура("ТочкаПоставки", "ТочкаПоставки");

	ПараметрыВТ = Новый Массив;
	ПараметрыВТ.Добавить(энргФормированиеТекстовЗапроса.ПараметрТипВременнаяТаблица(ТаблицаДляПомещения, СоотвествиеПолей)); 		
	
	ПараметрыСхемы = Новый Структура("ПараметрыВТ", ПараметрыВТ);	
	РегистрыСведений.энргПараметрыТочекПоставки.ЗаполнитьСхемуАктуальныеПараметрыТочкиПоставки(Схема, ПараметрыСхемы, ТаблицаДляПомещения);
	
	Пакет = Схема.ПакетЗапросов.Добавить();	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ДанныеДокумента.ТочкаПоставки КАК ТочкаПоставки,
	|	ДанныеРС.МаксимальнаяМощность КАК МаксимальнаяМощность,
	|	ДанныеРС.ПрисоединеннаяМощность КАК ПрисоединеннаяМощность,
	|	ДанныеРС.СетеваяОрганизация КАК СетеваяОрганизация,
	|	ДанныеРС.СтруктураСети КАК СтруктураСети,
	|	ДанныеРС.УровеньНапряжения КАК УровеньНапряжения,
	|	ДанныеРС.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный,
	|	ДанныеРС.ДоговорТП КАК ДоговорТП,
	|	ДанныеРС.АктТП КАК АктТП
	|ИЗ
	|	ДанныеДокумента КАК ДанныеДокумента
	|		ПОЛНОЕ СОЕДИНЕНИЕ ДанныеРС КАК ДанныеРС
	|		ПО ДанныеДокумента.ТочкаПоставки = ДанныеРС.ТочкаПоставки");
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("Ссылка"	,Ссылка );
	
	РезультатЗапроса = энргСхемаЗапросаСервер.ВыполнитьЗапрос(Схема, ПараметрыЗапроса);
	Возврат РезультатЗапроса;	
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьСхемуЗапроса(Схема, Регистры)
	
	ДобавитьТекстЗапросаСостояниеМКД(Схема, Регистры);
	ДобавитьТекстЗапросаВидБлагоустройствМКД(Схема, Регистры);
	ДобавитьТекстЗапросаФормыУправленияМКД(Схема, Регистры);
	ДобавитьТекстЗапросаФилиалыСтроений(Схема, Регистры);
	ДобавитьТекстЗапросаСпособРаспределенияОбъемаМКДНаАбонентов(Схема, Регистры);
	ДобавитьТекстЗапросаТипСхемыГВС(Схема, Регистры);
	ДобавитьТекстЗапросаТипПринадлежностиМКД(Схема, Регистры);
	ДобавитьТекстЗапросаэнргПроцентВетхостиСтроения(Схема, Регистры);
	
	ДобавитьТекстЗапросаЗначениеПлощадейМКД(Схема, Регистры);
	
	ДобавитьТекстЗапросаВладельцыТочекУчета(Схема, Регистры);
	ДобавитьТекстЗапросаУслугиТочекУчетаМКД(Схема, Регистры);	
	ДобавитьТекстЗапросаАктивностьТочекУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаПоставщикиУслугМКД(Схема, Регистры);
	ДобавитьТекстЗапросаТочкиПоставкиТочекУчетаСтроений(Схема, Регистры);
	
	ДобавитьТекстЗапросаПриборыТочекМКД(Схема, Регистры);
	ДобавитьТекстЗапросаСостояниеПриборовМКД(Схема, Регистры);
	ДобавитьТекстЗапросаПриборыУзловУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаСостояниеПриборовУзловУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаПриборыМОП(Схема, Регистры); 	
	ДобавитьТекстЗапросаПараметрыИзмерителей(Схема, Регистры);
	
	ДобавитьТекстЗапросаПоказанияПриборовУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаэнргНомерПломбПриборовУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаэнргКоэффциентыПриборовУчета(Схема, Регистры);
	ДобавитьТекстЗапросаэнргДатыПоверкиПрибораУчета(Схема, Регистры);
	ДобавитьТекстЗапросаВидыДифференцированностиПриборовУчетаМКД(Схема, Регистры);
	ДобавитьТекстЗапросаДопускПриборовУчетаККоммерческомуУчетуМКД(Схема, Регистры);
	
	ДобавитьТекстЗапросаТУМКДНаСтруктуреСети(Схема, Регистры);
	
	ДобавитьТекстЗапросаФормулыРасчетаУслугМКД(Схема, Регистры);
	
	ДобавитьТекстЗапросаОтветственныйПИР(Схема, Регистры);
	ДобавитьТекстЗапросаНаборТочекПоставок(Схема, Регистры);
	
	ДобавитьТекстЗапросаОрганизацийПоставщиков(Схема, Регистры);
	ДобавитьТекстЗапросаТехническаяВозможностьУстановкиПУДляМКД(Схема, Регистры);
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаКонтрольСостояниеМКД(Схема, Параметры, ДополнительныеСвойства)
	
	ПараметрыСостоянияМКД 		= Новый Структура;
	ПараметрыВременнойТаблицы 	= Новый Массив;
	ПараметрыВременнойТаблицы.Добавить(Новый Структура("ИмяПараметра, ТаблицаИсточник, ТипПараметра, СоотвествиеПолей","ПараметрыКонтроля","ПараметрыКонтроля","ТипПараметраВременнаяТаблица", Новый Структура("Организация,Район,МКД","Организация","Район","МКД")));
	ПараметрыСостоянияМКД.Вставить("ПараметрыВТ", ПараметрыВременнойТаблицы);
	РегистрыСведений.энргСостояниеМКД.СостояниеМногоквартирногоДома(Схема, ПараметрыСостоянияМКД, "СостояниеМногоквартирногоДома");
	
	ПараметрыПроведения = ДополнительныеСвойства.ПараметрыПроведения;
	Обработки.энргСтроенияМенеджер.СостояниеЛицевыхСчетовВМКД(
		Схема,
		ДополнительныеСвойства.МоментВремени,
		ПараметрыПроведения.Организация,
		ПараметрыПроведения.Район,
		ПараметрыПроведения.МКД);
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст 			=
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПРЕДСТАВЛЕНИЕ(ПараметрыКонтроля.Ссылка) КАК ПредставлениеОбъекта,
	|	&ТекстСообщенияМногоквартирныйДомЗакрыт КАК ТекстСообщения
	|ИЗ
	|	ПараметрыКонтроля КАК ПараметрыКонтроля
	|		ЛЕВОЕ СОЕДИНЕНИЕ СостояниеМногоквартирногоДома КАК СостояниеМногоквартирногоДома
	|		ПО ПараметрыКонтроля.Организация = СостояниеМногоквартирногоДома.Организация
	|			И ПараметрыКонтроля.Район = СостояниеМногоквартирногоДома.Район
	|			И ПараметрыКонтроля.МКД = СостояниеМногоквартирногоДома.МКД
	|ГДЕ
	|	(НЕ ЕСТЬNULL(СостояниеМногоквартирногоДома.Состояние, ЛОЖЬ)
	|			ИЛИ КОНЕЦПЕРИОДА(ПараметрыКонтроля.Период, ДЕНЬ) < ЕСТЬNULL(КОНЕЦПЕРИОДА(СостояниеМногоквартирногоДома.Период, ДЕНЬ), ДАТАВРЕМЯ(1, 1, 1)))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПРЕДСТАВЛЕНИЕ(ПараметрыКонтроля.Ссылка),
	|	&ТекстСообщенияОткрытыхЛС
	|ИЗ
	|	ПараметрыКонтроля КАК ПараметрыКонтроля
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АктивныеЛСМКД КАК АктивныеЛСМКД
	|		ПО (ИСТИНА)";
		
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "КонтрольСостояниеМКД";
	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаПараметрыКонтроля(Схема)
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст 		=
	"ВЫБРАТЬ
	|	Шапка.Ссылка КАК Ссылка,
	|	Шапка.Организация КАК Организация,
	|	Шапка.Район КАК Район,
	|	Шапка.МКД КАК МКД,
	|	ВЫБОР
	|		КОГДА НЕ Шапка.ДатаФактическогоСобытия = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА Шапка.ДатаФактическогоСобытия
	|		ИНАЧЕ Шапка.Дата
	|	КОНЕЦ КАК Период
	|ПОМЕСТИТЬ ПараметрыКонтроля
	|ИЗ
	|	Документ.энргОткрытиеМКД КАК Шапка
	|ГДЕ
	|	Шапка.Ссылка В(&мДокументы)
	|	И Шапка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОткрытиеМКД_Закрытие)";
		
	Пакет.УстановитьТекстЗапроса(Текст);
	
КонецПроцедуры

#Область ИнициализацияДанныхДокумента

Процедура ИнициализироватьИсходныеДанныеДокумента(Схема)
	
	ПолучитьШапкуДокумента(Схема);
	ПолучитьТаблицуТочекУчета(Схема);
	ПолучитьТаблицуИзмерителей(Схема);
	ПолучитьТаблицуШкалыПриборовУчета(Схема);
	
КонецПроцедуры

Процедура ПолучитьШапкуДокумента(Схема)
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
