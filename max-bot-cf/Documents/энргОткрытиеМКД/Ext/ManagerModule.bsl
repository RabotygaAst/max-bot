Процедура ПолучитьТаблицуИзмерителей(Схема)
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	энргОткрытиеМКДПриборыУзловУчета.Ссылка КАК Ссылка,
	|	энргОткрытиеМКДПриборыУзловУчета.IDСтроки КАК IDСтрокиТочкиУчета,
	|	энргОткрытиеМКДПриборыУзловУчета.IDСтрокиШкалы КАК IDСтроки,
	|	энргОткрытиеМКДПриборыУзловУчета.ДатаВыпуска КАК ДатаВыпуска,
	|	энргОткрытиеМКДПриборыУзловУчета.ДатаПоверкиСчетчика КАК ДатаПоверкиСчетчика,
	|	энргОткрытиеМКДПриборыУзловУчета.ДатаУстановкиПломбы КАК ДатаУстановкиПломбы,
	|	энргОткрытиеМКДПриборыУзловУчета.КонецДействияКоммерскогоУчета КАК КонецДействияКоммерскогоУчета,
	|	энргОткрытиеМКДПриборыУзловУчета.КоэффициентПУ КАК КоэффициентПУ,
	|	энргОткрытиеМКДПриборыУзловУчета.НачалоДействияКоммерскогоУчета КАК НачалоДействияКоммерскогоУчета,
	|	энргОткрытиеМКДПриборыУзловУчета.НомерПломбы КАК НомерПломбы,
	|	энргОткрытиеМКДПриборыУзловУчета.ПриборУчета КАК ПриборУчета,
	|	энргОткрытиеМКДПриборыУзловУчета.РасположениеИзмерителя КАК РасположениеИзмерителя,
	|	энргОткрытиеМКДПриборыУзловУчета.РегистрируетОбъем КАК РегистрируетОбъем,
	|	энргОткрытиеМКДПриборыУзловУчета.ТипПрибораУчета КАК ТипПрибораУчета,
	|	ИСТИНА КАК ВспомогательноеОборудование,
	|	NULL КАК КодАСКУЭ,
	|	NULL КАК СобственникАСКУЭ,
	|	NULL КАК ДатаИнтеграцииССистемой,
	|	NULL КАК СистемаУчетаЭлектроэнергии,
	|	NULL КАК ТипИзмерителя,
	|	NULL КАК ЗаводскойНомер,
	|	NULL КАК ДоступКПУ,
	|	NULL КАК ДатаУстановки,
	|	NULL КАК ДатаОчереднойПоверки,
	|	NULL КАК СобственникСИ,
	|	NULL КАК Фаза,
	|	NULL КАК БалансоваяПринадлежность,
	|	энргОткрытиеМКДПриборыУзловУчета.УдалитьВидПараметра КАК УдалитьВидПараметра
