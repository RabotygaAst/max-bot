	|	энргОткрытиеМКДИзмерители.ДатаПоверкиСчетчика,
	|	энргОткрытиеМКДИзмерители.ДатаУстановкиПломбы,
	|	энргОткрытиеМКДИзмерители.КонецДействияКоммерскогоУчета,
	|	энргОткрытиеМКДИзмерители.КоэффициентПУ,
	|	энргОткрытиеМКДИзмерители.НачалоДействияКоммерскогоУчета,
	|	энргОткрытиеМКДИзмерители.НомерПломбы,
	|	энргОткрытиеМКДИзмерители.ПриборУчета,
	|	энргОткрытиеМКДИзмерители.РасположениеИзмерителя,
	|	энргОткрытиеМКДИзмерители.РегистрируетОбъем,
	|	энргОткрытиеМКДИзмерители.ТипПрибораУчета,
	|	энргОткрытиеМКДИзмерители.ВспомогательноеОборудование,
	|	энргОткрытиеМКДИзмерители.КодАСКУЭ,
	|	энргОткрытиеМКДИзмерители.СобственникАСКУЭ,
	|	энргОткрытиеМКДИзмерители.ДатаИнтеграцииССистемой,
	|	энргОткрытиеМКДИзмерители.СистемаУчетаЭлектроэнергии,
	|	энргОткрытиеМКДИзмерители.ТипИзмерителя,
	|	энргОткрытиеМКДИзмерители.ЗаводскойНомер,
	|	энргОткрытиеМКДИзмерители.ДоступКПУ,
	|	энргОткрытиеМКДИзмерители.ДатаУстановки,
	|	энргОткрытиеМКДИзмерители.ДатаОчереднойПоверки,
	|	энргОткрытиеМКДИзмерители.СобственникСИ,
	|	энргОткрытиеМКДИзмерители.Фаза,
	|	энргОткрытиеМКДИзмерители.БалансоваяПринадлежность,
	|	энргОткрытиеМКДИзмерители.УдалитьВидПараметра
	|ИЗ
	|	Документ.энргОткрытиеМКД.Измерители КАК энргОткрытиеМКДИзмерители
	|ГДЕ
	|	энргОткрытиеМКДИзмерители.Ссылка В(&мДокументы)
	|	И &ИспользоватьУзлыМКД");	
	
КонецПроцедуры

Процедура ПолучитьТаблицуШкалыПриборовУчета(Схема)
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
