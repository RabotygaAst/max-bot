	Текст = 
	"ВЫБРАТЬ
	|	энргОткрытиеМКДНаборТочекПоставок.ТочкаПоставки КАК ТочкаПоставки
	|ПОМЕСТИТЬ ДанныеДокумента
	|ИЗ
	|	Документ.энргОткрытиеМКД.НаборТочекПоставок КАК энргОткрытиеМКДНаборТочекПоставок
	|ГДЕ
	|	энргОткрытиеМКДНаборТочекПоставок.Ссылка = &Ссылка";	
