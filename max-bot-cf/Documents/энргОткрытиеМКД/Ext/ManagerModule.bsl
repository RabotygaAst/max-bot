	КонецЕсли;
	
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	энргОткрытиеМКД.Ссылка КАК Ссылка,
	|	энргОткрытиеМКД.Номер КАК Номер,
	|	энргОткрытиеМКД.Дата КАК Дата,
	|	энргОткрытиеМКД.ВидОперации КАК ВидОперации,
