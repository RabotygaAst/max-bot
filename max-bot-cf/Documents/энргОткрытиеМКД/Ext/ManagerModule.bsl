		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаИзмерителей КАК ИзмерителиУзла
		|				ПО табТочкиУчета.Ссылка = ИзмерителиУзла.Ссылка
		|					И табТочкиУчета.IDСтроки = ИзмерителиУзла.IDСтрокиТочкиУчета
		|					И (ИзмерителиУзла.Ссылка В (&мДокументы))
		|					И (НЕ ИзмерителиУзла.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))
		|			ПО табШапка.Ссылка = табТочкиУчета.Ссылка
		|				И (табШапка.Ссылка В (&мДокументы))
		|				И (табТочкиУчета.Ссылка В (&мДокументы))
		|				И (табШапка.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.энргВидыОпераций.энргОткрытиеМКД_Открытие)))
		|				И (НЕ табТочкиУчета.ПриборУчета = ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка))) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргОткрытиеМКД.НомераПломб КАК таблицаНомераПломб
		|		ПО ВложенныйЗапрос.Ссылка = таблицаНомераПломб.Ссылка
		|			И ВложенныйЗапрос.IDСтроки = таблицаНомераПломб.IDСтрокиИзмерителя
		|			И (таблицаНомераПломб.Ссылка В (&мДокументы))";
		
	КонецЕсли;
			
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;
	
КонецПроцедуры

