Процедура УстановитьЗависимыеРеквизитыОтДокументаОснования(ДокументОснование, ЗависимыеРеквизиты, Контекст = Неопределено) Экспорт

	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда 
		Возврат;
	КонецЕсли; 
	
	ДлительныеОперации.СообщитьПрогресс(1, "Корректировка документов оплат");
		
	ЗависимыеПоляПерезаписиПоУмолчанию = "Дата,Организация,Район,АбонентскийОтдел,ПериодНачисления,ИсточникПоступления,ФайлДляЧтения";
	ЗависимыеПоляПерезаписи = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Контекст, "ЗависимыеПоляПерезаписи", ЗависимыеПоляПерезаписиПоУмолчанию);
	
	ПовторноеПроведение = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргПлатежноеПоручениеВходящие.Ссылка КАК Ссылка,
	|	энргПлатежноеПоручениеВходящие.ДокументОснование КАК ДокументОснование
	|ИЗ
	|	Документ.энргПлатежноеПоручениеВходящие КАК энргПлатежноеПоручениеВходящие
	|ГДЕ
	|	энргПлатежноеПоручениеВходящие.ДокументОснование = &ДокументОснование
	|	И энргПлатежноеПоручениеВходящие.Проведен";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать(); 
	Всего = Выборка.Количество();
	Счетчик = 0;
	КоличествоИтераций = Счетчик;
	КолвоСообщений = Цел(Всего / 15);
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ЗначениеЗаполнено(Выборка.ДокументОснование) Тогда 
			Продолжить;
		КонецЕсли;
		
		Если КоличествоИтераций = КолвоСообщений Тогда
			Процент = Цел(Счетчик / Всего * 100);
			ДлительныеОперации.СообщитьПрогресс(Процент, "Скорректировано документов оплат " + Счетчик + " из " + Всего);
			КоличествоИтераций = 0;
		КонецЕсли;
		
		УстановитьЗависимыеРеквизиты(Выборка.Ссылка, ЗависимыеРеквизиты, ЗависимыеПоляПерезаписи, ПовторноеПроведение);
		
		Счетчик = Счетчик + 1;
		КоличествоИтераций = КоличествоИтераций + 1;
		
	КонецЦикла;	
	
	Для Каждого ДокументСсылка из ПовторноеПроведение Цикл 
		УстановитьЗависимыеРеквизиты(ДокументСсылка, ЗависимыеРеквизиты, ЗависимыеПоляПерезаписи, ПовторноеПроведение)
	КонецЦикла;
	
КонецПроцедуры

Процедура ПровестиДокументыПоДокументуОснованию(ДокументОснование) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда 
		Возврат;
	КонецЕсли;
	
	ПовторноеПроведение = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	энргПлатежноеПоручениеВходящие.Ссылка КАК Ссылка,
	|	энргПлатежноеПоручениеВходящие.ДокументОснование КАК ДокументОснование
	|ИЗ
	|	Документ.энргПлатежноеПоручениеВходящие КАК энргПлатежноеПоручениеВходящие
	|ГДЕ
	|	энргПлатежноеПоручениеВходящие.ДокументОснование = &ДокументОснование
	|	И НЕ энргПлатежноеПоручениеВходящие.Проведен
	|	И НЕ энргПлатежноеПоручениеВходящие.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать(); 
	Всего = Выборка.Количество();
	Счетчик = 0;
	КоличествоИтераций = Счетчик;
	КолвоСообщений = Цел(Всего / 15);
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ЗначениеЗаполнено(Выборка.ДокументОснование) Тогда 
			Продолжить;
		КонецЕсли;
		
		Если КоличествоИтераций = КолвоСообщений Тогда
			Процент = Цел(Счетчик / Всего * 100);
			ДлительныеОперации.СообщитьПрогресс(Процент, "Проведено " + Счетчик + " из " + Всего);
			КоличествоИтераций = 0;
		КонецЕсли;
		
		ПровестиДокумент(Выборка.Ссылка, ПовторноеПроведение);
		
		Счетчик = Счетчик + 1;
		КоличествоИтераций = КоличествоИтераций + 1;
		
	КонецЦикла;	
	
	Для Каждого ДокументСсылка из ПовторноеПроведение Цикл 
		ПровестиДокумент(ДокументСсылка);
	КонецЦикла;	
	
КонецПроцедуры

Процедура ОтменитьПроведениеДокументовПоДокументуОснованию(ДокументОснование) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда 
		Возврат;
	КонецЕсли;
	
