#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства, Регистры = Неопределено) Экспорт 
		
	ПараметрыЗапроса  			= Новый Структура;
	Схема 						= Неопределено;

	ДобавитьТекстЗапросаПараметрыТочекПоставки(Схема, Регистры);
	ДобавитьТекстЗапросаКатегорииНадежностиТочекПоставок(Схема, Регистры);
	
	КлючиТаблицДвижений 			= энргФормированиеТекстовЗапроса.КлючиТаблицДвижений(Схема);
	ПараметрыЗапроса 				= Новый Структура;
	ПараметрыЗапроса.Вставить("мДокументы", 					ДокументСсылка);
	ПараметрыЗапроса.Вставить("ПустойУникальныйИдентификатор", 	Новый УникальныйИдентификатор());
		
	ДополнительныеСвойства.Вставить("ТаблицыДвижений", 		энргСхемаЗапросаСервер.ВыполнитьПакет(Схема,ПараметрыЗапроса));
	ДополнительныеСвойства.Вставить("КлючиТаблицДвижений", 	КлючиТаблицДвижений);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьТекстЗапросаПараметрыТочекПоставки(Схема, Регистры)
	
	ИмяРегистра = "энргПараметрыТочекПоставки";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	энргУстановитьПараметрыТочекПоставок.Дата КАК Период,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ТочкаПоставки КАК ТочкаПоставки,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.МаксимальнаяМощность КАК МаксимальнаяМощность,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ПрисоединеннаяМощность КАК ПрисоединеннаяМощность,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.СетеваяОрганизация КАК СетеваяОрганизация,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.СтруктураСети КАК СтруктураСети,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.УровеньНапряжения КАК УровеньНапряжения,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.УровеньНапряженияРасчетный КАК УровеньНапряженияРасчетный,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ДоговорТП КАК ДоговорТП,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.АктТП КАК АктТП,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ТочкаПрисоединения КАК ТочкаПрисоединения,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ГТП КАК ГТП,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ВидРынка КАК ВидРынка,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.СмежныйСубъектОРЭМ КАК СмежныйСубъектОРЭМ,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.РеквизитыПСИ КАК РеквизитыПСИ,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ДоговорПередачи КАК ДоговорПередачи,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ДоговорПокупки КАК ДоговорПокупки,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ОтделениеЭК КАК ОтделениеЭК,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.НапряжениеГБП КАК НапряжениеГБП,
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.АктРазграниченияБалансовойПринадлежности КАК АктРазграниченияБалансовойПринадлежности
	|ИЗ
	|	Документ.энргУстановитьПараметрыТочекПоставок.ТочкиПоставки КАК энргУстановитьПараметрыТочекПоставокТочкиПоставки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргУстановитьПараметрыТочекПоставок КАК энргУстановитьПараметрыТочекПоставок
	|		ПО энргУстановитьПараметрыТочекПоставокТочкиПоставки.Ссылка = энргУстановитьПараметрыТочекПоставок.Ссылка
	|ГДЕ
	|	энргУстановитьПараметрыТочекПоставок.Ссылка В(&мДокументы)";		
			
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;	
КонецПроцедуры

Процедура ДобавитьТекстЗапросаКатегорииНадежностиТочекПоставок(Схема, Регистры)
	
	ИмяРегистра = "энргКатегорииНадежностиТочекПоставок";
	
	Если НЕ энргПроведениеСервер.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Схема = Неопределено Тогда
		Схема 	= новый СхемаЗапроса;
		Пакет 	= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 	= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;
	
	Текст  	= 
	"ВЫБРАТЬ
	|	энргУстановитьПараметрыТочекПоставокТочкиПоставки.ТочкаПоставки КАК ТочкаПоставки,
	|	энргУстановитьПараметрыТочекПоставок.Дата КАК Период,
	|	энргУстановитьПараметрыТочекПоставокКатегорииНадежности.КатегорияНадежности КАК КатегорияНадежности,
	|	энргУстановитьПараметрыТочекПоставокКатегорииНадежности.ВТомЧисле КАК ВТомЧисле
	|ИЗ
	|	Документ.энргУстановитьПараметрыТочекПоставок.ТочкиПоставки КАК энргУстановитьПараметрыТочекПоставокТочкиПоставки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргУстановитьПараметрыТочекПоставок КАК энргУстановитьПараметрыТочекПоставок
	|		ПО энргУстановитьПараметрыТочекПоставокТочкиПоставки.Ссылка = энргУстановитьПараметрыТочекПоставок.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.энргУстановитьПараметрыТочекПоставок.КатегорииНадежности КАК энргУстановитьПараметрыТочекПоставокКатегорииНадежности
	|		ПО энргУстановитьПараметрыТочекПоставокТочкиПоставки.Ссылка = энргУстановитьПараметрыТочекПоставокКатегорииНадежности.Ссылка
	|			И энргУстановитьПараметрыТочекПоставокТочкиПоставки.IDСтроки = энргУстановитьПараметрыТочекПоставокКатегорииНадежности.IDСтроки
	|ГДЕ
	|	энргУстановитьПараметрыТочекПоставок.Ссылка В(&мДокументы)";		
			
	Пакет.УстановитьТекстЗапроса(Текст);
	Пакет.ТаблицаДляПомещения = "Набор" + ИмяРегистра;	
КонецПроцедуры

#КонецОбласти

#КонецЕсли