Функция AccountBalanceget(Запрос)

	Если Не MAXBotИнтеграция.ПроверитьАвторизацию(Запрос) Тогда
		Возврат ОтветОшибка(401, "UNAUTHORIZED", "Неверный токен авторизации");
	КонецЕсли;
	
	Попытка
		AccountID = Запрос.ПараметрыURL.Получить("account_id");
		MAXUserID = Число(Запрос.ПараметрыЗапроса.Получить("max_user_id"));
		
		Если Не MAXBotИнтеграция.ПользовательИмеетДоступКЛС(MAXUserID, AccountID) Тогда
			Возврат ОтветОшибка(403, "FORBIDDEN", "Нет доступа к лицевому счету");
