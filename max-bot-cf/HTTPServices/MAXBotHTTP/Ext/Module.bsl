КонецФункции

Функция AccountLinkConfirmpost(Запрос)

	Если Не MAXBotИнтеграция.ПроверитьАвторизацию(Запрос) Тогда
		Возврат ОтветОшибка(401, "UNAUTHORIZED", "Неверный токен авторизации");
	КонецЕсли;
	
	Попытка
		Тело = ПрочитатьJSONИзЗапроса(Запрос);
		
		Результат = MAXBotИнтеграция.ПодтвердитьПривязкуЛицевогоСчета(
			Тело.max_user_id,
			Тело.account_number,
			Тело.code,
			Тело.source
		);
		
		Если Результат.КодОшибки = "INVALID_CODE" Тогда
			Возврат ОтветОшибка(422, "INVALID_CODE", "Неверный код подтверждения");
		КонецЕсли;
		
		Если Результат.КодОшибки = "CODE_EXPIRED" Тогда
			Возврат ОтветОшибка(422, "CODE_EXPIRED", "Срок действия кода истек");
		КонецЕсли;
		
		ДанныеСчета = MAXBotИнтеграция.JSONЛицевойСчет(Результат.ЛицевойСчет);
		
		Возврат ОтветУспех(
			ДанныеСчета,
			"Лицевой счет привязан"
		);
		
	Исключение
		Возврат ОтветОшибка(500, "INTERNAL_ERROR", ОписаниеОшибки());
	КонецПопытки;

КонецФункции

