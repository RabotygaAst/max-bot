			Возврат ОтветОшибка(403, ОтветБаланса.code, ОтветБаланса.message);
		КонецЕсли;
		ДанныеБаланса = ОтветБаланса.data;
		Возврат ОтветУспех(ДанныеБаланса, "Баланс");
		
	Исключение
		Возврат ОтветОшибка(500, "INTERNAL_ERROR", ОписаниеОшибки());
	КонецПопытки;

КонецФункции

