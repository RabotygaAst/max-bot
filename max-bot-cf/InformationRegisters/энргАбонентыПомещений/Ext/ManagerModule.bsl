#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет текущего абонента в помещении.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ТекущийАбонентВПомещении(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "")  Экспорт 
	
	Если Схема = Неопределено Тогда
		Схема 							= Новый СхемаЗапроса;
		Пакет 							= Схема.ПакетЗапросов[0];	
	Иначе
		Пакет 							= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	КонецЕсли;			
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаТекущийАбонентВПомещении());
	Пакет.ТаблицаДляПомещения 			= ТаблицаДляПомещения;
	Пакет.ВыбиратьРазрешенные 			= ?(ПараметрыОтбора.Свойство("ВыбиратьРазрешенные") и НЕ ПараметрыОтбора.ВыбиратьРазрешенные, ЛОЖЬ, ИСТИНА);
	ОператорВыбора 						= Пакет.Операторы[0];	
	Источник 							= ОператорВыбора.Источники[0].Источник;
	Параметры 							= Источник.Параметры;
	
	ПараметрПериод 						= Параметры[0];
	
	Если НЕ ПараметрыОтбора.Свойство("Период") Тогда
		ПараметрПериод.Выражение 		= Новый ВыражениеСхемыЗапроса("");
	ИначеЕсли НЕ ПараметрыОтбора["Период"].ИмяПараметра = "Период" Тогда
		ПараметрПериод.Выражение 		= Новый ВыражениеСхемыЗапроса(СтрЗаменить(ПараметрПериод.Выражение,"&Период","&" + ПараметрыОтбора["Период"].ИмяПараметра));		
	КонецЕсли;
	
	ВспомогательныеПоля 				= "Период,Регистратор,НомерСтроки,Активность,ПериодРегистрации,ПериодНачисления";
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация, Район, КлючПомещения";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(ОператорВыбора.Источники[0].Источник.Параметры[1],ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 			= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 					= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
	
	
	Если ПараметрыОтбора.Свойство("ТолькоОткрытыеЛС") Тогда
		
		Пакет.ТаблицаДляПомещения 	= "ВсеАбонентыПомещения"; 
		ПараметрыСостоянияМКД 		= Новый Структура;
		ПараметрыВременнойТаблицы 	= Новый Массив;
		ПараметрыВременнойТаблицы.Добавить(Новый Структура("ИмяПараметра, ТаблицаИсточник, ТипПараметра, СоотвествиеПолей", "ВсеАбонентыПомещения","ВсеАбонентыПомещения","ТипПараметраВременнаяТаблица", Новый Структура("Организация,Район,Абонент","Организация","Район","Абонент")));
		Если ПараметрыОтбора.Свойство("Период") Тогда 
			ПараметрыСостоянияМКД.Вставить("Период", ПараметрыОтбора.Период);
		КонецЕсли; 		
		ПараметрыСостоянияМКД.Вставить("ПараметрыВТ", ПараметрыВременнойТаблицы);
		РегистрыСведений.энргСостояниеЛС.СостояниеЛицевогоСчета(Схема, ПараметрыСостоянияМКД, "СостояниеЛицевогоСчета");
		
		ДополнитьСхемуЗапросаАктуальнымиЛС(Схема, ТаблицаДляПомещения);
		
	КонецЕсли;
КонецПроцедуры

#Область РаботаСоСтабильнымиПериодыми

// Получает изменяемые параметры расчета
// 
// Возвращаемое значение:
//   Соответствие.
//
Функция ИзменяемыеПараметрыРасчета() Экспорт 
	
	ИзменяемыеПараметрыРасчета = Новый Соответствие; 
	
	ИзменяемыеПараметры = Новый Массив;
	ИзменяемыеПараметры.Добавить("Абонент");
	ИзменяемыеПараметрыРасчета.Вставить(Перечисления.энргВидыОпераций.ПустаяСсылка(), ИзменяемыеПараметры);
		
	Возврат ИзменяемыеПараметрыРасчета;
	
КонецФункции 

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Дополняет схему запроса актуальными ЛС.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ДополнитьСхемуЗапросаАктуальнымиЛС(Схема, ТаблицаДляПомещения) Экспорт

	Пакет = Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(
	"ВЫБРАТЬ
	|	ВсеАбонентыПомещения.Период КАК Период,
	|	ВсеАбонентыПомещения.Организация КАК Организация,
	|	ВсеАбонентыПомещения.Район КАК Район,
	|	ВсеАбонентыПомещения.КлючПомещения КАК КлючПомещения,
	|	ВсеАбонентыПомещения.Услуга КАК Услуга,
	|	ВсеАбонентыПомещения.Абонент КАК Абонент
	//|ПОМЕСТИТЬ " + ТаблицаДляПомещения + "
	|ИЗ
	|	ВсеАбонентыПомещения КАК ВсеАбонентыПомещения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СостояниеЛицевогоСчета КАК СостояниеЛицевогоСчета
	|		ПО ВсеАбонентыПомещения.Организация = СостояниеЛицевогоСчета.Организация
	|			И ВсеАбонентыПомещения.Район = СостояниеЛицевогоСчета.Район
	|			И ВсеАбонентыПомещения.Абонент = СостояниеЛицевогоСчета.Абонент
	|			И (СостояниеЛицевогоСчета.Состояние)");	
	
	Пакет.ТаблицаДляПомещения = ТаблицаДляПомещения;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаТекущийАбонентВПомещении()
	
	Текст =
	"ВЫБРАТЬ
	|	энргАбонентыПомещенийСрезПоследних.Период КАК Период,
	|	энргАбонентыПомещенийСрезПоследних.Организация КАК Организация,
	|	энргАбонентыПомещенийСрезПоследних.Район КАК Район,
	|	энргАбонентыПомещенийСрезПоследних.КлючПомещения КАК КлючПомещения,
	|	энргАбонентыПомещенийСрезПоследних.Услуга КАК Услуга,
	|	энргАбонентыПомещенийСрезПоследних.Абонент КАК Абонент
	|ИЗ
	|	РегистрСведений.энргАбонентыПомещений.СрезПоследних(&Период, ) КАК энргАбонентыПомещенийСрезПоследних";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#КонецЕсли