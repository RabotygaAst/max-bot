#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет значения текущих норм потребления.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Функция ЗначенияТекущихНормПотребления(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаЗначенияНормативовПотребления());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	ОператорВыбора 					= Пакет.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;
	
	Если ПараметрыОтбора.Свойство("Период") И Не ПустаяСтрока(ПараметрыОтбора.Период.ИмяПараметра) Тогда
		ПараметрПериод 				= Параметры[0];
		ПараметрПериод.Выражение 	= Новый ВыражениеСхемыЗапроса("&" + ПараметрыОтбора["Период"].ИмяПараметра);		
	КонецЕсли;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация, Район, ТипНачисления, НаправлениеИспользованияТУ, КлючНорматива, Услуга";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(ОператорВыбора.Источники[0].Источник.Параметры[1],ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);		
	КонецЕсли;	 	
		
	ВспомогательныеПоля 			= "Период,Регистратор,НомерСтроки,Активность";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 		= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 				= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
	
КонецФункции

// Заполняет значения текущих норм потребления коллекция периодов.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаПериодов		-	Строка.
//  ТаблицаДляПомещения	-	Строка.
//
Функция ЗначенияТекущихНормПотребленияКоллекцияПериодов(Схема,ПараметрыОтбора,ТаблицаПериодов,ТаблицаДляПомещения = "") Экспорт 
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТексЗапросЗначенияПовышающихКоэффициентовКоллекцияПериодов());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	ОператорВыбора 					= Пакет.Операторы[0].Источники[0].Источник.Запрос.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация, Район, ТипНачисления, НаправлениеИспользованияТУ, КлючНорматива, Услуга";
		ИмяТаблицы 					= "ЗначенияНормативовПотребления";
		энргФормированиеТекстовЗапроса.УстановитьОтборТаблицы(ОператорВыбора.Отбор,ИмяТаблицы,ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);				
	КонецЕсли;	 	
	
	ВспомогательныеПоля 			= "Период,НомерСтроки,Активность";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 		= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 				= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;

КонецФункции

// Заполняет схему благоустройства услуги.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ЗаполнитьСхемуБлагоустройстваУслуги(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "") Экспорт 
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТексЗапросаЗаполнитьСхемуБлагоустройстваУслуги());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	ОператорВыбора 					= Пакет.Операторы[0];	
	Источник 						= ОператорВыбора.Источники[0].Источник;
	Параметры 						= Источник.Параметры;
	
	Если ПараметрыОтбора.Свойство("Период") Тогда
		Параметры[0].Выражение 			= Новый ВыражениеСхемыЗапроса("&" + ПараметрыОтбора["Период"].ИмяПараметра);		
	КонецЕсли;	
	
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		ДоступныеПараметры 			= "Организация, Район, ТипНачисления, НаправлениеИспользованияТУ, КлючНорматива, Услуга";
		ИмяТаблицы 					= "ЗначенияНормативовПотребления";
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(Параметры[1],ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);				
	КонецЕсли;
КонецПроцедуры

// Заполняет схему значения норм потребления МКД.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура ЗаполнитьСхемуЗначенияНормПотребленияМКД(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "") Экспорт
	
	Если Схема = Неопределено Тогда
		Схема  						= Новый СхемаЗапроса;
		Пакет 						= Схема.ПакетЗапросов[0];
	Иначе
		Пакет 						= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));	
	КонецЕсли; 	
	
	Пакет.УстановитьТекстЗапроса(ТексЗапросаЗначенияНормПотребленияМКД());
	Пакет.ТаблицаДляПомещения 		= ТаблицаДляПомещения;
	Для Индекс = 0 По 1 Цикл
		ОператорВыбора 				= Пакет.Операторы[Индекс];	
		Источник 					= ОператорВыбора.Источники[0].Источник;
		Параметры 					= Источник.Параметры;
		
		Если ПараметрыОтбора.Свойство("Период") Тогда
			Параметры[0].Выражение 	= Новый ВыражениеСхемыЗапроса("&" + ПараметрыОтбора["Период"].ИмяПараметра);		
		КонецЕсли;	
		
		Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
			ДоступныеПараметры 		= "Организация, Район";
			ИмяТаблицы 				= "ЗначенияНормативовПотребления";
			энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(Параметры[1],ПараметрыОтбора.ПараметрыВТ,ДоступныеПараметры);				
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Получает текст запроса значения нормативов потребления.
// 
// Возвращаемое значение:
//   Строка.
//
Функция ТекстЗапросаЗначенияНормативовПотребления() Экспорт 
	
	Текст = 
	"ВЫБРАТЬ
	|	энргЗначенияНормативовПотребленияСрезПоследних.Организация КАК Организация,
	|	энргЗначенияНормативовПотребленияСрезПоследних.Район КАК Район,
	|	энргЗначенияНормативовПотребленияСрезПоследних.ТипНачисления КАК ТипНачисления,
	|	энргЗначенияНормативовПотребленияСрезПоследних.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	энргЗначенияНормативовПотребленияСрезПоследних.КлючНорматива КАК КлючНорматива,
	|	энргЗначенияНормативовПотребленияСрезПоследних.Услуга КАК Услуга,
	|	энргЗначенияНормативовПотребленияСрезПоследних.ЗначениеНорматива КАК ЗначениеНорматива
	|ИЗ
	|	РегистрСведений.энргЗначенияНормативовПотребления.СрезПоследних КАК энргЗначенияНормативовПотребленияСрезПоследних";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТексЗапросЗначенияПовышающихКоэффициентовКоллекцияПериодов()  
	
	Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.ПериодНачисления КАК ПериодНачисления,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Район КАК Район,
	|	ВложенныйЗапрос.ТипНачисления КАК ТипНачисления,
	|	ВложенныйЗапрос.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|	ВложенныйЗапрос.КлючНорматива КАК КлючНорматива,
	|	ВложенныйЗапрос.Услуга КАК Услуга,
	|	ЗначенияНормативовПотребления.ЗначениеНорматива КАК ЗначениеНорматива
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаПериодов.ПериодНачисления КАК ПериодНачисления,
	|		ЗначенияНормативовПотребления.Организация КАК Организация,
	|		ЗначенияНормативовПотребления.Район КАК Район,
	|		ЗначенияНормативовПотребления.ТипНачисления КАК ТипНачисления,
	|		ЗначенияНормативовПотребления.НаправлениеИспользованияТУ КАК НаправлениеИспользованияТУ,
	|		ЗначенияНормативовПотребления.КлючНорматива КАК КлючНорматива,
	|		ЗначенияНормативовПотребления.Услуга КАК Услуга,
	|		МАКСИМУМ(ЗначенияНормативовПотребления.Период) КАК Период
	|	ИЗ
	|		РегистрСведений.энргЗначенияНормативовПотребления КАК ЗначенияНормативовПотребления
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПериодов КАК ТаблицаПериодов
	|			ПО ЗначенияНормативовПотребления.Организация = ТаблицаПериодов.Организация
	|				И ЗначенияНормативовПотребления.Район = ТаблицаПериодов.Район
	|				И ЗначенияНормативовПотребления.Период < ТаблицаПериодов.ЗавершениеОП
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ТаблицаПериодов.ПериодНачисления,
	|		ЗначенияНормативовПотребления.Организация,
	|		ЗначенияНормативовПотребления.Район,
	|		ЗначенияНормативовПотребления.ТипНачисления,
	|		ЗначенияНормативовПотребления.НаправлениеИспользованияТУ,
	|		ЗначенияНормативовПотребления.КлючНорматива,
	|		ЗначенияНормативовПотребления.Услуга) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргЗначенияНормативовПотребления КАК ЗначенияНормативовПотребления
	|		ПО ВложенныйЗапрос.Организация = ЗначенияНормативовПотребления.Организация
	|			И ВложенныйЗапрос.Район = ЗначенияНормативовПотребления.Район
	|			И ВложенныйЗапрос.ТипНачисления = ЗначенияНормативовПотребления.ТипНачисления
	|			И ВложенныйЗапрос.НаправлениеИспользованияТУ = ЗначенияНормативовПотребления.НаправлениеИспользованияТУ
	|			И ВложенныйЗапрос.КлючНорматива = ЗначенияНормативовПотребления.КлючНорматива
	|			И ВложенныйЗапрос.Услуга = ЗначенияНормативовПотребления.Услуга
	|			И ВложенныйЗапрос.Период = ЗначенияНормативовПотребления.Период";
	
	Возврат Текст;
	
КонецФункции

Функция ТексЗапросаЗаполнитьСхемуБлагоустройстваУслуги()
	
	Текст  =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КлючиНормативов.ВидБлагоустройства КАК ВидБлагоустройства
	|ИЗ
	|	РегистрСведений.энргЗначенияНормативовПотребления.СрезПоследних КАК ЗначенияНормативовПотребленияСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргКлючиНормативов КАК КлючиНормативов
	|		ПО ЗначенияНормативовПотребленияСрезПоследних.КлючНорматива = КлючиНормативов.Ссылка";
	
	Возврат Текст;
	
КонецФункции

Функция ТексЗапросаЗначенияНормПотребленияМКД()
	
	Текст  = 
	"ВЫБРАТЬ
	|	ЗначенияНормативовПотребленияСрезПоследних.Организация КАК Организация,
	|	ЗначенияНормативовПотребленияСрезПоследних.Район КАК Район,
	|	ЗначенияНормативовПотребленияСрезПоследних.КлючНорматива КАК КлючНорматива,
	|	ЗначенияНормативовПотребленияСрезПоследних.Услуга КАК Услуга,
	|	ЗначенияНормативовПотребленияСрезПоследних.ЗначениеНорматива КАК ЗначениеНорматива
	|ИЗ
	|	РегистрСведений.энргЗначенияНормативовПотребления.СрезПоследних(
	|			,
	|			ТипНачисления = ЗНАЧЕНИЕ(Перечисление.энргТипыНачислений.ОбщедомовыеНачисления)
	|				И НаправлениеИспользованияТУ = ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление)) КАК ЗначенияНормативовПотребленияСрезПоследних
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗначенияНормативовПотребления.Организация,
	|	ЗначенияНормативовПотребления.Район,
	|	ЗначенияНормативовПотребления.КлючНорматива,
	|	ЗначенияНормативовПотребления.Услуга,
	|	ЗначенияНормативовПотребления.ЗначениеНорматива
	|ИЗ
	|	РегистрСведений.энргЗначенияНормативовПотребления.СрезПоследних(
	|			,
	|			ТипНачисления = ЗНАЧЕНИЕ(Перечисление.энргТипыНачислений.ИндивидуальныеНачисления)
	|				И НаправлениеИспользованияТУ = ЗНАЧЕНИЕ(Справочник.энргНаправлениеИспользованияТочекУчета.ОсновноеНаправление)) КАК ЗначенияНормативовПотребления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргВидыУслуг КАК энргВидыУслуг
	|		ПО ЗначенияНормативовПотребления.Услуга = энргВидыУслуг.Ссылка
	|			И (энргВидыУслуг.НормативДляИндивидуальных)";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#КонецЕсли