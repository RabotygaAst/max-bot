#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет актуальные значения потерь.
//
// Параметры:
//  Схема				-	СхемаЗапроса.
//  ПараметрыОтбора		-	Структура.
//  ТаблицаДляПомещения	-	Строка.
//
Процедура АктуальныеЗначенияПотерь(Схема,ПараметрыОтбора,ТаблицаДляПомещения = "") Экспорт 
	
	Если Схема = Неопределено Тогда
		РегистрыСведений.энргСостояниеВидовПотерь.АктивныеВидыПотерь(Схема,ПараметрыОтбора,"АктивныеВидыПотерь");
	Иначе	
		ЕстьДействующиеВидыПотерь 		= Ложь;
		Для Каждого яПакет Из Схема.ПакетЗапросов Цикл
			Если яПакет.ТаблицаДляПомещения  = "АктивныеВидыПотерь" Тогда
				ЕстьДействующиеВидыПотерь = Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
		
		Если НЕ ЕстьДействующиеВидыПотерь Тогда 
			РегистрыСведений.энргСостояниеВидовПотерь.АктивныеВидыПотерь(Схема,ПараметрыОтбора,"АктивныеВидыПотерь");
		КонецЕсли;
	КонецЕсли;	
	
	Пакет 								= Схема.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Пакет.УстановитьТекстЗапроса(ТекстЗапросаАктуальныеЗначенияПотерь());
	Пакет.ТаблицаДляПомещения 			= ТаблицаДляПомещения;
	ОператорВыбора 						= Пакет.Операторы[0];	
	Источник 							= ОператорВыбора.Источники[0].Источник;
	Параметры 							= Источник.Параметры;
	
	ПараметрПериод 						= Параметры[0];
	ДоступныеПараметры					= "Организация,Район,КлючПомещения,ТочкаУчета,ВидПотерь";
	
	Если НЕ ПараметрыОтбора.Свойство("Период") Тогда
		ПараметрПериод.Выражение 		= Новый ВыражениеСхемыЗапроса("");
	Иначе 
		ПараметрПериод.Выражение 		= Новый ВыражениеСхемыЗапроса("&" + ПараметрыОтбора["Период"].ИмяПараметра);		
	КонецЕсли;
		
	Если ПараметрыОтбора.Свойство("ПараметрыВТ") Тогда
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(Параметры[1], ПараметрыОтбора.ПараметрыВТ, ДоступныеПараметры);		
	КонецЕсли;	
	
	Если ПараметрыОтбора.Свойство("Отбор") Тогда
		энргФормированиеТекстовЗапроса.УстановитьПараметрыВременнойТаблицыРегистраСведений(ОператорВыбора.Отбор, "энргЗначенияПотерьСрезПоследних", ДоступныеПараметры);		
	КонецЕсли;
	
	ВспомогательныеПоля 				= "Период,Регистратор,НомерСтроки,Активность,ПериодРегистрации,ПериодНачисления";
	
	Если ПараметрыОтбора.Свойство("ВыбиратьВсеПоля") И ПараметрыОтбора.ВыбиратьВсеПоля Тогда
		мВспомогательныеПоля 			= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВспомогательныеПоля,",",Истина);
		Для Сч  = 0 По мВспомогательныеПоля.ВГраница() Цикл
			Выражение 					= Источник.Псевдоним + "." + мВспомогательныеПоля[Сч] + " КАК " + мВспомогательныеПоля[Сч];
			ОператорВыбора.ВыбираемыеПоля.Добавить(Выражение);
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаАктуальныеЗначенияПотерь()
	
	Текст  =
	"ВЫБРАТЬ
	|	энргЗначенияПотерьСрезПоследних.Организация КАК Организация,
	|	энргЗначенияПотерьСрезПоследних.Район КАК Район,
	|	энргЗначенияПотерьСрезПоследних.КлючПомещения КАК КлючПомещения,
	|	энргЗначенияПотерьСрезПоследних.ТочкаУчета КАК ТочкаУчета,
	|	энргЗначенияПотерьСрезПоследних.ВидПотерь КАК ВидПотерь,
	|	энргЗначенияПотерьСрезПоследних.СпособРасчетаПотерь КАК СпособРасчетаПотерь,
	|	энргЗначенияПотерьСрезПоследних.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.энргЗначенияПотерь.СрезПоследних(
	|			&Период,
	|			(Организация, Район, КлючПомещения, ТочкаУчета, ВидПотерь) В
	|				(ВЫБРАТЬ
	|					АктивныеВидыПотерь.Организация,
	|					АктивныеВидыПотерь.Район,
	|					АктивныеВидыПотерь.КлючПомещения,
	|					АктивныеВидыПотерь.ТочкаУчета,
	|					АктивныеВидыПотерь.ВидПотерь
	|				ИЗ
	|					АктивныеВидыПотерь КАК АктивныеВидыПотерь)) КАК энргЗначенияПотерьСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Район,
	|	КлючПомещения,
	|	ТочкаУчета";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#КонецЕсли