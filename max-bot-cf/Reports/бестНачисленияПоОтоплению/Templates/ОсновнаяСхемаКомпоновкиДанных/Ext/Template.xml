		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	энргОбъемНачисленийОбороты.Организация КАК Организация,
	энргОбъемНачисленийОбороты.Район КАК Район,
	энргОбъемНачисленийОбороты.МКД КАК МКД,
	энргОбъемНачисленийОбороты.Абонент КАК Абонент,
	энргОбъемНачисленийОбороты.ВидНачисления КАК ВидНачисления,
	энргОбъемНачисленийОбороты.СпособНачисления КАК СпособНачисления,
	энргОбъемНачисленийОбороты.ЗначениеТарифа КАК ЗначениеТарифа,
	энргОбъемНачисленийОбороты.ПериодРасчета КАК ПериодРасчета,
	СУММА(энргОбъемНачисленийОбороты.СуммаОборот) КАК СуммаОборот,
	СУММА(энргОбъемНачисленийОбороты.ОбъемУслугиОборот) КАК ОбъемУслугиОборот,
	СУММА(ВЫБОР
			КОГДА энргОбъемНачисленийОбороты.СпособНачисления = &amp;ПоНормативу
				ТОГДА энргОбъемНачисленийОбороты.ОбъемУслугиОборот
			ИНАЧЕ 0
		КОНЕЦ) КАК ОбъемПоНормативу,
	СУММА(ВЫБОР
			КОГДА энргОбъемНачисленийОбороты.СпособНачисления = &amp;ПоСреднему
				ТОГДА энргОбъемНачисленийОбороты.ОбъемУслугиОборот
			ИНАЧЕ 0
		КОНЕЦ) КАК ОбъемПоСреднему
ПОМЕСТИТЬ ВрТ0
ИЗ
	РегистрНакопления.энргОбъемНачислений.Обороты(
			&amp;ДатаНач,
			&amp;ДатаКон,
			,
			Организация = &amp;Организация
				И Услуга = &amp;Тепло
				И ВидНачисления = &amp;ВидНачисления) КАК энргОбъемНачисленийОбороты

СГРУППИРОВАТЬ ПО
	энргОбъемНачисленийОбороты.Район,
	энргОбъемНачисленийОбороты.ВидНачисления,
	энргОбъемНачисленийОбороты.ПериодРасчета,
	энргОбъемНачисленийОбороты.Абонент,
	энргОбъемНачисленийОбороты.Организация,
	энргОбъемНачисленийОбороты.МКД,
	энргОбъемНачисленийОбороты.СпособНачисления,
	энргОбъемНачисленийОбороты.ЗначениеТарифа
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВрТ0.Организация КАК Организация,
	ВрТ0.Район КАК Район,
	ВрТ0.МКД КАК МКД,
	ВЫРАЗИТЬ(энргАбонентыКонтактнаяИнформация.Представление КАК СТРОКА(500)) КАК Адрес,
	ВрТ0.Абонент КАК Абонент,
	ВрТ0.ВидНачисления КАК ВидНачисления,
	ВрТ0.СпособНачисления КАК СпособНачисления,
	ВрТ0.ЗначениеТарифа КАК ЗначениеТарифа,
	ВрТ0.ПериодРасчета КАК ПериодРасчета,
	ВрТ0.СуммаОборот КАК СуммаОборот,
	ВрТ0.ОбъемУслугиОборот КАК ОбъемУслугиОборот,
	энргАбоненты.ЛицевойСчет КАК Поле1,
	ЕСТЬNULL(ВложенныйЗапрос.УК, ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка)) КАК УК,
	ВрТ0.ОбъемПоНормативу КАК ОбъемПоНормативу,
	ВрТ0.ОбъемПоСреднему КАК ОбъемПоСреднему,
	энргАбоненты.Квартира КАК Квартира
ПОМЕСТИТЬ ВрТ1
ИЗ
	ВрТ0 КАК ВрТ0
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
		ПО ВрТ0.Абонент = энргАбоненты.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты.КонтактнаяИнформация КАК энргАбонентыКонтактнаяИнформация
		ПО ВрТ0.Абонент = энргАбонентыКонтактнаяИнформация.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ВложенныйЗапрос.МКД КАК МКД,
			энргФормыУправленияМКДСрезПоследних.УК КАК УК
		ИЗ
			(ВЫБРАТЬ
				ВрТ0.МКД КАК МКД
			ИЗ
				ВрТ0 КАК ВрТ0
			
			СГРУППИРОВАТЬ ПО
				ВрТ0.МКД) КАК ВложенныйЗапрос
				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.энргФормыУправленияМКД.СрезПоследних(&amp;ДатаКон, Организация = &amp;Организация) КАК энргФормыУправленияМКДСрезПоследних
				ПО ВложенныйЗапрос.МКД = энргФормыУправленияМКДСрезПоследних.МКД) КАК ВложенныйЗапрос
		ПО ВрТ0.МКД = ВложенныйЗапрос.МКД

СГРУППИРОВАТЬ ПО
	ВрТ0.Район,
	ВрТ0.МКД,
	ВрТ0.Организация,
	ВЫРАЗИТЬ(энргАбонентыКонтактнаяИнформация.Представление КАК СТРОКА(500)),
	ВрТ0.Абонент,
	ВрТ0.ПериодРасчета,
	ВрТ0.СпособНачисления,
	ВрТ0.ВидНачисления,
	энргАбоненты.ЛицевойСчет,
	ЕСТЬNULL(ВложенныйЗапрос.УК, ЗНАЧЕНИЕ(Справочник.энргКонтрагенты.ПустаяСсылка)),
	ВрТ0.ЗначениеТарифа,
	ВрТ0.СуммаОборот,
	ВрТ0.ОбъемУслугиОборот,
	ВрТ0.ОбъемПоНормативу,
	ВрТ0.ОбъемПоСреднему,
	энргАбоненты.Квартира
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВрТ1.Организация КАК Организация,
	ВрТ1.Район КАК Район,
	ВрТ1.МКД КАК МКД,
	ВрТ1.Адрес КАК Адрес,
	ВрТ1.Абонент КАК Абонент,
	ВрТ1.ВидНачисления КАК ВидНачисления,
	ВрТ1.ЗначениеТарифа КАК ЗначениеТарифа,
	ВрТ1.ПериодРасчета КАК ПериодРасчета,
	ВрТ1.СуммаОборот КАК Стоимость,
	ВрТ1.Поле1 КАК ЛицевойСчет,
	ЕСТЬNULL(энргКоличествоПроживающихСрезПоследних.Количество, 0) КАК КоличествоПроживающих,
	ВрТ1.ОбъемПоНормативу КАК ОбъемПоНормативу,
	ВрТ1.ОбъемПоСреднему КАК ОбъемПоСреднему,
	ВрТ1.УК КАК УК,
	ЕСТЬNULL(энргЗначенияПлощадейСрезПоследних.Площадь, 0) КАК Площадь,
	"Жилое" КАК ТипПомещения,
	ВрТ1.Квартира КАК Квартира
ИЗ
	ВрТ1 КАК ВрТ1
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргКоличествоПроживающих.СрезПоследних(&amp;ДатаКон, Организация = &amp;Организация) КАК энргКоличествоПроживающихСрезПоследних
		ПО ВрТ1.Организация = энргКоличествоПроживающихСрезПоследних.Организация
			И ВрТ1.Район = энргКоличествоПроживающихСрезПоследних.Район
			И ВрТ1.Абонент = энргКоличествоПроживающихСрезПоследних.Абонент
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргЗначенияПлощадей.СрезПоследних(&amp;ДатаКон, ВидПлощади = &amp;ВидПлощади) КАК энргЗначенияПлощадейСрезПоследних
		ПО ВрТ1.Организация = энргЗначенияПлощадейСрезПоследних.Организация
			И ВрТ1.Район = энргЗначенияПлощадейСрезПоследних.Район
			И ВрТ1.Абонент = энргЗначенияПлощадейСрезПоследних.Абонент

СГРУППИРОВАТЬ ПО
	ВрТ1.ПериодРасчета,
	ВрТ1.Адрес,
	ВрТ1.Поле1,
	ВрТ1.ВидНачисления,
	ВрТ1.МКД,
	ВрТ1.Район,
	ВрТ1.Абонент,
	ВрТ1.Организация,
	ВрТ1.ЗначениеТарифа,
	ВрТ1.УК,
	ЕСТЬNULL(энргЗначенияПлощадейСрезПоследних.Площадь, 0),
	ЕСТЬNULL(энргКоличествоПроживающихСрезПоследних.Количество, 0),
	ВрТ1.СуммаОборот,
	ВрТ1.ОбъемПоНормативу,
	ВрТ1.ОбъемПоСреднему,
	ВрТ1.Квартира

УПОРЯДОЧИТЬ ПО
	Организация,
	УК,
	МКД,
	Адрес,
	ЛицевойСчет</query>
	</dataSet>
