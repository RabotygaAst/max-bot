	ПараметрыОтчета.Вставить("Организация", 	Организация);
	ПараметрыОтчета.Вставить("ОбъектыРасчета", 	МассивОбъектовРасчета);

	
	СформироватьПриложенияНаСервере(ПараметрыОтчета);
	МассивПриложений = Приложения.ВыгрузитьЗначения();
