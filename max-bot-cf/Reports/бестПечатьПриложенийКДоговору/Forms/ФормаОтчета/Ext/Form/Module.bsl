Процедура ЗаполнитьСписокОбъектовРасчета()
	
	МассивОбъектовРасчета = МассивОбъектовРасчета(Организация, Район, КонецДня(Период), Договор);
	ОбъектыРасчета.ЗагрузитьЗначения(МассивОбъектовРасчета);
