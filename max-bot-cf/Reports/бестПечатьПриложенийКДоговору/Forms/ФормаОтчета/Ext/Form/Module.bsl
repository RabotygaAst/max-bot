&НаСервереБезКонтекста
Функция МассивОбъектовРасчета(Организация, Район, Период, Договор)
	
	МассивОР = Новый Массив;
	РезультатОбъектыРасчета = РегистрыСведений.бестДоговорыТочекУчета.ПолучитьДанныеДоговоров(Организация, Район, Период, Договор, , , , , Ложь);
	Выборка = РезультатОбъектыРасчета.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если МассивОР.Найти(Выборка.ОбъектРасчета) = Неопределено Тогда
			МассивОР.Добавить(Выборка.ОбъектРасчета);
		КонецЕсли;
	КонецЦикла;
	Возврат МассивОР;
	
КонецФункции

&НаКлиенте
Процедура ПослеОтметкиОбъектовРасчета(Список, Параметры) Экспорт
	
	Если ЗначениеЗаполнено(Список) Тогда
		МассивОбъектовРасчета = ОбщегоНазначенияКлиентСервер.ОтмеченныеЭлементы(Список);
	Иначе
		МассивОбъектовРасчета = ОбъектыРасчета.ВыгрузитьЗначения();
	КонецЕсли;
	
КонецПроцедуры

