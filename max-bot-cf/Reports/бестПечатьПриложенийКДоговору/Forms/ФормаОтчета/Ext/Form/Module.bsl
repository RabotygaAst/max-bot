#Область СохранениеВФайл

&НаКлиенте
Функция ЗаполнитьСоответствиеПриложений()
	
	МассивСоответствий = Новый Массив;
	
	Для Каждого Приложение Из МассивПриложений Цикл
		Если Элементы[Приложение].Видимость = Истина Тогда
			СоответствиеПриложение = Новый Соответствие;
			АдресПриложение = ПоместитьВоВременноеХранилищеНаСервере(ЭтотОбъект[Приложение], УникальныйИдентификатор);
			СоответствиеПриложение.Вставить("АдресВХранилище", АдресПриложение);
			Имя = Приложения.НайтиПоЗначению(Приложение).Представление;
			СоответствиеПриложение.Вставить("Имя", Имя);
			МассивСоответствий.Добавить(СоответствиеПриложение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивСоответствий;
	
КонецФункции

&НаКлиенте
Процедура СформироватьФайлПакетом(ИмяФайлаТаблица)  
	
	МассивСоответствий = ЗаполнитьСоответствиеПриложений();

	Пакет = Новый ПакетОтображаемыхДокументов;
	Для Каждого Приложение Из МассивСоответствий Цикл
		НазваниеПриложения = Приложение["Имя"];		
		АдресВХранилище = Приложение["АдресВХранилище"];
		
		ЭлементПакета = Пакет.Состав.Добавить();
		ЭлементПакета.Наименование = НазваниеПриложения;               
		ЭлементПакета.Данные = АдресВХранилище;
	КонецЦикла;
	
	Пакет.Записать(ИмяФайлаТаблица, ТипФайлаПакетаОтображаемыхДокументов.XLSX);
	Для Каждого Приложение Из МассивСоответствий Цикл                     
		УдалитьИзВременногоХранилища(Приложение["АдресВХранилище"]);       
	КонецЦикла;

КонецПроцедуры

