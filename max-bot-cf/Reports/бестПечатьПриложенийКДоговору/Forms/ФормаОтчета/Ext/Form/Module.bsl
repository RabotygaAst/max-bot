#Область ОписаниеПеременных

&НаКлиенте
Перем МассивОбъектовРасчета,
МассивПриложений;

#КонецОбласти

#Область ОбработчикиСобытийФормы 

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("Договор") Тогда
		Договор 	= Параметры.Договор;
		Организация = Параметры.Организация;
		Район 		= Параметры.Район;
	КонецЕсли;
	Период = ТекущаяДата();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗаполнитьСписокОбъектовРасчета();
	ЗаполнитьСписокПриложений();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДоговорПриИзменении(Элемент)
	
	ЗаполнитьСписокОбъектовРасчета();
	ЗаполнитьСписокПриложений();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыРасчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Оповещение = Новый ОписаниеОповещения("ПослеОтметкиОбъектовРасчета", ЭтотОбъект);
	ОбъектыРасчета.ПоказатьОтметкуЭлементов(Оповещение, "Объекты расчета");
	
КонецПроцедуры

&НаКлиенте
Процедура ПриложенияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Оповещение = Новый ОписаниеОповещения("ПослеОтметкиПриложений", ЭтотОбъект);
	Приложения.ПоказатьОтметкуЭлементов(Оповещение, "Приложения");
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СформироватьПриложение2_1(Команда)
	
	Если НЕ ЗначениеЗаполнено(Договор) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выберите договор");
	    Возврат;
