	//Приложение2_1.АвтоМасштаб 			= Истина;
	//
	//Приложение2_2.ОриентацияСтраницы 	= ОриентацияСтраницы.Ландшафт;
	//Приложение2_2.АвтоМасштаб 			= Истина;
	//
	//Приложение1.ОриентацияСтраницы 	= ОриентацияСтраницы.Ландшафт;
	//Приложение1.АвтоМасштаб 			= Истина;
	//
	//Приложение10.ОриентацияСтраницы 	= ОриентацияСтраницы.Ландшафт;
	//Приложение10.АвтоМасштаб 			= Истина;

КонецПроцедуры

&НаКлиенте
Процедура СохранитьВОдинФайл(Команда)
	
	СохранитьВТаблицу = Команда.Имя = "СохранитьВОдинФайлТаблица";
	
	ДиалогСохранения = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога); 
	ДиалогСохранения.Каталог = ""; 
	ДиалогСохранения.МножественныйВыбор = Ложь; 
	ДиалогСохранения.Заголовок = "Выберите каталог сохранения файла";
	
	Попытка
		Если ДиалогСохранения.Выбрать() Тогда		
			ПутьККаталогу = ДиалогСохранения.Каталог;
			
			Если Прав(ПутьККаталогу, 1) <> "\" Тогда
				КаталогСохранения = ПутьККаталогу + "\";
			Иначе
				КаталогСохранения = ПутьККаталогу; 
			КонецЕсли;
			
			ДатаИВремя = СтрЗаменить(ТекущаяДата(),":","."); 
			
			Если СохранитьВТаблицу Тогда
				ИмяФайлаТаблица = СтрШаблон("%1Приложения_%2.xlsx", КаталогСохранения, ДатаИВремя);
				СформироватьФайлПакетом(ИмяФайлаТаблица);
			Иначе
				Для Каждого Приложение Из МассивПриложений Цикл
					Если Элементы[Приложение].Видимость = Истина Тогда
						Если Приложение = "Приложение4_1" Тогда
							ИмяФайлаДокумента = СтрШаблон("%1%2_%3.pdf", КаталогСохранения, Приложение, ДатаИВремя);
							ЭтотОбъект[Приложение].Записать(ИмяФайлаДокумента, ТипФайлаТабличногоДокумента.PDF);
							Продолжить;
						КонецЕсли;
						ИмяФайлаДокумента = СтрШаблон("%1%2_%3.docx", КаталогСохранения, Приложение, ДатаИВремя);
						ЭтотОбъект[Приложение].Записать(ИмяФайлаДокумента, ТипФайлаТабличногоДокумента.DOCX);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Выгрузка данных успешно завершена!'"));
		КонецЕсли;
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось сохранить файл");
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр(ОписаниеОшибки()));
	КонецПопытки;
	
КонецПроцедуры 

