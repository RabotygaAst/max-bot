		<field xsi:type="DataSetFieldField">
			<dataPath>Сторно</dataPath>
			<field>Сторно</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сторно</v8:content>
				</v8:item>
