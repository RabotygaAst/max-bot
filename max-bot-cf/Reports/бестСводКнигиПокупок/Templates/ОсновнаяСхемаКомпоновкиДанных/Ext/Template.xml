		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СторноНДС</dataPath>
			<field>СторноНДС</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сторно НДС</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СторноБезНДС</dataPath>
			<field>СторноБезНДС</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сторно без НДС</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ВЫБОР
		КОГДА бестАвансыЭЭ.ПериодНачисления = &amp;НачалоМесяца
			ТОГДА бестАвансыЭЭ.Сумма
		ИНАЧЕ 0
	КОНЕЦ КАК Переплата,
	ВЫБОР
		КОГДА бестАвансыЭЭ.ПериодНачисления = &amp;НачалоМесяца
			ТОГДА бестАвансыЭЭ.СуммаНДС
		ИНАЧЕ 0
	КОНЕЦ КАК ПереплатаНДС,
	ВЫБОР
		КОГДА бестАвансыЭЭ.ПериодНачисления = &amp;НачалоМесяца
			ТОГДА бестАвансыЭЭ.Сумма - бестАвансыЭЭ.СуммаНДС
		ИНАЧЕ 0
	КОНЕЦ КАК ПереплатаБезНДС,
	ВЫБОР
		КОГДА бестАвансыЭЭ.ПериодНачисления = &amp;НачалоМесяца
			ТОГДА 0
		ИНАЧЕ бестАвансыЭЭ.Сумма
	КОНЕЦ КАК Сторно,
	ВЫБОР
		КОГДА бестАвансыЭЭ.ПериодНачисления = &amp;НачалоМесяца
			ТОГДА 0
		ИНАЧЕ бестАвансыЭЭ.СуммаНДС
	КОНЕЦ КАК СторноНДС,
	ВЫБОР
		КОГДА бестАвансыЭЭ.ПериодНачисления = &amp;НачалоМесяца
			ТОГДА 0
		ИНАЧЕ бестАвансыЭЭ.Сумма - бестАвансыЭЭ.СуммаНДС
	КОНЕЦ КАК СторноБезНДС
ИЗ
	РегистрНакопления.бестАвансыЭЭ КАК бестАвансыЭЭ
ГДЕ
	бестАвансыЭЭ.Период МЕЖДУ &amp;НачалоМесяца И &amp;КонецМесяца
	И бестАвансыЭЭ.Организация = &amp;Организация
	И бестАвансыЭЭ.Район = &amp;Район
	И бестАвансыЭЭ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.расход)</query>
	</dataSet>
