		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ВРТ_ЗакрытиеЛС.Дата КАК Дата,
	ВРТ_ЗакрытиеЛС.Номер КАК Номер,
	ВРТ_ЗакрытиеЛС.Абонент КАК Абонент,
	ВРТ_ЗакрытиеЛС.АдресОбъекта КАК АдресОбъекта,
	ВРТ_ЗакрытиеЛС.Примечание КАК Примечание,
	ВРТ_ЗакрытиеЛС.Автор КАК Автор,
	ВРТ_ЗакрытиеЛС.Причина КАК Причина,
	ВРТ_ЗакрытиеЛС.ЛицевойСчет КАК ЛицевойСчет,
	NULL КАК НомерВодомера,
	NULL КАК КонечныеПоказания,
	NULL КАК Инспектор,
	NULL КАК ТипВодомера,
	NULL КАК СпособУстановки,
	NULL КАК СрокПоверки,
	NULL КАК Услуга,
	NULL КАК СуммаОплаты
ИЗ
	(ВЫБРАТЬ
		энргОперацияСЛицевымСчетом.Дата КАК Дата,
		энргОперацияСЛицевымСчетом.Номер КАК Номер,
		энргОперацияСЛицевымСчетом.Абонент КАК Абонент,
		(ВЫРАЗИТЬ(энргСтроенияКонтактнаяИнформация.Представление КАК СТРОКА(200))) + ВЫБОР
			КОГДА энргКлючиПомещений.Помещение ЕСТЬ NULL
					ИЛИ энргКлючиПомещений.Помещение = ЗНАЧЕНИЕ(Справочник.энргПомещения.ПустаяСсылка)
				ТОГДА ""
			ИНАЧЕ ", " + ВЫБОР
					КОГДА энргКлючиПомещений.Помещение.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.Квартира)
						ТОГДА "квартира "
					КОГДА энргКлючиПомещений.Помещение.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.Комната)
						ТОГДА "комната "
					КОГДА энргКлючиПомещений.Помещение.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.КойкоМесто)
						ТОГДА "койко-место "
					ИНАЧЕ ""
				КОНЕЦ + энргКлючиПомещений.Помещение.Наименование
		КОНЕЦ КАК АдресОбъекта,
		энргОперацияСЛицевымСчетом.Примечание КАК Примечание,
		энргОперацияСЛицевымСчетом.Ответственный КАК Автор,
		"" КАК Причина,
		энргАбоненты.ЛицевойСчет КАК ЛицевойСчет
	ИЗ
		Документ.энргОперацияСЛицевымСчетом КАК энргОперацияСЛицевымСчетом
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
			ПО энргОперацияСЛицевымСчетом.Абонент = энргАбоненты.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
			ПО энргОперацияСЛицевымСчетом.КлючПомещения = энргКлючиПомещений.КлючПомещения
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
			ПО (энргКлючиПомещений.Строение = энргСтроенияКонтактнаяИнформация.Ссылка)
				И (энргСтроенияКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресДома))
	ГДЕ
		энргОперацияСЛицевымСчетом.Проведен = ИСТИНА
		И энргОперацияСЛицевымСчетом.Дата МЕЖДУ &amp;ДатаНач И &amp;ДатаКон
		И энргОперацияСЛицевымСчетом.ВидОперации = &amp;ВидОперации) КАК ВРТ_ЗакрытиеЛС

СГРУППИРОВАТЬ ПО
	ВРТ_ЗакрытиеЛС.Абонент,
	ВРТ_ЗакрытиеЛС.Дата,
	ВРТ_ЗакрытиеЛС.Номер,
	ВРТ_ЗакрытиеЛС.Примечание,
	ВРТ_ЗакрытиеЛС.АдресОбъекта,
	ВРТ_ЗакрытиеЛС.Автор,
	ВРТ_ЗакрытиеЛС.Причина,
	ВРТ_ЗакрытиеЛС.ЛицевойСчет

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВРТ_АктВводаПУ.Дата,
	ВРТ_АктВводаПУ.Номер,
	ВРТ_АктВводаПУ.Абонент,
	ВРТ_АктВводаПУ.АдресОбъекта,
	ВРТ_АктВводаПУ.Примечание,
	ВРТ_АктВводаПУ.Автор,
	ВРТ_АктВводаПУ.Причина,
	ВРТ_АктВводаПУ.ЛицевойСчет,
	ВРТ_АктВводаПУ.НомерВодомера,
	ВРТ_АктВводаПУ.КонечныеПоказания,
	ВРТ_АктВводаПУ.Инспектор,
	ВРТ_АктВводаПУ.ТипВодомера,
	ВРТ_АктВводаПУ.СпособУстановки,
	ВРТ_АктВводаПУ.СрокПоверки,
	NULL,
	NULL
ИЗ
	(ВЫБРАТЬ
		энргОперацияСПриборомУчета.Дата КАК Дата,
		энргОперацияСПриборомУчета.Номер КАК Номер,
		энргОперацияСПриборомУчета.Абонент КАК Абонент,
		(ВЫРАЗИТЬ(энргСтроенияКонтактнаяИнформация.Представление КАК СТРОКА(200))) + ВЫБОР
			КОГДА энргКлючиПомещений.Помещение ЕСТЬ NULL
					ИЛИ энргКлючиПомещений.Помещение = ЗНАЧЕНИЕ(Справочник.энргПомещения.ПустаяСсылка)
				ТОГДА ""
			ИНАЧЕ ", " + ВЫБОР
					КОГДА энргКлючиПомещений.Помещение.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.Квартира)
						ТОГДА "квартира "
					КОГДА энргКлючиПомещений.Помещение.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.Комната)
						ТОГДА "комната "
					КОГДА энргКлючиПомещений.Помещение.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.КойкоМесто)
						ТОГДА "койко-место "
					ИНАЧЕ ""
				КОНЕЦ + энргКлючиПомещений.Помещение.Наименование
		КОНЕЦ КАК АдресОбъекта,
		энргОперацияСПриборомУчета.Примечание КАК Примечание,
		энргОперацияСПриборомУчета.Ответственный КАК Автор,
		"" КАК Причина,
		ЕСТЬNULL(энргАбоненты.ЛицевойСчет, "") КАК ЛицевойСчет,
		ЕСТЬNULL(энргОперацияСПриборомУчетаПоказанияПУВВод.ПриборУчета, ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)) КАК НомерВодомера,
		0 КАК КонечныеПоказания,
		энргОперацияСПриборомУчета.Контроллер КАК Инспектор,
		энргОперацияСПриборомУчетаПоказанияПУВВод.ПриборУчета.ТипПрибораУчета КАК ТипВодомера,
		энргОперацияСПриборомУчетаПоказанияПУВВод.ТочкаУчета КАК СпособУстановки,
		энргОперацияСПриборомУчетаПоказанияПУВВод.ДатаПоверкиСчетчика КАК СрокПоверки
	ИЗ
		Документ.энргОперацияСПриборомУчета КАК энргОперацияСПриборомУчета
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргАбоненты КАК энргАбоненты
			ПО энргОперацияСПриборомУчета.Абонент = энргАбоненты.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргОперацияСПриборомУчета.ТочкиУчета КАК энргОперацияСПриборомУчетаПоказанияПУВВод
			ПО энргОперацияСПриборомУчета.Ссылка = энргОперацияСПриборомУчетаПоказанияПУВВод.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.энргКлючиПомещений КАК энргКлючиПомещений
			ПО энргОперацияСПриборомУчета.КлючПомещения = энргКлючиПомещений.КлючПомещения
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.энргСтроения.КонтактнаяИнформация КАК энргСтроенияКонтактнаяИнформация
			ПО (энргКлючиПомещений.Строение = энргСтроенияКонтактнаяИнформация.Ссылка)
				И (энргСтроенияКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресДома))
	ГДЕ
		энргОперацияСПриборомУчета.Проведен = ИСТИНА
		И энргОперацияСПриборомУчета.Дата МЕЖДУ &amp;ДатаНач И &amp;ДатаКон
		И энргОперацияСПриборомУчета.ВидОперации = &amp;ВидОперации) КАК ВРТ_АктВводаПУ

СГРУППИРОВАТЬ ПО
	ВРТ_АктВводаПУ.Абонент,
	ВРТ_АктВводаПУ.Дата,
	ВРТ_АктВводаПУ.Номер,
	ВРТ_АктВводаПУ.Примечание,
	ВРТ_АктВводаПУ.АдресОбъекта,
	ВРТ_АктВводаПУ.Автор,
	ВРТ_АктВводаПУ.Причина,
	ВРТ_АктВводаПУ.ЛицевойСчет,
	ВРТ_АктВводаПУ.НомерВодомера,
	ВРТ_АктВводаПУ.Инспектор,
	ВРТ_АктВводаПУ.КонечныеПоказания,
	ВРТ_АктВводаПУ.ТипВодомера,
	ВРТ_АктВводаПУ.СпособУстановки,
	ВРТ_АктВводаПУ.СрокПоверки

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	энргОперацияСУслугами.Дата,
	энргОперацияСУслугами.Номер,
	энргОперацияСУслугами.Абонент,
	(ВЫРАЗИТЬ(энргСтроенияКонтактнаяИнформация.Представление КАК СТРОКА(200))) + ВЫБОР
		КОГДА энргКлючиПомещений.Помещение ЕСТЬ NULL
				ИЛИ энргКлючиПомещений.Помещение = ЗНАЧЕНИЕ(Справочник.энргПомещения.ПустаяСсылка)
			ТОГДА ""
		ИНАЧЕ ", " + ВЫБОР
				КОГДА энргКлючиПомещений.Помещение.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.Квартира)
					ТОГДА "квартира "
				КОГДА энргКлючиПомещений.Помещение.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.Комната)
					ТОГДА "комната "
				КОГДА энргКлючиПомещений.Помещение.ТипПомещения = ЗНАЧЕНИЕ(Перечисление.энргТипыПомещений.КойкоМесто)
					ТОГДА "койко-место "
				ИНАЧЕ ""
			КОНЕЦ + энргКлючиПомещений.Помещение.Наименование
	КОНЕЦ,
	энргОперацияСУслугами.Примечание,
	энргОперацияСУслугами.Ответственный,
	"",
	ЕСТЬNULL(энргАбоненты.ЛицевойСчет, ""),
	ЕСТЬNULL(энргОперацияСУслугамиТочкиУчета.ПриборУчета, ЗНАЧЕНИЕ(Справочник.энргПриборыУчетаАбонента.ПустаяСсылка)),
	0,
	энргОперацияСУслугами.Контроллер,
	энргОперацияСУслугамиТочкиУчета.ПриборУчета.ТипПрибораУчета,
	NULL,
	энргОперацияСУслугамиТочкиУчета.ДатаПоверкиСчетчика,
	энргОперацияСУслугамиТочкиУчета.Услуга,
	NULL
ИЗ
	Документ.энргОперацияСУслугами КАК энргОперацияСУслугами
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.энргОперацияСУслугами.ТочкиУчета КАК энргОперацияСУслугамиТочкиУчета
		ПО энргОперацияСУслугами.Ссылка = энргОперацияСУслугамиТочкиУчета.Ссылка
